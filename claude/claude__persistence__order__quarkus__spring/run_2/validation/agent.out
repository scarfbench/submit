Info\") String newOrderShippingInfo,\n    33→            Model model) {\n    34→        orderController.submitOrder(newOrderId, newOrderStatus.charAt(0), newOrderDiscount, newOrderShippingInfo);\n    35→        model.addAttribute(\"orders\", orderController.getOrders());\n    36→        model.addAttribute(\"vendorName\", null);\n    37→        model.addAttribute(\"vendorSearchResults\", null);\n    38→        model.addAttribute(\"findVendorTableDisabled\", false);\n    39→        return \"orders\";\n    40→    }\n    41→\n    42→    @PostMapping(\"/removeOrder\")\n    43→    public String removeOrder(@RequestParam(\"orderId\") Integer orderId, Model model) {\n    44→        orderController.removeOrder(orderId);\n    45→        model.addAttribute(\"orders\", orderController.getOrders());\n    46→        model.addAttribute(\"vendorName\", null);\n    47→        model.addAttribute(\"vendorSearchResults\", null);\n    48→        model.addAttribute(\"findVendorTableDisabled\", false);\n    49→        return \"orders\";\n    50→    }\n    51→\n    52→    @GetMapping(\"/lineItems\")\n    53→    public String getLineItems(@RequestParam(\"orderId\") Integer orderId, Model model) {\n    54→        model.addAttribute(\"currentOrder\", orderId);\n    55→        model.addAttribute(\"lineItems\", orderController.getLineItems(orderId));\n    56→        model.addAttribute(\"newOrderParts\", orderController.getNewOrderParts());\n    57→        return \"lineItems\";\n    58→    }\n    59→\n    60→    @PostMapping(\"/addLineItem\")\n    61→    public String addLineItem(\n    62→            @RequestParam(\"currentOrder\") Integer currentOrder,\n    63→            @RequestParam(\"selectedPartNumber\") String selectedPartNumber,\n    64→            @RequestParam(\"selectedPartRevision\") int selectedPartRevision,\n    65→            Model model) {\n    66→        orderController.addLineItem(currentOrder, selectedPartNumber, selectedPartRevision);\n    67→        model.addAttribute(\"currentOrder\", currentOrder);\n    68→        model.addAttribute(\"lineItems\", orderController.getLineItems(currentOrder));\n    69→        model.addAttribute(\"newOrderParts\", orderController.getNewOrderParts());\n    70→        return \"lineItems\";\n    71→    }\n    72→\n    73→    @PostMapping(\"/findVendor\")\n    74→    public String findVendor(@RequestParam(\"vendorName\") String vendorName, Model model) {\n    75→        model.addAttribute(\"orders\", orderController.getOrders());\n    76→        model.addAttribute(\"vendorName\", vendorName);\n    77→        model.addAttribute(\"vendorSearchResults\", orderController.findVendor(vendorName));\n    78→        model.addAttribute(\"findVendorTableDisabled\", true);\n    79→        return \"orders\";\n    80→    }\n    81→}\n    82→"}]},"parent_tool_use_id":null,"session_id":"5f91f76d-f7c8-410d-aa56-1490dbe7b4c7","uuid":"7781b74c-b597-4644-9534-d7c95df836d8"}
