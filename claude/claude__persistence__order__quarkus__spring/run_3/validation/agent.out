\"post\" action=\"/addLineItem\">\n    36→                    <input type=\"hidden\" name=\"currentOrder\" th:value=\"${currentOrder}\"/>\n    37→                    <input type=\"hidden\" name=\"selectedPartNumber\" th:value=\"${part.partNumber}\"/>\n    38→                    <input type=\"hidden\" name=\"selectedPartRevision\" th:value=\"${part.revision}\"/>\n    39→                    <button type=\"submit\">Add</button>\n    40→                </form>\n    41→            </td>\n    42→        </tr>\n    43→    </table>\n    44→    <br/>\n    45→    <a href=\"/orders\">Back to Orders</a>\n    46→</body>\n    47→</html>\n    48→"}]},"parent_tool_use_id":null,"session_id":"9a19d292-8d72-47c8-a27b-ee917a0b25a7","uuid":"5f0eae5e-b1bb-43ef-bbe4-00c715e1aef3"}
