.\n\nRUN if [ -f smoke.py ]; then chmod +x smoke.py; fi\n\n# Build the application at image build time\nRUN mvn clean package -DskipTests\n\nCMD [\"java\", \"-jar\", \"target/order-spring-1.0.0-SNAPSHOT.jar\"]"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1983,"cache_read_input_tokens":58423,"cache_creation":{"ephemeral_5m_input_tokens":1983,"ephemeral_1h_input_tokens":0},"output_tokens":3658},"context_management":null},"parent_tool_use_id":null,"session_id":"380c2ee0-cd4b-46ce-87c8-68ac4fb04c36","uuid":"3f3a2d95-ea6d-4913-821d-aea8b5ba07af"}
