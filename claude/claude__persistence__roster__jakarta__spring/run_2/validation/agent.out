n CHANGELOG.md"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8287,"cache_read_input_tokens":70613,"cache_creation":{"ephemeral_5m_input_tokens":8287,"ephemeral_1h_input_tokens":0},"output_tokens":524},"context_management":null},"parent_tool_use_id":null,"session_id":"7aa9e9e3-b010-487c-a19d-8b03349f63ee","uuid":"2bd56007-61a0-4a97-9226-91659590250e"}
