ng changes in CHANGELOG.md"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":152,"cache_read_input_tokens":108664,"cache_creation":{"ephemeral_5m_input_tokens":152,"ephemeral_1h_input_tokens":0},"output_tokens":502},"context_management":null},"parent_tool_use_id":null,"session_id":"7aa9e9e3-b010-487c-a19d-8b03349f63ee","uuid":"ae5a752f-7cc8-4c02-af60-16896977ca85"}
