sponsive\" alt=\"gallery6\">\n   845→                        </a>\n   846→                    </div>\n   847→                    <div class=\"col-md-4 image wow fadeIn\" data-wow-delay=\"900ms\" >\n   848→                        <a href=\"images/gallery9.png\" data-bs-toggle=\"lightbox\" data-gallery=\"lava-gallery\">\n   849→                            <img src=\"images/gallery9.png\" class=\"img-responsive\" alt=\"gallery6\">\n   850→                        </a>\n   851→                    </div>\n   852→                </div>\n   853→            </div>\n   854→        </div>\n   855→    </div>\n   856→</section>\n   857→<span class=\"anchor\" id=\"reservation\"></span>\n   858→<section class=\"cat\">\n   859→    <div class=\"container-fluid padding-2x\">\n   860→        <div class=\"row\">\n   861→            <div class=\"col-xs-12\">\n   862→                <div class=\"container\">\n   863→                    <div class=\"row\">\n   864→                        <div class=\"col-xs-12\">\n   865→                            <h4>Want to make a reservation? <i class=\"fa fa-phone\"></i> Call 012-345-6789</h4>\n   866→                        </div>\n   867→                    </div>\n   868→                </div>\n   869→            </div>\n   870→        </div>\n   871→    </div>\n   872→</section>\n   873→<span class=\"anchor\" id=\"contact\"></span>\n   874→<section class=\"contact\">\n   875→    <div class=\"container padding-2x\">\n   876→        <div class=\"row text-wrap\">\n   877→            <div class=\"col-sm-12\">\n   878→                <h3 class=\"text-center\">Contact</h3>\n   879→                <hr>\n   880→                <p>Want to talk to a Red Hatter about Quarkus, Kafka, or Kubernetes?  Or let us know what you thought about the demo?</p>\n   881→            </div>\n   882→        </div>\n   883→        <div class=\"row\">\n   884→            <div class=\"col-xs-12 col-md-8 col-md-offset-2\">\n   885→                <form>\n   886→               