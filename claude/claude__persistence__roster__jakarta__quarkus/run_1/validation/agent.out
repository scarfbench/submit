et(f\"{BASE_URL}/team/{tid}/players\")\n   170→        assert r.status_code == 200\n   171→        data = r.json()\n   172→        ids = [p[\"id\"] for p in data]\n   173→        assert pid in ids\n   174→\n   175→    def test_get_all_players(self):\n   176→        \"\"\"Get all players.\"\"\"\n   177→        r = requests.get(f\"{BASE_URL}/players\")\n   178→        assert r.status_code == 200\n   179→        data = r.json()\n   180→        assert isinstance(data, list)\n   181→\n   182→    def test_get_nonexistent_player(self):\n   183→        \"\"\"Verify 404 for a nonexistent player.\"\"\"\n   184→        r = requests.get(f\"{BASE_URL}/player/NONEXISTENT\")\n   185→        assert r.status_code == 404\n   186→\n   187→    def test_get_players_not_on_team(self):\n   188→        \"\"\"Get players not on any team.\"\"\"\n   189→        r = requests.get(f\"{BASE_URL}/players/not-on-team\")\n   190→        assert r.status_code == 200\n   191→        data = r.json()\n   192→        assert isinstance(data, list)\n   193→\n   194→    def test_get_players_by_position(self):\n   195→        \"\"\"Get players by position.\"\"\"\n   196→        pid = f\"PP{_RUN_ID}\"\n   197→        requests.post(\n   198→            f\"{BASE_URL}/player?id={pid}&name=Pos+Test&position=goalkeeper&salary=100.0\")\n   199→        r = requests.get(f\"{BASE_URL}/players/position/goalkeeper\")\n   200→        assert r.status_code == 200\n   201→        data = r.json()\n   202→        assert isinstance(data, list)\n   203→        assert any(p[\"position\"] == \"goalkeeper\" for p in data)\n   204→\n   205→    def test_get_players_by_salary_range(self):\n   206→        \"\"\"Get players by salary range.\"\"\"\n   207→        r = requests.get(f\"{BASE_URL}/players/salary/range?low=100&high=600\")\n   208→        assert r.status_code == 200\n   209→        data = r.json()\n   210→        assert isinstance(data, list)\n   211→\n   212→    def test_remove_player(self):\n   213→        \"\"\"Remove a player and verify it's gone.\"\"\"\n   214→        pid = f\"PD{_RUN_ID}\"\n   215→        requests.post(\n   216→            f\"{BASE_URL}/player?id={pid}&name=Del+Test&position=bench&salary=50.0\")\n   217→        r = requests.delete(f\"{BASE_URL}/player/{pid}\")\n   218→        assert r.status_code == 200\n   219→\n   220→        r = requests.get(f\"{BASE_URL}/player/{pid}\")\n   221→        assert r.status_code == 404\n   222→\n   223→\n   224→class TestQueryEndpoints:\n   225→    \"\"\"Tests for query-related REST endpoints.\"\"\"\n   226→\n   227→    def test_get_players_by_league(self):\n   228→        \"\"\"Query players by league ID.\"\"\"\n   229→        r = requests.get(f\"{BASE_URL}/players/league/L1\")\n   230→        assert r.status_code == 200\n   231→        data = r.json()\n   232→        assert isinstance(data, list)\n   233→\n   234→    def test_get_players_by_sport(self):\n   235→        \"\"\"Query players by sport.\"\"\"\n   236→        r = requests.get(f\"{BASE_URL}/players/sport/Soccer\")\n   237→        assert r.status_code == 200\n   238→        data = r.json()\n   239→        assert isinstance(data, list)\n   240→\n   241→    def test_get_players_by_city(self):\n   242→        \"\"\"Query players by city.\"\"\"\n   243→        r = requests.get(f\"{BASE_URL}/players/city/PlayerCity\")\n   244→        assert r.status_code == 200\n   245→        data = r.json()\n   246→        assert isinstance(data, list)\n   247→\n   248→    def test_get_player_leagues(self):\n   249→        \"\"\"Get leagues of a player that was added to a team.\"\"\"\n   250→        pid = f\"PQ{_RUN_ID}\"\n   251→        tid = f\"TQ{_RUN_ID}\"\n   252→        requests.post(\n   253→            f\"{BASE_URL}/player?id={pid}&name=Query+Test&position=defender&salary=200.0\")\n   254→        team = {\"id\": tid, \"name\": \"Query Team\", \"city\": \"QueryCity\"}\n   255→        requests.post(f\"{BASE_URL}/team/league/L1\",\n   256→                      json=team,\n   257→                      headers={\"Content-Type\": \"application/json\"})\n   258→        requests.post(f\"{BASE_URL}/player/{pid}/team/{tid}\")\n   259→\n   260→        r = requests.get(f\"{BASE_URL}/player/{pid}/leagues\")\n   261→        assert r.status_code == 200\n   262→        data = r.json()\n   263→        assert isinstance(data, list)\n   264→        assert any(l[\"id\"] == \"L1\" for l in data)\n   265→\n   266→    def test_get_player_sports(self):\n   267→        \"\"\"Get sports of a player.\"\"\"\n   268→        pid = f\"PQ{_RUN_ID}\"\n   269→        r = requests.get(f\"{BASE_URL}/player/{pid}/sports\")\n   270→        assert r.status_code == 200\n   271→        data = r.json()\n   272→        assert isinstance(data, list)\n   273→        assert \"Soccer\" in data\n   274→\n   275→\n   276→if __name__ == \"__main__\":\n   277→    print(f\"Waiting for application at {BASE_URL}...\")\n   278→    if not wait_for_ready():\n   279→        print(\"ERROR: Application did not become ready in time.\")\n   280→        sys.exit(1)\n   281→    print(\"Application is ready. Running tests...\")\n   282→    sys.exit(pytest.main([__file__, \"-v\", \"--tb=short\"]))\n   283→"}]},"parent_tool_use_id":null,"session_id":"40d6367f-f3fd-4de9-a25e-2a8ba1c4e96f","uuid":"c766b63b-0808-4554-8070-fd6015e7d195"}
