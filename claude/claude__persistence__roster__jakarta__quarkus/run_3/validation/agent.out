utorial.roster.entity.League_;\n    37→import jakartaee.tutorial.roster.entity.Player;\n    38→import jakartaee.tutorial.roster.entity.Player_;\n    39→import jakartaee.tutorial.roster.entity.SummerLeague;\n    40→import jakartaee.tutorial.roster.entity.Team;\n    41→import jakartaee.tutorial.roster.entity.Team_;\n    42→import jakartaee.tutorial.roster.entity.WinterLeague;\n    43→\n    44→/**\n    45→ * CDI bean replacing the former EJB RequestBean.\n    46→ * Migrated from @Stateful @LocalBean to @ApplicationScoped @Transactional.\n    47→ */\n    48→@ApplicationScoped\n    49→@Transactional\n    50→public class RequestBean implements Request {\n    51→\n    52→    private static final Logger logger = Logger.getLogger(\"roster.request.RequestBean\");\n    53→\n    54→    @PersistenceContext\n    55→    EntityManager em;\n    56→\n    57→    private CriteriaBuilder cb() {\n    58→        return em.getCriteriaBuilder();\n    59→    }\n    60→\n    61→    @Override\n    62→    public void createPlayer(String id,\n    63→            String name,\n    64→            String position,\n    65→            double salary) {\n    66→        logger.info(\"createPlayer\");\n    67→        Player player = new Player(id, name, position, salary);\n    68→        em.persist(player);\n    69→    }\n    70→\n    71→    @Override\n    72→    public void addPlayer(String playerId, String teamId) {\n    73→        logger.info(\"addPlayer\");\n    74→        Player player = em.find(Player.class, playerId);\n    75→        Team team = em.find(Team.class, teamId);\n    76→        team.addPlayer(player);\n    77→        player.addTeam(team);\n    78→    }\n    79→\n    80→    @Override\n    81→    public void removePlayer(String playerId) {\n    82→        logger.info(\"removePlayer\");\n    83→        Player player = em.find(Player.class, playerId);\n    84→        Collection<Team> teams = player.getTeams();\n    85→        Iterator<Team> i = teams.iterator();\n    86→        while (i.hasNext()) {\n    87→            Team team = i.next();\n    88→            team.dropPlayer(player);\n    89→        }\n    90→        em.remove(player);\n    91→    }\n    92→\n    93→    @Override\n    94→    public void dropPlayer(String playerId, String teamId) {\n    95→        logger.info(\"dropPlayer\");\n    96→        Player player = em.find(Player.class, playerId);\n    97→        Team team = em.find(Team.class, teamId);\n    98→        team.dropPlayer(player);\n    99→        player.dropTeam(team);\n   100→    }\n   101→\n   102→    @Override\n   103→    public PlayerDetails getPlayer(String playerId) {\n   104→        logger.info(\"getPlayerDetails\");\n   105→        Player player = em.find(Player.class, playerId);\n   106→        if (player == null) {\n   107→            return null;\n   108→        }\n   109→        return new PlayerDetails(player.getId(),\n   110→                player.getName(),\n   111→                player.getPosition(),\n   112→                player.getSalary());\n   113→    }\n   114→\n   115→    @Override\n   116→    public List<PlayerDetails> getPlayersOfTeam(String teamId) {\n   117→        logger.info(\"getPlayersOfTeam\");\n   118→        Team team = em.find(Team.class, teamId);\n   119→        return this.copyPlayersToDetails(new ArrayList<>(team.getPlayers()));\n   120→    }\n   121→\n   122→    @Override\n   123→    public List<LeagueDetails> getAllLeagues() {\n   124→        logger.info(\"getAllLeagues\");\n   125→        CriteriaBuilder cb = cb();\n   126→        CriteriaQuery<League> cq = cb.createQuery(League.class);\n   127→        Root<League> league = cq.from(League.class);\n   128→        cq.select(league);\n   129→        cq.orderBy(cb.asc(league.get(League_.id)));\n   130→        List<League> leagues = em.createQuery(cq).getResultList();\n   131→\n   132→        List<LeagueDetails> details = new ArrayList<>();\n   133→        for (League l : leagues) {\n   134→            details.add(new LeagueDetails(l.getId(), l.getName(), l.getSport()));\n   135→        }\n   136→        return details;\n   137→    }\n   138→\n   139→    @Override\n   140→    public List<TeamDetails> getTeamsOfLeague(String leagueId) {\n   141→        logger.info(\"getTeamsOfLeague\");\n   142→        List<TeamDetails> detailsList = new ArrayList<>();\n   143→\n   144→        League league = em.find(League.class, leagueId);\n   145→        Collection<Team> teams = league.getTeams();\n   146→\n   147→        Iterator<Team> i = teams.iterator();\n   148→        while (i.hasNext()) {\n   149→            Team team = (Team) i.next();\n   150→            TeamDetails teamDetails = new TeamDetails(team.getId(),\n   151→                    team.getName(),\n   152→                    team.getCity());\n   153→            detailsList.add(teamDetails);\n   154→        }\n   155→        return detailsList;\n   156→    }\n   157→\n   158→    @Override\n   159→    public List<PlayerDetails> getPlayersByPosition(String position) {\n   160→        logger.info(\"getPlayersByPosition\");\n   161→        CriteriaBuilder cb = cb();\n   162→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   163→        Root<Player> player = cq.from(Player.class);\n   164→        cq.where(cb.equal(player.get(Player_.position), position));\n   165→        cq.select(player);\n   166→        TypedQuery<Player> q = em.createQuery(cq);\n   167→        return copyPlayersToDetails(q.getResultList());\n   168→    }\n   169→\n   170→    @Override\n   171→    public List<PlayerDetails> getPlayersByHigherSalary(String name) {\n   172→        logger.info(\"getPlayersByHigherSalary\");\n   173→        CriteriaBuilder cb = cb();\n   174→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   175→        Root<Player> player1 = cq.from(Player.class);\n   176→        Root<Player> player2 = cq.from(Player.class);\n   177→\n   178→        Predicate gtPredicate = cb.greaterThan(\n   179→                player1.get(Player_.salary),\n   180→                player2.get(Player_.salary));\n   181→        Predicate equalPredicate = cb.equal(\n   182→                player2.get(Player_.name),\n   183→                name);\n   184→        cq.where(gtPredicate, equalPredicate);\n   185→        cq.select(player1).distinct(true);\n   186→        TypedQuery<Player> q = em.createQuery(cq);\n   187→        return copyPlayersToDetails(q.getResultList());\n   188→    }\n   189→\n   190→    @Override\n   191→    public List<PlayerDetails> getPlayersBySalaryRange(double low, double high) {\n   192→        logger.info(\"getPlayersBySalaryRange\");\n   193→        CriteriaBuilder cb = cb();\n   194→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   195→        Root<Player> player = cq.from(Player.class);\n   196→        cq.where(cb.between(player.get(Player_.salary), low, high));\n   197→        cq.select(player).distinct(true);\n   198→        TypedQuery<Player> q = em.createQuery(cq);\n   199→        return copyPlayersToDetails(q.getResultList());\n   200→    }\n   201→\n   202→    @Override\n   203→    public List<PlayerDetails> getPlayersByLeagueId(String leagueId) {\n   204→        logger.info(\"getPlayersByLeagueId\");\n   205→        CriteriaBuilder cb = cb();\n   206→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   207→        Root<Player> player = cq.from(Player.class);\n   208→        Join<Player, Team> team = player.join(Player_.teams);\n   209→        Join<Team, League> league = team.join(Team_.league);\n   210→        cq.where(cb.equal(league.get(League_.id), leagueId));\n   211→        cq.select(player).distinct(true);\n   212→        TypedQuery<Player> q = em.createQuery(cq);\n   213→        return copyPlayersToDetails(q.getResultList());\n   214→    }\n   215→\n   216→    @Override\n   217→    public List<PlayerDetails> getPlayersBySport(String sport) {\n   218→        logger.info(\"getPlayersBySport\");\n   219→        CriteriaBuilder cb = cb();\n   220→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   221→        Root<Player> player = cq.from(Player.class);\n   222→        Join<Player, Team> team = player.join(Player_.teams);\n   223→        Join<Team, League> league = team.join(Team_.league);\n   224→        cq.where(cb.equal(league.get(League_.sport), sport));\n   225→        cq.select(player).distinct(true);\n   226→        TypedQuery<Player> q = em.createQuery(cq);\n   227→        return copyPlayersToDetails(q.getResultList());\n   228→    }\n   229→\n   230→    @Override\n   231→    public List<PlayerDetails> getPlayersByCity(String city) {\n   232→        logger.info(\"getPlayersByCity\");\n   233→        CriteriaBuilder cb = cb();\n   234→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   235→        Root<Player> player = cq.from(Player.class);\n   236→        Join<Player, Team> team = player.join(Player_.teams);\n   237→        cq.where(cb.equal(team.get(Team_.city), city));\n   238→        cq.select(player).distinct(true);\n   239→        TypedQuery<Player> q = em.createQuery(cq);\n   240→        return copyPlayersToDetails(q.getResultList());\n   241→    }\n   242→\n   243→    @Override\n   244→    public List<PlayerDetails> getAllPlayers() {\n   245→        logger.info(\"getAllPlayers\");\n   246→        CriteriaBuilder cb = cb();\n   247→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   248→        Root<Player> player = cq.from(Player.class);\n   249→        cq.select(player);\n   250→        TypedQuery<Player> q = em.createQuery(cq);\n   251→        return copyPlayersToDetails(q.getResultList());\n   252→    }\n   253→\n   254→    @Override\n   255→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   256→        logger.info(\"getPlayersNotOnTeam\");\n   257→        CriteriaBuilder cb = cb();\n   258→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   259→        Root<Player> player = cq.from(Player.class);\n   260→        cq.where(cb.isEmpty(player.get(Player_.teams)));\n   261→        cq.select(player).distinct(true);\n   262→        TypedQuery<Player> q = em.createQuery(cq);\n   263→        return copyPlayersToDetails(q.getResultList());\n   264→    }\n   265→\n   266→    @Override\n   267→    public List<PlayerDetails> getPlayersByPositionAndName(String position, String name) {\n   268→        logger.info(\"getPlayersByPositionAndName\");\n   269→        CriteriaBuilder cb = cb();\n   270→        CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   271→        Root<Player> player = cq.from(Player.class);\n   272→        cq.where(cb.equal(player.get(Player_.position), position),\n   273→                cb.equal(player.get(Player_.name), name));\n   274→        cq.select(player).distinct(true);\n   275→        TypedQuery<Player> q = em.createQuery(cq);\n   276→        return copyPlayersToDetails(q.getResultList());\n   277→    }\n   278→\n   279→    @Override\n   280→    public List<LeagueDetails> getLeaguesOfPlayer(String playerId) {\n   281→        logger.info(\"getLeaguesOfPlayer\");\n   282→        List<LeagueDetails> detailsList = new ArrayList<>();\n   283→\n   284→        CriteriaBuilder cb = cb();\n   285→        CriteriaQuery<League> cq = cb.createQuery(League.class);\n   286→        Root<League> league = cq.from(League.class);\n   287→        Join<League, Team> team = league.join(League_.teams);\n   288→        Join<Team, Player> player = team.join(Team_.players);\n   289→        cq.where(cb.equal(player.get(Player_.id), playerId));\n   290→        cq.select(league).distinct(true);\n   291→        TypedQuery<League> q = em.createQuery(cq);\n   292→        List<League> leagues = q.getResultList();\n   293→\n   294→        if (leagues == null || leagues.isEmpty()) {\n   295→            logger.log(Level.WARNING, \"No leagues found for player with ID {0}.\", playerId);\n   296→            return detailsList;\n   297→        }\n   298→\n   299→        for (League l : leagues) {\n   300→            detailsList.add(new LeagueDetails(l.getId(), l.getName(), l.getSport()));\n   301→        }\n   302→        return detailsList;\n   303→    }\n   304→\n   305→    @Override\n   306→    public List<String> getSportsOfPlayer(String playerId) {\n   307→        logger.info(\"getSportsOfPlayer\");\n   308→        CriteriaBuilder cb = cb();\n   309→        CriteriaQuery<String> cq = cb.createQuery(String.class);\n   310→        Root<Player> player = cq.from(Player.class);\n   311→        Join<Player, Team> team = player.join(Player_.teams);\n   312→        Join<Team, League> league = team.join(Team_.league);\n   313→        cq.where(cb.equal(player.get(Player_.id), playerId));\n   314→        cq.select(league.get(League_.sport)).distinct(true);\n   315→        TypedQuery<String> q = em.createQuery(cq);\n   316→        return q.getResultList();\n   317→    }\n   318→\n   319→    @Override\n   320→    public void createTeamInLeague(TeamDetails teamDetails, String leagueId) {\n   321→        logger.info(\"createTeamInLeague\");\n   322→        League league = em.find(League.class, leagueId);\n   323→        if (league == null) {\n   324→            throw new IllegalArgumentException(\"League not found: \" + leagueId);\n   325→        }\n   326→        Team team = new Team(teamDetails.getId(),\n   327→                teamDetails.getName(),\n   328→                teamDetails.getCity());\n   329→        em.persist(team);\n   330→        team.setLeague(league);\n   331→        league.addTeam(team);\n   332→    }\n   333→\n   334→    @Override\n   335→    public void removeTeam(String teamId) {\n   336→        logger.info(\"removeTeam\");\n   337→        Team team = em.find(Team.class, teamId);\n   338→        Collection<Player> players = team.getPlayers();\n   339→        Iterator<Player> i = players.iterator();\n   340→        while (i.hasNext()) {\n   341→            Player player = (Player) i.next();\n   342→            player.dropTeam(team);\n   343→        }\n   344→        em.remove(team);\n   345→    }\n   346→\n   347→    @Override\n   348→    public TeamDetails getTeam(String teamId) {\n   349→        logger.info(\"getTeam\");\n   350→        Team team = em.find(Team.class, teamId);\n   351→        if (team == null) {\n   352→            return null;\n   353→        }\n   354→        return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   355→    }\n   356→\n   357→    @Override\n   358→    public void createLeague(LeagueDetails leagueDetails) {\n   359→        logger.info(\"createLeague\");\n   360→        try {\n   361→            if (leagueDetails.getSport().equalsIgnoreCase(\"soccer\")\n   362→                    || leagueDetails.getSport().equalsIgnoreCase(\"swimming\")\n   363→                    || leagueDetails.getSport().equalsIgnoreCase(\"basketball\")\n   364→                    || leagueDetails.getSport().equalsIgnoreCase(\"baseball\")) {\n   365→                SummerLeague league = new SummerLeague(leagueDetails.getId(),\n   366→                        leagueDetails.getName(),\n   367→                        leagueDetails.getSport());\n   368→                em.persist(league);\n   369→            } else if (leagueDetails.getSport().equalsIgnoreCase(\"hockey\")\n   370→                    || leagueDetails.getSport().equalsIgnoreCase(\"skiing\")\n   371→                    || leagueDetails.getSport().equalsIgnoreCase(\"snowboarding\")) {\n   372→                WinterLeague league = new WinterLeague(leagueDetails.getId(),\n   373→                        leagueDetails.getName(),\n   374→                        leagueDetails.getSport());\n   375→                em.persist(league);\n   376→            } else {\n   377→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   378→            }\n   379→        } catch (IncorrectSportException ex) {\n   380→            throw new RuntimeException(ex);\n   381→        }\n   382→    }\n   383→\n   384→    @Override\n   385→    public void removeLeague(String leagueId) {\n   386→        logger.info(\"removeLeague\");\n   387→        League league = em.find(League.class, leagueId);\n   388→        em.remove(league);\n   389→    }\n   390→\n   391→    @Override\n   392→    public LeagueDetails getLeague(String leagueId) {\n   393→        logger.info(\"getLeague\");\n   394→        League league = em.find(League.class, leagueId);\n   395→        if (league == null) {\n   396→            return null;\n   397→        }\n   398→        return new LeagueDetails(league.getId(),\n   399→                league.getName(),\n   400→                league.getSport());\n   401→    }\n   402→\n   403→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   404→        List<PlayerDetails> detailsList = new ArrayList<>();\n   405→        for (Player player : players) {\n   406→            detailsList.add(new PlayerDetails(player.getId(),\n   407→                    player.getName(),\n   408→                    player.getPosition(),\n   409→                    player.getSalary()));\n   410→        }\n   411→        return detailsList;\n   412→    }\n   413→}\n   414→"}]},"parent_tool_use_id":null,"session_id":"180e23c6-f89e-42a0-8c25-442c06157534","uuid":"834e617b-6adf-4f9f-a37b-29ce1de8be53"}
