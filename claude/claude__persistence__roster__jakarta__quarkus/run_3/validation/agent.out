{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_012ggkYvQ9y4krS9Ag9cv7Zs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_012qUsiM2KopG6B8CnSUCNrV","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__roster__jakarta__quarkus/run_3/output/smoke.py","content":"\"\"\"\nSmoke tests for the Roster application migrated to Quarkus.\nTests all REST endpoints to verify the migration preserves functionality.\n\"\"\"\nimport os\nimport sys\nimport time\nimport requests\nimport pytest\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\n\ndef wait_for_app(url, timeout=60):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            r = requests.get(f\"{url}/players\", timeout=5)\n            if r.status_code in (200, 204):\n                return True\n        except requests.ConnectionError:\n            pass\n        time.sleep(2)\n    return False\n\n\n@pytest.fixture(scope=\"session\", autouse=True)\ndef app_ready():\n    \"\"\"Ensure the application is up before running tests.\"\"\"\n    if not wait_for_app(BASE_URL):\n        pytest.skip(\"Application not ready within timeout\")\n\n\n# -----------------------------------------------------------------------\n# League tests\n# -----------------------------------------------------------------------\n\nclass TestLeagues:\n    def test_get_seeded_league_l1(self):\n        \"\"\"Verify seeded league L1 exists.\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/L1\")\n        assert r.status_code == 200\n        data = r.json()\n        assert data[\"id\"] == \"L1\"\n        assert data[\"name\"] == \"Mountain\"\n        assert data[\"sport\"] == \"Soccer\"\n\n    def test_get_seeded_league_l2(self):\n        \"\"\"Verify seeded league L2 exists.\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/L2\")\n        assert r.status_code == 200\n        data = r.json()\n        assert data[\"id\"] == \"L2\"\n        assert data[\"name\"] == \"Valley\"\n        assert data[\"sport\"] == \"Basketball\"\n\n    def test_get_seeded_league_l3(self):\n        \"\"\"Verify seeded league L3 exists.\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/L3\")\n        assert r.status_code == 200\n        data = r.json()\n        assert data[\"id\"] == \"L3\"\n        assert data[\"name\"] == \"Foothills\"\n        assert data[\"sport\"] == \"Soccer\"\n\n    def test_get_seeded_league_l4(self):\n        \"\"\"Verify seeded league L4 exists.\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/L4\")\n        assert r.status_code == 200\n        data = r.json()\n        assert data[\"id\"] == \"L4\"\n        assert data[\"name\"] == \"Alpine\"\n        assert data[\"sport\"] == \"Snowboarding\"\n\n    def test_get_nonexistent_league(self):\n        \"\"\"Verify 404 for non-existent league.\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/NONEXISTENT\")\n        assert r.status_code == 404\n\n    def test_create_league(self):\n        \"\"\"Test creating a new summer league.\"\"\"\n        payload = {\"id\": \"L99\", \"name\": \"Test League\", \"sport\": \"Swimming\"}\n        r = requests.post(f\"{BASE_URL}/league\", json=payload)\n        assert r.status_code == 200\n\n        # Verify it was created\n        r2 = requests.get(f\"{BASE_URL}/league/L99\")\n        assert r2.status_code == 200\n        data = r2.json()\n        assert data[\"id\"] == \"L99\"\n        assert data[\"name\"] == \"Test League\"\n        assert data[\"sport\"] == \"Swimming\"\n\n    def test_create_winter_league(self):\n        \"\"\"Test creating a new winter league.\"\"\"\n        payload = {\"id\": \"L98\", \"name\": \"Ski League\", \"sport\": \"Skiing\"}\n        r = requests.post(f\"{BASE_URL}/league\", json=payload)\n        assert r.status_code == 200\n\n        r2 = requests.get(f\"{BASE_URL}/league/L98\")\n        assert r2.status_code == 200\n        data = r2.json()\n        assert data[\"sport\"] == \"Skiing\"\n\n    def test_create_league_invalid_sport(self):\n        \"\"\"Test that invalid sport returns 400.\"\"\"\n        payload = {\"id\": \"L97\", \"name\": \"Bad League\", \"sport\": \"Curling\"}\n        r = requests.post(f\"{BASE_URL}/league\", json=payload)\n        assert r.status_code == 400\n\n\n# -----------------------------------------------------------------------\n# Team tests\n# -----------------------------------------------------------------------\n\nclass TestTeams:\n    def test_create_and_get_team(self):\n        \"\"\"Test creating a team in a league and retrieving it.\"\"\"\n        payload = {\"id\": \"T99\", \"name\": \"Test Hawks\", \"city\": \"Testville\"}\n        r = requests.post(f\"{BASE_URL}/team/league/L1\", json=payload)\n        assert r.status_code == 200\n\n        r2 = requests.get(f\"{BASE_URL}/team/T99\")\n        assert r2.status_code == 200\n        data = r2.json()\n        assert data[\"id\"] == \"T99\"\n        assert data[\"name\"] == \"Test Hawks\"\n        assert data[\"city\"] == \"Testville\"\n\n    def test_get_nonexistent_team(self):\n        \"\"\"Verify 404 for non-existent team.\"\"\"\n        r = requests.get(f\"{BASE_URL}/team/NONEXISTENT\")\n        assert r.status_code == 404\n\n    def test_get_teams_of_league(self):\n        \"\"\"Test listing teams in league L1 (should have at least the team we created).\"\"\"\n        r = requests.get(f\"{BASE_URL}/league/L1/teams\")\n        assert r.status_code == 200\n        data = r.json()\n        assert isinstance(data, list)\n        assert len(data) >= 1\n\n\n# -----------------------------------------------------------------------\n# Player tests\n# -----------------------------------------------------------------------\n\nclass TestPlayers:\n    def test_create_and_get_player(self):\n        \"\"\"Test creating and retrieving a player.\"\"\"\n        r = requests.post(\n            f\"{BASE_URL}/player?id=P99&name=Test+Player&position=forward&salary=500.0\"\n        )\n        assert r.status_code == 200\n\n        r2 = requests.get(f\"{BASE_URL}/player/P99\")\n        assert r2.status_code == 200\n        data = r2.json()\n        assert data[\"id\"] == \"P99\"\n        assert data[\"name\"] == \"Test Player\"\n        assert data[\"position\"] == \"forward\"\n        assert data[\"salary\"] == 500.0\n\n    def test_get_nonexistent_player(self):\n        \"\"\"Verify 404 for non-existent player.\"\"\"\n        r = requests.get(f\"{BASE_URL}/player/NONEXISTENT\")\n        assert r.status_code == 404\n\n    def test_add_player_to_team(self):\n        \"\"\"Test adding a player to a team.\"\"\"\n        # Ensure team T99 exists from prior test; create player P98\n        requests.post(\n            f\"{BASE_URL}/player?id=P98&name=Team+Member&position=midfielder&salary=300.0\"\n        )\n        # Ensure team exists\n        payload = {\"id\": \"T98\", \"name\": \"Player Test Team\", \"city\": \"TeamCity\"}\n        requests.post(f\"{BASE_URL}/team/league/L1\", json=payload)\n\n        r = requests.post(f\"{BASE_URL}/player/P98/team/T98\")\n        assert r.status_code == 200\n\n        # Verify player appears in team's player list\n        r2 = requests.get(f\"{BASE_URL}/team/T98/players\")\n        assert r2.status_code == 200\n        players = r2.json()\n        player_ids = [p[\"id\"] for p in players]\n        assert \"P98\" in player_ids\n\n    def test_get_all_players(self):\n        \"\"\"Test getting all players.\"\"\"\n        r = requests.get(f\"{BASE_URL}/players\")\n        assert r.status_code == 200\n        data = r.json()\n        assert isinstance(data, list)\n        assert len(data) >= 1\n\n    def test_get_players_not_on_team(self):\n        \"\"\"Test getting players not on any team.\"\"\"\n        r = requests.get(f\"{BASE_URL}/players/not-on-team\")\n        assert r.status_code == 200\n        data = r.json()\n        assert isinstance(data, list)\n\n    def test_get_players_by_position(self):\n        \"\"\"Test getting players by position.\"\"\"\n        r = requests.get(f\"{BASE_URL}/players/position/forward\")\n        assert r.status_code == 200\n        data = r.json()\n        assert isinstance(data, list)\n        for p in data:\n            assert p[\"position\"] == \"forward\"\n\n    def test_get_players_by_salary_range(self):\n        \"\"\"Test getting players by salary range.\"\"\"\n        r = requests.get(f\"{BASE_URL}/players/salary/range?low=200&high=600\")\n        assert r.status_code == 200\n        data = r.json()\n        assert isinstance(data, list)\n        for p in data:\n            assert 200 <= p[\"salary\"] <= 600\n\n    def test_remove_player(self):\n        \"\"\"Test removing a player.\"\"\"\n        # Create a player to remove\n        requests.post(\n            f\"{BASE_URL}/player?id=P97&name=Remove+Me&position=defender&salary=100.0\"\n        )\n        r = requests.delete(f\"{BASE_URL}/player/P97\")\n        assert r.status_code == 200\n\n        # Verify removal\n        r2 = requests.get(f\"{BASE_URL}/player/P97\")\n        assert r2.status_code == 404\n\n\n# -----------------------------------------------------------------------\n# Integration tests\n# -----------------------------------------------------------------------\n\nclass TestIntegration:\n    def test_full_workflow(self):\n        \"\"\"Test complete create-read-delete workflow.\"\"\"\n        # Create league\n        league = {\"id\": \"LINT\", \"name\": \"Integration League\", \"sport\": \"Baseball\"}\n        r = requests.post(f\"{BASE_URL}/league\", json=league)\n        assert r.status_code == 200\n\n        # Create team in league\n        team = {\"id\": \"TINT\", \"name\": \"Integration Team\", \"city\": \"IntCity\"}\n        r = requests.post(f\"{BASE_URL}/team/league/LINT\", json=team)\n        assert r.status_code == 200\n\n        # Create player\n        r = requests.post(\n            f\"{BASE_URL}/player?id=PINT&name=Int+Player&position=pitcher&salary=600.0\"\n        )\n        assert r.status_code == 200\n\n        # Add player to team\n        r = requests.post(f\"{BASE_URL}/player/PINT/team/TINT\")\n        assert r.status_code == 200\n\n        # Verify player is on team\n        r = requests.get(f\"{BASE_URL}/team/TINT/players\")\n        assert r.status_code == 200\n        players = r.json()\n        assert any(p[\"id\"] == \"PINT\" for p in players)\n\n        # Get leagues of player\n        r = requests.get(f\"{BASE_URL}/player/PINT/leagues\")\n        assert r.status_code == 200\n        leagues = r.json()\n        assert any(l[\"id\"] == \"LINT\" for l in leagues)\n\n        # Get sports of player\n        r = requests.get(f\"{BASE_URL}/player/PINT/sports\")\n        assert r.status_code == 200\n        sports = r.json()\n        assert \"Baseball\" in sports\n\n        # Get players by sport\n        r = requests.get(f\"{BASE_URL}/players/sport/Baseball\")\n        assert r.status_code == 200\n        data = r.json()\n        assert any(p[\"id\"] == \"PINT\" for p in data)\n\n        # Get players by city\n        r = requests.get(f\"{BASE_URL}/players/city/IntCity\")\n        assert r.status_code == 200\n        data = r.json()\n        assert any(p[\"id\"] == \"PINT\" for p in data)\n\n        # Get players by league\n        r = requests.get(f\"{BASE_URL}/players/league/LINT\")\n        assert r.status_code == 200\n        data = r.json()\n        assert any(p[\"id\"] == \"PINT\" for p in data)\n\n        # Drop player from team\n        r = requests.delete(f\"{BASE_URL}/player/PINT/team/TINT\")\n        assert r.status_code == 200\n\n        # Remove player\n        r = requests.delete(f\"{BASE_URL}/player/PINT\")\n        assert r.status_code == 200\n\n        # Remove team\n        r = requests.delete(f\"{BASE_URL}/team/TINT\")\n        assert r.status_code == 200\n\n        # Remove league\n        r = requests.delete(f\"{BASE_URL}/league/LINT\")\n        assert r.status_code == 200\n\n        # Verify league is gone\n        r = requests.get(f\"{BASE_URL}/league/LINT\")\n        assert r.status_code == 404\n\n\nif __name__ == \"__main__\":\n    pytest.main([__file__, \"-v\"])\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":495,"cache_read_input_tokens":109904,"cache_creation":{"ephemeral_5m_input_tokens":495,"ephemeral_1h_input_tokens":0},"output_tokens":3451},"context_management":null},"parent_tool_use_id":null,"session_id":"180e23c6-f89e-42a0-8c25-442c06157534","uuid":"e3a8704c-189c-425c-9cd5-1ffcd2dd223a"}
