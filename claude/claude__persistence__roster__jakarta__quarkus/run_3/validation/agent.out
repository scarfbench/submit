dependency>\n    47→      <groupId>com.h2database</groupId>\n    48→      <artifactId>h2</artifactId>\n    49→      <version>2.3.232</version>\n    50→    </dependency>\n    51→  </dependencies>\n    52→\n    53→  <build>\n    54→    <plugins>\n    55→      <plugin>\n    56→        <groupId>org.apache.maven.plugins</groupId>\n    57→        <artifactId>maven-ear-plugin</artifactId>\n    58→        <version>3.3.0</version>\n    59→        <configuration>\n    60→          <generateApplicationXml>true</generateApplicationXml>\n    61→          <defaultLibBundleDir>lib</defaultLibBundleDir>\n    62→          <modules>\n    63→            <ejbModule>\n    64→              <groupId>jakarta.tutorial</groupId>\n    65→              <artifactId>roster-ejb</artifactId>\n    66→            </ejbModule>\n    67→            <jarModule>\n    68→              <groupId>jakarta.tutorial</groupId>\n    69→              <artifactId>roster-appclient</artifactId>\n    70→            </jarModule>\n    71→            <webModule>\n    72→              <groupId>jakarta.tutorial</groupId>\n    73→              <artifactId>roster-web</artifactId>\n    74→              <contextRoot>/roster</contextRoot>\n    75→            </webModule>\n    76→          </modules>\n    77→        </configuration>\n    78→      </plugin>\n    79→      <plugin>\n    80→        <groupId>io.openliberty.tools</groupId>\n    81→        <artifactId>liberty-maven-plugin</artifactId>\n    82→        <configuration>\n    83→          <copyDependencies>\n    84→            <dependencyGroup>\n    85→              <location>${project.build.directory}/liberty/wlp/usr/shared/resources</location>\n    86→              <dependency>\n    87→                <groupId>com.h2database</groupId>\n    88→                <artifactId>h2</artifactId>\n    89→              </dependency>\n    90→            </dependencyGroup>\n    91→          </copyDependencies>\n    92→        </configuration>\n    93→      </plugin>\n    94→    </plugi