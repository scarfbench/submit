\n    32→      LocalDateTime registrationTime,\n    33→      LocalDateTime completionTime,\n    34→      TrackingId trackingId,\n    35→      VoyageNumber voyageNumber,\n    36→      UnLocode unlocode,\n    37→      HandlingEvent.Type type) throws CannotCreateHandlingEventException {\n    38→    Cargo cargo = findCargo(trackingId);\n    39→    Voyage voyage = findVoyage(voyageNumber);\n    40→    Location location = findLocation(unlocode);\n    41→    try {\n    42→      if (voyage == null) {\n    43→        return new HandlingEvent(cargo, completionTime, registrationTime, type, location);\n    44→      } else {\n    45→        return new HandlingEvent(cargo, completionTime, registrationTime, type, location, voyage);\n    46→      }\n    47→    } catch (Exception e) {\n    48→      throw new CannotCreateHandlingEventException(e);\n    49→    }\n    50→  }\n    51→\n    52→  private Cargo findCargo(TrackingId trackingId) throws UnknownCargoException {\n    53→    Cargo cargo = cargoRepository.find(trackingId);\n    54→    if (cargo == null) {\n    55→      throw new UnknownCargoException(trackingId);\n    56→    }\n    57→    return cargo;\n    58→  }\n    59→\n    60→  private Voyage findVoyage(VoyageNumber voyageNumber) throws UnknownVoyageException {\n    61→    if (voyageNumber == null) {\n    62→      return null;\n    63→    }\n    64→    Voyage voyage = voyageRepository.find(voyageNumber);\n    65→    if (voyage == null) {\n    66→      throw new UnknownVoyageException(voyageNumber);\n    67→    }\n    68→    return voyage;\n    69→  }\n    70→\n    71→  private Location findLocation(UnLocode unlocode) throws UnknownLocationException {\n    72→    Location location = locationRepository.find(unlocode);\n    73→    if (location == null) {\n    74→      throw new UnknownLocationException(unlocode);\n    75→    }\n    76→    return location;\n    77→  }\n    78→}\n    79→"}]},"parent_tool_use_id":"toolu_bdrk_01L41fAWXBu8n71FQ2z33khN","session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"18d0472b-db3b-4c2f-ae1b-88617bb9ecde"}
