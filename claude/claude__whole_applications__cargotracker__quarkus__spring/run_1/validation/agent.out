{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01GsjCVLHL4JUG19u9ohmv2z","type":"tool_result","content":"     1→package org.eclipse.cargotracker.interfaces.tracking.web;\n     2→\n     3→import static java.nio.charset.StandardCharsets.UTF_8;\n     4→\n     5→import java.io.Serializable;\n     6→import java.io.UnsupportedEncodingException;\n     7→import java.net.URLEncoder;\n     8→import java.util.List;\n     9→import java.util.logging.Level;\n    10→import java.util.logging.Logger;\n    11→import jakarta.faces.view.ViewScoped;\n    12→import jakarta.inject.Inject;\n    13→import jakarta.inject.Named;\n    14→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    15→import org.eclipse.cargotracker.domain.model.cargo.CargoRepository;\n    16→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    17→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    18→import org.eclipse.cargotracker.domain.model.handling.HandlingEventRepository;\n    19→import com.fasterxml.jackson.core.JsonProcessingException;\n    20→import com.fasterxml.jackson.databind.ObjectMapper;\n    21→\n    22→/**\n    23→ * Backing bean for tracking cargo. This interface sits immediately on top of the domain layer,\n    24→ * unlike the booking interface which has a facade and supporting DTOs in between.\n    25→ *\n    26→ * <p>\n    27→ * An adapter class, designed for the tracking use case, is used to wrap the domain model to make it\n    28→ * easier to work with in a web page rendering context. We do not want to apply view rendering\n    29→ * constraints to the design of our domain model and the adapter helps us shield the domain model\n    30→ * classes where needed.\n    31→ *\n    32→ * <p>\n    33→ * In some very simplistic cases, it is fine to not use even an adapter.\n    34→ */\n    35→@Named(\"publicTrack\")\n    36→@ViewScoped\n    37→public class Track implements Serializable {\n    38→\n    39→  private static final long serialVersionUID = 1L;\n    40→\n    41→  @Inject\n    42→  private transient Logger logger;\n    43→\n    44→  @Inject\n    45→  private CargoRepository cargoRepository;\n    46→  @Inject\n    47→  private HandlingEventRepository handlingEventRepository;\n    48→  @Inject\n    49→  private ObjectMapper objectMapper;\n    50→\n    51→  private String trackingId;\n    52→  private CargoTrackingViewAdapter cargo;\n    53→\n    54→  public String getTrackingId() {\n    55→    return trackingId;\n    56→  }\n    57→\n    58→  public void setTrackingId(String trackingId) {\n    59→    if (trackingId != null) {\n    60→      trackingId = trackingId.trim();\n    61→    }\n    62→\n    63→    this.trackingId = trackingId;\n    64→  }\n    65→\n    66→  public CargoTrackingViewAdapter getCargo() {\n    67→    return cargo;\n    68→  }\n    69→\n    70→  public String getCargoAsJson() {\n    71→    try {\n    72→      return URLEncoder.encode(objectMapper.writeValueAsString(cargo), UTF_8.name());\n    73→    } catch (UnsupportedEncodingException | JsonProcessingException ex) {\n    74→      logger.log(Level.WARNING, \"URL encoding error.\", ex);\n    75→      return \"\"; // Should never happen.\n    76→    }\n    77→  }\n    78→\n    79→  public void onTrackById() {\n    80→    Cargo cargo = cargoRepository.find(new TrackingId(trackingId));\n    81→\n    82→    if (cargo != null) {\n    83→      List<HandlingEvent> handlingEvents =\n    84→          handlingEventRepository\n    85→              .lookupHandlingHistoryOfCargo(new TrackingId(trackingId))\n    86→              .getDistinctEventsByCompletionTime();\n    87→      this.cargo = new CargoTrackingViewAdapter(cargo, handlingEvents);\n    88→    } else {\n    89→      this.cargo = null;\n    90→    }\n    91→  }\n    92→}\n    93→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"df8c372e-6075-4250-be91-6b9e508363fe"}
