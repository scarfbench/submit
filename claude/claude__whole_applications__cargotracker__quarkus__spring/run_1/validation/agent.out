tion4);\n   200→    Itinerary itinerary4 = new Itinerary(Arrays.asList(\n   201→        new Leg(SampleVoyages.NEW_YORK_TO_DALLAS, SampleLocations.NEWYORK, SampleLocations.DALLAS,\n   202→            LocalDateTime.now().minusDays(34).minusHours(1).minusMinutes(1),\n   203→            LocalDateTime.now().minusDays(28).minusHours(10).minusMinutes(1))));\n   204→    mno456.assignToRoute(itinerary4);\n   205→    entityManager.persist(mno456);\n   206→\n   207→    try {\n   208→      HandlingEvent event1 = handlingEventFactory.createHandlingEvent(\n   209→          LocalDateTime.now().minusHours(16).minusMinutes(9),\n   210→          LocalDateTime.now().minusDays(37).minusHours(2).minusMinutes(21),\n   211→          trackingId4, null, SampleLocations.NEWYORK.getUnLocode(), HandlingEvent.Type.RECEIVE);\n   212→      entityManager.persist(event1);\n   213→      HandlingEvent event2 = handlingEventFactory.createHandlingEvent(\n   214→          LocalDateTime.now().minusHours(3).minusMinutes(9),\n   215→          LocalDateTime.now().minusDays(34).minusHours(3).minusMinutes(8),\n   216→          trackingId4, SampleVoyages.NEW_YORK_TO_DALLAS.getVoyageNumber(),\n   217→          SampleLocations.NEWYORK.getUnLocode(), HandlingEvent.Type.LOAD);\n   218→      entityManager.persist(event2);\n   219→      HandlingEvent event3 = handlingEventFactory.createHandlingEvent(\n   220→          LocalDateTime.now().minusHours(14).minusMinutes(10),\n   221→          LocalDateTime.now().minusDays(28).minusHours(7).minusMinutes(7),\n   222→          trackingId4, SampleVoyages.NEW_YORK_TO_DALLAS.getVoyageNumber(),\n   223→          SampleLocations.DALLAS.getUnLocode(), HandlingEvent.Type.UNLOAD);\n   224→      entityManager.persist(event3);\n   225→      HandlingEvent event4 = handlingEventFactory.createHandlingEvent(\n   226→          LocalDateTime.now().minusHours(22).minusMinutes(1),\n   227→          LocalDateTime.now().minusDays(27).minusHours(18).minusMinutes(3),\n   228→          trackingId