 logging handling events.\n    27→ */\n    28→@RestController\n    29→@RequestMapping(\"/rest/event-logger\")\n    30→public class EventLogger {\n    31→\n    32→    @Autowired\n    33→    private JpaCargoRepository cargoRepository;\n    34→\n    35→    @Autowired\n    36→    private JpaLocationRepository locationRepository;\n    37→\n    38→    @Autowired\n    39→    private JpaVoyageRepository voyageRepository;\n    40→\n    41→    @Autowired\n    42→    private ApplicationEvents applicationEvents;\n    43→\n    44→    @GetMapping(\"/tracking-ids\")\n    45→    public List<String> getTrackingIds() {\n    46→        return cargoRepository.listAll().stream()\n    47→                .filter(cargo -> !cargo.getItinerary().getLegs().isEmpty()\n    48→                        && !cargo.getDelivery().getTransportStatus()\n    49→                                .sameValueAs(TransportStatus.CLAIMED))\n    50→                .map(cargo -> cargo.getTrackingId().getIdString())\n    51→                .collect(Collectors.toList());\n    52→    }\n    53→\n    54→    @GetMapping(\"/locations\")\n    55→    public List<Map<String, String>> getLocations() {\n    56→        return locationRepository.listAll().stream()\n    57→                .map(location -> Map.of(\n    58→                        \"code\", location.getUnLocode().getIdString(),\n    59→                        \"name\", location.getName() + \" (\" + location.getUnLocode().getIdString() + \")\"))\n    60→                .collect(Collectors.toList());\n    61→    }\n    62→\n    63→    @GetMapping(\"/voyages\")\n    64→    public List<String> getVoyages() {\n    65→        return voyageRepository.listAll().stream()\n    66→                .map(voyage -> voyage.getVoyageNumber().getIdString())\n    67→                .collect(Collectors.toList());\n    68→    }\n    69→\n    70→    @GetMapping(\"/event-types\")\n    71→    public HandlingEvent.Type[] getEventTypes() {\n    72→        return HandlingEvent.Type.values();\n    73→    }\n    74→\n    75→    @PostMapping(\"/submit\")\n    76→    public ResponseEntity<Map<String, String>> submit(\n    77→            @RequestParam String trackingId,\n    78→            @RequestParam String location,\n    79→            @RequestParam HandlingEvent.Type eventType,\n    80→            @RequestParam(required = false) String voyageNumber,\n    81→            @RequestParam String completionTime) {\n    82→\n    83→        if (eventType.requiresVoyage() && (voyageNumber == null || voyageNumber.isEmpty())) {\n    84→            return ResponseEntity.badRequest()\n    85→                    .body(Map.of(\"error\", \"Voyage number is required for LOAD/UNLOAD events\"));\n    86→        }\n    87→\n    88→        TrackingId tid = new TrackingId(trackingId);\n    89→        UnLocode loc = new UnLocode(location);\n    90→        VoyageNumber voyage = (voyageNumber != null && !voyageNumber.isEmpty())\n    91→                ? new VoyageNumber(voyageNumber) : null;\n    92→        LocalDateTime completion = LocalDateTime.parse(completionTime);\n    93→\n    94→        HandlingEventRegistrationAttempt attempt =\n    95→                new HandlingEventRegistrationAttempt(\n    96→                        LocalDateTime.now(), completion, tid, voyage, eventType, loc);\n    97→\n    98→        applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n    99→\n   100→        return ResponseEntity.ok(Map.of(\"message\", \"Event submitted\"));\n   101→    }\n   102→}\n   103→"}]},"parent_tool_use_id":"toolu_bdrk_01MjyZGdbAte4s4mPovucSiL","session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"84d5f216-fbd0-409d-b69b-d89665bae0a9"}
