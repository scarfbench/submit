ository locationRepository;\n    32→  @Autowired\n    33→  private RoutingService routingService;\n    34→\n    35→  @Override\n    36→  public TrackingId bookNewCargo(UnLocode originUnLocode, UnLocode destinationUnLocode, LocalDate arrivalDeadline) {\n    37→    TrackingId trackingId = cargoRepository.nextTrackingId();\n    38→    Location origin = locationRepository.find(originUnLocode);\n    39→    Location destination = locationRepository.find(destinationUnLocode);\n    40→    RouteSpecification routeSpecification = new RouteSpecification(origin, destination, arrivalDeadline);\n    41→    Cargo cargo = new Cargo(trackingId, routeSpecification);\n    42→    cargoRepository.store(cargo);\n    43→    logger.log(Level.INFO, \"Booked new cargo with tracking ID {0}\", cargo.getTrackingId().getIdString());\n    44→    return cargo.getTrackingId();\n    45→  }\n    46→\n    47→  @Override\n    48→  public List<Itinerary> requestPossibleRoutesForCargo(TrackingId trackingId) {\n    49→    Cargo cargo = cargoRepository.find(trackingId);\n    50→    if (cargo == null) {\n    51→      return Collections.emptyList();\n    52→    }\n    53→    return routingService.fetchRoutesForSpecification(cargo.getRouteSpecification());\n    54→  }\n    55→\n    56→  @Override\n    57→  public void assignCargoToRoute(Itinerary itinerary, TrackingId trackingId) {\n    58→    Cargo cargo = cargoRepository.find(trackingId);\n    59→    cargo.assignToRoute(itinerary);\n    60→    cargoRepository.store(cargo);\n    61→    logger.log(Level.INFO, \"Assigned cargo {0} to new route\", trackingId);\n    62→  }\n    63→\n    64→  @Override\n    65→  public void changeDestination(TrackingId trackingId, UnLocode unLocode) {\n    66→    Cargo cargo = cargoRepository.find(trackingId);\n    67→    Location newDestination = locationRepository.find(unLocode);\n    68→    RouteSpecification routeSpecification = new RouteSpecification(\n    69→        cargo.getOrigin(), newDestination, cargo.getRouteSpecification().getArrivalDeadline());\n    70→    cargo.specifyNewRoute(routeSpecification);\n    71→    cargoRepository.store(cargo);\n    72→    logger.log(Level.INFO, \"Changed destination for cargo {0} to {1}\",\n    73→        new Object[]{trackingId, routeSpecification.getDestination()});\n    74→  }\n    75→\n    76→  @Override\n    77→  public void changeDeadline(TrackingId trackingId, LocalDate newDeadline) {\n    78→    Cargo cargo = cargoRepository.find(trackingId);\n    79→    RouteSpecification routeSpecification = new RouteSpecification(\n    80→        cargo.getOrigin(), cargo.getRouteSpecification().getDestination(), newDeadline);\n    81→    cargo.specifyNewRoute(routeSpecification);\n    82→    cargoRepository.store(cargo);\n    83→    logger.log(Level.INFO, \"Changed deadline for cargo {0} to {1}\", new Object[]{trackingId, newDeadline});\n    84→  }\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_bdrk_01L41fAWXBu8n71FQ2z33khN","session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"f3b989d2-997e-4497-8153-6cd9b40c09a8"}
