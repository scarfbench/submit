{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01VxNNP1ZUWda4roJfaNMK5E","type":"tool_result","content":"     1→package org.eclipse.cargotracker.application.util;\n     2→\n     3→import java.time.LocalDate;\n     4→import java.time.LocalDateTime;\n     5→import java.util.Arrays;\n     6→import java.util.logging.Logger;\n     7→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n     8→import org.eclipse.cargotracker.domain.model.cargo.Itinerary;\n     9→import org.eclipse.cargotracker.domain.model.cargo.Leg;\n    10→import org.eclipse.cargotracker.domain.model.cargo.RouteSpecification;\n    11→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    12→import org.eclipse.cargotracker.domain.model.handling.CannotCreateHandlingEventException;\n    13→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    14→import org.eclipse.cargotracker.domain.model.handling.HandlingEventFactory;\n    15→import org.eclipse.cargotracker.domain.model.handling.HandlingEventRepository;\n    16→import org.eclipse.cargotracker.domain.model.handling.HandlingHistory;\n    17→import org.eclipse.cargotracker.domain.model.location.SampleLocations;\n    18→import org.eclipse.cargotracker.domain.model.voyage.SampleVoyages;\n    19→import jakarta.persistence.EntityManager;\n    20→import jakarta.persistence.LockModeType;\n    21→import jakarta.persistence.NoResultException;\n    22→import jakarta.persistence.PersistenceContext;\n    23→import org.springframework.beans.factory.annotation.Autowired;\n    24→import org.springframework.stereotype.Service;\n    25→import org.springframework.transaction.annotation.Transactional;\n    26→\n    27→@Service\n    28→public class InitLoader {\n    29→\n    30→  private static final Logger logger = Logger.getLogger(InitLoader.class.getName());\n    31→\n    32→  @PersistenceContext\n    33→  private EntityManager entityManager;\n    34→\n    35→  @Autowired\n    36→  private HandlingEventFactory handlingEventFactory;\n    37→\n    38→  @Autowired\n    39→  private HandlingEventRepository handlingEventRepository;\n    40→\n    41→  @Transactional\n    42→  public void loadData() {\n    43→    if (!isSampleLoaded()) {\n    44→      logger.info(\"Loading sample data.\");\n    45→      loadSampleLocations();\n    46→      loadSampleVoyages();\n    47→      loadSampleCargos();\n    48→    } else {\n    49→      logger.info(\"Sample data already loaded, skipping.\");\n    50→    }\n    51→  }\n    52→\n    53→  private boolean isSampleLoaded() {\n    54→    boolean sampleLoaded = false;\n    55→    try {\n    56→      ApplicationSettings settings =\n    57→          entityManager.find(ApplicationSettings.class, 1L, LockModeType.PESSIMISTIC_WRITE);\n    58→      if (settings == null) {\n    59→        // Create the settings row if it does not exist\n    60→        settings = new ApplicationSettings();\n    61→        settings.setSampleLoaded(true);\n    62→        entityManager.persist(settings);\n    63→        return false;\n    64→      }\n    65→      sampleLoaded = settings.isSampleLoaded();\n    66→      settings.setSampleLoaded(true);\n    67→    } catch (NoResultException e) {\n    68→      throw new RuntimeException(\"Could not retrieve application settings.\", e);\n    69→    }\n    70→    return sampleLoaded;\n    71→  }\n    72→\n    73→  private void loadSampleLocations() {\n    74→    logger.info(\"Loading sample locations.\");\n    75→    entityManager.persist(SampleLocations.HONGKONG);\n    76→    entityManager.persist(SampleLocations.MELBOURNE);\n    77→    entityManager.persist(SampleLocations.STOCKHOLM);\n    78→    entityManager.persist(SampleLocations.HELSINKI);\n    79→    entityManager.persist(SampleLocations.CHICAGO);\n    80→    entityManager.persist(SampleLocations.TOKYO);\n    81→    entityManager.persist(SampleLocations.HAMBURG);\n    82→    entityManager.persist(SampleLocations.SHANGHAI);\n    83→    entityManager.persist(SampleLocations.ROTTERDAM);\n    84→    entityManager.persist(SampleLocations.GOTHENBURG);\n    85→    entityManager.persist(SampleLocations.HANGZOU);\n    86→    entityManager.persist(SampleLocations.NEWYORK);\n    87→    entityManager.persist(SampleLocations.DALLAS);\n    88→  }\n    89→\n    90→  private void loadSampleVoyages() {\n    91→    logger.info(\"Loading sample voyages.\");\n    92→    entityManager.persist(SampleVoyages.HONGKONG_TO_NEW_YORK);\n    93→    entityManager.persist(SampleVoyages.NEW_YORK_TO_DALLAS);\n    94→    entityManager.persist(SampleVoyages.DALLAS_TO_HELSINKI);\n    95→    entityManager.persist(SampleVoyages.HELSINKI_TO_HONGKONG);\n    96→    entityManager.persist(SampleVoyages.DALLAS_TO_HELSINKI_ALT);\n    97→  }\n    98→\n    99→  private void loadSampleCargos() {\n   100→    logger.info(\"Loading sample cargo data.\");\n   101→\n   102→    TrackingId trackingId1 = new TrackingId(\"ABC123\");\n   103→    RouteSpecification routeSpecification1 = new RouteSpecification(\n   104→        SampleLocations.HONGKONG, SampleLocations.HELSINKI, LocalDate.now().plusDays(15));\n   105→    Cargo abc123 = new Cargo(trackingId1, routeSpecification1);\n   106→    Itinerary itinerary1 = new Itinerary(Arrays.asList(\n   107→        new Leg(SampleVoyages.HONGKONG_TO_NEW_YORK, SampleLocations.HONGKONG, SampleLocations.NEWYORK,\n   108→            LocalDateTime.now().minusDays(7).minusHours(2).minusMinutes(4),\n   109→            LocalDateTime.now().minusDays(1).minusHours(10).minusMinutes(52)),\n   110→        new Leg(SampleVoyages.NEW_YORK_TO_DALLAS, SampleLocations.NEWYORK, SampleLocations.DALLAS,\n   111→            LocalDateTime.now().plusDays(2).minusHours(18).minusMinutes(38),\n   112→            LocalDateTime.now().plusDays(6).minusHours(3).minusMinutes(22)),\n   113→        new Leg(SampleVoyages.DALLAS_TO_HELSINKI, SampleLocations.DALLAS, SampleLocations.HELSINKI,\n   114→            LocalDateTime.now().plusDays(8).minusHours(8).minusMinutes(18),\n   115→            LocalDateTime.now().plusDays(14).minusHours(12).minusMinutes(29))));\n   116→    abc123.assignToRoute(itinerary1);\n   117→    entityManager.persist(abc123);\n   118→\n   119→    try {\n   120→      HandlingEvent event1 = handlingEventFactory.createHandlingEvent(\n   121→          LocalDateTime.now().minusHours(5).minusMinutes(5),\n   122→          LocalDateTime.now().minusDays(10).minusHours(9).minusMinutes(11),\n   123→          trackingId1, null, SampleLocations.HONGKONG.getUnLocode(), HandlingEvent.Type.RECEIVE);\n   124→      entityManager.persist(event1);\n   125→      HandlingEvent event2 = handlingEventFactory.createHandlingEvent(\n   126→          LocalDateTime.now().minusHours(6).minusMinutes(46),\n   127→          LocalDateTime.now().minusDays(7).minusHours(2).minusMinutes(50),\n   128→          trackingId1, SampleVoyages.HONGKONG_TO_NEW_YORK.getVoyageNumber(),\n   129→          SampleLocations.HONGKONG.getUnLocode(), HandlingEvent.Type.LOAD);\n   130→      entityManager.persist(event2);\n   131→      HandlingEvent event3 = handlingEventFactory.createHandlingEvent(\n   132→          LocalDateTime.now().minusHours(15).minusMinutes(26),\n   133→          LocalDateTime.now().minusDays(1).minusHours(4).minusMinutes(32),\n   134→          trackingId1, SampleVoyages.HONGKONG_TO_NEW_YORK.getVoyageNumber(),\n   135→          SampleLocations.NEWYORK.getUnLocode(), HandlingEvent.Type.UNLOAD);\n   136→      entityManager.persist(event3);\n   137→    } catch (CannotCreateHandlingEventException e) {\n   138→      throw new RuntimeException(e);\n   139→    }\n   140→\n   141→    HandlingHistory handlingHistory1 = handlingEventRepository.lookupHandlingHistoryOfCargo(trackingId1);\n   142→    abc123.deriveDeliveryProgress(handlingHistory1);\n   143→    entityManager.persist(abc123);\n   144→\n   145→    TrackingId trackingId2 = new TrackingId(\"JKL567\");\n   146→    RouteSpecification routeSpecification2 = new RouteSpecification(\n   147→        SampleLoc