→          .getSingleResult();\n    35→    } catch (NoResultException e) {\n    36→      logger.log(Level.FINE, \"Find called on non-existant tracking ID.\", e);\n    37→      return null;\n    38→    }\n    39→  }\n    40→\n    41→  @Override\n    42→  public void store(Cargo cargo) {\n    43→    cargo.getItinerary().getLegs().forEach(leg -> entityManager.persist(leg));\n    44→    entityManager.merge(cargo);\n    45→    eventPublisher.publishEvent(cargo);\n    46→  }\n    47→\n    48→  @Override\n    49→  public TrackingId nextTrackingId() {\n    50→    String random = UUID.randomUUID().toString().toUpperCase();\n    51→    return new TrackingId(random.substring(0, random.indexOf(\"-\")));\n    52→  }\n    53→\n    54→  public List<Cargo> listAll() {\n    55→    return entityManager.createQuery(\"SELECT c FROM Cargo c\", Cargo.class).getResultList();\n    56→  }\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_bdrk_013miDQQ4H2WRCwFNJuH1WVr","session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"77eac361-ad9f-44bc-98ab-883ffaea6f26"}
