boot.test.context.SpringBootTest;\n    28→import org.springframework.transaction.annotation.Transactional;\n    29→\n    30→/**\n    31→ * Application layer integration test covering a number of otherwise fairly trivial components that\n    32→ * largely do not warrant their own tests.\n    33→ */\n    34→@SpringBootTest\n    35→@TestMethodOrder(MethodOrderer.OrderAnnotation.class)\n    36→public class BookingServiceTest {\n    37→  private static TrackingId trackingId;\n    38→  private static List<Itinerary> candidates;\n    39→  private static LocalDate deadline;\n    40→  private static Itinerary assigned;\n    41→\n    42→  @Autowired\n    43→  private BookingService bookingService;\n    44→  @Autowired\n    45→  private JpaCargoRepository cargoRepository;\n    46→\n    47→  @Test\n    48→  @Order(1)\n    49→  @Transactional\n    50→  public void testRegisterNew() {\n    51→    UnLocode fromUnlocode = new UnLocode(\"USCHI\");\n    52→    UnLocode toUnlocode = new UnLocode(\"SESTO\");\n    53→\n    54→    deadline = LocalDate.now().plusMonths(6);\n    55→\n    56→    trackingId = bookingService.bookNewCargo(fromUnlocode, toUnlocode, deadline);\n    57→\n    58→    Cargo cargo = cargoRepository.find(trackingId);\n    59→\n    60→    assertEquals(SampleLocations.CHICAGO, cargo.getOrigin());\n    61→    assertEquals(SampleLocations.STOCKHOLM, cargo.getRouteSpecification().getDestination());\n    62→    assertTrue(deadline.isEqual(cargo.getRouteSpecification().getArrivalDeadline()));\n    63→    assertEquals(TransportStatus.NOT_RECEIVED, cargo.getDelivery().getTransportStatus());\n    64→    assertEquals(Location.UNKNOWN, cargo.getDelivery().getLastKnownLocation());\n    65→    assertEquals(Voyage.NONE, cargo.getDelivery().getCurrentVoyage());\n    66→    assertFalse(cargo.getDelivery().isMisdirected());\n    67→    assertEquals(Delivery.ETA_UNKOWN, cargo.getDelivery().getEstimatedTimeOfArrival());\n    68→    assertEquals(Delivery.NO_ACTIVITY, cargo.getDelivery().getNextExpectedActivity());\n    69→    assertFalse(cargo.getDelivery().isUnloadedAtDestination());\n    70→    assertEquals(RoutingStatus.NOT_ROUTED, cargo.getDelivery().getRoutingStatus());\n    71→    assertEquals(Itinerary.EMPTY_ITINERARY, cargo.getItinerary());\n    72→  }\n    73→\n    74→  @Test\n    75→  @Order(2)\n    76→  @Transactional\n    77→  public void testRouteCandidates() {\n    78→    candidates = bookingService.requestPossibleRoutesForCargo(trackingId);\n    79→\n    80→    assertFalse(candidates.isEmpty());\n    81→  }\n    82→\n    83→  @Test\n    84→  @Order(3)\n    85→  @Transactional\n    86→  public void testAssignRoute() {\n    87→    assigned = candidates.get(new Random().nextInt(candidates.size()));\n    88→\n    89→    bookingService.assignCargoToRoute(assigned, trackingId);\n    90→\n    91→    Cargo cargo = cargoRepository.find(trackingId);\n    92→\n    93→    assertEquals(assigned, cargo.getItinerary());\n    94→    assertEquals(TransportStatus.NOT_RECEIVED, cargo.getDelivery().getTransportStatus());\n    95→    assertEquals(Location.UNKNOWN, cargo.getDelivery().getLastKnownLocation());\n    96→    assertEquals(Voyage.NONE, cargo.getDelivery().getCurrentVoyage());\n    97→    assertFalse(cargo.getDelivery().isMisdirected());\n    98→    assertTrue(cargo.getDelivery().getEstimatedTimeOfArrival().isBefore(deadline.atStartOfDay()));\n    99→    assertEquals(\n   100→        HandlingEvent.Type.RECEIVE, cargo.getDelivery().getNextExpectedActivity().getType());\n   101→    assertEquals(\n   102→        SampleLocations.CHICAGO, cargo.getDelivery().getNextExpectedActivity().getLocation());\n   103→    assertEquals(null, cargo.getDelivery().getNextExpectedActivity().getVoyage());\n   104→    assertFalse(cargo.getDelivery().isUnloadedAtDestination());\n   105→    assertEquals(RoutingStatus.ROUTED, cargo.getDelivery().getRoutingStatus());\n   106→  }\n   107→\n   108→  @Test\n   109→  @Order(4)\n   110→  @Transactional\n   111→  public void testChangeDestination() {\n   112→    bookingService.changeDestination(trackingId, new UnLocode(\"FIHEL\"));\n   113→\n   114→    Cargo cargo = cargoRepository.find(trackingId);\n   115→\n   116→    assertEquals(SampleLocations.CHICAGO, cargo.getOrigin());\n   117→    assertEquals(SampleLocations.HELSINKI, cargo.getRouteSpecification().getDestination());\n   118→    assertTrue(deadline.isEqual(cargo.getRouteSpecification().getArrivalDeadline()));\n   119→    assertEquals(assigned, cargo.getItinerary());\n   120→    assertEquals(TransportStatus.NOT_RECEIVED, cargo.getDelivery().getTransportStatus());\n   121→    assertEquals(Location.UNKNOWN, cargo.getDelivery().getLastKnownLocation());\n   122→    assertEquals(Voyage.NONE, cargo.getDelivery().getCurrentVoyage());\n   123→    assertFalse(cargo.getDelivery().isMisdirected());\n   124→    assertEquals(Delivery.ETA_UNKOWN, cargo.getDelivery().getEstimatedTimeOfArrival());\n   125→    assertEquals(Delivery.NO_ACTIVITY, cargo.getDelivery().getNextExpectedActivity());\n   126→    assertFalse(cargo.getDelivery().isUnloadedAtDestination());\n   127→    assertEquals(RoutingStatus.MISROUTED, cargo.getDelivery().getRoutingStatus());\n   128→  }\n   129→\n   130→  @Test\n   131→  @Order(5)\n   132→  @Transactional\n   133→  public void testChangeDeadline() {\n   134→    LocalDate newDeadline = deadline.plusMonths(1);\n   135→    bookingService.changeDeadline(trackingId, newDeadline);\n   136→\n   137→    Cargo cargo = cargoRepository.find(trackingId);\n   138→\n   139→    assertEquals(SampleLocations.CHICAGO, cargo.getOrigin());\n   140→    assertEquals(SampleLocations.HELSINKI, cargo.getRouteSpecification().getDestination());\n   141→    assertTrue(newDeadline.isEqual(cargo.getRouteSpecification().getArrivalDeadline()));\n   142→    assertEquals(assigned, cargo.getItinerary());\n   143→    assertEquals(TransportStatus.NOT_RECEIVED, cargo.getDelivery().getTransportStatus());\n   144→    assertEquals(Location.UNKNOWN, cargo.getDelivery().getLastKnownLocation());\n   145→    assertEquals(Voyage.NONE, cargo.getDelivery().getCurrentVoyage());\n   146→    assertFalse(cargo.getDelivery().isMisdirected());\n   147→    assertEquals(Delivery.ETA_UNKOWN, cargo.getDelivery().getEstimatedTimeOfArrival());\n   148→    assertEquals(Delivery.NO_ACTIVITY, cargo.getDelivery().getNextExpectedActivity());\n   149→    assertFalse(cargo.getDelivery().isUnloadedAtDestination());\n   150→    assertEquals(RoutingStatus.MISROUTED, cargo.getDelivery().getRoutingStatus());\n   151→  }\n   152→}\n   153→"}]},"parent_tool_use_id":null,"session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"4a30128b-7196-43fd-88b7-05985f3f18bc"}
