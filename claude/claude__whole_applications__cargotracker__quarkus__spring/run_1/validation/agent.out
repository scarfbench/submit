  110→            LocalDateTime.now().plusDays(8).minusHours(8).minusMinutes(18),\n   111→            LocalDateTime.now().plusDays(14).minusHours(12).minusMinutes(29))));\n   112→    abc123.assignToRoute(itinerary1);\n   113→    entityManager.persist(abc123);\n   114→\n   115→    try {\n   116→      HandlingEvent event1 = handlingEventFactory.createHandlingEvent(\n   117→          LocalDateTime.now().minusHours(5).minusMinutes(5),\n   118→          LocalDateTime.now().minusDays(10).minusHours(9).minusMinutes(11),\n   119→          trackingId1, null, SampleLocations.HONGKONG.getUnLocode(), HandlingEvent.Type.RECEIVE);\n   120→      entityManager.persist(event1);\n   121→      HandlingEvent event2 = handlingEventFactory.createHandlingEvent(\n   122→          LocalDateTime.now().minusHours(6).minusMinutes(46),\n   123→          LocalDateTime.now().minusDays(7).minusHours(2).minusMinutes(50),\n   124→          trackingId1, SampleVoyages.HONGKONG_TO_NEW_YORK.getVoyageNumber(),\n   125→          SampleLocations.HONGKONG.getUnLocode(), HandlingEvent.Type.LOAD);\n   126→      entityManager.persist(event2);\n   127→      HandlingEvent event3 = handlingEventFactory.createHandlingEvent(\n   128→          LocalDateTime.now().minusHours(15).minusMinutes(26),\n   129→          LocalDateTime.now().minusDays(1).minusHours(4).minusMinutes(32),\n   130→          trackingId1, SampleVoyages.HONGKONG_TO_NEW_YORK.getVoyageNumber(),\n   131→          SampleLocations.NEWYORK.getUnLocode(), HandlingEvent.Type.UNLOAD);\n   132→      entityManager.persist(event3);\n   133→    } catch (CannotCreateHandlingEventException e) {\n   134→      throw new RuntimeException(e);\n   135→    }\n   136→\n   137→    HandlingHistory handlingHistory1 = handlingEventRepository.lookupHandlingHistoryOfCargo(trackingId1);\n   138→    abc123.deriveDeliveryProgress(handlingHistory1);\n   139→    entityManager.persist(abc123);\n   140→\n   141→    TrackingId trackingId2 = new TrackingId(\"JKL567\");\n   142→    Rou