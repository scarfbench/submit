 if (cargo == null) {\n    33→      logger.log(Level.WARNING, \"Can''t inspect non-existing cargo {0}\", trackingId);\n    34→      return;\n    35→    }\n    36→    HandlingHistory handlingHistory = handlingEventRepository.lookupHandlingHistoryOfCargo(trackingId);\n    37→    cargo.deriveDeliveryProgress(handlingHistory);\n    38→    if (cargo.getDelivery().isMisdirected()) {\n    39→      applicationEvents.cargoWasMisdirected(cargo);\n    40→    }\n    41→    if (cargo.getDelivery().isUnloadedAtDestination()) {\n    42→      applicationEvents.cargoHasArrived(cargo);\n    43→    }\n    44→    cargoRepository.store(cargo);\n    45→  }\n    46→}\n    47→"}]},"parent_tool_use_id":"toolu_bdrk_01L41fAWXBu8n71FQ2z33khN","session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"efea2419-c700-42ae-91cc-bf1f0a4468b9"}
