{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XHWKyFLmFhkAC5nHUUsiHB","type":"tool_result","content":"     1→\"\"\"\n     2→Smoke tests for the Cargo Tracker Spring Boot application.\n     3→Validates that the application starts correctly and key REST endpoints are functional.\n     4→\"\"\"\n     5→\n     6→import json\n     7→import sys\n     8→import time\n     9→import urllib.request\n    10→import urllib.error\n    11→\n    12→\n    13→BASE_URL = None\n    14→\n    15→\n    16→def get_base_url():\n    17→    \"\"\"Get the base URL - should be set before tests run.\"\"\"\n    18→    global BASE_URL\n    19→    if BASE_URL is None:\n    20→        raise RuntimeError(\"BASE_URL not set. Call set_base_url() first.\")\n    21→    return BASE_URL\n    22→\n    23→\n    24→def set_base_url(url):\n    25→    global BASE_URL\n    26→    BASE_URL = url\n    27→\n    28→\n    29→def http_get(path, timeout=10):\n    30→    \"\"\"Make an HTTP GET request and return (status_code, body).\"\"\"\n    31→    url = get_base_url() + path\n    32→    try:\n    33→        req = urllib.request.Request(url)\n    34→        resp = urllib.request.urlopen(req, timeout=timeout)\n    35→        body = resp.read().decode(\"utf-8\")\n    36→        return resp.status, body\n    37→    except urllib.error.HTTPError as e:\n    38→        body = e.read().decode(\"utf-8\") if e.fp else \"\"\n    39→        return e.code, body\n    40→    except Exception as e:\n    41→        return 0, str(e)\n    42→\n    43→\n    44→def http_post(path, data=None, content_type=\"application/x-www-form-urlencoded\", timeout=10):\n    45→    \"\"\"Make an HTTP POST request and return (status_code, body).\"\"\"\n    46→    url = get_base_url() + path\n    47→    try:\n    48→        if data is not None:\n    49→            if isinstance(data, dict) and content_type == \"application/x-www-form-urlencoded\":\n    50→                encoded = urllib.parse.urlencode(data).encode(\"utf-8\")\n    51→            elif isinstance(data, str):\n    52→                encoded = data.encode(\"utf-8\")\n    53→            else:\n    54→                encoded = json.dumps(data).encode(\"utf-8\")\n    55→        else:\n    56→            encoded = b\"\"\n    57→        req = urllib.request.Request(url, data=encoded, method=\"POST\")\n    58→        req.add_header(\"Content-Type\", content_type)\n    59→        resp = urllib.request.urlopen(req, timeout=timeout)\n    60→        body = resp.read().decode(\"utf-8\")\n    61→        return resp.status, body\n    62→    except urllib.error.HTTPError as e:\n    63→        body = e.read().decode(\"utf-8\") if e.fp else \"\"\n    64→        return e.code, body\n    65→    except Exception as e:\n    66→        return 0, str(e)\n    67→\n    68→\n    69→import urllib.parse\n    70→\n    71→\n    72→def wait_for_app(max_wait=120):\n    73→    \"\"\"Wait for the application to be ready.\"\"\"\n    74→    print(f\"Waiting for application at {get_base_url()} ...\")\n    75→    start = time.time()\n    76→    while time.time() - start < max_wait:\n    77→        try:\n    78→            status, _ = http_get(\"/rest/booking/locations\", timeout=5)\n    79→            if status == 200:\n    80→                print(f\"Application is ready (took {int(time.time() - start)}s)\")\n    81→                return True\n    82→        except Exception:\n    83→            pass\n    84→        time.sleep(2)\n    85→    print(f\"Application did not become ready within {max_wait}s\")\n    86→    return False\n    87→\n    88→\n    89→def test_list_locations():\n    90→    \"\"\"Test that we can list shipping locations.\"\"\"\n    91→    status, body = http_get(\"/rest/booking/locations\")\n    92→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    93→    data = json.loads(body)\n    94→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    95→    assert len(data) > 0, \"Expected at least one location\"\n    96→    print(f\"  PASS: list locations returned {len(data)} locations\")\n    97→    return True\n    98→\n    99→\n   100→def test_list_cargos():\n   101→    \"\"\"Test that we can list all cargos.\"\"\"\n   102→    status, body = http_get(\"/rest/booking/cargos\")\n   103→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   104→    data = json.loads(body)\n   105→    assert isinstance(data, dict), f\"Expected dict, got {type(data)}\"\n   106→    print(f\"  PASS: list cargos returned categories\")\n   107→    return True\n   108→\n   109→\n   110→def test_list_tracking_ids():\n   111→    \"\"\"Test that we can list tracking IDs.\"\"\"\n   112→    status, body = http_get(\"/rest/booking/tracking/ids\")\n   113→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   114→    data = json.loads(body)\n   115→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   116→    print(f\"  PASS: list tracking IDs returned {len(data)} IDs\")\n   117→    return True\n   118→\n   119→\n   120→def test_graph_traversal():\n   121→    \"\"\"Test the graph traversal shortest-path endpoint.\"\"\"\n   122→    status, body = http_get(\"/rest/graph-traversal/shortest-path?origin=CNHKG&destination=FIHEL\")\n   123→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   124→    data = json.loads(body)\n   125→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   126→    print(f\"  PASS: graph traversal returned {len(data)} routes\")\n   127→    return True\n   128→\n   129→\n   130→def test_event_logger_tracking_ids():\n   131→    \"\"\"Test the event logger tracking IDs endpoint.\"\"\"\n   132→    status, body = http_get(\"/rest/event-logger/tracking-ids\")\n   133→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   134→    data = json.loads(body)\n   135→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   136→    print(f\"  PASS: event logger tracking IDs returned {len(data)} IDs\")\n   137→    return True\n   138→\n   139→\n   140→def test_event_logger_locations():\n   141→    \"\"\"Test the event logger locations endpoint.\"\"\"\n   142→    status, body = http_get(\"/rest/event-logger/locations\")\n   143→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   144→    data = json.loads(body)\n   145→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   146→    print(f\"  PASS: event logger locations returned {len(data)} locations\")\n   147→    return True\n   148→\n   149→\n   150→def test_event_logger_voyages():\n   151→    \"\"\"Test the event logger voyages endpoint.\"\"\"\n   152→    status, body = http_get(\"/rest/event-logger/voyages\")\n   153→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   154→    data = json.loads(body)\n   155→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   156→    print(f\"  PASS: event logger voyages returned {len(data)} voyages\")\n   157→    return True\n   158→\n   159→\n   160→def test_event_types():\n   161→    \"\"\"Test the event types endpoint.\"\"\"\n   162→    status, body = http_get(\"/rest/event-logger/event-types\")\n   163→    assert status == 200, f\"Expected 200, got {status}: {body}\"\n   164→    data = json.loads(body)\n   165→    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n   166→    assert len(data) > 0, \"Expected at least one event type\"\n   167→    print(f\"  PASS: event types returned {len(data)} types\")\n   168→    return True\n   169→\n   170→\n   171→def run_tests():\n   172→    \"\"\"Run all smoke tests.\"\"\"\n   173→    tests = [\n   174→        (\"List Locations\", test_list_locations),\n   175→        (\"List Cargos\", test_list_cargos),\n   176→        (\"List Tracking IDs\", test_list_tracking_ids),\n   177→        (\"Graph Traversal\", test_graph_traversal),\n   178→        (\"Event Logger Tracking IDs\", test_event_logger_tracking_ids),\n   179→        (\"Event Logger Locations\", test_event_logger_locations),\n   180→        (\"Event Logger Voyages\", test_event_logger_voyages),\n   181→        (\"Event Types\", test_event_types),\n   182→    ]\n   183→\n   184→    passed = 0\n   185→    failed = 0\n   186→    errors = []\n   187→\n   188→    for name, test_fn in tests:\n   189→        try:\n   190→            print(f\"Running: {name}\")\n   191→            test_fn()\n   192→            passed += 1\n   193→        except Exception as e:\n   194→            failed += 1\n   195→            errors.append((name, str(e)))\n   196→            print(f\"  FAIL: {name}: {e}\")\n   197→\n   198→    print(f\"\\n{'='*50}\")\n   199→    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n   200→    if errors:\n   201→        print(\"\\nFailed tests:\")\n   202→        for name, error in errors:\n   203→            print(f\"  - {name}: {error}\")\n   204→\n   205→    return failed == 0\n   206→\n   207→\n   208→if __name__ == \"__main__\":\n   209→    if len(sys.argv) < 2:\n   210→        print(\"Usage: python smoke.py <base_url>\")\n   211→        print(\"Example: python smoke.py http://localhost:8080/cargo-tracker\")\n   212→        sys.exit(1)\n   213→\n   214→    set_base_url(sys.argv[1].rstrip(\"/\"))\n   215→\n   216→    if not wait_for_app():\n   217→        sys.exit(1)\n   218→\n   219→    success = run_tests()\n   220→    sys.exit(0 if success else 1)\n   221→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8543075e-efdd-4cb8-9429-6656037679ab","uuid":"aa438405-1baa-4981-b91c-316226f91926"}
