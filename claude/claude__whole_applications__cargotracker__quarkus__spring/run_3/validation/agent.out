migration.\n    31→ * This backing bean structure is preserved but JSF features are disabled.\n    32→ */\n    33→@Component(\"booking\")\n    34→// @FlowScoped(\"booking\") // JSF flow scope - not applicable in Spring\n    35→public class Booking implements Serializable {\n    36→\n    37→  private static final long serialVersionUID = 1L;\n    38→\n    39→  private static final long MIN_JOURNEY_DURATION = 1; // Journey should be 1 day minimum.\n    40→\n    41→  @Autowired\n    42→  private BookingServiceFacade bookingServiceFacade;\n    43→\n    44→  // @Inject\n    45→  // private FacesContext context; // JSF-specific - commented out\n    46→\n    47→  private LocalDate today = null;\n    48→  private List<Location> locations;\n    49→\n    50→  private String originUnlocode;\n    51→  private String originName;\n    52→  private String destinationName;\n    53→  private String destinationUnlocode;\n    54→  private LocalDate arrivalDeadline;\n    55→\n    56→  private boolean bookable = false;\n    57→  private long duration = -1;\n    58→\n    59→  @PostConstruct\n    60→  public void init() {\n    61→    today = LocalDate.now();\n    62→    locations = bookingServiceFacade.listShippingLocations();\n    63→  }\n    64→\n    65→  public List<Location> getLocations() {\n    66→    List<Location> filteredLocations = new ArrayList<>();\n    67→    String locationToRemove = null;\n    68→\n    69→    // JSF-specific view logic commented out\n    70→    // if (context.getViewRoot().getViewId().endsWith(\"destination.xhtml\")) {\n    71→    //   // In the destination menu, origin can't be selected.\n    72→    //   locationToRemove = originUnlocode;\n    73→    // } else { // Vice-versa.\n    74→    //   if (destinationUnlocode != null) {\n    75→    //     locationToRemove = destinationUnlocode;\n    76→    //   }\n    77→    // }\n    78→\n    79→    // For now, return all locations (REST API usage)\n    80→    if (destinationUnlocode != null) {\n    81→      locationToRemove = destinationUnlocode;\n    82→    } else if (originUnlocode != null) {\n    83→      locationToRemove = originUnlocode;\n    84→    }\n    85→\n    86→    for (Location location : locations) {\n    87→      if (locationToRemove == null || !location.getUnLocode().equalsIgnoreCase(locationToRemove)) {\n    88→        filteredLocations.add(location);\n    89→      }\n    90→    }\n    91→\n    92→    return filteredLocations;\n    93→  }\n    94→\n    95→  public String getOriginUnlocode() {\n    96→    return originUnlocode;\n    97→  }\n    98→\n    99→  public void setOriginUnlocode(String originUnlocode) {\n   100→    this.originUnlocode = originUnlocode;\n   101→    this.originName =\n   102→        locations\n   103→            .stream()\n   104→            .filter(location -> location.getUnLocode().equalsIgnoreCase(originUnlocode))\n   105→            .findAny()\n   106→            .get()\n   107→            .getName();\n   108→  }\n   109→\n   110→  public String getOriginName() {\n   111→    return originName;\n   112→  }\n   113→\n   114→  public String getDestinationUnlocode() {\n   115→    return destinationUnlocode;\n   116→  }\n   117→\n   118→  public void setDestinationUnlocode(String destinationUnlocode) {\n   119→    this.destinationUnlocode = destinationUnlocode;\n   120→    this.destinationName =\n   121→        locations\n   122→            .stream()\n   123→            .filter(location -> location.getUnLocode().equalsIgnoreCase(destinationUnlocode))\n   124→            .findAny()\n   125→            .get()\n   126→            .getName();\n   127→  }\n   128→\n   129→  public String getDestinationName() {\n   130→    return destinationName;\n   131→  }\n   132→\n   133→  public LocalDate getToday() {\n   134→    return today;\n   135→  }\n   136→\n   137→  public LocalDate getArrivalDeadline() {\n   138→    return arrivalDeadline;\n   139→  }\n   140→\n   141→  public void setArrivalDeadline(LocalDate arrivalDeadline) {\n   142→    this.arrivalDeadline = arrivalDeadline;\n   143→  }\n   144→\n   145→  public long getDuration() {\n   146→    return duration;\n   147→  }\n   148→\n   149→  public boolean isBookable() {\n   150→    return bookable;\n   151→  }\n   152→\n   153→  public void deadlineUpdated() {\n   154→    duration = ChronoUnit.DAYS.between(today, arrivalDeadline);\n   155→\n   156→    if (duration >= MIN_JOURNEY_DURATION) {\n   157→      bookable = true;\n   158→    } else {\n   159→      bookable = false;\n   160→    }\n   161→\n   162→    // PrimeFaces AJAX calls commented out (JSF-specific)\n   163→    // PrimeFaces.current().ajax().update(\"dateForm:durationPanel\");\n   164→    // PrimeFaces.current().ajax().update(\"dateForm:bookBtn\");\n   165→  }\n   166→\n   167→  public String register() {\n   168→    if (!originUnlocode.equals(destinationUnlocode)) {\n   169→      bookingServiceFacade.bookNewCargo(originUnlocode, destinationUnlocode, arrivalDeadline);\n   170→    } else {\n   171→      // UI now prevents from selecting same origin/destination\n   172→      // FacesMessage message = new FacesMessage(\"Origin and destination cannot be the same.\");\n   173→      // message.setSeverity(FacesMessage.SEVERITY_ERROR);\n   174→      // context.addMessage(null, message);\n   175→      return null;\n   176→    }\n   177→\n   178→    return \"/admin/dashboard.xhtml\";\n   179→  }\n   180→\n   181→  public String getReturnValue() {\n   182→    return \"/admin/dashboard.xhtml\";\n   183→  }\n   184→}\n   185→"}]},"parent_tool_use_id":"toolu_bdrk_01G7yhcnLAQnhjvZ7hMmvvbT","session_id":"726ac45c-03cf-4dc6-9fff-d69b80f6c98b","uuid":"c932ad6f-0c38-49d5-8b9e-d55a367673f8"}
