   <version>${quarkus.platform.version}</version>\n    33→                <type>pom</type>\n    34→                <scope>import</scope>\n    35→            </dependency>\n    36→            <!-- <dependency>\n    37→                <groupId>io.quarkiverse</groupId>\n    38→                <artifactId>quarkiverse-bom</artifactId>\n    39→                <version>${quarkiverse.platform.version}</version>\n    40→                <type>pom</type>\n    41→                <scope>import</scope>\n    42→            </dependency> -->\n    43→        </dependencies>\n    44→    </dependencyManagement>\n    45→\n    46→    <dependencies>\n    47→        <dependency>\n    48→            <groupId>org.amqphub.quarkus</groupId>\n    49→            <artifactId>quarkus-qpid-jms</artifactId>\n    50→        </dependency>\n    51→        <dependency>\n    52→            <groupId>io.quarkus</groupId>\n    53→            <artifactId>quarkus-rest-jackson</artifactId>\n    54→        </dependency>\n    55→        <dependency>\n    56→            <groupId>io.quarkus</groupId>\n    57→            <artifactId>quarkus-rest-client-jackson</artifactId>\n    58→        </dependency>\n    59→        <dependency>\n    60→            <groupId>io.quarkus</groupId>\n    61→            <artifactId>quarkus-rest-jaxb</artifactId>\n    62→        </dependency>\n    63→        <dependency>\n    64→            <groupId>io.quarkus</groupId>\n    65→            <artifactId>quarkus-jdbc-h2</artifactId>\n    66→        </dependency>\n    67→        <dependency>\n    68→            <groupId>io.quarkus</groupId>\n    69→            <artifactId>quarkus-hibernate-validator</artifactId>\n    70→        </dependency>\n    71→        \n    72→        <dependency>\n    73→            <groupId>io.quarkiverse.primefaces</groupId>\n    74→            <artifactId>quarkus-primefaces</artifactId>\n    75→            <version>4.15.11</version>\n    76→        </dependency>\n    77→        <dependency>\n    78→            <groupId>io.quarkus</groupId>\n    79→            <artifactId>quarkus-hibernate-orm-panache</artifactId>\n    80→        </dependency>\n    81→        <dependency>\n    82→            <groupId>io.quarkus</groupId>\n    83→            <artifactId>quarkus-scheduler</artifactId>\n    84→        </dependency>\n    85→        <dependency>\n    86→            <groupId>io.quarkiverse.jberet</groupId>\n    87→            <artifactId>quarkus-jberet</artifactId>\n    88→            <version>2.8.0</version>\n    89→        </dependency>\n    90→        <dependency>\n    91→            <groupId>io.quarkus</groupId>\n    92→            <artifactId>quarkus-arc</artifactId>\n    93→        </dependency>\n    94→        <dependency>\n    95→            <groupId>io.quarkus</groupId>\n    96→            <artifactId>quarkus-hibernate-orm</artifactId>\n    97→        </dependency>\n    98→        <dependency>\n    99→            <groupId>io.quarkus</groupId>\n   100→            <artifactId>quarkus-junit5</artifactId>\n   101→            <scope>test</scope>\n   102→        </dependency>\n   103→        <dependency>\n   104→            <groupId>io.rest-assured</groupId>\n   105→            <artifactId>rest-assured</artifactId>\n   106→            <scope>test</scope>\n   107→        </dependency>\n   108→    </dependencies>\n   109→\n   110→    <build>\n   111→        <plugins>\n   112→            <plugin>\n   113→                <groupId>${quarkus.platform.group-id}</groupId>\n   114→                <artifactId>quarkus-maven-plugin</artifactId>\n   115→                <version>${quarkus.platform.version}</version>\n   116→                <extensions>true</extensions>\n   117→                <executions>\n   118→                    <execution>\n   119→                        <goals>\n   120→                            <goal>build</goal>\n   121→                            <goal>generate-code</goal>\n   122→                            <goal>generate-code-tests</goal>\n   123→                