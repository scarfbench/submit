dling\")\n    27→@Transactional\n    28→public class HandlingReportService {\n    29→\n    30→    @Autowired\n    31→    private ApplicationEvents applicationEvents;\n    32→\n    33→    @PostMapping(value = \"/reports\", consumes = {\"application/json\", \"application/xml\"})\n    34→    public void submitReport(\n    35→            @NotNull(message = \"Missing handling report.\") @Valid @RequestBody HandlingReport handlingReport) {\n    36→        LocalDateTime completionTime = DateConverter.toDateTime(handlingReport.getCompletionTime());\n    37→        VoyageNumber voyageNumber = null;\n    38→\n    39→        if (handlingReport.getVoyageNumber() != null) {\n    40→            voyageNumber = new VoyageNumber(handlingReport.getVoyageNumber());\n    41→        }\n    42→\n    43→        HandlingEvent.Type type = HandlingEvent.Type.valueOf(handlingReport.getEventType());\n    44→        UnLocode unLocode = new UnLocode(handlingReport.getUnLocode());\n    45→        TrackingId trackingId = new TrackingId(handlingReport.getTrackingId());\n    46→\n    47→        HandlingEventRegistrationAttempt attempt =\n    48→                new HandlingEventRegistrationAttempt(\n    49→                        LocalDateTime.now(), completionTime, trackingId, voyageNumber, type, unLocode);\n    50→\n    51→        applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n    52→    }\n    53→}\n    54→"}]},"parent_tool_use_id":"toolu_bdrk_01JkZ646joRLRSWy5FjgnSZm","session_id":"726ac45c-03cf-4dc6-9fff-d69b80f6c98b","uuid":"2b0620d6-ce1e-4d60-8c87-88347aaaa538"}
