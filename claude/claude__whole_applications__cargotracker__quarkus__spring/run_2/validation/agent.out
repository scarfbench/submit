ndlingReportService {\n    28→\n    29→    @Autowired\n    30→    private ApplicationEvents applicationEvents;\n    31→\n    32→    @PostMapping(value = \"/reports\", consumes = {\"application/json\", \"application/xml\"})\n    33→    public void submitReport(@RequestBody @Valid HandlingReport handlingReport) {\n    34→        LocalDateTime completionTime = DateConverter.toDateTime(handlingReport.getCompletionTime());\n    35→        VoyageNumber voyageNumber = null;\n    36→\n    37→        if (handlingReport.getVoyageNumber() != null) {\n    38→            voyageNumber = new VoyageNumber(handlingReport.getVoyageNumber());\n    39→        }\n    40→\n    41→        HandlingEvent.Type type = HandlingEvent.Type.valueOf(handlingReport.getEventType());\n    42→        UnLocode unLocode = new UnLocode(handlingReport.getUnLocode());\n    43→\n    44→        TrackingId trackingId = new TrackingId(handlingReport.getTrackingId());\n    45→\n    46→        HandlingEventRegistrationAttempt attempt =\n    47→            new HandlingEventRegistrationAttempt(\n    48→                LocalDateTime.now(), completionTime, trackingId, voyageNumber, type, unLocode);\n    49→\n    50→        applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n    51→    }\n    52→}\n    53→"}]},"parent_tool_use_id":"toolu_bdrk_01Po5TzbCS71VY2e5ojJk3PJ","session_id":"6fabce19-5bc2-4de5-94d2-1fb45743d165","uuid":"23553bfa-ae24-41b0-96db-3290ca1b4978"}
