{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_011y3azeSyx6L3CuwH1yWEb6","type":"tool_result","content":"     1→package org.eclipse.cargotracker.interfaces.handling.mobile;\n     2→\n     3→import static java.util.stream.Collectors.toMap;\n     4→\n     5→import java.io.Serializable;\n     6→import java.time.LocalDateTime;\n     7→import java.util.ArrayList;\n     8→import java.util.Arrays;\n     9→import java.util.Collections;\n    10→import java.util.List;\n    11→import java.util.Map;\n    12→import java.util.function.Function;\n    13→import org.eclipse.cargotracker.application.ApplicationEvents;\n    14→import org.eclipse.cargotracker.application.util.DateConverter;\n    15→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    16→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    17→import org.eclipse.cargotracker.domain.model.cargo.TransportStatus;\n    18→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    19→import org.eclipse.cargotracker.domain.model.location.Location;\n    20→import org.eclipse.cargotracker.domain.model.location.UnLocode;\n    21→import org.eclipse.cargotracker.domain.model.voyage.Voyage;\n    22→import org.eclipse.cargotracker.domain.model.voyage.VoyageNumber;\n    23→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaCargoRepository;\n    24→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaLocationRepository;\n    25→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaVoyageRepository;\n    26→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    27→import org.springframework.beans.factory.annotation.Autowired;\n    28→import org.springframework.stereotype.Component;\n    29→\n    30→@Component\n    31→public class EventLogger implements Serializable {\n    32→\n    33→  private static final long serialVersionUID = 1L;\n    34→\n    35→  @Autowired\n    36→  private JpaCargoRepository cargoRepository;\n    37→  @Autowired\n    38→  private JpaLocationRepository locationRepository;\n    39→  @Autowired\n    40→  private JpaVoyageRepository voyageRepository;\n    41→  @Autowired\n    42→  private ApplicationEvents applicationEvents;\n    43→\n    44→  private List<SelectItem> trackingIds;\n    45→  private List<SelectItem> locations;\n    46→  private List<SelectItem> voyages;\n    47→\n    48→  private String trackingId;\n    49→  private String location;\n    50→  private HandlingEvent.Type eventType;\n    51→  private String voyageNumber;\n    52→  private LocalDateTime completionTime;\n    53→\n    54→  public String getTrackingId() {\n    55→    return trackingId;\n    56→  }\n    57→\n    58→  public void setTrackingId(String trackingId) {\n    59→    this.trackingId = trackingId;\n    60→  }\n    61→\n    62→  public List<SelectItem> getTrackingIds() {\n    63→    return trackingIds;\n    64→  }\n    65→\n    66→  public String getLocation() {\n    67→    return location;\n    68→  }\n    69→\n    70→  public void setLocation(String location) {\n    71→    this.location = location;\n    72→  }\n    73→\n    74→  public List<SelectItem> getLocations() {\n    75→    return locations;\n    76→  }\n    77→\n    78→  public Map<HandlingEvent.Type, HandlingEvent.Type> getEventTypes() {\n    79→    return Collections.unmodifiableMap(\n    80→        Arrays.asList(HandlingEvent.Type.values())\n    81→            .stream()\n    82→            .collect(toMap(Function.identity(), Function.identity())));\n    83→  }\n    84→\n    85→  public HandlingEvent.Type getEventType() {\n    86→    return eventType;\n    87→  }\n    88→\n    89→  public void setEventType(HandlingEvent.Type eventType) {\n    90→    this.eventType = eventType;\n    91→  }\n    92→\n    93→  public String getVoyageNumber() {\n    94→    return voyageNumber;\n    95→  }\n    96→\n    97→  public void setVoyageNumber(String voyageNumber) {\n    98→    this.voyageNumber = voyageNumber;\n    99→  }\n   100→\n   101→  public List<SelectItem> getVoyages() {\n   102→    return voyages;\n   103→  }\n   104→\n   105→  public LocalDateTime getCompletionTime() {\n   106→    return completionTime;\n   107→  }\n   108→\n   109→  public void setCompletionTime(LocalDateTime completionTime) {\n   110→    this.completionTime = completionTime;\n   111→  }\n   112→\n   113→  public String getCompletionTimeValue() {\n   114→    return DateConverter.toString(completionTime);\n   115→  }\n   116→\n   117→  public String getCompletionTimePattern() {\n   118→    return DateConverter.DATE_TIME_FORMAT;\n   119→  }\n   120→\n   121→  public void init() {\n   122→    List<Cargo> cargos = cargoRepository.findAll();\n   123→\n   124→    trackingIds = new ArrayList<>(cargos.size());\n   125→\n   126→    // List only routed cargo that is not claimed yet.\n   127→    cargos\n   128→        .stream()\n   129→        .filter(\n   130→            cargo -> !cargo.getItinerary().getLegs().isEmpty()\n   131→                && !(cargo\n   132→                    .getDelivery()\n   133→                    .getTransportStatus()\n   134→                    .sameValueAs(TransportStatus.CLAIMED)))\n   135→        .map(cargo -> cargo.getTrackingId().getIdString())\n   136→        .forEachOrdered(trackingId -> trackingIds.add(new SelectItem(trackingId, trackingId)));\n   137→\n   138→    List<Location> locations = locationRepository.findAll();\n   139→\n   140→    this.locations = new ArrayList<>(locations.size());\n   141→\n   142→    locations.forEach(\n   143→        location -> {\n   144→          String locationCode = location.getUnLocode().getIdString();\n   145→          this.locations.add(\n   146→              new SelectItem(locationCode, location.getName() + \" (\" + locationCode + \")\"));\n   147→        });\n   148→\n   149→    List<Voyage> voyages = voyageRepository.findAll(Sort.by(\"voyageNumber\"));\n   150→\n   151→    this.voyages = new ArrayList<>(voyages.size());\n   152→\n   153→    voyages.forEach(\n   154→        voyage -> this.voyages.add(\n   155→            new SelectItem(\n   156→                voyage.getVoyageNumber().getIdString(),\n   157→                voyage.getVoyageNumber().getIdString())));\n   158→  }\n   159→\n   160→  public String onFlowProcess(Object event) {\n   161→    // Flow processing removed - JSF specific\n   162→    return null;\n   163→  }\n   164→\n   165→  private boolean validate(final String step) {\n   166→    if (\"voyageTab\".equals(step) && eventType.requiresVoyage() && voyageNumber == null) {\n   167→      return false;\n   168→    }\n   169→\n   170→    return true;\n   171→  }\n   172→\n   173→  public void submit() {\n   174→    VoyageNumber voyage;\n   175→\n   176→    TrackingId trackingId = new TrackingId(this.trackingId);\n   177→    UnLocode location = new UnLocode(this.location);\n   178→\n   179→    if (eventType.requiresVoyage()) {\n   180→      voyage = new VoyageNumber(voyageNumber);\n   181→    } else {\n   182→      voyage = null;\n   183→    }\n   184→\n   185→    HandlingEventRegistrationAttempt attempt =\n   186→        new HandlingEventRegistrationAttempt(\n   187→            LocalDateTime.now(), completionTime, trackingId, voyage, eventType, location);\n   188→\n   189→    applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n   190→  }\n   191→\n   192→  // Simple SelectItem replacement for JSF\n   193→  public static class SelectItem {\n   194→    private final String value;\n   195→    private final String label;\n   196→\n   197→    public SelectItem(String value, String label) {\n   198→      this.value = value;\n   199→      this.label = label;\n   200→    }\n   201→\n   202→    public String getValue() {\n   203→      return value;\n   204→    }\n   205→\n   206→    public String getLabel() {\n   207→      return label;\n   208→    }\n   209→  }\n   210→}\n   211→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it