+x smoke.py; fi\n    36→\n    37→# Build the application at image build time\n    38→RUN mvn clean package -DskipTests\n    39→\n    40→# Start Artemis broker in background, then run Spring Boot\n    41→CMD /var/lib/artemis-broker/bin/artemis-service start && java -jar target/cargo-tracker-1.0.0-SNAPSHOT.jar\n    42→"}]},"parent_tool_use_id":null,"session_id":"6fabce19-5bc2-4de5-94d2-1fb45743d165","uuid":"7b8b74a0-4df6-4a26-963f-62ebe92ff17e"}
