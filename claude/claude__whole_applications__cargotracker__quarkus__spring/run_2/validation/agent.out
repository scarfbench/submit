Form":"Documenting migration"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":96782,"cache_read_input_tokens":12443,"cache_creation":{"ephemeral_5m_input_tokens":96782,"ephemeral_1h_input_tokens":0},"output_tokens":553},"context_management":null},"parent_tool_use_id":null,"session_id":"6fabce19-5bc2-4de5-94d2-1fb45743d165","uuid":"8657065d-afb5-403a-a317-bf66ab26bcda"}
