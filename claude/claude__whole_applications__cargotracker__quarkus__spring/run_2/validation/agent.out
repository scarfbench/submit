he domain model\n    29→ * classes where needed.\n    30→ *\n    31→ * <p>\n    32→ * In some very simplistic cases, it is fine to not use even an adapter.\n    33→ */\n    34→@Component(\"publicTrack\")\n    35→public class Track implements Serializable {\n    36→\n    37→  private static final long serialVersionUID = 1L;\n    38→\n    39→  @Autowired\n    40→  private transient Logger logger;\n    41→\n    42→  @Autowired\n    43→  private CargoRepository cargoRepository;\n    44→  @Autowired\n    45→  private HandlingEventRepository handlingEventRepository;\n    46→  @Autowired\n    47→  private ObjectMapper objectMapper;\n    48→\n    49→  private String trackingId;\n    50→  private CargoTrackingViewAdapter cargo;\n    51→\n    52→  public String getTrackingId() {\n    53→    return trackingId;\n    54→  }\n    55→\n    56→  public void setTrackingId(String trackingId) {\n    57→    if (trackingId != null) {\n    58→      trackingId = trackingId.trim();\n    59→    }\n    60→\n    61→    this.trackingId = trackingId;\n    62→  }\n    63→\n    64→  public CargoTrackingViewAdapter getCargo() {\n    65→    return cargo;\n    66→  }\n    67→\n    68→  public String getCargoAsJson() {\n    69→    try {\n    70→      return URLEncoder.encode(objectMapper.writeValueAsString(cargo), UTF_8.name());\n    71→    } catch (UnsupportedEncodingException | JsonProcessingException ex) {\n    72→      logger.log(Level.WARNING, \"URL encoding error.\", ex);\n    73→      return \"\"; // Should never happen.\n    74→    }\n    75→  }\n    76→\n    77→  public void onTrackById() {\n    78→    Cargo cargo = cargoRepository.find(new TrackingId(trackingId));\n    79→\n    80→    if (cargo != null) {\n    81→      List<HandlingEvent> handlingEvents =\n    82→          handlingEventRepository\n    83→              .lookupHandlingHistoryOfCargo(new TrackingId(trackingId))\n    84→              .getDistinctEventsByCompletionTime();\n    85→      this.cargo = new CargoTrackingViewAdapter(cargo, handlingEvents);\n    86→    } else {\n    87→      this.cargo = null;\n    88→    }\n    89→  }\n    90→}\n    91→"}]},"parent_tool_use_id":"toolu_bdrk_01TAT9CH1d56hdbJeZhmpWUg","session_id":"6fabce19-5bc2-4de5-94d2-1fb45743d165","uuid":"76911b8d-d401-4e1d-a532-a1ee03970845"}
