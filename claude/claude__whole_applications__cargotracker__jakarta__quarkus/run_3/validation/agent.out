75→  margin-bottom: 0;\n    76→  padding-bottom: 0;\n    77→}\n    78→\n    79→.side-panel .menu-container .ui-menu .ui-state-hover {\n    80→  background: inherit;\n    81→  /* remove default Primefaces background on hover */\n    82→}\n    83→\n    84→.side-panel .menu-container .ui-menu .ui-state-hover span {\n    85→  color: orange;\n    86→}\n    87→\n    88→.side-panel .menu-footer {\n    89→  position: absolute;\n    90→  bottom: 0;\n    91→  width: inherit;\n    92→  margin-left: -0.5em;\n    93→}\n    94→\n    95→/*************************************\n    96→             Table style\n    97→ *************************************/\n    98→\n    99→.ui-datatable table {\n   100→  border-collapse: collapse;\n   101→  width: 100%;\n   102→  font-size: 0.9em;\n   103→}\n   104→\n   105→.ui-datatable .ui-datatable-header,\n   106→.ui-datatable .ui-datatable-footer {\n   107→  text-align: left;\n   108→  padding: 4px 10px;\n   109→  text-align-last: left;\n   110→}\n   111→\n   112→.ui-datatable .ui-datatable-header {\n   113→  background: var(--primary-color);\n   114→  color: #ffffff;\n   115→\n   116→  font-weight: bold;\n   117→  font-size: 2em;\n   118→\n   119→  border-bottom: 0 none;\n   120→}\n   121→\n   122→.ui-datatable .ui-datatable-footer {\n   123→  border-top: 0 none;\n   124→  background: var(--primary-color);\n   125→}\n   126→\n   127→.ui-datatable th.ui-state-default,\n   128→.ui-datatable tfoot td.ui-state-default {\n   129→  background: var(--primary-color);\n   130→\n   131→  color: #ffffff;\n   132→  text-align: center;\n   133→  font-weight: bold;\n   134→  font-size: 1.5em;\n   135→\n   136→  border-top: 0 none;\n   137→  border-right: 0 none;\n   138→  border-left: 0 none;\n   139→}\n   140→\n   141→.ui-datatable thead th,\n   142→.ui-datatable tbody td,\n   143→.ui-datatable tfoot td {\n   144→  padding: 4px 10px;\n   145→  white-space: pre-line;\n   146→}\n   147→\n   148→.ui-datatable thead th,\n   149→.ui-datatable tbody td,\n   150→