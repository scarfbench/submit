 </dependencyManagement>\n    37→  <dependencies>\n    38→    <dependency>\n    39→      <groupId>jakarta.platform</groupId>\n    40→      <artifactId>jakarta.jakartaee-api</artifactId>\n    41→      <version>${jakartaee-api.version}</version>\n    42→      <scope>provided</scope>\n    43→    </dependency>\n    44→    <dependency>\n    45→      <groupId>org.glassfish.jaxb</groupId>\n    46→      <artifactId>jaxb-runtime</artifactId>\n    47→      <version>2.3.8</version>\n    48→      <scope>provided</scope>\n    49→    </dependency>\n    50→    <dependency>\n    51→      <groupId>org.apache.commons</groupId>\n    52→      <artifactId>commons-lang3</artifactId>\n    53→      <version>3.18.0</version>\n    54→    </dependency>\n    55→    <dependency>\n    56→      <groupId>org.primefaces</groupId>\n    57→      <artifactId>primefaces</artifactId>\n    58→      <version>10.0.26-LTS</version>\n    59→    </dependency>\n    60→    <dependency>\n    61→      <groupId>junit</groupId>\n    62→      <artifactId>junit</artifactId>\n    63→      <version>4.13.2</version>\n    64→      <scope>test</scope>\n    65→    </dependency>\n    66→    <dependency>\n    67→      <groupId>org.hamcrest</groupId>\n    68→      <artifactId>hamcrest</artifactId>\n    69→      <version>2.2</version>\n    70→      <scope>test</scope>\n    71→    </dependency>\n    72→    <dependency>\n    73→      <groupId>org.assertj</groupId>\n    74→      <artifactId>assertj-core</artifactId>\n    75→      <version>3.24.2</version>\n    76→      <scope>test</scope>\n    77→    </dependency>\n    78→    <dependency>\n    79→      <groupId>org.jboss.arquillian.junit</groupId>\n    80→      <artifactId>arquillian-junit-container</artifactId>\n    81→      <scope>test</scope>\n    82→    </dependency>\n    83→    <dependency>\n    84→      <groupId>org.jboss.shrinkwrap.resolver</groupId>\n    85→      <artifactId>shrinkwrap-resolver-impl-maven</artifactId>\n    86→      <scope>test</scope>\n    87→    </depend