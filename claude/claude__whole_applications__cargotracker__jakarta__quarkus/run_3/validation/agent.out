{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01N8AAD5B47BXEs8Xj1C9NsH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01UtZW3YpWhtQWYfx7pHyjQw","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__cargotracker__jakarta__quarkus/run_3/output/smoke/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"Smoke tests for Cargo Tracker Quarkus application.\"\"\"\n\nimport os\nimport sys\nimport time\nimport requests\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\nTIMEOUT = 10\n\n\ndef test_health_check():\n    \"\"\"Test that the Quarkus health endpoint is accessible.\"\"\"\n    url = f\"{BASE_URL}/q/health\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Health check failed: {resp.status_code} {resp.text}\"\n    data = resp.json()\n    assert data.get(\"status\") == \"UP\", f\"Health status is not UP: {data}\"\n    print(\"[PASS] Health check\")\n\n\ndef test_health_ready():\n    \"\"\"Test the readiness endpoint.\"\"\"\n    url = f\"{BASE_URL}/q/health/ready\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Readiness check failed: {resp.status_code} {resp.text}\"\n    print(\"[PASS] Readiness check\")\n\n\ndef test_health_live():\n    \"\"\"Test the liveness endpoint.\"\"\"\n    url = f\"{BASE_URL}/q/health/live\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Liveness check failed: {resp.status_code} {resp.text}\"\n    print(\"[PASS] Liveness check\")\n\n\ndef test_list_locations():\n    \"\"\"Test that locations endpoint returns sample locations.\"\"\"\n    url = f\"{BASE_URL}/rest/booking/locations\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"List locations failed: {resp.status_code} {resp.text}\"\n    locations = resp.json()\n    assert isinstance(locations, list), f\"Expected list, got {type(locations)}\"\n    assert len(locations) > 0, \"No locations returned\"\n    print(f\"[PASS] List locations - found {len(locations)} locations\")\n\n\ndef test_list_cargos():\n    \"\"\"Test that cargos endpoint returns sample cargos.\"\"\"\n    url = f\"{BASE_URL}/rest/booking/cargos\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"List cargos failed: {resp.status_code} {resp.text}\"\n    cargos = resp.json()\n    assert isinstance(cargos, list), f\"Expected list, got {type(cargos)}\"\n    assert len(cargos) > 0, \"No cargos returned - sample data may not have loaded\"\n    print(f\"[PASS] List cargos - found {len(cargos)} cargos\")\n\n\ndef test_get_cargo_by_tracking_id():\n    \"\"\"Test getting a specific cargo by tracking ID (sample data).\"\"\"\n    url = f\"{BASE_URL}/rest/booking/cargos/ABC123\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Get cargo failed: {resp.status_code} {resp.text}\"\n    cargo = resp.json()\n    assert \"trackingId\" in cargo or \"TrackingId\" in str(cargo), f\"Unexpected cargo format: {cargo}\"\n    print(\"[PASS] Get cargo by tracking ID (ABC123)\")\n\n\ndef test_track_cargo():\n    \"\"\"Test tracking a cargo by tracking ID.\"\"\"\n    url = f\"{BASE_URL}/rest/track/ABC123\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Track cargo failed: {resp.status_code} {resp.text}\"\n    print(\"[PASS] Track cargo (ABC123)\")\n\n\ndef test_track_nonexistent_cargo():\n    \"\"\"Test tracking a nonexistent cargo returns 404.\"\"\"\n    url = f\"{BASE_URL}/rest/track/NONEXISTENT999\"\n    resp = requests.get(url, timeout=TIMEOUT)\n    assert resp.status_code == 404, f\"Expected 404, got: {resp.status_code}\"\n    print(\"[PASS] Track nonexistent cargo returns 404\")\n\n\ndef test_graph_traversal():\n    \"\"\"Test the pathfinder graph traversal service.\"\"\"\n    url = f\"{BASE_URL}/rest/graph-traversal/shortest-path\"\n    params = {\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"}\n    resp = requests.get(url, params=params, timeout=TIMEOUT)\n    assert resp.status_code == 200, f\"Graph traversal failed: {resp.status_code} {resp.text}\"\n    paths = resp.json()\n    assert isinstance(paths, list), f\"Expected list, got {type(paths)}\"\n    assert len(paths) > 0, \"No transit paths returned\"\n    print(f\"[PASS] Graph traversal - found {len(paths)} paths from CNHKG to FIHEL\")\n\n\ndef test_handling_report():\n    \"\"\"Test submitting a handling report.\"\"\"\n    url = f\"{BASE_URL}/rest/handling/reports\"\n    report = {\n        \"completionTime\": \"3/15/2026 12:00 PM\",\n        \"trackingId\": \"ABC123\",\n        \"eventType\": \"UNLOAD\",\n        \"unLocode\": \"USDAL\",\n        \"voyageNumber\": \"0200T\"\n    }\n    resp = requests.post(url, json=report, timeout=TIMEOUT)\n    # Accept 200, 201, or 204 as success\n    assert resp.status_code in [200, 201, 204], \\\n        f\"Handling report submission failed: {resp.status_code} {resp.text}\"\n    print(\"[PASS] Submit handling report\")\n\n\ndef wait_for_startup(max_retries=30, delay=2):\n    \"\"\"Wait for the application to start.\"\"\"\n    print(f\"Waiting for application at {BASE_URL} ...\")\n    for i in range(max_retries):\n        try:\n            resp = requests.get(f\"{BASE_URL}/q/health\", timeout=5)\n            if resp.status_code == 200:\n                print(f\"Application is ready after {i * delay} seconds\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(delay)\n    print(f\"Application did not start after {max_retries * delay} seconds\")\n    return False\n\n\ndef main():\n    if not wait_for_startup():\n        print(\"[FAIL] Application did not start\")\n        sys.exit(1)\n\n    # Give a bit more time for sample data loading\n    time.sleep(3)\n\n    tests = [\n        test_health_check,\n        test_health_ready,\n        test_health_live,\n        test_list_locations,\n        test_list_cargos,\n        test_get_cargo_by_tracking_id,\n        test_track_cargo,\n        test_track_nonexistent_cargo,\n        test_graph_traversal,\n        test_handling_report,\n    ]\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except AssertionError as e:\n            failed += 1\n            errors.append(f\"[FAIL] {test.__name__}: {e}\")\n            print(f\"[FAIL] {test.__name__}: {e}\")\n        except Exception as e:\n            failed += 1\n            errors.append(f\"[ERROR] {test.__name__}: {e}\")\n            print(f\"[ERROR] {test.__name__}: {e}\")\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n\n    if errors:\n        print(\"\\nFailures:\")\n        for err in errors:\n            print(f\"  {err}\")\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":602,"cache_read_input_tokens":123830,"cache_creation":{"ephemeral_5m_input_tokens":602,"ephemeral_1h_input_tokens":0},"output_tokens":2138},"context_management":null},"parent_tool_use_id":null,"session_id":"a4072757-006a-493f-88e0-08a9064c7917","uuid":"e5571a33-9d15-42bc-8a00-7499ae45c766"}
