e-highlight {\n   211→  background: var(--primary-color-darker);\n   212→  color: var(--secondary-text-color);\n   213→}\n   214→\n   215→.ui-inputfield {\n   216→  border-width: 0 0 2px;\n   217→  border-color: var(--secondary-color)\n   218→}\n   219→\n   220→.ui-inputfield.ui-state-focus {\n   221→  outline: 0 none;\n   222→  box-shadow: none;\n   223→  border-color: var(--primary-color);\n   224→}\n   225→\n   226→/*************************************\n   227→             Timeline style\n   228→ *************************************/\n   229→\n   230→.ok-timeline-event {\n   231→  border: #90ee90;\n   232→  background: #818181 none !important;\n   233→  color: #ffffff !important;\n   234→}\n   235→\n   236→.error-timeline-event {\n   237→  border: #cd5c5c;\n   238→  background: #d26161 none !important;\n   239→  color: #ffffff !important;\n   240→}\n   241→\n   242→/*************************************\n   243→             Wizard style\n   244→ *************************************/\n   245→\n   246→.ui-wizard-step-titles {\n   247→  display: flex;\n   248→  align-items: center;\n   249→  justify-content: center;\n   250→\n   251→  width: 100%;\n   252→}\n   253→\n   254→.ui-wizard-step-titles::before {\n   255→  content: ' ';\n   256→  border-top: 1px solid black;\n   257→  width: 100%;\n   258→  left: 0;\n   259→  display: block;\n   260→  position: absolute;\n   261→  z-index: -100;\n   262→}\n   263→\n   264→.ui-wizard-step-title::before {\n   265→  content: '';\n   266→  display: inline-block;\n   267→  width: 15px;\n   268→  height: 15px;\n   269→  -moz-border-radius: 7.5px;\n   270→  -webkit-border-radius: 7.5px;\n   271→  border-radius: 7.5px;\n   272→  background-color: var(--background-panel-main-color);\n   273→  padding: 1px;\n   274→  margin: 10px;\n   275→}\n   276→\n   277→.ui-wizard-step-title {\n   278→  font-size: 0 !important;\n   279→  background: none;\n   280→  border: none;\n   281→}\n   282→\n   283→.ui-wizard-step-title.ui-state-highli