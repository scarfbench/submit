code,\n    75→                fromDate,\n    76→                toDate));\n    77→        fromUnLocode = toUnLocode;\n    78→        date = nextDate(toDate);\n    79→      }\n    80→      candidates.add(new TransitPath(transitEdges));\n    81→    }\n    82→    return candidates;\n    83→  }\n    84→\n    85→  private LocalDateTime nextDate(LocalDateTime date) {\n    86→    return date.plus(ONE_DAY_MS + (random.nextInt(1000) - 500) * ONE_MIN_MS, ChronoUnit.MILLIS);\n    87→  }\n    88→\n    89→  private int getRandomNumberOfCandidates() {\n    90→    return 3 + random.nextInt(3);\n    91→  }\n    92→\n    93→  private List<String> getRandomChunkOfLocations(List<String> allLocations) {\n    94→    Collections.shuffle(allLocations);\n    95→    int total = allLocations.size();\n    96→    int chunk = total > 4 ? 1 + random.nextInt(5) : total;\n    97→    return allLocations.subList(0, chunk);\n    98→  }\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_bdrk_0127QqeHMQV8DkvqJfVjFqAJ","session_id":"300f1a06-b6cf-43f1-b117-9879dd779de7","uuid":"bd26ddc9-d2e8-4dba-9838-29e8ac686349"}
