ypes>\n   116→                        <con:authType>Global HTTP Settings</con:authType>\n   117→                    </con:credentials>\n   118→                    <con:jmsConfig JMSDeliveryMode=\"PERSISTENT\"/>\n   119→                    <con:jmsPropertyConfig/>\n   120→                    <con:parameters>\n   121→                        <entry key=\"origin\" value=\"CNHKG\" xmlns=\"http://eviware.com/soapui/config\"/>\n   122→                    </con:parameters>\n   123→                </con:request>\n   124→            </con:method>\n   125→        </con:resource>\n   126→        <con:resource name=\"handling-reports\" path=\"/handling/reports\" id=\"48f88e9d-4bf4-4aae-b599-7e3083d5b7e1\">\n   127→            <con:settings/>\n   128→            <con:parameters/>\n   129→            <con:method name=\"Submit Report\" method=\"POST\" id=\"dc3389b3-6b4d-410a-8b0d-8a1083e7b687\">\n   130→                <con:settings/>\n   131→                <con:parameters/>\n   132→                <con:representation type=\"FAULT\">\n   133→                    <con:mediaType>text/html</con:mediaType>\n   134→                    <con:status>404 400 500 415</con:status>\n   135→                    <con:params/>\n   136→                    <con:element xmlns:xht=\"http://www.w3.org/1999/xhtml\">xht:html</con:element>\n   137→                </con:representation>\n   138→                <con:representation type=\"RESPONSE\">\n   139→                    <con:mediaType>application/json</con:mediaType>\n   140→                    <con:status>200</con:status>\n   141→                    <con:params/>\n   142→                    <con:element xmlns:exam=\"http://localhost/cargo-tracker/rest/handling/example\">exam:Response\n   143→                    </con:element>\n   144→                </con:representation>\n   145→                <con:representation type=\"REQUEST\">\n   146→                    <con:mediaType>application/json</con:mediaType>\n   147→                    <con:params/>\n 