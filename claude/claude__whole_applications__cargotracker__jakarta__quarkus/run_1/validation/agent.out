{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01RezxBrCaNwTKHu9TYzxG3N","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01TBMY7Aox5K8cC41Z6UqbX5","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__cargotracker__jakarta__quarkus/run_1/output/smoke/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"Smoke tests for the Cargo Tracker Quarkus application.\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport requests\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\ndef log(msg):\n    print(f\"[SMOKE] {msg}\")\n\ndef test_health_check():\n    \"\"\"Test that the health endpoint responds.\"\"\"\n    log(\"Testing health check endpoint...\")\n    resp = requests.get(f\"{BASE_URL}/q/health\", timeout=10)\n    assert resp.status_code == 200, f\"Health check failed with status {resp.status_code}\"\n    data = resp.json()\n    assert data[\"status\"] == \"UP\", f\"Health status is not UP: {data['status']}\"\n    log(\"  PASS: Health check endpoint responds with UP status\")\n\ndef test_health_live():\n    \"\"\"Test that the liveness endpoint responds.\"\"\"\n    log(\"Testing liveness endpoint...\")\n    resp = requests.get(f\"{BASE_URL}/q/health/live\", timeout=10)\n    assert resp.status_code == 200, f\"Liveness check failed with status {resp.status_code}\"\n    log(\"  PASS: Liveness endpoint responds OK\")\n\ndef test_health_ready():\n    \"\"\"Test that the readiness endpoint responds.\"\"\"\n    log(\"Testing readiness endpoint...\")\n    resp = requests.get(f\"{BASE_URL}/q/health/ready\", timeout=10)\n    assert resp.status_code == 200, f\"Readiness check failed with status {resp.status_code}\"\n    log(\"  PASS: Readiness endpoint responds OK\")\n\ndef test_list_locations():\n    \"\"\"Test listing available shipping locations.\"\"\"\n    log(\"Testing list locations endpoint...\")\n    resp = requests.get(f\"{BASE_URL}/rest/booking/locations\", timeout=10)\n    assert resp.status_code == 200, f\"List locations failed with status {resp.status_code}\"\n    locations = resp.json()\n    assert isinstance(locations, list), \"Locations should be a list\"\n    assert len(locations) > 0, \"Should have at least one location\"\n    log(f\"  PASS: Found {len(locations)} locations\")\n\ndef test_list_cargos():\n    \"\"\"Test listing all cargos (sample data should be loaded).\"\"\"\n    log(\"Testing list cargos endpoint...\")\n    resp = requests.get(f\"{BASE_URL}/rest/booking/cargos\", timeout=10)\n    assert resp.status_code == 200, f\"List cargos failed with status {resp.status_code}\"\n    cargos = resp.json()\n    assert isinstance(cargos, list), \"Cargos should be a list\"\n    assert len(cargos) >= 4, f\"Should have at least 4 sample cargos, got {len(cargos)}\"\n    log(f\"  PASS: Found {len(cargos)} cargos\")\n\ndef test_get_cargo_abc123():\n    \"\"\"Test getting a specific cargo by tracking ID.\"\"\"\n    log(\"Testing get cargo ABC123...\")\n    resp = requests.get(f\"{BASE_URL}/rest/booking/cargos/ABC123\", timeout=10)\n    assert resp.status_code == 200, f\"Get cargo failed with status {resp.status_code}\"\n    cargo = resp.json()\n    assert cargo[\"trackingId\"] == \"ABC123\", f\"Expected ABC123 but got {cargo.get('trackingId')}\"\n    log(\"  PASS: Cargo ABC123 found with correct tracking ID\")\n\ndef test_track_cargo():\n    \"\"\"Test the tracking endpoint.\"\"\"\n    log(\"Testing track cargo ABC123...\")\n    resp = requests.get(f\"{BASE_URL}/rest/track/ABC123\", timeout=10)\n    assert resp.status_code == 200, f\"Track cargo failed with status {resp.status_code}\"\n    status = resp.json()\n    assert status[\"trackingId\"] == \"ABC123\", f\"Expected ABC123 but got {status.get('trackingId')}\"\n    log(\"  PASS: Track cargo returns correct data\")\n\ndef test_track_unknown_cargo():\n    \"\"\"Test tracking a non-existent cargo.\"\"\"\n    log(\"Testing track unknown cargo...\")\n    resp = requests.get(f\"{BASE_URL}/rest/track/ZZZZZ\", timeout=10)\n    assert resp.status_code == 404, f\"Expected 404 for unknown cargo, got {resp.status_code}\"\n    log(\"  PASS: Unknown cargo returns 404\")\n\ndef test_graph_traversal():\n    \"\"\"Test the graph traversal / pathfinding endpoint.\"\"\"\n    log(\"Testing graph traversal endpoint...\")\n    resp = requests.get(\n        f\"{BASE_URL}/rest/graph-traversal/shortest-path\",\n        params={\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"},\n        timeout=10\n    )\n    assert resp.status_code == 200, f\"Graph traversal failed with status {resp.status_code}\"\n    paths = resp.json()\n    assert isinstance(paths, list), \"Should return a list of transit paths\"\n    assert len(paths) > 0, \"Should find at least one path\"\n    log(f\"  PASS: Found {len(paths)} possible routes\")\n\ndef test_handling_report():\n    \"\"\"Test submitting a handling report.\"\"\"\n    log(\"Testing handling report endpoint...\")\n    report = {\n        \"completionTime\": \"3/15/2026 8:30 AM\",\n        \"trackingId\": \"ABC123\",\n        \"eventType\": \"UNLOAD\",\n        \"unLocode\": \"USDAL\",\n        \"voyageNumber\": \"0200T\"\n    }\n    resp = requests.post(\n        f\"{BASE_URL}/rest/handling/reports\",\n        json=report,\n        headers={\"Content-Type\": \"application/json\"},\n        timeout=10\n    )\n    # 200 or 204 are both acceptable\n    assert resp.status_code in (200, 204), \\\n        f\"Handling report failed with status {resp.status_code}: {resp.text}\"\n    log(\"  PASS: Handling report accepted\")\n\ndef test_request_routes():\n    \"\"\"Test requesting possible routes for a cargo.\"\"\"\n    log(\"Testing request routes for DEF789...\")\n    resp = requests.get(f\"{BASE_URL}/rest/booking/cargos/DEF789/routes\", timeout=10)\n    assert resp.status_code == 200, f\"Request routes failed with status {resp.status_code}\"\n    routes = resp.json()\n    assert isinstance(routes, list), \"Routes should be a list\"\n    log(f\"  PASS: Found {len(routes)} possible routes for DEF789\")\n\ndef wait_for_app(max_wait=120):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    log(f\"Waiting for application at {BASE_URL} (max {max_wait}s)...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            resp = requests.get(f\"{BASE_URL}/q/health/ready\", timeout=5)\n            if resp.status_code == 200:\n                log(\"Application is ready!\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    log(\"ERROR: Application did not become ready in time\")\n    return False\n\ndef main():\n    if not wait_for_app():\n        sys.exit(1)\n\n    # Give sample data time to load\n    time.sleep(3)\n\n    tests = [\n        test_health_check,\n        test_health_live,\n        test_health_ready,\n        test_list_locations,\n        test_list_cargos,\n        test_get_cargo_abc123,\n        test_track_cargo,\n        test_track_unknown_cargo,\n        test_graph_traversal,\n        test_handling_report,\n        test_request_routes,\n    ]\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except Exception as e:\n            failed += 1\n            errors.append((test.__name__, str(e)))\n            log(f\"  FAIL: {test.__name__}: {e}\")\n\n    log(f\"\\nResults: {passed} passed, {failed} failed, {len(tests)} total\")\n\n    if errors:\n        log(\"\\nFailed tests:\")\n        for name, error in errors:\n            log(f\"  - {name}: {error}\")\n\n    sys.exit(0 if failed == 0 else 1)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":275,"cache_read_input_tokens":124363,"cache_creation":{"ephemeral_5m_input_tokens":275,"ephemeral_1h_input_tokens":0},"output_tokens":2252},"context_management":null},"parent_tool_use_id":null,"session_id":"300f1a06-b6cf-43f1-b117-9879dd779de7","uuid":"a868c41f-b1b9-4d58-ab91-dbfa42fd72cf"}
