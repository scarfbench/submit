{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01Cv7oTchCJDNnBPWeWLiUxa","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01RQVemGwwetzL4bjYd1Tvqj","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__cargotracker__jakarta__quarkus/run_2/output/smoke/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"Smoke tests for Cargo Tracker Quarkus application.\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport requests\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\nREST_BASE = f\"{BASE_URL}/rest\"\n\npassed = 0\nfailed = 0\nerrors = []\n\n\ndef test(name, func):\n    \"\"\"Run a test and track results.\"\"\"\n    global passed, failed\n    try:\n        func()\n        passed += 1\n        print(f\"  PASS: {name}\")\n    except Exception as e:\n        failed += 1\n        errors.append((name, str(e)))\n        print(f\"  FAIL: {name} - {e}\")\n\n\ndef wait_for_app(timeout=120):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    print(f\"Waiting for application at {BASE_URL}...\")\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            r = requests.get(f\"{BASE_URL}/q/health/ready\", timeout=5)\n            if r.status_code == 200:\n                print(\"Application is ready!\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        time.sleep(2)\n    print(\"Timeout waiting for application\")\n    return False\n\n\ndef test_health_check():\n    \"\"\"Test health endpoint.\"\"\"\n    r = requests.get(f\"{BASE_URL}/q/health\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert data[\"status\"] == \"UP\", f\"Health status is {data['status']}\"\n\n\ndef test_health_ready():\n    \"\"\"Test readiness endpoint.\"\"\"\n    r = requests.get(f\"{BASE_URL}/q/health/ready\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n\n\ndef test_health_live():\n    \"\"\"Test liveness endpoint.\"\"\"\n    r = requests.get(f\"{BASE_URL}/q/health/live\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n\n\ndef test_list_cargos():\n    \"\"\"Test listing all cargos.\"\"\"\n    r = requests.get(f\"{REST_BASE}/booking/cargos\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 4, f\"Expected at least 4 cargos (sample data), got {len(data)}\"\n\n\ndef test_list_locations():\n    \"\"\"Test listing all shipping locations.\"\"\"\n    r = requests.get(f\"{REST_BASE}/booking/locations\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 13, f\"Expected at least 13 locations, got {len(data)}\"\n\n\ndef test_list_tracking_ids():\n    \"\"\"Test listing all tracking IDs.\"\"\"\n    r = requests.get(f\"{REST_BASE}/booking/trackingids\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert \"ABC123\" in data, f\"Expected ABC123 in tracking IDs: {data}\"\n    assert \"JKL567\" in data, f\"Expected JKL567 in tracking IDs: {data}\"\n    assert \"DEF789\" in data, f\"Expected DEF789 in tracking IDs: {data}\"\n    assert \"MNO456\" in data, f\"Expected MNO456 in tracking IDs: {data}\"\n\n\ndef test_get_cargo_details():\n    \"\"\"Test getting specific cargo details.\"\"\"\n    r = requests.get(f\"{REST_BASE}/booking/cargos/ABC123\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert data[\"trackingId\"] == \"ABC123\", f\"Expected ABC123, got {data.get('trackingId')}\"\n\n\ndef test_track_cargo():\n    \"\"\"Test tracking a specific cargo.\"\"\"\n    r = requests.get(f\"{REST_BASE}/booking/tracking/ABC123\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert data[\"trackingId\"] == \"ABC123\", f\"Expected ABC123, got {data.get('trackingId')}\"\n\n\ndef test_graph_traversal():\n    \"\"\"Test the graph traversal shortest path endpoint.\"\"\"\n    r = requests.get(\n        f\"{REST_BASE}/graph-traversal/shortest-path\",\n        params={\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"},\n        timeout=10,\n    )\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) > 0, \"Expected at least one transit path\"\n\n\ndef test_handling_report():\n    \"\"\"Test submitting a handling report.\"\"\"\n    report = {\n        \"completionTime\": \"3/15/2026 12:00 PM\",\n        \"trackingId\": \"ABC123\",\n        \"eventType\": \"UNLOAD\",\n        \"unLocode\": \"USDAL\",\n        \"voyageNumber\": \"0200T\",\n    }\n    r = requests.post(\n        f\"{REST_BASE}/handling/reports\",\n        json=report,\n        headers={\"Content-Type\": \"application/json\"},\n        timeout=10,\n    )\n    # 200 or 204 both acceptable for successful post\n    assert r.status_code in [200, 204], f\"Expected 200/204, got {r.status_code}: {r.text}\"\n\n\ndef test_cargo_tracking_endpoint():\n    \"\"\"Test the real-time cargo tracking REST endpoint.\"\"\"\n    r = requests.get(f\"{REST_BASE}/cargo\", timeout=10)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n\n\ndef main():\n    \"\"\"Run all smoke tests.\"\"\"\n    print(\"=\" * 60)\n    print(\"Cargo Tracker Smoke Tests\")\n    print(\"=\" * 60)\n    print(f\"Target: {BASE_URL}\")\n    print()\n\n    if not wait_for_app():\n        print(\"FATAL: Application did not start in time\")\n        sys.exit(1)\n\n    # Give the app a few more seconds for sample data to load\n    time.sleep(5)\n\n    print(\"\\nRunning tests...\")\n    print(\"-\" * 40)\n\n    test(\"Health Check\", test_health_check)\n    test(\"Health Ready\", test_health_ready)\n    test(\"Health Live\", test_health_live)\n    test(\"List Cargos\", test_list_cargos)\n    test(\"List Locations\", test_list_locations)\n    test(\"List Tracking IDs\", test_list_tracking_ids)\n    test(\"Get Cargo Details (ABC123)\", test_get_cargo_details)\n    test(\"Track Cargo (ABC123)\", test_track_cargo)\n    test(\"Graph Traversal\", test_graph_traversal)\n    test(\"Submit Handling Report\", test_handling_report)\n    test(\"Cargo Tracking Endpoint\", test_cargo_tracking_endpoint)\n\n    print()\n    print(\"=\" * 60)\n    print(f\"Results: {passed} passed, {failed} failed out of {passed + failed} tests\")\n\n    if errors:\n        print(\"\\nFailed tests:\")\n        for name, err in errors:\n            print(f\"  - {name}: {err}\")\n\n    print(\"=\" * 60)\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":653,"cache_read_input_tokens":139544,"cache_creation":{"ephemeral_5m_input_tokens":653,"ephemeral_1h_input_tokens":0},"output_tokens":2222},"context_management":null},"parent_tool_use_id":null,"session_id":"8a9b0dd0-5198-4e27-99cf-ce225aa708f6","uuid":"ba470a45-30b4-4e0f-b0aa-f667fec01cf9"}
