   44→        return current;\n    45→    }\n    46→\n    47→    private ContactService getFacade() {\n    48→        return ejbFacade;\n    49→    }\n    50→\n    51→    public static abstract class PaginationHelper {\n    52→        private final int pageSize;\n    53→        private int page;\n    54→\n    55→        protected PaginationHelper(int pageSize) { this.pageSize = pageSize; }\n    56→\n    57→        public abstract int getItemsCount();\n    58→\n    59→        public abstract List<Contact> createPageData();\n    60→\n    61→        public int getPageFirstItem() {\n    62→            return page * pageSize;\n    63→        }\n    64→\n    65→        public int getPageLastItem() {\n    66→            int i = getPageFirstItem() + pageSize - 1;\n    67→            int count = getItemsCount() - 1;\n    68→            if (i > count) {\n    69→                i = count;\n    70→            }\n    71→            if (i < 0) {\n    72→                i = 0;\n    73→            }\n    74→            return i;\n    75→        }\n    76→\n    77→        public boolean isHasNextPage() {\n    78→            return (page + 1) * pageSize + 1 <= getItemsCount();\n    79→        }\n    80→\n    81→        public void nextPage() {\n    82→            if (isHasNextPage()) {\n    83→                page++;\n    84→            }\n    85→        }\n    86→\n    87→        public boolean isHasPreviousPage() {\n    88→            return page > 0;\n    89→        }\n    90→\n    91→        public void previousPage() {\n    92→            if (isHasPreviousPage()) {\n    93→                page--;\n    94→            }\n    95→        }\n    96→\n    97→        public int getPageSize() {\n    98→            return pageSize;\n    99→        }\n   100→    }\n   101→\n   102→    public PaginationHelper getPagination() {\n   103→        if (pagination == null) {\n   104→            pagination = new PaginationHelper(10) {\n   105→                @Override\n   106→                public int getItemsCount() {\n   107→                    return getFacade().count();\n   108→                }\n   109→\n   110→                @Override\n   111→                public List<Contact> createPageData() {\n   112→                    int first = getPageFirstItem();\n   113→                    int lastExclusive = getPageFirstItem() + getPageSize();\n   114→                    return getFacade().findRange(new int[]{first, lastExclusive});\n   115→                }\n   116→            };\n   117→        }\n   118→        return pagination;\n   119→    }\n   120→\n   121→    public String prepareList() {\n   122→        recreateModel();\n   123→        return \"List\";\n   124→    }\n   125→\n   126→    public String prepareView(Contact contact) {\n   127→        current = contact;\n   128→        selectedItemIndex = getItems().indexOf(contact);\n   129→        return \"View\";\n   130→    }\n   131→\n   132→    public String prepareCreate() {\n   133→        current = new Contact();\n   134→        selectedItemIndex = -1;\n   135→        return \"Create\";\n   136→    }\n   137→\n   138→    public String create() {\n   139→        try {\n   140→            getFacade().create(current);\n   141→            FacesContext.getCurrentInstance().addMessage(null,\n   142→                    new FacesMessage(\n   143→                            ResourceBundle.getBundle(\"Bundle\").getString(\"ContactCreated\")));\n   144→            return prepareCreate();\n   145→        } catch (Exception e) {\n   146→            FacesContext.getCurrentInstance().addMessage(null,\n   147→                    new FacesMessage(\n   148→                            ResourceBundle.getBundle(\"Bundle\").getString(\"PersistenceErrorOccured\")));\n   149→            return null;\n   150→        }\n   151→    }\n   152→\n   153→    public String prepareEdit(Contact contact) {\n   154→        current = contact;\n   155→        selectedItemIndex = getItems().indexOf(contact);\n   156→        return \"Edit\";\n   157→    }\n   158→\n   159→    public String update() {\n   160→        try {\n   161→            getFacade().edit(current);\n   162→            FacesContext.getCurrentInstance().addMessage(null,\n   163→                    new FacesMessage(\n   164→                            ResourceBundle.getBundle(\"Bundle\").getString(\"ContactUpdated\")));\n   165→            return \"View\";\n   166→        } catch (Exception e) {\n   167→            FacesContext.getCurrentInstance().addMessage(null,\n   168→                    new FacesMessage(\n   169→                            ResourceBundle.getBundle(\"Bundle\").getString(\"PersistenceErrorOccured\")));\n   170→            return null;\n   171→        }\n   172→    }\n   173→\n   174→    public String destroy(Contact contact) {\n   175→        current = contact;\n   176→        selectedItemIndex = getItems().indexOf(contact);\n   177→        performDestroy();\n   178→        recreateModel();\n   179→        return \"List\";\n   180→    }\n   181→\n   182→    public String destroyAndView() {\n   183→        performDestroy();\n   184→        recreateModel();\n   185→        updateCurrentItem();\n   186→        if (selectedItemIndex >= 0) {\n   187→            return \"View\";\n   188→        } else {\n   189→            recreateModel();\n   190→            return \"List\";\n   191→        }\n   192→    }\n   193→\n   194→    private void performDestroy() {\n   195→        try {\n   196→            getFacade().remove(current);\n   197→            FacesContext.getCurrentInstance().addMessage(null,\n   198→                    new FacesMessage(\n   199→                            ResourceBundle.getBundle(\"Bundle\").getString(\"ContactDeleted\")));\n   200→        } catch (Exception e) {\n   201→            FacesContext.getCurrentInstance().addMessage(null,\n   202→                    new FacesMessage(\n   203→                            ResourceBundle.getBundle(\"Bundle\").getString(\"PersistenceErrorOccured\")));\n   204→        }\n   205→    }\n   206→\n   207→    private void updateCurrentItem() {\n   208→        int count = getFacade().count();\n   209→        if (selectedItemIndex >= count) {\n   210→            selectedItemIndex = count - 1;\n   211→            if (getPagination().getPageFirstItem() >= count) {\n   212→                getPagination().previousPage();\n   213→            }\n   214→        }\n   215→        if (selectedItemIndex >= 0) {\n   216→            current = getFacade().findRange(new int[]{selectedItemIndex, selectedItemIndex + 1}).get(0);\n   217→        } else {\n   218→            current = null;\n   219→        }\n   220→    }\n   221→\n   222→    public List<Contact> getItems() {\n   223→        if (items == null) {\n   224→            items = new ArrayList<>(getPagination().createPageData());\n   225→        }\n   226→        return items;\n   227→    }\n   228→\n   229→    private void recreateModel() {\n   230→        items = null;\n   231→    }\n   232→\n   233→    public String next() {\n   234→        getPagination().nextPage();\n   235→        recreateModel();\n   236→        return \"List\";\n   237→    }\n   238→\n   239→    public String previous() {\n   240→        getPagination().previousPage();\n   241→        recreateModel();\n   242→        return \"List\";\n   243→    }\n   244→\n   245→    public List<Contact> getItemsAvailableSelectMany() {\n   246→        return getFacade().findAll();\n   247→    }\n   248→\n   249→    public List<Contact> getItemsAvailableSelectOne() {\n   250→        return getFacade().findAll();\n   251→    }\n   252→}\n   253→"}]},"parent_tool_use_id":null,"session_id":"1d77b2ee-6e15-42d9-9f65-0c272b9a6995","uuid":"e7c5eac2-22bb-4353-8a3d-e3924de19c58"}
