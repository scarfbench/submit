 -- 78) Hibernate: \n\u001b[0m\u001b[0m22:28:44,810 INFO  [stdout] (ServerService Thread Pool -- 78)     create table Contact (\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         birthday date,\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         id bigint not null,\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         email varchar(255),\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         firstName varchar(255) not null,\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         homePhone varchar(255),\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         lastName varchar(255) not null,\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         mobilePhone varchar(255),\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)         primary key (id)\n\u001b[0m\u001b[0m22:28:44,811 INFO  [stdout] (ServerService Thread Pool -- 78)     )\n\u001b[0m\u001b[0m22:28:45,521 INFO  [jakarta.enterprise.resource.webcontainer.faces.config] (ServerService Thread Pool -- 78) Initializing Mojarra 4.0.5 for context '/address-book'\n\u001b[0m\u001b[0m22:28:45,815 INFO  [jakarta.enterprise.resource.webcontainer.faces.config] (ServerService Thread Pool -- 78) Monitoring file:/opt/jboss/wildfly/standalone/tmp/vfs/temp/tempdadc5a6a5f7f4f1a/content-93073b97f2ec245b/WEB-INF/faces-config.xml for modifications\n\u001b[0m\u001b[0m22:28:46,251 INFO  [org.jboss.resteasy.resteasy_jaxrs.i18n] (ServerService Thread Pool -- 78) RESTEASY002225: Deploying jakarta.ws.rs.core.Application: class com.example.addressbook.rest.RestApplication$Proxy$_$$_WeldClientProxy\n\u001b[0m\u001b[0m22:28:46,295 INFO  [org.wildfly.extension.undertow] (ServerService Thread Pool -- 78) WFLYUT0021: Registered web context: '/address-book' for server 'default-se