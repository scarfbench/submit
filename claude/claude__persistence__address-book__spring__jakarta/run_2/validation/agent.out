{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01CtSMaZRmUGHabu1t4VQxh4","type":"message","role":"assistant","content":[{"type":"text","text":"Now let me create the smoke test file:"}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1179,"cache_read_input_tokens":64211,"cache_creation":{"ephemeral_5m_input_tokens":1179,"ephemeral_1h_input_tokens":0},"output_tokens":2283},"context_management":null},"parent_tool_use_id":null,"session_id":"5178e60b-6983-4b64-b8b8-e65cc691e770","uuid":"8d2a36d7-aa42-4dba-87be-6289a10ea55c"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01CtSMaZRmUGHabu1t4VQxh4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_018SuCQ9XY9GdhwGxnSvcTyr","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__address-book__spring__jakarta/run_2/output/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"\nSmoke tests for the Address Book Jakarta EE application.\nTests the REST API endpoints and JSF pages.\n\"\"\"\n\nimport os\nimport sys\nimport time\nimport requests\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\nAPP_PATH = \"/address-book\"\nAPI_BASE = f\"{BASE_URL}{APP_PATH}/api\"\n\n\ndef wait_for_server(timeout=120):\n    \"\"\"Wait for the server to be ready.\"\"\"\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            r = requests.get(f\"{API_BASE}/health\", timeout=5)\n            if r.status_code == 200:\n                print(f\"Server ready after {time.time() - start:.1f}s\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    print(f\"Server did not become ready within {timeout}s\")\n    return False\n\n\ndef test_health_endpoint():\n    \"\"\"Test the health endpoint returns 200.\"\"\"\n    r = requests.get(f\"{API_BASE}/health\", timeout=10)\n    assert r.status_code == 200, f\"Health check failed: {r.status_code}\"\n    data = r.json()\n    assert data[\"status\"] == \"UP\", f\"Health status is not UP: {data}\"\n    print(\"PASS: Health endpoint\")\n\n\ndef test_index_page():\n    \"\"\"Test that the JSF index page loads.\"\"\"\n    r = requests.get(f\"{BASE_URL}{APP_PATH}/index.xhtml\", timeout=10)\n    assert r.status_code == 200, f\"Index page failed: {r.status_code}\"\n    assert \"Address Book\" in r.text or \"Welcome\" in r.text, \"Index page content missing\"\n    print(\"PASS: Index page\")\n\n\ndef test_contact_list_page():\n    \"\"\"Test that the contact list JSF page loads.\"\"\"\n    r = requests.get(f\"{BASE_URL}{APP_PATH}/contact/List.xhtml\", timeout=10)\n    assert r.status_code == 200, f\"Contact list page failed: {r.status_code}\"\n    print(\"PASS: Contact list page\")\n\n\ndef test_create_contact_page():\n    \"\"\"Test that the create contact JSF page loads.\"\"\"\n    r = requests.get(f\"{BASE_URL}{APP_PATH}/contact/Create.xhtml\", timeout=10)\n    assert r.status_code == 200, f\"Create contact page failed: {r.status_code}\"\n    print(\"PASS: Create contact page\")\n\n\ndef test_rest_contacts_empty():\n    \"\"\"Test that the contacts API returns an empty list initially.\"\"\"\n    r = requests.get(f\"{API_BASE}/contacts\", timeout=10)\n    assert r.status_code == 200, f\"Contacts API failed: {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    print(f\"PASS: REST contacts list (count: {len(data)})\")\n\n\ndef test_rest_create_contact():\n    \"\"\"Test creating a contact via REST API.\"\"\"\n    contact = {\n        \"firstName\": \"John\",\n        \"lastName\": \"Doe\",\n        \"email\": \"john@example.com\",\n        \"mobilePhone\": \"555-123-4567\",\n        \"homePhone\": \"555-987-6543\"\n    }\n    r = requests.post(f\"{API_BASE}/contacts\", json=contact, timeout=10)\n    assert r.status_code == 201, f\"Create contact failed: {r.status_code} - {r.text}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"John\", f\"Name mismatch: {data}\"\n    assert data[\"id\"] is not None, \"Contact ID should be set\"\n    print(f\"PASS: REST create contact (id: {data['id']})\")\n    return data[\"id\"]\n\n\ndef test_rest_get_contact(contact_id):\n    \"\"\"Test getting a single contact via REST API.\"\"\"\n    r = requests.get(f\"{API_BASE}/contacts/{contact_id}\", timeout=10)\n    assert r.status_code == 200, f\"Get contact failed: {r.status_code}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"John\", f\"Name mismatch: {data}\"\n    print(f\"PASS: REST get contact {contact_id}\")\n\n\ndef test_rest_update_contact(contact_id):\n    \"\"\"Test updating a contact via REST API.\"\"\"\n    contact = {\n        \"firstName\": \"Jane\",\n        \"lastName\": \"Doe\",\n        \"email\": \"jane@example.com\",\n        \"mobilePhone\": \"555-123-4567\",\n        \"homePhone\": \"555-987-6543\"\n    }\n    r = requests.put(f\"{API_BASE}/contacts/{contact_id}\", json=contact, timeout=10)\n    assert r.status_code == 200, f\"Update contact failed: {r.status_code} - {r.text}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"Jane\", f\"Name not updated: {data}\"\n    print(f\"PASS: REST update contact {contact_id}\")\n\n\ndef test_rest_contact_count():\n    \"\"\"Test the contact count endpoint.\"\"\"\n    r = requests.get(f\"{API_BASE}/contacts/count\", timeout=10)\n    assert r.status_code == 200, f\"Count failed: {r.status_code}\"\n    data = r.json()\n    assert data[\"count\"] >= 1, f\"Expected at least 1 contact: {data}\"\n    print(f\"PASS: REST contact count ({data['count']})\")\n\n\ndef test_rest_delete_contact(contact_id):\n    \"\"\"Test deleting a contact via REST API.\"\"\"\n    r = requests.delete(f\"{API_BASE}/contacts/{contact_id}\", timeout=10)\n    assert r.status_code == 204, f\"Delete contact failed: {r.status_code}\"\n    # Verify deletion\n    r2 = requests.get(f\"{API_BASE}/contacts/{contact_id}\", timeout=10)\n    assert r2.status_code == 404, f\"Contact should be deleted: {r2.status_code}\"\n    print(f\"PASS: REST delete contact {contact_id}\")\n\n\ndef test_rest_get_nonexistent():\n    \"\"\"Test that getting a nonexistent contact returns 404.\"\"\"\n    r = requests.get(f\"{API_BASE}/contacts/99999\", timeout=10)\n    assert r.status_code == 404, f\"Expected 404, got: {r.status_code}\"\n    print(\"PASS: REST get nonexistent contact returns 404\")\n\n\ndef main():\n    print(f\"Running smoke tests against {BASE_URL}\")\n    print(f\"API base: {API_BASE}\")\n    print(\"=\" * 60)\n\n    if not wait_for_server():\n        print(\"FAIL: Server not ready\")\n        sys.exit(1)\n\n    failures = 0\n    tests_run = 0\n\n    test_funcs = [\n        (\"Health endpoint\", lambda: test_health_endpoint()),\n        (\"Index page\", lambda: test_index_page()),\n        (\"Contact list page\", lambda: test_contact_list_page()),\n        (\"Create contact page\", lambda: test_create_contact_page()),\n        (\"REST contacts empty\", lambda: test_rest_contacts_empty()),\n        (\"REST get nonexistent\", lambda: test_rest_get_nonexistent()),\n    ]\n\n    for name, func in test_funcs:\n        tests_run += 1\n        try:\n            func()\n        except Exception as e:\n            print(f\"FAIL: {name} - {e}\")\n            failures += 1\n\n    # CRUD sequence tests\n    try:\n        tests_run += 1\n        contact_id = test_rest_create_contact()\n\n        tests_run += 1\n        test_rest_get_contact(contact_id)\n\n        tests_run += 1\n        test_rest_update_contact(contact_id)\n\n        tests_run += 1\n        test_rest_contact_count()\n\n        tests_run += 1\n        test_rest_delete_contact(contact_id)\n    except Exception as e:\n        print(f\"FAIL: CRUD sequence - {e}\")\n        failures += 1\n\n    print(\"=\" * 60)\n    print(f\"Tests run: {tests_run}, Failures: {failures}\")\n\n    if failures > 0:\n        print(\"SMOKE TESTS FAILED\")\n        sys.exit(1)\n    else:\n        print(\"ALL SMOKE TESTS PASSED\")\n        sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1179,"cache_read_input_tokens":64211,"cache_creation":{"ephemeral_5m_input_tokens":1179,"ephemeral_1h_input_tokens":0},"output_tokens":2283},"context_management":null},"parent_tool_use_id":null,"session_id":"5178e60b-6983-4b64-b8b8-e65cc691e770","uuid":"eb6ea6e6-eb93-438d-913c-89ff61dc04ac"}
