tokens":4103,"ephemeral_1h_input_tokens":0},"output_tokens":793},"context_management":null},"parent_tool_use_id":null,"session_id":"e80e1467-8d50-4d14-a21d-b94c86ec6299","uuid":"4e904dca-b9f5-44c3-8298-6142e265ce08"}
