rderController.getNewOrderParts()));\n    77→        return thymeleaf.render(\"lineItems\", data);\n    78→    }\n    79→\n    80→    @POST\n    81→    @Path(\"/addLineItem\")\n    82→    @Consumes(MediaType.APPLICATION_FORM_URLENCODED)\n    83→    @Produces(MediaType.TEXT_HTML)\n    84→    public String addLineItem(\n    85→            @FormParam(\"currentOrder\") Integer currentOrder,\n    86→            @FormParam(\"selectedPartNumber\") String selectedPartNumber,\n    87→            @FormParam(\"selectedPartRevision\") int selectedPartRevision) {\n    88→        orderController.addLineItem(currentOrder, selectedPartNumber, selectedPartRevision);\n    89→        Map<String, Object> data = new HashMap<>();\n    90→        data.put(\"currentOrder\", currentOrder);\n    91→        data.put(\"lineItems\", toLineItemMaps(orderController.getLineItems(currentOrder)));\n    92→        data.put(\"newOrderParts\", toPartMaps(orderController.getNewOrderParts()));\n    93→        return thymeleaf.render(\"lineItems\", data);\n    94→    }\n    95→\n    96→    @POST\n    97→    @Path(\"/findVendor\")\n    98→    @Consumes(MediaType.APPLICATION_FORM_URLENCODED)\n    99→    @Produces(MediaType.TEXT_HTML)\n   100→    public String findVendor(@FormParam(\"vendorName\") String vendorName) {\n   101→        Map<String, Object> data = new HashMap<>();\n   102→        data.put(\"orders\", toOrderMaps(orderController.getOrders()));\n   103→        data.put(\"vendorName\", vendorName);\n   104→        data.put(\"vendorSearchResults\", orderController.findVendor(vendorName));\n   105→        data.put(\"findVendorTableDisabled\", true);\n   106→        return thymeleaf.render(\"orders\", data);\n   107→    }\n   108→\n   109→    // Convert entities to Maps for Thymeleaf (avoids OGNL restricted access issues)\n   110→    private List<Map<String, Object>> toOrderMaps(List<CustomerOrder> orders) {\n   111→        if (orders == null) return new ArrayList<>();\n   112→        List<Map<String,