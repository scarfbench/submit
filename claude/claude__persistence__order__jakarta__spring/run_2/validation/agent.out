{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01DoDMnSdSq3ngYkqEbQXVZm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_014SNyUnFyiWSyTJ9zu2og7E","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__order__jakarta__spring/run_2/output/smoke.py","content":"\"\"\"\nSmoke tests for the migrated Spring Boot Order application.\nTests the REST API endpoints and web UI to verify functionality.\n\"\"\"\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\n\ndef fetch(path, method=\"GET\"):\n    \"\"\"Make an HTTP request and return status code and response body.\"\"\"\n    url = f\"{BASE_URL}{path}\"\n    req = urllib.request.Request(url, method=method)\n    try:\n        with urllib.request.urlopen(req, timeout=10) as resp:\n            body = resp.read().decode(\"utf-8\")\n            return resp.status, body\n    except urllib.error.HTTPError as e:\n        return e.code, e.read().decode(\"utf-8\")\n    except Exception as e:\n        return 0, str(e)\n\n\ndef test_health_endpoint():\n    \"\"\"Test the /api/health endpoint returns UP status.\"\"\"\n    status, body = fetch(\"/api/health\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert data[\"status\"] == \"UP\", f\"Expected status UP, got {data}\"\n    print(\"PASS: /api/health returns UP\")\n\n\ndef test_orders_api():\n    \"\"\"Test the /api/orders endpoint returns pre-loaded orders.\"\"\"\n    status, body = fetch(\"/api/orders\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 2, f\"Expected at least 2 orders, got {len(data)}\"\n\n    order_ids = [o[\"orderId\"] for o in data]\n    assert 1111 in order_ids, f\"Expected order 1111 in {order_ids}\"\n    assert 4312 in order_ids, f\"Expected order 4312 in {order_ids}\"\n    print(f\"PASS: /api/orders returns {len(data)} orders including 1111 and 4312\")\n\n\ndef test_order_details():\n    \"\"\"Test that orders have correct fields.\"\"\"\n    status, body = fetch(\"/api/orders\")\n    assert status == 200, f\"Expected 200, got {status}\"\n    data = json.loads(body)\n\n    order_1111 = next((o for o in data if o[\"orderId\"] == 1111), None)\n    assert order_1111 is not None, \"Order 1111 not found\"\n    assert order_1111[\"discount\"] == 10, f\"Expected discount 10, got {order_1111['discount']}\"\n    assert order_1111[\"shipmentInfo\"] == \"333 New Court, New City, CA 90000\", \\\n        f\"Unexpected shipment info: {order_1111['shipmentInfo']}\"\n    print(\"PASS: Order 1111 has correct details (discount=10, correct shipment info)\")\n\n\ndef test_line_items_api():\n    \"\"\"Test the line items endpoint for order 1111.\"\"\"\n    status, body = fetch(\"/api/orders/1111/lineItems\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) == 3, f\"Expected 3 line items for order 1111, got {len(data)}\"\n    print(f\"PASS: /api/orders/1111/lineItems returns {len(data)} items\")\n\n\ndef test_line_items_order_4312():\n    \"\"\"Test the line items endpoint for order 4312.\"\"\"\n    status, body = fetch(\"/api/orders/4312/lineItems\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) == 3, f\"Expected 3 line items for order 4312, got {len(data)}\"\n    print(f\"PASS: /api/orders/4312/lineItems returns {len(data)} items\")\n\n\ndef test_parts_api():\n    \"\"\"Test the /api/parts endpoint returns pre-loaded parts.\"\"\"\n    status, body = fetch(\"/api/parts\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) == 5, f\"Expected 5 parts, got {len(data)}\"\n    print(f\"PASS: /api/parts returns {len(data)} parts\")\n\n\ndef test_vendor_search():\n    \"\"\"Test vendor search by partial name.\"\"\"\n    status, body = fetch(\"/api/vendors/search?name=Widget\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 1, f\"Expected at least 1 vendor matching 'Widget', got {len(data)}\"\n    assert \"WidgetCorp\" in data, f\"Expected 'WidgetCorp' in {data}\"\n    print(f\"PASS: /api/vendors/search?name=Widget returns {data}\")\n\n\ndef test_vendor_search_gadget():\n    \"\"\"Test vendor search for Gadget.\"\"\"\n    status, body = fetch(\"/api/vendors/search?name=Gadget\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert len(data) >= 1, f\"Expected at least 1 vendor matching 'Gadget', got {len(data)}\"\n    assert \"Gadget, Inc.\" in data, f\"Expected 'Gadget, Inc.' in {data}\"\n    print(f\"PASS: /api/vendors/search?name=Gadget returns {data}\")\n\n\ndef test_order_price():\n    \"\"\"Test order price calculation.\"\"\"\n    status, body = fetch(\"/api/orders/1111/price\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert \"price\" in data, f\"Expected 'price' in response, got {data}\"\n    price = data[\"price\"]\n    assert price > 0, f\"Expected positive price, got {price}\"\n    print(f\"PASS: /api/orders/1111/price = {price}\")\n\n\ndef test_avg_vendor_part_price():\n    \"\"\"Test average vendor part price.\"\"\"\n    status, body = fetch(\"/api/vendorparts/avgprice\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert \"averagePrice\" in data, f\"Expected 'averagePrice' in response, got {data}\"\n    avg = data[\"averagePrice\"]\n    assert avg > 0, f\"Expected positive average price, got {avg}\"\n    print(f\"PASS: /api/vendorparts/avgprice = {avg}\")\n\n\ndef test_web_ui_order_page():\n    \"\"\"Test the web UI order page returns HTML.\"\"\"\n    status, body = fetch(\"/order\")\n    assert status == 200, f\"Expected 200, got {status}: {body[:200]}\"\n    assert \"Order Java Persistence Example\" in body, \\\n        f\"Expected 'Order Java Persistence Example' in page\"\n    assert \"1111\" in body, \"Expected order ID 1111 in page\"\n    assert \"4312\" in body, \"Expected order ID 4312 in page\"\n    print(\"PASS: /order returns HTML with order data\")\n\n\ndef test_web_ui_line_items_page():\n    \"\"\"Test the web UI line items page.\"\"\"\n    status, body = fetch(\"/lineItem?orderId=1111\")\n    assert status == 200, f\"Expected 200, got {status}: {body[:200]}\"\n    assert \"Line Items for Order\" in body, \\\n        f\"Expected 'Line Items for Order' in page\"\n    print(\"PASS: /lineItem?orderId=1111 returns HTML with line item data\")\n\n\ndef wait_for_server(max_wait=60):\n    \"\"\"Wait for the server to be ready.\"\"\"\n    print(f\"Waiting for server at {BASE_URL}...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            status, body = fetch(\"/api/health\")\n            if status == 200:\n                print(f\"Server is ready (took {time.time() - start:.1f}s)\")\n                return True\n        except Exception:\n            pass\n        time.sleep(2)\n    print(f\"Server did not become ready within {max_wait}s\")\n    return False\n\n\ndef main():\n    if not wait_for_server():\n        print(\"FAIL: Server not reachable\")\n        sys.exit(1)\n\n    tests = [\n        test_health_endpoint,\n        test_orders_api,\n        test_order_details,\n        test_line_items_api,\n        test_line_items_order_4312,\n        test_parts_api,\n        test_vendor_search,\n        test_vendor_search_gadget,\n        test_order_price,\n        test_avg_vendor_part_price,\n        test_web_ui_order_page,\n        test_web_ui_line_items_page,\n    ]\n\n    passed = 0\n    failed = 0\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except AssertionError as e:\n            print(f\"FAIL: {test.__name__}: {e}\")\n            failed += 1\n        except Exception as e:\n            print(f\"ERROR: {test.__name__}: {e}\")\n            failed += 1\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed, {len(tests)} total\")\n    print(f\"{'='*50}\")\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":537,"cache_read_input_tokens":76408,"cache_creation":{"ephemeral_5m_input_tokens":537,"ephemeral_1h_input_tokens":0},"output_tokens":2676},"context_management":null},"parent_tool_use_id":null,"session_id":"e2b0509a-15a6-43ee-b7b2-9e48288140b4","uuid":"f7de814a-beca-454a-b33f-46deacf3d7c6"}
