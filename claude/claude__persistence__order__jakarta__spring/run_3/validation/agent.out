{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_019Tf8J9A5FYF4qyrPPhhpXo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_017hxYZLjT6Qf83dywC16CSX","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__order__jakarta__spring/run_3/output/smoke.py","content":"\"\"\"\nSmoke tests for the Order Management Spring Boot application.\nTests the REST API endpoints and basic UI availability.\n\"\"\"\nimport requests\nimport sys\nimport time\nimport json\n\nBASE_URL = sys.argv[1] if len(sys.argv) > 1 else \"http://localhost:8080\"\n\n\ndef test_health():\n    \"\"\"Test health endpoint.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/health\")\n    assert resp.status_code == 200, f\"Health check failed: {resp.status_code}\"\n    data = resp.json()\n    assert data[\"status\"] == \"UP\", f\"Health status is not UP: {data}\"\n    print(\"PASS: Health check\")\n\n\ndef test_get_orders():\n    \"\"\"Test getting all orders.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/orders\")\n    assert resp.status_code == 200, f\"Get orders failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Orders should be a list\"\n    assert len(data) >= 2, f\"Expected at least 2 orders, got {len(data)}\"\n    order_ids = [o[\"orderId\"] for o in data]\n    assert 1111 in order_ids, \"Order 1111 not found\"\n    assert 4312 in order_ids, \"Order 4312 not found\"\n    print(f\"PASS: Get orders - found {len(data)} orders\")\n\n\ndef test_get_parts():\n    \"\"\"Test getting all parts.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/parts\")\n    assert resp.status_code == 200, f\"Get parts failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Parts should be a list\"\n    assert len(data) >= 5, f\"Expected at least 5 parts, got {len(data)}\"\n    print(f\"PASS: Get parts - found {len(data)} parts\")\n\n\ndef test_get_vendor_parts():\n    \"\"\"Test getting all vendor parts.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/vendorparts\")\n    assert resp.status_code == 200, f\"Get vendor parts failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Vendor parts should be a list\"\n    assert len(data) >= 5, f\"Expected at least 5 vendor parts, got {len(data)}\"\n    print(f\"PASS: Get vendor parts - found {len(data)} vendor parts\")\n\n\ndef test_get_avg_price():\n    \"\"\"Test getting average vendor part price.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/vendorparts/avgprice\")\n    assert resp.status_code == 200, f\"Get avg price failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"averagePrice\" in data, \"Missing averagePrice field\"\n    assert data[\"averagePrice\"] is not None, \"Average price is null\"\n    assert data[\"averagePrice\"] > 0, f\"Average price should be positive: {data['averagePrice']}\"\n    print(f\"PASS: Average vendor part price = {data['averagePrice']:.2f}\")\n\n\ndef test_get_vendors():\n    \"\"\"Test getting all vendors.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/vendors\")\n    assert resp.status_code == 200, f\"Get vendors failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Vendors should be a list\"\n    assert len(data) >= 2, f\"Expected at least 2 vendors, got {len(data)}\"\n    print(f\"PASS: Get vendors - found {len(data)} vendors\")\n\n\ndef test_search_vendors():\n    \"\"\"Test searching vendors by partial name.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/vendors/search\", params={\"name\": \"Widget\"})\n    assert resp.status_code == 200, f\"Search vendors failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Search results should be a list\"\n    assert len(data) >= 1, f\"Expected at least 1 vendor matching 'Widget', got {len(data)}\"\n    assert \"WidgetCorp\" in data, f\"Expected WidgetCorp in results: {data}\"\n    print(f\"PASS: Vendor search - found {len(data)} results\")\n\n\ndef test_get_order_price():\n    \"\"\"Test getting order price.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/orders/price\", params={\"orderId\": 1111})\n    assert resp.status_code == 200, f\"Get order price failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"price\" in data, \"Missing price field\"\n    assert data[\"price\"] > 0, f\"Order price should be positive: {data['price']}\"\n    print(f\"PASS: Order 1111 price = {data['price']:.2f}\")\n\n\ndef test_get_line_items():\n    \"\"\"Test getting line items for an order.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/orders/lineitems\", params={\"orderId\": 1111})\n    assert resp.status_code == 200, f\"Get line items failed: {resp.status_code}\"\n    data = resp.json()\n    assert isinstance(data, list), \"Line items should be a list\"\n    assert len(data) >= 3, f\"Expected at least 3 line items for order 1111, got {len(data)}\"\n    print(f\"PASS: Order 1111 line items - found {len(data)} items\")\n\n\ndef test_count_all_items():\n    \"\"\"Test counting all line items.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/lineitems/count\")\n    assert resp.status_code == 200, f\"Count items failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"count\" in data, \"Missing count field\"\n    assert data[\"count\"] >= 6, f\"Expected at least 6 line items, got {data['count']}\"\n    print(f\"PASS: Total line items = {data['count']}\")\n\n\ndef test_total_price_per_vendor():\n    \"\"\"Test getting total price per vendor.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/vendors/totalprice\", params={\"vendorId\": 100})\n    assert resp.status_code == 200, f\"Get total price per vendor failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"totalPrice\" in data, \"Missing totalPrice field\"\n    assert data[\"totalPrice\"] > 0, f\"Total price should be positive: {data['totalPrice']}\"\n    print(f\"PASS: Vendor 100 total price = {data['totalPrice']:.2f}\")\n\n\ndef test_bom_price():\n    \"\"\"Test getting bill of materials price.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/bom/price\", params={\n        \"bomPartNumber\": \"SDFG-ERTY-BN\",\n        \"bomRevision\": 7,\n        \"partNumber\": \"1234-5678-01\",\n        \"revision\": 1\n    })\n    assert resp.status_code == 200, f\"Get BOM price failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"price\" in data, \"Missing price field\"\n    assert data[\"price\"] > 0, f\"BOM price should be positive: {data['price']}\"\n    print(f\"PASS: BOM price = {data['price']:.2f}\")\n\n\ndef test_home_page():\n    \"\"\"Test that the home page loads.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/\")\n    assert resp.status_code == 200, f\"Home page failed: {resp.status_code}\"\n    assert \"Order\" in resp.text, \"Home page should contain 'Order'\"\n    print(\"PASS: Home page loads successfully\")\n\n\ndef test_line_items_page():\n    \"\"\"Test that the line items page loads.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/lineItems\", params={\"orderId\": 1111})\n    assert resp.status_code == 200, f\"Line items page failed: {resp.status_code}\"\n    assert \"Line Items\" in resp.text, \"Line items page should contain 'Line Items'\"\n    print(\"PASS: Line items page loads successfully\")\n\n\ndef test_vendors_by_order():\n    \"\"\"Test getting vendors by order report.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/api/orders/vendors\", params={\"orderId\": 1111})\n    assert resp.status_code == 200, f\"Vendors by order failed: {resp.status_code}\"\n    data = resp.json()\n    assert \"report\" in data, \"Missing report field\"\n    print(f\"PASS: Vendors by order report generated\")\n\n\ndef wait_for_server(url, timeout=60):\n    \"\"\"Wait for the server to be ready.\"\"\"\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            resp = requests.get(f\"{url}/api/health\", timeout=5)\n            if resp.status_code == 200:\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    return False\n\n\nif __name__ == \"__main__\":\n    print(f\"Running smoke tests against {BASE_URL}\")\n\n    if not wait_for_server(BASE_URL):\n        print(\"FAIL: Server did not start within timeout\")\n        sys.exit(1)\n\n    print(\"Server is ready, running tests...\\n\")\n\n    tests = [\n        test_health,\n        test_home_page,\n        test_get_orders,\n        test_get_parts,\n        test_get_vendor_parts,\n        test_get_avg_price,\n        test_get_vendors,\n        test_search_vendors,\n        test_get_order_price,\n        test_get_line_items,\n        test_count_all_items,\n        test_total_price_per_vendor,\n        test_bom_price,\n        test_line_items_page,\n        test_vendors_by_order,\n    ]\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except AssertionError as e:\n            failed += 1\n            errors.append(f\"FAIL: {test.__name__}: {e}\")\n            print(f\"FAIL: {test.__name__}: {e}\")\n        except Exception as e:\n            failed += 1\n            errors.append(f\"ERROR: {test.__name__}: {e}\")\n            print(f\"ERROR: {test.__name__}: {e}\")\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n\n    if errors:\n        print(\"\\nFailures:\")\n        for err in errors:\n            print(f\"  - {err}\")\n\n    sys.exit(0 if failed == 0 else 1)\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":958,"cache_read_input_tokens":77336,"cache_creation":{"ephemeral_5m_input_tokens":958,"ephemeral_1h_input_tokens":0},"output_tokens":2937},"context_management":null},"parent_tool_use_id":null,"session_id":"263c0197-604d-4139-b6dd-23a5ef8a48e5","uuid":"91fd9e67-2584-4e39-a07b-83e74d39bc56"}
