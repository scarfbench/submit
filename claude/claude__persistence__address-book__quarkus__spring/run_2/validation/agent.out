{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_018FT6rLgGpVK51QWWkUBHbb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01KyFHcTc2cY8nc5hDCiGHdU","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__address-book__quarkus__spring/run_2/output/smoke.py","content":"\"\"\"\nSmoke tests for the Address Book application.\nTests CRUD operations on the Contact REST API.\n\"\"\"\nimport requests\nimport sys\nimport time\nimport json\n\nBASE_URL = sys.argv[1] if len(sys.argv) > 1 else \"http://localhost:8080\"\n\ndef wait_for_app(url, timeout=60):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            r = requests.get(f\"{url}/api/contacts\", timeout=5)\n            if r.status_code in (200, 404):\n                print(f\"[OK] Application is ready at {url}\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    print(f\"[FAIL] Application not ready after {timeout}s\")\n    return False\n\n\ndef test_index_page():\n    \"\"\"Test that the index page loads.\"\"\"\n    r = requests.get(f\"{BASE_URL}/\")\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    print(\"[PASS] test_index_page\")\n\n\ndef test_list_contacts_empty():\n    \"\"\"Test listing contacts when none exist.\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/contacts\")\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert isinstance(data, list), \"Expected a list\"\n    print(f\"[PASS] test_list_contacts_empty (found {len(data)} contacts)\")\n\n\ndef test_create_contact():\n    \"\"\"Test creating a new contact.\"\"\"\n    contact = {\n        \"firstName\": \"John\",\n        \"lastName\": \"Doe\",\n        \"email\": \"john.doe@example.com\",\n        \"mobilePhone\": \"555-1234\",\n        \"homePhone\": \"555-5678\"\n    }\n    r = requests.post(f\"{BASE_URL}/api/contacts\", json=contact)\n    assert r.status_code in (200, 201), f\"Expected 200/201, got {r.status_code}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"John\", f\"Expected firstName=John, got {data.get('firstName')}\"\n    assert data[\"lastName\"] == \"Doe\", f\"Expected lastName=Doe, got {data.get('lastName')}\"\n    assert data[\"email\"] == \"john.doe@example.com\"\n    assert \"id\" in data, \"Expected id in response\"\n    print(f\"[PASS] test_create_contact (id={data['id']})\")\n    return data[\"id\"]\n\n\ndef test_get_contact(contact_id):\n    \"\"\"Test getting a single contact by ID.\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/contacts/{contact_id}\")\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert data[\"id\"] == contact_id, f\"Expected id={contact_id}, got {data.get('id')}\"\n    assert data[\"firstName\"] == \"John\"\n    assert data[\"lastName\"] == \"Doe\"\n    print(f\"[PASS] test_get_contact (id={contact_id})\")\n\n\ndef test_update_contact(contact_id):\n    \"\"\"Test updating a contact.\"\"\"\n    updated = {\n        \"firstName\": \"Jane\",\n        \"lastName\": \"Doe\",\n        \"email\": \"jane.doe@example.com\",\n        \"mobilePhone\": \"555-9999\",\n        \"homePhone\": \"555-0000\"\n    }\n    r = requests.put(f\"{BASE_URL}/api/contacts/{contact_id}\", json=updated)\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"Jane\", f\"Expected firstName=Jane, got {data.get('firstName')}\"\n    assert data[\"email\"] == \"jane.doe@example.com\"\n    print(f\"[PASS] test_update_contact (id={contact_id})\")\n\n\ndef test_list_contacts_not_empty():\n    \"\"\"Test listing contacts when at least one exists.\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/contacts\")\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    data = r.json()\n    assert len(data) > 0, \"Expected at least one contact\"\n    print(f\"[PASS] test_list_contacts_not_empty (found {len(data)} contacts)\")\n\n\ndef test_create_second_contact():\n    \"\"\"Test creating a second contact.\"\"\"\n    contact = {\n        \"firstName\": \"Alice\",\n        \"lastName\": \"Smith\",\n        \"email\": \"alice@example.com\",\n        \"mobilePhone\": \"555-AAAA\",\n        \"homePhone\": \"555-BBBB\"\n    }\n    r = requests.post(f\"{BASE_URL}/api/contacts\", json=contact)\n    assert r.status_code in (200, 201), f\"Expected 200/201, got {r.status_code}\"\n    data = r.json()\n    assert data[\"firstName\"] == \"Alice\"\n    print(f\"[PASS] test_create_second_contact (id={data['id']})\")\n    return data[\"id\"]\n\n\ndef test_delete_contact(contact_id):\n    \"\"\"Test deleting a contact.\"\"\"\n    r = requests.delete(f\"{BASE_URL}/api/contacts/{contact_id}\")\n    assert r.status_code in (200, 204), f\"Expected 200/204, got {r.status_code}\"\n    # Verify it's deleted\n    r2 = requests.get(f\"{BASE_URL}/api/contacts/{contact_id}\")\n    assert r2.status_code == 404, f\"Expected 404 after delete, got {r2.status_code}\"\n    print(f\"[PASS] test_delete_contact (id={contact_id})\")\n\n\ndef test_get_nonexistent_contact():\n    \"\"\"Test getting a contact that doesn't exist.\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/contacts/99999\")\n    assert r.status_code == 404, f\"Expected 404, got {r.status_code}\"\n    print(\"[PASS] test_get_nonexistent_contact\")\n\n\ndef test_contact_list_html_page():\n    \"\"\"Test that the HTML list page loads.\"\"\"\n    r = requests.get(f\"{BASE_URL}/contacts\")\n    assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    assert \"Contact\" in r.text or \"contact\" in r.text.lower(), \"Expected 'contact' in page\"\n    print(\"[PASS] test_contact_list_html_page\")\n\n\ndef main():\n    print(f\"Running smoke tests against {BASE_URL}\")\n\n    if not wait_for_app(BASE_URL):\n        sys.exit(1)\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    tests = [\n        (\"test_index_page\", lambda: test_index_page()),\n        (\"test_list_contacts_empty\", lambda: test_list_contacts_empty()),\n    ]\n\n    for name, test_fn in tests:\n        try:\n            test_fn()\n            passed += 1\n        except Exception as e:\n            failed += 1\n            errors.append((name, str(e)))\n            print(f\"[FAIL] {name}: {e}\")\n\n    # CRUD flow tests\n    try:\n        contact_id = test_create_contact()\n        passed += 1\n    except Exception as e:\n        failed += 1\n        errors.append((\"test_create_contact\", str(e)))\n        print(f\"[FAIL] test_create_contact: {e}\")\n        print(f\"\\nResults: {passed} passed, {failed} failed\")\n        sys.exit(1 if failed > 0 else 0)\n\n    crud_tests = [\n        (\"test_get_contact\", lambda: test_get_contact(contact_id)),\n        (\"test_update_contact\", lambda: test_update_contact(contact_id)),\n        (\"test_list_contacts_not_empty\", lambda: test_list_contacts_not_empty),\n        (\"test_contact_list_html_page\", lambda: test_contact_list_html_page()),\n    ]\n\n    for name, test_fn in crud_tests:\n        try:\n            test_fn()\n            passed += 1\n        except Exception as e:\n            failed += 1\n            errors.append((name, str(e)))\n            print(f\"[FAIL] {name}: {e}\")\n\n    # Create second contact, then delete it\n    try:\n        second_id = test_create_second_contact()\n        passed += 1\n    except Exception as e:\n        failed += 1\n        errors.append((\"test_create_second_contact\", str(e)))\n        print(f\"[FAIL] test_create_second_contact: {e}\")\n        second_id = None\n\n    if second_id:\n        try:\n            test_delete_contact(second_id)\n            passed += 1\n        except Exception as e:\n            failed += 1\n            errors.append((\"test_delete_contact\", str(e)))\n            print(f\"[FAIL] test_delete_contact: {e}\")\n\n    try:\n        test_get_nonexistent_contact()\n        passed += 1\n    except Exception as e:\n        failed += 1\n        errors.append((\"test_get_nonexistent_contact\", str(e)))\n        print(f\"[FAIL] test_get_nonexistent_contact: {e}\")\n\n    # Delete first contact to clean up\n    try:\n        test_delete_contact(contact_id)\n        passed += 1\n    except Exception as e:\n        failed += 1\n        errors.append((\"test_delete_first_contact\", str(e)))\n        print(f\"[FAIL] test_delete_first_contact: {e}\")\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed\")\n    if errors:\n        print(f\"\\nFailed tests:\")\n        for name, err in errors:\n            print(f\"  - {name}: {err}\")\n    print(f\"{'='*50}\")\n\n    sys.exit(1 if failed > 0 else 0)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":697,"cache_read_input_tokens":46939,"cache_creation":{"ephemeral_5m_input_tokens":697,"ephemeral_1h_input_tokens":0},"output_tokens":2783},"context_management":null},"parent_tool_use_id":null,"session_id":"fd257968-fc09-4865-84ad-86d17cc4ff85","uuid":"9f8eb11a-b3e6-4849-a6e9-634ca5c3af18"}
