{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01GGNrmAuhPWjwfejsvzPsU9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01E6Z5fLMAL8reJb9FxEZ4aP","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__address-book__quarkus__spring/run_3/output/smoke.py","content":"\"\"\"\nSmoke tests for Address Book Spring Boot application.\nTests the REST API endpoints and web UI pages.\n\"\"\"\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\n\ndef wait_for_app(url, timeout=60):\n    \"\"\"Wait for the application to become available.\"\"\"\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            req = urllib.request.Request(f\"{url}/actuator/health\")\n            resp = urllib.request.urlopen(req, timeout=5)\n            data = json.loads(resp.read().decode(\"utf-8\"))\n            if data.get(\"status\") == \"UP\":\n                print(f\"[PASS] Application is UP at {url}\")\n                return True\n        except Exception:\n            pass\n        time.sleep(2)\n    print(f\"[FAIL] Application did not start within {timeout}s\")\n    return False\n\n\ndef test_health_endpoint():\n    \"\"\"Test the actuator health endpoint.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/actuator/health\")\n        resp = urllib.request.urlopen(req)\n        data = json.loads(resp.read().decode(\"utf-8\"))\n        assert data[\"status\"] == \"UP\", f\"Expected UP, got {data['status']}\"\n        print(\"[PASS] Health endpoint returns UP\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Health endpoint: {e}\")\n        return False\n\n\ndef test_index_page():\n    \"\"\"Test the index/home page loads.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/\")\n        resp = urllib.request.urlopen(req)\n        body = resp.read().decode(\"utf-8\")\n        assert \"Welcome to the Address Book\" in body, \"Index page missing welcome text\"\n        assert \"Show All Contact Items\" in body, \"Index page missing link to contacts\"\n        print(\"[PASS] Index page loads correctly\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Index page: {e}\")\n        return False\n\n\ndef test_contact_list_page():\n    \"\"\"Test the contact list page loads.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/contact/List\")\n        resp = urllib.request.urlopen(req)\n        body = resp.read().decode(\"utf-8\")\n        assert \"Create New Contact\" in body, \"List page missing create link\"\n        print(\"[PASS] Contact list page loads correctly\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Contact list page: {e}\")\n        return False\n\n\ndef test_contact_create_page():\n    \"\"\"Test the contact create form page loads.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/contact/Create\")\n        resp = urllib.request.urlopen(req)\n        body = resp.read().decode(\"utf-8\")\n        assert \"First Name\" in body, \"Create page missing First Name field\"\n        assert \"Last Name\" in body, \"Create page missing Last Name field\"\n        assert \"Email\" in body, \"Create page missing Email field\"\n        print(\"[PASS] Contact create page loads correctly\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Contact create page: {e}\")\n        return False\n\n\ndef test_api_list_contacts_empty():\n    \"\"\"Test API returns empty list initially.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/api/contacts\")\n        resp = urllib.request.urlopen(req)\n        data = json.loads(resp.read().decode(\"utf-8\"))\n        assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n        print(f\"[PASS] API list contacts returns list (size={len(data)})\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] API list contacts: {e}\")\n        return False\n\n\ndef test_api_create_contact():\n    \"\"\"Test creating a contact via API.\"\"\"\n    try:\n        contact_data = json.dumps({\n            \"firstName\": \"John\",\n            \"lastName\": \"Doe\",\n            \"email\": \"john@example.com\",\n            \"mobilePhone\": \"555-0100\",\n            \"homePhone\": \"555-0101\"\n        }).encode(\"utf-8\")\n\n        req = urllib.request.Request(\n            f\"{BASE_URL}/api/contacts\",\n            data=contact_data,\n            headers={\"Content-Type\": \"application/json\"},\n            method=\"POST\"\n        )\n        resp = urllib.request.urlopen(req)\n        assert resp.getcode() == 201, f\"Expected 201, got {resp.getcode()}\"\n        data = json.loads(resp.read().decode(\"utf-8\"))\n        assert data[\"firstName\"] == \"John\", f\"Expected John, got {data.get('firstName')}\"\n        assert data[\"lastName\"] == \"Doe\", f\"Expected Doe, got {data.get('lastName')}\"\n        assert data[\"id\"] is not None, \"Contact should have an ID\"\n        print(f\"[PASS] API create contact (id={data['id']})\")\n        return data[\"id\"]\n    except Exception as e:\n        print(f\"[FAIL] API create contact: {e}\")\n        return None\n\n\ndef test_api_get_contact(contact_id):\n    \"\"\"Test getting a contact by ID via API.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/api/contacts/{contact_id}\")\n        resp = urllib.request.urlopen(req)\n        data = json.loads(resp.read().decode(\"utf-8\"))\n        assert data[\"id\"] == contact_id, f\"Expected id={contact_id}, got {data['id']}\"\n        assert data[\"firstName\"] == \"John\"\n        print(f\"[PASS] API get contact by ID ({contact_id})\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] API get contact: {e}\")\n        return False\n\n\ndef test_api_update_contact(contact_id):\n    \"\"\"Test updating a contact via API.\"\"\"\n    try:\n        contact_data = json.dumps({\n            \"firstName\": \"Jane\",\n            \"lastName\": \"Doe\",\n            \"email\": \"jane@example.com\",\n            \"mobilePhone\": \"555-0200\",\n            \"homePhone\": \"555-0201\"\n        }).encode(\"utf-8\")\n\n        req = urllib.request.Request(\n            f\"{BASE_URL}/api/contacts/{contact_id}\",\n            data=contact_data,\n            headers={\"Content-Type\": \"application/json\"},\n            method=\"PUT\"\n        )\n        resp = urllib.request.urlopen(req)\n        data = json.loads(resp.read().decode(\"utf-8\"))\n        assert data[\"firstName\"] == \"Jane\", f\"Expected Jane, got {data.get('firstName')}\"\n        print(f\"[PASS] API update contact ({contact_id})\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] API update contact: {e}\")\n        return False\n\n\ndef test_api_count():\n    \"\"\"Test the count endpoint.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/api/contacts/count\")\n        resp = urllib.request.urlopen(req)\n        count = int(resp.read().decode(\"utf-8\"))\n        assert count >= 1, f\"Expected count >= 1, got {count}\"\n        print(f\"[PASS] API contact count = {count}\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] API count: {e}\")\n        return False\n\n\ndef test_api_delete_contact(contact_id):\n    \"\"\"Test deleting a contact via API.\"\"\"\n    try:\n        req = urllib.request.Request(\n            f\"{BASE_URL}/api/contacts/{contact_id}\",\n            method=\"DELETE\"\n        )\n        resp = urllib.request.urlopen(req)\n        assert resp.getcode() == 204, f\"Expected 204, got {resp.getcode()}\"\n        print(f\"[PASS] API delete contact ({contact_id})\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] API delete contact: {e}\")\n        return False\n\n\ndef test_api_get_deleted_contact(contact_id):\n    \"\"\"Test that a deleted contact returns 404.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/api/contacts/{contact_id}\")\n        urllib.request.urlopen(req)\n        print(f\"[FAIL] API get deleted contact should return 404\")\n        return False\n    except urllib.error.HTTPError as e:\n        if e.code == 404:\n            print(f\"[PASS] API get deleted contact returns 404\")\n            return True\n        print(f\"[FAIL] API get deleted contact: unexpected status {e.code}\")\n        return False\n    except Exception as e:\n        print(f\"[FAIL] API get deleted contact: {e}\")\n        return False\n\n\ndef test_contact_view_page(contact_id):\n    \"\"\"Test viewing a contact page.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/contact/View/{contact_id}\")\n        resp = urllib.request.urlopen(req)\n        body = resp.read().decode(\"utf-8\")\n        assert \"View\" in body, \"View page missing title\"\n        print(f\"[PASS] Contact view page loads correctly for id={contact_id}\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Contact view page: {e}\")\n        return False\n\n\ndef test_contact_edit_page(contact_id):\n    \"\"\"Test the contact edit form loads.\"\"\"\n    try:\n        req = urllib.request.Request(f\"{BASE_URL}/contact/Edit/{contact_id}\")\n        resp = urllib.request.urlopen(req)\n        body = resp.read().decode(\"utf-8\")\n        assert \"Edit Contact\" in body, \"Edit page missing title\"\n        assert \"First Name\" in body, \"Edit page missing fields\"\n        print(f\"[PASS] Contact edit page loads correctly for id={contact_id}\")\n        return True\n    except Exception as e:\n        print(f\"[FAIL] Contact edit page: {e}\")\n        return False\n\n\ndef main():\n    print(f\"\\n{'='*60}\")\n    print(f\"Address Book Smoke Tests\")\n    print(f\"Base URL: {BASE_URL}\")\n    print(f\"{'='*60}\\n\")\n\n    # Wait for app to start\n    if not wait_for_app(BASE_URL):\n        sys.exit(1)\n\n    results = []\n\n    # Test basic endpoints\n    results.append((\"Health Endpoint\", test_health_endpoint()))\n    results.append((\"Index Page\", test_index_page()))\n    results.append((\"Contact List Page\", test_contact_list_page()))\n    results.append((\"Contact Create Page\", test_contact_create_page()))\n\n    # Test API CRUD\n    results.append((\"API List Contacts (empty)\", test_api_list_contacts_empty()))\n\n    contact_id = test_api_create_contact()\n    results.append((\"API Create Contact\", contact_id is not None))\n\n    if contact_id:\n        results.append((\"API Get Contact\", test_api_get_contact(contact_id)))\n        results.append((\"Contact View Page\", test_contact_view_page(contact_id)))\n        results.append((\"Contact Edit Page\", test_contact_edit_page(contact_id)))\n        results.append((\"API Update Contact\", test_api_update_contact(contact_id)))\n        results.append((\"API Contact Count\", test_api_count()))\n        results.append((\"API Delete Contact\", test_api_delete_contact(contact_id)))\n        results.append((\"API Verify Deletion\", test_api_get_deleted_contact(contact_id)))\n\n    # Summary\n    print(f\"\\n{'='*60}\")\n    passed = sum(1 for _, r in results if r)\n    total = len(results)\n    print(f\"Results: {passed}/{total} tests passed\")\n    print(f\"{'='*60}\\n\")\n\n    for name, result in results:\n        status = \"PASS\" if result else \"FAIL\"\n        print(f\"  [{status}] {name}\")\n\n    if passed < total:\n        print(f\"\\n{total - passed} test(s) FAILED\")\n        sys.exit(1)\n    else:\n        print(\"\\nAll tests PASSED!\")\n        sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":360,"cache_read_input_tokens":68714,"cache_creation":{"ephemeral_5m_input_tokens":360,"ephemeral_1h_input_tokens":0},"output_tokens":3256},"context_management":null},"parent_tool_use_id":null,"session_id":"817510db-4945-42e9-9845-9e09f3fea89b","uuid":"b5119105-f50c-4c3c-ba7f-051edec350a4"}
