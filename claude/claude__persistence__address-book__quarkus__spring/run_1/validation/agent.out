api_url(\"\"), method=\"POST\", data=contact)\n   127→    assert status in (200, 201), f\"Expected 200/201, got {status}: {body[:200]}\"\n   128→    created = json.loads(body)\n   129→    print(f\"  PASS (id={created['id']})\")\n   130→    return created[\"id\"]\n   131→\n   132→\n   133→def test_delete_contact_api(contact_id):\n   134→    \"\"\"Test deleting a contact via the REST API.\"\"\"\n   135→    print(f\"TEST: Delete contact {contact_id} via API...\")\n   136→    status, body = do_request(api_url(f\"/{contact_id}\"), method=\"DELETE\")\n   137→    assert status in (200, 204), f\"Expected 200/204, got {status}: {body[:200]}\"\n   138→    print(\"  PASS\")\n   139→\n   140→    # Verify deletion\n   141→    print(f\"TEST: Verify contact {contact_id} is deleted...\")\n   142→    status, body = do_request(api_url(f\"/{contact_id}\"))\n   143→    assert status == 404, f\"Expected 404 after deletion, got {status}: {body[:200]}\"\n   144→    print(\"  PASS\")\n   145→\n   146→\n   147→def test_create_contact_page():\n   148→    \"\"\"Test that the create contact page is accessible.\"\"\"\n   149→    print(\"TEST: Create contact web page...\")\n   150→    status, body = do_request(web_url(\"/contacts/new\"))\n   151→    assert status == 200, f\"Expected 200, got {status}: {body[:200]}\"\n   152→    print(\"  PASS\")\n   153→\n   154→\n   155→def wait_for_app(max_wait=60):\n   156→    \"\"\"Wait for the application to start.\"\"\"\n   157→    print(f\"Waiting for application at {BASE_URL}...\")\n   158→    start = time.time()\n   159→    while time.time() - start < max_wait:\n   160→        try:\n   161→            status, _ = do_request(web_url(\"/\"))\n   162→            if status == 200:\n   163→                print(f\"  Application ready after {time.time()-start:.1f}s\")\n   164→                return True\n   165→        except Exception:\n   166→            pass\n   167→        time.sleep(2)\n   168→    print(f\"  TIMEOUT after {max_wait}s\")\n   169→    return False\n   170→\n   171→\n   172→def main():\n   173→    if not wait_for_app():\n   174→        print(\"FAIL: Application did not start in time\")\n   175→        sys.exit(1)\n   176→\n   177→    passed = 0\n   178→    failed = 0\n   179→    errors = []\n   180→\n   181→    tests = [\n   182→        (\"health\", lambda: test_health()),\n   183→        (\"contact_list_page\", lambda: test_contact_list_page()),\n   184→        (\"create_contact_page\", lambda: test_create_contact_page()),\n   185→    ]\n   186→\n   187→    # Run basic tests first\n   188→    for name, test_fn in tests:\n   189→        try:\n   190→            test_fn()\n   191→            passed += 1\n   192→        except AssertionError as e:\n   193→            failed += 1\n   194→            errors.append(f\"{name}: {e}\")\n   195→            print(f\"  FAIL: {e}\")\n   196→        except Exception as e:\n   197→            failed += 1\n   198→            errors.append(f\"{name}: {e}\")\n   199→            print(f\"  ERROR: {e}\")\n   200→\n   201→    # Run CRUD sequence\n   202→    try:\n   203→        contact_id = test_create_contact_api()\n   204→        passed += 1\n   205→\n   206→        try:\n   207→            test_get_contact_api(contact_id)\n   208→            passed += 1\n   209→        except Exception as e:\n   210→            failed += 1\n   211→            errors.append(f\"get_contact: {e}\")\n   212→            print(f\"  FAIL: {e}\")\n   213→\n   214→        try:\n   215→            test_list_contacts_api()\n   216→            passed += 1\n   217→        except Exception as e:\n   218→            failed += 1\n   219→            errors.append(f\"list_contacts: {e}\")\n   220→            print(f\"  FAIL: {e}\")\n   221→\n   222→        try:\n   223→            test_update_contact_api(contact_id)\n   224→            passed += 1\n   225→        except Exception as e:\n   226→            failed += 1\n   227→            errors.append(f\"update_contact: {e}\")\n   228→            print(f\"  FAIL: {e}\")\n   229→\n   230→        try:\n   231→            second_id = test_create_second_contact()\n   232→            passed += 1\n   233→\n   234→            try:\n   235→                test_delete_contact_api(second_id)\n   236→                passed += 2  # delete + verify\n   237→            except Exception as e:\n   238→                failed += 1\n   239→                errors.append(f\"delete_contact: {e}\")\n   240→                print(f\"  FAIL: {e}\")\n   241→        except Exception as e:\n   242→            failed += 1\n   243→            errors.append(f\"create_second: {e}\")\n   244→            print(f\"  FAIL: {e}\")\n   245→\n   246→    except Exception as e:\n   247→        failed += 1\n   248→        errors.append(f\"create_contact: {e}\")\n   249→        print(f\"  FAIL: {e}\")\n   250→\n   251→    print(f\"\\n{'='*50}\")\n   252→    print(f\"Results: {passed} passed, {failed} failed\")\n   253→    if errors:\n   254→        print(\"Failures:\")\n   255→        for err in errors:\n   256→            print(f\"  - {err}\")\n   257→    print(f\"{'='*50}\")\n   258→\n   259→    sys.exit(0 if failed == 0 else 1)\n   260→\n   261→\n   262→if __name__ == \"__main__\":\n   263→    main()\n   264→"}]},"parent_tool_use_id":null,"session_id":"3f3022cf-e6b9-4d25-b360-0859e4628d59","uuid":"238cd8a3-61cf-4621-9230-7aaffa47f90f"}
