     criteriaQuery.orderBy(criteriaBuilder.desc(quoteRoot.get(\"change1\")));\n    80→      criteriaQuery.select(quoteRoot);\n    81→      TypedQuery<QuoteDataBean> q = entityManager.createQuery(criteriaQuery);\n    82→      quotes = q.getResultList();\n    83→    } catch (Exception e) {\n    84→      Log.debug(\"Warning: The database has not been configured. If this is the first time the application has been started, please create and populate the database tables. Then restart the server.\");\n    85→      return;\n    86→    }\n    87→\n    88→    /* TODO: Make this cleaner? */\n    89→    QuoteDataBean[] quoteArray = quotes.toArray(new QuoteDataBean[quotes.size()]);\n    90→    ArrayList<QuoteDataBean> topGainers = new ArrayList<QuoteDataBean>(5);\n    91→    ArrayList<QuoteDataBean> topLosers = new ArrayList<QuoteDataBean>(5);\n    92→    BigDecimal TSIA = FinancialUtils.ZERO;\n    93→    BigDecimal openTSIA = FinancialUtils.ZERO;\n    94→    double totalVolume = 0.0;\n    95→\n    96→    if (quoteArray.length > 5) {\n    97→      for (int i = 0; i < 5; i++) {\n    98→        topGainers.add(quoteArray[i]);\n    99→      }\n   100→      for (int i = quoteArray.length - 1; i >= quoteArray.length - 5; i--) {\n   101→        topLosers.add(quoteArray[i]);\n   102→      }\n   103→\n   104→      for (QuoteDataBean quote : quoteArray) {\n   105→        BigDecimal price = quote.getPrice();\n   106→        BigDecimal open = quote.getOpen();\n   107→        double volume = quote.getVolume();\n   108→        TSIA = TSIA.add(price);\n   109→        openTSIA = openTSIA.add(open);\n   110→        totalVolume += volume;\n   111→      }\n   112→      TSIA = TSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   113→      openTSIA = openTSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   114→    }\n   115→\n   116→    setMarketSummaryDataBean(new MarketSummaryDataBean(TSIA, openTSIA, totalVolume, topGainers, topLosers));\n   117→    applic