tValue())).append(\"\\\"\");\n        json.append(\"}\");\n\n        return json.toString();\n    }\n\n    private String escapeJson(String value) {\n        if (value == null) return \"\";\n        return value.replace(\"\\\\\", \"\\\\\\\\\")\n                   .replace(\"\\\"\", \"\\\\\\\"\")\n                   .replace(\"\\n\", \"\\\\n\")\n                   .replace(\"\\r\", \"\\\\r\")\n                   .replace(\"\\t\", \"\\\\t\");\n    }\n\n}"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":666,"cache_read_input_tokens":37500,"cache_creation":{"ephemeral_5m_input_tokens":666,"ephemeral_1h_input_tokens":0},"output_tokens":660},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01JbiTNr6WMQJtR55grWcfkZ","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"4a1281d8-7fe8-419e-a73a-eb1dd4f78b77"}
