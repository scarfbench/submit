hread.start();\n        \n    }","new_string":"    @OnOpen\n    public void onOpen(final Session session, EndpointConfig ec) {\n        currentSession = session;\n        sentHitCount = 0;\n        receivedHitCount = 0;\n\n        // Use standard Java Thread instead of ManagedThreadFactory\n        Thread thread = new Thread(new Runnable() {\n\n            @Override\n            public void run() {\n\n                try {\n\n                    Thread.sleep(500);\n\n                    while (currentSession.isOpen()) {\n                        sentHitCount++;\n\n                        JsonMessage response = new JsonMessage();\n                        response.setKey(\"sentHitCount\");\n                        response.setValue(sentHitCount.toString());\n                        currentSession.getAsyncRemote().sendObject(response);\n\n                        Thread.sleep(100);\n                    }\n\n\n                } catch (InterruptedException e) {\n                    e.printStackTrace();\n                }\n            }\n\n        });\n\n        thread.start();\n\n    }"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":333,"cache_read_input_tokens":51654,"cache_creation":{"ephemeral_5m_input_tokens":333,"ephemeral_1h_input_tokens":0},"output_tokens":730},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01JbiTNr6WMQJtR55grWcfkZ","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"2b8a8cd3-5ec3-4620-a466-63144b103975"}
