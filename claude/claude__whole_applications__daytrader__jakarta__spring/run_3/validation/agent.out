{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_0153e5Lisb1gtt7ZGTeAJTb7","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import javax.annotation.PostConstruct;\n    19→import javax.enterprise.context.RequestScoped;\n    20→import javax.enterprise.inject.Any;\n    21→import javax.enterprise.inject.Instance;\n    22→import javax.faces.component.html.HtmlDataTable;\n    23→import javax.faces.context.ExternalContext;\n    24→import javax.inject.Inject;\n    25→import javax.inject.Named;\n    26→import javax.servlet.http.HttpSession;\n    27→\n    28→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    29→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    30→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    31→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    32→import com.ibm.websphere.samples.daytrader.util.Log;\n    33→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    34→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    35→\n    36→@Named(\"quotedata\")\n    37→@RequestScoped\n    38→@Trace\n    39→public class QuoteJSF {\n    40→\n    41→  @Inject\n    42→  private ExternalContext context;\n    43→\n    44→  private TradeServices tradeAction;\n    45→\n    46→  private QuoteData[] quotes;\n    47→  private String symbols = null;\n    48→  private HtmlDataTable dataTable;\n    49→  private Integer quantity = 100;\n    50→\n    51→  @Inject \n    52→  public QuoteJSF(@Any Instance<TradeServices> services) {\n    53→    tradeAction = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    54→  }\n    55→\n    56→  @PostConstruct\n    57→  public void getAllQuotes() {\n    58→    getQuotesBySymbols();\n    59→  }\n    60→\n    61→  public String getQuotesBySymbols() {\n    62→    HttpSession session = (HttpSession) context.getSession(true);\n    63→\n    64→    if (symbols == null && (session.getAttribute(\"symbols\") == null)) {\n    65→      setSymbols(\"s:0,s:1,s:2,s:3,s:4\");\n    66→      session.setAttribute(\"symbols\", getSymbols());\n    67→    } else if (symbols == null && session.getAttribute(\"symbols\") != null) {\n    68→      setSymbols((String) session.getAttribute(\"symbols\"));\n    69→    }\n    70→\n    71→    else {\n    72→      session.setAttribute(\"symbols\", getSymbols());\n    73→    }\n    74→\n    75→    java.util.StringTokenizer st = new java.util.StringTokenizer(symbols, \" ,\");\n    76→    QuoteData[] quoteDatas = new QuoteData[st.countTokens()];\n    77→    int count = 0;\n    78→\n    79→    while (st.hasMoreElements()) {\n    80→      String symbol = st.nextToken();\n    81→\n    82→      try {\n    83→        QuoteDataBean quoteData = tradeAction.getQuote(symbol);\n    84→        quoteDatas[count] = new QuoteData(quoteData.getOpen(), quoteData.getPrice(), quoteData.getSymbol(), quoteData.getHigh(), quoteData.getLow(),\n    85→            quoteData.getCompanyName(), quoteData.getVolume(), quoteData.getChange());\n    86→        count++;\n    87→      } catch (Exception e) {\n    88→        Log.error(e.toString());\n    89→      }\n    90→    }\n    91→    setQuotes(quoteDatas);\n    92→    return \"quotes\";\n    93→  }\n    94→\n    95→  public String buy() {\n    96→    HttpSession session = (HttpSession) context.getSession(true);\n    97→    String userID = (String) session.getAttribute(\"uidBean\");\n    98→    QuoteData quoteData = (QuoteData) dataTable.getRowData();\n    99→    OrderDataBean orderDataBean;\n   100→\n   101→    try {\n   102→      orderDataBean = tradeAction.buy(userID, quoteData.getSymbol(), new Double(this.quantity).doubleValue(), TradeConfig.getOrderProcessingMode());\n   103→\n   104→      OrderData orderData = new OrderData(orderDataBean.getOrderID(), orderDataBean.getOrderStatus(), orderDataBean.getOpenDate(),\n   105→          orderDataBean.getCompletionDate(), orderDataBean.getOrderFee(), orderDataBean.getOrderType(), orderDataBean.getQuantity(),\n   106→          orderDataBean.getSymbol());\n   107→      session.setAttribute(\"orderData\", orderData);\n   108→    } catch (Exception e) {\n   109→      Log.error(e.toString());\n   110→      e.printStackTrace();\n   111→    }\n   112→    return \"buy\";\n   113→  }\n   114→\n   115→  public void setQuotes(QuoteData[] quotes) {\n   116→    this.quotes = quotes;\n   117→  }\n   118→\n   119→  public QuoteData[] getQuotes() {\n   120→    return quotes;\n   121→  }\n   122→\n   123→  public void setSymbols(String symbols) {\n   124→    this.symbols = symbols;\n   125→  }\n   126→\n   127→  public String getSymbols() {\n   128→    return symbols;\n   129→  }\n   130→\n   131→  public void setDataTable(HtmlDataTable dataTable) {\n   132→    this.dataTable = dataTable;\n   133→  }\n   134→\n   135→  public HtmlDataTable getDataTable() {\n   136→    return dataTable;\n   137→  }\n   138→\n   139→  public void setQuantity(Integer quantity) {\n   140→    this.quantity = quantity;\n   141→  }\n   142→\n   143→  public Integer getQuantity() {\n   144→    return quantity;\n   145→  }\n   146→}\n   147→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01LJeeEApPYxuC3Y6WHXiLUw","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"44049aa7-23c6-447e-8586-1a4024e61852"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_013CjipoCfq5McCZrb3me6Wn","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.ArrayList;\n    20→import java.util.Collection;\n    21→import java.util.Iterator;\n    22→\n    23→import javax.annotation.PostConstruct;\n    24→import javax.enterprise.context.RequestScoped;\n    25→import javax.enterprise.inject.Any;\n    26→import javax.enterprise.inject.Instance;\n    27→import javax.faces.component.html.HtmlDataTable;\n    28→import javax.faces.context.ExternalContext;\n    29→import javax.inject.Inject;\n    30→import javax.inject.Named;\n    31→import javax.servlet.http.HttpSession;\n    32→\n    33→import javax.validation.constraints.PositiveOrZero;\n    34→\n    35→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    36→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    37→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    38→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    40→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    41→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    42→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    43→\n    44→@Named(\"portfolio\")\n    45→@RequestScoped\n    46→@Trace\n    47→public class PortfolioJSF {\n    48→  @Inject\n    49→  private ExternalContext context;\n    50→\n    51→  private TradeServices tradeAction;\n    52→\n    53→  private BigDecimal balance;\n    54→  private BigDecimal openBalance;\n    55→  \n    56→  @PositiveOrZero\n    57→  private Integer numberHoldings;\n    58→  \n    59→  private BigDecimal holdingsTotal;\n    60→  private BigDecimal sumOfCashHoldings;\n    61→  private BigDecimal totalGain = new BigDecimal(0.0);\n    62→  private BigDecimal totalValue = new BigDecimal(0.0);\n    63→  private BigDecimal totalBasis = new BigDecimal(0.0);\n    64→  private BigDecimal totalGainPercent = new BigDecimal(0.0);\n    65→  private ArrayList<HoldingData> holdingDatas;\n    66→  private HtmlDataTable dataTable;\n    67→\n    68→  @Inject \n    69→  public PortfolioJSF(@Any Instance<TradeServices> services) {\n    70→    tradeAction = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    71→  }\n    72→\n    73→  @PostConstruct\n    74→  public void getPortfolio() {            \n    75→    try {\n    76→\n    77→      HttpSession session = (HttpSession) context.getSession(true);\n    78→      String userID = (String) session.getAttribute(\"uidBean\");\n    79→      Collection<?> holdingDataBeans = tradeAction.getHoldings(userID);\n    80→\n    81→      numberHoldings = holdingDataBeans.size();\n    82→\n    83→      // Walk through the collection of user holdings and creating a list\n    84→      // of quotes\n    85→      if (holdingDataBeans.size() > 0) {\n    86→        Iterator<?> it = holdingDataBeans.iterator();\n    87→        holdingDatas = new ArrayList<HoldingData>(holdingDataBeans.size());\n    88→\n    89→        while (it.hasNext()) {\n    90→          HoldingDataBean holdingData = (HoldingDataBean) it.next();\n    91→          QuoteDataBean quoteData = tradeAction.getQuote(holdingData.getQuoteID());\n    92→\n    93→          BigDecimal basis = holdingData.getPurchasePrice().multiply(new BigDecimal(holdingData.getQuantity()));\n    94→          BigDecimal marketValue = quoteData.getPrice().multiply(new BigDecimal(holdingData.getQuantity()));\n    95→          totalBasis = totalBasis.add(basis);\n    96→          totalValue = totalValue.add(marketValue);\n    97→          BigDecimal gain = marketValue.subtract(basis);\n    98→          totalGain = totalGain.add(gain);\n    99→\n   100→          HoldingData h = new HoldingData();\n   101→          h.setHoldingID(holdingData.getHoldingID());\n   102→          h.setPurchaseDate(holdingData.getPurchaseDate());\n   103→          h.setQuoteID(holdingData.getQuoteID());\n   104→          h.setQuantity(holdingData.getQuantity());\n   105→          h.setPurchasePrice(holdingData.getPurchasePrice());\n   106→          h.setBasis(basis);\n   107→          h.setGain(gain);\n   108→          h.setMarketValue(marketValue);\n   109→          h.setPrice(quoteData.getPrice());\n   110→          holdingDatas.add(h);\n   111→\n   112→        }\n   113→        // dataTable\n   114→        setTotalGainPercent(FinancialUtils.computeGainPercent(totalValue, totalBasis));\n   115→\n   116→      }\n   117→    } catch (Exception e) {\n   118→      e.printStackTrace();\n   119→    }\n   120→  }\n   121→\n   122→  public String sell() {\n   123→\n   124→    HttpSession session = (HttpSession) context.getSession(true);\n   125→    String userID = (String) session.getAttribute(\"uidBean\");\n   126→\n   127→    OrderDataBean orderDataBean = null;\n   128→    HoldingData holdingData = (HoldingData) dataTable.getRowData();\n   129→\n   130→    try {\n   131→      orderDataBean = tradeAction.sell(userID, holdingData.getHoldingID(), TradeConfig.getOrderProcessingMode());\n   132→      holdingDatas.remove(holdingData);\n   133→    } catch (Exception e) {\n   134→      e.printStackTrace();\n   135→    }\n   136→\n   137→    OrderData orderData = new OrderData(orderDataBean.getOrderID(), orderDataBean.getOrderStatus(), orderDataBean.getOpenDate(),\n   138→        orderDataBean.getCompletionDate(), orderDataBean.getOrderFee(), orderDataBean.getOrderType(), orderDataBean.getQuantity(),\n   139→        orderDataBean.getSymbol());\n   140→    session.setAttribute(\"orderData\", orderData);\n   141→    return \"sell\";\n   142→  }\n   143→\n   144→  public void setDataTable(HtmlDataTable dataTable) {\n   145→    this.dataTable = dataTable;\n   146→  }\n   147→\n   148→  public HtmlDataTable getDataTable() {\n   149→    return dataTable;\n   150→  }\n   151→\n   152→  public void setBalance(BigDecimal balance) {\n   153→    this.balance = balance;\n   154→  }\n   155→\n   156→  public BigDecimal getBalance() {\n   157→    return balance;\n   158→  }\n   159→\n   160→  public void setOpenBalance(BigDecimal openBalance) {\n   161→    this.openBalance = openBalance;\n   162→  }\n   163→\n   164→  public BigDecimal getOpenBalance() {\n   165→    return openBalance;\n   166→  }\n   167→\n   168→  public void setHoldingsTotal(BigDecimal holdingsTotal) {\n   169→    this.holdingsTotal = holdingsTotal;\n   170→  }\n   171→\n   172→  public BigDecimal getHoldingsTotal() {\n   173→    return holdingsTotal;\n   174→  }\n   175→\n   176→  public void setSumOfCashHoldings(BigDecimal sumOfCashHoldings) {\n   177→    this.sumOfCashHoldings = sumOfCashHoldings;\n   178→  }\n   179→\n   180→  public BigDecimal getSumOfCashHoldings() {\n   181→    return sumOfCashHoldings;\n   182→  }\n   183→\n   184→  public void setNumberHoldings(Integer numberHoldings) {\n   185→    this.numberHoldings = numberHoldings;\n   186→  }\n   187→\n   188→  public Integer getNumberHoldings() {\n   189→    return numberHoldings;\n   190→  }\n   191→\n   192→  public void setTotalGain(BigDecimal totalGain) {\n   193→    this.totalGain = totalGain;\n   194→  }\n   195→\n   196→  public BigDecimal getTotalGain() {\n   197→    return totalGain;\n   198→  }\n   199→\n   200→  public void setTotalValue(BigDecimal totalValue) {\n   201→    this.totalValue = totalValue;\n   202→  }\n   203→\n   204→  public BigDecimal getTotalValue() {\n   205→    return totalValue;\n   206→  }\n   207→\n   208→  public void setTotalBasis(BigDecimal totalBasis) {\n   209→    this.totalBasis = totalBasis;\n   210→  }\n   211→\n   212→  public BigDecimal getTotalBasis() {\n   213→    return totalBasis;\n   214→  }\n   215→\n   216→  public void setHoldingDatas(ArrayList<HoldingData> holdingDatas) {\n   217→    this.holdingDatas = holdingDatas;\n   218→  }\n   219→\n   220→  public ArrayList<HoldingData> getHoldingDatas() {\n   221→    return holdingDatas;\n   222→  }\n   223→\n   224→  public void setTotalGainPercent(BigDecimal totalGainPercent) {\n   225→    this.totalGainPercent = totalGainPercent;\n   226→  }\n   227→\n   228→  public BigDecimal getTotalGainPercent() {\n   229→    return totalGainPercent;\n   230→  }\n   231→\n   232→  public String getTotalGainPercentHTML() {\n   233→    return FinancialUtils.printGainPercentHTML(totalGainPercent);\n   234→  }\n   235→}\n   236→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01LJeeEApPYxuC3Y6WHXiLUw","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"017914a1-56e2-42d0-9547-8b4c53b96849"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01SZkUs3ChjZDW15M9DbxM9R","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.text.DecimalFormat;\n    20→\n    21→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    22→\n    23→public class QuoteData {\n    24→    private BigDecimal price;\n    25→    private BigDecimal open;\n    26→    private String symbol;\n    27→    private BigDecimal high;\n    28→    private BigDecimal low;\n    29→    private String companyName;\n    30→    private double volume;\n    31→    private double change;\n    32→    private String range;\n    33→    private BigDecimal gainPercent;\n    34→    private BigDecimal gain;\n    35→\n    36→    public QuoteData(BigDecimal price, BigDecimal open, String symbol) {\n    37→        this.open = open;\n    38→        this.price = price;\n    39→        this.symbol = symbol;\n    40→        this.change = price.subtract(open).setScale(2).doubleValue();\n    41→    }\n    42→\n    43→    public QuoteData(BigDecimal open, BigDecimal price, String symbol, BigDecimal high, BigDecimal low, String companyName, Double volume, Double change) {\n    44→        this.open = open;\n    45→        this.price = price;\n    46→        this.symbol = symbol;\n    47→        this.high = high;\n    48→        this.low = low;\n    49→        this.companyName = companyName;\n    50→        this.volume = volume;\n    51→        this.change = change;\n    52→        this.range = high.toString() + \"-\" + low.toString();\n    53→        this.gainPercent = FinancialUtils.computeGainPercent(price, open).setScale(2);\n    54→        this.gain = FinancialUtils.computeGain(price, open).setScale(2);\n    55→    }\n    56→\n    57→    public void setSymbol(String symbol) {\n    58→        this.symbol = symbol;\n    59→    }\n    60→\n    61→    public String getSymbol() {\n    62→        return symbol;\n    63→    }\n    64→\n    65→    public void setPrice(BigDecimal price) {\n    66→        this.price = price;\n    67→    }\n    68→\n    69→    public BigDecimal getPrice() {\n    70→        return price;\n    71→    }\n    72→\n    73→    public void setOpen(BigDecimal open) {\n    74→        this.open = open;\n    75→    }\n    76→\n    77→    public BigDecimal getOpen() {\n    78→        return open;\n    79→    }\n    80→\n    81→    public void setHigh(BigDecimal high) {\n    82→        this.high = high;\n    83→    }\n    84→\n    85→    public BigDecimal getHigh() {\n    86→        return high;\n    87→    }\n    88→\n    89→    public void setLow(BigDecimal low) {\n    90→        this.low = low;\n    91→    }\n    92→\n    93→    public BigDecimal getLow() {\n    94→        return low;\n    95→    }\n    96→\n    97→    public void setCompanyName(String companyName) {\n    98→        this.companyName = companyName;\n    99→    }\n   100→\n   101→    public String getCompanyName() {\n   102→        return companyName;\n   103→    }\n   104→\n   105→    public void setVolume(double volume) {\n   106→        this.volume = volume;\n   107→    }\n   108→\n   109→    public double getVolume() {\n   110→        return volume;\n   111→    }\n   112→\n   113→    public void setChange(double change) {\n   114→        this.change = change;\n   115→    }\n   116→\n   117→    public double getChange() {\n   118→        return change;\n   119→    }\n   120→\n   121→    public void setRange(String range) {\n   122→        this.range = range;\n   123→    }\n   124→\n   125→    public String getRange() {\n   126→        return range;\n   127→    }\n   128→\n   129→    public void setGainPercent(BigDecimal gainPercent) {\n   130→        this.gainPercent = gainPercent.setScale(2);\n   131→    }\n   132→\n   133→    public BigDecimal getGainPercent() {\n   134→        return gainPercent;\n   135→    }\n   136→\n   137→    public void setGain(BigDecimal gain) {\n   138→        this.gain = gain;\n   139→    }\n   140→\n   141→    public BigDecimal getGain() {\n   142→        return gain;\n   143→    }\n   144→\n   145→    public String getGainPercentHTML() {\n   146→        return FinancialUtils.printGainPercentHTML(gainPercent);\n   147→    }\n   148→\n   149→    public String getGainHTML() {\n   150→        return FinancialUtils.printGainHTML(gain);\n   151→    }\n   152→\n   153→    public String getChangeHTML() {\n   154→        String htmlString, arrow;\n   155→        if (change < 0.0) {\n   156→            htmlString = \"<FONT color=\\\"#cc0000\\\">\";\n   157→            arrow = \"arrowdown.gif\";\n   158→        } else {\n   159→            htmlString = \"<FONT color=\\\"#009900\\\">\";\n   160→            arrow = \"arrowup.gif\";\n   161→        }\n   162→        DecimalFormat df = new DecimalFormat(\"####0.00\");\n   163→\n   164→        htmlString += df.format(change) + \"</FONT><IMG src=\\\"images/\" + arrow + \"\\\" width=\\\"10\\\" height=\\\"10\\\" border=\\\"0\\\"></IMG>\";\n   165→        return htmlString;\n   166→    }\n   167→}\n   168→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01LJeeEApPYxuC3Y6WHXiLUw","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"20204548-9b3f-4b36-a29a-a7cd482c8240"}
