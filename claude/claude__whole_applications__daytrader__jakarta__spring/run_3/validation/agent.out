{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01GHbWmTPX86Hsdpa5FwqZKS","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.mdb;\n    17→\n    18→import javax.annotation.Resource;\n    19→import javax.ejb.ActivationConfigProperty;\n    20→import javax.ejb.MessageDriven;\n    21→import javax.ejb.MessageDrivenContext;\n    22→import javax.ejb.TransactionAttribute;\n    23→import javax.ejb.TransactionAttributeType;\n    24→import javax.ejb.TransactionManagement;\n    25→import javax.ejb.TransactionManagementType;\n    26→import javax.jms.Message;\n    27→import javax.jms.MessageListener;\n    28→import javax.jms.TextMessage;\n    29→\n    30→\n    31→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    32→import com.ibm.websphere.samples.daytrader.util.Log;\n    33→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    34→import com.ibm.websphere.samples.daytrader.util.TimerStat;\n    35→\n    36→//For Glassfish/Payara - take jms/ off of the destination name\n    37→\n    38→@TransactionAttribute(TransactionAttributeType.REQUIRED)\n    39→@TransactionManagement(TransactionManagementType.CONTAINER)\n    40→@MessageDriven(activationConfig = { @ActivationConfigProperty(propertyName = \"acknowledgeMode\", propertyValue = \"Auto-acknowledge\"),\n    41→    @ActivationConfigProperty(propertyName = \"destinationType\", propertyValue = \"javax.jms.Topic\"),\n    42→    @ActivationConfigProperty(propertyName = \"destination\", propertyValue = \"jms/TradeStreamerTopic\"),\n    43→    //@ActivationConfigProperty(propertyName = \"destination\", propertyValue = \"TradeStreamerTopic\"),\n    44→    @ActivationConfigProperty(propertyName = \"subscriptionDurability\", propertyValue = \"NonDurable\") })\n    45→@Trace\n    46→public class DTStreamer3MDB implements MessageListener {\n    47→\n    48→  private final MDBStats mdbStats;\n    49→  private int statInterval = 10000;\n    50→\n    51→  @Resource\n    52→  public MessageDrivenContext mdc;\n    53→ \n    54→\n    55→  /** Creates a new instance of TradeSteamerMDB */\n    56→  public DTStreamer3MDB() {\n    57→    Log.trace(\"DTStreamer3MDB:DTStreamer3MDB()\");\n    58→    \n    59→    if (statInterval <= 0) {\n    60→      statInterval = 10000;\n    61→    }\n    62→    mdbStats = MDBStats.getInstance();\n    63→  }\n    64→\n    65→  @Override\n    66→  public void onMessage(Message message) {\n    67→\n    68→    try {\n    69→      Log.trace(\"DTStreamer3MDB:onMessage -- received message -->\" + ((TextMessage) message).getText() + \"command-->\"\n    70→          + message.getStringProperty(\"command\") + \"<--\");\n    71→      \n    72→      String command = message.getStringProperty(\"command\");\n    73→      if (command == null) {\n    74→        Log.debug(\"DTStreamer3MDB:onMessage -- received message with null command. Message-->\" + message);\n    75→        return;\n    76→      }\n    77→      if (command.equalsIgnoreCase(\"updateQuote\")) {\n    78→        Log.trace(\"DTStreamer3MDB:onMessage -- received message -->\" + ((TextMessage) message).getText() + \"\\n\\t symbol = \"\n    79→              + message.getStringProperty(\"symbol\") + \"\\n\\t current price =\" + message.getStringProperty(\"price\") + \"\\n\\t old price =\"\n    80→              + message.getStringProperty(\"oldPrice\"));\n    81→        \n    82→        long publishTime = message.getLongProperty(\"publishTime\");\n    83→        long receiveTime = System.currentTimeMillis();\n    84→\n    85→        TimerStat currentStats = mdbStats.addTiming(\"DTStreamer3MDB:udpateQuote\", publishTime, receiveTime);\n    86→\n    87→        if ((currentStats.getCount() % statInterval) == 0) {\n    88→          Log.log(\" DTStreamer3MDB: \" + statInterval + \" prices updated:\" +\n    89→              \" Total message count = \" + currentStats.getCount() +\n    90→              \" Time (in seconds):\" +\n    91→              \" min: \" +currentStats.getMinSecs()+\n    92→              \" max: \" +currentStats.getMaxSecs()+\n    93→              \" avg: \" +currentStats.getAvgSecs() );\n    94→        }\n    95→      } else if (command.equalsIgnoreCase(\"ping\")) {\n    96→        Log.trace(\"DTStreamer3MDB:onMessage  received ping command -- message: \" + ((TextMessage) message).getText());\n    97→        \n    98→\n    99→        long publishTime = message.getLongProperty(\"publishTime\");\n   100→        long receiveTime = System.currentTimeMillis();\n   101→\n   102→        TimerStat currentStats = mdbStats.addTiming(\"DTStreamer3MDB:ping\", publishTime, receiveTime);\n   103→\n   104→        if ((currentStats.getCount() % statInterval) == 0) {\n   105→          Log.log(\" DTStreamer3MDB: received \" + statInterval + \" ping messages.\" +\n   106→              \" Total message count = \" + currentStats.getCount() +\n   107→              \" Time (in seconds):\" +\n   108→              \" min: \" +currentStats.getMinSecs()+\n   109→              \" max: \" +currentStats.getMaxSecs()+\n   110→              \" avg: \" +currentStats.getAvgSecs());\n   111→        }\n   112→      } else {\n   113→        Log.error(\"DTStreamer3MDB:onMessage - unknown message request command-->\" + command + \"<-- message=\" + ((TextMessage) message).getText());\n   114→      }\n   115→    } catch (Throwable t) {\n   116→      // JMS onMessage should handle all exceptions\n   117→      Log.error(\"DTStreamer3MDB: Exception\", t);\n   118→      //UPDATE - Not rolling back for now -- so error messages are not redelivered\n   119→      mdc.setRollbackOnly();\n   120→    }\n   121→  }\n   122→\n   123→}\n   124→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"c7236756-4aeb-4d56-8731-60367ac0e730"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_013rzEA9RZRVpY1XXnjrgQcZ","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.ArrayList;\n    20→import java.util.Random;\n    21→\n    22→/**\n    23→ * TradeConfig is a JavaBean holding all configuration and runtime parameters\n    24→ * for the Trade application TradeConfig sets runtime parameters such as the\n    25→ * RunTimeMode (EJB, JDBC, EJB_ALT)\n    26→ *\n    27→ */\n    28→\n    29→public class TradeConfig {\n    30→\n    31→  /* Trade Runtime Configuration Parameters */\n    32→\n    33→  /* Trade Runtime Mode parameters */\n    34→  private static String[] runTimeModeNames = { \"Full EJB3\", \"Direct (JDBC)\", \"Session to Direct\"};\n    35→  public static final int EJB3 = 0;\n    36→  public static final int DIRECT = 1;\n    37→  public static final int SESSION_TO_DIRECT = 2;\n    38→  private static int runTimeMode = EJB3;\n    39→\n    40→  private static String[] orderProcessingModeNames = { \"Sync\", \"Async\",\"Async_2-Phase\" };\n    41→  public static final int SYNCH = 0;\n    42→  public static final int ASYNCH = 1;\n    43→  public static final int ASYNCH_2PHASE = 2;\n    44→  private static int orderProcessingMode = SYNCH;\n    45→\n    46→  private static String[] accessModeNames = { \"Standard\", \"WebServices\" };\n    47→  public static final int STANDARD = 0;\n    48→  private static int accessMode = STANDARD;\n    49→\n    50→  /* Trade Web Interface parameters */\n    51→  private static String[] webInterfaceNames = { \"JSP\", \"JSP-Images\", \"JSP-Images-Http2\" };\n    52→  public static final int JSP = 0;\n    53→  public static final int JSP_Images = 1;\n    54→  public static final int JSP_Images_HTTP2 = 2;\n    55→  private static int webInterface = JSP;\n    56→\n    57→  /* Trade Database Scaling parameters */\n    58→  private static int MAX_USERS = 15000;\n    59→  private static int MAX_QUOTES = 10000;\n    60→\n    61→  \n    62→  /* Trade XA Datasource specific parameters */\n    63→  public static boolean JDBCDriverNeedsGlobalTransation = false;\n    64→\n    65→  /* Trade Config Miscellaneous itmes */\n    66→  public static String DATASOURCE = \"java:comp/env/jdbc/TradeDataSource\";\n    67→  public static int KEYBLOCKSIZE = 1000;\n    68→  public static int QUOTES_PER_PAGE = 10;\n    69→  public static boolean RND_USER = true;\n    70→  // public static int RND_SEED = 0;\n    71→  private static int MAX_HOLDINGS = 10;\n    72→  private static int count = 0;\n    73→  private static Object userID_count_semaphore = new Object();\n    74→  private static int userID_count = 0;\n    75→  private static String hostName = null;\n    76→  private static Random r0 = new Random(System.currentTimeMillis());\n    77→  // private static Random r1 = new Random(RND_SEED);\n    78→  private static Random randomNumberGenerator = r0;\n    79→  public static final String newUserPrefix = \"ru:\";\n    80→  public static final int verifyPercent = 5;\n    81→  private static boolean updateQuotePrices = true;\n    82→  private static int primIterations = 1;\n    83→  private static boolean longRun = true;\n    84→  private static boolean publishQuotePriceChange = true;\n    85→  private static int listQuotePriceChangeFrequency = 100;\n    86→  private static boolean displayOrderAlerts = true;\n    87→\n    88→  /**\n    89→   * -1 means every operation 0 means never perform a market summary > 0 means\n    90→   * number of seconds between summaries. These will be synchronized so only\n    91→   * one transaction in this period will create a summary and will cache its\n    92→   * results.\n    93→   */\n    94→  private static int marketSummaryInterval = 20;\n    95→\n    96→  /*\n    97→   * Penny stocks is a problem where the random price change factor gets a\n    98→   * stock down to $.01. In this case trade jumpstarts the price back to $6.00\n    99→   * to keep the math interesting.\n   100→   */\n   101→  public static BigDecimal PENNY_STOCK_PRICE;\n   102→  public static BigDecimal PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   103→  static {\n   104→    PENNY_STOCK_PRICE = new BigDecimal(0.01);\n   105→    PENNY_STOCK_PRICE = PENNY_STOCK_PRICE.setScale(2, BigDecimal.ROUND_HALF_UP);\n   106→    PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER = new BigDecimal(600.0);\n   107→    PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER.setScale(2, BigDecimal.ROUND_HALF_UP);\n   108→  }\n   109→\n   110→  /*\n   111→   * CJB (DAYTRADER-25) - Also need to impose a ceiling on the quote price to\n   112→   * ensure prevent account and holding balances from exceeding the databases\n   113→   * decimal precision. At some point, this maximum value can be used to\n   114→   * trigger a stock split.\n   115→   */\n   116→\n   117→  public static BigDecimal MAXIMUM_STOCK_PRICE;\n   118→  public static BigDecimal MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   119→  static {\n   120→    MAXIMUM_STOCK_PRICE = new BigDecimal(400);\n   121→    MAXIMUM_STOCK_PRICE.setScale(2, BigDecimal.ROUND_HALF_UP);\n   122→    MAXIMUM_STOCK_SPLIT_MULTIPLIER = new BigDecimal(0.5);\n   123→    MAXIMUM_STOCK_SPLIT_MULTIPLIER.setScale(2, BigDecimal.ROUND_HALF_UP);\n   124→  }\n   125→\n   126→  /*\n   127→   * Trade Scenario actions mixes. Each of the array rows represents a\n   128→   * specific Trade Scenario Mix. The columns give the percentages for each\n   129→   * action in the column header. Note: \"login\" is always 0. logout represents\n   130→   * both login and logout (because each logout operation will cause a new\n   131→   * login when the user context attempts the next action.\n   132→   */\n   133→  /* Trade Scenario Workload parameters */\n   134→  public static final int HOME_OP = 0;\n   135→  public static final int QUOTE_OP = 1;\n   136→  public static final int LOGIN_OP = 2;\n   137→  public static final int LOGOUT_OP = 3;\n   138→  public static final int REGISTER_OP = 4;\n   139→  public static final int ACCOUNT_OP = 5;\n   140→  public static final int PORTFOLIO_OP = 6;\n   141→  public static final int BUY_OP = 7;\n   142→  public static final int SELL_OP = 8;\n   143→  public static final int UPDATEACCOUNT_OP = 9;\n   144→\n   145→  private static int[][] scenarioMixes = {\n   146→      // h q l o r a p b s u\n   147→      { 20, 40, 0, 4, 2, 10, 12, 4, 4, 4 }, // STANDARD\n   148→      { 20, 40, 0, 4, 2, 7, 7, 7, 7, 6 }, // High Volume\n   149→  };\n   150→  private static char[] actions = { 'h', 'q', 'l', 'o', 'r', 'a', 'p', 'b', 's', 'u' };\n   151→  private static int sellDeficit = 0;\n   152→  // Tracks the number of buys over sell when a users portfolio is empty\n   153→  // Used to maintain the correct ratio of buys/sells\n   154→\n   155→  /* JSP pages for all Trade Actions */\n   156→\n   157→  public static final int WELCOME_PAGE = 0;\n   158→  public static final int REGISTER_PAGE = 1;\n   159→  public static final int PORTFOLIO_PAGE = 2;\n   160→  public static final int QUOTE_PAGE = 3;\n   161→  public static final int HOME_PAGE = 4;\n   162→  public static final int ACCOUNT_PAGE = 5;\n   163→  public static final int ORDER_PAGE = 6;\n   164→  public static final int CONFIG_PAGE = 7;\n   165→  public static final int STATS_PAGE = 8;\n   166→  public static final int MARKET_SUMMARY_PAGE = 9;\n   167→\n   168→  // FUTURE Add XML/XSL View\n   169→  public static String[][] webUI = {\n   170→      { \"/welcome.jsp\", \"/register.jsp\", \"/portfolio.jsp\", \"/quote.jsp\", \"/tradehome.jsp\", \"/account.jsp\", \"/order.jsp\", \"/config.jsp\", \"/runStats.jsp\",\n   171→      \"/marketSummary.jsp\" },\n   172→      // JSP Interface\n   173→      { \"/welcomeImg.jsp\", \"/registerImg.jsp\", \"/portfolioImg.jsp\", \"/quoteImg.jsp\", \"/tradehomeImg.jsp\", \"/accountImg.jsp\", \"/orderImg.jsp\",\n   174→        \"/config.jsp\", \"/runStats.jsp\", \"/marketSummary.jsp\" },\n   175→      // JSP Interface\n   176→      { \"/welcomeImg.jsp\", \"/registerImg.jsp\", \"/portfolioImg.jsp\", \"/quoteImg.jsp\", \"/tradehomeImg.jsp\", \"/accountImg.jsp\", \"/orderImg.jsp\",\n   177→          \"/config.jsp\", \"/runStats.jsp\", \"/marketSummary.jsp\" },\n   178→  };\n   179→\n   180→\n   181→  /**\n   182→   * Return the hostname for this system Creation date: (2/16/2000 9:02:25 PM)\n   183→   */\n   184→\n   185→  private static String getHostname() {\n   186→    try {\n   187→      if (hostName == null) {\n   188→        hostName = java.net.InetAddress.getLocalHost().getHostName();\n   189→        // Strip of fully qualifed domain if necessary\n   190→        try {\n   191→          hostName = hostName.substring(0, hostName.indexOf('.'));\n   192→        } catch (Exception e) {\n   193→        }\n   194→      }\n   195→    } catch (Exception e) {\n   196→      Log.error(\"Exception getting local host name using 'localhost' - \", e);\n   197→      hostName = \"localhost\";\n   198→    }\n   199→    return hostName;\n   200→  }\n   201→\n   202→  /**\n   203→   * Return a Trade UI Web page based on the current configuration This may\n   204→   * return a JSP page or a Servlet page Creation date: (3/14/2000 9:08:34 PM)\n   205→   */\n   206→\n   207→  public static String getPage(int pageNumber) {\n   208→    return webUI[webInterface][pageNumber];\n   209→  }\n   210→\n   211→  /**\n   212→   * Return the list of run time mode names Creation date: (3/8/2000 5:58:34\n   213→   * PM)\n   214→   *\n   215→   * @return java.lang.String[]\n   216→   */\n   217→  public static java.lang.String[] getRunTimeModeNames() {\n   218→    return runTimeModeNames;\n   219→  }\n   220→\n   221→  private static int scenarioCount = 0;\n   222→\n   223→  /**\n   224→   * Return a Trade Scenario Operation based on the setting of the current mix\n   225→   * (TradeScenarioMix) Creation date: (2/10/2000 9:08:34 PM)\n   226→   */\n   227→\n   228→  public static char getScenarioAction(boolean newUser) {\n   229→    int r = rndInt(100); // 0 to 99 = 100\n   230→    int i = 0;\n   231→    int sum = scenarioMixes[0][i];\n   232→    while (sum <= r) {\n   233→      i++;\n   234→      sum += scenarioMixes[0][i];\n   235→    }\n   236→\n   237→    incrementScenarioCount();\n   238→\n   239→    /*\n   240→     * In TradeScenarioServlet, if a sell action is selected, but the users\n   241→     * portfolio is empty, a buy is executed instead and sellDefecit is\n   242→     * incremented. This allows the number of buy/sell operations to stay in\n   243→     * sync w/ the given Trade mix.\n   244→     */\n   245→\n   246→    if ((!newUser) && (actions[i] == 'b')) {\n   247→      synchronized (TradeConfig.class) {\n   248→        if (sellDeficit > 0) {\n   249→          sellDeficit--;\n   250→          return 's';\n   251→          // Special case for TradeScenarioServlet to note this is a\n   252→          // buy switched to a sell to fix sellDeficit\n   253→        }\n   254→      }\n   255→    }\n   256→\n   257→    return actions[i];\n   258→  }\n   259→\n   260→  public static String getUserID() {\n   261→    String userID;\n   262→    if (RND_USER) {\n   263→      userID = rndUserID();\n   264→    } else {\n   265→      userID = nextUserID();\n   266→    }\n   267→    return userID;\n   268→  }\n   269→\n   270→  private static final BigDecimal orderFee = new BigDecimal(\"24.95\");\n   271→  private static final BigDecimal cashFee = new BigDecimal(\"0.0\");\n   272→\n   273→  public static BigDecimal getOrderFee(String orderType) {\n   274→    if ((orderType.compareToIgnoreCase(\"BUY\") == 0) || (orderType.compareToIgnoreCase(\"SELL\") == 0)) {\n   275→      return orderFee;\n   276→    }\n   277→\n   278→    return cashFee;\n   279→\n   280→  }\n   281→\n   282→  /**\n   283→   * Increment the sell deficit counter Creation date: (6/21/2000 11:33:45 AM)\n   284→   */\n   285→  public static synchronized void incrementSellDeficit() {\n   286→    sellDeficit++;\n   287→  }\n   288→\n   289→  public static String nextUserID() {\n   290→    String userID;\n   291→    synchronized (userID_count_semaphore) {\n   292→      userID = \"uid:\" + userID_count;\n   293→      userID_count++;\n   294→      if (userID_count % MAX_USERS == 0) {\n   295→        userID_count = 0;\n   296→      }\n   297→    }\n   298→    return userID;\n   299→  }\n   300→\n   301→  public static double random() {\n   302→    return randomNumberGenerator.nextDouble();\n   303→  }\n   304→\n   305→  public static String rndAddress() {\n   306→    return rndInt(1000) + \" Oak St.\";\n   307→  }\n   308→\n   309→  public static String rndBalance() {\n   310→    // Give all new users a cool mill in which to trade\n   311→    return \"1000000\";\n   312→  }\n   313→\n   314→  public static String rndCreditCard() {\n   315→    return rndInt(100) + \"-\" + rndInt(1000) + \"-\" + rndInt(1000) + \"-\" + rndInt(1000);\n   316→  }\n   317→\n   318→  public static String rndEmail(String userID) {\n   319→    return userID.replace(\":\", \"\") + \"@\" + rndInt(100) + \".com\";\n   320→  }\n   321→\n   322→  public static String rndFullName() {\n   323→    return \"first:\" + rndInt(1000) + \" last:\" + rndInt(5000);\n   324→  }\n   325→\n   326→  public static int rndInt(int i) {\n   327→    return (new Float(random() * i)).intValue();\n   328→  }\n   329→\n   330→  public static float rndFloat(int i) {\n   331→    return (new Float(random() * i)).floatValue();\n   332→  }\n   333→\n   334→  public static BigDecimal rndBigDecimal(float f) {\n   335→    return (new BigDecimal(random() * f)).setScale(2, BigDecimal.ROUND_HALF_UP);\n   336→  }\n   337→\n   338→  public static boolean rndBoolean() {\n   339→    return randomNumberGenerator.nextBoolean();\n   340→  }\n   341→\n   342→  /**\n   343→   * Returns a new Trade user Creation date: (2/16/2000 8:50:35 PM)\n   344→   */\n   345→  public static synchronized String rndNewUserID() {\n   346→\n   347→    return newUserPrefix + getHostname() + System.currentTimeMillis() + count++;\n   348→  }\n   349→\n   350→  public static float rndPrice() {\n   351→    return ((new Integer(rndInt(200))).floatValue()) + 1.0f;\n   352→  }\n   353→\n   354→  private static final BigDecimal ONE = new BigDecimal(1.0);\n   355→\n   356→  public static BigDecimal getRandomPriceChangeFactor() {\n   357→    // CJB (DAYTRADER-25) - Vary change factor between 1.1 and 0.9\n   358→    double percentGain = rndFloat(1) * 0.1;\n   359→    if (random() < .5) {\n   360→      percentGain *= -1;\n   361→    }\n   362→    percentGain += 1;\n   363→\n   364→    // change factor is between +/- 20%\n   365→    BigDecimal percentGainBD = (new BigDecimal(percentGain)).setScale(2, BigDecimal.ROUND_HALF_UP);\n   366→    if (percentGainBD.doubleValue() <= 0.0) {\n   367→      percentGainBD = ONE;\n   368→    }\n   369→\n   370→    return percentGainBD;\n   371→  }\n   372→\n   373→  public static float rndQuantity() {\n   374→    return ((new Integer(rndInt(200))).floatValue()) + 1.0f;\n   375→  }\n   376→\n   377→  public static String rndSymbol() {\n   378→    return \"s:\" + rndInt(MAX_QUOTES - 1);\n   379→  }\n   380→\n   381→  public static String rndSymbols() {\n   382→\n   383→    String symbols = \"\";\n   384→    int num_symbols = rndInt(QUOTES_PER_PAGE);\n   385→\n   386→    for (int i = 0; i <= num_symbols; i++) {\n   387→      symbols += \"s:\" + rndInt(MAX_QUOTES - 1);\n   388→      if (i < num_symbols) {\n   389→        symbols += \",\";\n   390→      }\n   391→    }\n   392→    return symbols;\n   393→  }\n   394→\n   395→  public static String rndUserID() {\n   396→    String nextUser = getNextUserIDFromDeck();\n   397→\n   398→    Log.trace(\"TradeConfig:rndUserID -- new trader = \" + nextUser);\n   399→\n   400→\n   401→    return nextUser;\n   402→  }\n   403→\n   404→  private static synchronized String getNextUserIDFromDeck() {\n   405→    int numUsers = getMAX_USERS();\n   406→    if (deck == null) {\n   407→      deck = new ArrayList<Integer>(numUsers);\n   408→      for (int i = 0; i < numUsers; i++) {\n   409→        deck.add(i, new Integer(i));\n   410→      }\n   411→      java.util.Collections.shuffle(deck, r0);\n   412→    }\n   413→    if (card >= numUsers) {\n   414→      card = 0;\n   415→    }\n   416→    return \"uid:\" + deck.get(card++);\n   417→\n   418→  }\n   419→\n   420→  // Trade implements a card deck approach to selecting\n   421→  // users for trading with tradescenarioservlet\n   422→  private static ArrayList<Integer> deck = null;\n   423→  private static int card = 0;\n   424→\n   425→  /**\n   426→   * This is a convenience method for servlets to set Trade configuration\n   427→   * parameters from servlet initialization parameters. The servlet provides\n   428→   * the init param and its value as strings. This method then parses the\n   429→   * parameter, converts the value to the correct type and sets the\n   430→   * corresponding TradeConfig parameter to the converted value\n   431→   *\n   432→   */\n   433→  public static void setConfigParam(String parm, String value) {\n   434→    Log.log(\"TradeConfig setting parameter: \" + parm + \"=\" + value);\n   435→    // Compare the parm value to valid TradeConfig parameters that can be\n   436→    // set\n   437→    // by servlet initialization\n   438→\n   439→    // First check the proposed new parm and value - if empty or null ignore\n   440→    // it\n   441→    if (parm == null) {\n   442→      return;\n   443→    }\n   444→    parm = parm.trim();\n   445→    if (parm.length() <= 0) {\n   446→      return;\n   447→    }\n   448→    if (value == null) {\n   449→      return;\n   450→    }\n   451→    value = value.trim();\n   452→\n   453→    if (parm.equalsIgnoreCase(\"orderProcessingMode\")) {\n   454→      try {\n   455→        for (int i = 0; i < orderProcessingModeNames.length; i++) {\n   456→          if (value.equalsIgnoreCase(orderProcessingModeNames[i])) {\n   457→            orderProcessingMode = i;\n   458→            break;\n   459→          }\n   460→        }\n   461→      } catch (Exception e) {\n   462→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set orderProcessingMode to \" + value\n   463→            + \"reverting to current value: \" + orderProcessingModeNames[orderProcessingMode], e);\n   464→      } // If the value is bad, simply revert to current\n   465→    } else if (parm.equalsIgnoreCase(\"accessMode\")) {\n   466→      try {\n   467→        for (int i = 0; i < accessModeNames.length; i++) {\n   468→          if (value.equalsIgnoreCase(accessModeNames[i])) {\n   469→            accessMode = i;\n   470→            break;\n   471→          }\n   472→        }\n   473→      } catch (Exception e) {\n   474→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set accessMode to \" + value + \"reverting to current value: \"\n   475→            + accessModeNames[accessMode], e);\n   476→      }\n   477→    } else if (parm.equalsIgnoreCase(\"WebInterface\")) {\n   478→      try {\n   479→        for (int i = 0; i < webInterfaceNames.length; i++) {\n   480→          if (value.equalsIgnoreCase(webInterfaceNames[i])) {\n   481→            webInterface = i;\n   482→            break;\n   483→          }\n   484→        }\n   485→      } catch (Exception e) {\n   486→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set WebInterface to \" + value + \"reverting to current value: \"\n   487→            + webInterfaceNames[webInterface], e);\n   488→\n   489→      } // If the value is bad, simply revert to current\n   490→    } else if (parm.equalsIgnoreCase(\"maxUsers\")) {\n   491→      try {\n   492→        MAX_USERS = Integer.parseInt(value);\n   493→      } catch (Exception e) {\n   494→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"Setting maxusers, error parsing string to int:\" + value\n   495→            + \"revering to current value: \" + MAX_USERS, e);\n   496→      } // On error, revert to saved\n   497→    } else if (parm.equalsIgnoreCase(\"maxQuotes\")) {\n   498→      try {\n   499→        MAX_QUOTES = Integer.parseInt(value);\n   500→      } catch (Exception e) {\n   501→        // >>rjm\n   502→        Log.error(\"TradeConfig.setConfigParm(...) minor exception caught\" + \"Setting max_quotes, error parsing string to int \" + value\n   503→            + \"reverting to current value: \" + MAX_QUOTES, e);\n   504→        // <<rjm\n   505→      } // On error, revert to saved\n   506→    } else if (parm.equalsIgnoreCase(\"primIterations\")) {\n   507→      try {\n   508→        primIterations = Integer.parseInt(value);\n   509→      } catch (Exception e) {\n   510→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"Setting primIterations, error parsing string to int:\" + value\n   511→            + \"revering to current value: \" + primIterations, e);\n   512→      } // On error, revert to saved\n   513→    } \n   514→  }\n   515→\n   516→  /**\n   517→   * Gets the orderProcessingModeNames\n   518→   *\n   519→   * @return Returns a String[]\n   520→   */\n   521→  public static String[] getOrderProcessingModeNames() {\n   522→    return orderProcessingModeNames;\n   523→  }\n   524→\n   525→  /**\n   526→   * Gets the webInterfaceNames\n   527→   *\n   528→   * @return Returns a String[]\n   529→   */\n   530→  public static String[] getWebInterfaceNames() {\n   531→    return webInterfaceNames;\n   532→  }\n   533→\n   534→  /**\n   535→   * Gets the webInterfaceNames\n   536→   *\n   537→   * @return Returns a String[]\n   538→   */\n   539→  /*public static String[] getCachingTypeNames() {\n   540→        return cachingTypeNames;\n   541→    }*/\n   542→\n   543→  /**\n   544→   * Gets the scenarioMixes\n   545→   *\n   546→   * @return Returns a int[][]\n   547→   */\n   548→  public static int[][] getScenarioMixes() {\n   549→    return scenarioMixes;\n   550→  }\n   551→\n   552→  /**\n   553→   * Gets the mAX_USERS.\n   554→   *\n   555→   * @return Returns a int\n   556→   */\n   557→  public static int getMAX_USERS() {\n   558→    return MAX_USERS;\n   559→  }\n   560→\n   561→  /**\n   562→   * Sets the mAX_USERS.\n   563→   *\n   564→   * @param mAX_USERS\n   565→   *            The mAX_USERS to set\n   566→   */\n   567→  public static void setMAX_USERS(int mAX_USERS) {\n   568→    MAX_USERS = mAX_USERS;\n   569→    deck = null; // reset the card deck for selecting users\n   570→  }\n   571→\n   572→  /**\n   573→   * Gets the mAX_QUOTES.\n   574→   *\n   575→   * @return Returns a int\n   576→   */\n   577→  public static int getMAX_QUOTES() {\n   578→    return MAX_QUOTES;\n   579→  }\n   580→\n   581→  /**\n   582→   * Sets the mAX_QUOTES.\n   583→   *\n   584→   * @param mAX_QUOTES\n   585→   *            The mAX_QUOTES to set\n   586→   */\n   587→  public static void setMAX_QUOTES(int mAX_QUOTES) {\n   588→    MAX_QUOTES = mAX_QUOTES;\n   589→  }\n   590→\n   591→  /**\n   592→   * Gets the mAX_HOLDINGS.\n   593→   *\n   594→   * @return Returns a int\n   595→   */\n   596→  public static int getMAX_HOLDINGS() {\n   597→    return MAX_HOLDINGS;\n   598→  }\n   599→\n   600→  /**\n   601→   * Sets the mAX_HOLDINGS.\n   602→   *\n   603→   * @param mAX_HOLDINGS\n   604→   *            The mAX_HOLDINGS to set\n   605→   */\n   606→  public static void setMAX_HOLDINGS(int mAX_HOLDINGS) {\n   607→    MAX_HOLDINGS = mAX_HOLDINGS;\n   608→  }\n   609→\n   610→  /**\n   611→   * Gets the scenarioCount.\n   612→   *\n   613→   * @return Returns a int\n   614→   */\n   615→  public static int getScenarioCount() {\n   616→    return scenarioCount;\n   617→  }\n   618→\n   619→  /**\n   620→   * Sets the scenarioCount.\n   621→   *\n   622→   * @param scenarioCount\n   623→   *            The scenarioCount to set\n   624→   */\n   625→  public static void setScenarioCount(int scenarioCount) {\n   626→    TradeConfig.scenarioCount = scenarioCount;\n   627→  }\n   628→\n   629→  public static synchronized void incrementScenarioCount() {\n   630→    scenarioCount++;\n   631→  }\n   632→\n   633→  /**\n   634→   * Gets the jdbc driver needs global transaction Some XA Drivers require a\n   635→   * global transaction to be started for all SQL calls. To work around this,\n   636→   * set this to true to cause the direct mode to start a user transaction.\n   637→   *\n   638→   * @return Returns a boolean\n   639→   */\n   640→  public static boolean getJDBCDriverNeedsGlobalTransation() {\n   641→    return JDBCDriverNeedsGlobalTransation;\n   642→  }\n   643→\n   644→  /**\n   645→   * Sets the jdbc driver needs global transaction\n   646→   *\n   647→   * @param JDBCDriverNeedsGlobalTransationVal\n   648→   *            the value\n   649→   */\n   650→  public static void setJDBCDriverNeedsGlobalTransation(boolean JDBCDriverNeedsGlobalTransationVal) {\n   651→    JDBCDriverNeedsGlobalTransation = JDBCDriverNeedsGlobalTransationVal;\n   652→  }\n   653→\n   654→  /**\n   655→   * Gets the updateQuotePrices.\n   656→   *\n   657→   * @return Returns a boolean\n   658→   */\n   659→  public static boolean getUpdateQuotePrices() {\n   660→    return updateQuotePrices;\n   661→  }\n   662→\n   663→  /**\n   664→   * Sets the updateQuotePrices.\n   665→   *\n   666→   * @param updateQuotePrices\n   667→   *            The updateQuotePrices to set\n   668→   */\n   669→  public static void setUpdateQuotePrices(boolean updateQuotePrices) {\n   670→    TradeConfig.updateQuotePrices = updateQuotePrices;\n   671→  }\n   672→\n   673→  public static int getPrimIterations() {\n   674→    return primIterations;\n   675→  }\n   676→\n   677→  public static void setPrimIterations(int iter) {\n   678→    primIterations = iter;\n   679→  }\n   680→\n   681→  public static boolean getLongRun() {\n   682→    return longRun;\n   683→  }\n   684→\n   685→  public static void setLongRun(boolean longRun) {\n   686→    TradeConfig.longRun = longRun;\n   687→  }\n   688→\n   689→  public static void setPublishQuotePriceChange(boolean publishQuotePriceChange) {\n   690→    TradeConfig.publishQuotePriceChange = publishQuotePriceChange;\n   691→  }\n   692→\n   693→  public static boolean getPublishQuotePriceChange() {\n   694→    return publishQuotePriceChange;\n   695→  }\n   696→\n   697→  public static void setMarketSummaryInterval(int seconds) {\n   698→    TradeConfig.marketSummaryInterval = seconds;\n   699→  }\n   700→\n   701→  public static int getMarketSummaryInterval() {\n   702→    return TradeConfig.marketSummaryInterval;\n   703→  }\n   704→\n   705→  public static void setRunTimeMode(int value) {\n   706→    runTimeMode = value;\n   707→  }\n   708→\n   709→  public static int getRunTimeMode() {\n   710→    return runTimeMode;\n   711→  }\n   712→\n   713→  public static void setOrderProcessingMode(int value) {\n   714→    orderProcessingMode = value;\n   715→  }\n   716→\n   717→  public static int getOrderProcessingMode() {\n   718→    return orderProcessingMode;\n   719→  }\n   720→\n   721→  public static void setAccessMode(int value) {\n   722→    accessMode = value;\n   723→  }\n   724→\n   725→  public static int getAccessMode() {\n   726→    return accessMode;\n   727→  }\n   728→\n   729→  public static void setWebInterface(int value) {\n   730→    webInterface = value;\n   731→  }\n   732→\n   733→  public static int getWebInterface() {\n   734→    return webInterface;\n   735→  }\n   736→\n   737→  public static void setDisplayOrderAlerts(boolean value) {\n   738→    displayOrderAlerts = value;\n   739→  }\n   740→\n   741→  public static boolean getDisplayOrderAlerts() {\n   742→    return displayOrderAlerts;\n   743→  }\n   744→\n   745→  public static void setListQuotePriceChangeFrequency(int value) {\n   746→    listQuotePriceChangeFrequency = value;\n   747→  }\n   748→\n   749→  public static int getListQuotePriceChangeFrequency() {\n   750→    return  listQuotePriceChangeFrequency;\n   751→  }\t\n   752→}\n   753→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"bda98573-c9be-4386-959d-3e463827f6ad"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01AmnUtKcZMRshexLpPwsVF6","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015, 2022.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import java.util.Collection;\n    19→import java.util.Iterator;\n    20→import java.util.logging.Level;\n    21→import java.util.logging.Logger;\n    22→\n    23→\n    24→\n    25→public class Log {\n    26→\n    27→  private final static Logger log = Logger.getLogger(\"daytrader\");\n    28→\n    29→\n    30→  // A general purpose, high performance logging, tracing, statistic service\n    31→\n    32→  public static void log(String message) {\n    33→    log.log(Level.INFO, message);\n    34→  }\n    35→\n    36→  public static void log(String msg1, String msg2) {\n    37→    log(msg1 + msg2);\n    38→  }\n    39→\n    40→  public static void log(String msg1, String msg2, String msg3) {\n    41→    log(msg1 + msg2 + msg3);\n    42→  }\n    43→\n    44→  public static void error(String message) {\n    45→    message = \"Error: \" + message;\n    46→    log.severe(message);\n    47→  }\n    48→\n    49→  public static void error(String message, Throwable e) {\n    50→    error(message + \"\\n\\t\" + e.toString());\n    51→    e.printStackTrace(System.out);\n    52→  }\n    53→\n    54→  public static void error(String msg1, String msg2, Throwable e) {\n    55→    error(msg1 + \"\\n\" + msg2 + \"\\n\\t\", e);\n    56→  }\n    57→\n    58→  public static void error(String msg1, String msg2, String msg3, Throwable e) {\n    59→    error(msg1 + \"\\n\" + msg2 + \"\\n\" + msg3 + \"\\n\\t\", e);\n    60→  }\n    61→\n    62→  public static void error(Throwable e, String message) {\n    63→    error(message + \"\\n\\t\", e);\n    64→    e.printStackTrace(System.out);\n    65→  }\n    66→\n    67→  public static void error(Throwable e, String msg1, String msg2) {\n    68→    error(msg1 + \"\\n\" + msg2 + \"\\n\\t\", e);\n    69→  }\n    70→\n    71→  public static void error(Throwable e, String msg1, String msg2, String msg3) {\n    72→    error(msg1 + \"\\n\" + msg2 + \"\\n\" + msg3 + \"\\n\\t\", e);\n    73→  }\n    74→\n    75→  public static void trace(String message) {\n    76→    log.log(Level.FINE, message + \" threadID=\" + Thread.currentThread());\n    77→  }\n    78→\n    79→  public static void traceInterceptor(String message, Object parm1) {\n    80→    log.log(Level.SEVERE,message,parm1);\n    81→  }\n    82→\n    83→  public static void trace(String message, Object parm1) {\n    84→    trace(message + \"(\" + parm1 + \")\");\n    85→  }\n    86→\n    87→  public static void trace(String message, Object parm1, Object parm2) {\n    88→    trace(message + \"(\" + parm1 + \", \" + parm2 + \")\");\n    89→  }\n    90→\n    91→  public static void trace(String message, Object parm1, Object parm2, Object parm3) {\n    92→    trace(message + \"(\" + parm1 + \", \" + parm2 + \", \" + parm3 + \")\");\n    93→  }\n    94→\n    95→  public static void trace(String message, Object parm1, Object parm2, Object parm3, Object parm4) {\n    96→    trace(message + \"(\" + parm1 + \", \" + parm2 + \", \" + parm3 + \")\" + \", \" + parm4);\n    97→  }\n    98→\n    99→  public static void trace(String message, Object parm1, Object parm2, Object parm3, Object parm4, Object parm5) {\n   100→    trace(message + \"(\" + parm1 + \", \" + parm2 + \", \" + parm3 + \")\" + \", \" + parm4 + \", \" + parm5);\n   101→  }\n   102→\n   103→  public static void trace(String message, Object parm1, Object parm2, Object parm3, Object parm4, Object parm5, Object parm6) {\n   104→    trace(message + \"(\" + parm1 + \", \" + parm2 + \", \" + parm3 + \")\" + \", \" + parm4 + \", \" + parm5 + \", \" + parm6);\n   105→  }\n   106→\n   107→  public static void trace(String message, Object parm1, Object parm2, Object parm3, Object parm4, Object parm5, Object parm6, Object parm7) {\n   108→    trace(message + \"(\" + parm1 + \", \" + parm2 + \", \" + parm3 + \")\" + \", \" + parm4 + \", \" + parm5 + \", \" + parm6 + \", \" + parm7);\n   109→  }\n   110→\n   111→  public static void traceEnter(String message) {\n   112→    log.log(Level.FINE,\"Method enter --\" + message);\n   113→  }\n   114→\n   115→  public static void traceExit(String message) {\n   116→    log.log(Level.FINE,\"Method exit  --\" + message);\n   117→  }\n   118→\n   119→  public static void stat(String message) {\n   120→    log(message);\n   121→  }\n   122→\n   123→  public static void debug(String message) {\n   124→    log.log(Level.INFO,message);\n   125→  }\n   126→\n   127→  public static void print(String message) {\n   128→    log(message);\n   129→  }\n   130→\n   131→  public static void printObject(Object o) {\n   132→    log(\"\\t\" + o.toString());\n   133→  }\n   134→\n   135→  public static void printCollection(Collection<?> c) {\n   136→    log(\"\\t---Log.printCollection -- collection size=\" + c.size());\n   137→    Iterator<?> it = c.iterator();\n   138→\n   139→    while (it.hasNext()) {\n   140→      log(\"\\t\\t\" + it.next().toString());\n   141→    }\n   142→    log(\"\\t---Log.printCollection -- complete\");\n   143→  }\n   144→\n   145→  public static void printCollection(String message, Collection<?> c) {\n   146→    log(message);\n   147→    printCollection(c);\n   148→  }\n   149→\n   150→\n   151→  public static boolean doDebug() {\n   152→    return true;\n   153→  }\n   154→\n   155→  public static boolean doTrace() {\n   156→    return log.isLoggable(Level.FINE);\n   157→  }\n   158→  \n   159→  public static void warning(String message) {\n   160→    log.log(Level.WARNING, message);\n   161→  }\n   162→}\n   163→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"b10fbf02-e887-4f87-aca6-63f55f1050de"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Mq3XcdrrqHTY1d9LLB4YeT","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.Collection;\n    20→import java.util.Iterator;\n    21→\n    22→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    23→\n    24→public class FinancialUtils {\n    25→\n    26→    public static final int ROUND = BigDecimal.ROUND_HALF_UP;\n    27→    public static final int SCALE = 2;\n    28→    public static final BigDecimal ZERO = (new BigDecimal(0.00)).setScale(SCALE);\n    29→    public static final BigDecimal ONE = (new BigDecimal(1.00)).setScale(SCALE);\n    30→    public static final BigDecimal HUNDRED = (new BigDecimal(100.00)).setScale(SCALE);\n    31→\n    32→    public static BigDecimal computeGain(BigDecimal currentBalance, BigDecimal openBalance) {\n    33→        return currentBalance.subtract(openBalance).setScale(SCALE);\n    34→    }\n    35→\n    36→    public static BigDecimal computeGainPercent(BigDecimal currentBalance, BigDecimal openBalance) {\n    37→        if (openBalance.doubleValue() == 0.0) {\n    38→            return ZERO;\n    39→        }\n    40→        BigDecimal gainPercent = currentBalance.divide(openBalance, ROUND).subtract(ONE).multiply(HUNDRED);\n    41→        return gainPercent;\n    42→    }\n    43→\n    44→    public static BigDecimal computeHoldingsTotal(Collection<?> holdingDataBeans) {\n    45→        BigDecimal holdingsTotal = new BigDecimal(0.0).setScale(SCALE);\n    46→        if (holdingDataBeans == null) {\n    47→            return holdingsTotal;\n    48→        }\n    49→        Iterator<?> it = holdingDataBeans.iterator();\n    50→        while (it.hasNext()) {\n    51→            HoldingDataBean holdingData = (HoldingDataBean) it.next();\n    52→            BigDecimal total = holdingData.getPurchasePrice().multiply(new BigDecimal(holdingData.getQuantity()));\n    53→            holdingsTotal = holdingsTotal.add(total);\n    54→        }\n    55→        return holdingsTotal.setScale(SCALE);\n    56→    }\n    57→\n    58→    public static String printGainHTML(BigDecimal gain) {\n    59→        String htmlString, arrow;\n    60→        if (gain.doubleValue() < 0.0) {\n    61→            htmlString = \"<FONT color=\\\"#ff0000\\\">\";\n    62→            arrow = \"arrowdown.gif\";\n    63→        } else {\n    64→            htmlString = \"<FONT color=\\\"#009900\\\">\";\n    65→            arrow = \"arrowup.gif\";\n    66→        }\n    67→\n    68→        htmlString += gain.setScale(SCALE, ROUND) + \"</FONT><IMG src=\\\"images/\" + arrow + \"\\\" width=\\\"10\\\" height=\\\"10\\\" border=\\\"0\\\"></IMG>\";\n    69→        return htmlString;\n    70→    }\n    71→\n    72→    public static String printChangeHTML(double change) {\n    73→        String htmlString, arrow;\n    74→        if (change < 0.0) {\n    75→            htmlString = \"<FONT color=\\\"#ff0000\\\">\";\n    76→            arrow = \"arrowdown.gif\";\n    77→        } else {\n    78→            htmlString = \"<FONT color=\\\"#009900\\\">\";\n    79→            arrow = \"arrowup.gif\";\n    80→        }\n    81→\n    82→        htmlString += change + \"</FONT><IMG src=\\\"images/\" + arrow + \"\\\" width=\\\"10\\\" height=\\\"10\\\" border=\\\"0\\\"></IMG>\";\n    83→        return htmlString;\n    84→    }\n    85→\n    86→    public static String printGainPercentHTML(BigDecimal gain) {\n    87→        String htmlString, arrow;\n    88→        if (gain.doubleValue() < 0.0) {\n    89→            htmlString = \"(<B><FONT color=\\\"#ff0000\\\">\";\n    90→            arrow = \"arrowdown.gif\";\n    91→        } else {\n    92→            htmlString = \"(<B><FONT color=\\\"#009900\\\">+\";\n    93→            arrow = \"arrowup.gif\";\n    94→        }\n    95→\n    96→        htmlString += gain.setScale(SCALE, ROUND);\n    97→        htmlString += \"%</FONT></B>)<IMG src=\\\"images/\" + arrow + \"\\\" width=\\\"10\\\" height=\\\"10\\\" border=\\\"0\\\"></IMG>\";\n    98→        return htmlString;\n    99→    }\n   100→\n   101→    public static String printQuoteLink(String symbol) {\n   102→        return \"<A href=\\\"app?action=quotes&symbols=\" + symbol + \"\\\">\" + symbol + \"</A>\";\n   103→    }\n   104→\n   105→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"8b9cd379-a3a1-4daf-8d73-fb57abf703a3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01STknsYyQ3H7DCeUU6Z95L6","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import java.io.Serializable;\n    19→import java.text.MessageFormat;\n    20→import java.util.Arrays;\n    21→\n    22→import javax.annotation.Priority;\n    23→\n    24→import javax.interceptor.AroundInvoke;\n    25→import javax.interceptor.Interceptor;\n    26→import javax.interceptor.InvocationContext;\n    27→\n    28→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    29→\n    30→\n    31→@Trace \n    32→@Interceptor\n    33→@Priority(Interceptor.Priority.APPLICATION)\n    34→public class TraceInterceptor implements Serializable {\n    35→\n    36→  private static final long serialVersionUID = -4195975993998268072L;\n    37→  private static final MessageFormat form = new MessageFormat(\"Method enter -- {0} called with {1}\");\n    38→\n    39→  @AroundInvoke\n    40→  public Object logMethodEntry(InvocationContext ctx) throws Exception {\n    41→    Log.trace(form.format(\n    42→        new String[]{\n    43→            ctx.getMethod().getDeclaringClass().getSimpleName() + \":\"+ ctx.getMethod().getName(),\n    44→            Arrays.deepToString(ctx.getParameters())\n    45→    }));\n    46→\n    47→    return ctx.proceed();\n    48→  }\n    49→}\n    50→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"d97363fd-56ed-4f16-9068-467fedae05ae"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_019mC84THAj5FyLndip3kJ7t","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import javax.enterprise.util.AnnotationLiteral;\n    19→\n    20→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    21→\n    22→public class TradeRunTimeModeLiteral extends AnnotationLiteral<RuntimeMode> implements RuntimeMode {\n    23→  \n    24→  private static final long serialVersionUID = -252789556335033400L;\n    25→    private String value;\n    26→    public TradeRunTimeModeLiteral(String value) {\n    27→        this.value = value;\n    28→    }\n    29→\n    30→    @Override\n    31→    public String value() {\n    32→         return value;\n    33→    }\n    34→\n    35→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"6693dd79-df0c-4761-a81c-6038bd4911f0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Jr9cvkBbjso2XXFRH24jtb","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→\n    21→import javax.enterprise.context.SessionScoped;\n    22→import javax.enterprise.inject.Any;\n    23→import javax.enterprise.inject.Instance;\n    24→import javax.faces.context.ExternalContext;\n    25→import javax.inject.Inject;\n    26→import javax.inject.Named;\n    27→import javax.servlet.ServletException;\n    28→import javax.servlet.http.HttpServletRequest;\n    29→import javax.servlet.http.HttpSession;\n    30→import javax.validation.constraints.Email;\n    31→import javax.validation.constraints.NotBlank;\n    32→\n    33→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    34→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    35→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    36→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    37→import com.ibm.websphere.samples.daytrader.util.Log;\n    38→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    39→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    40→\n    41→@Named(\"tradeapp\")\n    42→@SessionScoped\n    43→@Trace\n    44→public class TradeAppJSF implements Serializable {\n    45→\n    46→  @Inject ExternalContext context;\n    47→\n    48→  private TradeServices tradeAction;\n    49→\n    50→  private static final long serialVersionUID = 2L;\n    51→  \n    52→  @NotBlank\n    53→  private String userID = \"uid:0\";\n    54→  \n    55→  @NotBlank\n    56→  private String password = \"xxx\";\n    57→  \n    58→  @NotBlank\n    59→  private String cpassword;\n    60→  \n    61→  @NotBlank\n    62→  private String results;\n    63→  \n    64→  @NotBlank\n    65→  private String fullname;\n    66→  \n    67→  @NotBlank\n    68→  private String address;\n    69→  \n    70→  @Email\n    71→  private String email;\n    72→  \n    73→  @NotBlank\n    74→  private String ccn;\n    75→  \n    76→  @NotBlank\n    77→  private String money;\n    78→\n    79→  @Inject \n    80→  public TradeAppJSF(@Any Instance<TradeServices> services) {\n    81→    tradeAction = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    82→  }\n    83→\n    84→  public String login() {\n    85→    try {        \t\n    86→      AccountDataBean accountData = tradeAction.login(userID, password);\n    87→\n    88→      AccountProfileDataBean accountProfileData = tradeAction.getAccountProfileData(userID);\n    89→      if (accountData != null) {\n    90→        HttpSession session = (HttpSession) context.getSession(true);\n    91→\n    92→        session.setAttribute(\"uidBean\", userID);\n    93→        session.setAttribute(\"sessionCreationDate\", new java.util.Date());\n    94→        setResults(\"Ready to Trade\");\n    95→\n    96→        // Get account profile information\n    97→        setAddress(accountProfileData.getAddress());\n    98→        setCcn(accountProfileData.getCreditCard());\n    99→        setEmail(accountProfileData.getEmail());\n   100→        setFullname(accountProfileData.getFullName());\n   101→        setCpassword(accountProfileData.getPassword());\n   102→        return \"Ready to Trade\";\n   103→      } else {\n   104→        Log.log(\"TradeServletAction.doLogin(...)\", \"Error finding account for user \" + userID + \"\",\n   105→            \"user entered a bad username or the database is not populated\");\n   106→        throw new NullPointerException(\"User does not exist or password is incorrect!\");\n   107→      }\n   108→    }\n   109→\n   110→    catch (Exception se) {\n   111→      // Go to welcome page\n   112→      setResults(\"Could not find account\");\n   113→      return \"welcome\";\n   114→    }\n   115→  }\n   116→\n   117→  public String register() {\n   118→\n   119→    // Validate user passwords match and are atleast 1 char in length\n   120→    try {\n   121→      if ((password.equals(cpassword)) && (password.length() >= 1)) {\n   122→        AccountDataBean accountData = tradeAction.register(userID, password, fullname, address, email, ccn, new BigDecimal(money));\n   123→\n   124→        if (accountData == null) {\n   125→          setResults(\"Registration operation failed;\");\n   126→          // Go to register page\n   127→          return \"Registration operation failed\";\n   128→\n   129→        } else {\n   130→          login();\n   131→          setResults(\"Registration operation succeeded;  Account \" + accountData.getAccountID() + \" has been created.\");\n   132→          return \"Registration operation succeeded\";\n   133→        }\n   134→      }\n   135→\n   136→      else {\n   137→        // Password validation failed\n   138→        setResults(\"Registration operation failed, your passwords did not match\");\n   139→        // Go to register page\n   140→        return \"Registration operation failed\";\n   141→      }\n   142→    }\n   143→\n   144→    catch (Exception e) {\n   145→      // log the exception with error page\n   146→      Log.log(\"TradeServletAction.doRegister(...)\" + \" exception user =\" + userID);\n   147→      try {\n   148→        throw new Exception(\"TradeServletAction.doRegister(...)\" + \" exception user =\" + userID, e);\n   149→      } catch (Exception e1) {\n   150→        e1.printStackTrace();\n   151→      }\n   152→\n   153→    }\n   154→    return \"Registration operation succeeded\";\n   155→  }\n   156→\n   157→  public String updateProfile() {\n   158→\n   159→    // First verify input data\n   160→    boolean doUpdate = true;\n   161→\n   162→    if (password.equals(cpassword) == false) {\n   163→      results = \"Update profile error: passwords do not match\";\n   164→      doUpdate = false;\n   165→    }\n   166→\n   167→    AccountProfileDataBean accountProfileData = new AccountProfileDataBean(userID, password, fullname, address, email, ccn);\n   168→\n   169→    try {\n   170→      if (doUpdate) {\n   171→        accountProfileData = tradeAction.updateAccountProfile(accountProfileData);\n   172→        results = \"Account profile update successful\";\n   173→      }\n   174→\n   175→    } catch (java.lang.IllegalArgumentException e) {\n   176→      // this is a user error so I will\n   177→      // forward them to another page rather than throw a 500\n   178→      setResults(\"invalid argument, check userID is correct, and the database is populated\" + userID);\n   179→      Log.error(e, \"TradeServletAction.doAccount(...)\", \"illegal argument, information should be in exception string\",\n   180→          \"treating this as a user error and forwarding on to a new page\");\n   181→    } catch (Exception e) {\n   182→      // log the exception with error page\n   183→      e.printStackTrace();\n   184→    }\n   185→    // Go to account.xhtml\n   186→    return \"Go to account\";\n   187→  }\n   188→\n   189→  public String logout() {\n   190→\n   191→    try {\n   192→      setResults(\"\");\n   193→      tradeAction.logout(userID);\n   194→    } catch (java.lang.IllegalArgumentException e) {\n   195→      // this is a user error so I will\n   196→      // forward them to another page, at the end of the page.\n   197→      setResults(\"illegal argument:\" + e.getMessage());\n   198→\n   199→      // log the exception with an error level of 3 which means, handled\n   200→      // exception but would invalidate a automation run\n   201→      Log.error(e, \"TradeServletAction.doLogout(...)\", \"illegal argument, information should be in exception string\",\n   202→          \"treating this as a user error and forwarding on to a new page\");\n   203→    } catch (Exception e) {\n   204→      // log the exception and foward to a error page\n   205→      Log.error(e, \"TradeAppJSF.logout():\", \"Error logging out\" + userID, \"fowarding to an error page\");\n   206→    }\n   207→\n   208→    HttpSession session = (HttpSession)context.getSession(false);\n   209→\n   210→    if (session != null) {\n   211→      session.invalidate();\n   212→    }\n   213→\n   214→    // Added to actually remove a user from the authentication cache\n   215→    try {\n   216→      ((HttpServletRequest) context.getRequest()).logout();\n   217→    } catch (ServletException e) {\n   218→      Log.error(e, \"TradeAppJSF.logout():\", \"Error logging out request\" + userID, \"fowarding to an error page\");\n   219→    }\n   220→\n   221→    // Go to welcome page\n   222→    return \"welcome\";\n   223→  }\n   224→\n   225→  public String getUserID() {\n   226→    return userID;\n   227→  }\n   228→\n   229→  public void setUserID(String userID) {\n   230→    this.userID = userID;\n   231→  }\n   232→\n   233→  public String getPassword() {\n   234→    return password;\n   235→  }\n   236→\n   237→  public void setPassword(String password) {\n   238→    this.password = password;\n   239→  }\n   240→\n   241→  public String getCpassword() {\n   242→    return cpassword;\n   243→  }\n   244→\n   245→  public void setCpassword(String cpassword) {\n   246→    this.cpassword = cpassword;\n   247→  }\n   248→\n   249→  public String getFullname() {\n   250→    return fullname;\n   251→  }\n   252→\n   253→  public void setFullname(String fullname) {\n   254→    this.fullname = fullname;\n   255→  }\n   256→\n   257→  public String getResults() {\n   258→    String tempResults=results;\n   259→    results=\"\";\n   260→    return tempResults;\n   261→  }\n   262→\n   263→  public void setResults(String results) {\n   264→    this.results = results;\n   265→  }\n   266→\n   267→  public String getAddress() {\n   268→    return address;\n   269→  }\n   270→\n   271→  public void setAddress(String address) {\n   272→    this.address = address;\n   273→  }\n   274→\n   275→  public String getEmail() {\n   276→    return email;\n   277→  }\n   278→\n   279→  public void setEmail(String email) {\n   280→    this.email = email;\n   281→  }\n   282→\n   283→  public String getCcn() {\n   284→    return ccn;\n   285→  }\n   286→\n   287→  public void setCcn(String ccn) {\n   288→    this.ccn = ccn;\n   289→  }\n   290→\n   291→  public String getMoney() {\n   292→    return money;\n   293→  }\n   294→\n   295→  public void setMoney(String money) {\n   296→    this.money = money;\n   297→  }\n   298→};\n   299→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"a6328b36-cbda-4e11-8bf0-e6e0f1bab45b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01EdGTr4X6BS643Exz4fhbQ5","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import javax.enterprise.context.RequestScoped;\n    19→import javax.faces.context.ExternalContext;\n    20→import javax.inject.Inject;\n    21→import javax.inject.Named;\n    22→import javax.servlet.http.HttpSession;\n    23→\n    24→import com.ibm.websphere.samples.daytrader.beans.RunStatsDataBean;\n    25→import com.ibm.websphere.samples.daytrader.impl.direct.TradeDirectDBUtils;\n    26→import com.ibm.websphere.samples.daytrader.util.Log;\n    27→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    28→\n    29→@Named(\"tradeconfig\")\n    30→@RequestScoped\n    31→public class TradeConfigJSF {\n    32→\n    33→  @Inject\n    34→  private ExternalContext context;\n    35→\n    36→  @Inject \n    37→  TradeDirectDBUtils dbUtils;\n    38→\n    39→  private String runtimeMode = TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()];\n    40→  private String orderProcessingMode = TradeConfig.getOrderProcessingModeNames()[TradeConfig.getOrderProcessingMode()];\n    41→  private int maxUsers = TradeConfig.getMAX_USERS();\n    42→  private int maxQuotes = TradeConfig.getMAX_QUOTES();\n    43→  private int marketSummaryInterval = TradeConfig.getMarketSummaryInterval();\n    44→  private String webInterface = TradeConfig.getWebInterfaceNames()[TradeConfig.getWebInterface()];\n    45→  private int primIterations = TradeConfig.getPrimIterations();\n    46→  private int listQuotePriceChangeFrequency = TradeConfig.getListQuotePriceChangeFrequency();\n    47→  private boolean publishQuotePriceChange = TradeConfig.getPublishQuotePriceChange();\n    48→  private boolean longRun = TradeConfig.getLongRun();\n    49→  private boolean displayOrderAlerts = TradeConfig.getDisplayOrderAlerts();\n    50→  private String[] runtimeModeList = TradeConfig.getRunTimeModeNames();\n    51→  private String[] orderProcessingModeList = TradeConfig.getOrderProcessingModeNames();\n    52→\n    53→  private String[] webInterfaceList = TradeConfig.getWebInterfaceNames();\n    54→  private String result = \"\";\n    55→\n    56→  public void updateConfig() {\n    57→    String currentConfigStr = \"\\n\\n########## Trade configuration update. Current config:\\n\\n\";     \n    58→\n    59→    currentConfigStr += \"\\t\\tRunTimeMode:\\t\\t\\t\" + TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()] + \"\\n\";\n    60→\n    61→    String orderProcessingModeStr = this.orderProcessingMode;\n    62→    if (orderProcessingModeStr != null) {\n    63→      try {\n    64→        for (int i = 0; i < orderProcessingModeList.length; i++) {\n    65→          if (orderProcessingModeStr.equals(orderProcessingModeList[i])) {\n    66→            TradeConfig.setOrderProcessingMode(i);\n    67→          }\n    68→        }\n    69→      } catch (Exception e) {\n    70→        Log.error(e, \"TradeConfigJSF.updateConfig(..): minor exception caught\", \"trying to set orderProcessing to \" + orderProcessingModeStr,\n    71→            \"reverting to current value\");\n    72→\n    73→      } // If the value is bad, simply revert to current\n    74→    }\n    75→    currentConfigStr += \"\\t\\tOrderProcessingMode:\\t\\t\" + TradeConfig.getOrderProcessingModeNames()[TradeConfig.getOrderProcessingMode()] + \"\\n\";\n    76→\n    77→    String webInterfaceStr = webInterface;\n    78→    if (webInterfaceStr != null) {\n    79→      try {\n    80→        for (int i = 0; i < webInterfaceList.length; i++) {\n    81→          if (webInterfaceStr.equals(webInterfaceList[i])) {\n    82→            TradeConfig.setWebInterface(i);\n    83→          }\n    84→        }\n    85→      } catch (Exception e) {\n    86→        Log.error(e, \"TradeConfigJSF.updateConfig(..): minor exception caught\", \"trying to set WebInterface to \" + webInterfaceStr,\n    87→            \"reverting to current value\");\n    88→\n    89→      } // If the value is bad, simply revert to current\n    90→    }\n    91→    currentConfigStr += \"\\t\\tWeb Interface:\\t\\t\\t\" + TradeConfig.getWebInterfaceNames()[TradeConfig.getWebInterface()] + \"\\n\";\n    92→\n    93→    TradeConfig.setMAX_USERS(maxUsers);\n    94→    TradeConfig.setMAX_QUOTES(maxQuotes);\n    95→\n    96→    currentConfigStr += \"\\t\\tTrade  Users:\\t\\t\\t\" + TradeConfig.getMAX_USERS() + \"\\n\";\n    97→    currentConfigStr += \"\\t\\tTrade Quotes:\\t\\t\\t\" + TradeConfig.getMAX_QUOTES() + \"\\n\";\n    98→\n    99→    TradeConfig.setMarketSummaryInterval(marketSummaryInterval);\n   100→\n   101→    currentConfigStr += \"\\t\\tMarket Summary Interval:\\t\" + TradeConfig.getMarketSummaryInterval() + \"\\n\";\n   102→\n   103→    TradeConfig.setPrimIterations(primIterations);\n   104→\n   105→    currentConfigStr += \"\\t\\tPrimitive Iterations:\\t\\t\" + TradeConfig.getPrimIterations() + \"\\n\";\n   106→\n   107→    TradeConfig.setPublishQuotePriceChange(publishQuotePriceChange);\n   108→    currentConfigStr += \"\\t\\tTradeStreamer MDB Enabled:\\t\" + TradeConfig.getPublishQuotePriceChange() + \"\\n\";\n   109→\n   110→    TradeConfig.setListQuotePriceChangeFrequency(listQuotePriceChangeFrequency);\n   111→    currentConfigStr += \"\\t\\t% of trades on Websocket:\\t\" + TradeConfig.getListQuotePriceChangeFrequency() + \"\\n\";\n   112→\n   113→    TradeConfig.setLongRun(longRun);\n   114→    currentConfigStr += \"\\t\\tLong Run Enabled:\\t\\t\" + TradeConfig.getLongRun() + \"\\n\";\n   115→\n   116→    TradeConfig.setDisplayOrderAlerts(displayOrderAlerts);\n   117→    currentConfigStr += \"\\t\\tDisplay Order Alerts:\\t\\t\" + TradeConfig.getDisplayOrderAlerts() + \"\\n\";\n   118→\n   119→    System.out.println(currentConfigStr);\n   120→    setResult(\"DayTrader Configuration Updated\");\n   121→  }\n   122→\n   123→  public String resetTrade() {\n   124→    RunStatsDataBean runStatsData = new RunStatsDataBean();\n   125→    TradeConfig currentConfig = new TradeConfig();\n   126→    HttpSession session = (HttpSession) context.getSession(true);   \n   127→\n   128→\n   129→    try {     \n   130→      runStatsData = dbUtils.resetTrade(false);\n   131→      session.setAttribute(\"runStatsData\", runStatsData);\n   132→      session.setAttribute(\"tradeConfig\", currentConfig);\n   133→      result += \"Trade Reset completed successfully\";\n   134→\n   135→    } catch (Exception e) {\n   136→      result += \"Trade Reset Error  - see log for details\";\n   137→      session.setAttribute(\"result\", result);\n   138→      Log.error(e, result);\n   139→    }\n   140→\n   141→    return \"stats\";\n   142→  }\n   143→\n   144→  public String populateDatabase() {\n   145→\n   146→    try {\n   147→      dbUtils.buildDB(new java.io.PrintWriter(System.out), null);\n   148→    } catch (Exception e) {\n   149→      e.printStackTrace();\n   150→    }       \n   151→\n   152→    result = \"TradeBuildDB: **** DayTrader Database Built - \" + TradeConfig.getMAX_USERS() + \" users created, \" + TradeConfig.getMAX_QUOTES()\n   153→    + \" quotes created. ****<br/>\";\n   154→    result += \"TradeBuildDB: **** Check System.Out for any errors. ****<br/>\";\n   155→\n   156→    return \"database\";\n   157→  }\n   158→\n   159→  public String buildDatabaseTables() {\n   160→    try {\n   161→      String dbProductName = null;\n   162→      try {\n   163→        dbProductName = dbUtils.checkDBProductName();\n   164→      } catch (Exception e) {\n   165→        Log.error(e, \"TradeBuildDB: Unable to check DB Product name\");\n   166→      }\n   167→      if (dbProductName == null) {\n   168→        result += \"TradeBuildDB: **** Unable to check DB Product name, please check Database/AppServer configuration and retry ****<br/>\";\n   169→        return \"database\";\n   170→      }\n   171→\n   172→      String ddlFile = null;\n   173→      //Locate DDL file for the specified database\n   174→      try {\n   175→        result = result + \"TradeBuildDB: **** Database Product detected: \" + dbProductName + \" ****<br/>\";\n   176→        if (dbProductName.startsWith(\"DB2/\")) { // if db is DB2\n   177→          ddlFile = \"/dbscripts/db2/Table.ddl\";\n   178→        } else if (dbProductName.startsWith(\"Apache Derby\")) { //if db is Derby\n   179→          ddlFile = \"/dbscripts/derby/Table.ddl\";\n   180→        } else if (dbProductName.startsWith(\"Oracle\")) { // if the Db is Oracle\n   181→          ddlFile = \"/dbscripts/oracle/Table.ddl\";\n   182→        } else { // Unsupported \"Other\" Database\n   183→          ddlFile = \"/dbscripts/other/Table.ddl\";\n   184→          result = result + \"TradeBuildDB: **** This Database is unsupported/untested use at your own risk ****<br/>\";\n   185→        }\n   186→\n   187→        result = result + \"TradeBuildDB: **** The DDL file at path\" + ddlFile + \" will be used ****<br/>\";\n   188→      } catch (Exception e) {\n   189→        Log.error(e, \"TradeBuildDB: Unable to locate DDL file for the specified database\");\n   190→        result = result + \"TradeBuildDB: **** Unable to locate DDL file for the specified database ****<br/>\";\n   191→        return \"database\";\n   192→      }\n   193→\n   194→      dbUtils.buildDB(new java.io.PrintWriter(System.out), context.getResourceAsStream(ddlFile));\n   195→\n   196→      result = result + \"TradeBuildDB: **** DayTrader Database Created, Check System.Out for any errors. ****<br/>\";\n   197→\n   198→    } catch (Exception e) {\n   199→      e.printStackTrace();\n   200→    }\n   201→\n   202→    // Go to configure.xhtml\n   203→    return \"database\";\n   204→  }\n   205→\n   206→\n   207→\n   208→\n   209→  public String getRuntimeMode() {\n   210→    return runtimeMode;\n   211→  }\n   212→\n   213→  public void setRuntimeMode(String runtimeMode) {\n   214→    this.runtimeMode = runtimeMode;\n   215→  }\n   216→\n   217→  public void setOrderProcessingMode(String orderProcessingMode) {\n   218→    this.orderProcessingMode = orderProcessingMode;\n   219→  }\n   220→\n   221→  public String getOrderProcessingMode() {\n   222→    return orderProcessingMode;\n   223→  }\n   224→\n   225→\n   226→  public void setMaxUsers(int maxUsers) {\n   227→    this.maxUsers = maxUsers;\n   228→  }\n   229→\n   230→  public int getMaxUsers() {\n   231→    return maxUsers;\n   232→  }\n   233→\n   234→  public void setmaxQuotes(int maxQuotes) {\n   235→    this.maxQuotes = maxQuotes;\n   236→  }\n   237→\n   238→  public int getMaxQuotes() {\n   239→    return maxQuotes;\n   240→  }\n   241→\n   242→  public void setMarketSummaryInterval(int marketSummaryInterval) {\n   243→    this.marketSummaryInterval = marketSummaryInterval;\n   244→  }\n   245→\n   246→  public int getMarketSummaryInterval() {\n   247→    return marketSummaryInterval;\n   248→  }\n   249→\n   250→  public void setPrimIterations(int primIterations) {\n   251→    this.primIterations = primIterations;\n   252→  }\n   253→\n   254→  public int getPrimIterations() {\n   255→    return primIterations;\n   256→  }\n   257→\n   258→  public void setPublishQuotePriceChange(boolean publishQuotePriceChange) {\n   259→    this.publishQuotePriceChange = publishQuotePriceChange;\n   260→  }\n   261→\n   262→  public boolean isPublishQuotePriceChange() {\n   263→    return publishQuotePriceChange;\n   264→  }\n   265→\n   266→  public void setListQuotePriceChangeFrequency(int listQuotePriceChangeFrequency) {\n   267→    this.listQuotePriceChangeFrequency =  listQuotePriceChangeFrequency;\n   268→  }\n   269→\n   270→  public int getListQuotePriceChangeFrequency() {\n   271→    return  listQuotePriceChangeFrequency;\n   272→  }\n   273→\n   274→  public void setDisplayOrderAlerts(boolean displayOrderAlerts) {\n   275→    this.displayOrderAlerts = displayOrderAlerts;\n   276→  }\n   277→\n   278→  public boolean isDisplayOrderAlerts() {\n   279→    return displayOrderAlerts;\n   280→  }\n   281→\n   282→\n   283→  public void setLongRun(boolean longRun) {\n   284→    this.longRun = longRun;\n   285→  }\n   286→\n   287→  public boolean isLongRun() {\n   288→    return longRun;\n   289→  }\n   290→\n   291→  public String[] getRuntimeModeList() {\n   292→    return runtimeModeList;\n   293→  }\n   294→\n   295→  public void setRuntimeModeList(String[] runtimeModeList) {\n   296→    this.runtimeModeList = runtimeModeList;\n   297→  }\n   298→\n   299→  public void setOrderProcessingModeList(String[] orderProcessingModeList) {\n   300→    this.orderProcessingModeList = orderProcessingModeList;\n   301→  }\n   302→\n   303→  public String[] getOrderProcessingModeList() {\n   304→    return orderProcessingModeList;\n   305→  }\n   306→\n   307→  public void setWebInterface(String webInterface) {\n   308→    this.webInterface = webInterface;\n   309→  }\n   310→\n   311→  public String getWebInterface() {\n   312→    return webInterface;\n   313→  }\n   314→\n   315→  public void setWebInterfaceList(String[] webInterfaceList) {\n   316→    this.webInterfaceList = webInterfaceList;\n   317→  }\n   318→\n   319→  public String[] getWebInterfaceList() {\n   320→    return webInterfaceList;\n   321→  }\n   322→\n   323→  public void setResult(String result) {\n   324→    this.result = result;\n   325→  }\n   326→\n   327→  public String getResult() {\n   328→    return result;\n   329→  }\n   330→\n   331→}\n   332→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"53e38f32-4c36-49d5-9ece-09083da14a47"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01DPkxqfEYUCqGNYgxRzFfVo","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.jsf;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.math.RoundingMode;\n    20→import java.util.Collection;\n    21→import java.util.Date;\n    22→import java.util.Iterator;\n    23→\n    24→import javax.annotation.PostConstruct;\n    25→import javax.enterprise.context.RequestScoped;\n    26→import javax.enterprise.inject.Any;\n    27→import javax.enterprise.inject.Instance;\n    28→import javax.inject.Inject;\n    29→import javax.inject.Named;\n    30→\n    31→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    32→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    33→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    34→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    35→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    36→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    37→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    38→\n    39→@Named(\"marketdata\")\n    40→@RequestScoped\n    41→@Trace\n    42→public class MarketSummaryJSF {\n    43→\n    44→  private TradeServices tradeAction;\n    45→\n    46→  private BigDecimal TSIA;\n    47→  private BigDecimal openTSIA;\n    48→  private double volume;\n    49→  private QuoteData[] topGainers;\n    50→  private QuoteData[] topLosers;\n    51→  private Date summaryDate;\n    52→\n    53→  // cache the gainPercent once computed for this bean\n    54→  private BigDecimal gainPercent = null;\n    55→\n    56→  @Inject \n    57→  public MarketSummaryJSF(@Any Instance<TradeServices> services) {\n    58→    tradeAction = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    59→  }\n    60→  \n    61→  @PostConstruct\n    62→  public void getMarketSummary() {\n    63→   \n    64→    try {\n    65→      MarketSummaryDataBean marketSummaryData = tradeAction.getMarketSummary();\n    66→      setSummaryDate(marketSummaryData.getSummaryDate());\n    67→      setTSIA(marketSummaryData.getTSIA());\n    68→      setVolume(marketSummaryData.getVolume());\n    69→      setGainPercent(marketSummaryData.getGainPercent());\n    70→\n    71→      Collection<?> topGainers = marketSummaryData.getTopGainers();\n    72→\n    73→      Iterator<?> gainers = topGainers.iterator();\n    74→      int count = 0;\n    75→      QuoteData[] gainerjsfs = new QuoteData[5];\n    76→\n    77→      while (gainers.hasNext() && (count < 5)) {\n    78→        QuoteDataBean quote = (QuoteDataBean) gainers.next();\n    79→        QuoteData r = new QuoteData(quote.getPrice(), quote.getOpen(), quote.getSymbol());\n    80→        gainerjsfs[count] = r;\n    81→        count++;\n    82→      }\n    83→\n    84→      setTopGainers(gainerjsfs);\n    85→\n    86→      Collection<?> topLosers = marketSummaryData.getTopLosers();\n    87→\n    88→      QuoteData[] loserjsfs = new QuoteData[5];\n    89→      count = 0;\n    90→      Iterator<?> losers = topLosers.iterator();\n    91→\n    92→      while (losers.hasNext() && (count < 5)) {\n    93→        QuoteDataBean quote = (QuoteDataBean) losers.next();\n    94→        QuoteData r = new QuoteData(quote.getPrice(), quote.getOpen(), quote.getSymbol());\n    95→        loserjsfs[count] = r;\n    96→        count++;\n    97→      }\n    98→\n    99→      setTopLosers(loserjsfs);\n   100→\n   101→    } catch (Exception e) {\n   102→      e.printStackTrace();\n   103→    }\n   104→  }\n   105→\n   106→  public void setTSIA(BigDecimal tSIA) {\n   107→    TSIA = tSIA;\n   108→  }\n   109→\n   110→  public BigDecimal getTSIA() {\n   111→    return TSIA;\n   112→  }\n   113→\n   114→  public void setOpenTSIA(BigDecimal openTSIA) {\n   115→    this.openTSIA = openTSIA;\n   116→  }\n   117→\n   118→  public BigDecimal getOpenTSIA() {\n   119→    return openTSIA;\n   120→  }\n   121→\n   122→  public void setVolume(double volume) {\n   123→    this.volume = volume;\n   124→  }\n   125→\n   126→  public double getVolume() {\n   127→    return volume;\n   128→  }\n   129→\n   130→  public void setTopGainers(QuoteData[] topGainers) {\n   131→    this.topGainers = topGainers;\n   132→  }\n   133→\n   134→  public QuoteData[] getTopGainers() {\n   135→    return topGainers;\n   136→  }\n   137→\n   138→  public void setTopLosers(QuoteData[] topLosers) {\n   139→    this.topLosers = topLosers;\n   140→  }\n   141→\n   142→  public QuoteData[] getTopLosers() {\n   143→    return topLosers;\n   144→  }\n   145→\n   146→  public void setSummaryDate(Date summaryDate) {\n   147→    this.summaryDate = summaryDate;\n   148→  }\n   149→\n   150→  public Date getSummaryDate() {\n   151→    return summaryDate;\n   152→  }\n   153→\n   154→  public void setGainPercent(BigDecimal gainPercent) {\n   155→    this.gainPercent = gainPercent.setScale(2,RoundingMode.HALF_UP);\n   156→  }\n   157→\n   158→  public BigDecimal getGainPercent() {\n   159→    return gainPercent;\n   160→  }\n   161→\n   162→  public String getGainPercentHTML() {\n   163→    return FinancialUtils.printGainPercentHTML(gainPercent);\n   164→  }\n   165→\n   166→}\n   167→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01HNigotk2PYvHiQCeqzmCWW","session_id":"40640270-7dba-44a6-9773-cfde29fa9f25","uuid":"9d9451e7-a882-4453-b28e-2f1f0259b156"}
