      this.orderFee = orderFee;\n   241→    }\n   242→\n   243→    public String getSymbol() {\n   244→        if (quote != null) {\n   245→            return quote.getSymbol();\n   246→        }\n   247→        return symbol;\n   248→    }\n   249→\n   250→    public void setSymbol(String symbol) {\n   251→        this.symbol = symbol;\n   252→    }\n   253→\n   254→    public AccountDataBean getAccount() {\n   255→        return account;\n   256→    }\n   257→\n   258→    public void setAccount(AccountDataBean account) {\n   259→        this.account = account;\n   260→    }\n   261→\n   262→    public QuoteDataBean getQuote() {\n   263→        return quote;\n   264→    }\n   265→\n   266→    public void setQuote(QuoteDataBean quote) {\n   267→        this.quote = quote;\n   268→    }\n   269→\n   270→    public HoldingDataBean getHolding() {\n   271→        return holding;\n   272→    }\n   273→\n   274→    public void setHolding(HoldingDataBean holding) {\n   275→        this.holding = holding;\n   276→    }\n   277→\n   278→    public boolean isBuy() {\n   279→        String orderType = getOrderType();\n   280→        if (orderType.compareToIgnoreCase(\"buy\") == 0) {\n   281→            return true;\n   282→        }\n   283→        return false;\n   284→    }\n   285→\n   286→    public boolean isSell() {\n   287→        String orderType = getOrderType();\n   288→        if (orderType.compareToIgnoreCase(\"sell\") == 0) {\n   289→            return true;\n   290→        }\n   291→        return false;\n   292→    }\n   293→\n   294→    public boolean isOpen() {\n   295→        String orderStatus = getOrderStatus();\n   296→        if ((orderStatus.compareToIgnoreCase(\"open\") == 0) || (orderStatus.compareToIgnoreCase(\"processing\") == 0)) {\n   297→            return true;\n   298→        }\n   299→        return false;\n   300→    }\n   301→\n   302→    public boolean isCompleted() {\n   303→        String orderStatus = getOrderStatus();\n   304→        if ((orderStatus.compareToIgnoreCase(\"completed\") == 0) || (orderStatus.compareToIgnoreCase(\"alertcompleted\") == 0)\n   305→                || (orderStatus.compareToIgnoreCase(\"cancelled\") == 0)) {\n   306→            return true;\n   307→        }\n   308→        return false;\n   309→    }\n   310→\n   311→    public boolean isCancelled() {\n   312→        String orderStatus = getOrderStatus();\n   313→        if (orderStatus.compareToIgnoreCase(\"cancelled\") == 0) {\n   314→            return true;\n   315→        }\n   316→        return false;\n   317→    }\n   318→\n   319→    public void cancel() {\n   320→        setOrderStatus(\"cancelled\");\n   321→    }\n   322→\n   323→    @Override\n   324→    public int hashCode() {\n   325→        int hash = 0;\n   326→        hash += (this.orderID != null ? this.orderID.hashCode() : 0);\n   327→        return hash;\n   328→    }\n   329→\n   330→    @Override\n   331→    public boolean equals(Object object) {\n   332→\n   333→        if (!(object instanceof OrderDataBean)) {\n   334→            return false;\n   335→        }\n   336→        OrderDataBean other = (OrderDataBean) object;\n   337→        if (this.orderID != other.orderID && (this.orderID == null || !this.orderID.equals(other.orderID))) {\n   338→            return false;\n   339→        }\n   340→        return true;\n   341→    }\n   342→}\n   343→"}]},"parent_tool_use_id":"toolu_bdrk_01UPUFVrPCXmmc5QZ5xD6j1Y","session_id":"ac4f36ad-05ed-4d27-a34f-96d57675074f","uuid":"6bbda697-c8c2-486a-8800-a2be0b9aaab5"}
