Bean quote;\n    82→\n    83→    public HoldingDataBean() {\n    84→    }\n    85→\n    86→    public HoldingDataBean(Integer holdingID, double quantity, BigDecimal purchasePrice, Date purchaseDate, String quoteID) {\n    87→        setHoldingID(holdingID);\n    88→        setQuantity(quantity);\n    89→        setPurchasePrice(purchasePrice);\n    90→        setPurchaseDate(purchaseDate);\n    91→        setQuoteID(quoteID);\n    92→    }\n    93→\n    94→    public HoldingDataBean(double quantity, BigDecimal purchasePrice, Date purchaseDate, AccountDataBean account, QuoteDataBean quote) {\n    95→        setQuantity(quantity);\n    96→        setPurchasePrice(purchasePrice);\n    97→        setPurchaseDate(purchaseDate);\n    98→        setAccount(account);\n    99→        setQuote(quote);\n   100→    }\n   101→\n   102→    public static HoldingDataBean getRandomInstance() {\n   103→        return new HoldingDataBean(new Integer(TradeConfig.rndInt(100000)), // holdingID\n   104→                TradeConfig.rndQuantity(), // quantity\n   105→                TradeConfig.rndBigDecimal(1000.0f), // purchasePrice\n   106→                new java.util.Date(TradeConfig.rndInt(Integer.MAX_VALUE)), // purchaseDate\n   107→                TradeConfig.rndSymbol() // symbol\n   108→        );\n   109→    }\n   110→\n   111→    @Override\n   112→    public String toString() {\n   113→        return \"\\n\\tHolding Data for holding: \" + getHoldingID() + \"\\n\\t\\t      quantity:\" + getQuantity() + \"\\n\\t\\t purchasePrice:\" + getPurchasePrice()\n   114→                + \"\\n\\t\\t  purchaseDate:\" + getPurchaseDate() + \"\\n\\t\\t       quoteID:\" + getQuoteID();\n   115→    }\n   116→\n   117→    public String toHTML() {\n   118→        return \"<BR>Holding Data for holding: \" + getHoldingID() + \"</B>\" + \"<LI>      quantity:\" + getQuantity() + \"</LI>\" + \"<LI> purchasePrice:\"\n   119→                + getPurchasePrice() + \"</LI>\" + \"<LI>  purchaseDate:\" + getP