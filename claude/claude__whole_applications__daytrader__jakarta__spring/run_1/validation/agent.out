.websphere.samples.daytrader.entities.QuoteDataBean;\n    35→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    36→import com.ibm.websphere.samples.daytrader.util.Log;\n    37→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    38→\n    39→@Component\n    40→public class MarketSummarySingleton {\n    41→\n    42→    private MarketSummaryDataBean marketSummaryDataBean;\n    43→\n    44→    @PersistenceContext\n    45→    private EntityManager entityManager;\n    46→\n    47→    /* Update Market Summary every 20 seconds */\n    48→    @Scheduled(fixedRate = 20000)\n    49→    @Transactional\n    50→    public void updateMarketSummary() {\n    51→\n    52→        Log.trace(\"MarketSummarySingleton:updateMarketSummary -- updating market summary\");\n    53→\n    54→        if (TradeConfig.getRunTimeMode() != TradeConfig.EJB3) {\n    55→            Log.trace(\"MarketSummarySingleton:updateMarketSummary -- Not EJB3 Mode, so not updating\");\n    56→            return; // Only do the actual work if in EJB3 Mode\n    57→        }\n    58→\n    59→        List<QuoteDataBean> quotes;\n    60→\n    61→        try {\n    62→            // Find Trade Stock Index Quotes (Top 100 quotes) ordered by their change in value\n    63→            CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n    64→            CriteriaQuery<QuoteDataBean> criteriaQuery = criteriaBuilder.createQuery(QuoteDataBean.class);\n    65→            Root<QuoteDataBean> quoteRoot = criteriaQuery.from(QuoteDataBean.class);\n    66→            criteriaQuery.orderBy(criteriaBuilder.desc(quoteRoot.get(\"change1\")));\n    67→            criteriaQuery.select(quoteRoot);\n    68→            TypedQuery<QuoteDataBean> q = entityManager.createQuery(criteriaQuery);\n    69→            quotes = q.getResultList();\n    70→        } catch (Exception e) {\n    71→            Log.debug(\"Warning: The database has not been configured. If this is the first time the application has been started, please create and populate the database tables. Then restart the server.\");\n    72→            return;\n    73→        }\n    74→\n    75→        /* TODO: Make this cleaner? */\n    76→        QuoteDataBean[] quoteArray = quotes.toArray(new QuoteDataBean[quotes.size()]);\n    77→        ArrayList<QuoteDataBean> topGainers = new ArrayList<QuoteDataBean>(5);\n    78→        ArrayList<QuoteDataBean> topLosers = new ArrayList<QuoteDataBean>(5);\n    79→        BigDecimal TSIA = FinancialUtils.ZERO;\n    80→        BigDecimal openTSIA = FinancialUtils.ZERO;\n    81→        double totalVolume = 0.0;\n    82→\n    83→        if (quoteArray.length > 5) {\n    84→            for (int i = 0; i < 5; i++) {\n    85→                topGainers.add(quoteArray[i]);\n    86→            }\n    87→            for (int i = quoteArray.length - 1; i >= quoteArray.length - 5; i--) {\n    88→                topLosers.add(quoteArray[i]);\n    89→            }\n    90→\n    91→            for (QuoteDataBean quote : quoteArray) {\n    92→                BigDecimal price = quote.getPrice();\n    93→                BigDecimal open = quote.getOpen();\n    94→                double volume = quote.getVolume();\n    95→                TSIA = TSIA.add(price);\n    96→                openTSIA = openTSIA.add(open);\n    97→                totalVolume += volume;\n    98→            }\n    99→            TSIA = TSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   100→            openTSIA = openTSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   101→        }\n   102→\n   103→        setMarketSummaryDataBean(new MarketSummaryDataBean(TSIA, openTSIA, totalVolume, topGainers, topLosers));\n   104→    }\n   105→\n   106→    public synchronized MarketSummaryDataBean getMarketSummaryDataBean() {\n   107→        if (marketSummaryDataBean == null) {\n   108→            updateMarketSummary();\n   109→        }\n   110→        return marketSummaryDataBean;\n   111→    }\n   112→\n   113→    public synchronized void setMarketSummaryDataBean(MarketSummaryDataBean marketSummaryDataBean) {\n   114→        this.marketSummaryDataBean = marketSummaryDataBean;\n   115→    }\n   116→}\n   117→"}]},"parent_tool_use_id":"toolu_bdrk_01XJv3rnsi5f8HH2xVLqJQwu","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"8f4141a7-101d-4bd6-877f-fe0cc9ffd649"}
