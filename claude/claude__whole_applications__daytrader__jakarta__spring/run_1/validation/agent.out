n    34→ * all configuration and runtime parameters for the Trade application\n    35→ *\n    36→ */\n    37→@WebServlet(name = \"TradeConfigServlet\", urlPatterns = { \"/config\" })\n    38→public class TradeConfigServlet extends HttpServlet {\n    39→\n    40→  private static final long serialVersionUID = -1910381529792500095L;\n    41→\n    42→  /**\n    43→   * Servlet initialization method.\n    44→   */\n    45→  @Override\n    46→  public void init(ServletConfig config) throws ServletException {\n    47→    super.init(config);\n    48→  }\n    49→\n    50→  /**\n    51→   * Create the TradeConfig bean and pass it the config.jsp page\n    52→   * to display the current Trade runtime configuration\n    53→   * Creation date: (2/8/2000 3:43:59 PM)\n    54→   */\n    55→  void doConfigDisplay(HttpServletRequest req, HttpServletResponse resp, String results) throws Exception {\n    56→\n    57→    TradeConfig currentConfig = new TradeConfig();\n    58→\n    59→    req.setAttribute(\"tradeConfig\", currentConfig);\n    60→    req.setAttribute(\"status\", results);\n    61→    getServletConfig().getServletContext().getRequestDispatcher(TradeConfig.getPage(TradeConfig.CONFIG_PAGE)).include(req, resp);\n    62→  }\n    63→\n    64→  /**\n    65→   * Update Trade runtime configuration paramaters\n    66→   * Creation date: (2/8/2000 3:44:24 PM)\n    67→   */\n    68→  void doConfigUpdate(HttpServletRequest req, HttpServletResponse resp) throws Exception {\n    69→    String currentConfigStr = \"\\n\\n########## Trade configuration update. Current config:\\n\\n\";\n    70→\n    71→    currentConfigStr += \"\\t\\tRuntimeMode:\\t\\t\" + TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()] + \"\\n\";\n    72→\n    73→    String orderProcessingModeStr = req.getParameter(\"OrderProcessingMode\");\n    74→    if (orderProcessingModeStr != null) {\n    75→      try {\n    76→        int i = Integer.parseInt(orderProcessingModeStr);\n    77→        if ((i >= 0) && (i < TradeConfig.getOrderProcessingModeNames().length)) //Input validation\n    78→          TradeConfig.setOrderProcessingMode(i);\n    79→      } catch (Exception e) {\n    80→        //>>rjm\n    81→        Log.error(e, \"TradeConfigServlet.doConfigUpdate(..): minor exception caught\", \"trying to set orderProcessing to \" + orderProcessingModeStr,\n    82→            \"reverting to current value\");\n    83→\n    84→      } // If the value is bad, simply revert to current\n    85→    }\n    86→    currentConfigStr += \"\\t\\tOrderProcessingMode:\\t\\t\" + TradeConfig.getOrderProcessingModeNames()[TradeConfig.getOrderProcessingMode()] + \"\\n\";\n    87→\n    88→    String webInterfaceStr = req.getParameter(\"WebInterface\");\n    89→    if (webInterfaceStr != null) {\n    90→      try {\n    91→        int i = Integer.parseInt(webInterfaceStr);\n    92→        if ((i >= 0) && (i < TradeConfig.getWebInterfaceNames().length)) //Input validation\n    93→          TradeConfig.setWebInterface(i);\n    94→      } catch (Exception e) {\n    95→        Log.error(e, \"TradeConfigServlet.doConfigUpdate(..): minor exception caught\", \"trying to set WebInterface to \" + webInterfaceStr,\n    96→            \"reverting to current value\");\n    97→\n    98→      } // If the value is bad, simply revert to current\n    99→    }\n   100→    currentConfigStr += \"\\t\\tWeb Interface:\\t\\t\\t\" + TradeConfig.getWebInterfaceNames()[TradeConfig.getWebInterface()] + \"\\n\";\n   101→\n   102→    String parm = req.getParameter(\"MaxUsers\");\n   103→    if ((parm != null) && (parm.length() > 0)) {\n   104→      try {\n   105→        TradeConfig.setMAX_USERS(Integer.parseInt(parm));\n   106→      } catch (Exception e) {\n   107→        Log.error(e, \"TradeConfigServlet.doConfigUpdate(..): minor exception caught\", \"Setting maxusers, probably error parsing string to int:\" + parm,\n   108→            \"revertying to current value: \" + TradeConfig.getMAX_USERS());\n   109→\n   110→      } //On error, revert to saved\n   111→    }\n   112→    parm = req.getParameter(\"MaxQuotes\");\n   113→    if ((parm != null) && (parm.length() > 0)) {\n   114→      try {\n   115→        TradeConfig.setMAX_QUOTES(Integer.parseInt(parm));\n   116→      } catch (Exception e) {\n   117→        //>>rjm\n   118→        Log.error(e, \"TradeConfigServlet: minor exception caught\", \"trying to set max_quotes, error on parsing int \" + parm,\n   119→            \"reverting to current value \" + TradeConfig.getMAX_QUOTES());\n   120→        //<<rjm\n   121→\n   122→      } //On error, revert to saved\n   123→    }\n   124→    currentConfigStr += \"\\t\\tTrade Users:\\t\\t\\t\" + TradeConfig.getMAX_USERS() + \"\\n\";\n   125→    currentConfigStr += \"\\t\\tTrade Quotes:\\t\\t\\t\" + TradeConfig.getMAX_QUOTES() + \"\\n\";\n   126→\n   127→    parm = req.getParameter(\"marketSummaryInterval\");\n   128→    if ((parm != null) && (parm.length() > 0)) {\n   129→      try {\n   130→        TradeConfig.setMarketSummaryInterval(Integer.parseInt(parm));\n   131→      } catch (Exception e) {\n   132→        Log.error(e, \"TradeConfigServlet: minor exception caught\", \"trying to set marketSummaryInterval, error on parsing int \" + parm,\n   133→            \"reverting to current value \" + TradeConfig.getMarketSummaryInterval());\n   134→\n   135→      }\n   136→    }\n   137→    currentConfigStr += \"\\t\\tMarket Summary Interval:\\t\" + TradeConfig.getMarketSummaryInterval() + \"\\n\";\n   138→\n   139→    parm = req.getParameter(\"primIterations\");\n   140→    if ((parm != null) && (parm.length() > 0)) {\n   141→      try {\n   142→        TradeConfig.setPrimIterations(Integer.parseInt(parm));\n   143→      } catch (Exception e) {\n   144→        Log.error(e, \"TradeConfigServlet: minor exception caught\", \"trying to set primIterations, error on parsing int \" + parm,\n   145→            \"reverting to current value \" + TradeConfig.getPrimIterations());\n   146→\n   147→      }\n   148→    }\n   149→    currentConfigStr += \"\\t\\tPrimitive Iterations:\\t\\t\" + TradeConfig.getPrimIterations() + \"\\n\";\n   150→\n   151→    String enablePublishQuotePriceChange = req.getParameter(\"EnablePublishQuotePriceChange\");\n   152→\n   153→    if (enablePublishQuotePriceChange != null)\n   154→      TradeConfig.setPublishQuotePriceChange(true);\n   155→    else\n   156→      TradeConfig.setPublishQuotePriceChange(false);\n   157→    currentConfigStr += \"\\t\\tTradeStreamer MDB Enabled:\\t\" + TradeConfig.getPublishQuotePriceChange() + \"\\n\";\n   158→\n   159→    parm = req.getParameter(\"ListQuotePriceChangeFrequency\");\n   160→    if ((parm != null) && (parm.length() > 0)) {\n   161→      try {\n   162→        TradeConfig.setListQuotePriceChangeFrequency(Integer.parseInt(parm));\n   163→      } catch (Exception e) {\n   164→        Log.error(e, \"TradeConfigServlet: minor exception caught\", \"trying to set percentSentToWebSocket, error on parsing int \" + parm,\n   165→            \"reverting to current value \" + TradeConfig.getListQuotePriceChangeFrequency());\n   166→\n   167→      }\n   168→    }\n   169→    currentConfigStr += \"\\t\\t% of trades on Websocket:\\t\" + TradeConfig.getListQuotePriceChangeFrequency() + \"\\n\";\n   170→\n   171→    String enableLongRun = req.getParameter(\"EnableLongRun\");\n   172→\n   173→    if (enableLongRun != null)\n   174→      TradeConfig.setLongRun(true);\n   175→    else\n   176→      TradeConfig.setLongRun(false);\n   177→    currentConfigStr += \"\\t\\tLong Run Enabled:\\t\\t\" + TradeConfig.getLongRun() + \"\\n\";\n   178→\n   179→    String displayOrderAlerts = req.getParameter(\"DisplayOrderAlerts\");\n   180→\n   181→    if (displayOrderAlerts != null)\n   182→      TradeConfig.setDisplayOrderAlerts(true);\n   183→    else\n   184→      TradeConfig.setDisplayOrderAlerts(false);\n   185→    currentConfigStr += \"\\t\\tDisplay Order Alerts:\\t\\t\" + TradeConfig.getDisplayOrderAlerts() + \"\\n\";\n   186→\n   187→    System.out.println(currentConfigStr);\n   188→  }\n   189→\n   190→  @Override\n   191→  public void service(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n   192→\n   193→    String action = null;\n   194→    String result = \"\";\n   195→\n   196→    resp.setContentType(\"text/html\");\n   197→    try {\n   198→      action = req.getParameter(\"action\");\n   199→      if (action == null) {\n   200→        doConfigDisplay(req, resp, result + \"<b><br>Current DayTrader Configuration:</br></b>\");\n   201→        return;\n   202→      } else if (action.equals(\"updateConfig\")) {\n   203→        doConfigUpdate(req, resp);\n   204→        result = \"<B><BR>DayTrader Configuration Updated</BR></B>\";\n   205→      }\n   206→      doConfigDisplay(req, resp, result + \"Current DayTrader Configuration:\");\n   207→    } catch (Exception e) {\n   208→      Log.error(e, \"TradeConfigServlet.service(...)\", \"Exception trying to perform action=\" + action);\n   209→\n   210→      resp.sendError(500, \"TradeConfigServlet.service(...)\" + \"Exception trying to perform action=\" + action + \"\\nException details: \" + e.toString());\n   211→\n   212→    }\n   213→  }\n   214→}\n   215→"}]},"parent_tool_use_id":"toolu_bdrk_012cytam7rdytdbG3QvQJjiy","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"e4e1289d-27df-4bd5-a10d-a55fe162ba78"}
