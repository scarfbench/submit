{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01ReFEisQRtRjozgjgsTf2pB","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.util;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.ArrayList;\n    20→import java.util.Random;\n    21→\n    22→/**\n    23→ * TradeConfig is a JavaBean holding all configuration and runtime parameters\n    24→ * for the Trade application TradeConfig sets runtime parameters such as the\n    25→ * RunTimeMode (EJB, JDBC, EJB_ALT)\n    26→ *\n    27→ */\n    28→\n    29→public class TradeConfig {\n    30→\n    31→  /* Trade Runtime Configuration Parameters */\n    32→\n    33→  /* Trade Runtime Mode parameters */\n    34→  private static String[] runTimeModeNames = { \"Full EJB3\", \"Direct (JDBC)\", \"Session to Direct\"};\n    35→  public static final int EJB3 = 0;\n    36→  public static final int DIRECT = 1;\n    37→  public static final int SESSION_TO_DIRECT = 2;\n    38→  private static int runTimeMode = EJB3;\n    39→\n    40→  private static String[] orderProcessingModeNames = { \"Sync\", \"Async\",\"Async_2-Phase\" };\n    41→  public static final int SYNCH = 0;\n    42→  public static final int ASYNCH = 1;\n    43→  public static final int ASYNCH_2PHASE = 2;\n    44→  private static int orderProcessingMode = SYNCH;\n    45→\n    46→  private static String[] accessModeNames = { \"Standard\", \"WebServices\" };\n    47→  public static final int STANDARD = 0;\n    48→  private static int accessMode = STANDARD;\n    49→\n    50→  /* Trade Web Interface parameters */\n    51→  private static String[] webInterfaceNames = { \"JSP\", \"JSP-Images\", \"JSP-Images-Http2\" };\n    52→  public static final int JSP = 0;\n    53→  public static final int JSP_Images = 1;\n    54→  public static final int JSP_Images_HTTP2 = 2;\n    55→  private static int webInterface = JSP;\n    56→\n    57→  /* Trade Database Scaling parameters */\n    58→  private static int MAX_USERS = 15000;\n    59→  private static int MAX_QUOTES = 10000;\n    60→\n    61→  \n    62→  /* Trade XA Datasource specific parameters */\n    63→  public static boolean JDBCDriverNeedsGlobalTransation = false;\n    64→\n    65→  /* Trade Config Miscellaneous itmes */\n    66→  public static String DATASOURCE = \"java:comp/env/jdbc/TradeDataSource\";\n    67→  public static int KEYBLOCKSIZE = 1000;\n    68→  public static int QUOTES_PER_PAGE = 10;\n    69→  public static boolean RND_USER = true;\n    70→  // public static int RND_SEED = 0;\n    71→  private static int MAX_HOLDINGS = 10;\n    72→  private static int count = 0;\n    73→  private static Object userID_count_semaphore = new Object();\n    74→  private static int userID_count = 0;\n    75→  private static String hostName = null;\n    76→  private static Random r0 = new Random(System.currentTimeMillis());\n    77→  // private static Random r1 = new Random(RND_SEED);\n    78→  private static Random randomNumberGenerator = r0;\n    79→  public static final String newUserPrefix = \"ru:\";\n    80→  public static final int verifyPercent = 5;\n    81→  private static boolean updateQuotePrices = true;\n    82→  private static int primIterations = 1;\n    83→  private static boolean longRun = true;\n    84→  private static boolean publishQuotePriceChange = true;\n    85→  private static int listQuotePriceChangeFrequency = 100;\n    86→  private static boolean displayOrderAlerts = true;\n    87→\n    88→  /**\n    89→   * -1 means every operation 0 means never perform a market summary > 0 means\n    90→   * number of seconds between summaries. These will be synchronized so only\n    91→   * one transaction in this period will create a summary and will cache its\n    92→   * results.\n    93→   */\n    94→  private static int marketSummaryInterval = 20;\n    95→\n    96→  /*\n    97→   * Penny stocks is a problem where the random price change factor gets a\n    98→   * stock down to $.01. In this case trade jumpstarts the price back to $6.00\n    99→   * to keep the math interesting.\n   100→   */\n   101→  public static BigDecimal PENNY_STOCK_PRICE;\n   102→  public static BigDecimal PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   103→  static {\n   104→    PENNY_STOCK_PRICE = new BigDecimal(0.01);\n   105→    PENNY_STOCK_PRICE = PENNY_STOCK_PRICE.setScale(2, BigDecimal.ROUND_HALF_UP);\n   106→    PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER = new BigDecimal(600.0);\n   107→    PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER.setScale(2, BigDecimal.ROUND_HALF_UP);\n   108→  }\n   109→\n   110→  /*\n   111→   * CJB (DAYTRADER-25) - Also need to impose a ceiling on the quote price to\n   112→   * ensure prevent account and holding balances from exceeding the databases\n   113→   * decimal precision. At some point, this maximum value can be used to\n   114→   * trigger a stock split.\n   115→   */\n   116→\n   117→  public static BigDecimal MAXIMUM_STOCK_PRICE;\n   118→  public static BigDecimal MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   119→  static {\n   120→    MAXIMUM_STOCK_PRICE = new BigDecimal(400);\n   121→    MAXIMUM_STOCK_PRICE.setScale(2, BigDecimal.ROUND_HALF_UP);\n   122→    MAXIMUM_STOCK_SPLIT_MULTIPLIER = new BigDecimal(0.5);\n   123→    MAXIMUM_STOCK_SPLIT_MULTIPLIER.setScale(2, BigDecimal.ROUND_HALF_UP);\n   124→  }\n   125→\n   126→  /*\n   127→   * Trade Scenario actions mixes. Each of the array rows represents a\n   128→   * specific Trade Scenario Mix. The columns give the percentages for each\n   129→   * action in the column header. Note: \"login\" is always 0. logout represents\n   130→   * both login and logout (because each logout operation will cause a new\n   131→   * login when the user context attempts the next action.\n   132→   */\n   133→  /* Trade Scenario Workload parameters */\n   134→  public static final int HOME_OP = 0;\n   135→  public static final int QUOTE_OP = 1;\n   136→  public static final int LOGIN_OP = 2;\n   137→  public static final int LOGOUT_OP = 3;\n   138→  public static final int REGISTER_OP = 4;\n   139→  public static final int ACCOUNT_OP = 5;\n   140→  public static final int PORTFOLIO_OP = 6;\n   141→  public static final int BUY_OP = 7;\n   142→  public static final int SELL_OP = 8;\n   143→  public static final int UPDATEACCOUNT_OP = 9;\n   144→\n   145→  private static int[][] scenarioMixes = {\n   146→      // h q l o r a p b s u\n   147→      { 20, 40, 0, 4, 2, 10, 12, 4, 4, 4 }, // STANDARD\n   148→      { 20, 40, 0, 4, 2, 7, 7, 7, 7, 6 }, // High Volume\n   149→  };\n   150→  private static char[] actions = { 'h', 'q', 'l', 'o', 'r', 'a', 'p', 'b', 's', 'u' };\n   151→  private static int sellDeficit = 0;\n   152→  // Tracks the number of buys over sell when a users portfolio is empty\n   153→  // Used to maintain the correct ratio of buys/sells\n   154→\n   155→  /* JSP pages for all Trade Actions */\n   156→\n   157→  public static final int WELCOME_PAGE = 0;\n   158→  public static final int REGISTER_PAGE = 1;\n   159→  public static final int PORTFOLIO_PAGE = 2;\n   160→  public static final int QUOTE_PAGE = 3;\n   161→  public static final int HOME_PAGE = 4;\n   162→  public static final int ACCOUNT_PAGE = 5;\n   163→  public static final int ORDER_PAGE = 6;\n   164→  public static final int CONFIG_PAGE = 7;\n   165→  public static final int STATS_PAGE = 8;\n   166→  public static final int MARKET_SUMMARY_PAGE = 9;\n   167→\n   168→  // FUTURE Add XML/XSL View\n   169→  public static String[][] webUI = {\n   170→      { \"/welcome.jsp\", \"/register.jsp\", \"/portfolio.jsp\", \"/quote.jsp\", \"/tradehome.jsp\", \"/account.jsp\", \"/order.jsp\", \"/config.jsp\", \"/runStats.jsp\",\n   171→      \"/marketSummary.jsp\" },\n   172→      // JSP Interface\n   173→      { \"/welcomeImg.jsp\", \"/registerImg.jsp\", \"/portfolioImg.jsp\", \"/quoteImg.jsp\", \"/tradehomeImg.jsp\", \"/accountImg.jsp\", \"/orderImg.jsp\",\n   174→        \"/config.jsp\", \"/runStats.jsp\", \"/marketSummary.jsp\" },\n   175→      // JSP Interface\n   176→      { \"/welcomeImg.jsp\", \"/registerImg.jsp\", \"/portfolioImg.jsp\", \"/quoteImg.jsp\", \"/tradehomeImg.jsp\", \"/accountImg.jsp\", \"/orderImg.jsp\",\n   177→          \"/config.jsp\", \"/runStats.jsp\", \"/marketSummary.jsp\" },\n   178→  };\n   179→\n   180→\n   181→  /**\n   182→   * Return the hostname for this system Creation date: (2/16/2000 9:02:25 PM)\n   183→   */\n   184→\n   185→  private static String getHostname() {\n   186→    try {\n   187→      if (hostName == null) {\n   188→        hostName = java.net.InetAddress.getLocalHost().getHostName();\n   189→        // Strip of fully qualifed domain if necessary\n   190→        try {\n   191→          hostName = hostName.substring(0, hostName.indexOf('.'));\n   192→        } catch (Exception e) {\n   193→        }\n   194→      }\n   195→    } catch (Exception e) {\n   196→      Log.error(\"Exception getting local host name using 'localhost' - \", e);\n   197→      hostName = \"localhost\";\n   198→    }\n   199→    return hostName;\n   200→  }\n   201→\n   202→  /**\n   203→   * Return a Trade UI Web page based on the current configuration This may\n   204→   * return a JSP page or a Servlet page Creation date: (3/14/2000 9:08:34 PM)\n   205→   */\n   206→\n   207→  public static String getPage(int pageNumber) {\n   208→    return webUI[webInterface][pageNumber];\n   209→  }\n   210→\n   211→  /**\n   212→   * Return the list of run time mode names Creation date: (3/8/2000 5:58:34\n   213→   * PM)\n   214→   *\n   215→   * @return java.lang.String[]\n   216→   */\n   217→  public static java.lang.String[] getRunTimeModeNames() {\n   218→    return runTimeModeNames;\n   219→  }\n   220→\n   221→  private static int scenarioCount = 0;\n   222→\n   223→  /**\n   224→   * Return a Trade Scenario Operation based on the setting of the current mix\n   225→   * (TradeScenarioMix) Creation date: (2/10/2000 9:08:34 PM)\n   226→   */\n   227→\n   228→  public static char getScenarioAction(boolean newUser) {\n   229→    int r = rndInt(100); // 0 to 99 = 100\n   230→    int i = 0;\n   231→    int sum = scenarioMixes[0][i];\n   232→    while (sum <= r) {\n   233→      i++;\n   234→      sum += scenarioMixes[0][i];\n   235→    }\n   236→\n   237→    incrementScenarioCount();\n   238→\n   239→    /*\n   240→     * In TradeScenarioServlet, if a sell action is selected, but the users\n   241→     * portfolio is empty, a buy is executed instead and sellDefecit is\n   242→     * incremented. This allows the number of buy/sell operations to stay in\n   243→     * sync w/ the given Trade mix.\n   244→     */\n   245→\n   246→    if ((!newUser) && (actions[i] == 'b')) {\n   247→      synchronized (TradeConfig.class) {\n   248→        if (sellDeficit > 0) {\n   249→          sellDeficit--;\n   250→          return 's';\n   251→          // Special case for TradeScenarioServlet to note this is a\n   252→          // buy switched to a sell to fix sellDeficit\n   253→        }\n   254→      }\n   255→    }\n   256→\n   257→    return actions[i];\n   258→  }\n   259→\n   260→  public static String getUserID() {\n   261→    String userID;\n   262→    if (RND_USER) {\n   263→      userID = rndUserID();\n   264→    } else {\n   265→      userID = nextUserID();\n   266→    }\n   267→    return userID;\n   268→  }\n   269→\n   270→  private static final BigDecimal orderFee = new BigDecimal(\"24.95\");\n   271→  private static final BigDecimal cashFee = new BigDecimal(\"0.0\");\n   272→\n   273→  public static BigDecimal getOrderFee(String orderType) {\n   274→    if ((orderType.compareToIgnoreCase(\"BUY\") == 0) || (orderType.compareToIgnoreCase(\"SELL\") == 0)) {\n   275→      return orderFee;\n   276→    }\n   277→\n   278→    return cashFee;\n   279→\n   280→  }\n   281→\n   282→  /**\n   283→   * Increment the sell deficit counter Creation date: (6/21/2000 11:33:45 AM)\n   284→   */\n   285→  public static synchronized void incrementSellDeficit() {\n   286→    sellDeficit++;\n   287→  }\n   288→\n   289→  public static String nextUserID() {\n   290→    String userID;\n   291→    synchronized (userID_count_semaphore) {\n   292→      userID = \"uid:\" + userID_count;\n   293→      userID_count++;\n   294→      if (userID_count % MAX_USERS == 0) {\n   295→        userID_count = 0;\n   296→      }\n   297→    }\n   298→    return userID;\n   299→  }\n   300→\n   301→  public static double random() {\n   302→    return randomNumberGenerator.nextDouble();\n   303→  }\n   304→\n   305→  public static String rndAddress() {\n   306→    return rndInt(1000) + \" Oak St.\";\n   307→  }\n   308→\n   309→  public static String rndBalance() {\n   310→    // Give all new users a cool mill in which to trade\n   311→    return \"1000000\";\n   312→  }\n   313→\n   314→  public static String rndCreditCard() {\n   315→    return rndInt(100) + \"-\" + rndInt(1000) + \"-\" + rndInt(1000) + \"-\" + rndInt(1000);\n   316→  }\n   317→\n   318→  public static String rndEmail(String userID) {\n   319→    return userID.replace(\":\", \"\") + \"@\" + rndInt(100) + \".com\";\n   320→  }\n   321→\n   322→  public static String rndFullName() {\n   323→    return \"first:\" + rndInt(1000) + \" last:\" + rndInt(5000);\n   324→  }\n   325→\n   326→  public static int rndInt(int i) {\n   327→    return (new Float(random() * i)).intValue();\n   328→  }\n   329→\n   330→  public static float rndFloat(int i) {\n   331→    return (new Float(random() * i)).floatValue();\n   332→  }\n   333→\n   334→  public static BigDecimal rndBigDecimal(float f) {\n   335→    return (new BigDecimal(random() * f)).setScale(2, BigDecimal.ROUND_HALF_UP);\n   336→  }\n   337→\n   338→  public static boolean rndBoolean() {\n   339→    return randomNumberGenerator.nextBoolean();\n   340→  }\n   341→\n   342→  /**\n   343→   * Returns a new Trade user Creation date: (2/16/2000 8:50:35 PM)\n   344→   */\n   345→  public static synchronized String rndNewUserID() {\n   346→\n   347→    return newUserPrefix + getHostname() + System.currentTimeMillis() + count++;\n   348→  }\n   349→\n   350→  public static float rndPrice() {\n   351→    return ((new Integer(rndInt(200))).floatValue()) + 1.0f;\n   352→  }\n   353→\n   354→  private static final BigDecimal ONE = new BigDecimal(1.0);\n   355→\n   356→  public static BigDecimal getRandomPriceChangeFactor() {\n   357→    // CJB (DAYTRADER-25) - Vary change factor between 1.1 and 0.9\n   358→    double percentGain = rndFloat(1) * 0.1;\n   359→    if (random() < .5) {\n   360→      percentGain *= -1;\n   361→    }\n   362→    percentGain += 1;\n   363→\n   364→    // change factor is between +/- 20%\n   365→    BigDecimal percentGainBD = (new BigDecimal(percentGain)).setScale(2, BigDecimal.ROUND_HALF_UP);\n   366→    if (percentGainBD.doubleValue() <= 0.0) {\n   367→      percentGainBD = ONE;\n   368→    }\n   369→\n   370→    return percentGainBD;\n   371→  }\n   372→\n   373→  public static float rndQuantity() {\n   374→    return ((new Integer(rndInt(200))).floatValue()) + 1.0f;\n   375→  }\n   376→\n   377→  public static String rndSymbol() {\n   378→    return \"s:\" + rndInt(MAX_QUOTES - 1);\n   379→  }\n   380→\n   381→  public static String rndSymbols() {\n   382→\n   383→    String symbols = \"\";\n   384→    int num_symbols = rndInt(QUOTES_PER_PAGE);\n   385→\n   386→    for (int i = 0; i <= num_symbols; i++) {\n   387→      symbols += \"s:\" + rndInt(MAX_QUOTES - 1);\n   388→      if (i < num_symbols) {\n   389→        symbols += \",\";\n   390→      }\n   391→    }\n   392→    return symbols;\n   393→  }\n   394→\n   395→  public static String rndUserID() {\n   396→    String nextUser = getNextUserIDFromDeck();\n   397→\n   398→    Log.trace(\"TradeConfig:rndUserID -- new trader = \" + nextUser);\n   399→\n   400→\n   401→    return nextUser;\n   402→  }\n   403→\n   404→  private static synchronized String getNextUserIDFromDeck() {\n   405→    int numUsers = getMAX_USERS();\n   406→    if (deck == null) {\n   407→      deck = new ArrayList<Integer>(numUsers);\n   408→      for (int i = 0; i < numUsers; i++) {\n   409→        deck.add(i, new Integer(i));\n   410→      }\n   411→      java.util.Collections.shuffle(deck, r0);\n   412→    }\n   413→    if (card >= numUsers) {\n   414→      card = 0;\n   415→    }\n   416→    return \"uid:\" + deck.get(card++);\n   417→\n   418→  }\n   419→\n   420→  // Trade implements a card deck approach to selecting\n   421→  // users for trading with tradescenarioservlet\n   422→  private static ArrayList<Integer> deck = null;\n   423→  private static int card = 0;\n   424→\n   425→  /**\n   426→   * This is a convenience method for servlets to set Trade configuration\n   427→   * parameters from servlet initialization parameters. The servlet provides\n   428→   * the init param and its value as strings. This method then parses the\n   429→   * parameter, converts the value to the correct type and sets the\n   430→   * corresponding TradeConfig parameter to the converted value\n   431→   *\n   432→   */\n   433→  public static void setConfigParam(String parm, String value) {\n   434→    Log.log(\"TradeConfig setting parameter: \" + parm + \"=\" + value);\n   435→    // Compare the parm value to valid TradeConfig parameters that can be\n   436→    // set\n   437→    // by servlet initialization\n   438→\n   439→    // First check the proposed new parm and value - if empty or null ignore\n   440→    // it\n   441→    if (parm == null) {\n   442→      return;\n   443→    }\n   444→    parm = parm.trim();\n   445→    if (parm.length() <= 0) {\n   446→      return;\n   447→    }\n   448→    if (value == null) {\n   449→      return;\n   450→    }\n   451→    value = value.trim();\n   452→\n   453→    if (parm.equalsIgnoreCase(\"orderProcessingMode\")) {\n   454→      try {\n   455→        for (int i = 0; i < orderProcessingModeNames.length; i++) {\n   456→          if (value.equalsIgnoreCase(orderProcessingModeNames[i])) {\n   457→            orderProcessingMode = i;\n   458→            break;\n   459→          }\n   460→        }\n   461→      } catch (Exception e) {\n   462→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set orderProcessingMode to \" + value\n   463→            + \"reverting to current value: \" + orderProcessingModeNames[orderProcessingMode], e);\n   464→      } // If the value is bad, simply revert to current\n   465→    } else if (parm.equalsIgnoreCase(\"accessMode\")) {\n   466→      try {\n   467→        for (int i = 0; i < accessModeNames.length; i++) {\n   468→          if (value.equalsIgnoreCase(accessModeNames[i])) {\n   469→            accessMode = i;\n   470→            break;\n   471→          }\n   472→        }\n   473→      } catch (Exception e) {\n   474→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set accessMode to \" + value + \"reverting to current value: \"\n   475→            + accessModeNames[accessMode], e);\n   476→      }\n   477→    } else if (parm.equalsIgnoreCase(\"WebInterface\")) {\n   478→      try {\n   479→        for (int i = 0; i < webInterfaceNames.length; i++) {\n   480→          if (value.equalsIgnoreCase(webInterfaceNames[i])) {\n   481→            webInterface = i;\n   482→            break;\n   483→          }\n   484→        }\n   485→      } catch (Exception e) {\n   486→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"trying to set WebInterface to \" + value + \"reverting to current value: \"\n   487→            + webInterfaceNames[webInterface], e);\n   488→\n   489→      } // If the value is bad, simply revert to current\n   490→    } else if (parm.equalsIgnoreCase(\"maxUsers\")) {\n   491→      try {\n   492→        MAX_USERS = Integer.parseInt(value);\n   493→      } catch (Exception e) {\n   494→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"Setting maxusers, error parsing string to int:\" + value\n   495→            + \"revering to current value: \" + MAX_USERS, e);\n   496→      } // On error, revert to saved\n   497→    } else if (parm.equalsIgnoreCase(\"maxQuotes\")) {\n   498→      try {\n   499→        MAX_QUOTES = Integer.parseInt(value);\n   500→      } catch (Exception e) {\n   501→        // >>rjm\n   502→        Log.error(\"TradeConfig.setConfigParm(...) minor exception caught\" + \"Setting max_quotes, error parsing string to int \" + value\n   503→            + \"reverting to current value: \" + MAX_QUOTES, e);\n   504→        // <<rjm\n   505→      } // On error, revert to saved\n   506→    } else if (parm.equalsIgnoreCase(\"primIterations\")) {\n   507→      try {\n   508→        primIterations = Integer.parseInt(value);\n   509→      } catch (Exception e) {\n   510→        Log.error(\"TradeConfig.setConfigParm(..): minor exception caught\" + \"Setting primIterations, error parsing string to int:\" + value\n   511→            + \"revering to current value: \" + primIterations, e);\n   512→      } // On error, revert to saved\n   513→    } \n   514→  }\n   515→\n   516→  /**\n   517→   * Gets the orderProcessingModeNames\n   518→   *\n   519→   * @return Returns a String[]\n   520→   */\n   521→  public static String[] getOrderProcessingModeNames() {\n   522→    return orderProcessingModeNames;\n   523→  }\n   524→\n   525→  /**\n   526→   * Gets the webInterfaceNames\n   527→   *\n   528→   * @return Returns a String[]\n   529→   */\n   530→  public static String[] getWebInterfaceNames() {\n   531→    return webInterfaceNames;\n   532→  }\n   533→\n   534→  /**\n   535→   * Gets the webInterfaceNames\n   536→   *\n   537→   * @return Returns a String[]\n   538→   */\n   539→  /*public static String[] getCachingTypeNames() {\n   540→        return cachingTypeNames;\n   541→    }*/\n   542→\n   543→  /**\n   544→   * Gets the scenarioMixes\n   545→   *\n   546→   * @return Returns a int[][]\n   547→   */\n   548→  public static int[][] getScenarioMixes() {\n   549→    return scenarioMixes;\n   550→  }\n   551→\n   552→  /**\n   553→   * Gets the mAX_USERS.\n   554→   *\n   555→   * @return Returns a int\n   556→   */\n   557→  public static int getMAX_USERS() {\n   558→    return MAX_USERS;\n   559→  }\n   560→\n   561→  /**\n   562→   * Sets the mAX_USERS.\n   563→   *\n   564→   * @param mAX_USERS\n   565→   *            The mAX_USERS to set\n   566→   */\n   567→  public static void setMAX_USERS(int mAX_USERS) {\n   568→    MAX_USERS = mAX_USERS;\n   569→    deck = null; // reset the card deck for selecting users\n   570→  }\n   571→\n   572→  /**\n   573→   * Gets the mAX_QUOTES.\n   574→   *\n   575→   * @return Returns a int\n   576→   */\n   577→  public static int getMAX_QUOTES() {\n   578→    return MAX_QUOTES;\n   579→  }\n   580→\n   581→  /**\n   582→   * Sets the mAX_QUOTES.\n   583→   *\n   584→   * @param mAX_QUOTES\n   585→   *            The mAX_QUOTES to set\n   586→   */\n   587→  public static void setMAX_QUOTES(int mAX_QUOTES) {\n   588→    MAX_QUOTES = mAX_QUOTES;\n   589→  }\n   590→\n   591→  /**\n   592→   * Gets the mAX_HOLDINGS.\n   593→   *\n   594→   * @return Returns a int\n   595→   */\n   596→  public static int getMAX_HOLDINGS() {\n   597→    return MAX_HOLDINGS;\n   598→  }\n   599→\n   600→  /**\n   601→   * Sets the mAX_HOLDINGS.\n   602→   *\n   603→   * @param mAX_HOLDINGS\n   604→   *            The mAX_HOLDINGS to set\n   605→   */\n   606→  public static void setMAX_HOLDINGS(int mAX_HOLDINGS) {\n   607→    MAX_HOLDINGS = mAX_HOLDINGS;\n   608→  }\n   609→\n   610→  /**\n   611→   * Gets the scenarioCount.\n   612→   *\n   613→   * @return Returns a int\n   614→   */\n   615→  public static int getScenarioCount() {\n   616→    return scenarioCount;\n   617→  }\n   618→\n   619→  /**\n   620→   * Sets the scenarioCount.\n   621→   *\n   622→   * @param scenarioCount\n   623→   *            The scenarioCount to set\n   624→   */\n   625→  public static void setScenarioCount(int scenarioCount) {\n   626→    TradeConfig.scenarioCount = scenarioCount;\n   627→  }\n   628→\n   629→  public static synchronized void incrementScenarioCount() {\n   630→    scenarioCount++;\n   631→  }\n   632→\n   633→  /**\n   634→   * Gets the jdbc driver needs global transaction Some XA Drivers require a\n   635→   * global transaction to be started for all SQL calls. To work around this,\n   636→   * set this to true to cause the direct mode to start a user transaction.\n   637→   *\n   638→   * @return Returns a boolean\n   639→   */\n   640→  public static boolean getJDBCDriverNeedsGlobalTransation() {\n   641→    return JDBCDriverNeedsGlobalTransation;\n   642→  }\n   643→\n   644→  /**\n   645→   * Sets the jdbc driver needs global transaction\n   646→   *\n   647→   * @param JDBCDriverNeedsGlobalTransationVal\n   648→   *            the value\n   649→   */\n   650→  public static void setJDBCDriverNeedsGlobalTransation(boolean JDBCDriverNeedsGlobalTransationVal) {\n   651→    JDBCDriverNeedsGlobalTransation = JDBCDriverNeedsGlobalTransationVal;\n   652→  }\n   653→\n   654→  /**\n   655→   * Gets the updateQuotePrices.\n   656→   *\n   657→   * @return Returns a boolean\n   658→   */\n   659→  public static boolean getUpdateQuotePrices() {\n   660→    return updateQuotePrices;\n   661→  }\n   662→\n   663→  /**\n   664→   * Sets the updateQuotePrices.\n   665→   *\n   666→   * @param updateQuotePrices\n   667→   *            The updateQuotePrices to set\n   668→   */\n   669→  public static void setUpdateQuotePrices(boolean updateQuotePrices) {\n   670→    TradeConfig.updateQuotePrices = updateQuotePrices;\n   671→  }\n   672→\n   673→  public static int getPrimIterations() {\n   674→    return primIterations;\n   675→  }\n   676→\n   677→  public static void setPrimIterations(int iter) {\n   678→    primIterations = iter;\n   679→  }\n   680→\n   681→  public static boolean getLongRun() {\n   682→    return longRun;\n   683→  }\n   684→\n   685→  public static void setLongRun(boolean longRun) {\n   686→    TradeConfig.longRun = longRun;\n   687→  }\n   688→\n   689→  public static void setPublishQuotePriceChange(boolean publishQuotePriceChange) {\n   690→    TradeConfig.publishQuotePriceChange = publishQuotePriceChange;\n   691→  }\n   692→\n   693→  public static boolean getPublishQuotePriceChange() {\n   694→    return publishQuotePriceChange;\n   695→  }\n   696→\n   697→  public static void setMarketSummaryInterval(int seconds) {\n   698→    TradeConfig.marketSummaryInterval = seconds;\n   699→  }\n   700→\n   701→  public static int getMarketSummaryInterval() {\n   702→    return TradeConfig.marketSummaryInterval;\n   703→  }\n   704→\n   705→  public static void setRunTimeMode(int value) {\n   706→    runTimeMode = value;\n   707→  }\n   708→\n   709→  public static int getRunTimeMode() {\n   710→    return runTimeMode;\n   711→  }\n   712→\n   713→  public static void setOrderProcessingMode(int value) {\n   714→    orderProcessingMode = value;\n   715→  }\n   716→\n   717→  public static int getOrderProcessingMode() {\n   718→    return orderProcessingMode;\n   719→  }\n   720→\n   721→  public static void setAccessMode(int value) {\n   722→    accessMode = value;\n   723→  }\n   724→\n   725→  public static int getAccessMode() {\n   726→    return accessMode;\n   727→  }\n   728→\n   729→  public static void setWebInterface(int value) {\n   730→    webInterface = value;\n   731→  }\n   732→\n   733→  public static int getWebInterface() {\n   734→    return webInterface;\n   735→  }\n   736→\n   737→  public static void setDisplayOrderAlerts(boolean value) {\n   738→    displayOrderAlerts = value;\n   739→  }\n   740→\n   741→  public static boolean getDisplayOrderAlerts() {\n   742→    return displayOrderAlerts;\n   743→  }\n   744→\n   745→  public static void setListQuotePriceChangeFrequency(int value) {\n   746→    listQuotePriceChangeFrequency = value;\n   747→  }\n   748→\n   749→  public static int getListQuotePriceChangeFrequency() {\n   750→    return  listQuotePriceChangeFrequency;\n   751→  }\t\n   752→}\n   753→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"1f97351e-0846-45f2-9b1b-14f4ccf82da2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Ligz6Zf7bVePcSi1Q8RUoB","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.servlet;\n    17→\n    18→import java.io.IOException;\n    19→\n    20→import javax.inject.Inject;\n    21→import javax.servlet.ServletConfig;\n    22→import javax.servlet.ServletContext;\n    23→import javax.servlet.ServletException;\n    24→import javax.servlet.annotation.WebServlet;\n    25→import javax.servlet.http.HttpServlet;\n    26→import javax.servlet.http.HttpServletRequest;\n    27→import javax.servlet.http.HttpServletResponse;\n    28→import javax.servlet.http.HttpSession;\n    29→import javax.servlet.http.PushBuilder;\n    30→\n    31→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    32→import com.ibm.websphere.samples.daytrader.util.Log;\n    33→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    34→\n    35→\n    36→/**\n    37→ *\n    38→ * TradeAppServlet provides the standard web interface to Trade and can be\n    39→ * accessed with the Go Trade! link. Driving benchmark load using this interface\n    40→ * requires a sophisticated web load generator that is capable of filling HTML\n    41→ * forms and posting dynamic data.\n    42→ */\n    43→\n    44→@WebServlet(name = \"TradeAppServlet\", urlPatterns = { \"/app\" })\n    45→@Trace\n    46→public class TradeAppServlet extends HttpServlet {\n    47→\n    48→  @Inject\n    49→  TradeServletAction tsAction; \n    50→  \n    51→  private static final long serialVersionUID = 481530522846648373L;\n    52→\n    53→  /**\n    54→   * Servlet initialization method.\n    55→   */\n    56→  @Override\n    57→  public void init(ServletConfig config) throws ServletException {\n    58→    super.init(config);\n    59→    java.util.Enumeration<String> en = config.getInitParameterNames();\n    60→    while (en.hasMoreElements()) {\n    61→      String parm = en.nextElement();\n    62→      String value = config.getInitParameter(parm);\n    63→      TradeConfig.setConfigParam(parm, value);\n    64→    }\n    65→    try {\n    66→      // TODO: Uncomment this once split-tier issue is resolved\n    67→      // TradeDirect.init();\n    68→    } catch (Exception e) {\n    69→      Log.error(e, \"TradeAppServlet:init -- Error initializing TradeDirect\");\n    70→    }\n    71→  }\n    72→\n    73→  /**\n    74→   * Returns a string that contains information about TradeScenarioServlet\n    75→   *\n    76→   * @return The servlet information\n    77→   */\n    78→  @Override\n    79→  public java.lang.String getServletInfo() {\n    80→    return \"TradeAppServlet provides the standard web interface to Trade\";\n    81→  }\n    82→\n    83→  /**\n    84→   * Process incoming HTTP GET requests\n    85→   *\n    86→   * @param request\n    87→   *            Object that encapsulates the request to the servlet\n    88→   * @param response\n    89→   *            Object that encapsulates the response from the servlet\n    90→   */\n    91→  @Override\n    92→  public void doGet(javax.servlet.http.HttpServletRequest request, javax.servlet.http.HttpServletResponse response) throws ServletException, IOException {\n    93→    performTask(request, response);\n    94→  }\n    95→\n    96→  /**\n    97→   * Process incoming HTTP POST requests\n    98→   *\n    99→   * @param request\n   100→   *            Object that encapsulates the request to the servlet\n   101→   * @param response\n   102→   *            Object that encapsulates the response from the servlet\n   103→   */\n   104→  @Override\n   105→  public void doPost(javax.servlet.http.HttpServletRequest request, javax.servlet.http.HttpServletResponse response) throws ServletException, IOException {\n   106→    performTask(request, response);\n   107→  }\n   108→\n   109→  /**\n   110→   * Main service method for TradeAppServlet\n   111→   *\n   112→   * @param request\n   113→   *            Object that encapsulates the request to the servlet\n   114→   * @param response\n   115→   *            Object that encapsulates the response from the servlet\n   116→   */\n   117→  public void performTask(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {\n   118→\n   119→    String action = null;\n   120→    String userID = null;\n   121→    // String to create full dispatch path to TradeAppServlet w/ request\n   122→    // Parameters\n   123→\n   124→    resp.setContentType(\"text/html\");\n   125→\n   126→    // Dyna - need status string - prepended to output\n   127→    action = req.getParameter(\"action\");\n   128→\n   129→    ServletContext ctx = getServletConfig().getServletContext();\n   130→\n   131→    if (action == null) {\n   132→      tsAction.doWelcome(ctx, req, resp, \"\");\n   133→      return;\n   134→    } else if (action.equals(\"login\")) {\n   135→      userID = req.getParameter(\"uid\");\n   136→      String passwd = req.getParameter(\"passwd\");\n   137→      tsAction.doLogin(ctx, req, resp, userID, passwd);\n   138→      return;\n   139→    } else if (action.equals(\"register\")) {\n   140→      userID = req.getParameter(\"user id\");\n   141→      String passwd = req.getParameter(\"passwd\");\n   142→      String cpasswd = req.getParameter(\"confirm passwd\");\n   143→      String fullname = req.getParameter(\"Full Name\");\n   144→      String ccn = req.getParameter(\"Credit Card Number\");\n   145→      String money = req.getParameter(\"money\");\n   146→      String email = req.getParameter(\"email\");\n   147→      String smail = req.getParameter(\"snail mail\");\n   148→      tsAction.doRegister(ctx, req, resp, userID, passwd, cpasswd, fullname, ccn, money, email, smail);\n   149→      return;\n   150→    }\n   151→\n   152→    // The rest of the operations require the user to be logged in -\n   153→    // Get the Session and validate the user.\n   154→    HttpSession session = req.getSession();\n   155→    userID = (String) session.getAttribute(\"uidBean\");\n   156→\n   157→    if (userID == null) {\n   158→      System.out.println(\"TradeAppServlet service error: User Not Logged in\");\n   159→      tsAction.doWelcome(ctx, req, resp, \"User Not Logged in\");\n   160→      return;\n   161→    }\n   162→    \n   163→    // try http/2 push if we get here\n   164→    // should be logged in and doing real work by this point\n   165→    if (!action.equals(\"logout\") && TradeConfig.getWebInterface() == TradeConfig.JSP_Images_HTTP2) {\n   166→      pushHeaderImages(req.newPushBuilder());\n   167→    }\n   168→    \n   169→    if (action.equals(\"quotes\")) {\n   170→      String symbols = req.getParameter(\"symbols\");\n   171→      tsAction.doQuotes(ctx, req, resp, userID, symbols);\n   172→    } else if (action.equals(\"buy\")) {\n   173→      String symbol = req.getParameter(\"symbol\");\n   174→      String quantity = req.getParameter(\"quantity\");\n   175→      tsAction.doBuy(ctx, req, resp, userID, symbol, quantity);\n   176→    } else if (action.equals(\"sell\")) {\n   177→      int holdingID = Integer.parseInt(req.getParameter(\"holdingID\"));\n   178→      tsAction.doSell(ctx, req, resp, userID, new Integer(holdingID));\n   179→    } else if (action.equals(\"portfolio\") || action.equals(\"portfolioNoEdge\")) {\n   180→      tsAction.doPortfolio(ctx, req, resp, userID, \"Portfolio as of \" + new java.util.Date());\n   181→    } else if (action.equals(\"logout\")) {\n   182→      tsAction.doLogout(ctx, req, resp, userID);\n   183→    } else if (action.equals(\"home\")) {\n   184→      tsAction.doHome(ctx, req, resp, userID, \"Ready to Trade\");\n   185→    } else if (action.equals(\"account\")) {\n   186→      tsAction.doAccount(ctx, req, resp, userID, \"\");\n   187→    } else if (action.equals(\"update_profile\")) {      \n   188→      String password = req.getParameter(\"password\");\n   189→      String cpassword = req.getParameter(\"cpassword\");\n   190→      String fullName = req.getParameter(\"fullname\");\n   191→      String address = req.getParameter(\"address\");\n   192→      String creditcard = req.getParameter(\"creditcard\");\n   193→      String email = req.getParameter(\"email\");\n   194→      tsAction.doAccountUpdate(ctx, req, resp, userID, password == null ? \"\" : password.trim(), cpassword == null ? \"\" : cpassword.trim(),\n   195→          fullName == null ? \"\" : fullName.trim(), address == null ? \"\" : address.trim(), creditcard == null ? \"\" : creditcard.trim(),\n   196→              email == null ? \"\" : email.trim());\n   197→    } else if (action.equals(\"mksummary\")) {\n   198→      tsAction.doMarketSummary(ctx, req, resp, userID);\n   199→    } else {\n   200→      System.out.println(\"TradeAppServlet: Invalid Action=\" + action);\n   201→      tsAction.doWelcome(ctx, req, resp, \"TradeAppServlet: Invalid Action\" + action);\n   202→    }\n   203→  }\n   204→\n   205→  private void pushHeaderImages(PushBuilder pushBuilder) {       \n   206→    if (pushBuilder != null) {\n   207→      pushBuilder.path(\"images/menuHome.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   208→      pushBuilder.path(\"images/account.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   209→      pushBuilder.path(\"images/portfolio.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   210→      pushBuilder.path(\"images/quotes.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   211→      pushBuilder.path(\"images/logout.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   212→      pushBuilder.path(\"images/graph.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   213→      pushBuilder.path(\"images/line.gif\").addHeader(\"content-type\", \"image/gif\").push();\n   214→      Log.trace(\"HTTP/2 is enabled\");\n   215→    } else {\n   216→      Log.error(\"HTTP/2 not enabled\");\n   217→    }\n   218→    \n   219→  }\n   220→\n   221→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"def9de3f-7c21-4319-9fdd-33c602e3536e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XAUJbnMWxsRpAeK7SrTHBv","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.sql.Timestamp;\n    20→import java.util.Collection;\n    21→import java.util.Comparator;\n    22→import java.util.Iterator;\n    23→import java.util.List;\n    24→import java.util.concurrent.Future;\n    25→\n    26→import javax.annotation.Resource;\n    27→import javax.ejb.EJB;\n    28→import javax.ejb.EJBException;\n    29→import javax.ejb.SessionContext;\n    30→import javax.ejb.Stateless;\n    31→import javax.ejb.TransactionAttribute;\n    32→import javax.ejb.TransactionAttributeType;\n    33→import javax.ejb.TransactionManagement;\n    34→import javax.ejb.TransactionManagementType;\n    35→import javax.inject.Inject;\n    36→import javax.jms.JMSContext;\n    37→import javax.jms.Queue;\n    38→import javax.jms.QueueConnectionFactory;\n    39→import javax.jms.TextMessage;\n    40→import javax.jms.Topic;\n    41→import javax.jms.TopicConnectionFactory;\n    42→import javax.persistence.EntityManager;\n    43→import javax.persistence.PersistenceContext;\n    44→import javax.persistence.TypedQuery;\n    45→import javax.persistence.criteria.CriteriaBuilder;\n    46→import javax.persistence.criteria.CriteriaQuery;\n    47→import javax.persistence.criteria.Root;\n    48→import javax.transaction.RollbackException;\n    49→import javax.validation.constraints.NotNull;\n    50→\n    51→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    52→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    53→import com.ibm.websphere.samples.daytrader.interfaces.TradeEJB;\n    54→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    55→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    56→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    57→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    58→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    59→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    60→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    61→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    62→import com.ibm.websphere.samples.daytrader.util.Log;\n    63→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    64→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    65→\n    66→@Stateless\n    67→@TradeEJB\n    68→@RuntimeMode(\"Full EJB3\")\n    69→@Trace\n    70→@TransactionAttribute(TransactionAttributeType.REQUIRED)\n    71→@TransactionManagement(TransactionManagementType.CONTAINER)\n    72→public class TradeSLSBBean implements TradeServices {\n    73→\n    74→    // For Wildfly - add java:/ to these resource names.\n    75→    @Resource(name = \"jms/QueueConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n    76→    //@Resource(name = \"java:/jms/QueueConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n    77→    private QueueConnectionFactory queueConnectionFactory;\n    78→\n    79→    @Resource(name = \"jms/TopicConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n    80→    //@Resource(name = \"java:/jms/TopicConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n    81→    private TopicConnectionFactory topicConnectionFactory;\n    82→\n    83→    @Resource(lookup = \"jms/TradeStreamerTopic\")\n    84→    //@Resource(lookup = \"java:/jms/TradeStreamerTopic\")\n    85→    private Topic tradeStreamerTopic;\n    86→\n    87→    @Resource(lookup = \"jms/TradeBrokerQueue\")\n    88→    //@Resource(lookup = \"java:/jms/TradeBrokerQueue\")\n    89→    private Queue tradeBrokerQueue;\n    90→\n    91→    @PersistenceContext\n    92→    private EntityManager entityManager;\n    93→\n    94→    @Resource\n    95→    private SessionContext context;\n    96→\n    97→    @EJB\n    98→    MarketSummarySingleton marketSummarySingleton;\n    99→\n   100→    @Inject \n   101→    AsyncScheduledOrderSubmitter asyncEJBOrderSubmitter;\n   102→\n   103→    @Inject\n   104→    RecentQuotePriceChangeList recentQuotePriceChangeList;\n   105→\n   106→    @Override\n   107→    public MarketSummaryDataBean getMarketSummary() {\n   108→        return marketSummarySingleton.getMarketSummaryDataBean();\n   109→    }\n   110→\n   111→    @Override\n   112→    @NotNull\n   113→    public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) {\n   114→        OrderDataBean order = null;\n   115→        BigDecimal total;\n   116→        try {\n   117→\n   118→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   119→            AccountDataBean account = profile.getAccount();\n   120→            QuoteDataBean quote = entityManager.find(QuoteDataBean.class, symbol);\n   121→            HoldingDataBean holding = null; // The holding will be created by\n   122→            // this buy order\n   123→\n   124→            order = createOrder(account, quote, holding, \"buy\", quantity);\n   125→ \n   126→            // UPDATE - account should be credited during completeOrder\n   127→            BigDecimal price = quote.getPrice();\n   128→            BigDecimal orderFee = order.getOrderFee();\n   129→            BigDecimal balance = account.getBalance();\n   130→            total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   131→            account.setBalance(balance.subtract(total));\n   132→            final Integer orderID=order.getOrderID();\n   133→\n   134→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   135→              completeOrder(orderID, false);\n   136→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   137→              completeOrderAsync(orderID, false);\n   138→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   139→              queueOrder(orderID, true);\n   140→            }\n   141→        } catch (Exception e) {\n   142→            Log.error(\"TradeSLSBBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed\", e);\n   143→            /* On exception - cancel the order */\n   144→            // TODO figure out how to do this with JPA\n   145→            // if (order != null) order.cancel();\n   146→            throw new EJBException(e);\n   147→        }\n   148→        return order;\n   149→    }\n   150→\n   151→    @Override\n   152→    @NotNull\n   153→    public OrderDataBean sell(final String userID, final Integer holdingID, int orderProcessingMode) {\n   154→        OrderDataBean order=null;\n   155→        BigDecimal total;\n   156→        try {\n   157→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   158→            AccountDataBean account = profile.getAccount();\n   159→\n   160→            HoldingDataBean holding = entityManager.find(HoldingDataBean.class, holdingID);\n   161→\n   162→            if (holding == null) {\n   163→                Log.debug(\"TradeSLSBBean:sell User \" + userID + \" attempted to sell holding \" + holdingID + \" which has already been sold\");\n   164→\n   165→                OrderDataBean orderData = new OrderDataBean();\n   166→                orderData.setOrderStatus(\"cancelled\");\n   167→                entityManager.persist(orderData);\n   168→\n   169→                return orderData;\n   170→            }\n   171→\n   172→            QuoteDataBean quote = holding.getQuote();\n   173→            double quantity = holding.getQuantity();\n   174→\n   175→            order = createOrder(account, quote, holding, \"sell\", quantity);\n   176→\n   177→            // UPDATE the holding purchase data to signify this holding is\n   178→            // \"inflight\" to be sold\n   179→            // -- could add a new holdingStatus attribute to holdingEJB\n   180→            holding.setPurchaseDate(new java.sql.Timestamp(0));\n   181→\n   182→            // UPDATE - account should be credited during completeOrder\n   183→            BigDecimal price = quote.getPrice();\n   184→            BigDecimal orderFee = order.getOrderFee();\n   185→            BigDecimal balance = account.getBalance();\n   186→            total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   187→            account.setBalance(balance.add(total));\n   188→            final Integer orderID=order.getOrderID(); \n   189→\n   190→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   191→                completeOrder(orderID, false);\n   192→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   193→                completeOrderAsync(orderID, false);\n   194→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   195→                queueOrder(orderID, true);\n   196→            }\n   197→\n   198→        } catch (Exception e) {\n   199→            Log.error(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \") --> failed\", e);\n   200→            // if (order != null) order.cancel();\n   201→            // UPDATE - handle all exceptions like:\n   202→            throw new EJBException(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \")\", e);\n   203→        }\n   204→        return order;\n   205→    }\n   206→\n   207→    public void queueOrder(Integer orderID, boolean twoPhase) {\n   208→\n   209→        // 2 phase\n   210→        try (JMSContext queueContext = queueConnectionFactory.createContext();) {\n   211→          TextMessage message = queueContext.createTextMessage();\n   212→\n   213→          message.setStringProperty(\"command\", \"neworder\");\n   214→          message.setIntProperty(\"orderID\", orderID);\n   215→          message.setBooleanProperty(\"twoPhase\", twoPhase);\n   216→          message.setText(\"neworder: orderID=\" + orderID + \" runtimeMode=EJB twoPhase=\" + twoPhase);\n   217→          message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   218→\n   219→          queueContext.createProducer().send(tradeBrokerQueue, message);\n   220→\n   221→        } catch (Exception e) {\n   222→          throw new EJBException(e.getMessage(), e); // pass the exception\n   223→        }\n   224→    }\n   225→\n   226→    @Override\n   227→    public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   228→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   229→\n   230→        if (order == null) {\n   231→          System.out.println(\"error\");\n   232→            throw new EJBException(\"Error: attempt to complete Order that is null\\n\" + order);\n   233→        }\n   234→\n   235→        order.getQuote();\n   236→\n   237→        if (order.isCompleted()) {\n   238→            throw new EJBException(\"Error: attempt to complete Order that is already completed\\n\" + order);\n   239→        }\n   240→\n   241→        AccountDataBean account = order.getAccount();\n   242→        QuoteDataBean quote = order.getQuote();\n   243→        HoldingDataBean holding = order.getHolding();\n   244→        BigDecimal price = order.getPrice();\n   245→        double quantity = order.getQuantity();\n   246→\n   247→        if (order.isBuy()) {\n   248→            /*\n   249→             * Complete a Buy operation - create a new Holding for the Account -\n   250→             * deduct the Order cost from the Account balance\n   251→             */\n   252→\n   253→            HoldingDataBean newHolding = createHolding(account, quote, quantity, price);\n   254→            order.setHolding(newHolding);\n   255→            order.setOrderStatus(\"closed\");\n   256→            order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   257→            updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   258→        }\n   259→\n   260→        if (order.isSell()) {\n   261→            /*\n   262→             * Complete a Sell operation - remove the Holding from the Account -\n   263→             * deposit the Order proceeds to the Account balance\n   264→             */\n   265→            if (holding == null) {\n   266→                Log.debug(\"TradeSLSBBean:completeOrder -- Unable to sell order \" + order.getOrderID() + \" holding already sold\");\n   267→                order.cancel();\n   268→                //throw new EJBException(\"TradeSLSBBean:completeOrder -- Unable to sell order \" + order.getOrderID() + \" holding already sold\");\n   269→            } else {\n   270→                entityManager.remove(holding);\n   271→                order.setHolding(null);\n   272→                order.setOrderStatus(\"closed\");\n   273→                order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   274→                updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   275→            }\n   276→        } \n   277→\n   278→        Log.trace(\"TradeSLSBBean:completeOrder--> Completed Order \" + order.getOrderID() + \"\\n\\t Order info: \" + order + \"\\n\\t Account info: \" + account\n   279→            + \"\\n\\t Quote info: \" + quote + \"\\n\\t Holding info: \" + holding);\n   280→\n   281→        return order;\n   282→    }\n   283→\n   284→    @Override\n   285→    public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   286→      asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   287→      return null;\n   288→    }\n   289→\n   290→    @Override\n   291→    public void cancelOrder(Integer orderID, boolean twoPhase) {\n   292→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   293→        order.cancel();\n   294→    }\n   295→\n   296→    @Override\n   297→    public void orderCompleted(String userID, Integer orderID) {\n   298→        throw new UnsupportedOperationException(\"TradeSLSBBean:orderCompleted method not supported\");\n   299→    }\n   300→\n   301→    @Override\n   302→    public Collection<OrderDataBean> getOrders(String userID) {\n   303→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   304→        AccountDataBean account = profile.getAccount();\n   305→        return account.getOrders();\n   306→    }\n   307→\n   308→    @Override\n   309→    public Collection<OrderDataBean> getClosedOrders(String userID) {\n   310→\n   311→        try {\n   312→            /* I want to do a CriteriaUpdate here, but there are issues with JBoss/Hibernate */\n   313→            CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   314→            CriteriaQuery<OrderDataBean> criteriaQuery = criteriaBuilder.createQuery(OrderDataBean.class);\n   315→            Root<OrderDataBean> orders = criteriaQuery.from(OrderDataBean.class);\n   316→            criteriaQuery.select(orders);\n   317→            criteriaQuery.where(\n   318→                    criteriaBuilder.equal(orders.get(\"orderStatus\"), \n   319→                            criteriaBuilder.parameter(String.class, \"p_status\")), \n   320→                    criteriaBuilder.equal(orders.get(\"account\").get(\"profile\").get(\"userID\"), \n   321→                            criteriaBuilder.parameter(String.class, \"p_userid\")));\n   322→\n   323→            TypedQuery<OrderDataBean> q = entityManager.createQuery(criteriaQuery);\n   324→            q.setParameter(\"p_status\", \"closed\");\n   325→            q.setParameter(\"p_userid\", userID);\n   326→            List<OrderDataBean> results = q.getResultList();\n   327→\n   328→            Iterator<OrderDataBean> itr = results.iterator();\n   329→            // Spin through the orders to remove or mark completed\n   330→            while (itr.hasNext()) {\n   331→                OrderDataBean order = itr.next();\n   332→                // TODO: Investigate ConncurrentModification Exceptions\n   333→                if (TradeConfig.getLongRun()) {\n   334→                    //Added this for Longruns (to prevent orderejb growth)\n   335→                    entityManager.remove(order); \n   336→                }\n   337→                else {\n   338→                    order.setOrderStatus(\"completed\");\n   339→                }\n   340→            }\n   341→\n   342→            return results;\n   343→        } catch (Exception e) {\n   344→            Log.error(\"TradeSLSBBean.getClosedOrders\", e);\n   345→            throw new EJBException(\"TradeSLSBBean.getClosedOrders - error\", e);\n   346→        }\n   347→    }\n   348→\n   349→    @Override\n   350→    public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) {\n   351→        try {\n   352→            QuoteDataBean quote = new QuoteDataBean(symbol, companyName, 0, price, price, price, price, 0);\n   353→            entityManager.persist(quote);\n   354→\n   355→            Log.trace(\"TradeSLSBBean:createQuote-->\" + quote);\n   356→\n   357→            return quote;\n   358→        } catch (Exception e) {\n   359→            Log.error(\"TradeSLSBBean:createQuote -- exception creating Quote\", e);\n   360→            throw new EJBException(e);\n   361→        }\n   362→    }\n   363→\n   364→    @Override\n   365→    public QuoteDataBean getQuote(String symbol) {\n   366→        return entityManager.find(QuoteDataBean.class, symbol);\n   367→    }\n   368→\n   369→    @Override\n   370→    public Collection<QuoteDataBean> getAllQuotes() {\n   371→        TypedQuery<QuoteDataBean> query = entityManager.createNamedQuery(\"quoteejb.allQuotes\", QuoteDataBean.class);\n   372→        return query.getResultList();\n   373→    }\n   374→\n   375→    @Override\n   376→    public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded) {\n   377→        if (!TradeConfig.getUpdateQuotePrices()) {\n   378→            return new QuoteDataBean();\n   379→        }\n   380→\n   381→        Log.trace(\"TradeSLSBBean:updateQuote\", symbol, changeFactor);\n   382→\n   383→        TypedQuery<QuoteDataBean> q = entityManager.createNamedQuery(\"quoteejb.quoteForUpdate\", QuoteDataBean.class);\n   384→        q.setParameter(1, symbol);\n   385→        QuoteDataBean quote = q.getSingleResult();\n   386→\n   387→        BigDecimal oldPrice = quote.getPrice();\n   388→        BigDecimal openPrice = quote.getOpen();\n   389→\n   390→        if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n   391→            changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   392→        } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n   393→            changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   394→        }\n   395→\n   396→        BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   397→\n   398→        quote.setPrice(newPrice);\n   399→        quote.setChange(newPrice.subtract(openPrice).doubleValue());\n   400→        quote.setVolume(quote.getVolume() + sharesTraded);\n   401→        entityManager.merge(quote);\n   402→\n   403→        if (TradeConfig.getPublishQuotePriceChange()) {\n   404→          publishQuotePriceChange(quote, oldPrice, changeFactor, sharesTraded);\n   405→        }\n   406→\n   407→        recentQuotePriceChangeList.add(quote);\n   408→\n   409→        return quote;\n   410→    }\n   411→\n   412→    @Override\n   413→    public Collection<@NotNull HoldingDataBean> getHoldings(String userID) {\n   414→        CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   415→        CriteriaQuery<HoldingDataBean> criteriaQuery = criteriaBuilder.createQuery(HoldingDataBean.class);\n   416→        Root<HoldingDataBean> holdings = criteriaQuery.from(HoldingDataBean.class);\n   417→        criteriaQuery.where(\n   418→                criteriaBuilder.equal(holdings.get(\"account\").get(\"profile\").get(\"userID\"), \n   419→                        criteriaBuilder.parameter(String.class, \"p_userid\")));\n   420→        criteriaQuery.select(holdings);\n   421→\n   422→        TypedQuery<HoldingDataBean> typedQuery = entityManager.createQuery(criteriaQuery);\n   423→        typedQuery.setParameter(\"p_userid\", userID);\n   424→        return typedQuery.getResultList();\n   425→    }\n   426→\n   427→    @Override\n   428→    public HoldingDataBean getHolding(Integer holdingID) {\n   429→      return entityManager.find(HoldingDataBean.class, holdingID);\n   430→    }\n   431→\n   432→    @Override\n   433→    public AccountDataBean getAccountData(String userID) {\n   434→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   435→        AccountDataBean account = profile.getAccount();\n   436→\n   437→        // Added to populate transient field for account\n   438→        account.setProfileID(profile.getUserID());\n   439→\n   440→        return account;\n   441→    }\n   442→\n   443→    @Override\n   444→    public AccountProfileDataBean getAccountProfileData(String userID) {\n   445→        return entityManager.find(AccountProfileDataBean.class, userID);\n   446→    }\n   447→\n   448→    @Override\n   449→    public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) {\n   450→        AccountProfileDataBean temp = entityManager.find(AccountProfileDataBean.class, profileData.getUserID());\n   451→        temp.setAddress(profileData.getAddress());\n   452→        temp.setPassword(profileData.getPassword());\n   453→        temp.setFullName(profileData.getFullName());\n   454→        temp.setCreditCard(profileData.getCreditCard());\n   455→        temp.setEmail(profileData.getEmail());\n   456→\n   457→        entityManager.merge(temp);\n   458→\n   459→        return temp;\n   460→    }\n   461→\n   462→    @Override\n   463→    public AccountDataBean login(String userID, String password) throws RollbackException {\n   464→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   465→        if (profile == null) {\n   466→            throw new EJBException(\"No such user: \" + userID);\n   467→        }\n   468→\n   469→        AccountDataBean account = profile.getAccount();\n   470→        account.login(password);\n   471→\n   472→        Log.trace(\"TradeSLSBBean:login(\" + userID + \",\" + password + \") success\" + account);\n   473→\n   474→        return account;\n   475→    }\n   476→\n   477→    @Override\n   478→    public void logout(String userID) {\n   479→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   480→        AccountDataBean account = profile.getAccount();\n   481→        account.logout();\n   482→\n   483→        Log.trace(\"TradeSLSBBean:logout(\" + userID + \") success\");\n   484→    }\n   485→\n   486→    @Override\n   487→    public AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance) {\n   488→        AccountDataBean account = null;\n   489→        AccountProfileDataBean profile = null;\n   490→\n   491→        // Check to see if a profile with the desired userID already exists\n   492→        profile = entityManager.find(AccountProfileDataBean.class, userID);\n   493→\n   494→        if (profile != null) {\n   495→            Log.error(\"Failed to register new Account - AccountProfile with userID(\" + userID + \") already exists\");\n   496→            return null;\n   497→        } else {\n   498→            profile = new AccountProfileDataBean(userID, password, fullname, address, email, creditcard);\n   499→            account = new AccountDataBean(0, 0, null, new Timestamp(System.currentTimeMillis()), openBalance, openBalance, userID);\n   500→\n   501→            profile.setAccount(account);\n   502→            account.setProfile(profile);\n   503→\n   504→            entityManager.persist(profile);\n   505→            entityManager.persist(account);\n   506→        }\n   507→\n   508→        return account;\n   509→    }\n   510→\n   511→    @TransactionAttribute(TransactionAttributeType.REQUIRES_NEW)\n   512→    public void publishQuotePriceChange(QuoteDataBean quote, BigDecimal oldPrice, BigDecimal changeFactor, double sharesTraded) {\n   513→        if (!TradeConfig.getPublishQuotePriceChange()) {\n   514→            return;\n   515→        }\n   516→\n   517→        try (JMSContext topicContext = topicConnectionFactory.createContext();) {\n   518→            TextMessage message = topicContext.createTextMessage();\n   519→\n   520→            message.setStringProperty(\"command\", \"updateQuote\");\n   521→            message.setStringProperty(\"symbol\", quote.getSymbol());\n   522→            message.setStringProperty(\"company\", quote.getCompanyName());\n   523→            message.setStringProperty(\"price\", quote.getPrice().toString());\n   524→            message.setStringProperty(\"oldPrice\", oldPrice.toString());\n   525→            message.setStringProperty(\"open\", quote.getOpen().toString());\n   526→            message.setStringProperty(\"low\", quote.getLow().toString());\n   527→            message.setStringProperty(\"high\", quote.getHigh().toString());\n   528→            message.setDoubleProperty(\"volume\", quote.getVolume());\n   529→            message.setStringProperty(\"changeFactor\", changeFactor.toString());\n   530→            message.setDoubleProperty(\"sharesTraded\", sharesTraded);\n   531→            message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   532→            message.setText(\"Update Stock price for \" + quote.getSymbol() + \" old price = \" + oldPrice + \" new price = \" + quote.getPrice());\n   533→\n   534→            topicContext.createProducer().send(tradeStreamerTopic, message);\n   535→        } catch (Exception e) {\n   536→             throw new EJBException(e.getMessage(), e); // pass the exception\n   537→        }\n   538→    }\n   539→\n   540→    public OrderDataBean createOrder(AccountDataBean account, QuoteDataBean quote, HoldingDataBean holding, String orderType, double quantity) {\n   541→        OrderDataBean order;\n   542→\n   543→        try {\n   544→            order = new OrderDataBean(orderType, \"open\", new Timestamp(System.currentTimeMillis()), null, quantity, quote.getPrice().setScale(\n   545→                    FinancialUtils.SCALE, FinancialUtils.ROUND), TradeConfig.getOrderFee(orderType), account, quote, holding);\n   546→            entityManager.persist(order);\n   547→        } catch (Exception e) {\n   548→            Log.error(\"TradeSLSBBean:createOrder -- failed to create Order. The stock/quote may not exist in the database.\", e);\n   549→            throw new EJBException(\"TradeSLSBBean:createOrder -- failed to create Order. Check that the symbol exists in the database.\", e);\n   550→        }\n   551→        return order;\n   552→    }\n   553→\n   554→    private HoldingDataBean createHolding(AccountDataBean account, QuoteDataBean quote, double quantity, BigDecimal purchasePrice) throws Exception {\n   555→        HoldingDataBean newHolding = new HoldingDataBean(quantity, purchasePrice, new Timestamp(System.currentTimeMillis()), account, quote);\n   556→        entityManager.persist(newHolding);\n   557→        return newHolding;\n   558→    }\n   559→\n   560→    @Override\n   561→    public double investmentReturn(double investment, double NetValue) throws Exception {\n   562→        double diff = NetValue - investment;\n   563→        double ir = diff / investment;\n   564→        return ir;\n   565→    }\n   566→\n   567→    @Override\n   568→    public QuoteDataBean pingTwoPhase(String symbol) throws Exception {\n   569→        QuoteDataBean quoteData = null;\n   570→\n   571→        try (JMSContext queueContext = queueConnectionFactory.createContext();) {\n   572→            // Get a Quote and send a JMS message in a 2-phase commit\n   573→            quoteData = entityManager.find(QuoteDataBean.class, symbol);\n   574→            \n   575→            double sharesTraded = (Math.random() * 100) + 1 ;\n   576→            BigDecimal oldPrice = quoteData.getPrice();\n   577→            BigDecimal openPrice = quoteData.getOpen();\n   578→            BigDecimal changeFactor = new BigDecimal (Math.random() * 100);\n   579→\n   580→            BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   581→\n   582→            quoteData.setPrice(newPrice);\n   583→            quoteData.setChange(newPrice.subtract(openPrice).doubleValue());\n   584→            quoteData.setVolume(quoteData.getVolume() + sharesTraded);\n   585→            entityManager.merge(quoteData);\n   586→\n   587→            TextMessage message = queueContext.createTextMessage();\n   588→\n   589→            message.setStringProperty(\"command\", \"ping\");\n   590→            message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   591→            message.setText(\"Ping message for queue java:comp/env/jms/TradeBrokerQueue sent from TradeSLSBBean:pingTwoPhase at \" + new java.util.Date());\n   592→            queueContext.createProducer().send(tradeBrokerQueue, message);\n   593→        } catch (Exception e) {\n   594→            Log.error(\"TradeSLSBBean:pingTwoPhase -- exception caught\", e);\n   595→        }\n   596→\n   597→        return quoteData;\n   598→    }\n   599→\n   600→    class quotePriceComparator implements Comparator<QuoteDataBean> {\n   601→        @Override\n   602→        public int compare(QuoteDataBean quote1, QuoteDataBean quote2) {\n   603→            double change1 = quote1.getChange();\n   604→            double change2 = quote2.getChange();\n   605→            return new Double(change2).compareTo(change1);\n   606→        }\n   607→    }\n   608→\n   609→    @Override\n   610→    public int getImpl() {\n   611→      return TradeConfig.EJB3;\n   612→    }\n   613→\n   614→    @Override\n   615→    public void setInSession(boolean inSession) {\n   616→      throw new UnsupportedOperationException(\"TradeSLSBBean::setInGlobalTxn not supported\");\n   617→    }\n   618→}\n   619→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"b5c4c4e4-47d1-4fb8-aebc-61573d91d9f5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MQRs52sneBABQNyhzxVHYR","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.servlet;\n    17→\n    18→import java.io.IOException;\n    19→import java.io.Serializable;\n    20→import java.math.BigDecimal;\n    21→import java.util.ArrayList;\n    22→import java.util.Collection;\n    23→import java.util.Iterator;\n    24→\n    25→import javax.enterprise.context.SessionScoped;\n    26→import javax.enterprise.inject.Any;\n    27→import javax.enterprise.inject.Instance;\n    28→import javax.inject.Inject;\n    29→import javax.servlet.ServletContext;\n    30→import javax.servlet.ServletException;\n    31→import javax.servlet.http.HttpServletRequest;\n    32→import javax.servlet.http.HttpServletResponse;\n    33→import javax.servlet.http.HttpSession;\n    34→\n    35→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    36→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    37→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    38→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    39→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    40→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    41→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    42→import com.ibm.websphere.samples.daytrader.util.Log;\n    43→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    45→\n    46→\n    47→/**\n    48→ * TradeServletAction provides servlet specific client side access to each of\n    49→ * the Trade brokerage user operations. These include login, logout, buy, sell,\n    50→ * getQuote, etc. TradeServletAction manages a web interface to Trade handling\n    51→ * HttpRequests/HttpResponse objects and forwarding results to the appropriate\n    52→ * JSP page for the web interface. TradeServletAction invokes\n    53→ * {@link TradeAction} methods to actually perform each trading operation.\n    54→ *\n    55→ */\n    56→@SessionScoped\n    57→@Trace\n    58→public class TradeServletAction implements Serializable {\n    59→\n    60→  private static final long serialVersionUID = 7732313125198761455L;\n    61→\n    62→  private TradeServices tAction;  \n    63→\n    64→  @Inject \n    65→  public TradeServletAction(@Any Instance<TradeServices> services) {\n    66→    tAction = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    67→  }\n    68→\n    69→  public TradeServletAction() {\n    70→  }\n    71→\n    72→  /**\n    73→   * Display User Profile information such as address, email, etc. for the\n    74→   * given Trader Dispatch to the Trade Account JSP for display\n    75→   *\n    76→   * @param userID\n    77→   *            The User to display profile info\n    78→   * @param ctx\n    79→   *            the servlet context\n    80→   * @param req\n    81→   *            the HttpRequest object\n    82→   * @param resp\n    83→   *            the HttpResponse object\n    84→   * @param results\n    85→   *            A short description of the results/success of this web request\n    86→   *            provided on the web page\n    87→   * @exception javax.servlet.ServletException\n    88→   *                If a servlet specific exception is encountered\n    89→   * @exception javax.io.IOException\n    90→   *                If an exception occurs while writing results back to the\n    91→   *                user\n    92→   *\n    93→   */\n    94→  void doAccount(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String results) throws javax.servlet.ServletException,\n    95→  java.io.IOException {\n    96→    try {\n    97→\n    98→      AccountDataBean accountData = tAction.getAccountData(userID);\n    99→      AccountProfileDataBean accountProfileData = tAction.getAccountProfileData(userID);\n   100→      Collection<?> orderDataBeans = (TradeConfig.getLongRun() ? new ArrayList<Object>() : (Collection<?>) tAction.getOrders(userID));\n   101→\n   102→      req.setAttribute(\"accountData\", accountData);\n   103→      req.setAttribute(\"accountProfileData\", accountProfileData);\n   104→      req.setAttribute(\"orderDataBeans\", orderDataBeans);\n   105→      req.setAttribute(\"results\", results);\n   106→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.ACCOUNT_PAGE));\n   107→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   108→      // error so I will\n   109→      // forward them to another page rather than throw a 500\n   110→      req.setAttribute(\"results\", results + \"could not find account for userID = \" + userID);\n   111→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.HOME_PAGE));\n   112→      // log the exception with an error level of 3 which means, handled\n   113→      // exception but would invalidate a automation run\n   114→      Log.error(\"TradeServletAction.doAccount(...)\", \"illegal argument, information should be in exception string\", e);\n   115→    } catch (Exception e) {\n   116→      // log the exception with error page\n   117→      throw new ServletException(\"TradeServletAction.doAccount(...)\" + \" exception user =\" + userID, e);\n   118→    }\n   119→\n   120→  }\n   121→\n   122→  /**\n   123→   * Update User Profile information such as address, email, etc. for the\n   124→   * given Trader Dispatch to the Trade Account JSP for display If any in put\n   125→   * is incorrect revert back to the account page w/ an appropriate message\n   126→   *\n   127→   * @param userID\n   128→   *            The User to upddate profile info\n   129→   * @param password\n   130→   *            The new User password\n   131→   * @param cpassword\n   132→   *            Confirm password\n   133→   * @param fullname\n   134→   *            The new User fullname info\n   135→   * @param address\n   136→   *            The new User address info\n   137→   * @param cc\n   138→   *            The new User credit card info\n   139→   * @param email\n   140→   *            The new User email info\n   141→   * @param ctx\n   142→   *            the servlet context\n   143→   * @param req\n   144→   *            the HttpRequest object\n   145→   * @param resp\n   146→   *            the HttpResponse object\n   147→   * @exception javax.servlet.ServletException\n   148→   *                If a servlet specific exception is encountered\n   149→   * @exception javax.io.IOException\n   150→   *                If an exception occurs while writing results back to the\n   151→   *                user\n   152→   *\n   153→   */\n   154→  void doAccountUpdate(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String password, String cpassword,\n   155→      String fullName, String address, String creditcard, String email) throws javax.servlet.ServletException, java.io.IOException {\n   156→    String results = \"\";\n   157→\n   158→    // First verify input data\n   159→    boolean doUpdate = true;\n   160→    if (password.equals(cpassword) == false) {\n   161→      results = \"Update profile error: passwords do not match\";\n   162→      doUpdate = false;\n   163→    } else if (password.length() <= 0 || fullName.length() <= 0 || address.length() <= 0 || creditcard.length() <= 0 || email.length() <= 0) {\n   164→      results = \"Update profile error: please fill in all profile information fields\";\n   165→      doUpdate = false;\n   166→    }\n   167→    AccountProfileDataBean accountProfileData = new AccountProfileDataBean(userID, password, fullName, address, email, creditcard);\n   168→    try {\n   169→      if (doUpdate) {\n   170→        accountProfileData = tAction.updateAccountProfile(accountProfileData);\n   171→        results = \"Account profile update successful\";\n   172→      }\n   173→\n   174→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   175→      // error so I will\n   176→      // forward them to another page rather than throw a 500\n   177→      req.setAttribute(\"results\", results + \"invalid argument, check userID is correct, and the database is populated\" + userID);\n   178→      Log.error(e, \"TradeServletAction.doAccount(...)\", \"illegal argument, information should be in exception string\",\n   179→          \"treating this as a user error and forwarding on to a new page\");\n   180→    } catch (Exception e) {\n   181→      // log the exception with error page\n   182→      throw new ServletException(\"TradeServletAction.doAccountUpdate(...)\" + \" exception user =\" + userID, e);\n   183→    }\n   184→    doAccount(ctx, req, resp, userID, results);\n   185→  }\n   186→\n   187→  /**\n   188→   * Buy a new holding of shares for the given trader Dispatch to the Trade\n   189→   * Portfolio JSP for display\n   190→   *\n   191→   * @param userID\n   192→   *            The User buying shares\n   193→   * @param symbol\n   194→   *            The stock to purchase\n   195→   * @param amount\n   196→   *            The quantity of shares to purchase\n   197→   * @param ctx\n   198→   *            the servlet context\n   199→   * @param req\n   200→   *            the HttpRequest object\n   201→   * @param resp\n   202→   *            the HttpResponse object\n   203→   * @exception javax.servlet.ServletException\n   204→   *                If a servlet specific exception is encountered\n   205→   * @exception javax.io.IOException\n   206→   *                If an exception occurs while writing results back to the\n   207→   *                user\n   208→   *\n   209→   */\n   210→  void doBuy(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String symbol, String quantity) throws ServletException,\n   211→  IOException {\n   212→\n   213→    String results = \"\";\n   214→\n   215→    try {\n   216→\n   217→      OrderDataBean orderData = tAction.buy(userID, symbol, new Double(quantity).doubleValue(), TradeConfig.getOrderProcessingMode());\n   218→\n   219→      req.setAttribute(\"orderData\", orderData);\n   220→      req.setAttribute(\"results\", results);\n   221→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   222→      // error so I will\n   223→      // forward them to another page rather than throw a 500\n   224→      req.setAttribute(\"results\", results + \"illegal argument:\");\n   225→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.HOME_PAGE));\n   226→      // log the exception with an error level of 3 which means, handled\n   227→      // exception but would invalidate a automation run\n   228→      Log.error(e, \"TradeServletAction.doBuy(...)\", \"illegal argument. userID = \" + userID, \"symbol = \" + symbol);\n   229→    } catch (Exception e) {\n   230→      // log the exception with error page\n   231→      throw new ServletException(\"TradeServletAction.buy(...)\" + \" exception buying stock \" + symbol + \" for user \" + userID, e);\n   232→    }\n   233→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.ORDER_PAGE));\n   234→  }\n   235→\n   236→  /**\n   237→   * Create the Trade Home page with personalized information such as the\n   238→   * traders account balance Dispatch to the Trade Home JSP for display\n   239→   *\n   240→   * @param ctx\n   241→   *            the servlet context\n   242→   * @param req\n   243→   *            the HttpRequest object\n   244→   * @param resp\n   245→   *            the HttpResponse object\n   246→   * @param results\n   247→   *            A short description of the results/success of this web request\n   248→   *            provided on the web page\n   249→   * @exception javax.servlet.ServletException\n   250→   *                If a servlet specific exception is encountered\n   251→   * @exception javax.io.IOException\n   252→   *                If an exception occurs while writing results back to the\n   253→   *                user\n   254→   *\n   255→   */\n   256→  void doHome(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String results) throws javax.servlet.ServletException,\n   257→  java.io.IOException {\n   258→\n   259→    try {\n   260→      AccountDataBean accountData = tAction.getAccountData(userID);\n   261→      Collection<?> holdingDataBeans = tAction.getHoldings(userID);\n   262→\n   263→      // Edge Caching:\n   264→      // Getting the MarketSummary has been moved to the JSP\n   265→      // MarketSummary.jsp. This makes the MarketSummary a\n   266→      // standalone \"fragment\", and thus is a candidate for\n   267→      // Edge caching.\n   268→      // marketSummaryData = tAction.getMarketSummary();\n   269→\n   270→      req.setAttribute(\"accountData\", accountData);\n   271→      req.setAttribute(\"holdingDataBeans\", holdingDataBeans);\n   272→      // See Edge Caching above\n   273→      // req.setAttribute(\"marketSummaryData\", marketSummaryData);\n   274→      req.setAttribute(\"results\", results);\n   275→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   276→      // error so I will\n   277→      // forward them to another page rather than throw a 500\n   278→      req.setAttribute(\"results\", results + \"check userID = \" + userID + \" and that the database is populated\");\n   279→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.HOME_PAGE));\n   280→      // log the exception with an error level of 3 which means, handled\n   281→      // exception but would invalidate a automation run\n   282→      Log.error(\"TradeServletAction.doHome(...)\" + \"illegal argument, information should be in exception string\"\n   283→          + \"treating this as a user error and forwarding on to a new page\", e);\n   284→    } catch (javax.ejb.FinderException e) {\n   285→      // this is a user error so I will\n   286→      // forward them to another page rather than throw a 500\n   287→      req.setAttribute(\"results\", results + \"\\nCould not find account for + \" + userID);\n   288→      // requestDispatch(ctx, req, resp,\n   289→      // TradeConfig.getPage(TradeConfig.HOME_PAGE));\n   290→      // log the exception with an error level of 3 which means, handled\n   291→      // exception but would invalidate a automation run\n   292→      Log.error(\"TradeServletAction.doHome(...)\" + \"Error finding account for user \" + userID\n   293→          + \"treating this as a user error and forwarding on to a new page\", e);\n   294→    } catch (Exception e) {\n   295→      // log the exception with error page\n   296→      throw new ServletException(\"TradeServletAction.doHome(...)\" + \" exception user =\" + userID, e);\n   297→    }\n   298→\n   299→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.HOME_PAGE));\n   300→  }\n   301→\n   302→  /**\n   303→   * Login a Trade User. Dispatch to the Trade Home JSP for display\n   304→   *\n   305→   * @param userID\n   306→   *            The User to login\n   307→   * @param passwd\n   308→   *            The password supplied by the trader used to authenticate\n   309→   * @param ctx\n   310→   *            the servlet context\n   311→   * @param req\n   312→   *            the HttpRequest object\n   313→   * @param resp\n   314→   *            the HttpResponse object\n   315→   * @param results\n   316→   *            A short description of the results/success of this web request\n   317→   *            provided on the web page\n   318→   * @exception javax.servlet.ServletException\n   319→   *                If a servlet specific exception is encountered\n   320→   * @exception javax.io.IOException\n   321→   *                If an exception occurs while writing results back to the\n   322→   *                user\n   323→   *\n   324→   */\n   325→  void doLogin(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String passwd) throws javax.servlet.ServletException,\n   326→  java.io.IOException {\n   327→\n   328→    String results = \"\";\n   329→    try {\n   330→      // Got a valid userID and passwd, attempt login\n   331→      if (tAction==null) {\n   332→        System.out.println(\"null\");          }\n   333→      AccountDataBean accountData = tAction.login(userID, passwd);\n   334→\n   335→      if (accountData != null) {\n   336→        HttpSession session = req.getSession(true);\n   337→        session.setAttribute(\"uidBean\", userID);\n   338→        session.setAttribute(\"sessionCreationDate\", new java.util.Date());\n   339→\n   340→        results = \"Ready to Trade\";\n   341→        doHome(ctx, req, resp, userID, results);\n   342→        return;\n   343→      } else {\n   344→        req.setAttribute(\"results\", results + \"\\nCould not find account for + \" + userID);\n   345→        // log the exception with an error level of 3 which means,\n   346→        // handled exception but would invalidate a automation run\n   347→        Log.log(\"TradeServletAction.doLogin(...)\", \"Error finding account for user \" + userID + \"\",\n   348→            \"user entered a bad username or the database is not populated\");\n   349→      }\n   350→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   351→      // error so I will\n   352→      // forward them to another page rather than throw a 500\n   353→      req.setAttribute(\"results\", results + \"illegal argument:\" + e.getMessage());\n   354→      // log the exception with an error level of 3 which means, handled\n   355→      // exception but would invalidate a automation run\n   356→      Log.error(e, \"TradeServletAction.doLogin(...)\", \"illegal argument, information should be in exception string\",\n   357→          \"treating this as a user error and forwarding on to a new page\");\n   358→\n   359→    } catch (Exception e) {\n   360→      // log the exception with error page\n   361→      throw new ServletException(\"TradeServletAction.doLogin(...)\" + \"Exception logging in user \" + userID + \"with password\" + passwd, e);\n   362→    }\n   363→\n   364→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.WELCOME_PAGE));\n   365→\n   366→  }\n   367→\n   368→  /**\n   369→   * Logout a Trade User Dispatch to the Trade Welcome JSP for display\n   370→   *\n   371→   * @param userID\n   372→   *            The User to logout\n   373→   * @param ctx\n   374→   *            the servlet context\n   375→   * @param req\n   376→   *            the HttpRequest object\n   377→   * @param resp\n   378→   *            the HttpResponse object\n   379→   * @param results\n   380→   *            A short description of the results/success of this web request\n   381→   *            provided on the web page\n   382→   * @exception javax.servlet.ServletException\n   383→   *                If a servlet specific exception is encountered\n   384→   * @exception javax.io.IOException\n   385→   *                If an exception occurs while writing results back to the\n   386→   *                user\n   387→   *\n   388→   */\n   389→  void doLogout(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID) throws ServletException, IOException {\n   390→    String results = \"\";\n   391→\n   392→    try {\n   393→      tAction.logout(userID);\n   394→\n   395→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   396→      // error so I will\n   397→      // forward them to another page, at the end of the page.\n   398→      req.setAttribute(\"results\", results + \"illegal argument:\" + e.getMessage());\n   399→\n   400→      // log the exception with an error level of 3 which means, handled\n   401→      // exception but would invalidate a automation run\n   402→      Log.error(e, \"TradeServletAction.doLogout(...)\", \"illegal argument, information should be in exception string\",\n   403→          \"treating this as a user error and forwarding on to a new page\");\n   404→    } catch (Exception e) {\n   405→      // log the exception and foward to a error page\n   406→      Log.error(e, \"TradeServletAction.doLogout(...):\", \"Error logging out\" + userID, \"fowarding to an error page\");\n   407→      // set the status_code to 500\n   408→      throw new ServletException(\"TradeServletAction.doLogout(...)\" + \"exception logging out user \" + userID, e);\n   409→    }\n   410→    HttpSession session = req.getSession();\n   411→    if (session != null) {\n   412→      session.invalidate();\n   413→    }\n   414→\n   415→    // Added to actually remove a user from the authentication cache\n   416→    req.logout();\n   417→\n   418→    Object o = req.getAttribute(\"TSS-RecreateSessionInLogout\");\n   419→    if (o != null && ((Boolean) o).equals(Boolean.TRUE)) {\n   420→      // Recreate Session object before writing output to the response\n   421→      // Once the response headers are written back to the client the\n   422→      // opportunity\n   423→      // to create a new session in this request may be lost\n   424→      // This is to handle only the TradeScenarioServlet case\n   425→      session = req.getSession(true);\n   426→    }\n   427→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.WELCOME_PAGE));\n   428→  }\n   429→\n   430→  /**\n   431→   * Retrieve the current portfolio of stock holdings for the given trader\n   432→   * Dispatch to the Trade Portfolio JSP for display\n   433→   *\n   434→   * @param userID\n   435→   *            The User requesting to view their portfolio\n   436→   * @param ctx\n   437→   *            the servlet context\n   438→   * @param req\n   439→   *            the HttpRequest object\n   440→   * @param resp\n   441→   *            the HttpResponse object\n   442→   * @param results\n   443→   *            A short description of the results/success of this web request\n   444→   *            provided on the web page\n   445→   * @exception javax.servlet.ServletException\n   446→   *                If a servlet specific exception is encountered\n   447→   * @exception javax.io.IOException\n   448→   *                If an exception occurs while writing results back to the\n   449→   *                user\n   450→   *\n   451→   */\n   452→  void doPortfolio(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String results) throws ServletException, IOException {\n   453→\n   454→    try {\n   455→      // Get the holdiings for this user\n   456→\n   457→      Collection<QuoteDataBean> quoteDataBeans = new ArrayList<QuoteDataBean>();\n   458→      Collection<?> holdingDataBeans = tAction.getHoldings(userID);\n   459→\n   460→      // Walk through the collection of user\n   461→      // holdings and creating a list of quotes\n   462→      if (holdingDataBeans.size() > 0) {\n   463→\n   464→        Iterator<?> it = holdingDataBeans.iterator();\n   465→        while (it.hasNext()) {\n   466→          HoldingDataBean holdingData = (HoldingDataBean) it.next();\n   467→          QuoteDataBean quoteData = tAction.getQuote(holdingData.getQuoteID());\n   468→          quoteDataBeans.add(quoteData);\n   469→        }\n   470→      } else {\n   471→        results = results + \".  Your portfolio is empty.\";\n   472→      }\n   473→      req.setAttribute(\"results\", results);\n   474→      req.setAttribute(\"holdingDataBeans\", holdingDataBeans);\n   475→      req.setAttribute(\"quoteDataBeans\", quoteDataBeans);\n   476→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.PORTFOLIO_PAGE));\n   477→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   478→      // error so I will\n   479→      // forward them to another page rather than throw a 500\n   480→      req.setAttribute(\"results\", results + \"illegal argument:\" + e.getMessage());\n   481→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.PORTFOLIO_PAGE));\n   482→      // log the exception with an error level of 3 which means, handled\n   483→      // exception but would invalidate a automation run\n   484→      Log.error(e, \"TradeServletAction.doPortfolio(...)\", \"illegal argument, information should be in exception string\", \"user error\");\n   485→    } catch (Exception e) {\n   486→      // log the exception with error page\n   487→      throw new ServletException(\"TradeServletAction.doPortfolio(...)\" + \" exception user =\" + userID, e);\n   488→    }\n   489→  }\n   490→\n   491→  /**\n   492→   * Retrieve the current Quote for the given stock symbol Dispatch to the\n   493→   * Trade Quote JSP for display\n   494→   *\n   495→   * @param userID\n   496→   *            The stock symbol used to get the current quote\n   497→   * @param ctx\n   498→   *            the servlet context\n   499→   * @param req\n   500→   *            the HttpRequest object\n   501→   * @param resp\n   502→   *            the HttpResponse object\n   503→   * @exception javax.servlet.ServletException\n   504→   *                If a servlet specific exception is encountered\n   505→   * @exception javax.io.IOException\n   506→   *                If an exception occurs while writing results back to the\n   507→   *                user\n   508→   *\n   509→   */\n   510→  void doQuotes(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String symbols) throws ServletException, IOException {\n   511→\n   512→    try {\n   513→      Collection<QuoteDataBean> quoteDataBeans = new ArrayList<QuoteDataBean>();\n   514→      String[] symbolsSplit = symbols.split(\",\");\n   515→      for (String symbol: symbolsSplit) {\n   516→        QuoteDataBean quoteData = tAction.getQuote(symbol.trim());\n   517→        quoteDataBeans.add(quoteData);\n   518→      } \n   519→      req.setAttribute(\"quoteDataBeans\", quoteDataBeans);\n   520→      requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.QUOTE_PAGE));\n   521→\n   522→    } catch (Exception e) {\n   523→      // log the exception with error page\n   524→      throw new ServletException(\"TradeServletAction.doQuotes(...)\" + \" exception user =\" + userID, e);\n   525→    } \n   526→  }\n   527→\n   528→  /**\n   529→   * Register a new trader given the provided user Profile information such as\n   530→   * address, email, etc. Dispatch to the Trade Home JSP for display\n   531→   *\n   532→   * @param userID\n   533→   *            The User to create\n   534→   * @param passwd\n   535→   *            The User password\n   536→   * @param fullname\n   537→   *            The new User fullname info\n   538→   * @param ccn\n   539→   *            The new User credit card info\n   540→   * @param money\n   541→   *            The new User opening account balance\n   542→   * @param address\n   543→   *            The new User address info\n   544→   * @param email\n   545→   *            The new User email info\n   546→   * @return The userID of the new trader\n   547→   * @param ctx\n   548→   *            the servlet context\n   549→   * @param req\n   550→   *            the HttpRequest object\n   551→   * @param resp\n   552→   *            the HttpResponse object\n   553→   * @exception javax.servlet.ServletException\n   554→   *                If a servlet specific exception is encountered\n   555→   * @exception javax.io.IOException\n   556→   *                If an exception occurs while writing results back to the\n   557→   *                user\n   558→   *\n   559→   */\n   560→  void doRegister(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String passwd, String cpasswd, String fullname,\n   561→      String ccn, String openBalanceString, String email, String address) throws ServletException, IOException {\n   562→    String results = \"\";\n   563→\n   564→    try {\n   565→      // Validate user passwords match and are atleast 1 char in length\n   566→      if ((passwd.equals(cpasswd)) && (passwd.length() >= 1)) {\n   567→\n   568→        AccountDataBean accountData = tAction.register(userID, passwd, fullname, address, email, ccn, new BigDecimal(openBalanceString));\n   569→        if (accountData == null) {\n   570→          results = \"Registration operation failed;\";\n   571→          System.out.println(results);\n   572→          req.setAttribute(\"results\", results);\n   573→          requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.REGISTER_PAGE));\n   574→        } else {\n   575→          doLogin(ctx, req, resp, userID, passwd);\n   576→          results = \"Registration operation succeeded;  Account \" + accountData.getAccountID() + \" has been created.\";\n   577→          req.setAttribute(\"results\", results);\n   578→\n   579→        }\n   580→      } else {\n   581→        // Password validation failed\n   582→        results = \"Registration operation failed, your passwords did not match\";\n   583→        System.out.println(results);\n   584→        req.setAttribute(\"results\", results);\n   585→        requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.REGISTER_PAGE));\n   586→      }\n   587→\n   588→    } catch (Exception e) {\n   589→      // log the exception with error page\n   590→      throw new ServletException(\"TradeServletAction.doRegister(...)\" + \" exception user =\" + userID, e);\n   591→    }\n   592→  }\n   593→\n   594→  /**\n   595→   * Sell a current holding of stock shares for the given trader. Dispatch to\n   596→   * the Trade Portfolio JSP for display\n   597→   *\n   598→   * @param userID\n   599→   *            The User buying shares\n   600→   * @param symbol\n   601→   *            The stock to sell\n   602→   * @param indx\n   603→   *            The unique index identifying the users holding to sell\n   604→   * @param ctx\n   605→   *            the servlet context\n   606→   * @param req\n   607→   *            the HttpRequest object\n   608→   * @param resp\n   609→   *            the HttpResponse object\n   610→   * @exception javax.servlet.ServletException\n   611→   *                If a servlet specific exception is encountered\n   612→   * @exception javax.io.IOException\n   613→   *                If an exception occurs while writing results back to the\n   614→   *                user\n   615→   *\n   616→   */\n   617→  void doSell(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, Integer holdingID) throws ServletException, IOException {\n   618→    String results = \"\";\n   619→    try {\n   620→      OrderDataBean orderData = tAction.sell(userID, holdingID, TradeConfig.getOrderProcessingMode());\n   621→\n   622→      req.setAttribute(\"orderData\", orderData);\n   623→      req.setAttribute(\"results\", results);\n   624→    } catch (java.lang.IllegalArgumentException e) { // this is a user\n   625→      // error so I will\n   626→      // just log the exception and then later on I will redisplay the\n   627→      // portfolio page\n   628→      // because this is just a user exception\n   629→      Log.error(e, \"TradeServletAction.doSell(...)\", \"illegal argument, information should be in exception string\", \"user error\");\n   630→    } catch (Exception e) {\n   631→      // log the exception with error page\n   632→      throw new ServletException(\"TradeServletAction.doSell(...)\" + \" exception selling holding \" + holdingID + \" for user =\" + userID, e);\n   633→    }\n   634→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.ORDER_PAGE));\n   635→  }\n   636→\n   637→  void doWelcome(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String status) throws ServletException, IOException {\n   638→\n   639→    req.setAttribute(\"results\", status);\n   640→    requestDispatch(ctx, req, resp, null, TradeConfig.getPage(TradeConfig.WELCOME_PAGE));\n   641→  }\n   642→\n   643→  private void requestDispatch(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID, String page) throws ServletException,\n   644→  IOException {\n   645→\n   646→    ctx.getRequestDispatcher(page).include(req, resp);\n   647→  }\n   648→\n   649→  void doMarketSummary(ServletContext ctx, HttpServletRequest req, HttpServletResponse resp, String userID) throws ServletException, IOException {\n   650→    req.setAttribute(\"results\", \"test\");\n   651→    requestDispatch(ctx, req, resp, userID, TradeConfig.getPage(TradeConfig.MARKET_SUMMARY_PAGE));\n   652→\n   653→  }\n   654→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_