{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01E95UmrRMASNLV6wj88x2fB","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.beans;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.util.ArrayList;\n    21→import java.util.Collection;\n    22→import java.util.Date;\n    23→import java.util.Iterator;\n    24→\n    25→import javax.json.Json;\n    26→import javax.json.JsonObject;\n    27→import javax.json.JsonObjectBuilder;\n    28→\n    29→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    30→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    31→import com.ibm.websphere.samples.daytrader.util.Log;\n    32→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    33→\n    34→public class MarketSummaryDataBean implements Serializable {\n    35→\n    36→    private static final long serialVersionUID = 650652242288745600L;\n    37→    private BigDecimal TSIA; /* Trade Stock Index Average */\n    38→    private BigDecimal openTSIA; /* Trade Stock Index Average at the open */\n    39→    private double volume; /* volume of shares traded */\n    40→    private Collection<QuoteDataBean> topGainers; /*\n    41→                                                   * Collection of top gaining\n    42→                                                   * stocks\n    43→                                                   */\n    44→    private Collection<QuoteDataBean> topLosers; /*\n    45→                                                  * Collection of top losing\n    46→                                                  * stocks\n    47→                                                  */\n    48→    // FUTURE private Collection topVolume; /* Collection of top stocks by\n    49→    // volume */\n    50→    private Date summaryDate; /* Date this summary was taken */\n    51→\n    52→    // cache the gainPercent once computed for this bean\n    53→    private BigDecimal gainPercent = null;\n    54→\n    55→    public MarketSummaryDataBean() {\n    56→    }\n    57→\n    58→    public MarketSummaryDataBean(BigDecimal TSIA, BigDecimal openTSIA, double volume, Collection<QuoteDataBean> topGainers, Collection<QuoteDataBean> topLosers// , Collection topVolume\n    59→    ) {\n    60→        setTSIA(TSIA);\n    61→        setOpenTSIA(openTSIA);\n    62→        setVolume(volume);\n    63→        setTopGainers(topGainers);\n    64→        setTopLosers(topLosers);\n    65→        setSummaryDate(new java.sql.Date(System.currentTimeMillis()));\n    66→        gainPercent = FinancialUtils.computeGainPercent(getTSIA(), getOpenTSIA());\n    67→\n    68→    }\n    69→\n    70→    public static MarketSummaryDataBean getRandomInstance() {\n    71→        Collection<QuoteDataBean> gain = new ArrayList<QuoteDataBean>();\n    72→        Collection<QuoteDataBean> lose = new ArrayList<QuoteDataBean>();\n    73→\n    74→        for (int ii = 0; ii < 5; ii++) {\n    75→            QuoteDataBean quote1 = QuoteDataBean.getRandomInstance();\n    76→            QuoteDataBean quote2 = QuoteDataBean.getRandomInstance();\n    77→\n    78→            gain.add(quote1);\n    79→            lose.add(quote2);\n    80→        }\n    81→\n    82→        return new MarketSummaryDataBean(TradeConfig.rndBigDecimal(1000000.0f), TradeConfig.rndBigDecimal(1000000.0f), TradeConfig.rndQuantity(), gain, lose);\n    83→    }\n    84→\n    85→    @Override\n    86→    public String toString() {\n    87→        String ret = \"\\n\\tMarket Summary at: \" + getSummaryDate() + \"\\n\\t\\t        TSIA:\" + getTSIA() + \"\\n\\t\\t    openTSIA:\" + getOpenTSIA()\n    88→                + \"\\n\\t\\t        gain:\" + getGainPercent() + \"\\n\\t\\t      volume:\" + getVolume();\n    89→\n    90→        if ((getTopGainers() == null) || (getTopLosers() == null)) {\n    91→            return ret;\n    92→        }\n    93→        ret += \"\\n\\t\\t   Current Top Gainers:\";\n    94→        Iterator<QuoteDataBean> it = getTopGainers().iterator();\n    95→        while (it.hasNext()) {\n    96→            QuoteDataBean quoteData = it.next();\n    97→            ret += (\"\\n\\t\\t\\t\" + quoteData.toString());\n    98→        }\n    99→        ret += \"\\n\\t\\t   Current Top Losers:\";\n   100→        it = getTopLosers().iterator();\n   101→        while (it.hasNext()) {\n   102→            QuoteDataBean quoteData = it.next();\n   103→            ret += (\"\\n\\t\\t\\t\" + quoteData.toString());\n   104→        }\n   105→        return ret;\n   106→    }\n   107→\n   108→    public String toHTML() {\n   109→        String ret = \"<BR>Market Summary at: \" + getSummaryDate() + \"<LI>        TSIA:\" + getTSIA() + \"</LI>\" + \"<LI>    openTSIA:\" + getOpenTSIA() + \"</LI>\"\n   110→                + \"<LI>      volume:\" + getVolume() + \"</LI>\";\n   111→        if ((getTopGainers() == null) || (getTopLosers() == null)) {\n   112→            return ret;\n   113→        }\n   114→        ret += \"<BR> Current Top Gainers:\";\n   115→        Iterator<QuoteDataBean> it = getTopGainers().iterator();\n   116→\n   117→        while (it.hasNext()) {\n   118→            QuoteDataBean quoteData = it.next();\n   119→            ret += (\"<LI>\" + quoteData.toString() + \"</LI>\");\n   120→        }\n   121→        ret += \"<BR>   Current Top Losers:\";\n   122→        it = getTopLosers().iterator();\n   123→        while (it.hasNext()) {\n   124→            QuoteDataBean quoteData = it.next();\n   125→            ret += (\"<LI>\" + quoteData.toString() + \"</LI>\");\n   126→        }\n   127→        return ret;\n   128→    }\n   129→\n   130→    public JsonObject toJSON() {\n   131→        \n   132→        JsonObjectBuilder jObjectBuilder = Json.createObjectBuilder();\n   133→        \n   134→        int i = 1;\n   135→        for (Iterator<QuoteDataBean> iterator = topGainers.iterator(); iterator.hasNext();) {\n   136→            QuoteDataBean quote = iterator.next();\n   137→\n   138→            jObjectBuilder.add(\"gainer\" + i + \"_stock\",quote.getSymbol());\n   139→            jObjectBuilder.add(\"gainer\" + i + \"_price\",\"$\" + quote.getPrice());\n   140→            jObjectBuilder.add(\"gainer\" + i + \"_change\",quote.getChange());\n   141→            i++;\n   142→        }\n   143→\n   144→        i = 1;\n   145→        for (Iterator<QuoteDataBean> iterator = topLosers.iterator(); iterator.hasNext();) {\n   146→            QuoteDataBean quote = iterator.next();\n   147→\n   148→            jObjectBuilder.add(\"loser\" + i + \"_stock\",quote.getSymbol());\n   149→            jObjectBuilder.add(\"loser\" + i + \"_price\",\"$\" + quote.getPrice());\n   150→            jObjectBuilder.add(\"loser\" + i + \"_change\",quote.getChange());\n   151→            i++;\n   152→        }\n   153→\n   154→        jObjectBuilder.add(\"tsia\", TSIA);\n   155→        jObjectBuilder.add(\"volume\",volume);\n   156→        jObjectBuilder.add(\"date\", summaryDate.toString());\n   157→\n   158→        return jObjectBuilder.build();\n   159→        \n   160→    }\n   161→\n   162→    public void print() {\n   163→        Log.log(this.toString());\n   164→    }\n   165→\n   166→    public BigDecimal getGainPercent() {\n   167→        if (gainPercent == null) {\n   168→            gainPercent = FinancialUtils.computeGainPercent(getTSIA(), getOpenTSIA());\n   169→        }\n   170→        return gainPercent;\n   171→    }\n   172→\n   173→    /**\n   174→     * Gets the tSIA\n   175→     *\n   176→     * @return Returns a BigDecimal\n   177→     */\n   178→    public BigDecimal getTSIA() {\n   179→        return TSIA;\n   180→    }\n   181→\n   182→    /**\n   183→     * Sets the tSIA\n   184→     *\n   185→     * @param tSIA\n   186→     *            The tSIA to set\n   187→     */\n   188→    public void setTSIA(BigDecimal tSIA) {\n   189→        TSIA = tSIA;\n   190→    }\n   191→\n   192→    /**\n   193→     * Gets the openTSIA\n   194→     *\n   195→     * @return Returns a BigDecimal\n   196→     */\n   197→    public BigDecimal getOpenTSIA() {\n   198→        return openTSIA;\n   199→    }\n   200→\n   201→    /**\n   202→     * Sets the openTSIA\n   203→     *\n   204→     * @param openTSIA\n   205→     *            The openTSIA to set\n   206→     */\n   207→    public void setOpenTSIA(BigDecimal openTSIA) {\n   208→        this.openTSIA = openTSIA;\n   209→    }\n   210→\n   211→    /**\n   212→     * Gets the volume\n   213→     *\n   214→     * @return Returns a BigDecimal\n   215→     */\n   216→    public double getVolume() {\n   217→        return volume;\n   218→    }\n   219→\n   220→    /**\n   221→     * Sets the volume\n   222→     *\n   223→     * @param volume\n   224→     *            The volume to set\n   225→     */\n   226→    public void setVolume(double volume) {\n   227→        this.volume = volume;\n   228→    }\n   229→\n   230→    /**\n   231→     * Gets the topGainers\n   232→     *\n   233→     * @return Returns a Collection\n   234→     */\n   235→    public Collection<QuoteDataBean> getTopGainers() {\n   236→        return topGainers;\n   237→    }\n   238→\n   239→    /**\n   240→     * Sets the topGainers\n   241→     *\n   242→     * @param topGainers\n   243→     *            The topGainers to set\n   244→     */\n   245→    public void setTopGainers(Collection<QuoteDataBean> topGainers) {\n   246→        this.topGainers = topGainers;\n   247→    }\n   248→\n   249→    /**\n   250→     * Gets the topLosers\n   251→     *\n   252→     * @return Returns a Collection\n   253→     */\n   254→    public Collection<QuoteDataBean> getTopLosers() {\n   255→        return topLosers;\n   256→    }\n   257→\n   258→    /**\n   259→     * Sets the topLosers\n   260→     *\n   261→     * @param topLosers\n   262→     *            The topLosers to set\n   263→     */\n   264→    public void setTopLosers(Collection<QuoteDataBean> topLosers) {\n   265→        this.topLosers = topLosers;\n   266→    }\n   267→\n   268→    /**\n   269→     * Gets the summaryDate\n   270→     *\n   271→     * @return Returns a Date\n   272→     */\n   273→    public Date getSummaryDate() {\n   274→        return summaryDate;\n   275→    }\n   276→\n   277→    /**\n   278→     * Sets the summaryDate\n   279→     *\n   280→     * @param summaryDate\n   281→     *            The summaryDate to set\n   282→     */\n   283→    public void setSummaryDate(Date summaryDate) {\n   284→        this.summaryDate = summaryDate;\n   285→    }\n   286→\n   287→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"c30f8815-449b-492b-a118-eac02c0d1a6e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01NZASaz2DvLG1riCjVFLvtS","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.beans;\n    17→\n    18→import java.io.Serializable;\n    19→\n    20→public class RunStatsDataBean implements Serializable {\n    21→    private static final long serialVersionUID = 4017778674103242167L;\n    22→\n    23→    // Constructors\n    24→    public RunStatsDataBean() {\n    25→    }\n    26→\n    27→    // count of trade users in the database (users w/ userID like 'uid:%')\n    28→    private int tradeUserCount;\n    29→    // count of trade stocks in the database (stocks w/ symbol like 's:%')\n    30→    private int tradeStockCount;\n    31→\n    32→    // count of new registered users in this run (users w/ userID like 'ru:%')\n    33→    // -- random user\n    34→    private int newUserCount;\n    35→\n    36→    // sum of logins by trade users\n    37→    private int sumLoginCount;\n    38→    // sum of logouts by trade users\n    39→    private int sumLogoutCount;\n    40→\n    41→    // count of holdings of trade users\n    42→    private int holdingCount;\n    43→\n    44→    // count of orders of trade users\n    45→    private int orderCount;\n    46→    // count of buy orders of trade users\n    47→    private int buyOrderCount;\n    48→    // count of sell orders of trade users\n    49→    private int sellOrderCount;\n    50→    // count of cancelled orders of trade users\n    51→    private int cancelledOrderCount;\n    52→    // count of open orders of trade users\n    53→    private int openOrderCount;\n    54→    // count of orders deleted during this trade Reset\n    55→    private int deletedOrderCount;\n    56→\n    57→    @Override\n    58→    public String toString() {\n    59→        return \"\\n\\tRunStatsData for reset at \" + new java.util.Date() + \"\\n\\t\\t      tradeUserCount: \" + getTradeUserCount() + \"\\n\\t\\t        newUserCount: \"\n    60→                + getNewUserCount() + \"\\n\\t\\t       sumLoginCount: \" + getSumLoginCount() + \"\\n\\t\\t      sumLogoutCount: \" + getSumLogoutCount()\n    61→                + \"\\n\\t\\t        holdingCount: \" + getHoldingCount() + \"\\n\\t\\t          orderCount: \" + getOrderCount() + \"\\n\\t\\t       buyOrderCount: \"\n    62→                + getBuyOrderCount() + \"\\n\\t\\t      sellOrderCount: \" + getSellOrderCount() + \"\\n\\t\\t cancelledOrderCount: \" + getCancelledOrderCount()\n    63→                + \"\\n\\t\\t      openOrderCount: \" + getOpenOrderCount() + \"\\n\\t\\t   deletedOrderCount: \" + getDeletedOrderCount();\n    64→    }\n    65→\n    66→    /**\n    67→     * Gets the tradeUserCount\n    68→     *\n    69→     * @return Returns a int\n    70→     */\n    71→    public int getTradeUserCount() {\n    72→        return tradeUserCount;\n    73→    }\n    74→\n    75→    /**\n    76→     * Sets the tradeUserCount\n    77→     *\n    78→     * @param tradeUserCount\n    79→     *            The tradeUserCount to set\n    80→     */\n    81→    public void setTradeUserCount(int tradeUserCount) {\n    82→        this.tradeUserCount = tradeUserCount;\n    83→    }\n    84→\n    85→    /**\n    86→     * Gets the newUserCount\n    87→     *\n    88→     * @return Returns a int\n    89→     */\n    90→    public int getNewUserCount() {\n    91→        return newUserCount;\n    92→    }\n    93→\n    94→    /**\n    95→     * Sets the newUserCount\n    96→     *\n    97→     * @param newUserCount\n    98→     *            The newUserCount to set\n    99→     */\n   100→    public void setNewUserCount(int newUserCount) {\n   101→        this.newUserCount = newUserCount;\n   102→    }\n   103→\n   104→    /**\n   105→     * Gets the sumLoginCount\n   106→     *\n   107→     * @return Returns a int\n   108→     */\n   109→    public int getSumLoginCount() {\n   110→        return sumLoginCount;\n   111→    }\n   112→\n   113→    /**\n   114→     * Sets the sumLoginCount\n   115→     *\n   116→     * @param sumLoginCount\n   117→     *            The sumLoginCount to set\n   118→     */\n   119→    public void setSumLoginCount(int sumLoginCount) {\n   120→        this.sumLoginCount = sumLoginCount;\n   121→    }\n   122→\n   123→    /**\n   124→     * Gets the sumLogoutCount\n   125→     *\n   126→     * @return Returns a int\n   127→     */\n   128→    public int getSumLogoutCount() {\n   129→        return sumLogoutCount;\n   130→    }\n   131→\n   132→    /**\n   133→     * Sets the sumLogoutCount\n   134→     *\n   135→     * @param sumLogoutCount\n   136→     *            The sumLogoutCount to set\n   137→     */\n   138→    public void setSumLogoutCount(int sumLogoutCount) {\n   139→        this.sumLogoutCount = sumLogoutCount;\n   140→    }\n   141→\n   142→    /**\n   143→     * Gets the holdingCount\n   144→     *\n   145→     * @return Returns a int\n   146→     */\n   147→    public int getHoldingCount() {\n   148→        return holdingCount;\n   149→    }\n   150→\n   151→    /**\n   152→     * Sets the holdingCount\n   153→     *\n   154→     * @param holdingCount\n   155→     *            The holdingCount to set\n   156→     */\n   157→    public void setHoldingCount(int holdingCount) {\n   158→        this.holdingCount = holdingCount;\n   159→    }\n   160→\n   161→    /**\n   162→     * Gets the buyOrderCount\n   163→     *\n   164→     * @return Returns a int\n   165→     */\n   166→    public int getBuyOrderCount() {\n   167→        return buyOrderCount;\n   168→    }\n   169→\n   170→    /**\n   171→     * Sets the buyOrderCount\n   172→     *\n   173→     * @param buyOrderCount\n   174→     *            The buyOrderCount to set\n   175→     */\n   176→    public void setBuyOrderCount(int buyOrderCount) {\n   177→        this.buyOrderCount = buyOrderCount;\n   178→    }\n   179→\n   180→    /**\n   181→     * Gets the sellOrderCount\n   182→     *\n   183→     * @return Returns a int\n   184→     */\n   185→    public int getSellOrderCount() {\n   186→        return sellOrderCount;\n   187→    }\n   188→\n   189→    /**\n   190→     * Sets the sellOrderCount\n   191→     *\n   192→     * @param sellOrderCount\n   193→     *            The sellOrderCount to set\n   194→     */\n   195→    public void setSellOrderCount(int sellOrderCount) {\n   196→        this.sellOrderCount = sellOrderCount;\n   197→    }\n   198→\n   199→    /**\n   200→     * Gets the cancelledOrderCount\n   201→     *\n   202→     * @return Returns a int\n   203→     */\n   204→    public int getCancelledOrderCount() {\n   205→        return cancelledOrderCount;\n   206→    }\n   207→\n   208→    /**\n   209→     * Sets the cancelledOrderCount\n   210→     *\n   211→     * @param cancelledOrderCount\n   212→     *            The cancelledOrderCount to set\n   213→     */\n   214→    public void setCancelledOrderCount(int cancelledOrderCount) {\n   215→        this.cancelledOrderCount = cancelledOrderCount;\n   216→    }\n   217→\n   218→    /**\n   219→     * Gets the openOrderCount\n   220→     *\n   221→     * @return Returns a int\n   222→     */\n   223→    public int getOpenOrderCount() {\n   224→        return openOrderCount;\n   225→    }\n   226→\n   227→    /**\n   228→     * Sets the openOrderCount\n   229→     *\n   230→     * @param openOrderCount\n   231→     *            The openOrderCount to set\n   232→     */\n   233→    public void setOpenOrderCount(int openOrderCount) {\n   234→        this.openOrderCount = openOrderCount;\n   235→    }\n   236→\n   237→    /**\n   238→     * Gets the deletedOrderCount\n   239→     *\n   240→     * @return Returns a int\n   241→     */\n   242→    public int getDeletedOrderCount() {\n   243→        return deletedOrderCount;\n   244→    }\n   245→\n   246→    /**\n   247→     * Sets the deletedOrderCount\n   248→     *\n   249→     * @param deletedOrderCount\n   250→     *            The deletedOrderCount to set\n   251→     */\n   252→    public void setDeletedOrderCount(int deletedOrderCount) {\n   253→        this.deletedOrderCount = deletedOrderCount;\n   254→    }\n   255→\n   256→    /**\n   257→     * Gets the orderCount\n   258→     *\n   259→     * @return Returns a int\n   260→     */\n   261→    public int getOrderCount() {\n   262→        return orderCount;\n   263→    }\n   264→\n   265→    /**\n   266→     * Sets the orderCount\n   267→     *\n   268→     * @param orderCount\n   269→     *            The orderCount to set\n   270→     */\n   271→    public void setOrderCount(int orderCount) {\n   272→        this.orderCount = orderCount;\n   273→    }\n   274→\n   275→    /**\n   276→     * Gets the tradeStockCount\n   277→     *\n   278→     * @return Returns a int\n   279→     */\n   280→    public int getTradeStockCount() {\n   281→        return tradeStockCount;\n   282→    }\n   283→\n   284→    /**\n   285→     * Sets the tradeStockCount\n   286→     *\n   287→     * @param tradeStockCount\n   288→     *            The tradeStockCount to set\n   289→     */\n   290→    public void setTradeStockCount(int tradeStockCount) {\n   291→        this.tradeStockCount = tradeStockCount;\n   292→    }\n   293→\n   294→}\n   295→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"1a85f286-cd5d-403d-8bc1-a669b3b598f1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01DQth49jenPAwvUxvPFZuAq","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.ArrayList;\n    20→import java.util.List;\n    21→\n    22→import javax.annotation.Resource;\n    23→import javax.ejb.Lock;\n    24→import javax.ejb.LockType;\n    25→import javax.ejb.Schedule;\n    26→import javax.ejb.Singleton;\n    27→import javax.enterprise.concurrent.ManagedExecutorService;\n    28→import javax.enterprise.event.Event;\n    29→import javax.enterprise.event.NotificationOptions;\n    30→import javax.inject.Inject;\n    31→import javax.json.JsonObject;\n    32→import javax.persistence.EntityManager;\n    33→import javax.persistence.PersistenceContext;\n    34→import javax.persistence.TypedQuery;\n    35→import javax.persistence.criteria.CriteriaBuilder;\n    36→import javax.persistence.criteria.CriteriaQuery;\n    37→import javax.persistence.criteria.Root;\n    38→\n    39→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    40→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    41→import com.ibm.websphere.samples.daytrader.interfaces.MarketSummaryUpdate;\n    42→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    43→import com.ibm.websphere.samples.daytrader.util.Log;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    45→\n    46→@Singleton\n    47→public class MarketSummarySingleton {\n    48→\n    49→  private MarketSummaryDataBean marketSummaryDataBean;\n    50→\n    51→  @PersistenceContext\n    52→  private EntityManager entityManager;\n    53→  \n    54→  @Inject\n    55→  @MarketSummaryUpdate\n    56→  Event<String> mkSummaryUpdateEvent;\n    57→  \n    58→  @Resource\n    59→  private ManagedExecutorService mes;\n    60→  \n    61→\n    62→  /* Update Market Summary every 20 seconds */\n    63→  @Schedule(second = \"*/20\",minute = \"*\", hour = \"*\", persistent = false)\n    64→  private void updateMarketSummary() { \n    65→\n    66→\n    67→    Log.trace(\"MarketSummarySingleton:updateMarketSummary -- updating market summary\");\n    68→\n    69→\n    70→    if (TradeConfig.getRunTimeMode() != TradeConfig.EJB3)\n    71→    {\n    72→      Log.trace(\"MarketSummarySingleton:updateMarketSummary -- Not EJB3 Mode, so not updating\");\n    73→      return; // Only do the actual work if in EJB3 Mode\n    74→    }\n    75→\n    76→    List<QuoteDataBean> quotes;\n    77→\n    78→    try {        \n    79→      // Find Trade Stock Index Quotes (Top 100 quotes) ordered by their change in value\n    80→      CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n    81→      CriteriaQuery<QuoteDataBean> criteriaQuery = criteriaBuilder.createQuery(QuoteDataBean.class);\n    82→      Root<QuoteDataBean> quoteRoot = criteriaQuery.from(QuoteDataBean.class);\n    83→      criteriaQuery.orderBy(criteriaBuilder.desc(quoteRoot.get(\"change1\")));\n    84→      criteriaQuery.select(quoteRoot);\n    85→      TypedQuery<QuoteDataBean> q = entityManager.createQuery(criteriaQuery);\n    86→      quotes = q.getResultList();\n    87→    } catch (Exception e) {\n    88→      Log.debug(\"Warning: The database has not been configured. If this is the first time the application has been started, please create and populate the database tables. Then restart the server.\");\n    89→      return;\n    90→    }\t\n    91→\n    92→    /* TODO: Make this cleaner? */\n    93→    QuoteDataBean[] quoteArray = quotes.toArray(new QuoteDataBean[quotes.size()]);\n    94→    ArrayList<QuoteDataBean> topGainers = new ArrayList<QuoteDataBean>(5);\n    95→    ArrayList<QuoteDataBean> topLosers = new ArrayList<QuoteDataBean>(5);\n    96→    BigDecimal TSIA = FinancialUtils.ZERO;\n    97→    BigDecimal openTSIA = FinancialUtils.ZERO;\n    98→    double totalVolume = 0.0;\n    99→\n   100→    if (quoteArray.length > 5) {\n   101→      for (int i = 0; i < 5; i++) {\n   102→        topGainers.add(quoteArray[i]);\n   103→      }\n   104→      for (int i = quoteArray.length - 1; i >= quoteArray.length - 5; i--) {\n   105→        topLosers.add(quoteArray[i]);\n   106→      }\n   107→\n   108→      for (QuoteDataBean quote : quoteArray) {\n   109→        BigDecimal price = quote.getPrice();\n   110→        BigDecimal open = quote.getOpen();\n   111→        double volume = quote.getVolume();\n   112→        TSIA = TSIA.add(price);\n   113→        openTSIA = openTSIA.add(open);\n   114→        totalVolume += volume;\n   115→      }\n   116→      TSIA = TSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   117→      openTSIA = openTSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   118→    }\n   119→\n   120→    setMarketSummaryDataBean(new MarketSummaryDataBean(TSIA, openTSIA, totalVolume, topGainers, topLosers));\n   121→    mkSummaryUpdateEvent.fireAsync(\"MarketSummaryUpdate\", NotificationOptions.builder().setExecutor(mes).build());\n   122→  }\n   123→\n   124→  @Lock(LockType.READ)\n   125→  public MarketSummaryDataBean getMarketSummaryDataBean() { \n   126→    if (marketSummaryDataBean == null){\n   127→      updateMarketSummary();\n   128→    }\n   129→\n   130→    return marketSummaryDataBean;\n   131→  }\n   132→\n   133→  @Lock(LockType.WRITE)\n   134→  public void setMarketSummaryDataBean(MarketSummaryDataBean marketSummaryDataBean) {\n   135→    this.marketSummaryDataBean = marketSummaryDataBean;\n   136→  }\n   137→\n   138→}\n   139→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"96411bde-9c3a-474c-98ad-6b69bd760536"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WUiayzQz7iP5V4n1QWyuJ2","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→\n    19→import javax.enterprise.context.Dependent;\n    20→import javax.enterprise.inject.Any;\n    21→import javax.enterprise.inject.Instance;\n    22→import javax.inject.Inject;\n    23→\n    24→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    25→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    26→import com.ibm.websphere.samples.daytrader.util.TradeRunTimeModeLiteral;\n    27→\n    28→\n    29→@Dependent\n    30→public class AsyncScheduledOrder implements Runnable {\n    31→\n    32→  TradeServices tradeService;\n    33→\n    34→  Integer orderID;\n    35→  boolean twoPhase;\n    36→\n    37→  @Inject \n    38→  public AsyncScheduledOrder(@Any Instance<TradeServices> services) {\n    39→    tradeService = services.select(new TradeRunTimeModeLiteral(TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()])).get();\n    40→  }\n    41→\n    42→  public void setProperties(Integer orderID, boolean twoPhase) {\n    43→    this.orderID = orderID;\n    44→    this.twoPhase =  twoPhase;\n    45→  }     \n    46→\n    47→  @Override\n    48→  public void run() {\n    49→\n    50→\n    51→    try {  \n    52→      tradeService.completeOrder(orderID, twoPhase);      \n    53→\n    54→    } catch (Exception e) {\n    55→\n    56→      e.printStackTrace();\n    57→    }\n    58→  }\n    59→}\n    60→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"0de87932-9bb5-4e98-97fe-6f03ca911578"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_013nrZ6AXPFThfGWvrCrjRnc","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import java.util.concurrent.Future;\n    19→import java.util.concurrent.TimeUnit;\n    20→\n    21→import javax.annotation.Resource;\n    22→import javax.enterprise.concurrent.ManagedScheduledExecutorService;\n    23→import javax.enterprise.context.RequestScoped;\n    24→import javax.inject.Inject;\n    25→\n    26→@RequestScoped\n    27→public class AsyncScheduledOrderSubmitter {\n    28→  \n    29→  \n    30→  @Resource\n    31→  private ManagedScheduledExecutorService mes;\n    32→\n    33→  @Inject\n    34→  private AsyncScheduledOrder asyncOrder;\n    35→  \n    36→  \n    37→  public Future<?> submitOrder(Integer orderID, boolean twoPhase) {\n    38→    asyncOrder.setProperties(orderID,twoPhase);\n    39→    return mes.schedule(asyncOrder,500,TimeUnit.MILLISECONDS);\n    40→  }\n    41→}\n    42→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"314a1775-d6b7-4ab5-aec1-2712a18c6808"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01P7C9KPhVbPrETaAP1LaE4M","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.sql.Connection;\n    21→import java.sql.PreparedStatement;\n    22→import java.sql.ResultSet;\n    23→import java.sql.SQLException;\n    24→import java.sql.Statement;\n    25→import java.sql.Timestamp;\n    26→import java.util.ArrayList;\n    27→import java.util.Collection;\n    28→import java.util.concurrent.Future;\n    29→\n    30→import javax.annotation.Resource;\n    31→import javax.enterprise.concurrent.ManagedExecutorService;\n    32→import javax.enterprise.context.Dependent;\n    33→import javax.enterprise.event.Event;\n    34→import javax.enterprise.event.NotificationOptions;\n    35→import javax.inject.Inject;\n    36→import javax.jms.JMSContext;\n    37→import javax.jms.JMSException;\n    38→import javax.jms.Queue;\n    39→import javax.jms.QueueConnectionFactory;\n    40→import javax.jms.TextMessage;\n    41→import javax.jms.Topic;\n    42→import javax.jms.TopicConnectionFactory;\n    43→import javax.sql.DataSource;\n    44→import javax.transaction.UserTransaction;\n    45→import javax.validation.constraints.NotNull;\n    46→\n    47→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    48→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    49→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    50→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    51→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    52→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    53→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    54→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    55→import com.ibm.websphere.samples.daytrader.util.Log;\n    56→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    57→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    58→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    59→import com.ibm.websphere.samples.daytrader.interfaces.MarketSummaryUpdate;\n    60→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    61→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    62→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    63→\n    64→/**\n    65→ * TradeDirect uses direct JDBC and JMS access to a\n    66→ * <code>javax.sql.DataSource</code> to implement the business methods of the\n    67→ * Trade online broker application. These business methods represent the\n    68→ * features and operations that can be performed by customers of the brokerage\n    69→ * such as login, logout, get a stock quote, buy or sell a stock, etc. and are\n    70→ * specified in the {@link com.ibm.websphere.samples.daytrader.TradeServices}\n    71→ * interface\n    72→ *\n    73→ * Note: In order for this class to be thread-safe, a new TradeJDBC must be\n    74→ * created for each call to a method from the TradeInterface interface.\n    75→ * Otherwise, pooled connections may not be released.\n    76→ *\n    77→ * @see com.ibm.websphere.samples.daytrader.TradeServices\n    78→ *\n    79→ */\n    80→\n    81→@Dependent\n    82→@TradeJDBC\n    83→@RuntimeMode(\"Direct (JDBC)\")\n    84→@Trace\n    85→public class TradeDirect implements TradeServices, Serializable {\n    86→  /**\n    87→   * \n    88→   */\n    89→  private static final long serialVersionUID = -8089049090952927985L;\n    90→\n    91→  //This lock is used to serialize market summary operations.\n    92→  private static final Integer marketSummaryLock = new Integer(0);\n    93→  private static long nextMarketSummary = System.currentTimeMillis();\n    94→  private static MarketSummaryDataBean cachedMSDB = MarketSummaryDataBean.getRandomInstance();\n    95→\n    96→  private static BigDecimal ZERO = new BigDecimal(0.0);\n    97→  private boolean inGlobalTxn = false;\n    98→  private boolean inSession = false;\n    99→\n   100→  // For Wildfly - add java:/ to these resource names.\n   101→\n   102→  @Resource(name = \"jms/QueueConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n   103→  //@Resource(name = \"java:/jms/QueueConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n   104→  private QueueConnectionFactory queueConnectionFactory;\n   105→\n   106→  @Resource(name = \"jms/TopicConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n   107→  //@Resource(name = \"java:/jms/TopicConnectionFactory\", authenticationType = javax.annotation.Resource.AuthenticationType.APPLICATION)\n   108→  private TopicConnectionFactory topicConnectionFactory;\n   109→\n   110→  @Resource(lookup = \"jms/TradeStreamerTopic\")\n   111→  //@Resource(lookup = \"java:/jms/TradeStreamerTopic\")\n   112→  private Topic tradeStreamerTopic;\n   113→\n   114→  @Resource(lookup = \"jms/TradeBrokerQueue\")\n   115→  //@Resource(lookup = \"java:/jms/TradeBrokerQueue\")\n   116→  private Queue tradeBrokerQueue;\n   117→\n   118→  @Resource(lookup = \"jdbc/TradeDataSource\")\n   119→  //@Resource(lookup = \"java:/jdbc/TradeDataSource\")\n   120→  private DataSource datasource;\n   121→\n   122→  @Resource\n   123→  private  UserTransaction txn;\n   124→\n   125→  @Inject\n   126→  RecentQuotePriceChangeList recentQuotePriceChangeList;\n   127→  \n   128→  @Inject \n   129→  AsyncOrderSubmitter asyncOrderSubmitter;  \n   130→  \n   131→  @Inject\n   132→  @MarketSummaryUpdate\n   133→  Event<String> mkSummaryUpdateEvent;\n   134→  \n   135→  @Resource\n   136→  private ManagedExecutorService mes;\n   137→  \n   138→\n   139→  @Override\n   140→  public MarketSummaryDataBean getMarketSummary() throws Exception {\n   141→\n   142→    if (TradeConfig.getMarketSummaryInterval() == 0) {\n   143→      return getMarketSummaryInternal();\n   144→    }\n   145→    if (TradeConfig.getMarketSummaryInterval() < 0) {\n   146→      return cachedMSDB;\n   147→    }\n   148→\n   149→    /**\n   150→     * This is a little funky. If its time to fetch a new Market summary\n   151→     * then we'll synchronize access to make sure only one requester does\n   152→     * it. Others will merely return the old copy until the new\n   153→     * MarketSummary has been executed.\n   154→     */\n   155→\n   156→    long currentTime = System.currentTimeMillis();\n   157→\n   158→    if (currentTime > nextMarketSummary) {\n   159→      long oldNextMarketSummary = nextMarketSummary;\n   160→      boolean fetch = false;\n   161→\n   162→      synchronized (marketSummaryLock) {\n   163→        /**\n   164→         * Is it still ahead or did we miss lose the race? If we lost\n   165→         * then let's get out of here as the work has already been done.\n   166→         */\n   167→        if (oldNextMarketSummary == nextMarketSummary) {\n   168→          fetch = true;\n   169→          nextMarketSummary += TradeConfig.getMarketSummaryInterval() * 1000;\n   170→\n   171→          /**\n   172→           * If the server has been idle for a while then its possible\n   173→           * that nextMarketSummary could be way off. Rather than try\n   174→           * and play catch up we'll simply get in sync with the\n   175→           * current time + the interval.\n   176→           */\n   177→          if (nextMarketSummary < currentTime) {\n   178→            nextMarketSummary = currentTime + TradeConfig.getMarketSummaryInterval() * 1000;\n   179→          }\n   180→        }\n   181→      }\n   182→\n   183→      /**\n   184→       * If we're the lucky one then let's update the MarketSummary\n   185→       */\n   186→      if (fetch) {\n   187→        cachedMSDB = getMarketSummaryInternal();\n   188→  \n   189→      }\n   190→    }\n   191→\n   192→    return cachedMSDB;\n   193→  }\n   194→\n   195→\n   196→\n   197→  /**\n   198→   * @see TradeServices#getMarketSummary()\n   199→   */\n   200→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"907243d0-1d45-4e9c-8665-6f3eed4e77f2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_018NEhQMVreqd1BhJrq3qVyz","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.BufferedReader;\n    19→import java.io.IOException;\n    20→import java.io.InputStream;\n    21→import java.io.InputStreamReader;\n    22→import java.math.BigDecimal;\n    23→import java.sql.Connection;\n    24→import java.sql.DatabaseMetaData;\n    25→import java.sql.PreparedStatement;\n    26→import java.sql.ResultSet;\n    27→import java.sql.SQLException;\n    28→import java.sql.Statement;\n    29→import java.util.ArrayList;\n    30→\n    31→import javax.annotation.Resource;\n    32→import javax.enterprise.context.ApplicationScoped;\n    33→import javax.inject.Inject;\n    34→import javax.sql.DataSource;\n    35→\n    36→import com.ibm.websphere.samples.daytrader.beans.RunStatsDataBean;\n    37→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    38→import com.ibm.websphere.samples.daytrader.interfaces.TradeDB;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    41→import com.ibm.websphere.samples.daytrader.util.Log;\n    42→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    43→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    44→\n    45→/**\n    46→ * TradeBuildDB uses operations provided by the TradeApplication to (a) create the Database tables\n    47→ * (b)populate a DayTrader database without creating the tables. Specifically, a\n    48→ * new DayTrader User population is created using UserIDs of the form \"uid:xxx\"\n    49→ * where xxx is a sequential number (e.g. uid:0, uid:1, etc.). New stocks are also created of the\n    50→ * form \"s:xxx\", again where xxx represents sequential numbers (e.g. s:1, s:2, etc.)\n    51→ */\n    52→@ApplicationScoped\n    53→public class TradeDirectDBUtils implements TradeDB {\n    54→\n    55→  // For Wildfly - add java:/ to this resource.\n    56→  \n    57→  @Resource(lookup = \"jdbc/TradeDataSource\")\n    58→  //@Resource(lookup = \"java:/jdbc/TradeDataSource\")\n    59→  private DataSource datasource;\n    60→\n    61→  @Inject \n    62→  @TradeJDBC\n    63→  TradeServices ts;\n    64→\n    65→  public String checkDBProductName() throws Exception {\n    66→    Connection conn = null;\n    67→    String dbProductName = null;\n    68→\n    69→    try {\n    70→\n    71→      conn = datasource.getConnection();\n    72→      DatabaseMetaData dbmd = conn.getMetaData();\n    73→      dbProductName = dbmd.getDatabaseProductName();\n    74→    } catch (SQLException e) {\n    75→      Log.error(e, \"TradeDirect:checkDBProductName() -- Error checking the Daytrader Database Product Name\");\n    76→    } finally {\n    77→      conn.close();\n    78→    }\n    79→    return dbProductName;\n    80→  }\n    81→\n    82→\n    83→  /**\n    84→   * Re-create the DayTrader db tables and populate them OR just populate a DayTrader DB, logging to the provided output stream\n    85→   */\n    86→  public void buildDB(java.io.PrintWriter out, InputStream ddlFile) throws Exception {\n    87→    String symbol, companyName;\n    88→    int errorCount = 0; // Give up gracefully after 10 errors\n    89→\n    90→    //  TradeStatistics.statisticsEnabled=false;  // disable statistics\n    91→    out.println(\"<HEAD><BR><EM> TradeBuildDB: Building DayTrader Database...</EM><BR> This operation will take several minutes. Please wait...</HEAD>\");\n    92→    out.println(\"<BODY>\");\n    93→\n    94→    if (ddlFile != null) {\n    95→      //out.println(\"<BR>TradeBuildDB: **** warPath= \"+warPath+\" ****</BR></BODY>\");\n    96→\n    97→      boolean success = false;\n    98→\n    99→      Object[] sqlBuffer = null;\n   100→\n   101→      //parse the DDL file and fill the SQL commands into a buffer\n   102→      try {\n   103→        sqlBuffer = parseDDLToBuffer(ddlFile);\n   104→      } catch (Exception e) {\n   105→        Log.error(e, \"TradeBuildDB: Unable to parse DDL file\");\n   106→        out.println(\"<BR>TradeBuildDB: **** Unable to parse DDL file for the specified database ****</BR></BODY>\");\n   107→        return;\n   108→      }\n   109→      if ((sqlBuffer == null) || (sqlBuffer.length == 0)) {\n   110→        out.println(\"<BR>TradeBuildDB: **** Parsing DDL file returned empty buffer, please check that a valid DB specific DDL file is available and retry ****</BR></BODY>\");\n   111→        return;\n   112→      }\n   113→\n   114→      // send the sql commands buffer to drop and recreate the Daytrader tables\n   115→      out.println(\"<BR>TradeBuildDB: **** Dropping and Recreating the DayTrader tables... ****</BR>\");\n   116→      try {\n   117→        success = recreateDBTables(sqlBuffer, out);\n   118→      } catch (Exception e) {\n   119→        Log.error(e, \"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   120→        out.println(\"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   121→        return;\n   122→      }\n   123→      if (!success) {\n   124→        out.println(\"<BR>TradeBuildDB: **** Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing ****</BR></BODY>\");\n   125→        return;\n   126→      }\n   127→      out.println(\"<BR>TradeBuildDB: **** DayTrader tables successfully created! ****</BR><BR><b> Please Stop and Re-start your Daytrader application (or your application server) and then use the \\\"Repopulate Daytrader Database\\\" link to populate your database.</b></BR><BR><BR></BODY>\");\n   128→      return;\n   129→    } // end of createDBTables\n   130→\n   131→    out.println(\"<BR>TradeBuildDB: **** Creating \" + TradeConfig.getMAX_QUOTES() + \" Quotes ****</BR>\");\n   132→    //Attempt to delete all of the Trade users and Trade Quotes first\n   133→    try {\n   134→      resetTrade(true);\n   135→    } catch (Exception e) {\n   136→      Log.error(e, \"TradeBuildDB: Unable to delete Trade users (uid:0, uid:1, ...) and Trade Quotes (s:0, s:1, ...)\");\n   137→    }\n   138→    for (int i = 0; i < TradeConfig.getMAX_QUOTES(); i++) {\n   139→      symbol = \"s:\" + i;\n   140→      companyName = \"S\" + i + \" Incorporated\";\n   141→      try {\n   142→        ts.createQuote(symbol, companyName, new java.math.BigDecimal(TradeConfig.rndPrice()));\n   143→        if (i % 10 == 0) {\n   144→          out.print(\".....\" + symbol);\n   145→          if (i % 100 == 0) {\n   146→            out.println(\" -<BR>\");\n   147→            out.flush();\n   148→          }\n   149→        }\n   150→      } catch (Exception e) {\n   151→        if (errorCount++ >= 10) {\n   152→          String error = \"Populate Trade DB aborting after 10 create quote errors. Check the EJB datasource configuration. Check the log for details <BR><BR> Exception is: <BR> \"\n   153→              + e.toString();\n   154→          Log.error(e, error);\n   155→          throw e;\n   156→        }\n   157→      }\n   158→    }\n   159→    out.println(\"<BR>\");\n   160→    out.println(\"<BR>**** Registering \" + TradeConfig.getMAX_USERS() + \" Users **** \");\n   161→    errorCount = 0; //reset for user registrations\n   162→\n   163→    // Registration is a formal operation in Trade 2.\n   164→    for (int i = 0; i < TradeConfig.getMAX_USERS(); i++) {\n   165→      String userID = \"uid:\" + i;\n   166→      String fullname = TradeConfig.rndFullName();\n   167→      String email = TradeConfig.rndEmail(userID);\n   168→      String address = TradeConfig.rndAddress();\n   169→      String creditcard = TradeConfig.rndCreditCard();\n   170→      double initialBalance = (double) (TradeConfig.rndInt(100000)) + 200000;\n   171→      if (i == 0) {\n   172→        initialBalance = 1000000; // uid:0 starts with a cool million.\n   173→      }\n   174→      try {\n   175→        AccountDataBean accountData = ts.register(userID, \"xxx\", fullname, address, email, creditcard, new BigDecimal(initialBalance));\n   176→\n   177→        if (accountData != null) {\n   178→          if (i % 50 == 0) {\n   179→            out.print(\"<BR>Account# \" + accountData.getAccountID() + \" userID=\" + userID);\n   180→          } // end-if\n   181→\n   182→          int holdings = TradeConfig.rndInt(TradeConfig.getMAX_HOLDINGS() + 1); // 0-MAX_HOLDING (inclusive), avg holdings per user = (MAX-0)/2\n   183→          double quantity = 0;\n   184→\n   185→          for (int j = 0; j < holdings; j++) {\n   186→            symbol = TradeConfig.rndSymbol();\n   187→            quantity = TradeConfig.rndQuantity();\n   188→            ts.buy(userID, symbol, quantity, TradeConfig.getOrderProcessingMode());\n   189→          } // end-for\n   190→          if (i % 50 == 0) {\n   191→            out.println(\" has \" + holdings + \" holdings.\");\n   192→            out.flush();\n   193→          } // end-if\n   194→        } else {\n   195→          out.println(\"<BR>UID \" + userID + \" already registered.</BR>\");\n   196→          out.flush();\n   197→        } // end-if\n   198→\n   199→      } catch (Exception e) {\n   200→        if (errorCount++ >= 10) {\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GaeqSy2kG98H2eZRwFppY8","session_id":"fc03748e-8f3c-4e9b-a627-5ed371f2cf3e","uuid":"d2810e5a-51b5-47ee-ab88-e72170b39d14"}
