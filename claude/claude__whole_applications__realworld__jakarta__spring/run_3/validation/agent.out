 favoriteRelationship.getArticle().getId());\n    39→        query.setParameter(\"currentUserId\", favoriteRelationship.getUser().getId());\n    40→        List<FavoriteRelationshipEntity> resultList = query.getResultList();\n    41→        if (!resultList.isEmpty()) {\n    42→            return (resultList.get(0));\n    43→        } else {\n    44→            return null;\n    45→        }\n    46→    }\n    47→\n    48→    protected boolean isNotEmpty(List<?> list) {\n    49→        return list != null && !list.isEmpty();\n    50→    }\n    51→\n    52→    protected List<String> toUpperCase(List<String> subjectList) {\n    53→        return subjectList.stream().map(String::toUpperCase).collect(Collectors.toList());\n    54→    }\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_bdrk_015GtPhiKuyszHuNBzavn66f","session_id":"d8d75e0c-f395-45d5-b7d7-3f60b39c8ca5","uuid":"6ce348ba-09b6-4dc8-9633-c1cad790ae69"}
