{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Ku51GKkF4nHyimfBxikdQU","type":"tool_result","content":"     1→package org.example.realworldapi.domain.feature.impl;\n     2→\n     3→import org.example.realworldapi.domain.exception.EmailAlreadyExistsException;\n     4→import org.example.realworldapi.domain.exception.UsernameAlreadyExistsException;\n     5→import org.example.realworldapi.domain.feature.FindUserById;\n     6→import org.example.realworldapi.domain.feature.UpdateUser;\n     7→import org.example.realworldapi.domain.model.user.UpdateUserInput;\n     8→import org.example.realworldapi.domain.model.user.User;\n     9→import org.example.realworldapi.domain.model.user.UserRepository;\n    10→import org.example.realworldapi.domain.validator.ModelValidator;\n    11→\n    12→import java.util.UUID;\n    13→import org.springframework.stereotype.Service;\n    14→\n    15→@Service\n    16→public class UpdateUserImpl implements UpdateUser {\n    17→\n    18→    private final FindUserById findUserById;\n    19→    private final UserRepository userRepository;\n    20→    private final ModelValidator modelValidator;\n    21→    public UpdateUserImpl(FindUserById findUserById, UserRepository userRepository, ModelValidator modelValidator) {\n    22→        this.findUserById = findUserById;\n    23→        this.userRepository = userRepository;\n    24→        this.modelValidator = modelValidator;\n    25→    }\n    26→\n    27→    @Override\n    28→    public User handle(UpdateUserInput updateUserInput) {\n    29→        final var user = findUserById.handle(updateUserInput.getId());\n    30→        checkValidations(updateUserInput, updateUserInput.getId());\n    31→        updateFields(user, updateUserInput);\n    32→        userRepository.update(modelValidator.validate(user));\n    33→        return user;\n    34→    }\n    35→\n    36→    private void updateFields(User user, UpdateUserInput updateUserInput) {\n    37→        if (isPresent(updateUserInput.getUsername())) {\n    38→            user.setUsername(updateUserInput.getUsername());\n    39→        }\n    40→\n    41→        if (isPresent(updateUserInput.getEmail())) {\n    42→            user.setEmail(updateUserInput.getEmail());\n    43→        }\n    44→\n    45→        if (isPresent(updateUserInput.getBio())) {\n    46→            user.setBio(updateUserInput.getBio());\n    47→        }\n    48→\n    49→        if (isPresent(updateUserInput.getImage())) {\n    50→            user.setImage(updateUserInput.getImage());\n    51→        }\n    52→    }\n    53→\n    54→    private void checkValidations(UpdateUserInput updateUserInput, UUID excludeId) {\n    55→\n    56→        if (isPresent(updateUserInput.getUsername())) {\n    57→            checkUsername(excludeId, updateUserInput.getUsername());\n    58→        }\n    59→\n    60→        if (isPresent(updateUserInput.getEmail())) {\n    61→            checkEmail(excludeId, updateUserInput.getEmail());\n    62→        }\n    63→    }\n    64→\n    65→    private boolean isPresent(String property) {\n    66→        return property != null && !property.isEmpty();\n    67→    }\n    68→\n    69→    private void checkUsername(UUID selfId, String username) {\n    70→        if (userRepository.existsUsername(selfId, username)) {\n    71→            throw new UsernameAlreadyExistsException();\n    72→        }\n    73→    }\n    74→\n    75→    private void checkEmail(UUID selfId, String email) {\n    76→        if (userRepository.existsEmail(selfId, email)) {\n    77→            throw new EmailAlreadyExistsException();\n    78→        }\n    79→    }\n    80→}\n    81→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_015GtPhiKuyszHuNBzavn66f","session_id":"d8d75e0c-f395-45d5-b7d7-3f60b39c8ca5","uuid":"0e576b6e-6dce-4ed5-89cb-60238f58f144"}
