 33→        return findTagRelationshipEntities(article).stream().map(entityUtils::tag).toList();\n    34→    }\n    35→\n    36→    @Override\n    37→    public List<TagRelationship> findTagRelationships(Article article) {\n    38→        return findTagRelationshipEntities(article).stream().map(entityUtils::tagRelationship).toList();\n    39→    }\n    40→\n    41→    @Override\n    42→    public void delete(Article article) {\n    43→        List<TagRelationshipEntity> tagRelationshipEntities = findTagRelationshipEntities(article);\n    44→        tagRelationshipEntities.forEach(a -> em.remove(a));\n    45→    }\n    46→\n    47→    @SuppressWarnings(\"unchecked\")\n    48→    public List<TagRelationshipEntity> findTagRelationshipEntities(Article article) {\n    49→        String jpql = \"SELECT t FROM TagRelationshipEntity t where t.article.id = :articleId\";\n    50→        Query query = em.createQuery(jpql);\n    51→        query.setParameter(\"articleId\", article.getId());\n    52→        return query.getResultList();\n    53→    }\n    54→}\n    55→"}]},"parent_tool_use_id":"toolu_bdrk_015GtPhiKuyszHuNBzavn66f","session_id":"d8d75e0c-f395-45d5-b7d7-3f60b39c8ca5","uuid":"45a6f58b-7556-4ab8-90b8-555374d90a47"}
