   return !resultList.isEmpty();\n    33→    }\n    34→\n    35→    @Override\n    36→    public void save(FollowRelationship followRelationship) {\n    37→        final var userEntity = findUserEntityById(followRelationship.getUser().getId());\n    38→        final var userToFollowEntity = findUserEntityById(followRelationship.getFollowed().getId());\n    39→        em.persist(new FollowRelationshipEntity(userEntity, userToFollowEntity));\n    40→        em.flush();\n    41→    }\n    42→\n    43→    @Override\n    44→    public Optional<FollowRelationship> findByUsers(User loggedUser, User followedUser) {\n    45→        return findUsersFollowedEntityByUsers(loggedUser, followedUser).map(this::followingRelationship);\n    46→    }\n    47→\n    48→    @Override\n    49→    public void remove(FollowRelationship followRelationship) {\n    50→        final var usersFollowedEntity = findUsersFollowedEntityByUsers(\n    51→                followRelationship.getUser(), followRelationship.getFollowed()).orElseThrow();\n    52→        em.remove(usersFollowedEntity);\n    53→    }\n    54→\n    55→    @SuppressWarnings(\"unchecked\")\n    56→    private Optional<FollowRelationshipEntity> findUsersFollowedEntityByUsers(User loggedUser, User followedUser) {\n    57→        final var loggedUserEntity = findUserEntityById(loggedUser.getId());\n    58→        final var followedEntity = findUserEntityById(followedUser.getId());\n    59→        Query query = em.createNamedQuery(\"FRE.findByPrimaryKey_UserAndPrimaryKey_Followed\");\n    60→        query.setParameter(\"loggedUserEntity\", loggedUserEntity);\n    61→        query.setParameter(\"followedUserEntity\", followedEntity);\n    62→        List<FollowRelationshipEntity> resultList = query.getResultList();\n    63→        if (!resultList.isEmpty()) {\n    64→            return Optional.of(resultList.get(0));\n    65→        }\n    66→        return Optional.empty();\n    67→    }\n    68→\n    69→    private FollowRelationship followingRelationship(FollowRelationshipEntity followRelationshipEntity) {\n    70→        final var user = entityUtils.user(followRelationshipEntity.getUser());\n    71→        final var followed = entityUtils.user(followRelationshipEntity.getFollowed());\n    72→        return new FollowRelationship(user, followed);\n    73→    }\n    74→}\n    75→"}]},"parent_tool_use_id":"toolu_bdrk_015GtPhiKuyszHuNBzavn66f","session_id":"d8d75e0c-f395-45d5-b7d7-3f60b39c8ca5","uuid":"1f45f987-5f3a-4683-8b91-026b00c2b1f4"}
