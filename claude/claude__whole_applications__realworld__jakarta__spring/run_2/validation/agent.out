{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_018tqXANc31QLFVq9Z6CPqDw","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Smoke tests for the RealWorld API after migration from Jakarta EE to Spring Boot.\"\"\"\n     3→\n     4→import json\n     5→import time\n     6→import sys\n     7→import urllib.request\n     8→import urllib.error\n     9→\n    10→BASE_URL = sys.argv[1] if len(sys.argv) > 1 else \"http://localhost:8080\"\n    11→PASSED = 0\n    12→FAILED = 0\n    13→\n    14→def test(name, method, path, body=None, headers=None, expected_status=200, check_body=None):\n    15→    global PASSED, FAILED\n    16→    url = f\"{BASE_URL}{path}\"\n    17→    if headers is None:\n    18→        headers = {}\n    19→    headers.setdefault(\"Content-Type\", \"application/json\")\n    20→\n    21→    data = json.dumps(body).encode(\"utf-8\") if body else None\n    22→    req = urllib.request.Request(url, data=data, headers=headers, method=method)\n    23→\n    24→    try:\n    25→        resp = urllib.request.urlopen(req)\n    26→        status = resp.status\n    27→        resp_body = resp.read().decode(\"utf-8\")\n    28→    except urllib.error.HTTPError as e:\n    29→        status = e.code\n    30→        resp_body = e.read().decode(\"utf-8\")\n    31→    except Exception as e:\n    32→        print(f\"  FAIL {name}: Connection error: {e}\")\n    33→        FAILED += 1\n    34→        return None\n    35→\n    36→    if status != expected_status:\n    37→        print(f\"  FAIL {name}: Expected status {expected_status}, got {status}\")\n    38→        print(f\"       Response: {resp_body[:500]}\")\n    39→        FAILED += 1\n    40→        return None\n    41→\n    42→    result = None\n    43→    if resp_body:\n    44→        try:\n    45→            result = json.loads(resp_body)\n    46→        except json.JSONDecodeError:\n    47→            result = resp_body\n    48→\n    49→    if check_body and result:\n    50→        try:\n    51→            check_body(result)\n    52→            print(f\"  PASS {name}\")\n    53→            PASSED += 1\n    54→        except AssertionError as e:\n    55→            print(f\"  FAIL {name}: Body check failed: {e}\")\n    56→            FAILED += 1\n    57→            return result\n    58→    else:\n    59→        print(f\"  PASS {name}\")\n    60→        PASSED += 1\n    61→\n    62→    return result\n    63→\n    64→class AssertionError(Exception):\n    65→    pass\n    66→\n    67→def assert_has_key(d, key):\n    68→    if key not in d:\n    69→        raise AssertionError(f\"Missing key: {key}\")\n    70→\n    71→def assert_equals(actual, expected):\n    72→    if actual != expected:\n    73→        raise AssertionError(f\"Expected {expected}, got {actual}\")\n    74→\n    75→def wait_for_server(max_wait=120):\n    76→    \"\"\"Wait for the server to be ready.\"\"\"\n    77→    print(f\"Waiting for server at {BASE_URL} ...\")\n    78→    start = time.time()\n    79→    while time.time() - start < max_wait:\n    80→        try:\n    81→            req = urllib.request.Request(f\"{BASE_URL}/actuator/health\")\n    82→            resp = urllib.request.urlopen(req, timeout=5)\n    83→            if resp.status == 200:\n    84→                print(\"Server is ready!\")\n    85→                return True\n    86→        except Exception:\n    87→            pass\n    88→        time.sleep(2)\n    89→    print(\"Server did not start in time!\")\n    90→    return False\n    91→\n    92→def run_tests():\n    93→    global PASSED, FAILED\n    94→\n    95→    print(\"\\n=== RealWorld API Smoke Tests ===\\n\")\n    96→\n    97→    if not wait_for_server():\n    98→        print(\"ABORT: Server not available\")\n    99→        sys.exit(1)\n   100→\n   101→    # 1. Health check\n   102→    test(\"Health check\", \"GET\", \"/actuator/health\",\n   103→         check_body=lambda b: assert_has_key(b, \"status\"))\n   104→\n   105→    # 2. Get tags (empty initially)\n   106→    test(\"Get tags\", \"GET\", \"/api/tags\",\n   107→         check_body=lambda b: assert_has_key(b, \"tags\"))\n   108→\n   109→    # 3. Get articles (empty initially)\n   110→    test(\"Get articles\", \"GET\", \"/api/articles\",\n   111→         check_body=lambda b: (assert_has_key(b, \"articles\"), assert_has_key(b, \"articlesCount\")))\n   112→\n   113→    # 4. Register a user\n   114→    ts = str(int(time.time()))\n   115→    user1_data = {\n   116→        \"user\": {\n   117→            \"username\": f\"testuser{ts}\",\n   118→            \"email\": f\"test{ts}@example.com\",\n   119→            \"password\": \"password123\"\n   120→        }\n   121→    }\n   122→    result = test(\"Register user\", \"POST\", \"/api/users\", body=user1_data, expected_status=201,\n   123→                  check_body=lambda b: (assert_has_key(b, \"user\"), assert_has_key(b[\"user\"], \"token\")))\n   124→\n   125→    token = None\n   126→    if result and \"user\" in result:\n   127→        token = result[\"user\"][\"token\"]\n   128→\n   129→    # 5. Login with the created user\n   130→    login_data = {\n   131→        \"user\": {\n   132→            \"email\": f\"test{ts}@example.com\",\n   133→            \"password\": \"password123\"\n   134→        }\n   135→    }\n   136→    result = test(\"Login user\", \"POST\", \"/api/users/login\", body=login_data,\n   137→                  check_body=lambda b: (assert_has_key(b, \"user\"), assert_has_key(b[\"user\"], \"token\")))\n   138→\n   139→    if result and \"user\" in result:\n   140→        token = result[\"user\"][\"token\"]\n   141→\n   142→    if not token:\n   143→        print(\"  SKIP remaining tests: no auth token available\")\n   144→        print(f\"\\n=== Results: {PASSED} passed, {FAILED} failed ===\")\n   145→        sys.exit(1 if FAILED > 0 else 0)\n   146→\n   147→    auth_headers = {\"Authorization\": f\"Token {token}\", \"Content-Type\": \"application/json\"}\n   148→\n   149→    # 6. Get current user\n   150→    test(\"Get current user\", \"GET\", \"/api/user\", headers=auth_headers,\n   151→         check_body=lambda b: (assert_has_key(b, \"user\"), assert_has_key(b[\"user\"], \"email\")))\n   152→\n   153→    # 7. Update user\n   154→    update_data = {\"user\": {\"bio\": \"I am a test user\"}}\n   155→    test(\"Update user\", \"PUT\", \"/api/user\", body=update_data, headers=auth_headers,\n   156→         check_body=lambda b: assert_equals(b[\"user\"][\"bio\"], \"I am a test user\"))\n   157→\n   158→    # 8. Create article\n   159→    article_data = {\n   160→        \"article\": {\n   161→            \"title\": f\"Test Article {ts}\",\n   162→            \"description\": \"Test Description\",\n   163→            \"body\": \"Test Body Content\",\n   164→            \"tagList\": [\"test\", \"smoke\"]\n   165→        }\n   166→    }\n   167→    result = test(\"Create article\", \"POST\", \"/api/articles\", body=article_data,\n   168→                  headers=auth_headers, expected_status=201,\n   169→                  check_body=lambda b: (assert_has_key(b, \"article\"), assert_has_key(b[\"article\"], \"slug\")))\n   170→\n   171→    slug = None\n   172→    if result and \"article\" in result:\n   173→        slug = result[\"article\"][\"slug\"]\n   174→\n   175→    # 9. Get article by slug\n   176→    if slug:\n   177→        test(\"Get article by slug\", \"GET\", f\"/api/articles/{slug}\",\n   178→             check_body=lambda b: assert_equals(b[\"article\"][\"slug\"], slug))\n   179→\n   180→    # 10. Get articles with filter\n   181→    test(\"Get articles (with filter)\", \"GET\", f\"/api/articles?tag=test\",\n   182→         check_body=lambda b: assert_has_key(b, \"articles\"))\n   183→\n   184→    # 11. Update article\n   185→    if slug:\n   186→        update_article_data = {\"article\": {\"description\": \"Updated Description\"}}\n   187→        test(\"Update article\", \"PUT\", f\"/api/articles/{slug}\",\n   188→             body=update_article_data, headers=auth_headers,\n   189→             check_body=lambda b: assert_equals(b[\"article\"][\"description\"], \"Updated Description\"))\n   190→\n   191→    # 12. Favorite article\n   192→    if slug:\n   193→        test(\"Favorite article\", \"POST\", f\"/api/articles/{slug}/favorite\",\n   194→             headers=auth_headers,\n   195→             check_body=lambda b: assert_equals(b[\"article\"][\"favorited\"], True))\n   196→\n   197→    # 13. Unfavorite article\n   198→    if slug:\n   199→        test(\"Unfavorite article\", \"DELETE\", f\"/api/articles/{slug}/favorite\",\n   200→             headers=auth_headers,\n   201→             check_body=lambda b: assert_equals(b[\"article\"][\"favorited\"], False))\n   202→\n   203→    # 14. Add comment\n   204→    if slug:\n   205→        comment_data = {\"comment\": {\"body\": \"This is a test comment\"}}\n   206→        result = test(\"Add comment\", \"POST\", f\"/api/articles/{slug}/comments\",\n   207→                      body=comment_data, headers=auth_headers,\n   208→                      check_body=lambda b: assert_has_key(b, \"comment\"))\n   209→\n   210→    # 15. Get comments\n   211→    if slug:\n   212→        test(\"Get comments\", \"GET\", f\"/api/articles/{slug}/comments\",\n   213→             check_body=lambda b: assert_has_key(b, \"comments\"))\n   214→\n   215→    # 16. Get tags (should now have tags)\n   216→    test(\"Get tags (populated)\", \"GET\", \"/api/tags\",\n   217→         check_body=lambda b: assert_has_key(b, \"tags\"))\n   218→\n   219→    # 17. Register second user\n   220→    user2_data = {\n   221→        \"user\": {\n   222→            \"username\": f\"testuser2_{ts}\",\n   223→            \"email\": f\"test2_{ts}@example.com\",\n   224→            \"password\": \"password123\"\n   225→        }\n   226→    }\n   227→    result = test(\"Register second user\", \"POST\", \"/api/users\", body=user2_data,\n   228→                  expected_status=201,\n   229→                  check_body=lambda b: assert_has_key(b, \"user\"))\n   230→\n   231→    # 18. Get profile\n   232→    test(\"Get profile\", \"GET\", f\"/api/profiles/testuser{ts}\", headers=auth_headers,\n   233→         check_body=lambda b: (assert_has_key(b, \"profile\"), assert_equals(b[\"profile\"][\"username\"], f\"testuser{ts}\")))\n   234→\n   235→    # 19. Follow user\n   236→    test(\"Follow user\", \"POST\", f\"/api/profiles/testuser2_{ts}/follow\",\n   237→         headers=auth_headers,\n   238→         check_body=lambda b: assert_equals(b[\"profile\"][\"following\"], True))\n   239→\n   240→    # 20. Unfollow user\n   241→    test(\"Unfollow user\", \"DELETE\", f\"/api/profiles/testuser2_{ts}/follow\",\n   242→         headers=auth_headers,\n   243→         check_body=lambda b: assert_equals(b[\"profile\"][\"following\"], False))\n   244→\n   245→    # 21. Delete article\n   246→    if slug:\n   247→        test(\"Delete article\", \"DELETE\", f\"/api/articles/{slug}\",\n   248→             headers=auth_headers)\n   249→\n   250→    # 22. Login with wrong password should fail\n   251→    bad_login = {\"user\": {\"email\": f\"test{ts}@example.com\", \"password\": \"wrongpassword\"}}\n   252→    test(\"Login with wrong password\", \"POST\", \"/api/users/login\",\n   253→         body=bad_login, expected_status=401)\n   254→\n   255→    # 23. Duplicate registration should fail\n   256→    test(\"Duplicate registration\", \"POST\", \"/api/users\", body=user1_data,\n   257→         expected_status=409)\n   258→\n   259→    print(f\"\\n=== Results: {PASSED} passed, {FAILED} failed ===\")\n   260→    sys.exit(1 if FAILED > 0 else 0)\n   261→\n   262→if __name__ == \"__main__\":\n   263→    run_tests()\n   264→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"df1561a9-af26-4e6c-a6ca-e235ecd783f5","uuid":"db6c4e92-fdfd-4af3-aa1c-97e72fe53766"}
