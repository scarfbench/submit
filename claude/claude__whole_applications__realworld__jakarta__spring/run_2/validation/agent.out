{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01L7AWhfwcUbKHdjnMG7Z8cF","type":"tool_result","content":"     1→package org.example.realworldapi.infrastructure.web.mapper;\n     2→\n     3→import jakarta.validation.ConstraintViolationException;\n     4→import org.example.realworldapi.application.web.model.response.ErrorResponse;\n     5→import org.example.realworldapi.domain.exception.*;\n     6→import org.example.realworldapi.infrastructure.web.exception.ForbiddenException;\n     7→import org.example.realworldapi.infrastructure.web.exception.UnauthorizedException;\n     8→import org.springframework.http.HttpStatus;\n     9→import org.springframework.http.ResponseEntity;\n    10→import org.springframework.web.bind.MethodArgumentNotValidException;\n    11→import org.springframework.web.bind.annotation.ExceptionHandler;\n    12→import org.springframework.web.bind.annotation.RestControllerAdvice;\n    13→\n    14→@RestControllerAdvice\n    15→public class GlobalExceptionHandler {\n    16→\n    17→    @ExceptionHandler(ConstraintViolationException.class)\n    18→    public ResponseEntity<ErrorResponse> handleConstraintViolation(ConstraintViolationException e) {\n    19→        ErrorResponse errorResponse = new ErrorResponse();\n    20→        e.getConstraintViolations().forEach(v -> errorResponse.getBody().add(v.getMessage()));\n    21→        return ResponseEntity.status(422).body(errorResponse);\n    22→    }\n    23→\n    24→    @ExceptionHandler(MethodArgumentNotValidException.class)\n    25→    public ResponseEntity<ErrorResponse> handleMethodArgumentNotValid(MethodArgumentNotValidException e) {\n    26→        ErrorResponse errorResponse = new ErrorResponse();\n    27→        e.getBindingResult().getAllErrors().forEach(error -> errorResponse.getBody().add(error.getDefaultMessage()));\n    28→        return ResponseEntity.status(422).body(errorResponse);\n    29→    }\n    30→\n    31→    @ExceptionHandler(EmailAlreadyExistsException.class)\n    32→    public ResponseEntity<ErrorResponse> handleEmailExists(EmailAlreadyExistsException e) {\n    33→        return ResponseEntity.status(HttpStatus.CONFLICT).body(new ErrorResponse(e.getMessages()));\n    34→    }\n    35→\n    36→    @ExceptionHandler(UsernameAlreadyExistsException.class)\n    37→    public ResponseEntity<ErrorResponse> handleUsernameExists(UsernameAlreadyExistsException e) {\n    38→        return ResponseEntity.status(HttpStatus.CONFLICT).body(new ErrorResponse(e.getMessages()));\n    39→    }\n    40→\n    41→    @ExceptionHandler(UserNotFoundException.class)\n    42→    public ResponseEntity<ErrorResponse> handleUserNotFound(UserNotFoundException e) {\n    43→        return ResponseEntity.status(HttpStatus.NOT_FOUND).body(new ErrorResponse(e.getMessages()));\n    44→    }\n    45→\n    46→    @ExceptionHandler(ArticleNotFoundException.class)\n    47→    public ResponseEntity<ErrorResponse> handleArticleNotFound(ArticleNotFoundException e) {\n    48→        return ResponseEntity.status(HttpStatus.NOT_FOUND).body(new ErrorResponse(e.getMessages()));\n    49→    }\n    50→\n    51→    @ExceptionHandler(CommentNotFoundException.class)\n    52→    public ResponseEntity<ErrorResponse> handleCommentNotFound(CommentNotFoundException e) {\n    53→        return ResponseEntity.status(HttpStatus.NOT_FOUND).body(new ErrorResponse(e.getMessages()));\n    54→    }\n    55→\n    56→    @ExceptionHandler(TagNotFoundException.class)\n    57→    public ResponseEntity<ErrorResponse> handleTagNotFound(TagNotFoundException e) {\n    58→        return ResponseEntity.status(HttpStatus.NOT_FOUND).body(new ErrorResponse(e.getMessages()));\n    59→    }\n    60→\n    61→    @ExceptionHandler(InvalidPasswordException.class)\n    62→    public ResponseEntity<ErrorResponse> handleInvalidPassword(InvalidPasswordException e) {\n    63→        return ResponseEntity.status(HttpStatus.UNAUTHORIZED).body(new ErrorResponse(e.getMessages()));\n    64→    }\n    65→\n    66→    @ExceptionHandler(ModelValidationException.class)\n    67→    public ResponseEntity<ErrorResponse> handleModelValidation(ModelValidationException e) {\n    68→        return ResponseEntity.status(422).body(new ErrorResponse(e.getMessages()));\n    69→    }\n    70→\n    71→    @ExceptionHandler(UnauthorizedException.class)\n    72→    public ResponseEntity<ErrorResponse> handleUnauthorized(UnauthorizedException e) {\n    73→        return ResponseEntity.status(HttpStatus.UNAUTHORIZED).body(new ErrorResponse(HttpStatus.UNAUTHORIZED.toString()));\n    74→    }\n    75→\n    76→    @ExceptionHandler(ForbiddenException.class)\n    77→    public ResponseEntity<ErrorResponse> handleForbidden(ForbiddenException e) {\n    78→        return ResponseEntity.status(HttpStatus.FORBIDDEN).body(new ErrorResponse(HttpStatus.FORBIDDEN.toString()));\n    79→    }\n    80→}\n    81→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"df1561a9-af26-4e6c-a6ca-e235ecd783f5","uuid":"653e844a-418e-44cc-9822-28bd020ee910"}
