ySlug;\n    32→    @Autowired\n    33→    private UpdateArticleBySlug updateArticleBySlug;\n    34→    @Autowired\n    35→    private DeleteArticleBySlug deleteArticleBySlug;\n    36→    @Autowired\n    37→    private CreateComment createComment;\n    38→    @Autowired\n    39→    private DeleteComment deleteComment;\n    40→    @Autowired\n    41→    private FindCommentsByArticleSlug findCommentsByArticleSlug;\n    42→    @Autowired\n    43→    private FavoriteArticle favoriteArticle;\n    44→    @Autowired\n    45→    private UnfavoriteArticle unfavoriteArticle;\n    46→    @Autowired\n    47→    private ResourceUtils resourceUtils;\n    48→\n    49→    @GetMapping(value = \"/feed\", produces = \"application/json\")\n    50→    public ResponseEntity<?> feed(\n    51→            @RequestParam(defaultValue = \"0\") int offset,\n    52→            @RequestParam(defaultValue = \"0\") int limit,\n    53→            @RequestAttribute(required = false) UUID loggedUserId) {\n    54→        final var articlesFilter =\n    55→                new ArticleFilter(offset, resourceUtils.getLimit(limit), loggedUserId, null, null, null);\n    56→        final var articlesPageResult = findMostRecentArticlesByFilter.handle(articlesFilter);\n    57→        return ResponseEntity.ok(resourceUtils.articlesResponse(articlesPageResult, loggedUserId));\n    58→    }\n    59→\n    60→    @GetMapping(produces = \"application/json\")\n    61→    public ResponseEntity<?> getArticles(\n    62→            @RequestParam(defaultValue = \"0\") int offset,\n    63→            @RequestParam(defaultValue = \"0\") int limit,\n    64→            @RequestParam(required = false) List<String> tag,\n    65→            @RequestParam(required = false) List<String> author,\n    66→            @RequestParam(required = false) List<String> favorited,\n    67→            @RequestAttribute(required = false) UUID loggedUserId) {\n    68→        final var filter =\n    69→                new ArticleFilter(\n    70→                        offset, resourceUtils.getLimit(limit), loggedUserId, tag, author, favorited);\n    71→        final var articlesPageResult = findArticlesByFilter.handle(filter);\n    72→        return ResponseEntity.ok(resourceUtils.articlesResponse(articlesPageResult, loggedUserId));\n    73→    }\n    74→\n    75→    @PostMapping(consumes = \"application/json\", produces = \"application/json\")\n    76→    @Transactional\n    77→    public ResponseEntity<?> create(\n    78→            @Valid @RequestBody NewArticleRequestWrapper newArticleRequest,\n    79→            @RequestAttribute UUID loggedUserId) {\n    80→        final var article = createArticle.handle(newArticleRequest.getArticle().toNewArticleInput(loggedUserId));\n    81→        return ResponseEntity.status(HttpStatus.CREATED).body(resourceUtils.articleResponse(article, loggedUserId));\n    82→    }\n    83→\n    84→    @GetMapping(value = \"/{slug}\", produces = \"application/json\")\n    85→    public ResponseEntity<?> findBySlug(@PathVariable String slug) {\n    86→        final var article = findArticleBySlug.handle(slug);\n    87→        return ResponseEntity.ok(resourceUtils.articleResponse(article, null));\n    88→    }\n    89→\n    90→    @PutMapping(value = \"/{slug}\", consumes = \"application/json\", produces = \"application/json\")\n    91→    @Transactional\n    92→    public ResponseEntity<?> update(\n    93→            @PathVariable String slug,\n    94→            @Valid @RequestBody UpdateArticleRequestWrapper updateArticleRequest,\n    95→            @RequestAttribute UUID loggedUserId) {\n    96→        final var updatedArticle =\n    97→                updateArticleBySlug.handle(updateArticleRequest.getArticle().toUpdateArticleInput(loggedUserId, slug));\n    98→        return ResponseEntity.ok(resourceUtils.articleResponse(updatedArticle, null));\n    99→    }\n   100→\n   101→    @DeleteMapping(value = \"/{slug}\", produces = \"application/json\")\n   102→    @Transactional\n   103→    public ResponseEntity<?> delete(\n   104→            @PathVariable String slug,\n   105→            @RequestAttribute UUID loggedUserId) {\n   106→        deleteArticleBySlug.handle(loggedUserId, slug);\n   107→        return ResponseEntity.ok().build();\n   108→    }\n   109→\n   110→    @GetMapping(value = \"/{slug}/comments\", produces = \"application/json\")\n   111→    public ResponseEntity<?> getCommentsBySlug(\n   112→            @PathVariable String slug,\n   113→            @RequestAttribute(required = false) UUID loggedUserId) {\n   114→        final var comments = findCommentsByArticleSlug.handle(slug);\n   115→        return ResponseEntity.ok(resourceUtils.commentsResponse(comments, loggedUserId));\n   116→    }\n   117→\n   118→    @PostMapping(value = \"/{slug}/comments\", consumes = \"application/json\", produces = \"application/json\")\n   119→    @Transactional\n   120→    public ResponseEntity<?> createComment(\n   121→            @PathVariable String slug,\n   122→            @Valid @RequestBody NewCommentRequestWrapper newCommentRequest,\n   123→            @RequestAttribute UUID loggedUserId) {\n   124→        final var comment =\n   125→                createComment.handle(newCommentRequest.getComment().toNewCommentInput(loggedUserId, slug));\n   126→        return ResponseEntity.ok(resourceUtils.commentResponse(comment, loggedUserId));\n   127→    }\n   128→\n   129→    @DeleteMapping(value = \"/{slug}/comments/{id}\", produces = \"application/json\")\n   130→    @Transactional\n   131→    public ResponseEntity<?> deleteComment(\n   132→            @PathVariable String slug,\n   133→            @PathVariable UUID id,\n   134→            @RequestAttribute UUID loggedUserId) {\n   135→        deleteComment.handle(new DeleteCommentInput(id, loggedUserId, slug));\n   136→        return ResponseEntity.ok().build();\n   137→    }\n   138→\n   139→    @PostMapping(value = \"/{slug}/favorite\", produces = \"application/json\")\n   140→    @Transactional\n   141→    public ResponseEntity<?> favoriteArticle(\n   142→            @PathVariable String slug,\n   143→            @RequestAttribute UUID loggedUserId) {\n   144→        favoriteArticle.handle(slug, loggedUserId);\n   145→        final var article = findArticleBySlug.handle(slug);\n   146→        return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   147→    }\n   148→\n   149→    @DeleteMapping(value = \"/{slug}/favorite\", produces = \"application/json\")\n   150→    @Transactional\n   151→    public ResponseEntity<?> unfavoriteArticle(\n   152→            @PathVariable String slug,\n   153→            @RequestAttribute UUID loggedUserId) {\n   154→        unfavoriteArticle.handle(slug, loggedUserId);\n   155→        final var article = findArticleBySlug.handle(slug);\n   156→        return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   157→    }\n   158→}\n   159→"}]},"parent_tool_use_id":"toolu_bdrk_01MhF18yNWr612aMRb1m4H5j","session_id":"df1561a9-af26-4e6c-a6ca-e235ecd783f5","uuid":"819c250c-0070-4c25-ab95-8ee7d4007a8e"}
