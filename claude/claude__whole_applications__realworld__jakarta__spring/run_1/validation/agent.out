 userBuilder;\n    30→        this.tagBuilder = tagBuilder;\n    31→        this.articleBuilder = articleBuilder;\n    32→        this.commentBuilder = commentBuilder;\n    33→    }\n    34→\n    35→    public User user(UserEntity userEntity) {\n    36→        final var id = userEntity.getId();\n    37→        final var username = userEntity.getUsername();\n    38→        final var bio = userEntity.getBio();\n    39→        final var image = userEntity.getImage();\n    40→        final var password = userEntity.getPassword();\n    41→        final var email = userEntity.getEmail();\n    42→        return userBuilder.build(id, username, bio, image, password, email);\n    43→    }\n    44→\n    45→    public Tag tag(TagEntity tagEntity) {\n    46→        return tagBuilder.build(tagEntity.getId(), tagEntity.getName());\n    47→    }\n    48→\n    49→    public Tag tag(TagRelationshipEntity tagRelationshipEntity) {\n    50→        return tag(tagRelationshipEntity.getTag());\n    51→    }\n    52→\n    53→    public TagRelationship tagRelationship(TagRelationshipEntity tagRelationshipEntity) {\n    54→        return new TagRelationship(article(tagRelationshipEntity.getArticle()), tag(tagRelationshipEntity.getTag()));\n    55→    }\n    56→\n    57→    public Article article(ArticleEntity articleEntity) {\n    58→        return articleBuilder.build(\n    59→                articleEntity.getId(),\n    60→                articleEntity.getSlug(),\n    61→                articleEntity.getTitle(),\n    62→                articleEntity.getDescription(),\n    63→                articleEntity.getBody(),\n    64→                articleEntity.getCreatedAt(),\n    65→                articleEntity.getUpdatedAt(),\n    66→                user(articleEntity.getAuthor()));\n    67→    }\n    68→\n    69→    public Comment comment(CommentEntity commentEntity) {\n    70→        return commentBuilder.build(\n    71→                commentEntity.getId(),\n    72→                user(commentEntity.getAuthor()),\n    73→                article(commentEntity.getArticle()),\n    74→                commentEntity.getBody(),\n    75→                commentEntity.getCreatedAt(),\n    76→                commentEntity.getUpdatedAt());\n    77→    }\n    78→\n    79→    public FavoriteRelationship favoriteRelationship(\n    80→            FavoriteRelationshipEntity favoriteRelationshipEntity) {\n    81→        return new FavoriteRelationship(\n    82→                user(favoriteRelationshipEntity.getUser()),\n    83→                article(favoriteRelationshipEntity.getArticle()));\n    84→    }\n    85→}\n    86→"}]},"parent_tool_use_id":"toolu_bdrk_01TrtD1tKbaKwmrGzynjzvXR","session_id":"1968c9d1-9222-41bb-9d6c-3e0081e3cb16","uuid":"e3a041de-00bf-4e4d-917b-b7af7c63dd9a"}
