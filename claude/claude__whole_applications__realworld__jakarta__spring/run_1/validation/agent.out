Query.setParameter(entry.getKey(), entry.getValue());\n   153→        }\n   154→\n   155→        int offset = filter.getOffset();\n   156→        int limit = filter.getLimit();\n   157→        query.setFirstResult(offset);\n   158→        query.setMaxResults(limit);\n   159→\n   160→        List<ArticleEntity> articlesEntity = query.getResultList();\n   161→        long countArticleEntities = (long) countQuery.getSingleResult();\n   162→\n   163→        final var articlesResult = articlesEntity.stream().map(entityUtils::article).toList();\n   164→        return new PageResult<>(articlesResult, countArticleEntities);\n   165→    }\n   166→\n   167→    private void configFilterFindArticlesQueryBuilder(SimpleQueryBuilder findArticlesQueryBuilder, List<String> tags, List<String> authors, List<String> favorited, Map<String, Object> params) {\n   168→\n   169→        List<String> tagsUpper = new ArrayList<>();\n   170→        List<String> authorsUpper = new ArrayList<>();\n   171→        List<String> favUpper = new ArrayList<>();\n   172→\n   173→        if (isNotEmpty(tags)) {\n   174→            tagsUpper = toUpperCase(tags);\n   175→        }\n   176→\n   177→        if (isNotEmpty(authors)) {\n   178→            authorsUpper = toUpperCase(authors);\n   179→        }\n   180→\n   181→        if (isNotEmpty(favorited)) {\n   182→            favUpper = toUpperCase(favorited);\n   183→        }\n   184→\n   185→        List<String> finalTagsUpper = tagsUpper;\n   186→        List<String> finalAuthorsUpper = authorsUpper;\n   187→        List<String> finalFavsUpper = favUpper;\n   188→        findArticlesQueryBuilder.updateQueryStatementConditional(isNotEmpty(tags), \"inner join a.tags t inner join t.tag as tag\", \"upper(tag.name) in :tags\", () -> params.put(\"tags\", finalTagsUpper));\n   189→\n   190→        findArticlesQueryBuilder.updateQueryStatementConditional(isNotEmpty(authors), \"inner join a.author as authors\", \"upper(authors.username) in :authors\", () -> params.put(\"authors\", finalAuthorsUpper));\n   191→\n   192→        findArticlesQueryBuilder.updateQueryStatementConditional(isNotEmpty(favorited), \"inner join a.favorites as favorites inner join favorites.user as user\", \"upper(user.username) in :favorites\", () -> params.put(\"favorites\", finalFavsUpper));\n   193→    }\n   194→}\n   195→"}]},"parent_tool_use_id":"toolu_bdrk_01TrtD1tKbaKwmrGzynjzvXR","session_id":"1968c9d1-9222-41bb-9d6c-3e0081e3cb16","uuid":"b8b698eb-7b0a-49b1-a8aa-c268a2f29feb"}
