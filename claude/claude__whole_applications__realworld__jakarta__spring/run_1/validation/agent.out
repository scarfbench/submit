etId());\n    34→        checkValidations(updateUserInput, updateUserInput.getId());\n    35→        updateFields(user, updateUserInput);\n    36→        userRepository.update(modelValidator.validate(user));\n    37→        return user;\n    38→    }\n    39→\n    40→    private void updateFields(User user, UpdateUserInput updateUserInput) {\n    41→        if (isPresent(updateUserInput.getUsername())) {\n    42→            user.setUsername(updateUserInput.getUsername());\n    43→        }\n    44→\n    45→        if (isPresent(updateUserInput.getEmail())) {\n    46→            user.setEmail(updateUserInput.getEmail());\n    47→        }\n    48→\n    49→        if (isPresent(updateUserInput.getBio())) {\n    50→            user.setBio(updateUserInput.getBio());\n    51→        }\n    52→\n    53→        if (isPresent(updateUserInput.getImage())) {\n    54→            user.setImage(updateUserInput.getImage());\n    55→        }\n    56→    }\n    57→\n    58→    private void checkValidations(UpdateUserInput updateUserInput, UUID excludeId) {\n    59→\n    60→        if (isPresent(updateUserInput.getUsername())) {\n    61→            checkUsername(excludeId, updateUserInput.getUsername());\n    62→        }\n    63→\n    64→        if (isPresent(updateUserInput.getEmail())) {\n    65→            checkEmail(excludeId, updateUserInput.getEmail());\n    66→        }\n    67→    }\n    68→\n    69→    private boolean isPresent(String property) {\n    70→        return property != null && !property.isEmpty();\n    71→    }\n    72→\n    73→    private void checkUsername(UUID selfId, String username) {\n    74→        if (userRepository.existsUsername(selfId, username)) {\n    75→            throw new UsernameAlreadyExistsException();\n    76→        }\n    77→    }\n    78→\n    79→    private void checkEmail(UUID selfId, String email) {\n    80→        if (userRepository.existsEmail(selfId, email)) {\n    81→            throw new EmailAlreadyExistsException();\n    82→  