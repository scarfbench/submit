UPPER(t.name) = :name\";\n    38→        TypedQuery<TagEntity> query = em.createQuery(jpql, TagEntity.class);\n    39→        query.setParameter(\"name\", name.toUpperCase().trim());\n    40→\n    41→        List<TagEntity> resultList = query.getResultList();\n    42→        if (!resultList.isEmpty()) {\n    43→            Tag t = entityUtils.tag(resultList.get(0));\n    44→            return Optional.of(t);\n    45→        } else {\n    46→            return Optional.empty();\n    47→        }\n    48→    }\n    49→\n    50→    @Override\n    51→    public void save(Tag tag) {\n    52→        em.persist(new TagEntity(tag));\n    53→    }\n    54→\n    55→    @Override\n    56→    public List<Tag> findByNames(List<String> names) {\n    57→\n    58→        Query query = em.createNamedQuery(\"TagEntity.findByNamesIgnoreCase\");\n    59→        query.setParameter(\"names\", toUpperCase(names));\n    60→\n    61→        List<TagEntity> resultList = query.getResultList();\n    62→        return resultList.stream().map(entityUtils::tag).collect(Collectors.toList());\n    63→    }\n    64→}\n    65→"}]},"parent_tool_use_id":"toolu_bdrk_01TrtD1tKbaKwmrGzynjzvXR","session_id":"1968c9d1-9222-41bb-9d6c-3e0081e3cb16","uuid":"c2b0f566-d262-44a5-8079-d497e9e156d1"}
