.getName());\n    33→    final var user = findUserById.handle(userId);\n    34→    final var token = tokenProvider.createUserToken(user.getId().toString());\n    35→    return Response.ok(new UserResponse(user, token)).status(Response.Status.OK).build();\n    36→  }\n    37→\n    38→  @PUT\n    39→  @Transactional\n    40→  @RolesAllowed({\"USER\", \"ADMIN\"})\n    41→  @Consumes(MediaType.APPLICATION_JSON)\n    42→  @Produces(MediaType.APPLICATION_JSON)\n    43→  public Response update(\n    44→      @Context SecurityContext securityContext,\n    45→      @Valid @NotNull(message = ValidationMessages.REQUEST_BODY_MUST_BE_NOT_NULL)\n    46→          UpdateUserRequest updateUserRequest) {\n    47→    final var userId = UUID.fromString(securityContext.getUserPrincipal().getName());\n    48→    final var user = updateUser.handle(updateUserRequest.toUpdateUserInput(userId));\n    49→    final var token = tokenProvider.createUserToken(user.getId().toString());\n    50→    return Response.ok(new UserResponse(user, token)).status(Response.Status.OK).build();\n    51→  }\n    52→}\n    53→"}]},"parent_tool_use_id":"toolu_bdrk_01XkTiu9aVstQ59zWiy6Ux2C","session_id":"d45be86e-3e5a-4433-b76a-a33ae6e615f7","uuid":"e5ab0a0c-5c5d-4dea-a9e2-2f320b0c12fe"}
