\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK)\n   110→          String slug) {\n   111→    final var article = findArticleBySlug.handle(slug);\n   112→    return Response.ok(resourceUtils.articleResponse(article, null))\n   113→        .status(Response.Status.OK)\n   114→        .build();\n   115→  }\n   116→\n   117→  @PUT\n   118→  @Transactional\n   119→  @Path(\"/{slug}\")\n   120→  @RolesAllowed({\"USER\", \"ADMIN\"})\n   121→  @Consumes(MediaType.APPLICATION_JSON)\n   122→  @Produces(MediaType.APPLICATION_JSON)\n   123→  public Response update(\n   124→      @PathParam(\"slug\") @NotBlank String slug,\n   125→      @Valid @NotNull UpdateArticleRequest updateArticleRequest,\n   126→      @Context SecurityContext securityContext) {\n   127→    final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   128→    final var updatedArticle =\n   129→        updateArticleBySlug.handle(updateArticleRequest.toUpdateArticleInput(loggedUserId, slug));\n   130→    return Response.ok(resourceUtils.articleResponse(updatedArticle, null))\n   131→        .status(Response.Status.OK)\n   132→        .build();\n   133→  }\n   134→\n   135→  @DELETE\n   136→  @Transactional\n   137→  @Path(\"/{slug}\")\n   138→  @RolesAllowed({\"USER\", \"ADMIN\"})\n   139→  @Produces(MediaType.APPLICATION_JSON)\n   140→  public Response delete(\n   141→      @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   142→      @Context SecurityContext securityContext) {\n   143→    final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   144→    deleteArticleBySlug.handle(loggedUserId, slug);\n   145→    return Response.ok().build();\n   146→  }\n   147→\n   148→  @GET\n   149→  @Path(\"/{slug}/comments\")\n   150→  @Produces(MediaType.APPLICATION_JSON)\n   151→  public Response getCommentsBySlug(\n   152→      @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   153→      @Context SecurityContext securityContext)\n   154→      throws JsonProcessingException {\n   155→    final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   156→    final var comments = findCommentsByArticleSlug.handle(slug);\n   157→    return Response.ok(\n   158→            objectMapper.writeValueAsString(resourceUtils.commentsResponse(comments, loggedUserId)))\n   159→        .status(Response.Status.OK)\n   160→        .build();\n   161→  }\n   162→\n   163→  @POST\n   164→  @Transactional\n   165→  @Path(\"/{slug}/comments\")\n   166→  @RolesAllowed({\"USER\", \"ADMIN\"})\n   167→  @Consumes(MediaType.APPLICATION_JSON)\n   168→  @Produces(MediaType.APPLICATION_JSON)\n   169→  public Response createComment(\n   170→      @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   171→      @Valid NewCommentRequest newCommentRequest,\n   172→      @Context SecurityContext securityContext) {\n   173→    final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   174→    final var comment =\n   175→        createComment.handle(newCommentRequest.toNewCommentInput(loggedUserId, slug));\n   176→    return Response.ok(resourceUtils.commentResponse(comment, loggedUserId))\n   177→        .status(Response.Status.OK)\n   178→        .build();\n   179→  }\n   180→\n   181→  @DELETE\n   182→  @Transactional\n   183→  @Path(\"/{slug}/comments/{id}\")\n   184→  @RolesAllowed({\"USER\", \"ADMIN\"})\n   185→  @Produces(MediaType.APPLICATION_JSON)\n   186→  public Response deleteComment(\n   187→      @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   188→      @PathParam(\"id\") @NotNull(message = ValidationMessages.COMMENT_ID_MUST_BE_NOT_NULL) UUID id,\n   189→      @Context SecurityContext securityContext) {\n   190→    final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   191→    deleteComment.hand