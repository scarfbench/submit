fo(\"JPA EntityManager ready\");\n    35→\n    36→        // Configure RESTEasy with CDI\n    37→        ResteasyDeployment deployment = new ResteasyDeploymentImpl();\n    38→        deployment.setInjectorFactoryClass(CdiInjectorFactory.class.getName());\n    39→\n    40→        // Register JAX-RS resource classes\n    41→        deployment.setScannedResourceClasses(List.of(\n    42→            \"org.example.realworldapi.application.web.resource.HealthResource\",\n    43→            \"org.example.realworldapi.application.web.resource.ArticlesResource\",\n    44→            \"org.example.realworldapi.application.web.resource.ProfilesResource\",\n    45→            \"org.example.realworldapi.application.web.resource.TagsResource\",\n    46→            \"org.example.realworldapi.application.web.resource.UserResource\",\n    47→            \"org.example.realworldapi.application.web.resource.UsersResource\"\n    48→        ));\n    49→\n    50→        // Register JAX-RS provider classes\n    51→        deployment.setScannedProviderClasses(List.of(\n    52→            \"org.example.realworldapi.infrastructure.web.security.JwtSecurityFilter\",\n    53→            \"org.example.realworldapi.infrastructure.web.security.RolesAllowedFilter\",\n    54→            \"org.example.realworldapi.infrastructure.web.provider.JacksonConfigProvider\",\n    55→            \"org.example.realworldapi.infrastructure.web.mapper.BeanValidationExceptionMapper\",\n    56→            \"org.example.realworldapi.infrastructure.web.mapper.BusinessExceptionMapper\",\n    57→            \"org.example.realworldapi.infrastructure.web.mapper.GenericExceptionMapper\"\n    58→        ));\n    59→\n    60→        // Build Undertow deployment\n    61→        BeanManager beanManager = container.getBeanManager();\n    62→        DeploymentInfo di = new DeploymentInfo()\n    63→                .addServletContextAttribute(\n    64→                    ResteasyDeployment.class.getName(), deployment)\n    65→                .addServletContextAttribute(\n    66→                    \"jakarta.enterprise.inject.spi.BeanManager\", beanManager)\n    67→                .setContextPath(\"/api\")\n    68→                .setDeploymentName(\"ResteasyUndertow\")\n    69→                .setClassLoader(Main.class.getClassLoader())\n    70→                .addServlet(\n    71→                    Servlets.servlet(\"ResteasyServlet\",\n    72→                        org.jboss.resteasy.plugins.server.servlet.HttpServletDispatcher.class)\n    73→                        .setAsyncSupported(true)\n    74→                        .setLoadOnStartup(1)\n    75→                        .addMapping(\"/*\")\n    76→                );\n    77→\n    78→        UndertowJaxrsServer server = new UndertowJaxrsServer();\n    79→        server.start(\n    80→            Undertow.builder()\n    81→                .addHttpListener(port, host)\n    82→        );\n    83→        server.deploy(di);\n    84→\n    85→        LOG.info(\"RealWorld API started on port {}\", port);\n    86→        LOG.info(\"API available at http://{}:{}/api\", host, port);\n    87→\n    88→        Runtime.getRuntime().addShutdownHook(new Thread(() -> {\n    89→            LOG.info(\"Shutting down...\");\n    90→            server.stop();\n    91→            container.close();\n    92→        }));\n    93→    }\n    94→}\n    95→"}]},"parent_tool_use_id":null,"session_id":"d45be86e-3e5a-4433-b76a-a33ae6e615f7","uuid":"c26b05f3-2266-432a-afa0-4ae54dc0e159"}
