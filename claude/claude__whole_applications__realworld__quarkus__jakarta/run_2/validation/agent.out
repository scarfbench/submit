sses.add(BusinessExceptionMapper.class);\n    classes.add(GenericExceptionMapper.class);\n    // Providers\n    classes.add(JacksonConfigProvider.class);\n    // Security\n    classes.add(JwtSecurityFilter.class);\n    classes.add(RolesAllowedFilter.class);\n    return classes;\n  }\n}"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":767,"cache_read_input_tokens":154265,"cache_creation":{"ephemeral_5m_input_tokens":767,"ephemeral_1h_input_tokens":0},"output_tokens":669},"context_management":null},"parent_tool_use_id":null,"session_id":"d45be86e-3e5a-4433-b76a-a33ae6e615f7","uuid":"308a66ec-aa22-456f-9c9d-bf957b194cd5"}
