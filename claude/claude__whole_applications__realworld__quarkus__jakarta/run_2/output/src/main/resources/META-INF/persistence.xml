<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="realworld" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.UserEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.ArticleEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.CommentEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.TagEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.TagRelationshipEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.TagRelationshipEntityKey</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.FavoriteRelationshipEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.FavoriteRelationshipEntityKey</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.FollowRelationshipEntity</class>
        <class>org.example.realworldapi.infrastructure.repository.hibernate.entity.FollowRelationshipEntityKey</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/realworld"/>
            <property name="jakarta.persistence.jdbc.user" value="realworld"/>
            <property name="jakarta.persistence.jdbc.password" value="realworld"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
