      <scope>provided</scope>\n   179→        </dependency>\n   180→\n   181→        <!-- Apache Commons -->\n   182→        <dependency>\n   183→            <groupId>org.apache.commons</groupId>\n   184→            <artifactId>commons-lang3</artifactId>\n   185→            <version>3.17.0</version>\n   186→        </dependency>\n   187→\n   188→        <!-- Logging -->\n   189→        <dependency>\n   190→            <groupId>org.slf4j</groupId>\n   191→            <artifactId>slf4j-api</artifactId>\n   192→            <version>2.0.17</version>\n   193→        </dependency>\n   194→        <dependency>\n   195→            <groupId>ch.qos.logback</groupId>\n   196→            <artifactId>logback-classic</artifactId>\n   197→            <version>1.5.16</version>\n   198→        </dependency>\n   199→        <dependency>\n   200→            <groupId>org.jboss.logging</groupId>\n   201→            <artifactId>jboss-logging</artifactId>\n   202→            <version>3.6.1.Final</version>\n   203→        </dependency>\n   204→    </dependencies>\n   205→\n   206→    <build>\n   207→        <plugins>\n   208→            <plugin>\n   209→                <artifactId>maven-compiler-plugin</artifactId>\n   210→                <version>3.14.0</version>\n   211→                <configuration>\n   212→                    <release>21</release>\n   213→                    <compilerArgs>\n   214→                        <arg>-parameters</arg>\n   215→                    </compilerArgs>\n   216→                    <annotationProcessorPaths>\n   217→                        <path>\n   218→                            <groupId>org.projectlombok</groupId>\n   219→                            <artifactId>lombok</artifactId>\n   220→                            <version>${lombok.version}</version>\n   221→                        </path>\n   222→                    </annotationProcessorPaths>\n   223→                </configuration>\n   224→                <executions>\n   225→                 