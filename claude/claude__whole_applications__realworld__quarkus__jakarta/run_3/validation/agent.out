lworldapi.infrastructure.repository.hibernate.entity.TagRelationshipEntityKey</class>\n\n        <properties>\n            <property name=\"jakarta.persistence.jdbc.driver\" value=\"org.postgresql.Driver\"/>\n            <property name=\"jakarta.persistence.jdbc.url\" value=\"jdbc:postgresql://localhost:5432/realworld\"/>\n            <property name=\"jakarta.persistence.jdbc.user\" value=\"realworld\"/>\n            <property name=\"jakarta.persistence.jdbc.password\" value=\"realworld\"/>\n            <property name=\"hibernate.dialect\" value=\"org.hibernate.dialect.PostgreSQLDialect\"/>\n            <property name=\"hibernate.hbm2ddl.auto\" value=\"create-drop\"/>\n            <property name=\"hibernate.show_sql\" value=\"false\"/>\n            <property name=\"hibernate.format_sql\" value=\"false\"/>\n        </properties>\n    </persistence-unit>\n</persistence>\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1034,"cache_read_input_tokens":99823,"cache_creation":{"ephemeral_5m_input_tokens":1034,"ephemeral_1h_input_tokens":0},"output_tokens":803},"context_management":null},"parent_tool_use_id":null,"session_id":"9cccbbd3-df4b-4bdc-8bbb-45d794239170","uuid":"f35c51a7-6eaa-4b8b-b15b-418eb94232a1"}
