f);\n   129→\n   130→        int octLen = pkcs1Bytes.length;\n   131→        pkcs8[pkcs8Header.length - 2] = (byte)(octLen >> 8);\n   132→        pkcs8[pkcs8Header.length - 1] = (byte)(octLen & 0xff);\n   133→\n   134→        PKCS8EncodedKeySpec spec = new PKCS8EncodedKeySpec(pkcs8);\n   135→        KeyFactory kf = KeyFactory.getInstance(\"RSA\");\n   136→        return (RSAPrivateKey) kf.generatePrivate(spec);\n   137→    }\n   138→\n   139→    private RSAPublicKey loadPublicKey(String resourceName) throws Exception {\n   140→        String pem = loadResource(resourceName);\n   141→        pem = pem.replace(\"-----BEGIN PUBLIC KEY-----\", \"\")\n   142→                  .replace(\"-----END PUBLIC KEY-----\", \"\")\n   143→                  .replace(\"-----BEGIN RSA PUBLIC KEY-----\", \"\")\n   144→                  .replace(\"-----END RSA PUBLIC KEY-----\", \"\")\n   145→                  .replaceAll(\"\\\\s\", \"\");\n   146→\n   147→        byte[] decoded = Base64.getDecoder().decode(pem);\n   148→        X509EncodedKeySpec spec = new X509EncodedKeySpec(decoded);\n   149→        KeyFactory kf = KeyFactory.getInstance(\"RSA\");\n   150→        return (RSAPublicKey) kf.generatePublic(spec);\n   151→    }\n   152→\n   153→    private String loadResource(String name) throws Exception {\n   154→        try (InputStream is = Thread.currentThread().getContextClassLoader().getResourceAsStream(name)) {\n   155→            if (is == null) {\n   156→                throw new RuntimeException(\"Resource not found: \" + name);\n   157→            }\n   158→            return new String(is.readAllBytes(), StandardCharsets.UTF_8);\n   159→        }\n   160→    }\n   161→}\n   162→"}]},"parent_tool_use_id":null,"session_id":"9cccbbd3-df4b-4bdc-8bbb-45d794239170","uuid":"2a69acc0-a4fb-446a-988f-3d3550e8665c"}
