  38→            <groupId>jakarta.persistence</groupId>\n    39→            <artifactId>jakarta.persistence-api</artifactId>\n    40→            <version>3.2.0</version>\n    41→        </dependency>\n    42→        <dependency>\n    43→            <groupId>jakarta.transaction</groupId>\n    44→            <artifactId>jakarta.transaction-api</artifactId>\n    45→            <version>2.0.1</version>\n    46→        </dependency>\n    47→        <dependency>\n    48→            <groupId>jakarta.validation</groupId>\n    49→            <artifactId>jakarta.validation-api</artifactId>\n    50→            <version>3.1.0</version>\n    51→        </dependency>\n    52→        <dependency>\n    53→            <groupId>jakarta.annotation</groupId>\n    54→            <artifactId>jakarta.annotation-api</artifactId>\n    55→            <version>3.0.0</version>\n    56→        </dependency>\n    57→\n    58→        <!-- RESTEasy (JAX-RS implementation) with Undertow -->\n    59→        <dependency>\n    60→            <groupId>org.jboss.resteasy</groupId>\n    61→            <artifactId>resteasy-undertow-cdi</artifactId>\n    62→            <version>${resteasy.version}</version>\n    63→        </dependency>\n    64→        <dependency>\n    65→            <groupId>org.jboss.resteasy</groupId>\n    66→            <artifactId>resteasy-undertow</artifactId>\n    67→            <version>${resteasy.version}</version>\n    68→        </dependency>\n    69→        <dependency>\n    70→            <groupId>org.jboss.resteasy</groupId>\n    71→            <artifactId>resteasy-jackson2-provider</artifactId>\n    72→            <version>${resteasy.version}</version>\n    73→        </dependency>\n    74→        <dependency>\n    75→            <groupId>org.jboss.resteasy</groupId>\n    76→            <artifactId>resteasy-validator-provider</artifactId>\n    77→            <version>${resteasy.version}</version>\n    78→        </dependency>\n    79→        <dependency>\n    80→           