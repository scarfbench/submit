{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01FviG836c8zTjdeRDNq3JdX","type":"tool_result","content":"     1→package org.example.realworldapi.infrastructure.repository.hibernate.panache;\n     2→\n     3→import jakarta.enterprise.context.ApplicationScoped;\n     4→import jakarta.persistence.TypedQuery;\n     5→import java.util.*;\n     6→import java.util.stream.Collectors;\n     7→import org.example.realworldapi.domain.model.article.Article;\n     8→import org.example.realworldapi.domain.model.article.ArticleFilter;\n     9→import org.example.realworldapi.domain.model.article.ArticleRepository;\n    10→import org.example.realworldapi.domain.model.article.PageResult;\n    11→import org.example.realworldapi.infrastructure.repository.hibernate.entity.ArticleEntity;\n    12→import org.example.realworldapi.infrastructure.repository.hibernate.entity.EntityUtils;\n    13→import org.example.realworldapi.infrastructure.repository.hibernate.panache.utils.SimpleQueryBuilder;\n    14→\n    15→@ApplicationScoped\n    16→public class ArticleRepositoryPanache extends AbstractPanacheRepository\n    17→    implements ArticleRepository {\n    18→\n    19→  @jakarta.inject.Inject private EntityUtils entityUtils;\n    20→\n    21→  @Override\n    22→  public boolean existsBySlug(String slug) {\n    23→    Long count =\n    24→        em.createQuery(\"select count(a) from ArticleEntity a where upper(a.slug) = :slug\", Long.class)\n    25→            .setParameter(\"slug\", slug.toUpperCase().trim())\n    26→            .getSingleResult();\n    27→    return count > 0;\n    28→  }\n    29→\n    30→  @Override\n    31→  public void save(Article article) {\n    32→    final var author = findUserEntityById(article.getAuthor().getId());\n    33→    em.persist(new ArticleEntity(article, author));\n    34→    em.flush();\n    35→  }\n    36→\n    37→  @Override\n    38→  public Optional<Article> findArticleById(UUID id) {\n    39→    ArticleEntity entity = em.find(ArticleEntity.class, id);\n    40→    return Optional.ofNullable(entity).map(entityUtils::article);\n    41→  }\n    42→\n    43→  @Override\n    44→  public Optional<Article> findBySlug(String slug) {\n    45→    var results =\n    46→        em.createQuery(\n    47→                \"from ArticleEntity where upper(slug) = :slug\", ArticleEntity.class)\n    48→            .setParameter(\"slug\", slug.toUpperCase().trim())\n    49→            .getResultList();\n    50→    return results.stream().findFirst().map(entityUtils::article);\n    51→  }\n    52→\n    53→  @Override\n    54→  public void update(Article article) {\n    55→    final var articleEntity = findArticleEntityById(article.getId());\n    56→    articleEntity.update(article);\n    57→    em.merge(articleEntity);\n    58→  }\n    59→\n    60→  @Override\n    61→  public Optional<Article> findByAuthorAndSlug(UUID authorId, String slug) {\n    62→    var results =\n    63→        em.createQuery(\n    64→                \"from ArticleEntity where author.id = :authorId and upper(slug) = :slug\",\n    65→                ArticleEntity.class)\n    66→            .setParameter(\"authorId\", authorId)\n    67→            .setParameter(\"slug\", slug.toUpperCase().trim())\n    68→            .getResultList();\n    69→    return results.stream().findFirst().map(entityUtils::article);\n    70→  }\n    71→\n    72→  @Override\n    73→  public void delete(Article article) {\n    74→    var entity = em.find(ArticleEntity.class, article.getId());\n    75→    if (entity != null) {\n    76→      em.remove(entity);\n    77→    }\n    78→  }\n    79→\n    80→  @Override\n    81→  public PageResult<Article> findMostRecentArticlesByFilter(ArticleFilter articleFilter) {\n    82→    String jpql =\n    83→        \"select articles from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId order by articles.createdAt desc, articles.updatedAt desc\";\n    84→    var query =\n    85→        em.createQuery(jpql, ArticleEntity.class)\n    86→            .setParameter(\"loggedUserId\", articleFilter.getLoggedUserId())\n    87→            .setFirstResult(articleFilter.getOffset())\n    88→            .setMaxResults(articleFilter.getLimit());\n    89→    var articlesEntity = query.getResultList();\n    90→    final var articlesResult =\n    91→        articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n    92→    final var total = countByLoggedUser(articleFilter.getLoggedUserId());\n    93→    return new PageResult<>(articlesResult, total);\n    94→  }\n    95→\n    96→  @Override\n    97→  public PageResult<Article> findArticlesByFilter(ArticleFilter filter) {\n    98→    Map<String, Object> params = new LinkedHashMap<>();\n    99→    SimpleQueryBuilder findArticlesQueryBuilder = new SimpleQueryBuilder();\n   100→    findArticlesQueryBuilder.addQueryStatement(\"select articles from ArticleEntity as articles\");\n   101→    configFilterFindArticlesQueryBuilder(\n   102→        findArticlesQueryBuilder,\n   103→        filter.getTags(),\n   104→        filter.getAuthors(),\n   105→        filter.getFavorited(),\n   106→        params);\n   107→    String jpql =\n   108→        findArticlesQueryBuilder.toQueryString()\n   109→            + \" order by articles.createdAt desc, articles.updatedAt desc\";\n   110→    TypedQuery<ArticleEntity> query = em.createQuery(jpql, ArticleEntity.class);\n   111→    params.forEach(query::setParameter);\n   112→    query.setFirstResult(filter.getOffset());\n   113→    query.setMaxResults(filter.getLimit());\n   114→    var articlesEntity = query.getResultList();\n   115→    final var articlesResult =\n   116→        articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n   117→    final var total = count(filter.getTags(), filter.getAuthors(), filter.getFavorited());\n   118→    return new PageResult<>(articlesResult, total);\n   119→  }\n   120→\n   121→  @Override\n   122→  public long count(List<String> tags, List<String> authors, List<String> favorited) {\n   123→    Map<String, Object> params = new LinkedHashMap<>();\n   124→    SimpleQueryBuilder countArticlesQueryBuilder = new SimpleQueryBuilder();\n   125→    countArticlesQueryBuilder.addQueryStatement(\n   126→        \"select count(distinct articles) from ArticleEntity as articles\");\n   127→    configFilterFindArticlesQueryBuilder(countArticlesQueryBuilder, tags, authors, favorited, params);\n   128→    TypedQuery<Long> query =\n   129→        em.createQuery(countArticlesQueryBuilder.toQueryString(), Long.class);\n   130→    params.forEach(query::setParameter);\n   131→    return query.getSingleResult();\n   132→  }\n   133→\n   134→  public long countByLoggedUser(UUID loggedUserId) {\n   135→    return em.createQuery(\n   136→            \"select count(distinct articles) from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId\",\n   137→            Long.class)\n   138→        .setParameter(\"loggedUserId\", loggedUserId)\n   139→        .getSingleResult();\n   140→  }\n   141→\n   142→  private void configFilterFindArticlesQueryBuilder(\n   143→      SimpleQueryBuilder findArticlesQueryBuilder,\n   144→      List<String> tags,\n   145→      List<String> authors,\n   146→      List<String> favorited,\n   147→      Map<String, Object> params) {\n   148→\n   149→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   150→        isNotEmpty(tags),\n   151→        \"inner join articles.tags as tags inner join tags.primaryKey.tag as tag\",\n   152→        \"upper(tag.name) in (:tags)\",\n   153→        () -> params.put(\"tags\", toUpperCase(tags)));\n   154→\n   155→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   156→        isNotEmpty(authors),\n   157→        \"inner join articles.author as authors\",\n   158→        \"upper(authors.username) in (:authors)\",\n   159→        () -> params.put(\"authors\", toUpperCase(authors)));\n   160→\n   161→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   162→        isNotEmpty(favorited),\n   163→        \"inner join articles.favorites as favorites inner join favorites.primaryKey.user as user\",\n   164→        \"upper(user.username) in (:favorites)\",\n   165→        () -> params.put(\"favorites\", toUpperCase(favorited)));\n   166→  }\n   167→}\n   168→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01CoasTLqMjoZUamJHataGM4","session_id":"4d21e41c-7b8c-412a-ac18-df8336bdf9ca","uuid":"e43f700a-4c28-4aa2-8216-23c3f30a9e63"}
