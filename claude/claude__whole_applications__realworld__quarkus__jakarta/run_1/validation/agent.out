              </configuration>\n   225→            </plugin>\n   226→            <plugin>\n   227→                <groupId>org.apache.maven.plugins</groupId>\n   228→                <artifactId>maven-shade-plugin</artifactId>\n   229→                <version>3.6.0</version>\n   230→                <executions>\n   231→                    <execution>\n   232→                        <phase>package</phase>\n   233→                        <goals>\n   234→                            <goal>shade</goal>\n   235→                        </goals>\n   236→                        <configuration>\n   237→                            <createDependencyReducedPom>false</createDependencyReducedPom>\n   238→                            <transformers>\n   239→                                <transformer implementation=\"org.apache.maven.plugins.shade.resource.ManifestResourceTransformer\">\n   240→                                    <mainClass>org.example.realworldapi.Main</mainClass>\n   241→                                </transformer>\n   242→                                <transformer implementation=\"org.apache.maven.plugins.shade.resource.ServicesResourceTransformer\"/>\n   243→                                <transformer implementation=\"org.apache.maven.plugins.shade.resource.AppendingTransformer\">\n   244→                                    <resource>META-INF/beans.xml</resource>\n   245→                                </transformer>\n   246→                            </transformers>\n   247→                            <filters>\n   248→                                <filter>\n   249→                                    <artifact>*:*</artifact>\n   250→                                    <excludes>\n   251→                                        <exclude>META-INF/*.SF</exclude>\n   252→                                        <exclude>META-INF/*.DSA</exclude>\n   253→                                        <exclude>META-INF/*.RSA</exclude>\n   254→                           