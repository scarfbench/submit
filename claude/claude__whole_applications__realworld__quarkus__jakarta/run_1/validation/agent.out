.isActive()) {\n    36→                em.getTransaction().commit();\n    37→            }\n    38→            return result;\n    39→        } catch (Exception e) {\n    40→            if (startedTransaction && em.getTransaction().isActive()) {\n    41→                em.getTransaction().rollback();\n    42→            }\n    43→            throw e;\n    44→        } finally {\n    45→            if (startedTransaction) {\n    46→                EntityManagerProducer.closeCurrentEntityManager();\n    47→            }\n    48→        }\n    49→    }\n    50→}\n    51→"}]},"parent_tool_use_id":null,"session_id":"4d21e41c-7b8c-412a-ac18-df8336bdf9ca","uuid":"6b01a22d-acf3-4731-a6a4-528ff4af660a"}
