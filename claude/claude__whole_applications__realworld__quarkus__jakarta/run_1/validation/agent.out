{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Py9ACGXrjjjGMRjV3ec79R","type":"tool_result","content":"     1→package org.example.realworldapi.infrastructure.repository.hibernate.panache;\n     2→\n     3→import jakarta.enterprise.context.ApplicationScoped;\n     4→import java.util.Optional;\n     5→import java.util.UUID;\n     6→import org.example.realworldapi.domain.model.user.User;\n     7→import org.example.realworldapi.domain.model.user.UserRepository;\n     8→import org.example.realworldapi.infrastructure.repository.hibernate.entity.EntityUtils;\n     9→import org.example.realworldapi.infrastructure.repository.hibernate.entity.UserEntity;\n    10→\n    11→@ApplicationScoped\n    12→public class UserRepositoryPanache extends AbstractPanacheRepository implements UserRepository {\n    13→\n    14→  @jakarta.inject.Inject private EntityUtils entityUtils;\n    15→\n    16→  @Override\n    17→  public void save(User user) {\n    18→    getEm().persist(new UserEntity(user));\n    19→  }\n    20→\n    21→  @Override\n    22→  public boolean existsBy(String field, String value) {\n    23→    Long count =\n    24→        getEm().createQuery(\n    25→                \"select count(u) from UserEntity u where upper(u.\" + field + \") = :value\",\n    26→                Long.class)\n    27→            .setParameter(\"value\", value.toUpperCase().trim())\n    28→            .getSingleResult();\n    29→    return count > 0;\n    30→  }\n    31→\n    32→  @Override\n    33→  public Optional<User> findByEmail(String email) {\n    34→    var results =\n    35→        getEm().createQuery(\"from UserEntity where upper(email) = :email\", UserEntity.class)\n    36→            .setParameter(\"email\", email.toUpperCase().trim())\n    37→            .getResultList();\n    38→    return results.stream().findFirst().map(entityUtils::user);\n    39→  }\n    40→\n    41→  @Override\n    42→  public Optional<User> findUserById(UUID id) {\n    43→    UserEntity entity = getEm().find(UserEntity.class, id);\n    44→    return Optional.ofNullable(entity).map(entityUtils::user);\n    45→  }\n    46→\n    47→  @Override\n    48→  public boolean existsUsername(UUID excludeId, String username) {\n    49→    Long count =\n    50→        getEm().createQuery(\n    51→                \"select count(u) from UserEntity u where u.id != :excludeId and upper(u.username) = :username\",\n    52→                Long.class)\n    53→            .setParameter(\"excludeId\", excludeId)\n    54→            .setParameter(\"username\", username.toUpperCase().trim())\n    55→            .getSingleResult();\n    56→    return count > 0;\n    57→  }\n    58→\n    59→  @Override\n    60→  public boolean existsEmail(UUID excludeId, String email) {\n    61→    Long count =\n    62→        getEm().createQuery(\n    63→                \"select count(u) from UserEntity u where u.id != :excludeId and upper(u.email) = :email\",\n    64→                Long.class)\n    65→            .setParameter(\"excludeId\", excludeId)\n    66→            .setParameter(\"email\", email.toUpperCase().trim())\n    67→            .getSingleResult();\n    68→    return count > 0;\n    69→  }\n    70→\n    71→  @Override\n    72→  public void update(User user) {\n    73→    final var userEntity = getEm().find(UserEntity.class, user.getId());\n    74→    userEntity.update(user);\n    75→    getEm().merge(userEntity);\n    76→  }\n    77→\n    78→  @Override\n    79→  public Optional<User> findByUsername(String username) {\n    80→    var results =\n    81→        getEm().createQuery(\"from UserEntity where upper(username) = :username\", UserEntity.class)\n    82→            .setParameter(\"username\", username.toUpperCase().trim())\n    83→            .getResultList();\n    84→    return results.stream().findFirst().map(entityUtils::user);\n    85→  }\n    86→}\n    87→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware