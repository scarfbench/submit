reation":{"ephemeral_5m_input_tokens":10097,"ephemeral_1h_input_tokens":0},"output_tokens":529},"context_management":null},"parent_tool_use_id":null,"session_id":"937f5c14-6c2e-425e-831b-fd6be18e2599","uuid":"3dba8620-7a52-448f-b06a-283883d016cc"}
