→        this.revision = revision;\n   101→        this.description = description;\n   102→        this.revisionDate = revisionDate;\n   103→        this.specification = specification;\n   104→        this.drawing = drawing;\n   105→        this.parts = new ArrayList<>();\n   106→    }\n   107→\n   108→    public String getPartNumber() {\n   109→        return partNumber;\n   110→    }\n   111→\n   112→    public void setPartNumber(String partNumber) {\n   113→        this.partNumber = partNumber;\n   114→    }\n   115→\n   116→    public int getRevision() {\n   117→        return revision;\n   118→    }\n   119→\n   120→    public void setRevision(int revision) {\n   121→        this.revision = revision;\n   122→    }\n   123→\n   124→    public String getDescription() {\n   125→        return description;\n   126→    }\n   127→\n   128→    public void setDescription(String description) {\n   129→        this.description = description;\n   130→    }\n   131→\n   132→    public Date getRevisionDate() {\n   133→        return revisionDate;\n   134→    }\n   135→\n   136→    public void setRevisionDate(Date revisionDate) {\n   137→        this.revisionDate = revisionDate;\n   138→    }\n   139→\n   140→    public Serializable getDrawing() {\n   141→        return drawing;\n   142→    }\n   143→\n   144→    public void setDrawing(Serializable drawing) {\n   145→        this.drawing = drawing;\n   146→    }\n   147→\n   148→    public String getSpecification() {\n   149→        return specification;\n   150→    }\n   151→\n   152→    public void setSpecification(String specification) {\n   153→        this.specification = specification;\n   154→    }\n   155→\n   156→    public Part getBomPart() {\n   157→        return bomPart;\n   158→    }\n   159→\n   160→    public void setBomPart(Part bomPart) {\n   161→        this.bomPart = bomPart;\n   162→    }\n   163→\n   164→    public List<Part> getParts() {\n   165→        return parts;\n   166→    }\n   167→\n   168→    public void setParts(List<Part> parts) {\n   169→        this.parts = parts;\n   170→    }\n   171→\n   172→    public VendorPart getVendorPart() {\n   173→        return vendorPart;\n   174→    }\n   175→\n   176→    public void setVendorPart(VendorPart vendorPart) {\n   177→        this.vendorPart = vendorPart;\n   178→    }\n   179→}\n   180→"}]},"parent_tool_use_id":null,"session_id":"55e73a7c-4fe4-4151-9924-02c4bb9835cf","uuid":"cae1bc76-061e-4c85-9cdc-8b2450530284"}
