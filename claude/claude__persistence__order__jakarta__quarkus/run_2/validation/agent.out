c Date getRevisionDate() {\n   107→        return revisionDate;\n   108→    }\n   109→\n   110→    public void setRevisionDate(Date revisionDate) {\n   111→        this.revisionDate = revisionDate;\n   112→    }\n   113→\n   114→    @Column(table=\"PERSISTENCE_ORDER_PART_DETAIL\")\n   115→    @Lob\n   116→    public Serializable getDrawing() {\n   117→        return drawing;\n   118→    }\n   119→\n   120→    public void setDrawing(Serializable drawing) {\n   121→        this.drawing = drawing;\n   122→    }\n   123→\n   124→    @Column(table=\"PERSISTENCE_ORDER_PART_DETAIL\")\n   125→    @Lob\n   126→    public String getSpecification() {\n   127→        return specification;\n   128→    }\n   129→\n   130→    public void setSpecification(String specification) {\n   131→        this.specification = specification;\n   132→    }\n   133→\n   134→    @ManyToOne\n   135→    @JoinColumns({\n   136→        @JoinColumn(name=\"BOMPARTNUMBER\", referencedColumnName=\"PARTNUMBER\"),\n   137→        @JoinColumn(name=\"BOMREVISION\", referencedColumnName=\"REVISION\")\n   138→    })\n   139→    public Part getBomPart() {\n   140→        return bomPart;\n   141→    }\n   142→\n   143→    public void setBomPart(Part bomPart) {\n   144→        this.bomPart = bomPart;\n   145→    }\n   146→\n   147→    @OneToMany(mappedBy=\"bomPart\")\n   148→    public List<Part> getParts() {\n   149→        return parts;\n   150→    }\n   151→\n   152→    public void setParts(List<Part> parts) {\n   153→        this.parts = parts;\n   154→    }\n   155→\n   156→    @OneToOne(mappedBy=\"part\")\n   157→    public VendorPart getVendorPart() {\n   158→        return vendorPart;\n   159→    }\n   160→\n   161→    public void setVendorPart(VendorPart vendorPart) {\n   162→        this.vendorPart = vendorPart;\n   163→    }\n   164→}\n   165→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what 