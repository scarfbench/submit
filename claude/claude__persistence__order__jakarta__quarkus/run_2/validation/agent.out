String partNumber,\n    44→            int revision,\n    45→            String description,\n    46→            java.util.Date revisionDate,\n    47→            String specification,\n    48→            Serializable drawing) {\n    49→        try {\n    50→            Part part = new Part(partNumber,\n    51→                    revision,\n    52→                    description,\n    53→                    revisionDate,\n    54→                    specification,\n    55→                    drawing);\n    56→            logger.log(Level.INFO, \"Created part {0}-{1}\", new Object[]{partNumber, revision});\n    57→            em.persist(part);\n    58→            logger.log(Level.INFO, \"Persisted part {0}-{1}\", new Object[]{partNumber, revision});\n    59→        } catch (Exception ex) {\n    60→            throw new RuntimeException(ex.getMessage(), ex);\n    61→        }\n    62→    }\n    63→\n    64→    @SuppressWarnings(\"unchecked\")\n    65→    public List<Part> getAllParts() {\n    66→        List<Part> parts = (List<Part>) em.createNamedQuery(\"findAllParts\").getResultList();\n    67→        return parts;\n    68→    }\n    69→\n    70→    public void addPartToBillOfMaterial(String bomPartNumber,\n    71→            int bomRevision,\n    72→            String partNumber,\n    73→            int revision) {\n    74→        logger.log(Level.INFO, \"BOM part number: {0}\", bomPartNumber);\n    75→        logger.log(Level.INFO, \"BOM revision: {0}\", bomRevision);\n    76→        logger.log(Level.INFO, \"Part number: {0}\", partNumber);\n    77→        logger.log(Level.INFO, \"Part revision: {0}\", revision);\n    78→        try {\n    79→            PartKey bomKey = new PartKey();\n    80→            bomKey.setPartNumber(bomPartNumber);\n    81→            bomKey.setRevision(bomRevision);\n    82→\n    83→            Part bom = em.find(Part.class, bomKey);\n    84→            logger.log(Level.INFO, \"BOM Part found: {0}\", bom.getPartNumber());\n    85→\n    86→            PartKey partKey = new PartKey();\n    87→            partKey.setPartNumber(partNumber);\n    88→            partKey.setRevision(revision);\n    89→\n    90→            Part part = em.find(Part.class, partKey);\n    91→            logger.log(Level.INFO, \"Part found: {0}\", part.getPartNumber());\n    92→            bom.getParts().add(part);\n    93→            part.setBomPart(bom);\n    94→        } catch (Exception e) {\n    95→            logger.log(Level.WARNING, \"Error adding part to BOM\", e);\n    96→        }\n    97→    }\n    98→\n    99→    public void createVendor(int vendorId,\n   100→            String name,\n   101→            String address,\n   102→            String contact,\n   103→            String phone) {\n   104→        try {\n   105→            Vendor vendor = new Vendor(vendorId, name, address, contact, phone);\n   106→            em.persist(vendor);\n   107→        } catch (Exception e) {\n   108→            throw new RuntimeException(e.getMessage(), e);\n   109→        }\n   110→    }\n   111→\n   112→    public void createVendorPart(String partNumber,\n   113→            int revision,\n   114→            String description,\n   115→            double price,\n   116→            int vendorId) {\n   117→        try {\n   118→            PartKey pkey = new PartKey();\n   119→            pkey.setPartNumber(partNumber);\n   120→            pkey.setRevision(revision);\n   121→\n   122→            Part part = em.find(Part.class, pkey);\n   123→\n   124→            VendorPart vendorPart = new VendorPart(description, price, part);\n   125→            em.persist(vendorPart);\n   126→\n   127→            Vendor vendor = em.find(Vendor.class, vendorId);\n   128→            vendor.addVendorPart(vendorPart);\n   129→            vendorPart.setVendor(vendor);\n   130→        } catch (Exception e) {\n   131→            throw new RuntimeException(e.getMessage(), e);\n   132→        }\n   133→    }\n   134→\n   135→    public void createOrder(Integer orderId, char status, int discount, String shipmentInfo) {\n   136→        try {\n   137→            CustomerOrder order = new CustomerOrder(orderId, status, discount, shipmentInfo);\n   138→            em.persist(order);\n   139→        } catch (Exception e) {\n   140→            throw new RuntimeException(e.getMessage(), e);\n   141→        }\n   142→    }\n   143→\n   144→    @SuppressWarnings(\"unchecked\")\n   145→    public List<CustomerOrder> getOrders() {\n   146→        try {\n   147→            return (List<CustomerOrder>) em.createNamedQuery(\"findAllOrders\").getResultList();\n   148→        } catch (Exception e) {\n   149→            throw new RuntimeException(e.getMessage(), e);\n   150→        }\n   151→    }\n   152→\n   153→    public void addLineItem(Integer orderId, String partNumber, int revision, int quantity) {\n   154→        try {\n   155→            CustomerOrder order = em.find(CustomerOrder.class, orderId);\n   156→            logger.log(Level.INFO, \"Found order ID {0}\", orderId);\n   157→\n   158→            PartKey pkey = new PartKey();\n   159→            pkey.setPartNumber(partNumber);\n   160→            pkey.setRevision(revision);\n   161→\n   162→            Part part = em.find(Part.class, pkey);\n   163→\n   164→            LineItem lineItem = new LineItem(order, quantity, part.getVendorPart());\n   165→            order.addLineItem(lineItem);\n   166→        } catch (Exception e) {\n   167→            logger.log(Level.WARNING, \"Couldn''t add {0} to order ID {1}.\", new Object[]{partNumber, orderId});\n   168→            throw new RuntimeException(e.getMessage(), e);\n   169→        }\n   170→    }\n   171→\n   172→    public double getBillOfMaterialPrice(String bomPartNumber, int bomRevision, String partNumber, int revision) {\n   173→        double price = 0.0;\n   174→        try {\n   175→            PartKey bomkey = new PartKey();\n   176→            bomkey.setPartNumber(bomPartNumber);\n   177→            bomkey.setRevision(bomRevision);\n   178→\n   179→            Part bom = em.find(Part.class, bomkey);\n   180→            Collection<Part> parts = bom.getParts();\n   181→            for (Part part : parts) {\n   182→                VendorPart vendorPart = part.getVendorPart();\n   183→                price += vendorPart.getPrice();\n   184→            }\n   185→\n   186→        } catch (Exception e) {\n   187→            throw new RuntimeException(e.getMessage(), e);\n   188→        }\n   189→        return price;\n   190→    }\n   191→\n   192→    public double getOrderPrice(Integer orderId) {\n   193→        double price = 0.0;\n   194→        try {\n   195→            CustomerOrder order = em.find(CustomerOrder.class, orderId);\n   196→            price = order.calculateAmmount();\n   197→        } catch (Exception e) {\n   198→            throw new RuntimeException(e.getMessage(), e);\n   199→        }\n   200→        return price;\n   201→    }\n   202→\n   203→    @SuppressWarnings(\"unchecked\")\n   204→    public void adjustOrderDiscount(int adjustment) {\n   205→        try {\n   206→            List<CustomerOrder> orders = em.createNamedQuery(\"findAllOrders\").getResultList();\n   207→            for (CustomerOrder order : orders) {\n   208→                int newDiscount = order.getDiscount() + adjustment;\n   209→                order.setDiscount((newDiscount > 0) ? newDiscount : 0);\n   210→            }\n   211→        } catch (Exception e) {\n   212→            throw new RuntimeException(e.getMessage(), e);\n   213→        }\n   214→    }\n   215→\n   216→    public Double getAvgPrice() {\n   217→        try {\n   218→            return (Double) em.createNamedQuery(\n   219→                    \"findAverageVendorPartPrice\")\n   220→                    .getSingleResult();\n   221→        } catch (Exception e) {\n   222→            throw new RuntimeException(e.getMessage(), e);\n   223→        }\n   224→    }\n   225→\n   226→    public Double getTotalPricePerVendor(int vendorId) {\n   227→        try {\n   228→            return (Double) em.createNamedQuery(\n   229→                    \"findTotalVendorPartPricePerVendor\")\n   230→                    .setParameter(\"id\", vendorId)\n   231→                    .getSingleResult();\n   232→        } catch (Exception e) {\n   233→            throw new RuntimeException(e.getMessage(), e);\n   234→        }\n   235→    }\n   236→\n   237→    @SuppressWarnings(\"unchecked\")\n   238→    public List<String> locateVendorsByPartialName(String name) {\n   239→\n   240→        List<String> names = new ArrayList<>();\n   241→        try {\n   242→            List<Vendor> vendors = em.createNamedQuery(\n   243→                    \"findVendorsByPartialName\")\n   244→                    .setParameter(\"name\", name)\n   245→                    .getResultList();\n   246→            for (Vendor vendor : vendors) {\n   247→                names.add(vendor.getName());\n   248→            }\n   249→        } catch (Exception e) {\n   250→            throw new RuntimeException(e.getMessage(), e);\n   251→        }\n   252→        return names;\n   253→    }\n   254→\n   255→    @SuppressWarnings(\"unchecked\")\n   256→    public int countAllItems() {\n   257→        int count = 0;\n   258→        try {\n   259→            count = em.createNamedQuery(\n   260→                    \"findAllLineItems\")\n   261→                    .getResultList()\n   262→                    .size();\n   263→        } catch (Exception e) {\n   264→            throw new RuntimeException(e.getMessage(), e);\n   265→        }\n   266→        return count;\n   267→    }\n   268→\n   269→    @SuppressWarnings(\"unchecked\")\n   270→    public List<LineItem> getLineItems(int orderId) {\n   271→        try {\n   272→            return em.createNamedQuery(\"findLineItemsByOrderId\")\n   273→                    .setParameter(\"orderId\", orderId)\n   274→                    .getResultList();\n   275→        } catch (Exception e) {\n   276→            throw new RuntimeException(e.getMessage(), e);\n   277→        }\n   278→    }\n   279→\n   280→    public void removeOrder(Integer orderId) {\n   281→        try {\n   282→            CustomerOrder order = em.find(CustomerOrder.class, orderId);\n   283→            em.remove(order);\n   284→        } catch (Exception e) {\n   285→            throw new RuntimeException(e.getMessage(), e);\n   286→        }\n   287→    }\n   288→\n   289→    @SuppressWarnings(\"unchecked\")\n   290→    public String reportVendorsByOrder(Integer orderId) {\n   291→        StringBuilder report = new StringBuilder();\n   292→        try {\n   293→            List<Vendor> vendors = em.createNamedQuery(\n   294→                    \"findVendorByCustomerOrder\")\n   295→                    .setParameter(\"id\", orderId)\n   296→                    .getResultList();\n   297→            for (Vendor vendor : vendors) {\n   298→                report.append(vendor.getVendorId()).append(' ')\n   299→                .append(vendor.getName()).append(' ')\n   300→                .append(vendor.getContact()).append('\\n');\n   301→            }\n   302→\n   303→        } catch (Exception e) {\n   304→            throw new RuntimeException(e.getMessage(), e);\n   305→        }\n   306→        return report.toString();\n   307→    }\n   308→}\n   309→"}]},"parent_tool_use_id":null,"session_id":"04849b1d-a68c-421a-9431-0379c34c836f","uuid":"af6b3bbe-1b1f-400a-9ecb-07eea7713208"}
