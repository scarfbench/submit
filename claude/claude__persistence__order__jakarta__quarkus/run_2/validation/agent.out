ndorPart.vendor.name\"\n    42→    )\n    43→})\n    44→public class Vendor implements java.io.Serializable {\n    45→    private static final long serialVersionUID = 2538635007598426330L;\n    46→    private int vendorId;\n    47→    private String name;\n    48→    private String address;\n    49→    private String contact;\n    50→    private String phone;\n    51→    private Collection<VendorPart> vendorParts;\n    52→\n    53→    public Vendor() {}\n    54→\n    55→    public Vendor(int vendorId,\n    56→            String name,\n    57→            String address,\n    58→            String contact,\n    59→            String phone) {\n    60→        this.vendorId = vendorId;\n    61→        this.name = name;\n    62→        this.address = address;\n    63→        this.contact = contact;\n    64→        this.phone = phone;\n    65→    }\n    66→\n    67→    @Id\n    68→    public int getVendorId() {\n    69→        return vendorId;\n    70→    }\n    71→\n    72→    public void setVendorId(int vendorId) {\n    73→        this.vendorId = vendorId;\n    74→    }\n    75→\n    76→    @Column(name=\"VENDORNAME\")\n    77→    public String getName() {\n    78→        return name;\n    79→    }\n    80→\n    81→    public void setName(String name) {\n    82→        this.name = name;\n    83→    }\n    84→\n    85→    public String getAddress() {\n    86→        return address;\n    87→    }\n    88→\n    89→    public void setAddress(String address) {\n    90→        this.address = address;\n    91→    }\n    92→\n    93→    public String getContact() {\n    94→        return contact;\n    95→    }\n    96→\n    97→    public void setContact(String contact) {\n    98→        this.contact = contact;\n    99→    }\n   100→\n   101→    public String getPhone() {\n   102→        return phone;\n   103→    }\n   104→\n   105→    public void setPhone(String phone) {\n   106→        this.phone = phone;\n   107→    }\n   108→\n   109→    @OneToMany(cascade=CascadeType.ALL, mappedBy=\"vendor\")\n   110→    @JsonIgnore\n   111→    public Collection<VendorPart> getVendorParts() {\n   112→        return vendorParts;\n   113→    }\n   114→\n   115→    public void setVendorParts(Collection<VendorPart> vendorParts) {\n   116→        this.vendorParts = vendorParts;\n   117→    }\n   118→\n   119→    public void addVendorPart(VendorPart vendorPart) {\n   120→        this.getVendorParts().add(vendorPart);\n   121→    }\n   122→}\n   123→"}]},"parent_tool_use_id":null,"session_id":"04849b1d-a68c-421a-9431-0379c34c836f","uuid":"d9c8eac2-2bb4-4266-875c-b9533aaa163c"}
