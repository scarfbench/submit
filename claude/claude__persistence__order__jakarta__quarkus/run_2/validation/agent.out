{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01CWPxpvGHwpPg3ZR7H49XoV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_014jRGv5kyMNJLZrDgcyS1kY","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__order__jakarta__quarkus/run_2/output/smoke.py","content":"\"\"\"\nSmoke tests for the Order Management Quarkus application.\nTests the REST API endpoints that replace the original JSF web layer.\n\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\ndef make_request(method, path, data=None, content_type=\"application/json\"):\n    \"\"\"Helper to make HTTP requests.\"\"\"\n    url = f\"{BASE_URL}{path}\"\n    headers = {}\n    body = None\n    if data is not None:\n        body = json.dumps(data).encode(\"utf-8\")\n        headers[\"Content-Type\"] = content_type\n    req = urllib.request.Request(url, data=body, headers=headers, method=method)\n    try:\n        with urllib.request.urlopen(req, timeout=10) as resp:\n            resp_body = resp.read().decode(\"utf-8\")\n            return resp.status, resp_body\n    except urllib.error.HTTPError as e:\n        return e.code, e.read().decode(\"utf-8\") if e.fp else \"\"\n    except Exception as e:\n        return None, str(e)\n\n\ndef wait_for_app(max_wait=120):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    print(f\"Waiting for application at {BASE_URL} ...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            req = urllib.request.Request(f\"{BASE_URL}/q/health/ready\", method=\"GET\")\n            with urllib.request.urlopen(req, timeout=5) as resp:\n                if resp.status == 200:\n                    print(\"Application is ready!\")\n                    return True\n        except Exception:\n            pass\n        time.sleep(2)\n    print(\"Application did not become ready in time.\")\n    return False\n\n\ndef test_health_endpoint():\n    \"\"\"Test that health endpoint returns 200.\"\"\"\n    print(\"TEST: Health endpoint...\")\n    status, body = make_request(\"GET\", \"/q/health\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert data.get(\"status\") == \"UP\", f\"Expected UP status, got {data}\"\n    print(\"  PASSED\")\n\n\ndef test_get_orders():\n    \"\"\"Test that GET /api/orders returns the pre-loaded orders.\"\"\"\n    print(\"TEST: Get all orders...\")\n    status, body = make_request(\"GET\", \"/api/orders\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    orders = json.loads(body)\n    assert isinstance(orders, list), f\"Expected list, got {type(orders)}\"\n    assert len(orders) >= 2, f\"Expected at least 2 orders, got {len(orders)}\"\n\n    order_ids = [o[\"orderId\"] for o in orders]\n    assert 1111 in order_ids, f\"Order 1111 not found in {order_ids}\"\n    assert 4312 in order_ids, f\"Order 4312 not found in {order_ids}\"\n    print(f\"  PASSED - Found {len(orders)} orders\")\n\n\ndef test_get_order_line_items():\n    \"\"\"Test that GET /api/orders/1111/lineItems returns line items.\"\"\"\n    print(\"TEST: Get line items for order 1111...\")\n    status, body = make_request(\"GET\", \"/api/orders/1111/lineItems\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    items = json.loads(body)\n    assert isinstance(items, list), f\"Expected list, got {type(items)}\"\n    assert len(items) == 3, f\"Expected 3 line items, got {len(items)}\"\n    print(f\"  PASSED - Found {len(items)} line items\")\n\n\ndef test_get_parts():\n    \"\"\"Test that GET /api/parts returns all parts.\"\"\"\n    print(\"TEST: Get all parts...\")\n    status, body = make_request(\"GET\", \"/api/parts\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    parts = json.loads(body)\n    assert isinstance(parts, list), f\"Expected list, got {type(parts)}\"\n    assert len(parts) >= 5, f\"Expected at least 5 parts, got {len(parts)}\"\n    print(f\"  PASSED - Found {len(parts)} parts\")\n\n\ndef test_search_vendors():\n    \"\"\"Test that GET /api/vendors/search?name=Widget returns results.\"\"\"\n    print(\"TEST: Search vendors by name 'Widget'...\")\n    status, body = make_request(\"GET\", \"/api/vendors/search?name=Widget\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    vendors = json.loads(body)\n    assert isinstance(vendors, list), f\"Expected list, got {type(vendors)}\"\n    assert len(vendors) >= 1, f\"Expected at least 1 vendor, got {len(vendors)}\"\n    assert \"WidgetCorp\" in vendors, f\"Expected WidgetCorp in {vendors}\"\n    print(f\"  PASSED - Found vendors: {vendors}\")\n\n\ndef test_average_vendor_part_price():\n    \"\"\"Test average vendor part price endpoint.\"\"\"\n    print(\"TEST: Average vendor part price...\")\n    status, body = make_request(\"GET\", \"/api/vendorparts/avgprice\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, dict), f\"Expected dict, got {type(data)}\"\n    avg_price = data.get(\"value\", 0)\n    assert avg_price > 0, f\"Expected positive price, got {avg_price}\"\n    print(f\"  PASSED - Average price: {avg_price}\")\n\n\ndef test_total_price_per_vendor():\n    \"\"\"Test total price per vendor endpoint.\"\"\"\n    print(\"TEST: Total price for vendor 100...\")\n    status, body = make_request(\"GET\", \"/api/vendors/100/totalprice\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, dict), f\"Expected dict, got {type(data)}\"\n    total = data.get(\"value\", 0)\n    assert total > 0, f\"Expected positive total, got {total}\"\n    print(f\"  PASSED - Total price for vendor 100: {total}\")\n\n\ndef test_order_price():\n    \"\"\"Test order price calculation endpoint.\"\"\"\n    print(\"TEST: Order price for order 1111...\")\n    status, body = make_request(\"GET\", \"/api/orders/1111/price\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, dict), f\"Expected dict, got {type(data)}\"\n    price = data.get(\"value\", 0)\n    assert price > 0, f\"Expected positive price, got {price}\"\n    print(f\"  PASSED - Order 1111 price: {price}\")\n\n\ndef test_line_item_count():\n    \"\"\"Test line item count endpoint.\"\"\"\n    print(\"TEST: Count all line items...\")\n    status, body = make_request(\"GET\", \"/api/lineItems/count\")\n    assert status == 200, f\"Expected 200, got {status}: {body}\"\n    data = json.loads(body)\n    assert isinstance(data, dict), f\"Expected dict, got {type(data)}\"\n    count = data.get(\"value\", 0)\n    assert count >= 6, f\"Expected at least 6 line items, got {count}\"\n    print(f\"  PASSED - Total line items: {count}\")\n\n\ndef test_create_and_delete_order():\n    \"\"\"Test creating a new order and then deleting it.\"\"\"\n    print(\"TEST: Create and delete order...\")\n\n    # Create order\n    order_data = {\n        \"orderId\": 9999,\n        \"status\": \"N\",\n        \"discount\": 5,\n        \"shipmentInfo\": \"Test Address\"\n    }\n    status, body = make_request(\"POST\", \"/api/orders\", order_data)\n    assert status == 200, f\"Expected 200 for create, got {status}: {body}\"\n\n    # Verify it exists\n    status, body = make_request(\"GET\", \"/api/orders\")\n    orders = json.loads(body)\n    order_ids = [o[\"orderId\"] for o in orders]\n    assert 9999 in order_ids, f\"Newly created order 9999 not found\"\n\n    # Delete order\n    status, body = make_request(\"DELETE\", \"/api/orders/9999\")\n    assert status == 200, f\"Expected 200 for delete, got {status}: {body}\"\n\n    # Verify it's gone\n    status, body = make_request(\"GET\", \"/api/orders\")\n    orders = json.loads(body)\n    order_ids = [o[\"orderId\"] for o in orders]\n    assert 9999 not in order_ids, f\"Deleted order 9999 still found\"\n    print(\"  PASSED\")\n\n\ndef main():\n    if not wait_for_app():\n        print(\"FAIL: Application not ready\")\n        sys.exit(1)\n\n    tests = [\n        test_health_endpoint,\n        test_get_orders,\n        test_get_order_line_items,\n        test_get_parts,\n        test_search_vendors,\n        test_average_vendor_part_price,\n        test_total_price_per_vendor,\n        test_order_price,\n        test_line_item_count,\n        test_create_and_delete_order,\n    ]\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    for test_fn in tests:\n        try:\n            test_fn()\n            passed += 1\n        except AssertionError as e:\n            failed += 1\n            errors.append(f\"  FAILED: {test_fn.__name__}: {e}\")\n            print(f\"  FAILED: {e}\")\n        except Exception as e:\n            failed += 1\n            errors.append(f\"  ERROR: {test_fn.__name__}: {e}\")\n            print(f\"  ERROR: {e}\")\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n    if errors:\n        print(\"Failures:\")\n        for err in errors:\n            print(err)\n    print(f\"{'='*50}\")\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1480,"cache_read_input_tokens":142710,"cache_creation":{"ephemeral_5m_input_tokens":1480,"ephemeral_1h_input_tokens":0},"output_tokens":2783},"context_management":null},"parent_tool_use_id":null,"session_id":"04849b1d-a68c-421a-9431-0379c34c836f","uuid":"60f887db-b401-4bac-8973-6a7566fceaf8"}
