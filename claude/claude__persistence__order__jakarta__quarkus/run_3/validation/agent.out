{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01959fQPKWyAv5QkvLa45DpC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01LFGCYR1trKLaHykN2h9iA5","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__order__jakarta__quarkus/run_3/output/smoke.py","content":"\"\"\"\nSmoke tests for the Quarkus Order Management application.\nTests all REST endpoints exposed by the migrated application.\n\"\"\"\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\n\nBASE_URL = os.environ.get(\"APP_URL\", \"http://localhost:8080\")\n\n\ndef make_request(method, path, data=None, expected_status=None):\n    \"\"\"Helper to make HTTP requests.\"\"\"\n    url = f\"{BASE_URL}{path}\"\n    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n    body = json.dumps(data).encode(\"utf-8\") if data else None\n    req = urllib.request.Request(url, data=body, headers=headers, method=method)\n    try:\n        resp = urllib.request.urlopen(req)\n        status = resp.getcode()\n        content = resp.read().decode(\"utf-8\")\n        if expected_status and status != expected_status:\n            print(f\"  FAIL: Expected status {expected_status}, got {status}\")\n            return None, status\n        try:\n            return json.loads(content) if content else None, status\n        except json.JSONDecodeError:\n            return content, status\n    except urllib.error.HTTPError as e:\n        status = e.code\n        content = e.read().decode(\"utf-8\") if e.fp else \"\"\n        if expected_status and status == expected_status:\n            try:\n                return json.loads(content) if content else None, status\n            except json.JSONDecodeError:\n                return content, status\n        print(f\"  HTTP Error {status}: {content[:200]}\")\n        return None, status\n\n\ndef wait_for_app(timeout=120):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    print(f\"Waiting for application at {BASE_URL}...\")\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            req = urllib.request.Request(f\"{BASE_URL}/q/health/ready\")\n            resp = urllib.request.urlopen(req, timeout=5)\n            if resp.getcode() == 200:\n                print(\"Application is ready!\")\n                return True\n        except Exception:\n            pass\n        time.sleep(2)\n    print(\"Timeout waiting for application!\")\n    return False\n\n\ndef test_health_check():\n    \"\"\"Test that health endpoint is available.\"\"\"\n    print(\"Test: Health check endpoint\")\n    data, status = make_request(\"GET\", \"/q/health\")\n    assert status == 200, f\"Health check failed with status {status}\"\n    print(\"  PASS: Health check returns 200\")\n\n\ndef test_get_orders():\n    \"\"\"Test getting all orders (seeded data).\"\"\"\n    print(\"Test: GET /api/orders\")\n    data, status = make_request(\"GET\", \"/api/orders\", expected_status=200)\n    assert status == 200, f\"GET /api/orders failed with status {status}\"\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 2, f\"Expected at least 2 orders (seeded), got {len(data)}\"\n    order_ids = [o.get(\"orderId\") for o in data]\n    assert 1111 in order_ids, f\"Expected order 1111 in {order_ids}\"\n    assert 4312 in order_ids, f\"Expected order 4312 in {order_ids}\"\n    print(f\"  PASS: Got {len(data)} orders, including seeded orders 1111 and 4312\")\n\n\ndef test_get_parts():\n    \"\"\"Test getting all parts (seeded data).\"\"\"\n    print(\"Test: GET /api/parts\")\n    data, status = make_request(\"GET\", \"/api/parts\", expected_status=200)\n    assert status == 200, f\"GET /api/parts failed with status {status}\"\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 5, f\"Expected at least 5 parts (seeded), got {len(data)}\"\n    print(f\"  PASS: Got {len(data)} parts\")\n\n\ndef test_get_line_items():\n    \"\"\"Test getting line items for order 1111 (seeded data).\"\"\"\n    print(\"Test: GET /api/orders/1111/lineItems\")\n    data, status = make_request(\"GET\", \"/api/orders/1111/lineItems\", expected_status=200)\n    assert status == 200, f\"GET /api/orders/1111/lineItems failed with status {status}\"\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 3, f\"Expected at least 3 line items for order 1111, got {len(data)}\"\n    print(f\"  PASS: Got {len(data)} line items for order 1111\")\n\n\ndef test_get_order_price():\n    \"\"\"Test getting order price for order 1111.\"\"\"\n    print(\"Test: GET /api/orders/1111/price\")\n    data, status = make_request(\"GET\", \"/api/orders/1111/price\", expected_status=200)\n    assert status == 200, f\"GET /api/orders/1111/price failed with status {status}\"\n    assert \"price\" in data, f\"Expected 'price' key in response\"\n    assert data[\"price\"] > 0, f\"Expected positive price, got {data['price']}\"\n    print(f\"  PASS: Order 1111 price = {data['price']}\")\n\n\ndef test_vendor_search():\n    \"\"\"Test searching for vendors.\"\"\"\n    print(\"Test: GET /api/vendors/search?name=Widget\")\n    data, status = make_request(\"GET\", \"/api/vendors/search?name=Widget\", expected_status=200)\n    assert status == 200, f\"Vendor search failed with status {status}\"\n    assert isinstance(data, list), f\"Expected list, got {type(data)}\"\n    assert len(data) >= 1, f\"Expected at least 1 vendor matching 'Widget', got {len(data)}\"\n    assert \"WidgetCorp\" in data, f\"Expected 'WidgetCorp' in results: {data}\"\n    print(f\"  PASS: Found {len(data)} vendor(s) matching 'Widget'\")\n\n\ndef test_avg_vendor_part_price():\n    \"\"\"Test average vendor part price.\"\"\"\n    print(\"Test: GET /api/vendorparts/avgprice\")\n    data, status = make_request(\"GET\", \"/api/vendorparts/avgprice\", expected_status=200)\n    assert status == 200, f\"Avg price failed with status {status}\"\n    assert \"price\" in data, f\"Expected 'price' key in response\"\n    assert data[\"price\"] > 0, f\"Expected positive average price, got {data['price']}\"\n    print(f\"  PASS: Average vendor part price = {data['price']}\")\n\n\ndef test_total_price_per_vendor():\n    \"\"\"Test total price per vendor.\"\"\"\n    print(\"Test: GET /api/vendors/100/totalprice\")\n    data, status = make_request(\"GET\", \"/api/vendors/100/totalprice\", expected_status=200)\n    assert status == 200, f\"Total price failed with status {status}\"\n    assert \"price\" in data, f\"Expected 'price' key in response\"\n    assert data[\"price\"] > 0, f\"Expected positive total price, got {data['price']}\"\n    print(f\"  PASS: Total price for vendor 100 = {data['price']}\")\n\n\ndef test_line_item_count():\n    \"\"\"Test counting all line items.\"\"\"\n    print(\"Test: GET /api/lineitems/count\")\n    data, status = make_request(\"GET\", \"/api/lineitems/count\", expected_status=200)\n    assert status == 200, f\"Line item count failed with status {status}\"\n    assert \"count\" in data, f\"Expected 'count' key in response\"\n    assert data[\"count\"] >= 6, f\"Expected at least 6 line items, got {data['count']}\"\n    print(f\"  PASS: Total line items = {data['count']}\")\n\n\ndef test_create_and_delete_order():\n    \"\"\"Test creating a new order and then deleting it.\"\"\"\n    print(\"Test: POST /api/orders (create new order 9999)\")\n    order_data = {\n        \"orderId\": 9999,\n        \"status\": \"N\",\n        \"discount\": 5,\n        \"shipmentInfo\": \"Test shipping info\"\n    }\n    data, status = make_request(\"POST\", \"/api/orders\", data=order_data, expected_status=201)\n    assert status == 201, f\"Create order failed with status {status}\"\n    print(\"  PASS: Order 9999 created\")\n\n    # Verify order exists\n    print(\"Test: Verify order 9999 exists in GET /api/orders\")\n    data, status = make_request(\"GET\", \"/api/orders\", expected_status=200)\n    order_ids = [o.get(\"orderId\") for o in data]\n    assert 9999 in order_ids, f\"Order 9999 not found in orders list\"\n    print(\"  PASS: Order 9999 found in orders list\")\n\n    # Delete the order\n    print(\"Test: DELETE /api/orders/9999\")\n    data, status = make_request(\"DELETE\", \"/api/orders/9999\", expected_status=204)\n    assert status == 204, f\"Delete order failed with status {status}\"\n    print(\"  PASS: Order 9999 deleted\")\n\n    # Verify order is deleted\n    print(\"Test: Verify order 9999 is deleted\")\n    data, status = make_request(\"GET\", \"/api/orders\", expected_status=200)\n    order_ids = [o.get(\"orderId\") for o in data]\n    assert 9999 not in order_ids, f\"Order 9999 still found after deletion\"\n    print(\"  PASS: Order 9999 confirmed deleted\")\n\n\ndef main():\n    if not wait_for_app():\n        sys.exit(1)\n\n    tests = [\n        test_health_check,\n        test_get_orders,\n        test_get_parts,\n        test_get_line_items,\n        test_get_order_price,\n        test_vendor_search,\n        test_avg_vendor_part_price,\n        test_total_price_per_vendor,\n        test_line_item_count,\n        test_create_and_delete_order,\n    ]\n\n    passed = 0\n    failed = 0\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except Exception as e:\n            print(f\"  FAIL: {e}\")\n            failed += 1\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n    print(f\"{'='*50}\")\n\n    if failed > 0:\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":526,"cache_read_input_tokens":97705,"cache_creation":{"ephemeral_5m_input_tokens":526,"ephemeral_1h_input_tokens":0},"output_tokens":2848},"context_management":null},"parent_tool_use_id":null,"session_id":"9c218712-4305-4391-b809-2a32cfe389f4","uuid":"1f493cbe-02a2-4780-9937-17d75f1365b2"}
