est.orderId, orderRequest.status,\n    86→                            orderRequest.discount, orderRequest.shipmentInfo});\n    87→            return Response.status(Response.Status.CREATED).build();\n    88→        } catch (Exception e) {\n    89→            logger.warning(\"Problem creating order in submitOrder.\");\n    90→            throw new WebApplicationException(\"Failed to create order\", Response.Status.INTERNAL_SERVER_ERROR);\n    91→        }\n    92→    }\n    93→\n    94→    @POST\n    95→    @Path(\"/orders/{orderId}/lineItems\")\n    96→    public Response addLineItem(@PathParam(\"orderId\") Integer orderId, LineItemRequest lineItemRequest) {\n    97→        try {\n    98→            request.addLineItem(orderId,\n    99→                    lineItemRequest.partNumber,\n   100→                    lineItemRequest.partRevision,\n   101→                    lineItemRequest.quantity);\n   102→            logger.log(Level.INFO, \"Adding line item to order # {0}\", orderId);\n   103→            return Response.status(Response.Status.CREATED).build();\n   104→        } catch (Exception e) {\n   105→            logger.log(Level.WARNING, \"Problem adding line items to order ID {0}\", orderId);\n   106→            throw new WebApplicationException(\"Failed to add line item\", Response.Status.INTERNAL_SERVER_ERROR);\n   107→        }\n   108→    }\n   109→\n   110→    @GET\n   111→    @Path(\"/parts\")\n   112→    public List<Part> getParts() {\n   113→        return request.getAllParts();\n   114→    }\n   115→\n   116→    @GET\n   117→    @Path(\"/vendors/search\")\n   118→    public List<String> findVendor(@QueryParam(\"name\") String name) {\n   119→        try {\n   120→            List<String> results = request.locateVendorsByPartialName(name);\n   121→            logger.log(Level.INFO, \"Found {0} vendor(s) using the search string {1}.\",\n   122→                    new Object[]{results.size(), name});\n   123→            return results;\n   124→        } catch (Exception e) {\n   125→            logger.warning(\"Problem calling RequestBean.locateVendorsByPartialName from findVendor\");\n   126→            throw new WebApplicationException(\"Failed to search vendors\", Response.Status.INTERNAL_SERVER_ERROR);\n   127→        }\n   128→    }\n   129→\n   130→    @GET\n   131→    @Path(\"/orders/{orderId}/price\")\n   132→    public Response getOrderPrice(@PathParam(\"orderId\") Integer orderId) {\n   133→        try {\n   134→            double price = request.getOrderPrice(orderId);\n   135→            return Response.ok(new PriceResponse(price)).build();\n   136→        } catch (Exception e) {\n   137→            throw new WebApplicationException(\"Failed to get order price\", Response.Status.INTERNAL_SERVER_ERROR);\n   138→        }\n   139→    }\n   140→\n   141→    @GET\n   142→    @Path(\"/vendorparts/avgprice\")\n   143→    public Response getAvgPrice() {\n   144→        try {\n   145→            Double avg = request.getAvgPrice();\n   146→            return Response.ok(new PriceResponse(avg != null ? avg : 0.0)).build();\n   147→        } catch (Exception e) {\n   148→            throw new WebApplicationException(\"Failed to get average price\", Response.Status.INTERNAL_SERVER_ERROR);\n   149→        }\n   150→    }\n   151→\n   152→    @GET\n   153→    @Path(\"/vendors/{vendorId}/totalprice\")\n   154→    public Response getTotalPricePerVendor(@PathParam(\"vendorId\") int vendorId) {\n   155→        try {\n   156→            Double total = request.getTotalPricePerVendor(vendorId);\n   157→            return Response.ok(new PriceResponse(total != null ? total : 0.0)).build();\n   158→        } catch (Exception e) {\n   159→            throw new WebApplicationException(\"Failed to get total price\", Response.Status.INTERNAL_SERVER_ERROR);\n   160→        }\n   161→    }\n   162→\n   163→    @GET\n   164→    @Path(\"/lineitems/count\")\n   165→    public Response countAllItems() {\n   166→        try {\n   167→            int count = request.countAllItems();\n   168→            return Response.ok(new CountResponse(count)).build();\n   169→        } catch (Exception e) {\n   170→            throw new WebApplicationException(\"Failed to count items\", Response.Status.INTERNAL_SERVER_ERROR);\n   171→        }\n   172→    }\n   173→\n   174→    @GET\n   175→    @Path(\"/orders/{orderId}/vendors\")\n   176→    public Response reportVendorsByOrder(@PathParam(\"orderId\") Integer orderId) {\n   177→        try {\n   178→            String report = request.reportVendorsByOrder(orderId);\n   179→            return Response.ok(new ReportResponse(report)).build();\n   180→        } catch (Exception e) {\n   181→            throw new WebApplicationException(\"Failed to get vendors report\", Response.Status.INTERNAL_SERVER_ERROR);\n   182→        }\n   183→    }\n   184→\n   185→    // DTO classes for request/response\n   186→\n   187→    public static class OrderRequest {\n   188→        public Integer orderId;\n   189→        public char status;\n   190→        public int discount;\n   191→        public String shipmentInfo;\n   192→    }\n   193→\n   194→    public static class LineItemRequest {\n   195→        public String partNumber;\n   196→        public int partRevision;\n   197→        public int quantity;\n   198→    }\n   199→\n   200→    public static class PriceResponse {\n   201→        public double price;\n   202→        public PriceResponse() {}\n   203→        public PriceResponse(double price) { this.price = price; }\n   204→    }\n   205→\n   206→    public static class CountResponse {\n   207→        public int count;\n   208→        public CountResponse() {}\n   209→        public CountResponse(int count) { this.count = count; }\n   210→    }\n   211→\n   212→    public static class ReportResponse {\n   213→        public String report;\n   214→        public ReportResponse() {}\n   215→        public ReportResponse(String report) { this.report = report; }\n   216→    }\n   217→}\n   218→"}]},"parent_tool_use_id":null,"session_id":"9c218712-4305-4391-b809-2a32cfe389f4","uuid":"e282342f-b37f-4db3-8637-b4ac90c75cc7"}
