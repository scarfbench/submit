;\n    86→            partKey.setPartNumber(partNumber);\n    87→            partKey.setRevision(revision);\n    88→\n    89→            Part part = em.find(Part.class, partKey);\n    90→            logger.log(Level.INFO, \"Part found: {0}\", part.getPartNumber());\n    91→            bom.getParts().add(part);\n    92→            part.setBomPart(bom);\n    93→        } catch (Exception e) {\n    94→            logger.log(Level.WARNING, \"Error adding part to BOM\", e);\n    95→        }\n    96→    }\n    97→\n    98→    public void createVendor(int vendorId,\n    99→            String name,\n   100→            String address,\n   101→            String contact,\n   102→            String phone) {\n   103→        try {\n   104→            Vendor vendor = new Vendor(vendorId, name, address, contact, phone);\n   105→            em.persist(vendor);\n   106→        } catch (Exception e) {\n   107→            throw new RuntimeException(e.getMessage(), e);\n   108→        }\n   109→    }\n   110→\n   111→    public void createVendorPart(String partNumber,\n   112→            int revision,\n   113→            String description,\n   114→            double price,\n   115→            int vendorId) {\n   116→        try {\n   117→            PartKey pkey = new PartKey();\n   118→            pkey.setPartNumber(partNumber);\n   119→            pkey.setRevision(revision);\n   120→\n   121→            Part part = em.find(Part.class, pkey);\n   122→\n   123→            VendorPart vendorPart = new VendorPart(description, price, part);\n   124→            em.persist(vendorPart);\n   125→\n   126→            Vendor vendor = em.find(Vendor.class, vendorId);\n   127→            vendor.addVendorPart(vendorPart);\n   128→            vendorPart.setVendor(vendor);\n   129→        } catch (Exception e) {\n   130→            throw new RuntimeException(e.getMessage(), e);\n   131→        }\n   132→    }\n   133→\n   134→    public void createOrder(Integer orderId, char status, int discount, S