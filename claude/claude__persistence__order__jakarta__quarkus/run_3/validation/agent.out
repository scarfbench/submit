ivate String phone;\n    49→    private Collection<VendorPart> vendorParts;\n    50→    \n    51→    public Vendor() {}\n    52→    \n    53→    public Vendor(int vendorId, \n    54→            String name, \n    55→            String address, \n    56→            String contact, \n    57→            String phone) {\n    58→        this.vendorId = vendorId;\n    59→        this.name = name;\n    60→        this.address = address;\n    61→        this.contact = contact;\n    62→        this.phone = phone;\n    63→    }\n    64→\n    65→    @Id\n    66→    public int getVendorId() {\n    67→        return vendorId;\n    68→    }\n    69→\n    70→    public void setVendorId(int vendorId) {\n    71→        this.vendorId = vendorId;\n    72→    }\n    73→\n    74→    @Column(name=\"VENDORNAME\")\n    75→    public String getName() {\n    76→        return name;\n    77→    }\n    78→\n    79→    public void setName(String name) {\n    80→        this.name = name;\n    81→    }\n    82→\n    83→    public String getAddress() {\n    84→        return address;\n    85→    }\n    86→\n    87→    public void setAddress(String address) {\n    88→        this.address = address;\n    89→    }\n    90→\n    91→    public String getContact() {\n    92→        return contact;\n    93→    }\n    94→\n    95→    public void setContact(String contact) {\n    96→        this.contact = contact;\n    97→    }\n    98→\n    99→    public String getPhone() {\n   100→        return phone;\n   101→    }\n   102→\n   103→    public void setPhone(String phone) {\n   104→        this.phone = phone;\n   105→    }\n   106→\n   107→    @OneToMany(cascade=CascadeType.ALL, mappedBy=\"vendor\")\n   108→    public Collection<VendorPart> getVendorParts() {\n   109→        return vendorParts;\n   110→    }\n   111→\n   112→    public void setVendorParts(Collection<VendorPart> vendorParts) {\n   113→        this.vendorParts = vendorParts;\n   114→    }\n   115→    \n   116→    public void addVendorPart(V