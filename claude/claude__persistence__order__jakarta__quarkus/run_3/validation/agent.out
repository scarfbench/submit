    request.createPart(\"ABCD-XYZW-FF\", 5, \"XYZ PART\",\n    43→                new java.util.Date(), \"PARTQWERTYUIOPASXDCFVGBHNJMKL\", null);\n    44→        request.createPart(\"SDFG-ERTY-BN\", 7, \"BOM PART\",\n    45→                new java.util.Date(), \"PARTQWERTYUIOPASXDCFVGBHNJMKL\", null);\n    46→\n    47→        request.addPartToBillOfMaterial(\"SDFG-ERTY-BN\", 7,\n    48→                \"1234-5678-01\", 1);\n    49→        request.addPartToBillOfMaterial(\"SDFG-ERTY-BN\", 7,\n    50→                \"9876-4321-02\", 2);\n    51→        request.addPartToBillOfMaterial(\"SDFG-ERTY-BN\", 7,\n    52→                \"5456-6789-03\", 3);\n    53→        request.addPartToBillOfMaterial(\"SDFG-ERTY-BN\", 7,\n    54→                \"ABCD-XYZW-FF\", 5);\n    55→\n    56→        request.createVendor(100, \"WidgetCorp\",\n    57→                \"111 Main St., Anytown, KY 99999\", \"Mr. Jones\",\n    58→                \"888-777-9999\");\n    59→        request.createVendor(200, \"Gadget, Inc.\",\n    60→                \"123 State St., Sometown, MI 88888\", \"Mrs. Smith\",\n    61→                \"866-345-6789\");\n    62→\n    63→        request.createVendorPart(\"1234-5678-01\", 1,\n    64→                \"PART1\", 100.00, 100);\n    65→        request.createVendorPart(\"9876-4321-02\", 2,\n    66→                \"PART2\", 10.44, 200);\n    67→        request.createVendorPart(\"5456-6789-03\", 3,\n    68→                \"PART3\", 76.23, 200);\n    69→        request.createVendorPart(\"ABCD-XYZW-FF\", 5,\n    70→                \"PART4\", 55.19, 100);\n    71→        request.createVendorPart(\"SDFG-ERTY-BN\", 7,\n    72→                \"PART5\", 345.87, 100);\n    73→\n    74→        Integer orderId = 1111;\n    75→        request.createOrder(orderId, 'N', 10,\n    76→                \"333 New Court, New City, CA 90000\");\n    77→        request.addLineItem(orderId, \"1234-5678-01\", 1, 3);\n    78→        request.addLineItem(orderId, \"9876-4321-02\"