ing database\");\n    81→        }\n    82→    }\n    83→\n    84→    private void populateQuotes() {\n    85→        Log.log(\"TradeBuildDB: Creating \" + maxQuotes + \" Quotes...\");\n    86→\n    87→        for (int i = 0; i < maxQuotes; i++) {\n    88→            String symbol = \"s:\" + i;\n    89→            String companyName = \"S\" + i + \" Incorporated\";\n    90→            BigDecimal price = new BigDecimal(TradeConfig.rndPrice());\n    91→\n    92→            QuoteDataBean quote = new QuoteDataBean();\n    93→            quote.setSymbol(symbol);\n    94→            quote.setCompanyName(companyName);\n    95→            quote.setPrice(price);\n    96→            quote.setOpen(price);\n    97→            quote.setLow(price);\n    98→            quote.setHigh(price);\n    99→            quote.setChange(0.0);\n   100→            quote.setVolume(0.0);\n   101→\n   102→            em.persist(quote);\n   103→\n   104→            if (i % 10 == 0) {\n   105→                Log.log(\"Created quote: \" + symbol);\n   106→            }\n   107→        }\n   108→        em.flush();\n   109→    }\n   110→\n   111→    private void populateUsers() {\n   112→        Log.log(\"TradeBuildDB: Registering \" + maxUsers + \" Users...\");\n   113→\n   114→        for (int i = 0; i < maxUsers; i++) {\n   115→            String userID = \"uid:\" + i;\n   116→            String fullname = TradeConfig.rndFullName();\n   117→            String email = TradeConfig.rndEmail(userID);\n   118→            String address = TradeConfig.rndAddress();\n   119→            String creditcard = TradeConfig.rndCreditCard();\n   120→            BigDecimal initialBalance = new BigDecimal((double) (TradeConfig.rndInt(100000)) + 200000);\n   121→\n   122→            if (i == 0) {\n   123→                initialBalance = new BigDecimal(1000000);\n   124→            }\n   125→\n   126→            AccountProfileDataBean profile = new AccountProfileDataBean();\n   127→            profile.setUserID(userI