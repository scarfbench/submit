{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01X1vYyCweVwbvQqdgVByg4j","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Smoke tests for DayTrader Spring Boot application.\n     4→Tests core REST API endpoints to verify the migration works correctly.\n     5→\"\"\"\n     6→\n     7→import json\n     8→import os\n     9→import sys\n    10→import time\n    11→import urllib.request\n    12→import urllib.error\n    13→import urllib.parse\n    14→\n    15→BASE_URL = os.environ.get(\"APP_URL\", \"http://localhost:8080\")\n    16→REST_BASE = f\"{BASE_URL}/rest\"\n    17→\n    18→passed = 0\n    19→failed = 0\n    20→errors = []\n    21→\n    22→\n    23→def test(name, fn):\n    24→    global passed, failed, errors\n    25→    try:\n    26→        fn()\n    27→        passed += 1\n    28→        print(f\"  PASS: {name}\")\n    29→    except Exception as e:\n    30→        failed += 1\n    31→        errors.append((name, str(e)))\n    32→        print(f\"  FAIL: {name} - {e}\")\n    33→\n    34→\n    35→def get_json(url):\n    36→    \"\"\"GET request expecting JSON response.\"\"\"\n    37→    req = urllib.request.Request(url)\n    38→    req.add_header(\"Accept\", \"application/json\")\n    39→    with urllib.request.urlopen(req, timeout=15) as resp:\n    40→        body = resp.read().decode(\"utf-8\")\n    41→        return json.loads(body), resp.status\n    42→\n    43→\n    44→def post_form(url, data):\n    45→    \"\"\"POST form-encoded data expecting JSON response.\"\"\"\n    46→    encoded = urllib.parse.urlencode(data).encode(\"utf-8\")\n    47→    req = urllib.request.Request(url, data=encoded, method=\"POST\")\n    48→    req.add_header(\"Content-Type\", \"application/x-www-form-urlencoded\")\n    49→    req.add_header(\"Accept\", \"application/json\")\n    50→    with urllib.request.urlopen(req, timeout=15) as resp:\n    51→        body = resp.read().decode(\"utf-8\")\n    52→        try:\n    53→            return json.loads(body), resp.status\n    54→        except json.JSONDecodeError:\n    55→            return body, resp.status\n    56→\n    57→\n    58→def get_text(url):\n    59→    \"\"\"GET request expecting text/html response.\"\"\"\n    60→    req = urllib.request.Request(url)\n    61→    with urllib.request.urlopen(req, timeout=15) as resp:\n    62→        return resp.read().decode(\"utf-8\"), resp.status\n    63→\n    64→\n    65→def wait_for_ready(max_wait=120):\n    66→    \"\"\"Wait for the application to be ready.\"\"\"\n    67→    print(f\"Waiting for application at {BASE_URL} to be ready...\")\n    68→    # Actuator endpoints go through DispatcherServlet at /rest path\n    69→    health_url = f\"{REST_BASE}/actuator/health\"\n    70→    start = time.time()\n    71→    while time.time() - start < max_wait:\n    72→        try:\n    73→            req = urllib.request.Request(health_url)\n    74→            with urllib.request.urlopen(req, timeout=5) as resp:\n    75→                body = json.loads(resp.read().decode(\"utf-8\"))\n    76→                if body.get(\"status\") == \"UP\":\n    77→                    print(f\"Application is ready! (took {time.time() - start:.1f}s)\")\n    78→                    return True\n    79→        except Exception:\n    80→            pass\n    81→        time.sleep(2)\n    82→    print(f\"Application did not become ready within {max_wait}s\")\n    83→    return False\n    84→\n    85→\n    86→# ============================================================\n    87→# Test functions\n    88→# ============================================================\n    89→\n    90→def test_health_endpoint():\n    91→    \"\"\"Test the actuator health endpoint.\"\"\"\n    92→    body, status = get_json(f\"{BASE_URL}/actuator/health\")\n    93→    assert status == 200, f\"Expected 200, got {status}\"\n    94→    assert body.get(\"status\") == \"UP\", f\"Expected UP, got {body.get('status')}\"\n    95→\n    96→\n    97→def test_market_summary():\n    98→    \"\"\"Test the market summary endpoint.\"\"\"\n    99→    body, status = get_json(f\"{REST_BASE}/trade/market\")\n   100→    assert status == 200, f\"Expected 200, got {status}\"\n   101→    assert body is not None, \"Market summary should not be null\"\n   102→\n   103→\n   104→def test_get_quote():\n   105→    \"\"\"Test getting a stock quote.\"\"\"\n   106→    body, status = get_json(f\"{REST_BASE}/quotes/s:0\")\n   107→    assert status == 200, f\"Expected 200, got {status}\"\n   108→    # Response is a list of quotes\n   109→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   110→    assert len(body) > 0, \"Expected at least one quote\"\n   111→    quote = body[0]\n   112→    assert quote.get(\"symbol\") == \"s:0\", f\"Expected symbol s:0, got {quote.get('symbol')}\"\n   113→\n   114→\n   115→def test_get_multiple_quotes():\n   116→    \"\"\"Test getting multiple stock quotes.\"\"\"\n   117→    body, status = get_json(f\"{REST_BASE}/quotes/s:0,s:1,s:2\")\n   118→    assert status == 200, f\"Expected 200, got {status}\"\n   119→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   120→    assert len(body) >= 3, f\"Expected at least 3 quotes, got {len(body)}\"\n   121→\n   122→\n   123→def test_login():\n   124→    \"\"\"Test user login.\"\"\"\n   125→    body, status = post_form(f\"{REST_BASE}/trade/login\", {\n   126→        \"uid\": \"uid:0\",\n   127→        \"passwd\": \"xxx\"\n   128→    })\n   129→    assert status == 200, f\"Expected 200, got {status}\"\n   130→    assert body is not None, \"Login response should not be null\"\n   131→\n   132→\n   133→def test_get_account():\n   134→    \"\"\"Test getting account data.\"\"\"\n   135→    body, status = get_json(f\"{REST_BASE}/trade/account?uid=uid:0\")\n   136→    assert status == 200, f\"Expected 200, got {status}\"\n   137→    assert body is not None, \"Account data should not be null\"\n   138→\n   139→\n   140→def test_get_holdings():\n   141→    \"\"\"Test getting user holdings.\"\"\"\n   142→    body, status = get_json(f\"{REST_BASE}/trade/holdings?uid=uid:0\")\n   143→    assert status == 200, f\"Expected 200, got {status}\"\n   144→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   145→\n   146→\n   147→def test_get_orders():\n   148→    \"\"\"Test getting user orders.\"\"\"\n   149→    body, status = get_json(f\"{REST_BASE}/trade/orders?uid=uid:0\")\n   150→    assert status == 200, f\"Expected 200, got {status}\"\n   151→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   152→\n   153→\n   154→def test_buy_stock():\n   155→    \"\"\"Test buying stock.\"\"\"\n   156→    body, status = post_form(f\"{REST_BASE}/trade/buy\", {\n   157→        \"uid\": \"uid:0\",\n   158→        \"symbol\": \"s:1\",\n   159→        \"quantity\": \"100.0\"\n   160→    })\n   161→    assert status == 200, f\"Expected 200, got {status}\"\n   162→\n   163→\n   164→def test_register_user():\n   165→    \"\"\"Test registering a new user.\"\"\"\n   166→    body, status = post_form(f\"{REST_BASE}/trade/register\", {\n   167→        \"uid\": \"testuser1\",\n   168→        \"passwd\": \"testpass\",\n   169→        \"fullname\": \"Test User\",\n   170→        \"address\": \"123 Test St\",\n   171→        \"email\": \"test@test.com\",\n   172→        \"creditcard\": \"1234-5678-9012-3456\",\n   173→        \"balance\": \"100000\"\n   174→    })\n   175→    assert status == 200, f\"Expected 200, got {status}\"\n   176→\n   177→\n   178→def test_web_welcome_page():\n   179→    \"\"\"Test the web welcome page.\"\"\"\n   180→    body, status = get_text(f\"{REST_BASE}/app\")\n   181→    assert status == 200, f\"Expected 200, got {status}\"\n   182→    assert \"DayTrader\" in body, \"Welcome page should contain 'DayTrader'\"\n   183→\n   184→\n   185→def test_messaging_ping_broker():\n   186→    \"\"\"Test messaging ping to broker.\"\"\"\n   187→    body, status = get_json(f\"{REST_BASE}/messaging/pingBroker?text=smoketest\")\n   188→    assert status == 200, f\"Expected 200, got {status}\"\n   189→\n   190→\n   191→def test_messaging_ping_streamer():\n   192→    \"\"\"Test messaging ping to streamer.\"\"\"\n   193→    body, status = get_json(f\"{REST_BASE}/messaging/pingStreamer?text=smoketest\")\n   194→    assert status == 200, f\"Expected 200, got {status}\"\n   195→\n   196→\n   197→def test_messaging_stats():\n   198→    \"\"\"Test getting MDB stats.\"\"\"\n   199→    body, status = get_json(f\"{REST_BASE}/messaging/stats\")\n   200→    assert status == 200, f\"Expected 200, got {status}\"\n   201→\n   202→\n   203→# ============================================================\n   204→# Main\n   205→# ============================================================\n   206→\n   207→if __name__ == \"__main__\":\n   208→    if not wait_for_ready():\n   209→        print(\"FATAL: Application not ready. Exiting.\")\n   210→        sys.exit(1)\n   211→\n   212→    # Give the app a moment after health check passes for DB population\n   213→    time.sleep(5)\n   214→\n   215→    print(\"\\n--- Running Smoke Tests ---\\n\")\n   216→\n   217→    test(\"Health endpoint\", test_health_endpoint)\n   218→    test(\"Market summary\", test_market_summary)\n   219→    test(\"Get single quote\", test_get_quote)\n   220→    test(\"Get multiple quotes\", test_get_multiple_quotes)\n   221→    test(\"User login\", test_login)\n   222→    test(\"Get account data\", test_get_account)\n   223→    test(\"Get holdings\", test_get_holdings)\n   224→    test(\"Get orders\", test_get_orders)\n   225→    test(\"Buy stock\", test_buy_stock)\n   226→    test(\"Register user\", test_register_user)\n   227→    test(\"Web welcome page\", test_web_welcome_page)\n   228→    test(\"Messaging ping broker\", test_messaging_ping_broker)\n   229→    test(\"Messaging ping streamer\", test_messaging_ping_streamer)\n   230→    test(\"Messaging stats\", test_messaging_stats)\n   231→\n   232→    print(f\"\\n--- Results: {passed} passed, {failed} failed ---\\n\")\n   233→\n   234→    if errors:\n   235→        print(\"Failures:\")\n   236→        for name, err in errors:\n   237→            print(f\"  - {name}: {err}\")\n   238→\n   239→    sys.exit(0 if failed == 0 else 1)\n   240→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f3099ad-61fc-4987-ab0b-e3abd721a458","uuid":"2a5e5a2f-22be-4da5-b115-a7afee0bafd6"}
