{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01RLCAc8uRGZBFtYr3nLMx5K","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.entities;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.util.Collection;\n    21→import java.util.Date;\n    22→\n    23→// MIGRATION: javax.* -> jakarta.*\n    24→import jakarta.persistence.Column;\n    25→import jakarta.persistence.Entity;\n    26→import jakarta.persistence.FetchType;\n    27→import jakarta.persistence.GeneratedValue;\n    28→import jakarta.persistence.GenerationType;\n    29→import jakarta.persistence.Id;\n    30→import jakarta.persistence.JoinColumn;\n    31→import jakarta.persistence.OneToMany;\n    32→import jakarta.persistence.OneToOne;\n    33→import jakarta.persistence.Table;\n    34→import jakarta.persistence.Temporal;\n    35→import jakarta.persistence.TemporalType;\n    36→import jakarta.persistence.Transient;\n    37→import jakarta.validation.constraints.NotNull;\n    38→import jakarta.validation.constraints.PastOrPresent;\n    39→import jakarta.validation.constraints.PositiveOrZero;\n    40→\n    41→import com.fasterxml.jackson.annotation.JsonIgnore;\n    42→\n    43→import com.ibm.websphere.samples.daytrader.util.Log;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    45→\n    46→@Entity(name = \"accountejb\")\n    47→@Table(name = \"accountejb\")\n    48→public class AccountDataBean implements Serializable {\n    49→\n    50→    private static final long serialVersionUID = 8437841265136840545L;\n    51→\n    52→    // MIGRATION: Simplified ID generation - Quarkus/Hibernate handles this better with IDENTITY\n    53→    @Id\n    54→    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    55→    @Column(name = \"ACCOUNTID\", nullable = false)\n    56→    private Integer accountID;\n    57→\n    58→    @NotNull\n    59→    @PositiveOrZero\n    60→    @Column(name = \"LOGINCOUNT\", nullable = false)\n    61→    private int loginCount;\n    62→\n    63→    @NotNull\n    64→    @PositiveOrZero\n    65→    @Column(name = \"LOGOUTCOUNT\", nullable = false)\n    66→    private int logoutCount;\n    67→\n    68→    @Column(name = \"LASTLOGIN\")\n    69→    @Temporal(TemporalType.TIMESTAMP)\n    70→    @PastOrPresent\n    71→    private Date lastLogin;\n    72→\n    73→    @Column(name = \"CREATIONDATE\")\n    74→    @Temporal(TemporalType.TIMESTAMP)\n    75→    @PastOrPresent\n    76→    private Date creationDate;\n    77→\n    78→    @Column(name = \"BALANCE\")\n    79→    private BigDecimal balance;\n    80→\n    81→    @Column(name = \"OPENBALANCE\")\n    82→    private BigDecimal openBalance;\n    83→\n    84→    @JsonIgnore\n    85→    @OneToMany(mappedBy = \"account\", fetch = FetchType.LAZY)\n    86→    private Collection<OrderDataBean> orders;\n    87→\n    88→    @JsonIgnore\n    89→    @OneToMany(mappedBy = \"account\", fetch = FetchType.LAZY)\n    90→    private Collection<HoldingDataBean> holdings;\n    91→\n    92→    @JsonIgnore\n    93→    @OneToOne(fetch = FetchType.LAZY)\n    94→    @JoinColumn(name = \"PROFILE_USERID\")\n    95→    private AccountProfileDataBean profile;\n    96→\n    97→    @Transient\n    98→    private String profileID;\n    99→\n   100→    public AccountDataBean() {\n   101→    }\n   102→\n   103→    public AccountDataBean(Integer accountID, int loginCount, int logoutCount, \n   104→            Date lastLogin, Date creationDate, BigDecimal balance, \n   105→            BigDecimal openBalance, String profileID) {\n   106→        setAccountID(accountID);\n   107→        setLoginCount(loginCount);\n   108→        setLogoutCount(logoutCount);\n   109→        setLastLogin(lastLogin);\n   110→        setCreationDate(creationDate);\n   111→        setBalance(balance);\n   112→        setOpenBalance(openBalance);\n   113→        setProfileID(profileID);\n   114→    }\n   115→\n   116→    public AccountDataBean(int loginCount, int logoutCount, Date lastLogin, \n   117→            Date creationDate, BigDecimal balance, BigDecimal openBalance, \n   118→            String profileID) {\n   119→        setLoginCount(loginCount);\n   120→        setLogoutCount(logoutCount);\n   121→        setLastLogin(lastLogin);\n   122→        setCreationDate(creationDate);\n   123→        setBalance(balance);\n   124→        setOpenBalance(openBalance);\n   125→        setProfileID(profileID);\n   126→    }\n   127→\n   128→    public void login(String password) {\n   129→        AccountProfileDataBean profile = getProfile();\n   130→        if (profile == null) {\n   131→            throw new RuntimeException(\"AccountDataBean:login -- Cannot find profile\");\n   132→        }\n   133→        if (!password.equals(profile.getPassword())) {\n   134→            throw new RuntimeException(\"AccountDataBean:login -- Password does not match\");\n   135→        }\n   136→        setLoginCount(getLoginCount() + 1);\n   137→        setLastLogin(new Date());\n   138→    }\n   139→\n   140→    public void logout() {\n   141→        setLogoutCount(getLogoutCount() + 1);\n   142→    }\n   143→\n   144→    @Override\n   145→    public String toString() {\n   146→        return \"AccountDataBean [accountID=\" + accountID + \", loginCount=\" + loginCount \n   147→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin \n   148→            + \", creationDate=\" + creationDate + \", balance=\" + balance \n   149→            + \", openBalance=\" + openBalance + \"]\";\n   150→    }\n   151→\n   152→    public String toHTML() {\n   153→        return \"<BR>AccountData [accountID=\" + accountID + \", loginCount=\" + loginCount\n   154→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin\n   155→            + \", creationDate=\" + creationDate + \", balance=\" + balance\n   156→            + \", openBalance=\" + openBalance + \"]\";\n   157→    }\n   158→\n   159→    // Getters and Setters\n   160→    public Integer getAccountID() {\n   161→        return accountID;\n   162→    }\n   163→\n   164→    public void setAccountID(Integer accountID) {\n   165→        this.accountID = accountID;\n   166→    }\n   167→\n   168→    public int getLoginCount() {\n   169→        return loginCount;\n   170→    }\n   171→\n   172→    public void setLoginCount(int loginCount) {\n   173→        this.loginCount = loginCount;\n   174→    }\n   175→\n   176→    public int getLogoutCount() {\n   177→        return logoutCount;\n   178→    }\n   179→\n   180→    public void setLogoutCount(int logoutCount) {\n   181→        this.logoutCount = logoutCount;\n   182→    }\n   183→\n   184→    public Date getLastLogin() {\n   185→        return lastLogin;\n   186→    }\n   187→\n   188→    public void setLastLogin(Date lastLogin) {\n   189→        this.lastLogin = lastLogin;\n   190→    }\n   191→\n   192→    public Date getCreationDate() {\n   193→        return creationDate;\n   194→    }\n   195→\n   196→    public void setCreationDate(Date creationDate) {\n   197→        this.creationDate = creationDate;\n   198→    }\n   199→\n   200→    public BigDecimal getBalance() {\n   201→        return balance;\n   202→    }\n   203→\n   204→    public void setBalance(BigDecimal balance) {\n   205→        this.balance = balance;\n   206→    }\n   207→\n   208→    public BigDecimal getOpenBalance() {\n   209→        return openBalance;\n   210→    }\n   211→\n   212→    public void setOpenBalance(BigDecimal openBalance) {\n   213→        this.openBalance = openBalance;\n   214→    }\n   215→\n   216→    public Collection<OrderDataBean> getOrders() {\n   217→        return orders;\n   218→    }\n   219→\n   220→    public void setOrders(Collection<OrderDataBean> orders) {\n   221→        this.orders = orders;\n   222→    }\n   223→\n   224→    public Collection<HoldingDataBean> getHoldings() {\n   225→        return holdings;\n   226→    }\n   227→\n   228→    public void setHoldings(Collection<HoldingDataBean> holdings) {\n   229→        this.holdings = holdings;\n   230→    }\n   231→\n   232→    public AccountProfileDataBean getProfile() {\n   233→        return profile;\n   234→    }\n   235→\n   236→    public void setProfile(AccountProfileDataBean profile) {\n   237→        this.profile = profile;\n   238→    }\n   239→\n   240→    public String getProfileID() {\n   241→        return profileID;\n   242→    }\n   243→\n   244→    public void setProfileID(String profileID) {\n   245→        this.profileID = profileID;\n   246→    }\n   247→\n   248→    @Override\n   249→    public int hashCode() {\n   250→        int hash = 0;\n   251→        hash += (this.accountID != null ? this.accountID.hashCode() : 0);\n   252→        return hash;\n   253→    }\n   254→\n   255→    @Override\n   256→    public boolean equals(Object object) {\n   257→        if (!(object instanceof AccountDataBean)) {\n   258→            return false;\n   259→        }\n   260→        AccountDataBean other = (AccountDataBean) object;\n   261→        if (this.accountID != null && !this.accountID.equals(other.accountID)) {\n   262→            return false;\n   263→        }\n   264→        return true;\n   265→    }\n   266→}\n   267→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01S3bMaPQhx8E18Du7cTWPBt","session_id":"8f3099ad-61fc-4987-ab0b-e3abd721a458","uuid":"b3422931-fb45-4322-a51b-e4a7eb6a1b66"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01GDLbVUJTYcB3kt85CvN39J","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.beans;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.util.ArrayList;\n    21→import java.util.Collection;\n    22→import java.util.Date;\n    23→import java.util.Iterator;\n    24→\n    25→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    26→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    27→import com.ibm.websphere.samples.daytrader.util.Log;\n    28→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    29→\n    30→/**\n    31→ * MIGRATION NOTE: Removed javax.json dependency as it's not commonly used in Quarkus.\n    32→ * Use Jackson (which Quarkus uses by default) for JSON serialization instead.\n    33→ */\n    34→public class MarketSummaryDataBean implements Serializable {\n    35→\n    36→    private static final long serialVersionUID = 650652242288745600L;\n    37→    \n    38→    private BigDecimal TSIA;           /* Trade Stock Index Average */\n    39→    private BigDecimal openTSIA;       /* Trade Stock Index Average at the open */\n    40→    private double volume;             /* volume of shares traded */\n    41→    private Collection<QuoteDataBean> topGainers;  /* Collection of top gaining stocks */\n    42→    private Collection<QuoteDataBean> topLosers;   /* Collection of top losing stocks */\n    43→    private Date summaryDate;          /* Date this summary was taken */\n    44→    private BigDecimal gainPercent = null;\n    45→\n    46→    public MarketSummaryDataBean() {\n    47→    }\n    48→\n    49→    public MarketSummaryDataBean(BigDecimal TSIA, BigDecimal openTSIA, double volume, \n    50→            Collection<QuoteDataBean> topGainers, Collection<QuoteDataBean> topLosers) {\n    51→        setTSIA(TSIA);\n    52→        setOpenTSIA(openTSIA);\n    53→        setVolume(volume);\n    54→        setTopGainers(topGainers);\n    55→        setTopLosers(topLosers);\n    56→        setSummaryDate(new java.sql.Date(System.currentTimeMillis()));\n    57→        gainPercent = FinancialUtils.computeGainPercent(getTSIA(), getOpenTSIA());\n    58→    }\n    59→\n    60→    public static MarketSummaryDataBean getRandomInstance() {\n    61→        Collection<QuoteDataBean> gain = new ArrayList<>();\n    62→        Collection<QuoteDataBean> lose = new ArrayList<>();\n    63→\n    64→        for (int ii = 0; ii < 5; ii++) {\n    65→            QuoteDataBean quote1 = QuoteDataBean.getRandomInstance();\n    66→            QuoteDataBean quote2 = QuoteDataBean.getRandomInstance();\n    67→            gain.add(quote1);\n    68→            lose.add(quote2);\n    69→        }\n    70→\n    71→        return new MarketSummaryDataBean(\n    72→            TradeConfig.rndBigDecimal(1000000.0f), \n    73→            TradeConfig.rndBigDecimal(1000000.0f), \n    74→            TradeConfig.rndQuantity(), \n    75→            gain, \n    76→            lose\n    77→        );\n    78→    }\n    79→\n    80→    @Override\n    81→    public String toString() {\n    82→        String ret = \"\\n\\tMarket Summary at: \" + getSummaryDate() \n    83→            + \"\\n\\t\\t        TSIA:\" + getTSIA() \n    84→            + \"\\n\\t\\t    openTSIA:\" + getOpenTSIA()\n    85→            + \"\\n\\t\\t        gain:\" + getGainPercent() \n    86→            + \"\\n\\t\\t      volume:\" + getVolume();\n    87→\n    88→        if ((getTopGainers() == null) || (getTopLosers() == null)) {\n    89→            return ret;\n    90→        }\n    91→        \n    92→        ret += \"\\n\\t\\t   Current Top Gainers:\";\n    93→        for (QuoteDataBean quoteData : getTopGainers()) {\n    94→            ret += (\"\\n\\t\\t\\t\" + quoteData.toString());\n    95→        }\n    96→        \n    97→        ret += \"\\n\\t\\t   Current Top Losers:\";\n    98→        for (QuoteDataBean quoteData : getTopLosers()) {\n    99→            ret += (\"\\n\\t\\t\\t\" + quoteData.toString());\n   100→        }\n   101→        return ret;\n   102→    }\n   103→\n   104→    public String toHTML() {\n   105→        String ret = \"<BR>Market Summary at: \" + getSummaryDate() \n   106→            + \"<LI>        TSIA:\" + getTSIA() + \"</LI>\" \n   107→            + \"<LI>    openTSIA:\" + getOpenTSIA() + \"</LI>\"\n   108→            + \"<LI>      volume:\" + getVolume() + \"</LI>\";\n   109→            \n   110→        if ((getTopGainers() == null) || (getTopLosers() == null)) {\n   111→            return ret;\n   112→        }\n   113→        \n   114→        ret += \"<BR> Current Top Gainers:\";\n   115→        for (QuoteDataBean quoteData : getTopGainers()) {\n   116→            ret += (\"<LI>\" + quoteData.toString() + \"</LI>\");\n   117→        }\n   118→        \n   119→        ret += \"<BR>   Current Top Losers:\";\n   120→        for (QuoteDataBean quoteData : getTopLosers()) {\n   121→            ret += (\"<LI>\" + quoteData.toString() + \"</LI>\");\n   122→        }\n   123→        return ret;\n   124→    }\n   125→\n   126→    public void print() {\n   127→        Log.log(this.toString());\n   128→    }\n   129→\n   130→    // Getters and Setters\n   131→    public BigDecimal getGainPercent() {\n   132→        if (gainPercent == null) {\n   133→            gainPercent = FinancialUtils.computeGainPercent(getTSIA(), getOpenTSIA());\n   134→        }\n   135→        return gainPercent;\n   136→    }\n   137→\n   138→    public BigDecimal getTSIA() {\n   139→        return TSIA;\n   140→    }\n   141→\n   142→    public void setTSIA(BigDecimal tSIA) {\n   143→        TSIA = tSIA;\n   144→    }\n   145→\n   146→    public BigDecimal getOpenTSIA() {\n   147→        return openTSIA;\n   148→    }\n   149→\n   150→    public void setOpenTSIA(BigDecimal openTSIA) {\n   151→        this.openTSIA = openTSIA;\n   152→    }\n   153→\n   154→    public double getVolume() {\n   155→        return volume;\n   156→    }\n   157→\n   158→    public void setVolume(double volume) {\n   159→        this.volume = volume;\n   160→    }\n   161→\n   162→    public Collection<QuoteDataBean> getTopGainers() {\n   163→        return topGainers;\n   164→    }\n   165→\n   166→    public void setTopGainers(Collection<QuoteDataBean> topGainers) {\n   167→        this.topGainers = topGainers;\n   168→    }\n   169→\n   170→    public Collection<QuoteDataBean> getTopLosers() {\n   171→        return topLosers;\n   172→    }\n   173→\n   174→    public void setTopLosers(Collection<QuoteDataBean> topLosers) {\n   175→        this.topLosers = topLosers;\n   176→    }\n   177→\n   178→    public Date getSummaryDate() {\n   179→        return summaryDate;\n   180→    }\n   181→\n   182→    public void setSummaryDate(Date summaryDate) {\n   183→        this.summaryDate = summaryDate;\n   184→    }\n   185→}\n   186→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01S3bMaPQhx8E18Du7cTWPBt","session_id":"8f3099ad-61fc-4987-ab0b-e3abd721a458","uuid":"fdfb75af-7905-4999-98cc-8b62ff4f9675"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01JGcjJgoZqXUfWxvvakFBgG","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.beans;\n    17→\n    18→import java.io.Serializable;\n    19→\n    20→public class RunStatsDataBean implements Serializable {\n    21→    private static final long serialVersionUID = 4017778674103242167L;\n    22→\n    23→    // Constructors\n    24→    public RunStatsDataBean() {\n    25→    }\n    26→\n    27→    // count of trade users in the database (users w/ userID like 'uid:%')\n    28→    private int tradeUserCount;\n    29→    // count of trade stocks in the database (stocks w/ symbol like 's:%')\n    30→    private int tradeStockCount;\n    31→\n    32→    // count of new registered users in this run (users w/ userID like 'ru:%')\n    33→    // -- random user\n    34→    private int newUserCount;\n    35→\n    36→    // sum of logins by trade users\n    37→    private int sumLoginCount;\n    38→    // sum of logouts by trade users\n    39→    private int sumLogoutCount;\n    40→\n    41→    // count of holdings of trade users\n    42→    private int holdingCount;\n    43→\n    44→    // count of orders of trade users\n    45→    private int orderCount;\n    46→    // count of buy orders of trade users\n    47→    private int buyOrderCount;\n    48→    // count of sell orders of trade users\n    49→    private int sellOrderCount;\n    50→    // count of cancelled orders of trade users\n    51→    private int cancelledOrderCount;\n    52→    // count of open orders of trade users\n    53→    private int openOrderCount;\n    54→    // count of orders deleted during this trade Reset\n    55→    private int deletedOrderCount;\n    56→\n    57→    @Override\n    58→    public String toString() {\n    59→        return \"\\n\\tRunStatsData for reset at \" + new java.util.Date() + \"\\n\\t\\t      tradeUserCount: \" + getTradeUserCount() + \"\\n\\t\\t        newUserCount: \"\n    60→                + getNewUserCount() + \"\\n\\t\\t       sumLoginCount: \" + getSumLoginCount() + \"\\n\\t\\t      sumLogoutCount: \" + getSumLogoutCount()\n    61→                + \"\\n\\t\\t        holdingCount: \" + getHoldingCount() + \"\\n\\t\\t          orderCount: \" + getOrderCount() + \"\\n\\t\\t       buyOrderCount: \"\n    62→                + getBuyOrderCount() + \"\\n\\t\\t      sellOrderCount: \" + getSellOrderCount() + \"\\n\\t\\t cancelledOrderCount: \" + getCancelledOrderCount()\n    63→                + \"\\n\\t\\t      openOrderCount: \" + getOpenOrderCount() + \"\\n\\t\\t   deletedOrderCount: \" + getDeletedOrderCount();\n    64→    }\n    65→\n    66→    /**\n    67→     * Gets the tradeUserCount\n    68→     *\n    69→     * @return Returns a int\n    70→     */\n    71→    public int getTradeUserCount() {\n    72→        return tradeUserCount;\n    73→    }\n    74→\n    75→    /**\n    76→     * Sets the tradeUserCount\n    77→     *\n    78→     * @param tradeUserCount\n    79→     *            The tradeUserCount to set\n    80→     */\n    81→    public void setTradeUserCount(int tradeUserCount) {\n    82→        this.tradeUserCount = tradeUserCount;\n    83→    }\n    84→\n    85→    /**\n    86→     * Gets the newUserCount\n    87→     *\n    88→     * @return Returns a int\n    89→     */\n    90→    public int getNewUserCount() {\n    91→        return newUserCount;\n    92→    }\n    93→\n    94→    /**\n    95→     * Sets the newUserCount\n    96→     *\n    97→     * @param newUserCount\n    98→     *            The newUserCount to set\n    99→     */\n   100→    public void setNewUserCount(int newUserCount) {\n   101→        this.newUserCount = newUserCount;\n   102→    }\n   103→\n   104→    /**\n   105→     * Gets the sumLoginCount\n   106→     *\n   107→     * @return Returns a int\n   108→     */\n   109→    public int getSumLoginCount() {\n   110→        return sumLoginCount;\n   111→    }\n   112→\n   113→    /**\n   114→     * Sets the sumLoginCount\n   115→     *\n   116→     * @param sumLoginCount\n   117→     *            The sumLoginCount to set\n   118→     */\n   119→    public void setSumLoginCount(int sumLoginCount) {\n   120→        this.sumLoginCount = sumLoginCount;\n   121→    }\n   122→\n   123→    /**\n   124→     * Gets the sumLogoutCount\n   125→     *\n   126→     * @return Returns a int\n   127→     */\n   128→    public int getSumLogoutCount() {\n   129→        return sumLogoutCount;\n   130→    }\n   131→\n   132→    /**\n   133→     * Sets the sumLogoutCount\n   134→     *\n   135→     * @param sumLogoutCount\n   136→     *            The sumLogoutCount to set\n   137→     */\n   138→    public void setSumLogoutCount(int sumLogoutCount) {\n   139→        this.sumLogoutCount = sumLogoutCount;\n   140→    }\n   141→\n   142→    /**\n   143→     * Gets the holdingCount\n   144→     *\n   145→     * @return Returns a int\n   146→     */\n   147→    public int getHoldingCount() {\n   148→        return holdingCount;\n   149→    }\n   150→\n   151→    /**\n   152→     * Sets the holdingCount\n   153→     *\n   154→     * @param holdingCount\n   155→     *            The holdingCount to set\n   156→     */\n   157→    public void setHoldingCount(int holdingCo