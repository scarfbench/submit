{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01PYVVEnGjFaPkcS7Kbz5LWH","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Smoke tests for DayTrader Spring Boot application.\n     4→Tests core REST API endpoints to verify the migration works correctly.\n     5→\"\"\"\n     6→\n     7→import json\n     8→import os\n     9→import sys\n    10→import time\n    11→import urllib.request\n    12→import urllib.error\n    13→import urllib.parse\n    14→\n    15→BASE_URL = os.environ.get(\"APP_URL\", \"http://localhost:8080\")\n    16→REST_BASE = f\"{BASE_URL}/rest\"\n    17→\n    18→passed = 0\n    19→failed = 0\n    20→errors = []\n    21→\n    22→\n    23→def test(name, fn):\n    24→    global passed, failed, errors\n    25→    try:\n    26→        fn()\n    27→        passed += 1\n    28→        print(f\"  PASS: {name}\")\n    29→    except Exception as e:\n    30→        failed += 1\n    31→        errors.append((name, str(e)))\n    32→        print(f\"  FAIL: {name} - {e}\")\n    33→\n    34→\n    35→def get_json(url):\n    36→    \"\"\"GET request expecting JSON response.\"\"\"\n    37→    req = urllib.request.Request(url)\n    38→    req.add_header(\"Accept\", \"application/json\")\n    39→    with urllib.request.urlopen(req, timeout=15) as resp:\n    40→        body = resp.read().decode(\"utf-8\")\n    41→        return json.loads(body), resp.status\n    42→\n    43→\n    44→def post_form(url, data):\n    45→    \"\"\"POST form-encoded data expecting JSON response.\"\"\"\n    46→    encoded = urllib.parse.urlencode(data).encode(\"utf-8\")\n    47→    req = urllib.request.Request(url, data=encoded, method=\"POST\")\n    48→    req.add_header(\"Content-Type\", \"application/x-www-form-urlencoded\")\n    49→    req.add_header(\"Accept\", \"application/json\")\n    50→    with urllib.request.urlopen(req, timeout=15) as resp:\n    51→        body = resp.read().decode(\"utf-8\")\n    52→        try:\n    53→            return json.loads(body), resp.status\n    54→        except json.JSONDecodeError:\n    55→            return body, resp.status\n    56→\n    57→\n    58→def get_text(url):\n    59→    \"\"\"GET request expecting text/html response.\"\"\"\n    60→    req = urllib.request.Request(url)\n    61→    with urllib.request.urlopen(req, timeout=15) as resp:\n    62→        return resp.read().decode(\"utf-8\"), resp.status\n    63→\n    64→\n    65→def wait_for_ready(max_wait=120):\n    66→    \"\"\"Wait for the application to be ready.\"\"\"\n    67→    print(f\"Waiting for application at {BASE_URL} to be ready...\")\n    68→    start = time.time()\n    69→    while time.time() - start < max_wait:\n    70→        try:\n    71→            req = urllib.request.Request(f\"{BASE_URL}/actuator/health\")\n    72→            with urllib.request.urlopen(req, timeout=5) as resp:\n    73→                body = json.loads(resp.read().decode(\"utf-8\"))\n    74→                if body.get(\"status\") == \"UP\":\n    75→                    print(f\"Application is ready! (took {time.time() - start:.1f}s)\")\n    76→                    return True\n    77→        except Exception:\n    78→            pass\n    79→        time.sleep(2)\n    80→    print(f\"Application did not become ready within {max_wait}s\")\n    81→    return False\n    82→\n    83→\n    84→# ============================================================\n    85→# Test functions\n    86→# ============================================================\n    87→\n    88→def test_health_endpoint():\n    89→    \"\"\"Test the actuator health endpoint.\"\"\"\n    90→    body, status = get_json(f\"{BASE_URL}/actuator/health\")\n    91→    assert status == 200, f\"Expected 200, got {status}\"\n    92→    assert body.get(\"status\") == \"UP\", f\"Expected UP, got {body.get('status')}\"\n    93→\n    94→\n    95→def test_market_summary():\n    96→    \"\"\"Test the market summary endpoint.\"\"\"\n    97→    body, status = get_json(f\"{REST_BASE}/trade/market\")\n    98→    assert status == 200, f\"Expected 200, got {status}\"\n    99→    assert body is not None, \"Market summary should not be null\"\n   100→\n   101→\n   102→def test_get_quote():\n   103→    \"\"\"Test getting a stock quote.\"\"\"\n   104→    body, status = get_json(f\"{REST_BASE}/quotes/s:0\")\n   105→    assert status == 200, f\"Expected 200, got {status}\"\n   106→    # Response is a list of quotes\n   107→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   108→    assert len(body) > 0, \"Expected at least one quote\"\n   109→    quote = body[0]\n   110→    assert quote.get(\"symbol\") == \"s:0\", f\"Expected symbol s:0, got {quote.get('symbol')}\"\n   111→\n   112→\n   113→def test_get_multiple_quotes():\n   114→    \"\"\"Test getting multiple stock quotes.\"\"\"\n   115→    body, status = get_json(f\"{REST_BASE}/quotes/s:0,s:1,s:2\")\n   116→    assert status == 200, f\"Expected 200, got {status}\"\n   117→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   118→    assert len(body) >= 3, f\"Expected at least 3 quotes, got {len(body)}\"\n   119→\n   120→\n   121→def test_login():\n   122→    \"\"\"Test user login.\"\"\"\n   123→    body, status = post_form(f\"{REST_BASE}/trade/login\", {\n   124→        \"uid\": \"uid:0\",\n   125→        \"passwd\": \"xxx\"\n   126→    })\n   127→    assert status == 200, f\"Expected 200, got {status}\"\n   128→    assert body is not None, \"Login response should not be null\"\n   129→\n   130→\n   131→def test_get_account():\n   132→    \"\"\"Test getting account data.\"\"\"\n   133→    body, status = get_json(f\"{REST_BASE}/trade/account?uid=uid:0\")\n   134→    assert status == 200, f\"Expected 200, got {status}\"\n   135→    assert body is not None, \"Account data should not be null\"\n   136→\n   137→\n   138→def test_get_holdings():\n   139→    \"\"\"Test getting user holdings.\"\"\"\n   140→    body, status = get_json(f\"{REST_BASE}/trade/holdings?uid=uid:0\")\n   141→    assert status == 200, f\"Expected 200, got {status}\"\n   142→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   143→\n   144→\n   145→def test_get_orders():\n   146→    \"\"\"Test getting user orders.\"\"\"\n   147→    body, status = get_json(f\"{REST_BASE}/trade/orders?uid=uid:0\")\n   148→    assert status == 200, f\"Expected 200, got {status}\"\n   149→    assert isinstance(body, list), f\"Expected list, got {type(body)}\"\n   150→\n   151→\n   152→def test_buy_stock():\n   153→    \"\"\"Test buying stock.\"\"\"\n   154→    body, status = post_form(f\"{REST_BASE}/trade/buy\", {\n   155→        \"uid\": \"uid:0\",\n   156→        \"symbol\": \"s:1\",\n   157→        \"quantity\": \"100.0\"\n   158→    })\n   159→    assert status == 200, f\"Expected 200, got {status}\"\n   160→\n   161→\n   162→def test_register_user():\n   163→    \"\"\"Test registering a new user.\"\"\"\n   164→    body, status = post_form(f\"{REST_BASE}/trade/register\", {\n   165→        \"uid\": \"testuser1\",\n   166→        \"passwd\": \"testpass\",\n   167→        \"fullname\": \"Test User\",\n   168→        \"address\": \"123 Test St\",\n   169→        \"email\": \"test@test.com\",\n   170→        \"creditcard\": \"1234-5678-9012-3456\",\n   171→        \"balance\": \"100000\"\n   172→    })\n   173→    assert status == 200, f\"Expected 200, got {status}\"\n   174→\n   175→\n   176→def test_web_welcome_page():\n   177→    \"\"\"Test the web welcome page.\"\"\"\n   178→    body, status = get_text(f\"{REST_BASE}/app\")\n   179→    assert status == 200, f\"Expected 200, got {status}\"\n   180→    assert \"DayTrader\" in body, \"Welcome page should contain 'DayTrader'\"\n   181→\n   182→\n   183→def test_messaging_ping_broker():\n   184→    \"\"\"Test messaging ping to broker.\"\"\"\n   185→    body, status = get_json(f\"{REST_BASE}/messaging/pingBroker?text=smoketest\")\n   186→    assert status == 200, f\"Expected 200, got {status}\"\n   187→\n   188→\n   189→def test_messaging_ping_streamer():\n   190→    \"\"\"Test messaging ping to streamer.\"\"\"\n   191→    body, status = get_json(f\"{REST_BASE}/messaging/pingStreamer?text=smoketest\")\n   192→    assert status == 200, f\"Expected 200, got {status}\"\n   193→\n   194→\n   195→def test_messaging_stats():\n   196→    \"\"\"Test getting MDB stats.\"\"\"\n   197→    body, status = get_json(f\"{REST_BASE}/messaging/stats\")\n   198→    assert status == 200, f\"Expected 200, got {status}\"\n   199→\n   200→\n   201→# ============================================================\n   202→# Main\n   203→# ============================================================\n   204→\n   205→if __name__ == \"__main__\":\n   206→    if not wait_for_ready():\n   207→        print(\"FATAL: Application not ready. Exiting.\")\n   208→        sys.exit(1)\n   209→\n   210→    # Give the app a moment after health check passes for DB population\n   211→    time.sleep(5)\n   212→\n   213→    print(\"\\n--- Running Smoke Tests ---\\n\")\n   214→\n   215→    test(\"Health endpoint\", test_health_endpoint)\n   216→    test(\"Market summary\", test_market_summary)\n   217→    test(\"Get single quote\", test_get_quote)\n   218→    test(\"Get multiple quotes\", test_get_multiple_quotes)\n   219→    test(\"User login\", test_login)\n   220→    test(\"Get account data\", test_get_account)\n   221→    test(\"Get holdings\", test_get_holdings)\n   222→    test(\"Get orders\", test_get_orders)\n   223→    test(\"Buy stock\", test_buy_stock)\n   224→    test(\"Register user\", test_register_user)\n   225→    test(\"Web welcome page\", test_web_welcome_page)\n   226→    test(\"Messaging ping broker\", test_messaging_ping_broker)\n   227→    test(\"Messaging ping streamer\", test_messaging_ping_streamer)\n   228→    test(\"Messaging stats\", test_messaging_stats)\n   229→\n   230→    print(f\"\\n--- Results: {passed} passed, {failed} failed ---\\n\")\n   231→\n   232→    if errors:\n   233→        print(\"Failures:\")\n   234→        for name, err in errors:\n   235→            print(f\"  - {name}: {err}\")\n   236→\n   237→    sys.exit(0 if failed == 0 else 1)\n   238→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8f3099ad-61fc-4987-ab0b-e3abd721a458","uuid":"f80a788b-7d56-45ab-851c-ee0bc33c4964"}
