latformTransactionManager;\n    37→import org.springframework.transaction.TransactionStatus;\n    38→import org.springframework.transaction.support.DefaultTransactionDefinition;\n    39→\n    40→import com.ibm.websphere.samples.daytrader.messaging.MessageProducerService;\n    41→\n    42→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    43→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    44→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    45→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    46→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    47→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    48→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    49→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    50→import com.ibm.websphere.samples.daytrader.util.Log;\n    51→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    52→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    53→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    54→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    55→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    56→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    57→\n    58→/**\n    59→ * TradeDirect uses direct JDBC and JMS access to a\n    60→ * <code>javax.sql.DataSource</code> to implement the business methods of the\n    61→ * Trade online broker application. These business methods represent the\n    62→ * features and operations that can be performed by customers of the brokerage\n    63→ * such as login, logout, get a stock quote, buy or sell a stock, etc. and are\n    64→ * specified in the {@link com.ibm.websphere.samples.daytrader.TradeServices}\n    65→ * interface\n    66→ *\n    67→ * Note: In order for this class to be thread-safe, a new TradeJDBC must be\n    68→ * created for each call to a method from the TradeInterface interface.\n    69→ * Otherwise, pooled connections may not be released.\n    70→ *\n    71→ * @see com.ibm.websphere.samples.daytrader.TradeServices\n    72→ *\n    73→ */\n    74→\n    75→// TradeDirect is injectable only via @TradeJDBC qualifier (no @Default)\n    76→// This prevents ambiguity with TradeSLSBBean which is the @Default implementation\n    77→@Component\n    78→@Scope(\"prototype\")\n    79→@TradeJDBC\n    80→@RuntimeMode(\"Direct (JDBC)\")\n    81→@Trace\n    82→public class TradeDirect implements TradeServices, Serializable {\n    83→  /**\n    84→   *\n    85→   */\n    86→  private static final long serialVersionUID = -8089049090952927985L;\n    87→\n    88→  //This lock is used to serialize market summary operations.\n    89→  private static final Integer marketSummaryLock = new Integer(0);\n    90→  private static long nextMarketSummary = System.currentTimeMillis();\n    91→  private static MarketSummaryDataBean cachedMSDB = MarketSummaryDataBean.getRandomInstance();\n    92→\n    93→  private static BigDecimal ZERO = new BigDecimal(0.0);\n    94→  private boolean inGlobalTxn = false;\n    95→  private boolean inSession = false;\n    96→\n    97→  // MIGRATION: JMS resources replaced with MessageProducerService\n    98→  // Original Jakarta EE used JMS QueueConnectionFactory and TopicConnectionFactory\n    99→  // Spring uses MessageProducerService\n   100→\n   101→  @Autowired\n   102→  private DataSource datasource;\n   103→\n   104→  @Autowired\n   105→  private PlatformTransactionManager transactionManager;\n   106→\n   107→  private TransactionStatus txStatus;\n   108→\n   109→  @Autowired\n   110→  RecentQuotePriceChangeList recentQuotePriceChangeList;\n   111→\n   112→  @Autowired\n   113→  AsyncOrderSubmitter asyncOrderSubmitter;\n   114→\n   115→  // MIGRATION: Removed CDI Event - not needed in Spring\n   116→\n   117→  @Autowired\n   118→  MessageProducerService messageProducer;\n   119→\n   120→\n   121→  @Override\n   122→  public MarketSummaryDataBean getMarketSummary() throws Exception {\n   123→\n   124→    if (TradeConfig.getMarketSummaryInterval() == 0) {\n   125→      return getMarketSummaryInternal();\n   126→    }\n   127→    if (TradeConfig.getMarketSummaryInterval() < 0) {\n   128→      return cachedMSDB;\n   129→    }\n   130→\n   131→    /**\n   132→     * This is a little funky. If its time to fetch a new Market summary\n   133→     * then we'll synchronize access to make sure only one requester does\n   134→     * it. Others will merely return the old copy until the new\n   135→     * MarketSummary has been executed.\n   136→     */\n   137→\n   138→    long currentTime = System.currentTimeMillis();\n   139→\n   140→    if (currentTime > nextMarketSummary) {\n   141→      long oldNextMarketSummary = nextMarketSummary;\n   142→      boolean fetch = false;\n   143→\n   144→      synchronized (marketSummaryLock) {\n   145→        /**\n   146→         * Is it still ahead or did we miss lose the race? If we lost\n   147→         * then let's get out of here as the work has already been done.\n   148→         */\n   149→        if (oldNextMarketSummary == nextMarketSummary) {\n   150→          fetch = true;\n   151→          nextMarketSummary += TradeConfig.getMarketSummaryInterval() * 1000;\n   152→\n   153→          /**\n   154→           * If the server has been idle for a while then its possible\n   155→           * that nextMarketSummary could be way off. Rather than try\n   156→           * and play catch up we'll simply get in sync with the\n   157→           * current time + the interval.\n   158→           */\n   159→          if (nextMarketSummary < currentTime) {\n   160→            nextMarketSummary = currentTime + TradeConfig.getMarketSummaryInterval() * 1000;\n   161→          }\n   162→        }\n   163→      }\n   164→\n   165→      /**\n   166→       * If we're the lucky one then let's update the MarketSummary\n   167→       */\n   168→      if (fetch) {\n   169→        cachedMSDB = getMarketSummaryInternal();\n   170→\n   171→      }\n   172→    }\n   173→\n   174→    return cachedMSDB;\n   175→  }\n   176→\n   177→\n   178→\n   179→  /**\n   180→   * @see TradeServices#getMarketSummary()\n   181→   */\n   182→\n   183→  public MarketSummaryDataBean getMarketSummaryInternal() throws Exception {\n   184→\n   185→    MarketSummaryDataBean marketSummaryData = null;\n   186→    Connection conn = null;\n   187→    try {\n   188→\n   189→      Log.trace(\"TradeDirect:getMarketSummary - inSession(\" + this.inSession + \")\");\n   190→\n   191→      conn = getConn();\n   192→      PreparedStatement stmt = getStatement(conn, getTSIAQuotesOrderByChangeSQL, ResultSet.TYPE_SCROLL_INSENSITIVE, ResultSet.CONCUR_READ_ONLY);\n   193→\n   194→      ArrayList<QuoteDataBean> topGainersData = new ArrayList<QuoteDataBean>(5);\n   195→      ArrayList<QuoteDataBean> topLosersData = new ArrayList<QuoteDataBean>(5);\n   196→\n   197→      ResultSet rs = stmt.executeQuery();\n   198→\n   199→      int count = 0;\n   200→      while (rs.next() && (count++ < 5)) {\n   201→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   202→        topLosersData.add(quoteData);\n   203→      }\n   204→\n   205→      stmt.close();\n   206→      stmt = getStatement(conn, \"select * from quoteejb q order by q.change1 DESC\", ResultSet.TYPE_SCROLL_INSENSITIVE, ResultSet.CONCUR_READ_ONLY);\n   207→      rs = stmt.executeQuery();\n   208→\n   209→      count = 0;\n   210→      while (rs.next() && (count++ < 5)) {\n   211→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   212→        topGainersData.add(quoteData);\n   213→      }\n   214→\n   215→      /*\n   216→       * rs.last(); count = 0; while (rs.previous() && (count++ < 5) ) {\n   217→       * QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   218→       * topGainersData.add(quoteData); }\n   219→       */\n   220→\n   221→      stmt.close();\n   222→\n   223→      BigDecimal TSIA = ZERO;\n   224→      BigDecimal openTSIA = ZERO;\n   225→      double volume = 0.0;\n   226→\n   227→      if ((topGainersData.size() > 0) || (topLosersData.size() > 0)) {\n   228→\n   229→        stmt = getStatement(conn, getTSIASQL);\n   230→        rs = stmt.executeQuery();\n   231→\n   232→        if (!rs.next()) {\n   233→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIASQL -- no results\");\n   234→        } else {\n   235→          TSIA = rs.getBigDecimal(\"TSIA\");\n   236→        }\n   237→        stmt.close();\n   238→\n   239→        stmt = getStatement(conn, getOpenTSIASQL);\n   240→        rs = stmt.executeQuery();\n   241→\n   242→        if (!rs.next()) {\n   243→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getOpenTSIASQL -- no results\");\n   244→        } else {\n   245→          openTSIA = rs.getBigDecimal(\"openTSIA\");\n   246→        }\n   247→        stmt.close();\n   248→\n   249→        stmt = getStatement(conn, getTSIATotalVolumeSQL);\n   250→        rs = stmt.executeQuery();\n   251→\n   252→        if (!rs.next()) {\n   253→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIATotalVolumeSQL -- no results\");\n   254→        } else {\n   255→          volume = rs.getDouble(\"totalVolume\");\n   256→        }\n   257→        stmt.close();\n   258→      }\n   259→      commit(conn);\n   260→\n   261→      marketSummaryData = new MarketSummaryDataBean(TSIA, openTSIA, volume, topGainersData, topLosersData);\n   262→      // MIGRATION: Removed CDI Event fireAsync call\n   263→\n   264→    }\n   265→\n   266→    catch (Exception e) {\n   267→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n   268→      rollBack(conn, e);\n   269→    } finally {\n   270→      releaseConn(conn);\n   271→    }\n   272→    return marketSummaryData;\n   273→\n   274→  }\n   275→\n   276→  /**\n   277→   * @see TradeServices#buy(String, String, double)\n   278→   */\n   279→  @Override\n   280→  @NotNull\n   281→  public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) throws Exception {\n   282→\n   283→    final Connection conn = getConn();\n   284→    OrderDataBean orderData = null;\n   285→\n   286→    BigDecimal total;\n   287→\n   288→    try {\n   289→\n   290→      Log.trace(\"TradeDirect:buy - inSession(\" + this.inSession + \")\");//, userID, symbol, new Double(quantity));\n   291→\n   292→\n   293→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   294→\n   295→        Log.trace(\"TradeDirect:buy create/begin global transaction\");\n   296→\n   297→\n   298→        txStatus = transactionManager.getTransaction(new DefaultTransactionDefinition());\n   299→        setInGlobalTxn(true);\n   300→      }\n   301→\n   302→      //conn = getConn();\n   303→\n   304→      AccountDataBean accountData = getAccountData(conn, userID);\n   305→      QuoteDataBean quoteData = getQuoteData(conn, symbol);\n   306→      HoldingDataBean holdingData = null; // the buy operation will create\n   307→      // the holding\n   308→\n   309→      orderData = createOrder(accountData, quoteData, holdingData, \"buy\", quantity);\n   310→\n   311→      // Update -- account should be credited during completeOrder\n   312→      BigDecimal price = quoteData.getPrice();\n   313→      BigDecimal orderFee = orderData.getOrderFee();\n   314→      total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   315→      // subtract total from account balance\n   316→      creditAccountBalance(conn, accountData, total.negate());\n   317→      final Integer orderID = orderData.getOrderID();\n   318→\n   319→      try {\n   320→\n   321→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   322→          completeOrder(conn, orderData.getOrderID());\n   323→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   324→          completeOrderAsync(orderID, true);\n   325→        } else  if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   326→          queueOrder(orderID, true); // 2-phase\n   327→        }\n   328→      } catch (Exception je) {\n   329→        // MIGRATION: JMSException -> Exception (no JMS in Spring)\n   330→        Log.error(\"TradeBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed to queueOrder\", je);\n   331→\n   332→\n   333→        cancelOrder(conn, orderData.getOrderID());\n   334→      }\n   335→\n   336→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   337→\n   338→      if (getInGlobalTxn()) {\n   339→\n   340→        Log.trace(\"TradeDirect:buy committing global transaction\");\n   341→\n   342→        if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   343→          transactionManager.commit(txStatus);\n   344→          setInGlobalTxn(false);\n   345→        }\n   346→      } else {\n   347→        commit(conn);\n   348→      }\n   349→    } catch (Exception e) {\n   350→      Log.error(\"TradeDirect:buy error - rolling back\", e);\n   351→      if (getInGlobalTxn()) {\n   352→        transactionManager.rollback(txStatus);\n   353→      } else {\n   354→        rollBack(conn, e);\n   355→      }\n   356→    } finally {\n   357→      releaseConn(conn);\n   358→    }\n   359→\n   360→    return orderData;\n   361→  }\n   362→\n   363→  /**\n   364→   * @see TradeServices#sell(String, Integer)\n   365→   */\n   366→  @Override\n   367→  @NotNull\n   368→  public OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception {\n   369→    Connection conn = null;\n   370→    OrderDataBean orderData = null;\n   371→    //UserTransaction txn = null;\n   372→\n   373→    /*\n   374→     * total = (quantity * purchasePrice) + orderFee\n   375→     */\n   376→    BigDecimal total;\n   377→\n   378→    try {\n   379→\n   380→      Log.trace(\"TradeDirect:sell - inSession(\" + this.inSession + \")\", userID, holdingID);\n   381→\n   382→\n   383→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   384→\n   385→        Log.trace(\"TradeDirect:sell create/begin global transaction\");\n   386→\n   387→        txStatus = transactionManager.getTransaction(new DefaultTransactionDefinition());\n   388→        setInGlobalTxn(true);\n   389→      }\n   390→\n   391→      conn = getConn();\n   392→\n   393→      AccountDataBean accountData = getAccountData(conn, userID);\n   394→      HoldingDataBean holdingData = getHoldingData(conn, holdingID.intValue());\n   395→      QuoteDataBean quoteData = null;\n   396→      if (holdingData != null) {\n   397→        quoteData = getQuoteData(conn, holdingData.getQuoteID());\n   398→      }\n   399→\n   400→      if ((accountData == null) || (holdingData == null) || (quoteData == null)) {\n   401→        String error = \"TradeDirect:sell -- error selling stock -- unable to find:  \\n\\taccount=\" + accountData + \"\\n\\tholding=\" + holdingData\n   402→            + \"\\n\\tquote=\" + quoteData + \"\\nfor user: \" + userID + \" and holdingID: \" + holdingID;\n   403→        Log.debug(error);\n   404→        if (getInGlobalTxn()) {\n   405→          transactionManager.rollback(txStatus);\n   406→        } else {\n   407→          rollBack(conn, new Exception(error));\n   408→        }\n   409→        orderData = new OrderDataBean();\n   410→        orderData.setOrderStatus(\"cancelled\");\n   411→        return orderData;\n   412→      }\n   413→\n   414→      double quantity = holdingData.getQuantity();\n   415→\n   416→      orderData = createOrder(accountData, quoteData, holdingData, \"sell\", quantity);\n   417→\n   418→      // Set the holdingSymbol purchaseDate to selling to signify the sell\n   419→      // is \"inflight\"\n   420→      updateHoldingStatus(conn, holdingData.getHoldingID(), holdingData.getQuoteID());\n   421→\n   422→      // UPDATE -- account should be credited during completeOrder\n   423→      BigDecimal price = quoteData.getPrice();\n   424→      BigDecimal orderFee = orderData.getOrderFee();\n   425→      total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   426→      creditAccountBalance(conn, accountData, total);\n   427→\n   428→      try {\n   429→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   430→          completeOrder(conn, orderData.getOrderID());\n   431→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   432→          this.completeOrderAsync(orderData.getOrderID(), true);\n   433→        } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   434→          queueOrder(orderData.getOrderID(), true);\n   435→        }\n   436→      } catch (Exception je) {\n   437→        // MIGRATION: JMSException -> Exception (no JMS in Spring)\n   438→        Log.error(\"TradeBean:sell(\" + userID + \",\" + holdingID + \") --> failed to queueOrder\", je);\n   439→\n   440→        cancelOrder(conn, orderData.getOrderID());\n   441→      }\n   442→\n   443→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   444→\n   445→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   446→\n   447→        Log.trace(\"TradeDirect:sell committing global transaction\");\n   448→\n   449→        transactionManager.commit(txStatus);\n   450→        setInGlobalTxn(false);\n   451→      } else {\n   452→        commit(conn);\n   453→      }\n   454→    } catch (Exception e) {\n   455→      Log.error(\"TradeDirect:sell error\", e);\n   456→      if (getInGlobalTxn()) {\n   457→        transactionManager.rollback(txStatus);\n   458→      } else {\n   459→        rollBack(conn, e);\n   460→      }\n   461→    } finally {\n   462→      releaseConn(conn);\n   463→    }\n   464→\n   465→    return orderData;\n   466→  }\n   467→\n   468→  /**\n   469→   * @see TradeServices#queueOrder(Integer)\n   470→   */\n   471→  @Override\n   472→  public void queueOrder(Integer orderID, boolean twoPhase) throws Exception {\n   473→\n   474→\n   475→    Log.trace(\"TradeDirect:queueOrder - inSession(\" + this.inSession + \")\", orderID);\n   476→\n   477→    // MIGRATION: JMS Queue -> Messaging via MessageProducerService\n   478→    // Original: Create JMSContext, TextMessage, set properties, send to queue\n   479→    // Spring: Simply call messageProducer.queueOrderForProcessing()\n   480→    messageProducer.queueOrderForProcessing(orderID, twoPhase);\n   481→  }\n   482→\n   483→  /**\n   484→   * @see TradeServices#completeOrder(Integer)\n   485→   */\n   486→  @Override\n   487→  public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   488→    OrderDataBean orderData = null;\n   489→    Connection conn = null;\n   490→\n   491→    try { // twoPhase\n   492→\n   493→\n   494→      Log.trace(\"TradeDirect:completeOrder - inSession(\" + this.inSession + \")\", orderID);\n   495→\n   496→      setInGlobalTxn(!inSession && twoPhase);\n   497→      conn = getConn();\n   498→\n   499→      orderData = completeOrder(conn, orderID);\n   500→\n   501→      commit(conn);\n   502→\n   503→    } catch (Exception e) {\n   504→      Log.error(\"TradeDirect:completeOrder -- error completing order\", e);\n   505→      rollBack(conn, e);\n   506→      cancelOrder(orderID, twoPhase);\n   507→    } finally {\n   508→      releaseConn(conn);\n   509→    }\n   510→\n   511→    return orderData;\n   512→\n   513→  }\n   514→\n   515→  @Override\n   516→  public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   517→    if (!inSession) {\n   518→      asyncOrderSubmitter.submitOrder(orderID, twoPhase);\n   519→    }\n   520→    return null;\n   521→  }\n   522→\n   523→\n   524→  private OrderDataBean completeOrder(Connection conn, Integer orderID) throws Exception {\n   525→    //conn = getConn();\n   526→    OrderDataBean orderData = null;\n   527→\n   528→    Log.trace(\"TradeDirect:completeOrderInternal - inSession(\" + this.inSession + \")\", orderID);\n   529→\n   530→\n   531→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n   532→    stmt.setInt(1, orderID.intValue());\n   533→\n   534→    ResultSet rs = stmt.executeQuery();\n   535→\n   536→    if (!rs.next()) {\n   537→      Log.error(\"TradeDirect:completeOrder -- unable to find order: \" + orderID);\n   538→      stmt.close();\n   539→      return orderData;\n   540→    }\n   541→    orderData = getOrderDataFromResultSet(rs);\n   542→\n   543→    String orderType = orderData.getOrderType();\n   544→    String orderStatus = orderData.getOrderStatus();\n   545→\n   546→    // if (order.isCompleted())\n   547→    if ((orderStatus.compareToIgnoreCase(\"completed\") == 0) || (orderStatus.compareToIgnoreCase(\"alertcompleted\") == 0)\n   548→        || (orderStatus.compareToIgnoreCase(\"cancelled\") == 0)) {\n   549→      throw new Exception(\"TradeDirect:completeOrder -- attempt to complete Order that is already completed\");\n   550→    }\n   551→\n   552→    int accountID = rs.getInt(\"account_accountID\");\n   553→    String quoteID = rs.getString(\"quote_symbol\");\n   554→    int holdingID = rs.getInt(\"holding_holdingID\");\n   555→\n   556→    BigDecimal price = orderData.getPrice();\n   557→    double quantity = orderData.getQuantity();\n   558→\n   559→    // get the data for the account and quote\n   560→    // the holding will be created for a buy or extracted for a sell\n   561→\n   562→    /*\n   563→     * Use the AccountID and Quote Symbol from the Order AccountDataBean\n   564→     * accountData = getAccountData(accountID, conn); QuoteDataBean\n   565→     * quoteData = getQuoteData(conn, quoteID);\n   566→     */\n   567→    String userID = getAccountProfileData(conn, new Integer(accountID)).getUserID();\n   568→\n   569→    HoldingDataBean holdingData = null;\n   570→\n   571→\n   572→    Log.trace(\"TradeDirect:completeOrder--> Completing Order \" + orderData.getOrderID() + \"\\n\\t Order info: \" + orderData + \"\\n\\t Account info: \"\n   573→          + accountID + \"\\n\\t Quote info: \" + quoteID);\n   574→\n   575→\n   576→    // if (order.isBuy())\n   577→    if (orderType.compareToIgnoreCase(\"buy\") == 0) {\n   578→      /*\n   579→       * Complete a Buy operation - create a new Holding for the Account -\n   580→       * deduct the Order cost from the Account balance\n   581→       */\n   582→\n   583→      holdingData = createHolding(conn, accountID, quoteID, quantity, price);\n   584→      updateOrderHolding(conn, orderID.intValue(), holdingData.getHoldingID().intValue());\n   585→      updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   586→      updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), orderData.getQuantity());\n   587→    }\n   588→\n   589→    // if (order.isSell()) {\n   590→    if (orderType.compareToIgnoreCase(\"sell\") == 0) {\n   591→      /*\n   592→       * Complete a Sell operation - remove the Holding from the Account -\n   593→       * deposit the Order proceeds to the Account balance\n   594→       */\n   595→      holdingData = getHoldingData(conn, holdingID);\n   596→      if (holdingData == null) {\n   597→        Log.debug(\"TradeDirect:completeOrder:sell -- user: \" + userID + \" already sold holding: \" + holdingID);\n   598→        updateOrderStatus(conn, orderData.getOrderID(), \"cancelled\");\n   599→      } else {\n   600→        removeHolding(conn, holdingID, orderID.intValue());\n   601→        updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   602→        updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), orderData.getQuantity());\n   603→      }\n   604→\n   605→    }\n   606→\n   607→\n   608→\n   609→    Log.trace(\"TradeDirect:completeOrder--> Completed Order \" + orderData.getOrderID() + \"\\n\\t Order info: \" + orderData + \"\\n\\t Account info: \"\n   610→          + accountID + \"\\n\\t Quote info: \" + quoteID + \"\\n\\t Holding info: \" + holdingData);\n   611→\n   612→    stmt.close();\n   613→\n   614→    commit(conn);\n   615→\n   616→\n   617→\n   618→    return orderData;\n   619→  }\n   620→\n   621→  /**\n   622→   * @see TradeServices#cancelOrder(Integer, boolean)\n   623→   */\n   624→  @Override\n   625→  public void cancelOrder(Integer orderID, boolean twoPhase) throws Exception {\n   626→\n   627→    Connection conn = null;\n   628→    try {\n   629→\n   630→      Log.trace(\"TradeDirect:cancelOrder - inSession(\" + this.inSession + \")\", orderID);\n   631→\n   632→      setInGlobalTxn(!inSession && twoPhase);\n   633→      conn = getConn();\n   634→      cancelOrder(conn, orderID);\n   635→      commit(conn);\n   636→\n   637→    } catch (Exception e) {\n   638→      Log.error(\"TradeDirect:cancelOrder -- error cancelling order: \" + orderID, e);\n   639→      rollBack(conn, e);\n   640→    } finally {\n   641→      releaseConn(conn);\n   642→    }\n   643→  }\n   644→\n   645→  private void cancelOrder(Connection conn, Integer orderID) throws Exception {\n   646→    updateOrderStatus(conn, orderID, \"cancelled\");\n   647→  }\n   648→\n   649→  @Override\n   650→  public void orderCompleted(String userID, Integer orderID) throws Exception {\n   651→    throw new UnsupportedOperationException(\"TradeDirect:orderCompleted method not supported\");\n   652→  }\n   653→\n   654→  private HoldingDataBean createHolding(Connection conn, int accountID, String symbol, double quantity, BigDecimal purchasePrice) throws Exception {\n   655→\n   656→    Timestamp purchaseDate = new Timestamp(System.currentTimeMillis());\n   657→    PreparedStatement stmt = getStatement(conn, createHoldingSQL);\n   658→\n   659→    Integer holdingID = KeySequenceDirect.getNextID(conn, \"holding\", inSession, getInGlobalTxn());\n   660→    stmt.setInt(1, holdingID.intValue());\n   661→    stmt.setTimestamp(2, purchaseDate);\n   662→    stmt.setBigDecimal(3, purchasePrice);\n   663→    stmt.setDouble(4, quantity);\n   664→    stmt.setString(5, symbol);\n   665→    stmt.setInt(6, accountID);\n   666→    stmt.executeUpdate();\n   667→\n   668→    stmt.close();\n   669→\n   670→    return getHoldingData(conn, holdingID.intValue());\n   671→  }\n   672→\n   673→  private void removeHolding(Connection conn, int holdingID, int orderID) throws Exception {\n   674→    PreparedStatement stmt = getStatement(conn, removeHoldingSQL);\n   675→\n   676→    stmt.setInt(1, holdingID);\n   677→    stmt.executeUpdate();\n   678→    stmt.close();\n   679→\n   680→    // set the HoldingID to NULL for the purchase and sell order now that\n   681→    // the holding as been removed\n   682→    stmt = getStatement(conn, removeHoldingFromOrderSQL);\n   683→\n   684→    stmt.setInt(1, holdingID);\n   685→    stmt.executeUpdate();\n   686→    stmt.close();\n   687→\n   688→  }\n   689→\n   690→  public OrderDataBean createOrder(AccountDataBean accountData, QuoteDataBean quoteData, HoldingDataBean holdingData, String orderType,\n   691→      double quantity) throws Exception {\n   692→    OrderDataBean orderData = null;\n   693→    Connection conn = null;\n   694→    try {\n   695→\n   696→      conn = getConn();\n   697→      Timestamp currentDate = new Timestamp(System.currentTimeMillis());\n   698→\n   699→      PreparedStatement stmt = getStatement(conn, createOrderSQL);\n   700→\n   701→      Integer orderID = KeySequenceDirect.getNextID(conn, \"order\", inSession, getInGlobalTxn());\n   702→      stmt.setInt(1, orderID.intValue());\n   703→      stmt.setString(2, orderType);\n   704→      stmt.setString(3, \"open\");\n   705→      stmt.setTimestamp(4, currentDate);\n   706→      stmt.setDouble(5, quantity);\n   707→      stmt.setBigDecimal(6, quoteData.getPrice().setScale(FinancialUtils.SCALE, FinancialUtils.ROUND));\n   708→      stmt.setBigDecimal(7, TradeConfig.getOrderFee(orderType));\n   709→      stmt.setInt(8, accountData.getAccountID().intValue());\n   710→      if (holdingData == null) {\n   711→        stmt.setNull(9, java.sql.Types.INTEGER);\n   712→      } else {\n   713→        stmt.setInt(9, holdingData.getHoldingID().intValue());\n   714→      }\n   715→      stmt.setString(10, quoteData.getSymbol());\n   716→      stmt.executeUpdate();\n   717→\n   718→      orderData = getOrderData(conn, orderID.intValue());\n   719→\n   720→      stmt.close();\n   721→\n   722→      commit(conn);\n   723→    } catch (Exception e) {\n   724→      Log.error(\"TradeDirect:createOrder -- error getting user orders\", e);\n   725→      rollBack(conn, e);\n   726→    } finally {\n   727→      releaseConn(conn);\n   728→    }\n   729→\n   730→    return orderData;\n   731→  }\n   732→\n   733→  /**\n   734→   * @see TradeServices#getOrders(String)\n   735→   */\n   736→  @Override\n   737→  public Collection<OrderDataBean> getOrders(String userID) throws Exception {\n   738→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   739→    Connection conn = null;\n   740→    try {\n   741→      Log.trace(\"TradeDirect:getOrders - inSession(\" + this.inSession + \")\", userID);\n   742→\n   743→\n   744→      conn = getConn();\n   745→      PreparedStatement stmt = getStatement(conn, getOrdersByUserSQL);\n   746→      stmt.setString(1, userID);\n   747→\n   748→      ResultSet rs = stmt.executeQuery();\n   749→\n   750→      // TODO: return top 5 orders for now -- next version will add a\n   751→      // getAllOrders method\n   752→      // also need to get orders sorted by order id descending\n   753→      int i = 0;\n   754→      while ((rs.next()) && (i++ < 5)) {\n   755→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   756→        orderDataBeans.add(orderData);\n   757→      }\n   758→\n   759→      stmt.close();\n   760→      commit(conn);\n   761→\n   762→    } catch (Exception e) {\n   763→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   764→      rollBack(conn, e);\n   765→    } finally {\n   766→      releaseConn(conn);\n   767→    }\n   768→    return orderDataBeans;\n   769→  }\n   770→\n   771→  /**\n   772→   * @see TradeServices#getClosedOrders(String)\n   773→   */\n   774→  @Override\n   775→  public Collection<OrderDataBean> getClosedOrders(String userID) throws Exception {\n   776→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   777→    Connection conn = null;\n   778→    try {\n   779→\n   780→      Log.trace(\"TradeDirect:getClosedOrders - inSession(\" + this.inSession + \")\", userID);\n   781→\n   782→\n   783→      conn = getConn();\n   784→      PreparedStatement stmt = getStatement(conn, getClosedOrdersSQL);\n   785→      stmt.setString(1, userID);\n   786→\n   787→      ResultSet rs = stmt.executeQuery();\n   788→\n   789→      while (rs.next()) {\n   790→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   791→        orderData.setOrderStatus(\"completed\");\n   792→        updateOrderStatus(conn, orderData.getOrderID(), orderData.getOrderStatus());\n   793→        orderDataBeans.add(orderData);\n   794→\n   795→      }\n   796→\n   797→      stmt.close();\n   798→      commit(conn);\n   799→    } catch (Exception e) {\n   800→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   801→      rollBack(conn, e);\n   802→    } finally {\n   803→      releaseConn(conn);\n   804→    }\n   805→    return orderDataBeans;\n   806→  }\n   807→\n   808→  /**\n   809→   * @see TradeServices#createQuote(String, String, BigDecimal)\n   810→   */\n   811→  @Override\n   812→  public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception {\n   813→\n   814→    QuoteDataBean quoteData = null;\n   815→    Connection conn = null;\n   816→    try {\n   817→\n   818→      Log.trace(\"TradeDirect:createQuote - inSession(\" + this.inSession + \")\");\n   819→\n   820→\n   821→      price = price.setScale(FinancialUtils.SCALE, FinancialUtils.ROUND);\n   822→      double volume = 0.0, change = 0.0;\n   823→\n   824→      conn = getConn();\n   825→      PreparedStatement stmt = getStatement(conn, createQuoteSQL);\n   826→      stmt.setString(1, symbol); // symbol\n   827→      stmt.setString(2, companyName); // companyName\n   828→      stmt.setDouble(3, volume); // volume\n   829→      stmt.setBigDecimal(4, price); // price\n   830→      stmt.setBigDecimal(5, price); // open\n   831→      stmt.setBigDecimal(6, price); // low\n   832→      stmt.setBigDecimal(7, price); // high\n   833→      stmt.setDouble(8, change); // change\n   834→\n   835→      stmt.executeUpdate();\n   836→      stmt.close();\n   837→      commit(conn);\n   838→\n   839→      quoteData = new QuoteDataBean(symbol, companyName, volume, price, price, price, price, change);\n   840→    } catch (Exception e) {\n   841→      Log.error(\"TradeDirect:createQuote -- error creating quote\", e);\n   842→    } finally {\n   843→      releaseConn(conn);\n   844→    }\n   845→    return quoteData;\n   846→  }\n   847→\n   848→  /**\n   849→   * @see TradeServices#getQuote(String)\n   850→   */\n   851→\n   852→  @Override\n   853→  public QuoteDataBean getQuote(String symbol) throws Exception {\n   854→    QuoteDataBean quoteData = null;\n   855→    Connection conn = null;\n   856→\n   857→    try {\n   858→\n   859→      Log.trace(\"TradeDirect:getQuote - inSession(\" + this.inSession + \")\", symbol);\n   860→\n   861→\n   862→      conn = getConn();\n   863→      quoteData = getQuote(conn, symbol);\n   864→      commit(conn);\n   865→    } catch (Exception e) {\n   866→      Log.error(\"TradeDirect:getQuote -- error getting quote\", e);\n   867→      rollBack(conn, e);\n   868→    } finally {\n   869→      releaseConn(conn);\n   870→    }\n   871→    return quoteData;\n   872→  }\n   873→\n   874→  private QuoteDataBean getQuote(Connection conn, String symbol) throws Exception {\n   875→    QuoteDataBean quoteData = null;\n   876→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n   877→    stmt.setString(1, symbol); // symbol\n   878→\n   879→    ResultSet rs = stmt.executeQuery();\n   880→\n   881→    if (!rs.next()) {\n   882→      Log.error(\"TradeDirect:getQuote -- failure no result.next() for symbol: \" + symbol);\n   883→    } else {\n   884→      quoteData = getQuoteDataFromResultSet(rs);\n   885→    }\n   886→\n   887→    stmt.close();\n   888→\n   889→    return quoteData;\n   890→  }\n   891→\n   892→  private QuoteDataBean getQuoteForUpdate(Connection conn, String symbol) throws Exception {\n   893→    QuoteDataBean quoteData = null;\n   894→    PreparedStatement stmt = getStatement(conn, getQuoteForUpdateSQL);\n   895→    stmt.setString(1, symbol); // symbol\n   896→\n   897→    ResultSet rs = stmt.executeQuery();\n   898→\n   899→    if (!rs.next()) {\n   900→      Log.error(\"TradeDirect:getQuote -- failure no result.next()\");\n   901→    } else {\n   902→      quoteData = getQuoteDataFromResultSet(rs);\n   903→    }\n   904→\n   905→    stmt.close();\n   906→\n   907→    return quoteData;\n   908→  }\n   909→\n   910→  /**\n   911→   * @see TradeServices#getAllQuotes(String)\n   912→   */\n   913→  @Override\n   914→  public Collection<QuoteDataBean> getAllQuotes() throws Exception {\n   915→    Collection<QuoteDataBean> quotes = new ArrayList<QuoteDataBean>();\n   916→    QuoteDataBean quoteData = null;\n   917→\n   918→    Connection conn = null;\n   919→    try {\n   920→      conn = getConn();\n   921→\n   922→      PreparedStatement stmt = getStatement(conn, getAllQuotesSQL);\n   923→\n   924→      ResultSet rs = stmt.executeQuery();\n   925→\n   926→      while (!rs.next()) {\n   927→        quoteData = getQuoteDataFromResultSet(rs);\n   928→        quotes.add(quoteData);\n   929→      }\n   930→\n   931→      stmt.close();\n   932→    } catch (Exception e) {\n   933→      Log.error(\"TradeDirect:getAllQuotes\", e);\n   934→      rollBack(conn, e);\n   935→    } finally {\n   936→      releaseConn(conn);\n   937→    }\n   938→\n   939→    return quotes;\n   940→  }\n   941→\n   942→  /**\n   943→   * @see TradeServices#getHoldings(String)\n   944→   */\n   945→  @Override\n   946→  public Collection<HoldingDataBean> getHoldings(String userID) throws Exception {\n   947→    Collection<HoldingDataBean> holdingDataBeans = new ArrayList<HoldingDataBean>();\n   948→    Connection conn = null;\n   949→    try {\n   950→\n   951→      Log.trace(\"TradeDirect:getHoldings - inSession(\" + this.inSession + \")\", userID);\n   952→\n   953→\n   954→      conn = getConn();\n   955→      PreparedStatement stmt = getStatement(conn, getHoldingsForUserSQL);\n   956→      stmt.setString(1, userID);\n   957→\n   958→      ResultSet rs = stmt.executeQuery();\n   959→\n   960→      while (rs.next()) {\n   961→        HoldingDataBean holdingData = getHoldingDataFromResultSet(rs);\n   962→        holdingDataBeans.add(holdingData);\n   963→      }\n   964→\n   965→      stmt.close();\n   966→      commit(conn);\n   967→\n   968→    } catch (Exception e) {\n   969→      Log.error(\"TradeDirect:getHoldings -- error getting user holings\", e);\n   970→      rollBack(conn, e);\n   971→    } finally {\n   972→      releaseConn(conn);\n   973→    }\n   974→    return holdingDataBeans;\n   975→  }\n   976→\n   977→  /**\n   978→   * @see TradeServices#getHolding(Integer)\n   979→   */\n   980→  @Override\n   981→  public HoldingDataBean getHolding(Integer holdingID) throws Exception {\n   982→    HoldingDataBean holdingData = null;\n   983→    Connection conn = null;\n   984→    try {\n   985→\n   986→      Log.trace(\"TradeDirect:getHolding - inSession(\" + this.inSession + \")\", holdingID);\n   987→\n   988→\n   989→      conn = getConn();\n   990→      holdingData = getHoldingData(holdingID.intValue());\n   991→\n   992→      commit(conn);\n   993→\n   994→    } catch (Exception e) {\n   995→      Log.error(\"TradeDirect:getHolding -- error getting holding \" + holdingID + \"\", e);\n   996→      rollBack(conn, e);\n   997→    } finally {\n   998→      releaseConn(conn);\n   999→    }\n  1000→    return holdingData;\n  1001→  }\n  1002→\n  1003→  /**\n  1004→   * @see TradeServices#getAccountData(String)\n  1005→   */\n  1006→  @Override\n  1007→  public AccountDataBean getAccountData(String userID) throws Exception {\n  1008→    try {\n  1009→      AccountDataBean accountData = null;\n  1010→      Connection conn = null;\n  1011→      try {\n  1012→\n  1013→        Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", userID);\n  1014→\n  1015→\n  1016→        conn = getConn();\n  1017→        accountData = getAccountData(conn, userID);\n  1018→        commit(conn);\n  1019→\n  1020→      } catch (Exception e) {\n  1021→        Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1022→        rollBack(conn, e);\n  1023→      } finally {\n  1024→        releaseConn(conn);\n  1025→      }\n  1026→      return accountData;\n  1027→    } catch (Exception e) {\n  1028→      throw new Exception(e.getMessage(), e);\n  1029→    }\n  1030→  }\n  1031→\n  1032→  private AccountDataBean getAccountData(Connection conn, String userID) throws Exception {\n  1033→    PreparedStatement stmt = getStatement(conn, getAccountForUserSQL);\n  1034→    stmt.setString(1, userID);\n  1035→    ResultSet rs = stmt.executeQuery();\n  1036→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1037→    stmt.close();\n  1038→    return accountData;\n  1039→  }\n  1040→\n  1041→  /**\n  1042→   * @see TradeServices#getAccountData(String)\n  1043→   */\n  1044→  public AccountDataBean getAccountData(int accountID) throws Exception {\n  1045→    AccountDataBean accountData = null;\n  1046→    Connection conn = null;\n  1047→    try {\n  1048→\n  1049→      Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", new Integer(accountID));\n  1050→\n  1051→      conn = getConn();\n  1052→      accountData = getAccountData(accountID, conn);\n  1053→      commit(conn);\n  1054→\n  1055→    } catch (Exception e) {\n  1056→      Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1057→      rollBack(conn, e);\n  1058→    } finally {\n  1059→      releaseConn(conn);\n  1060→    }\n  1061→    return accountData;\n  1062→  }\n  1063→\n  1064→  private AccountDataBean getAccountData(int accountID, Connection conn) throws Exception {\n  1065→    PreparedStatement stmt = getStatement(conn, getAccountSQL);\n  1066→    stmt.setInt(1, accountID);\n  1067→    ResultSet rs = stmt.executeQuery();\n  1068→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1069→    stmt.close();\n  1070→    return accountData;\n  1071→  }\n  1072→\n  1073→  private QuoteDataBean getQuoteData(Connection conn, String symbol) throws Exception {\n  1074→    QuoteDataBean quoteData = null;\n  1075→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n  1076→    stmt.setString(1, symbol);\n  1077→    ResultSet rs = stmt.executeQuery();\n  1078→    if (!rs.next()) {\n  1079→      Log.error(\"TradeDirect:getQuoteData -- could not find quote for symbol=\" + symbol);\n  1080→    } else {\n  1081→      quoteData = getQuoteDataFromResultSet(rs);\n  1082→    }\n  1083→    stmt.close();\n  1084→    return quoteData;\n  1085→  }\n  1086→\n  1087→  private HoldingDataBean getHoldingData(int holdingID) throws Exception {\n  1088→    HoldingDataBean holdingData = null;\n  1089→    Connection conn = null;\n  1090→    try {\n  1091→      conn = getConn();\n  1092→      holdingData = getHoldingData(conn, holdingID);\n  1093→      commit(conn);\n  1094→    } catch (Exception e) {\n  1095→      Log.error(\"TradeDirect:getHoldingData -- error getting data\", e);\n  1096→      rollBack(conn, e);\n  1097→    } finally {\n  1098→      releaseConn(conn);\n  1099→    }\n  1100→    return holdingData;\n  1101→  }\n  1102→\n  1103→  private HoldingDataBean getHoldingData(Connection conn, int holdingID) throws Exception {\n  1104→    HoldingDataBean holdingData = null;\n  1105→    PreparedStatement stmt = getStatement(conn, getHoldingSQL);\n  1106→    stmt.setInt(1, holdingID);\n  1107→    ResultSet rs = stmt.executeQuery();\n  1108→    if (!rs.next()) {\n  1109→      // already sold\n  1110→      Log.debug(\"TradeDirect:getHoldingData -- no results -- holdingID=\" + holdingID);\n  1111→    } else {\n  1112→      holdingData = getHoldingDataFromResultSet(rs);\n  1113→    }\n  1114→\n  1115→    stmt.close();\n  1116→    return holdingData;\n  1117→  }\n  1118→\n  1119→  private OrderDataBean getOrderData(Connection conn, int orderID) throws Exception {\n  1120→    OrderDataBean orderData = null;\n  1121→\n  1122→    Log.trace(\"TradeDirect:getOrderData(conn, \" + orderID + \")\");\n  1123→\n  1124→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n  1125→    stmt.setInt(1, orderID);\n  1126→    ResultSet rs = stmt.executeQuery();\n  1127→    if (!rs.next()) {\n  1128→      // already sold\n  1129→      Log.error(\"TradeDirect:getOrderData -- no results for orderID:\" + orderID);\n  1130→    } else {\n  1131→      orderData = getOrderDataFromResultSet(rs);\n  1132→    }\n  1133→    stmt.close();\n  1134→    return orderData;\n  1135→  }\n  1136→\n  1137→  /**\n  1138→   * @see TradeServices#getAccountProfileData(String)\n  1139→   */\n  1140→  @Override\n  1141→  public AccountProfileDataBean getAccountProfileData(String userID) throws Exception {\n  1142→    AccountProfileDataBean accountProfileData = null;\n  1143→    Connection conn = null;\n  1144→\n  1145→    try {\n  1146→\n  1147→      Log.trace(\"TradeDirect:getAccountProfileData - inSession(\" + this.inSession + \")\", userID);\n  1148→\n  1149→\n  1150→      conn = getConn();\n  1151→      accountProfileData = getAccountProfileData(conn, userID);\n  1152→      commit(conn);\n  1153→    } catch (Exception e) {\n  1154→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1155→      rollBack(conn, e);\n  1156→    } finally {\n  1157→      releaseConn(conn);\n  1158→    }\n  1159→    return accountProfileData;\n  1160→  }\n  1161→\n  1162→  private AccountProfileDataBean getAccountProfileData(Connection conn, String userID) throws Exception {\n  1163→    PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1164→    stmt.setString(1, userID);\n  1165→\n  1166→    ResultSet rs = stmt.executeQuery();\n  1167→\n  1168→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1169→    stmt.close();\n  1170→    return accountProfileData;\n  1171→  }\n  1172→\n  1173→  private AccountProfileDataBean getAccountProfileData(Connection conn, Integer accountID) throws Exception {\n  1174→    PreparedStatement stmt = getStatement(conn, getAccountProfileForAccountSQL);\n  1175→    stmt.setInt(1, accountID.intValue());\n  1176→\n  1177→    ResultSet rs = stmt.executeQuery();\n  1178→\n  1179→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1180→    stmt.close();\n  1181→    return accountProfileData;\n  1182→  }\n  1183→\n  1184→  /**\n  1185→   * @see TradeServices#updateAccountProfile(AccountProfileDataBean)\n  1186→   */\n  1187→  @Override\n  1188→  public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception {\n  1189→    AccountProfileDataBean accountProfileData = null;\n  1190→    Connection conn = null;\n  1191→\n  1192→    try {\n  1193→\n  1194→      Log.trace(\"TradeDirect:updateAccountProfileData - inSession(\" + this.inSession + \")\", profileData.getUserID());\n  1195→\n  1196→      conn = getConn();\n  1197→      updateAccountProfile(conn, profileData);\n  1198→\n  1199→      accountProfileData = getAccountProfileData(conn, profileData.getUserID());\n  1200→      commit(conn);\n  1201→    } catch (Exception e) {\n  1202→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1203→      rollBack(conn, e);\n  1204→    } finally {\n  1205→      releaseConn(conn);\n  1206→    }\n  1207→    return accountProfileData;\n  1208→  }\n  1209→\n  1210→  private void creditAccountBalance(Connection conn, AccountDataBean accountData, BigDecimal credit) throws Exception {\n  1211→    PreparedStatement stmt = getStatement(conn, creditAccountBalanceSQL);\n  1212→\n  1213→    stmt.setBigDecimal(1, credit);\n  1214→    stmt.setInt(2, accountData.getAccountID().intValue());\n  1215→\n  1216→    stmt.executeUpdate();\n  1217→    stmt.close();\n  1218→\n  1219→  }\n  1220→\n  1221→  // Set Timestamp to zero to denote sell is inflight\n  1222→  // UPDATE -- could add a \"status\" attribute to holding\n  1223→  private void updateHoldingStatus(Connection conn, Integer holdingID, String symbol) throws Exception {\n  1224→    Timestamp ts = new Timestamp(0);\n  1225→    PreparedStatement stmt = getStatement(conn, \"update holdingejb set purchasedate= ? where holdingid = ?\");\n  1226→\n  1227→    stmt.setTimestamp(1, ts);\n  1228→    stmt.setInt(2, holdingID.intValue());\n  1229→    stmt.executeUpdate();\n  1230→    stmt.close();\n  1231→  }\n  1232→\n  1233→  private void updateOrderStatus(Connection conn, Integer orderID, String status) throws Exception {\n  1234→    PreparedStatement stmt = getStatement(conn, updateOrderStatusSQL);\n  1235→\n  1236→    stmt.setString(1, status);\n  1237→    stmt.setTimestamp(2, new Timestamp(System.currentTimeMillis()));\n  1238→    stmt.setInt(3, orderID.intValue());\n  1239→    stmt.executeUpdate();\n  1240→    stmt.close();\n  1241→  }\n  1242→\n  1243→  private void updateOrderHolding(Connection conn, int orderID, int holdingID) throws Exception {\n  1244→    PreparedStatement stmt = getStatement(conn, updateOrderHoldingSQL);\n  1245→\n  1246→    stmt.setInt(1, holdingID);\n  1247→    stmt.setInt(2, orderID);\n  1248→    stmt.executeUpdate();\n  1249→    stmt.close();\n  1250→  }\n  1251→\n  1252→  private void updateAccountProfile(Connection conn, AccountProfileDataBean profileData) throws Exception {\n  1253→    PreparedStatement stmt = getStatement(conn, updateAccountProfileSQL);\n  1254→\n  1255→    stmt.setString(1, profileData.getPassword());\n  1256→    stmt.setString(2, profileData.getFullName());\n  1257→    stmt.setString(3, profileData.getAddress());\n  1258→    stmt.setString(4, profileData.getEmail());\n  1259→    stmt.setString(5, profileData.getCreditCard());\n  1260→    stmt.setString(6, profileData.getUserID());\n  1261→\n  1262→    stmt.executeUpdate();\n  1263→    stmt.close();\n  1264→  }\n  1265→\n  1266→  @Override\n  1267→  public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded) throws Exception {\n  1268→    return updateQuotePriceVolumeInt(symbol, changeFactor, sharesTraded, TradeConfig.getPublishQuotePriceChange());\n  1269→  }\n  1270→\n  1271→  /**\n  1272→   * Update a quote's price and volume\n  1273→   *\n  1274→   * @param symbol\n  1275→   *            The PK of the quote\n  1276→   * @param changeFactor\n  1277→   *            the percent to change the old price by (between 50% and 150%)\n  1278→   * @param sharedTraded\n  1279→   *            the ammount to add to the current volume\n  1280→   * @param publishQuotePriceChange\n  1281→   *            used by the PingJDBCWrite Primitive to ensure no JMS is used,\n  1282→   *            should be true for all normal calls to this API\n  1283→   */\n  1284→  public QuoteDataBean updateQuotePriceVolumeInt(String symbol, BigDecimal changeFactor, double sharesTraded, boolean publishQuotePriceChange)\n  1285→      throws Exception {\n  1286→\n  1287→    if (TradeConfig.getUpdateQuotePrices() == false) {\n  1288→      return new QuoteDataBean();\n  1289→    }\n  1290→\n  1291→    QuoteDataBean quoteData = null;\n  1292→    Connection conn = null;\n  1293→\n  1294→    try {\n  1295→      Log.trace(\"TradeDirect:updateQuotePriceVolume - inSession(\" + this.inSession + \")\", symbol, changeFactor, new Double(sharesTraded));\n  1296→\n  1297→      conn = getConn();\n  1298→\n  1299→      quoteData = getQuoteForUpdate(conn, symbol);\n  1300→      BigDecimal oldPrice = quoteData.getPrice();\n  1301→      BigDecimal openPrice = quoteData.getOpen();\n  1302→\n  1303→      double newVolume = quoteData.getVolume() + sharesTraded;\n  1304→\n  1305→      if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n  1306→        changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n  1307→      } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n  1308→        changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n  1309→      }\n  1310→\n  1311→      BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n  1312→      double change = newPrice.subtract(openPrice).doubleValue();\n  1313→\n  1314→      updateQuotePriceVolume(conn, quoteData.getSymbol(), newPrice, newVolume, change);\n  1315→      quoteData = getQuote(conn, symbol);\n  1316→\n  1317→      commit(conn);\n  1318→\n  1319→      if (publishQuotePriceChange) {\n  1320→        publishQuotePriceChange(quoteData, oldPrice, changeFactor, sharesTraded);\n  1321→      }\n  1322→\n  1323→      recentQuotePriceChangeList.add(quoteData);\n  1324→\n  1325→    } catch (Exception e) {\n  1326→      Log.error(\"TradeDirect:updateQuotePriceVolume -- error updating quote price/volume for symbol:\" + symbol);\n  1327→      rollBack(conn, e);\n  1328→      throw e;\n  1329→    } finally {\n  1330→      releaseConn(conn);\n  1331→    }\n  1332→    return quoteData;\n  1333→  }\n  1334→\n  1335→  private void updateQuotePriceVolume(Connection conn, String symbol, BigDecimal newPrice, double newVolume, double change) throws Exception {\n  1336→\n  1337→    PreparedStatement stmt = getStatement(conn, updateQuotePriceVolumeSQL);\n  1338→\n  1339→    stmt.setBigDecimal(1, newPrice);\n  1340→    stmt.setDouble(2, change);\n  1341→    stmt.setDouble(3, newVolume);\n  1342→    stmt.setString(4, symbol);\n  1343→\n  1344→    stmt.executeUpdate();\n  1345→    stmt.close();\n  1346→  }\n  1347→\n  1348→  private void publishQuotePriceChange(QuoteDataBean quoteData, BigDecimal oldPrice, BigDecimal changeFactor, double sharesTraded) throws Exception {\n  1349→\n  1350→    Log.trace(\"TradeDirect:publishQuotePrice PUBLISHING to MDB quoteData = \" + quoteData);\n  1351→\n  1352→    // MIGRATION: JMS Topic -> Messaging via MessageProducerService\n  1353→    // Original: Create JMSContext, TextMessage, set properties, send to topic\n  1354→    // Spring: Simply call messageProducer.publishQuotePriceChange()\n  1355→    messageProducer.publishQuotePriceChange(\n  1356→        quoteData.getSymbol(),\n  1357→        quoteData.getCompanyName(),\n  1358→        quoteData.getPrice(),\n  1359→        oldPrice,\n  1360→        quoteData.getOpen(),\n  1361→        quoteData.getLow(),\n  1362→        quoteData.getHigh(),\n  1363→        quoteData.getVolume(),\n  1364→        changeFactor,\n  1365→        sharesTraded\n  1366→    );\n  1367→  }\n  1368→\n  1369→  /**\n  1370→   * @see TradeServices#login(String, String)\n  1371→   */\n  1372→\n  1373→  @Override\n  1374→  public AccountDataBean login(String userID, String password) throws Exception {\n  1375→\n  1376→    AccountDataBean accountData = null;\n  1377→    Connection conn = null;\n  1378→    try {\n  1379→      Log.trace(\"TradeDirect:login - inSession(\" + this.inSession + \")\", userID, password);\n  1380→\n  1381→      conn = getConn();\n  1382→      PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1383→      stmt.setString(1, userID);\n  1384→\n  1385→      ResultSet rs = stmt.executeQuery();\n  1386→      if (!rs.next()) {\n  1387→        Log.error(\"TradeDirect:login -- failure to find account for\" + userID);\n  1388→        // MIGRATION: javax.ejb.FinderException -> RuntimeException (no EJB in Spring)\n  1389→        throw new RuntimeException(\"Cannot find account for \" + userID);\n  1390→      }\n  1391→\n  1392→      String pw = rs.getString(\"passwd\");\n  1393→      stmt.close();\n  1394→      if ((pw == null) || (pw.equals(password) == false)) {\n  1395→        String error = \"TradeDirect:Login failure for user: \" + userID + \"\\n\\tIncorrect password-->\" + userID + \":\" + password;\n  1396→        Log.error(error);\n  1397→        throw new Exception(error);\n  1398→      }\n  1399→\n  1400→      stmt = getStatement(conn, loginSQL);\n  1401→      stmt.setTimestamp(1, new Timestamp(System.currentTimeMillis()));\n  1402→      stmt.setString(2, userID);\n  1403→\n  1404→      stmt.executeUpdate();\n  1405→      stmt.close();\n  1406→\n  1407→      stmt = getStatement(conn, getAccountForUserSQL);\n  1408→      stmt.setString(1, userID);\n  1409→      rs = stmt.executeQuery();\n  1410→\n  1411→      accountData = getAccountDataFromResultSet(rs);\n  1412→\n  1413→      stmt.close();\n  1414→\n  1415→      commit(conn);\n  1416→    } catch (Exception e) {\n  1417→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n  1418→      rollBack(conn, e);\n  1419→    } finally {\n  1420→      releaseConn(conn);\n  1421→    }\n  1422→    return accountData;\n  1423→\n  1424→    /*\n  1425→     * setLastLogin( new Timestamp(System.currentTimeMillis()) );\n  1426→     * setLoginCount( getLoginCount() + 1 );\n  1427→     */\n  1428→  }\n  1429→\n  1430→  /**\n  1431→   * @see TradeServices#logout(String)\n  1432→   */\n  1433→  @Override\n  1434→  public void logout(String userID) throws Exception {\n  1435→    Log.trace(\"TradeDirect:logout - inSession(\" + this.inSession + \")\", userID);\n  1436→\n  1437→    Connection conn = null;\n  1438→    try {\n  1439→      conn = getConn();\n  1440→      PreparedStatement stmt = getStatement(conn, logoutSQL);\n  1441→      stmt.setString(1, userID);\n  1442→      stmt.executeUpdate();\n  1443→      stmt.close();\n  1444→\n  1445→      commit(conn);\n  1446→    } catch (Exception e) {\n  1447→      Log.error(\"TradeDirect:logout -- error logging out user\", e);\n  1448→      rollBack(conn, e);\n  1449→    } finally {\n  1450→      releaseConn(conn);\n  1451→    }\n  1452→  }\n  1453→\n  1454→  /**\n  1455→   * @see TradeServices#register(String, String, String, String, String,\n  1456→   *      String, BigDecimal, boolean)\n  1457→   */\n  1458→\n  1459→  @Override\n  1460→  public AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance)\n  1461→      throws Exception {\n  1462→\n  1463→    AccountDataBean accountData = null;\n  1464→    Connection conn = null;\n  1465→    try {\n  1466→      Log.trace(\"TradeDirect:register - inSession(\" + this.inSession + \")\");\n  1467→\n  1468→      conn = getConn();\n  1469→      PreparedStatement stmt = getStatement(conn, createAccountSQL);\n  1470→\n  1471→      Integer accountID = KeySequenceDirect.getNextID(conn, \"account\", inSession, getInGlobalTxn());\n  1472→      BigDecimal balance = openBalance;\n  1473→      Timestamp creationDate = new Timestamp(System.currentTimeMillis());\n  1474→      Timestamp lastLogin = creationDate;\n  1475→      int loginCount = 0;\n  1476→      int logoutCount = 0;\n  1477→\n  1478→      stmt.setInt(1, accountID.intValue());\n  1479→      stmt.setTimestamp(2, creationDate);\n  1480→      stmt.setBigDecimal(3, openBalance);\n  1481→      stmt.setBigDecimal(4, balance);\n  1482→      stmt.setTimestamp(5, lastLogin);\n  1483→      stmt.setInt(6, loginCount);\n  1484→      stmt.setInt(7, logoutCount);\n  1485→      stmt.setString(8, userID);\n  1486→      stmt.executeUpdate();\n  1487→      stmt.close();\n  1488→\n  1489→      stmt = getStatement(conn, createAccountProfileSQL);\n  1490→      stmt.setString(1, userID);\n  1491→      stmt.setString(2, password);\n  1492→      stmt.setString(3, fullname);\n  1493→      stmt.setString(4, address);\n  1494→      stmt.setString(5, email);\n  1495→      stmt.setString(6, creditcard);\n  1496→      stmt.executeUpdate();\n  1497→      stmt.close();\n  1498→\n  1499→      commit(conn);\n  1500→\n  1501→      accountData = new AccountDataBean(accountID, loginCount, logoutCount, lastLogin, creationDate, balance, openBalance, userID);\n  1502→\n  1503→    } catch (Exception e) {\n  1504→      Log.error(\"TradeDirect:register -- error registering new user\", e);\n  1505→    } finally {\n  1506→      releaseConn(conn);\n  1507→    }\n  1508→    return accountData;\n  1509→  }\n  1510→\n  1511→  private AccountDataBean getAccountDataFromResultSet(ResultSet rs) throws Exception {\n  1512→    AccountDataBean accountData = null;\n  1513→\n  1514→    if (!rs.next()) {\n  1515→      Log.error(\"TradeDirect:getAccountDataFromResultSet -- cannot find account data\");\n  1516→    } else {\n  1517→      accountData = new AccountDataBean(new Integer(rs.getInt(\"accountID\")), rs.getInt(\"loginCount\"), rs.getInt(\"logoutCount\"),\n  1518→          rs.getTimestamp(\"lastLogin\"), rs.getTimestamp(\"creationDate\"), rs.getBigDecimal(\"balance\"), rs.getBigDecimal(\"openBalance\"),\n  1519→          rs.getString(\"profile_userID\"));\n  1520→    }\n  1521→    return accountData;\n  1522→  }\n  1523→\n  1524→  private AccountProfileDataBean getAccountProfileDataFromResultSet(ResultSet rs) throws Exception {\n  1525→    AccountProfileDataBean accountProfileData = null;\n  1526→\n  1527→    if (!rs.next()) {\n  1528→      Log.error(\"TradeDirect:getAccountProfileDataFromResultSet -- cannot find accountprofile data\");\n  1529→    } else {\n  1530→      accountProfileData = new AccountProfileDataBean(rs.getString(\"userID\"), rs.getString(\"passwd\"), rs.getString(\"fullName\"), rs.getString(\"address\"),\n  1531→          rs.getString(\"email\"), rs.getString(\"creditCard\"));\n  1532→    }\n  1533→\n  1534→    return accountProfileData;\n  1535→  }\n  1536→\n  1537→  private HoldingDataBean getHoldingDataFromResultSet(ResultSet rs) throws Exception {\n  1538→    HoldingDataBean holdingData = null;\n  1539→\n  1540→    holdingData = new HoldingDataBean(new Integer(rs.getInt(\"holdingID\")), rs.getDouble(\"quantity\"), rs.getBigDecimal(\"purchasePrice\"),\n  1541→        rs.getTimestamp(\"purchaseDate\"), rs.getString(\"quote_symbol\"));\n  1542→    return holdingData;\n  1543→  }\n  1544→\n  1545→  private QuoteDataBean getQuoteDataFromResultSet(ResultSet rs) throws Exception {\n  1546→    QuoteDataBean quoteData = null;\n  1547→\n  1548→    quoteData = new QuoteDataBean(rs.getString(\"symbol\"), rs.getString(\"companyName\"), rs.getDouble(\"volume\"), rs.getBigDecimal(\"price\"),\n  1549→        rs.getBigDecimal(\"open1\"), rs.getBigDecimal(\"low\"), rs.getBigDecimal(\"high\"), rs.getDouble(\"change1\"));\n  1550→    return quoteData;\n  1551→  }\n  1552→\n  1553→  private OrderDataBean getOrderDataFromResultSet(ResultSet rs) throws Exception {\n  1554→    OrderDataBean orderData = null;\n  1555→\n  1556→    orderData = new OrderDataBean(new Integer(rs.getInt(\"orderID\")), rs.getString(\"orderType\"), rs.getString(\"orderStatus\"), rs.getTimestamp(\"openDate\"),\n  1557→        rs.getTimestamp(\"completionDate\"), rs.getDouble(\"quantity\"), rs.getBigDecimal(\"price\"), rs.getBigDecimal(\"orderFee\"),\n  1558→        rs.getString(\"quote_symbol\"));\n  1559→    return orderData;\n  1560→  }\n  1561→\n  1562→  public boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n  1563→    // Clear MDB Statistics\n  1564→    MDBStats.getInstance().reset();\n  1565→\n  1566→    Connection conn = null;\n  1567→    boolean success = false;\n  1568→    try {\n  1569→\n  1570→      Log.trace(\"TradeDirect:recreateDBTables\");\n  1571→\n  1572→      conn = getConn();\n  1573→      Statement stmt = conn.createStatement();\n  1574→      int bufferLength = sqlBuffer.length;\n  1575→      for (int i = 0; i < bufferLength; i++) {\n  1576→        try {\n  1577→          stmt.executeUpdate((String) sqlBuffer[i]);\n  1578→          // commit(conn);\n  1579→        } catch (SQLException ex) {\n  1580→          // Ignore DROP statements as tables won't always exist.\n  1581→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n  1582→            Log.error(\"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i], ex);\n  1583→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i] + \"</I> . Check log for details.</BR>\");\n  1584→          }\n  1585→        }\n  1586→      }\n  1587→      stmt.close();\n  1588→      commit(conn);\n  1589→      success = true;\n  1590→    } catch (Exception e) {\n  1591→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n  1592→    } finally {\n  1593→      releaseConn(conn);\n  1594→    }\n  1595→    return success;\n  1596→  }\n  1597→\n  1598→  ;\n  1599→\n  1600→\n  1601→\n  1602→  private void releaseConn(Connection conn) throws Exception {\n  1603→    try {\n  1604→      if (conn != null) {\n  1605→        conn.close();\n  1606→        if (Log.doTrace()) {\n  1607→          synchronized (lock) {\n  1608→            connCount--;\n  1609→          }\n  1610→          Log.trace(\"TradeDirect:releaseConn -- connection closed, connCount=\" + connCount);\n  1611→        }\n  1612→      }\n  1613→    } catch (Exception e) {\n  1614→      Log.error(\"TradeDirect:releaseConnection -- failed to close connection\", e);\n  1615→    }\n  1616→  }\n  1617→\n  1618→\n  1619→  /*\n  1620→   * Allocate a new connection to the datasource\n  1621→   */\n  1622→  private static int connCount = 0;\n  1623→\n  1624→  private static Integer lock = new Integer(0);\n  1625→\n  1626→  private Connection getConn() throws Exception {\n  1627→\n  1628→    Connection conn = datasource.getConnection();\n  1629→\n  1630→    if (!this.inGlobalTxn) {\n  1631→      conn.setAutoCommit(false);\n  1632→    }\n  1633→    if (Log.doTrace()) {\n  1634→      synchronized (lock) {\n  1635→        connCount++;\n  1636→      }\n  1637→      Log.trace(\"TradeDirect:getConn -- new connection allocated, IsolationLevel=\" + conn.getTransactionIsolation() + \" connectionCount = \" + connCount);\n  1638→    }\n  1639→\n  1640→    return conn;\n  1641→  }\n  1642→\n  1643→  public Connection getConnPublic() throws Exception {\n  1644→    return getConn();\n  1645→  }\n  1646→\n  1647→  /*\n  1648→   * Commit the provided connection if not under Global Transaction scope -\n  1649→   * conn.commit() is not allowed in a global transaction. the txn manager\n  1650→   * will perform the commit\n  1651→   */\n  1652→  private void commit(Connection conn) throws Exception {\n  1653→    if (!inSession) {\n  1654→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1655→        conn.commit();\n  1656→      }\n  1657→    }\n  1658→  }\n  1659→\n  1660→  /*\n  1661→   * Rollback the statement for the given connection\n  1662→   */\n  1663→  private void rollBack(Connection conn, Exception e) throws Exception {\n  1664→    if (!inSession) {\n  1665→      Log.log(\"TradeDirect:rollBack -- rolling back conn due to previously caught exception -- inGlobalTxn=\" + getInGlobalTxn());\n  1666→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1667→        conn.rollback();\n  1668→      } else {\n  1669→        throw e; // Throw the exception\n  1670→        // so the Global txn manager will rollBack\n  1671→      }\n  1672→    }\n  1673→  }\n  1674→\n  1675→  /*\n  1676→   * Allocate a new prepared statment for this connection\n  1677→   */\n  1678→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n  1679→    return conn.prepareStatement(sql);\n  1680→  }\n  1681→\n  1682→  private PreparedStatement getStatement(Connection conn, String sql, int type, int concurrency) throws Exception {\n  1683→    return conn.prepareStatement(sql, type, concurrency);\n  1684→  }\n  1685→\n  1686→  private static final String createQuoteSQL = \"insert into quoteejb \" + \"( symbol, companyName, volume, price, open1, low, high, change1 ) \"\n  1687→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1688→\n  1689→  private static final String createAccountSQL = \"insert into accountejb \"\n  1690→      + \"( accountid, creationDate, openBalance, balance, lastLogin, loginCount, logoutCount, profile_userid) \"\n  1691→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1692→\n  1693→  private static final String createAccountProfileSQL = \"insert into accountprofileejb \" + \"( userid, passwd, fullname, address, email, creditcard ) \"\n  1694→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1695→\n  1696→  private static final String createHoldingSQL = \"insert into holdingejb \"\n  1697→      + \"( holdingid, purchaseDate, purchasePrice, quantity, quote_symbol, account_accountid ) \" + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ? )\";\n  1698→\n  1699→  private static final String createOrderSQL = \"insert into orderejb \"\n  1700→      + \"( orderid, ordertype, orderstatus, opendate, quantity, price, orderfee, account_accountid,  holding_holdingid, quote_symbol) \"\n  1701→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  , ? , ? , ?)\";\n  1702→\n  1703→  private static final String removeHoldingSQL = \"delete from holdingejb where holdingid = ?\";\n  1704→\n  1705→  private static final String removeHoldingFromOrderSQL = \"update orderejb set holding_holdingid=null where holding_holdingid = ?\";\n  1706→\n  1707→  private static final String updateAccountProfileSQL = \"update accountprofileejb set \" + \"passwd = ?, fullname = ?, address = ?, email = ?, creditcard = ? \"\n  1708→      + \"where userid = (select profile_userid from accountejb a \" + \"where a.profile_userid=?)\";\n  1709→\n  1710→  private static final String loginSQL = \"update accountejb set lastLogin=?, logincount=logincount+1 \" + \"where profile_userid=?\";\n  1711→\n  1712→  private static final String logoutSQL = \"update accountejb set logoutcount=logoutcount+1 \" + \"where profile_userid=?\";\n  1713→\n  1714→  private static final String getAccountSQL = \"select * from accountejb a where a.accountid = ?\";\n  1715→\n  1716→  private static final String getAccountProfileSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1717→      + \"(select profile_userid from accountejb a where a.profile_userid=?)\";\n  1718→\n  1719→  private static final String getAccountProfileForAccountSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1720→      + \"(select profile_userid from accountejb a where a.accountid=?)\";\n  1721→\n  1722→  private static final String getAccountForUserSQL = \"select * from accountejb a where a.profile_userid = \"\n  1723→      + \"( select userid from accountprofileejb ap where ap.userid = ?)\";\n  1724→\n  1725→  private static final String getHoldingSQL = \"select * from holdingejb h where h.holdingid = ?\";\n  1726→\n  1727→  private static final String getHoldingsForUserSQL = \"select * from holdingejb h where h.account_accountid = \"\n  1728→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1729→\n  1730→  private static final String getOrderSQL = \"select * from orderejb o where o.orderid = ?\";\n  1731→\n  1732→  private static final String getOrdersByUserSQL = \"select * from orderejb o where o.account_accountid = \"\n  1733→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1734→\n  1735→  private static final String getClosedOrdersSQL = \"select * from orderejb o \" + \"where o.orderstatus = 'closed' AND o.account_accountid = \"\n  1736→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1737→\n  1738→  private static final String getQuoteSQL = \"select * from quoteejb q where q.symbol=?\";\n  1739→\n  1740→  private static final String getAllQuotesSQL = \"select * from quoteejb q\";\n  1741→\n  1742→  private static final String getQuoteForUpdateSQL = \"select * from quoteejb q where q.symbol=? For Update\";\n  1743→\n  1744→  private static final String getTSIAQuotesOrderByChangeSQL = \"select * from quoteejb q order by q.change1\";\n  1745→\n  1746→  private static final String getTSIASQL = \"select SUM(price)/count(*) as TSIA from quoteejb q \";\n  1747→\n  1748→  private static final String getOpenTSIASQL = \"select SUM(open1)/count(*) as openTSIA from quoteejb q \";\n  1749→\n  1750→  private static final String getTSIATotalVolumeSQL = \"select SUM(volume) as totalVolume from quoteejb q \";\n  1751→\n  1752→  private static final String creditAccountBalanceSQL = \"update accountejb set \" + \"balance = balance + ? \" + \"where accountid = ?\";\n  1753→\n  1754→  private static final String updateOrderStatusSQL = \"update orderejb set \" + \"orderstatus = ?, completiondate = ? \" + \"where orderid = ?\";\n  1755→\n  1756→  private static final String updateOrderHoldingSQL = \"update orderejb set \" + \"holding_holdingID = ? \" + \"where orderid = ?\";\n  1757→\n  1758→  private static final String updateQuotePriceVolumeSQL = \"update quoteejb set \" + \"price = ?, change1 = ?, volume = ? \" + \"where symbol = ?\";\n  1759→\n  1760→  /**\n  1761→   * Gets the inGlobalTxn\n  1762→   *\n  1763→   * @return Returns a boolean\n  1764→   */\n  1765→  private boolean getInGlobalTxn() {\n  1766→    return inGlobalTxn;\n  1767→  }\n  1768→\n  1769→  /**\n  1770→   * Sets the inGlobalTxn\n  1771→   *\n  1772→   * @param inGlobalTxn\n  1773→   *            The inGlobalTxn to set\n  1774→   */\n  1775→  private void setInGlobalTxn(boolean inGlobalTxn) {\n  1776→    this.inGlobalTxn = inGlobalTxn;\n  1777→  }\n  1778→\n  1779→  public void setInSession(boolean inSession) {\n  1780→    this.inSession = inSession;\n  1781→  }\n  1782→\n  1783→  @Override\n  1784→  public int getImpl() {\n  1785→    return TradeConfig.DIRECT;\n  1786→  }\n  1787→\n  1788→\n  1789→\n  1790→  @Override\n  1791→  public QuoteDataBean pingTwoPhase(String symbol) {\n  1792→    throw new UnsupportedOperationException();\n  1793→  }\n  1794→\n  1795→\n  1796→\n  1797→  @Override\n  1798→  public double investmentReturn(double rnd1, double rnd2) {\n  1799→    throw new UnsupportedOperationException();\n  1800→  }\n  1801→}\n  1802→"}]},"parent_tool_use_id":"toolu_bdrk_01SqhjQB4kvuNkenUVvUyqh1","session_id":"b6271ebd-2120-4e7f-8b1b-494582b368b5","uuid":"f5c96330-c5ca-41ed-b485-2c89143ba7b3"}
