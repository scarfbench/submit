 false);\n    77→    }\n    78→\n    79→    return orderdata;\n    80→  }\n    81→\n    82→  @Override\n    83→  @NotNull\n    84→  public OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception {\n    85→    tradeDirect.setInSession(true);\n    86→    OrderDataBean orderdata =  tradeDirect.sell(userID, holdingID, orderProcessingMode);\n    87→\n    88→    if (orderProcessingMode == TradeConfig.ASYNCH) {\n    89→      this.completeOrderAsync(orderdata.getOrderID(), false);\n    90→    }\n    91→    return orderdata;\n    92→\n    93→  }\n    94→\n    95→  @Override\n    96→  public void queueOrder(Integer orderID, boolean twoPhase) throws Exception {\n    97→    tradeDirect.setInSession(true);\n    98→    tradeDirect.queueOrder(orderID, twoPhase);\n    99→\n   100→  }\n   101→\n   102→  @Override\n   103→  public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   104→    tradeDirect.setInSession(true);\n   105→    return tradeDirect.completeOrder(orderID, twoPhase);\n   106→  }\n   107→\n   108→  @Override\n   109→  public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   110→    asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   111→    return null;\n   112→  }\n   113→\n   114→  @Override\n   115→  public void cancelOrder(Integer orderID, boolean twoPhase) throws Exception {\n   116→    tradeDirect.setInSession(true);\n   117→    tradeDirect.cancelOrder(orderID, twoPhase);\n   118→\n   119→  }\n   120→\n   121→  @Override\n   122→  public void orderCompleted(String userID, Integer orderID) throws Exception {\n   123→    tradeDirect.setInSession(true);\n   124→    tradeDirect.orderCompleted(userID, orderID);\n   125→\n   126→  }\n   127→\n   128→  @Override\n   129→  public Collection<?> getOrders(String userID) throws Exception {\n   130→    tradeDirect.setInSession(true);\n   131→    return tradeDirect.getOrders(userID);\n   132→  }\n   133→\n   134→  @Override\n   135→  public Collection<?> getClosedOrders(String userID) throws Exception {\n   136→    tradeDirect.setInSession(true);\n   137→    return tradeDirect.getClosedOrders(userID);\n   138→  }\n   139→\n   140→  @Override\n   141→  public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception {\n   142→    tradeDirect.setInSession(true);\n   143→    return tradeDirect.createQuote(symbol, companyName, price);\n   144→  }\n   145→\n   146→  @Override\n   147→  public QuoteDataBean getQuote(String symbol) throws Exception {\n   148→    tradeDirect.setInSession(true);\n   149→    return tradeDirect.getQuote(symbol);\n   150→  }\n   151→\n   152→  @Override\n   153→  public Collection<?> getAllQuotes() throws Exception {\n   154→    tradeDirect.setInSession(true);\n   155→    return tradeDirect.getAllQuotes();\n   156→  }\n   157→\n   158→  @Override\n   159→  public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal newPrice, double sharesTraded)\n   160→      throws Exception {\n   161→    tradeDirect.setInSession(true);\n   162→    return tradeDirect.updateQuotePriceVolume(symbol, newPrice, sharesTraded);\n   163→  }\n   164→\n   165→  @Override\n   166→  public Collection<HoldingDataBean> getHoldings(String userID) throws Exception {\n   167→    tradeDirect.setInSession(true);\n   168→    return tradeDirect.getHoldings(userID);\n   169→  }\n   170→\n   171→  @Override\n   172→  public HoldingDataBean getHolding(Integer holdingID) throws Exception {\n   173→    tradeDirect.setInSession(true);\n   174→    return tradeDirect.getHolding(holdingID);\n   175→  }\n   176→\n   177→  @Override\n   178→  public AccountDataBean getAccountData(String userID) throws Exception {\n   179→    tradeDirect.setInSession(true);\n   180→    return tradeDirect.getAccountData(userID);\n   181→  }\n   182→\n   183→  @Override\n   184→  public AccountProfileDataBean getAccountProfileData(String userID) throws Exception {\n   185→    tradeDirect.setInSession(true);\n   186→    return tradeDirect.getAccountProfileData(userID);\n   187→  }\n   188→\n   189→  @Override\n   190→  public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception {\n   191→    tradeDirect.setInSession(true);\n   192→    return tradeDirect.updateAccountProfile(profileData);\n   193→  }\n   194→\n   195→  @Override\n   196→  public AccountDataBean login(String userID, String password) throws Exception {\n   197→    tradeDirect.setInSession(true);\n   198→    return tradeDirect.login(userID, password);\n   199→  }\n   200→\n   201→  @Override\n   202→  public void logout(String userID) throws Exception {\n   203→    tradeDirect.setInSession(true);\n   204→    tradeDirect.logout(userID);\n   205→  }\n   206→\n   207→  @Override\n   208→  public AccountDataBean register(String userID, String password, String fullname, String address, String email,\n   209→      String creditcard, BigDecimal openBalance) throws Exception {\n   210→    tradeDirect.setInSession(true);\n   211→    return tradeDirect.register(userID, password, fullname, address, email, creditcard, openBalance);\n   212→  }\n   213→\n   214→  @Override\n   215→  public QuoteDataBean pingTwoPhase(String symbol) throws Exception {\n   216→    throw new UnsupportedOperationException();\n   217→  }\n   218→\n   219→  @Override\n   220→  public double investmentReturn(double rnd1, double rnd2) throws Exception {\n   221→    throw new UnsupportedOperationException();\n   222→  }\n   223→\n   224→\n   225→  @Override\n   226→  public void setInSession(boolean inSession) {\n   227→    throw new UnsupportedOperationException(\"DirectSLSBBean::setInGlobalTxn not supported\");\n   228→  }\n   229→}\n   230→"}]},"parent_tool_use_id":"toolu_bdrk_014E5cqqH4NQFf1TiQASdPng","session_id":"0a2ab8cf-d9b3-4fb3-875c-ac24a464972f","uuid":"2c61fb17-3cd7-4de3-b475-72952e78dce4"}
