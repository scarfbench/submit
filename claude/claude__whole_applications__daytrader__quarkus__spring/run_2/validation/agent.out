kens":6,"cache_creation_input_tokens":17894,"cache_read_input_tokens":12512,"cache_creation":{"ephemeral_5m_input_tokens":17894,"ephemeral_1h_input_tokens":0},"output_tokens":12982},"context_management":null},"parent_tool_use_id":"toolu_bdrk_014E5cqqH4NQFf1TiQASdPng","session_id":"0a2ab8cf-d9b3-4fb3-875c-ac24a464972f","uuid":"e367786c-949d-40d4-a73a-92b904a07d31"}
