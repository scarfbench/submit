tus":"pending","activeForm":"Deleting old Quarkus test files"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":10137,"cache_read_input_tokens":78085,"cache_creation":{"ephemeral_5m_input_tokens":10137,"ephemeral_1h_input_tokens":0},"output_tokens":605},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01UWVVzdzc77xZKiKvHCX5Ld","session_id":"0a2ab8cf-d9b3-4fb3-875c-ac24a464972f","uuid":"d438addc-cd9e-4d8b-9ecc-091e4f195b5a"}
