anges in CHANGELOG.md"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1771,"cache_read_input_tokens":129163,"cache_creation":{"ephemeral_5m_input_tokens":1771,"ephemeral_1h_input_tokens":0},"output_tokens":557},"context_management":null},"parent_tool_use_id":null,"session_id":"887ed637-45f4-4598-acb3-9e086d9e5f12","uuid":"8ebb4923-4d9e-4bcb-bd11-eda5c785edfd"}
