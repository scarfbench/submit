artifactId>quarkus-messaging-kafka</artifactId>\n    89→    </dependency>\n    90→    <dependency>\n    91→      <groupId>io.quarkus</groupId>\n    92→      <artifactId>quarkus-resteasy-jackson</artifactId>\n    93→    </dependency>\n    94→    <dependency>\n    95→      <groupId>io.quarkus</groupId>\n    96→      <artifactId>quarkus-resteasy-mutiny</artifactId>\n    97→    </dependency>\n    98→    <dependency>\n    99→      <groupId>io.quarkus</groupId>\n   100→      <artifactId>quarkus-resteasy-qute</artifactId>\n   101→    </dependency>\n   102→    <dependency>\n   103→      <groupId>io.quarkus</groupId>\n   104→      <artifactId>quarkus-smallrye-context-propagation</artifactId>\n   105→    </dependency>\n   106→    <dependency>\n   107→      <groupId>io.quarkus</groupId>\n   108→      <artifactId>quarkus-vertx</artifactId>\n   109→    </dependency>\n   110→    <!-- Testing -->\n   111→    <dependency>\n   112→      <groupId>io.quarkus</groupId>\n   113→      <artifactId>quarkus-junit5</artifactId>\n   114→      <scope>test</scope>\n   115→    </dependency>\n   116→    <dependency>\n   117→      <groupId>io.quarkus</groupId>\n   118→      <artifactId>quarkus-junit5-mockito</artifactId>\n   119→      <scope>test</scope>\n   120→    </dependency>\n   121→    <dependency>\n   122→      <groupId>io.rest-assured</groupId>\n   123→      <artifactId>rest-assured</artifactId>\n   124→      <scope>test</scope>\n   125→    </dependency>\n   126→    <dependency>\n   127→      <groupId>io.quarkus</groupId>\n   128→      <artifactId>quarkus-jdbc-h2</artifactId>\n   129→    </dependency>\n   130→    <dependency>\n   131→      <groupId>org.awaitility</groupId>\n   132→      <artifactId>awaitility</artifactId>\n   133→      <version>4.0.3</version>\n   134→      <scope>test</scope>\n   135→    </dependency>\n   136→    <dependency>\n   137→      <groupId>io.quarkus</groupId>\n   138→      <artifactId>quarkus-jacoco</artifactId>\n   139→      <scope>test</scope>\n   140→    </dependency>\n   141→    <dependency>\n   142→  <groupId>at.yawk.lz4</groupId>\n   143→  <artifactId>lz4-java</artifactId>\n   144→</dependency>\n   145→  </dependencies>\n   146→  <build>\n   147→    <plugins>\n   148→      <plugin>\n   149→        <groupId>io.quarkus</groupId>\n   150→        <artifactId>quarkus-maven-plugin</artifactId>\n   151→        <version>${quarkus-plugin.version}</version>\n   152→        <extensions>true</extensions>\n   153→        <executions>\n   154→          <execution>\n   155→            <goals>\n   156→              <goal>build</goal>\n   157→              <goal>generate-code</goal>\n   158→              <goal>generate-code-tests</goal>\n   159→            </goals>\n   160→          </execution>\n   161→        </executions>\n   162→      </plugin>\n   163→      <plugin>\n   164→        <artifactId>maven-compiler-plugin</artifactId>\n   165→        <version>${compiler-plugin.version}</version>\n   166→      </plugin>\n   167→      <plugin>\n   168→        <artifactId>maven-surefire-plugin</artifactId>\n   169→        <version>${surefire-plugin.version}</version>\n   170→        <configuration>\n   171→          <systemPropertyVariables>\n   172→            <jacoco-agent.destfile>${project.build.directory}/jacoco.exec</jacoco-agent.destfile>\n   173→            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   174→            <maven.home>${maven.home}</maven.home>\n   175→          </systemPropertyVariables>\n   176→        </configuration>\n   177→      </plugin>\n   178→      <!-- Code quality -->\n   179→      <plugin>\n   180→        <groupId>org.apache.maven.plugins</groupId>\n   181→        <artifactId>maven-pmd-plugin</artifactId>\n   182→        <version>3.21.2</version>\n   183→        <configuration>\n   184→          <linkXRef>true</linkXRef>\n   185→          <rulesets>\n   186→            <ruleset>/category/java/codestyle.xml</ruleset>\n   187→            <ruleset>/category/java/bestpractices.xml</ruleset>\n   188→          </rulesets>\n   189→        </configuration>\n   190→        <executions>\n   191→          <execution>\n   192→            <id>pmd-scan</id>\n   193→            <phase>verify</phase>\n   194→            <goals>\n   195→              <goal>check</goal>\n   196→            </goals>\n   197→          </execution>\n   198→        </executions>\n   199→      </plugin>\n   200→      <plugin>\n   201→        <groupId>com.github.spotbugs</groupId>\n   202→        <artifactId>spotbugs-maven-plugin</artifactId>\n   203→        <version>4.2.0</version>\n   204→        <configuration>\n   205→          <effort>Max</effort>\n   206→          <threshold>Low</threshold>\n   207→          <failOnError>true</failOnError>\n   208→          <plugins>\n   209→            <plugin>\n   210→              <groupId>com.h3xstream.findsecbugs</groupId>\n   211→              <artifactId>findsecbugs-plugin</artifactId>\n   212→              <version>1.11.0</version>\n   213→            </plugin>\n   214→          </plugins>\n   215→        </configuration>\n   216→        <executions>\n   217→          <execution>\n   218→            <id>scan</id>\n   219→            <phase>verify</phase>\n   220→            <goals>\n   221→              <goal>check</goal>\n   222→            </goals>\n   223→          </execution>\n   224→        </executions>\n   225→      </plugin>\n   226→    </plugins>\n   227→  </build>\n   228→  <profiles>\n   229→    <profile>\n   230→      <id>native</id>\n   231→      <activation>\n   232→        <property>\n   233→          <name>native</name>\n   234→        </property>\n   235→      </activation>\n   236→      <build>\n   237→        <plugins>\n   238→          <plugin>\n   239→            <artifactId>maven-failsafe-plugin</artifactId>\n   240→            <version>${surefire-plugin.version}</version>\n   241→            <executions>\n   242→              <execution>\n   243→                <goals>\n   244→                  <goal>integration-test</goal>\n   245→                  <goal>verify</goal>\n   246→                </goals>\n   247→                <configuration>\n   248→                  <systemPropertyVariables>\n   249→                    <native.image.path>${project.build.directory}/${project.build.finalName}-runner</native.image.path>\n   250→                    <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   251→                    <maven.home>${maven.home}</maven.home>\n   252→                  </systemPropertyVariables>\n   253→                </configuration>\n   254→              </execution>\n   255→            </executions>\n   256→          </plugin>\n   257→        </plugins>\n   258→      </build>\n   259→      <properties>\n   260→        <quarkus.native.enabled>true</quarkus.native.enabled>\n   261→        <quarkus.package.jar.enabled>false</quarkus.package.jar.enabled>\n   262→      </properties>\n   263→    </profile>\n   264→  </profiles>\n   265→</project>\n   266→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01D79PEVqFgYKDsezSUtKZsz","session_id":"887ed637-45f4-4598-acb3-9e086d9e5f12","uuid":"86f04ac1-cb92-42c4-8874-14ed912da1ee"}
