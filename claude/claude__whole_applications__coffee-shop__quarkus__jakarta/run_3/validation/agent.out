son = JsonUtil.toJson(orderUp);\n    75→        assertNotNull(json);\n    76→        logger.info(\"OrderUp JSON: {}\", json);\n    77→\n    78→        OrderUp deserialized = JsonUtil.fromJsonToOrderUp(json);\n    79→        assertNotNull(deserialized);\n    80→        assertEquals(orderUp.orderId, deserialized.orderId);\n    81→        assertEquals(orderUp.madeBy, deserialized.madeBy);\n    82→    }\n    83→}\n    84→"}]},"parent_tool_use_id":null,"session_id":"887ed637-45f4-4598-acb3-9e086d9e5f12","uuid":"a076a30b-841c-4882-bd48-d7fb5f68dbeb"}
