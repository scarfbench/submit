rderIn);\n        assertEquals(Item.CROISSANT, orderIn.item);\n        assertEquals(\"Spock\", orderIn.name);\n        assertNotNull(orderIn.orderId);\n        assertNotNull(orderIn.itemId);\n\n        // Test JSON serialization/deserialization\n        String json = JsonUtil.toJson(orderIn);\n        assertNotNull(json);\n        LOGGER.info(\"OrderIn JSON: {}\", json);\n\n        OrderIn deserialized = JsonUtil.fromJson(json, OrderIn.class);\n        assertNotNull(deserialized);\n        assertEquals(orderIn.item, deserialized.item);\n        assertEquals(orderIn.name, deserialized.name);\n    }\n}"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":872,"cache_read_input_tokens":24041,"cache_creation":{"ephemeral_5m_input_tokens":872,"ephemeral_1h_input_tokens":0},"output_tokens":750},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01Twv4hkxgC3FvKVF4HH2TKG","session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"20dee173-c510-4390-96e0-9c89f4a9d760"}
