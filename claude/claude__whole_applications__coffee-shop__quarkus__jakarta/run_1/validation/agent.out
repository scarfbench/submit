   667â†’                                    </div>\n   668â†’                                    <div class=\"desc\">\n   669â†’                                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, duis sed dapibus leo nec ornare diam. </p>\n   670â†’                                    </div>\n   671â†’                                </div>\n   672â†’                            </div>\n   673â†’                        </div>\n   674â†’                    </div>\n   675â†’                </div>\n   676â†’            </div>\n   677â†’        </div>\n   678â†’    </div>\n   679â†’</section>\n   680â†’<span class=\"anchor\" id=\"statusboard\"></span>\n   681â†’<section class=\"statusboard\">\n   682â†’    <div class=\"container padding-2x\">\n   683â†’        <div class=\"row text-wrap\">\n   684â†’            <div class=\"col-sm-12\">\n   685â†’                <h3 class=\"text-center\">Orders</h3>\n   686â†’                <hr/>\n   687â†’                <p class=\"text-center\">Check Here for Your Order Status</p>\n   688â†’            </div>\n   689â†’            <div class=\"row justify-content-center\">\n   690â†’                <table class=\"table table-lg table-striped\">\n   691â†’                    <thead class=\"thead-dark\">\n   692â†’                    <tr>\n   693â†’                        <th style=\"width:30%\">Customer</th>\n   694â†’                        <th style=\"width:30%\">Item</th>\n   695â†’                        <th style=\"width:20%\">Status</th>\n   696â†’                        <th style=\"width:20%\">Prepared By</th>\n   697â†’                    </tr>\n   698â†’                    </thead>\n   699â†’                    <tbody>\n   700â†’                    </tbody>\n   701â†’                </table>\n   702â†’\n   703â†’            </div>\n   704â†’        </div>\n   705â†’    </div>\n   706â†’</section>\n   707â†’<span class=\"anchor\" id=\"team\"></span>\n   708â†’<section class=\"team\">\n   709â†’    <div class=\"container padding-2x\">\n   710â†’        <div class=\"row text-wrap\">\n   711â†’            <div class=\"col-sm-12\">\n   712â†’                <h3 class=\"text-center\">Meet Our Team</h3>\n   713â†’                <hr>\n   714â†’                <p class=\"text-center\">Many people contribute to Quarkus, but these 5 Red Hatters were the ones who started the project\n   715â†’                </p>\n   716â†’            </div>\n   717â†’        </div>\n   718â†’        <div class=\"row team-boxes\">\n   719â†’            <div class=\"col-md-2 col-md-offset-1\">\n   720â†’                <div class=\"box wow fadeInUp\" data-wow-duration=\"400ms\" data-wow-offset=\"10\">\n   721â†’                    <img src=\"images/headshots/emmanuel-bernard.jpg\" alt=\"Emmanuel Bernard\" />\n   722â†’                    <h6>Emmanuel Bernard</h6>\n   723â†’                    <p>Co-Founder / Co-Lead</p>\n   724â†’                </div>\n   725â†’            </div>\n   726â†’            <div class=\"col-md-2\">\n   727â†’                <div class=\"box wow fadeInUp\" data-wow-duration=\"800ms\" data-wow-offset=\"10\">\n   728â†’                    <img src=\"images/headshots/jason-greene.jpg\" alt=\"Jason Greene\" />\n   729â†’                    <h6>Jason Greene</h6>\n   730â†’                    <p>Co-Founder / Co-Lead</p>\n   731â†’                </div>\n   732â†’            </div>\n   733â†’            <div class=\"col-md-2\">\n   734â†’                <div class=\"box wow fadeInUp\" data-wow-duration=\"1.2s\" data-wow-offset=\"10\">\n   735â†’                    <img src=\"images/headshots/ken_avatar_2019.png\" alt=\"Ken Finnigan\" />\n   736â†’                    <h6>Ken Finnigan</h6>\n   737â†’                    <p>Pre-Quarkus Co-Founder</p>\n   738â†’                </div>\n   739â†’            </div>\n   740â†’            <div class=\"col-md-2\">\n   741â†’                <div class=\"box wow fadeInUp\" data-wow-duration=\"1.6s\" data-wow-offset=\"10\">\n   742â†’                    <img src=\"images/headshots/max-andersen.jpg\" alt=\"Max Andersen\" />\n   743â†’                    <h6>Max Andersen</h6>\n   744â†’                    <p>Devex Lead</p>\n   745â†’                </div>\n   746â†’            </div>\n   747â†’            <div class=\"col-md-2\">\n   748â†’                <div class=\"box wow fadeInUp\" data-wow-duration=\"1.6s\" data-wow-offset=\"10\">\n   749â†’                    <img src=\"images/headshots/clement_escoffier.jpeg\" alt=\"Clement Escoffier\" />\n   750â†’                    <h6>Clement Escoffier</h6>\n   751â†’                    <p>Reactive Lead</p>\n   752â†’                </div>\n   753â†’            </div>\n   754â†’        </div>\n   755â†’    </div>\n   756â†’</section>\n   757â†’<span class=\"anchor\" id=\"testimonials\"></span>\n   758â†’<section class=\"testimonials\">\n   759â†’    <div id=\"carousel-testimonials\" class=\"carousel slide\" data-bs-ride=\"carousel\">\n   760â†’        <div class=\"container-fluid padding-2x\">\n   761â†’            <!-- Wrapper for slides -->\n   762â†’            <div class=\"row\">\n   763â†’                <div class=\"col-xs-12\">\n   764â†’                    <h3 class=\"text-center\">Twitter</h3>\n   765â†’                    <hr>\n   766â†’                </div>\n   767â†’            </div>\n   768â†’            <div class=\"row\">\n   769â†’                <div class=\"col-xs-10 col-xs-offset-1 col-sm-6 col-sm-offset-3\">\n   770â†’                    <div class=\"carousel-inner\">\n   771â†’                        <div class=\"carousel-item active\">\n   772â†’                            <div class=\"carousel-content\">\n   773â†’                                <blockquote class=\"twitter-tweet tw-align-center \"><p lang=\"en\" dir=\"ltr\">I really like <a href=\"https://twitter.com/QuarkusIO?ref_src=twsrc%5Etfw\">@QuarkusIO</a>&#39;s extension system. The deployment time (build time) hook allows for a lot of interesting uses I haven&#39;t thought of yet đźš€</p>&mdash; Knut Wannheden (@knutwannheden) <a href=\"https://twitter.com/knutwannheden/status/1276588974849634304?ref_src=twsrc%5Etfw\">June 26, 2020</a></blockquote> <script async src=\"https://platform.twitter.com/widgets.js\" charset=\"utf-8\"></script>\n   774â†’                            </div>\n   775â†’                        </div>\n   776â†’                        <div class=\"carousel-item\">\n   777â†’                            <div class=\"carousel-content\">\n   778â†’                                <blockquote class=\"twitter-tweet tw-align-center \"><p lang=\"en\" dir=\"ltr\">â€śOne of the real benefits of <a href=\"https://twitter.com/hashtag/Java?src=hash&amp;ref_src=twsrc%5Etfw\">#Java</a> is that it does have a huge <a href=\"https://twitter.com/hashtag/ecosystem?src=hash&amp;ref_src=twsrc%5Etfw\">#ecosystem</a> of <a href=\"https://twitter.com/hashtag/libraries?src=hash&amp;ref_src=twsrc%5Etfw\">#libraries</a> and <a href=\"https://twitter.com/hashtag/utilities?src=hash&amp;ref_src=twsrc%5Etfw\">#utilities</a> for doing practically everything.&quot; Therefore, consider using the <a href=\"https://twitter.com/hashtag/Quarkus?src=hash&amp;ref_src=twsrc%5Etfw\">#Quarkus</a> <a href=\"https://twitter.com/hashtag/framework?src=hash&amp;ref_src=twsrc%5Etfw\">#framework</a> for your next <a href=\"https://twitter.com/hashtag/microservice?src=hash&amp;ref_src=twsrc%5Etfw\">#microservice</a> project. <a href=\"https://twitter.com/QuarkusIO?ref_src=twsrc%5Etfw\">@QuarkusIO</a><a href=\"https://t.co/Z6JNMFSxab\">https://t.co/Z6JNMFSxab</a></p>&mdash; Felix Seifert (@flx_seifert) <a href=\"https://twitter.com/flx_seifert/status/1274708071630045185?ref_src=twsrc%5Etfw\">June 21, 2020</a></blockquote> <script async src=\"https://platform.twitter.com/widgets.js\" charset=\"utf-8\"></script>\n   779â†’                            </div>\n   780â†’                        </div>\n   781â†’                        <div class=\"carousel-item\">\n   782â†’                            <div class=\"carousel-content\">\n   783â†’                                <blockquote class=\"twitter-tweet tw-align-center \"><p lang=\"en\" dir=\"ltr\">âšˇď¸ŹNew: Running a native image on AWS <a href=\"https://twitter.com/hashtag/Lambda?src=hash&amp;ref_src=twsrc%5Etfw\">#Lambda</a> through <a href=\"https://twitter.com/hashtag/Quarkus?src=hash&amp;ref_src=twsrc%5Etfw\">#Quarkus</a> and <a href=\"https://twitter.com/hashtag/GraalVM?src=hash&amp;ref_src=twsrc%5Etfw\">#GraalVM</a>, <a href=\"https://twitter.com/sascha242?ref_src=twsrc%5Etfw\">@sascha242</a> and me examine the benefits you can get and describe the build steps required for your <a href=\"https://twitter.com/hashtag/Java?src=hash&amp;ref_src=twsrc%5Etfw\">#Java</a> app. <a href=\"https://t.co/yRSSEvOSuz\">https://t.co/yRSSEvOSuz</a> <a href=\"https://t.co/6H7OOi3geF\">pic.twitter.com/6H7OOi3geF</a></p>&mdash; Steffen Grunwald (@steffeng) <a href=\"https://twitter.com/steffeng/status/1273485530030903298?ref_src=twsrc%5Etfw\">June 18, 2020</a></blockquote> <script async src=\"https://platform.twitter.com/widgets.js\" charset=\"utf-8\"></script>\n   784â†’                            </div>\n   785â†’                        </div>\n   786â†’                        <!-- Indicators -->\n   787â†’                        <div class=\"carousel-indicators\">\n   788â†’                            <button type=\"button\" data-bs-target=\"#carousel-testimonials\" data-bs-slide-to=\"0\" class=\"active\" aria-current=\"true\" aria-label=\"Slide 1\"></button>\n   789â†’                            <button type=\"button\" data-bs-target=\"#carousel-testimonials\" data-bs-slide-to=\"1\" aria-label=\"Slide 2\"></button>\n   790â†’                            <button type=\"button\" data-bs-target=\"#carousel-testimonials\" data-bs-slide-to=\"2\" aria-label=\"Slide 3\"></button>\n   791â†’                        </div>\n   792â†’                    </div>\n   793â†’                <