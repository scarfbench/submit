{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_019pN8GgtH2FLReb3Tib2yFj","type":"tool_result","content":"     1â†’package io.quarkuscoffeeshop.coffeeshop.web;\n     2â†’\n     3â†’import io.quarkus.test.junit.QuarkusTest;\n     4â†’import io.quarkuscoffeeshop.coffeeshop.domain.commands.PlaceOrderCommand;\n     5â†’import io.quarkuscoffeeshop.coffeeshop.utils.TestUtils;\n     6â†’import io.quarkuscoffeeshop.utils.JsonUtil;\n     7â†’import org.junit.jupiter.api.Test;\n     8â†’import org.slf4j.Logger;\n     9â†’import org.slf4j.LoggerFactory;\n    10â†’\n    11â†’import jakarta.ws.rs.core.MediaType;\n    12â†’\n    13â†’import static io.restassured.RestAssured.given;\n    14â†’import static org.junit.jupiter.api.Assertions.assertNull;\n    15â†’\n    16â†’@QuarkusTest\n    17â†’public class CoffeeshopApiResourceTest {\n    18â†’\n    19â†’    Logger LOGGER = LoggerFactory.getLogger(CoffeeshopApiResourceTest.class);\n    20â†’\n    21â†’    @Test\n    22â†’    public void testPlaceOrder() {\n    23â†’\n    24â†’        PlaceOrderCommand placeOrderCommand = TestUtils.mockPlaceOrderCommand();\n    25â†’\n    26â†’        LOGGER.info(\"Testing place order with json: {}\", JsonUtil.toJson(placeOrderCommand));\n    27â†’        given()\n    28â†’                .contentType(MediaType.APPLICATION_JSON)\n    29â†’                .when()\n    30â†’                .body(JsonUtil.toJson(placeOrderCommand))\n    31â†’                .post(\"/api/order\")\n    32â†’                .then()\n    33â†’                .statusCode(202);\n    34â†’    }\n    35â†’\n    36â†’    @Test\n    37â†’    public void testPlaceOrderForSingleCroissant() {\n    38â†’\n    39â†’    }\n    40â†’}\n    41â†’\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"b0730843-c203-4ad2-ba19-34a11188577d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Pv2y9Q9mcv8Qg7HigHBNnX","type":"tool_result","content":"     1â†’package io.quarkuscoffeeshop.coffeeshop.web;\n     2â†’\n     3â†’import io.quarkus.test.junit.QuarkusTest;\n     4â†’import io.quarkus.test.junit.mockito.InjectSpy;\n     5â†’import io.quarkuscoffeeshop.coffeeshop.counter.api.OrderService;\n     6â†’import io.quarkuscoffeeshop.coffeeshop.domain.commands.PlaceOrderCommand;\n     7â†’import io.quarkuscoffeeshop.coffeeshop.utils.TestUtils;\n     8â†’import io.quarkuscoffeeshop.utils.JsonUtil;\n     9â†’import org.junit.jupiter.api.Test;\n    10â†’import org.mockito.Mockito;\n    11â†’import org.slf4j.Logger;\n    12â†’import org.slf4j.LoggerFactory;\n    13â†’\n    14â†’import jakarta.ws.rs.core.MediaType;\n    15â†’\n    16â†’import static io.restassured.RestAssured.given;\n    17â†’import static org.mockito.ArgumentMatchers.any;\n    18â†’\n    19â†’@QuarkusTest\n    20â†’public class CoffeeshopApiResourceIT {\n    21â†’\n    22â†’    private static final Logger LOGGER = LoggerFactory.getLogger(CoffeeshopApiResourceIT.class);\n    23â†’\n    24â†’    @InjectSpy\n    25â†’    OrderService orderService;\n    26â†’\n    27â†’    @Test\n    28â†’    public void testJson() {\n    29â†’        String json = \"{\\\"id\\\":\\\"1e08c459-7e9e-463d-9c19-608688d1a63e\\\",\\\"orderSource\\\":\\\"COUNTER\\\",\\\"location\\\":\\\"ATLANTA\\\",\\\"loyaltyMemberId\\\":\\\"StarshipCaptain\\\",\\\"baristaItems\\\":[{\\\"name\\\":\\\"Jeremy\\\",\\\"item\\\":\\\"COFFEE_BLACK\\\",\\\"price\\\":3.50}],\\\"kitchenItems\\\":[]}\";\n    30â†’        String jsop =                                 \"{\\\"commandType\\\":\\\"PLACE_ORDER\\\",\\\"id\\\":\\\"985176b9-fb9a-4bec-87b5-501240f65b96\\\",\\\"orderSource\\\":\\\"COUNTER\\\",\\\"location\\\":\\\"ATLANTA\\\",\\\"loyaltyMemberId\\\":\\\"StarshipCaptain\\\",\\\"baristaItems\\\":[{\\\"item\\\":\\\"COFFEE_BLACK\\\",\\\"name\\\":\\\"Kirk\\\",\\\"price\\\":3.0}],\\\"kitchenItems\\\":null,\\\"timestamp\\\":1616611945.403978000}\";\n    31â†’\n    32â†’        given()\n    33â†’                .contentType(MediaType.APPLICATION_JSON)\n    34â†’                .body(JsonUtil.toJson(jsop))\n    35â†’                .when()\n    36â†’                .post(\"/api/order\")\n    37â†’                .then()\n    38â†’                .assertThat()\n    39â†’                .statusCode(202);\n    40â†’\n    41â†’        Mockito.verify(orderService, Mockito.times(1)).onOrderIn(any(PlaceOrderCommand.class));\n    42â†’    }\n    43â†’\n    44â†’    @Test\n    45â†’    public void testPlaceOrder() {\n    46â†’\n    47â†’        PlaceOrderCommand placeOrderCommand = TestUtils.mockPlaceOrderCommand();\n    48â†’\n    49â†’        LOGGER.info(\"placeOrderCommand: {}\", placeOrderCommand);\n    50â†’        LOGGER.info(\"Testing place order\");\n    51â†’        System.out.println(JsonUtil.toJson(placeOrderCommand));\n    52â†’\n    53â†’        given()\n    54â†’                .contentType(MediaType.APPLICATION_JSON)\n    55â†’                .body(JsonUtil.toJson(TestUtils.mockPlaceOrderCommand()))\n    56â†’                .when()\n    57â†’                .post(\"/api/order\")\n    58â†’                .then()\n    59â†’                .assertThat()\n    60â†’                .statusCode(202);\n    61â†’\n    62â†’        Mockito.verify(orderService, Mockito.times(1)).onOrderIn(any(PlaceOrderCommand.class));\n    63â†’    }\n    64â†’\n    65â†’}\n    66â†’\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"e00df7fb-2dac-4a38-aa48-5118e5540e0e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01HvAJWGTAYv2DPMUsFYUGS7","type":"tool_result","content":"     1â†’package io.quarkuscoffeeshop.coffeeshop.utils;\n     2â†’\n     3â†’import io.quarkuscoffeeshop.coffeeshop.domain.Item;\n     4â†’import io.quarkuscoffeeshop.coffeeshop.domain.Location;\n     5â†’import io.quarkuscoffeeshop.coffeeshop.domain.OrderSource;\n     6â†’import io.quarkuscoffeeshop.coffeeshop.domain.commands.CommandItem;\n     7â†’import io.quarkuscoffeeshop.coffeeshop.domain.commands.CommandType;\n     8â†’import io.quarkuscoffeeshop.coffeeshop.domain.commands.PlaceOrderCommand;\n     9â†’\n    10â†’import java.math.BigDecimal;\n    11â†’import java.time.Instant;\n    12â†’import java.util.Arrays;\n    13â†’import java.util.Optional;\n    14â†’import java.util.UUID;\n    15â†’\n    16â†’public class TestUtils {\n    17â†’\n    18â†’    public static PlaceOrderCommand mockPlaceOrderCommand() {\n    19â†’\n    20â†’        return new PlaceOrderCommand(\n    21â†’                UUID.randomUUID().toString(),\n    22â†’                OrderSource.COUNTER,\n    23â†’                Location.ATLANTA,\n    24â†’                Optional.of(\"StarshipCaptain\"),\n    25â†’                Optional.of(Arrays.asList(new CommandItem(Item.COFFEE_BLACK, \"Kirk\", BigDecimal.valueOf(3.00)))),\n    26â†’                Optional.empty(), CommandType.PLACE_ORDER);\n    27â†’    }\n    28â†’\n    29â†’}\n    30â†’\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"0e5b2730-9448-4d46-8614-67a2f6e1abf0"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01NhN2GAcEMbHdG5F6zFxCjX","type":"tool_result","content":"     1â†’DO $$\n     2â†’BEGIN\n     3â†’  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = 'coffeeshopuser') THEN\n     4â†’    CREATE ROLE coffeeshopuser LOGIN PASSWORD 'redhat-21';\n     5â†’  ELSE\n     6â†’    ALTER ROLE coffeeshopuser WITH LOGIN PASSWORD 'redhat-21';\n     7â†’  END IF;\n     8â†’END$$;\n     9â†’\n    10â†’GRANT CONNECT, TEMP, CREATE ON DATABASE coffeeshopdb TO coffeeshopuser;\n    11â†’\n    12â†’DO $$\n    13â†’BEGIN\n    14â†’  IF NOT EXISTS (SELECT 1 FROM pg_namespace WHERE nspname = 'coffeeshop') THEN\n    15â†’    EXECUTE 'CREATE SCHEMA coffeeshop AUTHORIZATION coffeeshopuser';\n    16â†’  END IF;\n    17â†’  IF NOT EXISTS (SELECT 1 FROM pg_namespace WHERE nspname = 'barista') THEN\n    18â†’    EXECUTE 'CREATE SCHEMA barista AUTHORIZATION coffeeshopuser';\n    19â†’  END IF;\n    20â†’  IF NOT EXISTS (SELECT 1 FROM pg_namespace WHERE nspname = 'kitchen') THEN\n    21â†’    EXECUTE 'CREATE SCHEMA kitchen AUTHORIZATION coffeeshopuser';\n    22â†’  END IF;\n    23â†’END$$;\n    24â†’\n    25â†’ALTER SCHEMA coffeeshop OWNER TO coffeeshopuser;\n    26â†’ALTER SCHEMA barista    OWNER TO coffeeshopuser;\n    27â†’ALTER SCHEMA kitchen    OWNER TO coffeeshopuser;\n    28â†’\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"57fd79de-dc20-4ec3-bb7a-09de67ce519a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Y5gfY8XhQ8SGjRyoCymKtM","type":"tool_result","content":"     1â†’<!DOCTYPE html>\n     2â†’<html lang=\"en\">\n     3â†’<head>\n     4â†’    <meta charset=\"utf-8\">\n     5â†’    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n     6â†’    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n     7â†’    <meta name=\"format-detection\" content=\"telephone=no\">\n     8â†’    <!-- The above 3 meta tags *must* come first in the head; any other head content must come *after* these tags -->\n     9â†’    <title>Quarkus Coffee Shop</title>\n    10â†’    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"favicon/apple-touch-icon.png\">\n    11â†’    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"favicon/favicon-32x32.png\">\n    12â†’    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"favicon/favicon-16x16.png\">\n    13â†’    <link rel=\"manifest\" href=\"favicon/site.webmanifest\">\n    14â†’    <link rel=\"mask-icon\" href=\"favicon/safari-pinned-tab.svg\" color=\"#5bbad5\">\n    15â†’    <link rel=\"shortcut icon\" href=\"favicon/favicon.ico\">\n    16â†’    <meta name=\"msapplication-TileColor\" content=\"#da532c\">\n    17â†’    <meta name=\"msapplication-config\" content=\"favicon/browserconfig.xml\">\n    18â†’    <meta name=\"theme-color\" content=\"#ffffff\">\n    19â†’    <!-- Bootstrap -->\n    20â†’    <link href=\"css/bootstrap.min.css\" rel=\"stylesheet\">\n    21â†’    <!-- Base Styles -->\n    22â†’    <link href=\"css/styles.css\" rel=\"stylesheet\">\n    23â†’    <!-- Custom CSS -->\n    24â†’    <link href=\"css/custom.css\" rel=\"stylesheet\">\n    25â†’    <!-- Google Fonts -->\n    26â†’    <link href=\"https://fonts.googleapis.com/css?family=Cookie%7cMontserrat:300,400,500,600,700%7cRoboto:300,400,500,700\" rel=\"stylesheet\">\n    27â†’    <!-- Font Awesome -->\n    28â†’    <link href=\"https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css\" rel=\"stylesheet\" integrity=\"sha384-wvfXpqpZZVQGK6TAh5PVlGOfQNHSoD2xbE+QkPxCAFlNEevoEH3Sl0sibVcOQVnN\" crossorigin=\"anonymous\">\n    29â†’    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.min.css\">\n    30â†’    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/ekko-lightbox/5.3.0/ekko-lightbox.css\">\n    31â†’    <!-- Customized css -->\n    32â†’    <link href=\"css/cafe.css\" rel=\"stylesheet\" />\n    33â†’    <link href=\"css/toastr.css\" rel=\"stylesheet\">\n    34â†’    <!-- HTML5 shim and Respond.js for IE8 support of HTML5 elements and media queries -->\n    35â†’    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->\n    36â†’    <!--[if lt IE 9]>\n    37â†’    <script src=\"https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js\"></script>\n    38â†’    <script src=\"https://oss.maxcdn.com/respond/1.4.2/respond.min.js\"></script>\n    39â†’    <![endif]-->\n    40â†’</head>\n    41â†’<body>\n    42â†’<nav class=\"navbar navbar-expand-lg navbar-dark bg-dark fixed-top\">\n    43â†’  <div class=\"container\">\n    44â†’    <a class=\"navbar-brand\" href=\"#banner\"><i class=\"fa fa-coffee\"></i> Quarkus Coffee Shop</a>\n    45â†’\n    46â†’    <button class=\"navbar-toggler\" type=\"button\"\n    47â†’            data-bs-toggle=\"collapse\" data-bs-target=\"#navbarSupportedContent\"\n    48â†’            aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n    49â†’      <span class=\"navbar-toggler-icon\"></span>\n    50â†’    </button>\n    51â†’\n    52â†’    <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n    53â†’      <ul class=\"navbar-nav ms-auto mb-2 mb-lg-0\">\n    54â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#about\">About</a></li>\n    55â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#menu\">Menu</a></li>\n    56â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#gallery\">Gallery</a></li>\n    57â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#team\">Team</a></li>\n    58â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#testimonials\">Twitter</a></li>\n    59â†’        <li class=\"nav-item\"><a class=\"nav-link\" href=\"#contact\">Contact</a></li>\n    60â†’\n    61â†’        <li id=\"rewards_link\" class=\"nav-item\">\n    62â†’          <a class=\"nav-link\" href=\"#\" data-bs-toggle=\"modal\" data-bs-target=\"#rewardsModal\">Rewards</a>\n    63â†’        </li>\n    64â†’      </ul>\n    65â†’    </div>\n    66â†’  </div>\n    67â†’</nav>\n    68â†’\n    69â†’<span id=\"banner\"></span>\n    70â†’<section class=\"banner\">\n    71â†’    <div class=\"jumbotron\">\n    72â†’        <div class=\"container\">\n    73â†’            <div class=\"content\">\n    74â†’                <h5>Established 2020</h5>\n    75â†’                <h1>Quarkus Coffee Shop</h1>\n    76â†’                <a href=\"#menu\" class=\"btn\">Place an Order</a>\n    77â†’            </div>\n    78â†’        </div>\n    79â†’    </div>\n    80â†’</section>\n    81â†’\n    82â†’<div class=\"modal\" id=\"rewardsModal\">\n    83â†’    <div class=\"modal-dialog\">\n    84â†’        <form id=\"rewards_modal\">\n    85â†’\n    86â†’            <div class=\"modal-content\">\n    87â†’                <!-- Modal Header -->\n    88â†’                <div class=\"modal-header\">\n    89â†’                    <h4 class=\"modal-title\">\n    90â†’                        Rewards Info\n    91â†’                    </h4>\n    92â†’                    <button id=\"btn_cancel\" type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\n    93â†’                </div>\n    94â†’                <!-- Modal body -->\n    95â†’                <div class=\"modal-body flex-fill d-inline-flex\">\n    96â†’                    <div class=\"flex-fill d-inline-flex justify-content-end form-group\">\n    97â†’                        <label for=\"rewards_id\" class=\"mr-sm-2 input-cafe text-nowrap mb-2\">Rewards email:</label>\n    98â†’                        <input type=\"email\" required class=\"form-control mb-2 mr-sm-2\" placeholder=\"Enter rewards email\" id=\"rewards_id\" rewards_id=\"rewards_id\">\n    99â†’                    </div>\n   100â†’                </div>\n   101â†’\n   102â†’                <!-- Modal footer -->\n   103â†’                <div class=\"modal-footer\">\n   104â†’                    <div class=\"flex-fill\">\n   105â†’                        <button type=\"submit\" id=\"rewards_entered\" class=\"btn-sm btn-primary pull-right\">Done</button>\n   106â†’                    </div>\n   107â†’                </div>\n   108â†’            </div>\n   109â†’        </form>\n   110â†’    </div>\n   111â†’</div>\n   112â†’\n   113â†’<span class=\"anchor\" id=\"about\"></span>\n   114â†’<section class=\"about\">\n   115â†’    <div class=\"container padding-2x\">\n   116â†’        <div class=\"row text-wrap\">\n   117â†’            <div class=\"col-sm-12\">\n   118â†’                <h3 class=\"text-center\">Welcome to Quarkus, Kafka, Kubernetes, and Coffee</h3>\n   119â†’                <hr>\n   120â†’                <p class=\"text-center\">Quarkus is a Kubernetes Native Java stack tailored for OpenJDK HotSpot and GraalVM, crafted from the best of breed Java libraries and standards.</p>\n   121â†’            </div>\n   122â†’        </div>\n   123â†’        <div class=\"row about-info\">\n   124â†’            <div class=\"col-sm-12 col-md-6\">\n   125â†’                <div class=\"box wow fadeIn\" data-wow-duration=\"400ms\" data-wow-offset=\"10\">\n   126â†’                    <img src=\"images/about.jpg\" alt=\"about\" />\n   127â†’                </div>\n   128â†’            </div>\n   129â†’            <div class=\"col-sm-12 col-md-6\">\n   130â†’                <div class=\"box wow fadeIn\" data-wow-duration=\"800ms\" data-wow-offset=\"10\">\n   131â†’                    <h5>Our Story</h5>\n   132â†’                    <p>A Kubernetes Native Java stack tailored for OpenJDK HotSpot and GraalVM, crafted from the best of breed Java libraries and standards.</p>\n   133â†’                    <p>Quarkus tailors your application for GraalVM and HotSpot. Amazingly fast boot time, incredibly low RSS memory (not just heap size!) offering near instant scale up and high density memory utilization in container orchestration platforms like Kubernetes.</p>\n   134â†’                    <p>This application is demo showcasing an event driven Quarkus application that uses Apache Kafka for messaging.</p>\n   135â†’                </div>\n   136â†’            </div>\n   137â†’        </div>\n   138â†’    </div>\n   139â†’</section>\n   140â†’<span class=\"anchor\" id=\"menu\"></span>\n   141â†’<section class=\"menu\">\n   142â†’    <div class=\"container padding-2x\">\n   143â†’        <div class=\"row text-wrap\">\n   144â†’            <div class=\"col-sm-12\">\n   145â†’                <h3 class=\"text-center\">Menu</h3>\n   146â†’                <hr>\n   147â†’                <p class=\"text-center\">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer nec odio. Praesent libero. Sed cursus ante dapibus diam. Sed nisi. </p>\n   148â†’            </div>\n   149â†’        </div>\n   150â†’        <div class=\"modal\" id=\"myModal\">\n   151â†’            <div class=\"modal-dialog\" display=\"flex\">\n   152â†’                <div class=\"modal-content\">\n   153â†’                    <!-- Modal Header -->\n   154â†’                    <div class=\"modal-header\">\n   155â†’                        <h4 class=\"modal-title\" >\n   156â†’                            Current Order\n   157â†’                        </h4>\n   158â†’                        <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\n   159â†’                        <div class=\"pt-10\">\n   160â†’                            <ul class=\"list-group mt-10\" id=\"current_order\">\n   161â†’                            </ul>\n   162â†’                        </div>\n   163â†’                        <div class=\"alert alert-success\" role=\"alert\"id=\"item_added_alert\" >\n   164â†’                        </div>\n   165â†’                    </div>\n   166â†’                    <!-- Modal body -->\n   167â†’                    <div class=\"modal-body\">\n   168â†’                        <div id=\"rewards_display\" class=\"small text-muted\" style=\"align-self: flex-end\">\n   169â†’                            <text> Rewards member</text>\n   170â†’                            <text id=\"rewards_display_id\"></text>\n   171â†’                        </div>\n   172â†’                        <form class=\"form-inline\" action=\"\" id=\"item_form\">\n   173â†’                            <div class=\"flex-fill d-inline-flex justify-content-between\">\n   174â†’                                <input type=\"hidden\" id=\"item_type\" name=\"item_type\"/>\n   175â†’                                <input type=\"hidden\" id=\"item_price\" name=\"item_price\"/>\n   176â†’                                <label for=\"item\" class=\"mr-sm-2 input-cafe text-nowrap mb-2\" id=\"item_label\"></label>\n   177â†’                                <input type=\"hidden\" id=\"item\" name=\"item\"/>\n   178â†’                                <label for=\"name\" class=\"mr-sm-2 input-cafe text-nowrap mb-2\">for Name:</label>\n   179â†’                                <input type=\"text\" class=\"form-control mb-2 mr-sm-2\" placeholder=\"Enter name\" id=\"name\" name=\"name\">\n   180â†’                                <button type=\"submit\" class=\"btn-sm btn-primary mb-2\">Add</button>\n   181â†’                            </div>\n   182â†’                        </form>\n   183â†’                    </div>\n  