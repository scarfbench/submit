             \", item=\" + item +\n    53â†’                \", name='\" + name + '\\'' +\n    54â†’                \", price=\" + price +\n    55â†’                \", itemStatus=\" + itemStatus +\n    56â†’                '}';\n    57â†’    }\n    58â†’\n    59â†’    @Override\n    60â†’    public boolean equals(Object o) {\n    61â†’        if (this == o) return true;\n    62â†’        if (o == null || getClass() != o.getClass()) return false;\n    63â†’\n    64â†’        LineItem lineItem = (LineItem) o;\n    65â†’\n    66â†’        if (order != null ? !order.equals(lineItem.order) : lineItem.order != null) return false;\n    67â†’        if (itemId != null ? !itemId.equals(lineItem.itemId) : lineItem.itemId != null) return false;\n    68â†’        if (item != lineItem.item) return false;\n    69â†’        if (name != null ? !name.equals(lineItem.name) : lineItem.name != null) return false;\n    70â†’        if (price != null ? !price.equals(lineItem.price) : lineItem.price != null) return false;\n    71â†’        return itemStatus == lineItem.itemStatus;\n    72â†’    }\n    73â†’\n    74â†’    @Override\n    75â†’    public int hashCode() {\n    76â†’        int result = order != null ? order.hashCode() : 0;\n    77â†’        result = 31 * result + (itemId != null ? itemId.hashCode() : 0);\n    78â†’        result = 31 * result + (item != null ? item.hashCode() : 0);\n    79â†’        result = 31 * result + (name != null ? name.hashCode() : 0);\n    80â†’        result = 31 * result + (price != null ? price.hashCode() : 0);\n    81â†’        result = 31 * result + (itemStatus != null ? itemStatus.hashCode() : 0);\n    82â†’        return result;\n    83â†’    }\n    84â†’\n    85â†’    public Order getOrder() {\n    86â†’        return order;\n    87â†’    }\n    88â†’\n    89â†’    public void setOrder(Order order) {\n    90â†’        this.order = order;\n    91â†’    }\n    92â†’\n    93â†’    public String getItemId() {\n    94â†’        return itemId;\n   