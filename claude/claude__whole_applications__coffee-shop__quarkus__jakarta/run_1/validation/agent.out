us=\").append(status);\n    46â†’        sb.append(\", madeBy='\").append(madeBy).append('\\'');\n    47â†’        sb.append('}');\n    48â†’        return sb.toString();\n    49â†’    }\n    50â†’\n    51â†’    @Override\n    52â†’    public boolean equals(Object o) {\n    53â†’        if (this == o) return true;\n    54â†’        if (o == null || getClass() != o.getClass()) return false;\n    55â†’\n    56â†’        OrderUpdate that = (OrderUpdate) o;\n    57â†’\n    58â†’        if (orderId != null ? !orderId.equals(that.orderId) : that.orderId != null) return false;\n    59â†’        if (itemId != null ? !itemId.equals(that.itemId) : that.itemId != null) return false;\n    60â†’        if (name != null ? !name.equals(that.name) : that.name != null) return false;\n    61â†’        if (item != that.item) return false;\n    62â†’        if (status != that.status) return false;\n    63â†’        return madeBy != null ? madeBy.equals(that.madeBy) : that.madeBy == null;\n    64â†’    }\n    65â†’\n    66â†’    @Override\n    67â†’    public int hashCode() {\n    68â†’        int result = orderId != null ? orderId.hashCode() : 0;\n    69â†’        result = 31 * result + (itemId != null ? itemId.hashCode() : 0);\n    70â†’        result = 31 * result + (name != null ? name.hashCode() : 0);\n    71â†’        result = 31 * result + (item != null ? item.hashCode() : 0);\n    72â†’        result = 31 * result + (status != null ? status.hashCode() : 0);\n    73â†’        result = 31 * result + (madeBy != null ? madeBy.hashCode() : 0);\n    74â†’        return result;\n    75â†’    }\n    76â†’\n    77â†’\n    78â†’}\n    79â†’\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"pare