{"type":"user","message":{"role":"user","content":[{"type":"tool_result","content":"Exit code 1\n============================================\n  Coffee Shop Jakarta EE - Smoke Tests\n  Target: http://localhost:33989\n============================================\n\n--- Test 1: Health Check ---\n[PASS] GET /health returns 200 (HTTP 200)\n[PASS] Health response contains 'UP'\n\n--- Test 2: Root Endpoint ---\n[PASS] GET / returns 200 (HTTP 200)\n\n--- Test 3: Place Order (barista items) ---\n[FAIL] POST /api/order (barista) returns 202 (expected HTTP 202, got HTTP 500)\n\n--- Test 4: Place Order (kitchen items) ---\n[PASS] POST /api/order (kitchen) returns 202 (HTTP 202)\n\n--- Test 5: Place Order (mixed items) ---\n[PASS] POST /api/order (mixed) returns 202 (HTTP 202)\n\n--- Test 6: Send Message ---\n[PASS] POST /api/message returns 204 (HTTP 204)\n\n--- Test 7: Dashboard Stream ---\n[INFO] GET /dashboard/stream returned HTTP 000200 (SSE endpoint, may timeout)\n\n============================================\n  Results: 7 passed, 1 failed\n============================================","is_error":true,"tool_use_id":"toolu_bdrk_01NwpnpA48HyG4TXWdv1hNv8"}]},"parent_tool_use_id":null,"session_id":"55a9df99-a1b9-45b0-ac12-d337ab838722","uuid":"2732a30d-8b10-451b-a1a1-b33057af07e4"}
