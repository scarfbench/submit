<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="coffeeshop" transaction-type="JTA">
        <jta-data-source>jdbc/coffeeshop</jta-data-source>
        <class>io.quarkuscoffeeshop.coffeeshop.domain.Order</class>
        <class>io.quarkuscoffeeshop.coffeeshop.domain.LineItem</class>
        <class>io.quarkuscoffeeshop.coffeeshop.domain.InstantAttributeConverter</class>
        <class>io.quarkuscoffeeshop.coffeeshop.barista.domain.BaristaItem</class>
        <class>io.quarkuscoffeeshop.coffeeshop.kitchen.domain.KitchenOrder</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="eclipselink.target-database" value="org.eclipse.persistence.platform.database.H2Platform"/>
            <property name="eclipselink.logging.level" value="WARNING"/>
        </properties>
    </persistence-unit>
</persistence>
