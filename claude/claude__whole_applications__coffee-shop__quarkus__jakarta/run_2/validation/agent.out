        \", price=\" + price +\n    55→                \", itemStatus=\" + itemStatus +\n    56→                '}';\n    57→    }\n    58→\n    59→    @Override\n    60→    public boolean equals(Object o) {\n    61→        if (this == o) return true;\n    62→        if (o == null || getClass() != o.getClass()) return false;\n    63→\n    64→        LineItem lineItem = (LineItem) o;\n    65→\n    66→        if (order != null ? !order.equals(lineItem.order) : lineItem.order != null) return false;\n    67→        if (itemId != null ? !itemId.equals(lineItem.itemId) : lineItem.itemId != null) return false;\n    68→        if (item != lineItem.item) return false;\n    69→        if (name != null ? !name.equals(lineItem.name) : lineItem.name != null) return false;\n    70→        if (price != null ? !price.equals(lineItem.price) : lineItem.price != null) return false;\n    71→        return itemStatus == lineItem.itemStatus;\n    72→    }\n    73→\n    74→    @Override\n    75→    public int hashCode() {\n    76→        int result = order != null ? order.hashCode() : 0;\n    77→        result = 31 * result + (itemId != null ? itemId.hashCode() : 0);\n    78→        result = 31 * result + (item != null ? item.hashCode() : 0);\n    79→        result = 31 * result + (name != null ? name.hashCode() : 0);\n    80→        result = 31 * result + (price != null ? price.hashCode() : 0);\n    81→        result = 31 * result + (itemStatus != null ? itemStatus.hashCode() : 0);\n    82→        return result;\n    83→    }\n    84→\n    85→    public Order getOrder() {\n    86→        return order;\n    87→    }\n    88→\n    89→    public void setOrder(Order order) {\n    90→        this.order = order;\n    91→    }\n    92→\n    93→    public String getItemId() {\n    94→        return itemId;\n    95→    }\n    96→\n    97→    public void setItemId(String itemId) {\n    98→        this.itemId = itemId;\n    99→    }\n   100→\n   101→    public Item getItem() {\n   102→        return item;\n   103→    }\n   104→\n   105→    public void setItem(Item item) {\n   106→        this.item = item;\n   107→    }\n   108→\n   109→    public String getName() {\n   110→        return name;\n   111→    }\n   112→\n   113→    public void setName(String name) {\n   114→        this.name = name;\n   115→    }\n   116→\n   117→    public BigDecimal getPrice() {\n   118→        return price;\n   119→    }\n   120→\n   121→    public void setPrice(BigDecimal price) {\n   122→        this.price = price;\n   123→    }\n   124→\n   125→    public ItemStatus getItemStatus() {\n   126→        return itemStatus;\n   127→    }\n   128→\n   129→    public void setItemStatus(ItemStatus itemStatus) {\n   130→        this.itemStatus = itemStatus;\n   131→    }\n   132→}\n   133→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"fccccfb6-6c3c-4161-b41c-50ffcb4f1374","uuid":"55c61be2-b862-4ffe-825f-6eb7912fe188"}
