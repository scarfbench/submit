ardEndpoint.class);\n\n    @Inject\n    DashboardBroadcaster broadcaster;\n\n    @GET\n    @Path(\"/stream\")\n    @Produces(MediaType.SERVER_SENT_EVENTS)\n    public void dashboardStream(@Context SseEventSink eventSink, @Context Sse sse) {\n        LOGGER.debug(\"New SSE client connected\");\n        broadcaster.register(eventSink, sse);\n    }\n}"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":645,"cache_read_input_tokens":44871,"cache_creation":{"ephemeral_5m_input_tokens":645,"ephemeral_1h_input_tokens":0},"output_tokens":772},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01A2G3ceUgkrV7tVMLirmLgA","session_id":"fccccfb6-6c3c-4161-b41c-50ffcb4f1374","uuid":"afb24a3f-7e80-4f51-a836-717af7012928"}
