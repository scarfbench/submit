<?xml version="1.0" encoding="UTF-8"?>
<server description="Roster Application">

    <featureManager>
        <feature>jakartaee-10.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="8080"
                  httpsPort="9443" />

    <!-- H2 library shared across data sources -->
    <library id="h2Lib">
        <fileset dir="${server.config.dir}/lib" includes="h2*.jar"/>
    </library>

    <!-- In-memory H2 data source -->
    <dataSource id="DefaultDataSource" jndiName="jdbc/roster">
        <jdbcDriver libraryRef="h2Lib"/>
        <properties URL="jdbc:h2:mem:roster;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE"
                    user="sa"
                    password=""/>
    </dataSource>

    <webApplication location="roster-boot.war" contextRoot="/">
        <classloader commonLibraryRef="h2Lib"/>
    </webApplication>

</server>
