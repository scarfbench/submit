{"type":"user","message":{"role":"user","content":[{"type":"tool_result","content":"Exit code 1\nWaiting for server at http://localhost:34218 ...\nServer is ready!\n\n=== Smoke Tests ===\n\n  FAIL  create_league: POST /roster/league => 500, expected 200\n  PASS  get_league\n  PASS  create_team_in_league\n  PASS  get_team\n  PASS  get_teams_of_league\n  PASS  create_player\n  PASS  get_player\n  PASS  add_player_to_team\n  PASS  get_players_of_team\n  PASS  get_all_players\n  PASS  get_players_by_position\n  PASS  get_players_by_salary_range\n  PASS  get_players_by_league\n  PASS  get_players_by_sport\n  PASS  get_players_by_city\n  PASS  get_leagues_of_player\n  PASS  get_sports_of_player\n  PASS  create_second_player_not_on_team\n  PASS  get_players_not_on_team\n  PASS  get_players_by_position_and_name\n  PASS  get_players_higher_salary\n  PASS  drop_player_from_team\n  PASS  remove_player\n  PASS  remove_team\n  PASS  remove_league\n  PASS  winter_league\n  PASS  bad_sport_returns_400\n\n=== Results: 26 passed, 1 failed ===\n\nFailures:\n  - create_league: POST /roster/league => 500, expected 200","is_error":true,"tool_use_id":"toolu_bdrk_017p2T9uo8K6fwrRwswBQwaB"}]},"parent_tool_use_id":null,"session_id":"9366d3a9-49bd-4899-a76f-da6890618a7b","uuid":"06e44c53-556a-4a33-9af0-cb6eda5ead73"}
