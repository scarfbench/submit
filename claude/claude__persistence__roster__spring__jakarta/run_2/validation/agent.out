ar\n    45→\n    46→# Copy smoke test if present\n    47→COPY --from=build /app/smoke.py /app/smoke.py\n    48→RUN if [ -f /app/smoke.py ]; then chmod +x /app/smoke.py; fi\n    49→\n    50→EXPOSE 8080\n    51→\n    52→CMD [\"/opt/ol/wlp/bin/server\", \"run\", \"defaultServer\"]\n    53→"}]},"parent_tool_use_id":null,"session_id":"330ba2d4-1b8a-41b4-8954-1bf20c0cd90b","uuid":"8fc29de6-d6b6-462d-b843-d686e2f6009c"}
