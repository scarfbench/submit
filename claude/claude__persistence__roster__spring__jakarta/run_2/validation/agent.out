ouble high);\n\n    List<PlayerDetails> getPlayersBySport(String sport);\n\n    List<PlayerDetails> getPlayersNotOnTeam();\n\n    List<PlayerDetails> getPlayersOfTeam(String teamId);\n\n    List<String> getSportsOfPlayer(String playerId);\n\n    TeamDetails getTeam(String teamId);\n\n    List<TeamDetails> getTeamsOfLeague(String leagueId);\n\n    void removeLeague(String leagueId);\n\n    void removePlayer(String playerId);\n\n    void removeTeam(String teamId);\n\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":446,"cache_read_input_tokens":56092,"cache_creation":{"ephemeral_5m_input_tokens":446,"ephemeral_1h_input_tokens":0},"output_tokens":2698},"context_management":null},"parent_tool_use_id":null,"session_id":"330ba2d4-1b8a-41b4-8954-1bf20c0cd90b","uuid":"bfed66cb-1b07-45ce-8502-334f6acc64b4"}
