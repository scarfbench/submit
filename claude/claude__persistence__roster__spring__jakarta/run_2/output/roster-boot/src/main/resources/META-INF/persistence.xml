<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="roster-pu" transaction-type="JTA">
        <jta-data-source>jdbc/rosterDS</jta-data-source>
        <class>jakartaee.tutorial.roster.entity.League</class>
        <class>jakartaee.tutorial.roster.entity.SummerLeague</class>
        <class>jakartaee.tutorial.roster.entity.WinterLeague</class>
        <class>jakartaee.tutorial.roster.entity.Team</class>
        <class>jakartaee.tutorial.roster.entity.Player</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="eclipselink.logging.level" value="FINE"/>
        </properties>
    </persistence-unit>
</persistence>
