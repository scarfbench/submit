# WildFly CLI script to configure H2 datasource
embed-server --std-out=echo

# Configure datasource
/subsystem=datasources/data-source=PetClinicDS:add(jndi-name=java:jboss/datasources/PetClinicDS, connection-url="jdbc:h2:mem:petclinic;DB_CLOSE_DELAY=-1", driver-name=h2, user-name=sa, password=sa)

stop-embedded-server
