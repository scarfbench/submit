<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="petclinic" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/PetClinicDS</jta-data-source>

        <class>org.jakarta.samples.petclinic.owner.Owner</class>
        <class>org.jakarta.samples.petclinic.owner.Pet</class>
        <class>org.jakarta.samples.petclinic.owner.PetType</class>
        <class>org.jakarta.samples.petclinic.vet.Vet</class>
        <class>org.jakarta.samples.petclinic.vet.Specialty</class>
        <class>org.jakarta.samples.petclinic.visit.Visit</class>

        <properties>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
        </properties>
    </persistence-unit>
</persistence>
