Controller\n    35→@RequestMapping(\"/roster\")\n    36→public class RequestBean implements Request, Serializable {\n    37→    private static final Logger logger = Logger.getLogger(\"quarkus.tutorial.roster.request.RequestBean\");\n    38→\n    39→    @PersistenceContext\n    40→    private EntityManager em;\n    41→    private CriteriaBuilder cb;\n    42→\n    43→    @PostConstruct\n    44→    private void init() {\n    45→        cb = em.getCriteriaBuilder();\n    46→    }\n    47→\n    48→    @Override\n    49→    @PostMapping(value = \"/player\", consumes = MediaType.APPLICATION_FORM_URLENCODED_VALUE,\n    50→            produces = MediaType.APPLICATION_JSON_VALUE)\n    51→    @Transactional\n    52→    public void createPlayer(\n    53→            @RequestParam(\"id\") String id,\n    54→            @RequestParam(\"name\") String name,\n    55→            @RequestParam(\"position\") String position,\n    56→            @RequestParam(\"salary\") double salary) {\n    57→        logger.info(\"createPlayer\");\n    58→        try {\n    59→            Player player = new Player(id, name, position, salary);\n    60→            em.persist(player);\n    61→            em.flush();\n    62→        } catch (Exception ex) {\n    63→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    64→        }\n    65→    }\n    66→\n    67→    @Override\n    68→    @PostMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    69→    @Transactional\n    70→    public void addPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n    71→        logger.info(\"addPlayer\");\n    72→        try {\n    73→            Player player = em.find(Player.class, playerId);\n    74→            Team team = em.find(Team.class, teamId);\n    75→            if (player == null || team == null) {\n    76→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n    77→            }\n    78→            team.addPlayer(player);\n    79→            player.addTeam(team);\n    80→            em.merge(player);\n    81→            em.merge(team);\n    82→            em.flush();\n    83→        } catch (ResponseStatusException ex) {\n    84→            throw ex;\n    85→        } catch (Exception ex) {\n    86→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    87→        }\n    88→    }\n    89→\n    90→    @Override\n    91→    @DeleteMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    92→    @Transactional\n    93→    public void removePlayer(@PathVariable(\"playerId\") String playerId) {\n    94→        logger.info(\"removePlayer\");\n    95→        try {\n    96→            Player player = em.find(Player.class, playerId);\n    97→            if (player == null) {\n    98→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n    99→            }\n   100→            Collection<Team> teams = player.getTeams();\n   101→            for (Team team : teams) {\n   102→                team.dropPlayer(player);\n   103→            }\n   104→            em.remove(player);\n   105→            em.flush();\n   106→        } catch (ResponseStatusException ex) {\n   107→            throw ex;\n   108→        } catch (Exception ex) {\n   109→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   110→        }\n   111→    }\n   112→\n   113→    @Override\n   114→    @DeleteMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   115→    @Transactional\n   116→    public void dropPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n   117→        logger.info(\"dropPlayer\");\n   118→        try {\n   119→            Player player = em.find(Player.class, playerId);\n   120→            Team team = em.find(Team.class, teamId);\n   121→            if (player == null || team == null) {\n   122→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n   123→            }\n   124→            team.dropPlayer(player);\n   125→            player.dropTeam(team);\n   126→            em.merge(player);\n   127→            em.merge(team);\n   128→            em.flush();\n   129→        } catch (ResponseStatusException ex) {\n   130→            throw ex;\n   131→        } catch (Exception ex) {\n   132→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   133→        }\n   134→    }\n   135→\n   136→    @Override\n   137→    @GetMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   138→    public PlayerDetails getPlayer(@PathVariable(\"playerId\") String playerId) {\n   139→        logger.info(\"getPlayerDetails\");\n   140→        try {\n   141→            Player player = em.find(Player.class, playerId);\n   142→            if (player == null) {\n   143→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n   144→            }\n   145→            return new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary());\n   146→        } catch (ResponseStatusException ex) {\n   147→            throw ex;\n   148→        } catch (Exception ex) {\n   149→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   150→        }\n   151→    }\n   152→\n   153→    @Override\n   154→    @GetMapping(value = \"/team/{teamId}/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   155→    @Transactional(readOnly = true)\n   156→    public List<PlayerDetails> getPlayersOfTeam(@PathVariable(\"teamId\") String teamId) {\n   157→        logger.info(\"getPlayersOfTeam\");\n   158→        try {\n   159→            Team team = em.find(Team.class, teamId);\n   160→            if (team == null) {\n   161→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   162→            }\n   163→            return copyPlayersToDetails(new ArrayList<>(team.getPlayers()));\n   164→        } catch (ResponseStatusException ex) {\n   165→            throw ex;\n   166→        } catch (Exception ex) {\n   167→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   168→        }\n   169→    }\n   170→\n   171→    @Override\n   172→    @GetMapping(value = \"/league/{leagueId}/teams\", produces = MediaType.APPLICATION_JSON_VALUE)\n   173→    @Transactional(readOnly = true)\n   174→    public List<TeamDetails> getTeamsOfLeague(@PathVariable(\"leagueId\") String leagueId) {\n   175→        logger.info(\"getTeamsOfLeague\");\n   176→        List<TeamDetails> detailsList = new ArrayList<>();\n   177→        try {\n   178→            League league = em.find(League.class, leagueId);\n   179→            if (league == null) {\n   180→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   181→            }\n   182→            for (Team team : league.getTeams()) {\n   183→                detailsList.add(new TeamDetails(team.getId(), team.getName(), team.getCity()));\n   184→            }\n   185→            return detailsList;\n   186→        } catch (ResponseStatusException ex) {\n   187→            throw ex;\n   188→        } catch (Exception ex) {\n   189→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   190→        }\n   191→    }\n   192→\n   193→    @Override\n   194→    @GetMapping(value = \"/players/position/{position}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   195→    @Transactional(readOnly = true)\n   196→    public List<PlayerDetails> getPlayersByPosition(@PathVariable(\"position\") String position) {\n   197→        logger.info(\"getPlayersByPosition\");\n   198→        try {\n   199→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   200→            Root<Player> player = cq.from(Player.class);\n   201→            cq.where(cb.equal(player.get(\"position\"), position));\n   202→            cq.select(player);\n   203→            TypedQuery<Player> q = em.createQuery(cq);\n   204→            List<Player> players = q.getResultList();\n   205→            return copyPlayersToDetails(players);\n   206→        } catch (Exception ex) {\n   207→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   208→        }\n   209→    }\n   210→\n   211→    @Override\n   212→    @GetMapping(value = \"/players/salary/higher/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   213→    @Transactional(readOnly = true)\n   214→    public List<PlayerDetails> getPlayersByHigherSalary(@PathVariable(\"name\") String name) {\n   215→        logger.info(\"getPlayersByHigherSalary\");\n   216→        try {\n   217→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   218→            Root<Player> player1 = cq.from(Player.class);\n   219→            Root<Player> player2 = cq.from(Player.class);\n   220→            Predicate gtPredicate = cb.greaterThan(player1.get(\"salary\"), player2.get(\"salary\"));\n   221→            Predicate equalPredicate = cb.equal(player2.get(\"name\"), name);\n   222→            cq.where(gtPredicate, equalPredicate);\n   223→            cq.select(player1).distinct(true);\n   224→            TypedQuery<Player> q = em.createQuery(cq);\n   225→            List<Player> players = q.getResultList();\n   226→            return copyPlayersToDetails(players);\n   227→        } catch (Exception ex) {\n   228→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   229→        }\n   230→    }\n   231→\n   232→    @Override\n   233→    @GetMapping(value = \"/players/salary/range\", produces = MediaType.APPLICATION_JSON_VALUE)\n   234→    @Transactional(readOnly = true)\n   235→    public List<PlayerDetails> getPlayersBySalaryRange(@RequestParam(\"low\") double low, @RequestParam(\"high\") double high) {\n   236→        logger.info(\"getPlayersBySalaryRange\");\n   237→        try {\n   238→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   239→            Root<Player> player = cq.from(Player.class);\n   240→            cq.where(cb.between(player.get(\"salary\"), low, high));\n   241→            cq.select(player).distinct(true);\n   242→            TypedQuery<Player> q = em.createQuery(cq);\n   243→            List<Player> players = q.getResultList();\n   244→            return copyPlayersToDetails(players);\n   245→        } catch (Exception ex) {\n   246→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   247→        }\n   248→    }\n   249→\n   250→    @Override\n   251→    @GetMapping(value = \"/players/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   252→    @Transactional(readOnly = true)\n   253→    public List<PlayerDetails> getPlayersByLeagueId(@PathVariable(\"leagueId\") String leagueId) {\n   254→        logger.info(\"getPlayersByLeagueId\");\n   255→        try {\n   256→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   257→            Root<Player> player = cq.from(Player.class);\n   258→            Join<Player, Team> team = player.join(\"teams\");\n   259→            Join<Team, League> league = team.join(\"league\");\n   260→            cq.where(cb.equal(league.get(\"id\"), leagueId));\n   261→            cq.select(player).distinct(true);\n   262→            TypedQuery<Player> q = em.createQuery(cq);\n   263→            List<Player> players = q.getResultList();\n   264→            return copyPlayersToDetails(players);\n   265→        } catch (Exception ex) {\n   266→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   267→        }\n   268→    }\n   269→\n   270→    @Override\n   271→    @GetMapping(value = \"/players/sport/{sport}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   272→    @Transactional(readOnly = true)\n   273→    public List<PlayerDetails> getPlayersBySport(@PathVariable(\"sport\") String sport) {\n   274→        logger.info(\"getPlayersBySport\");\n   275→        try {\n   276→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   277→            Root<Player> player = cq.from(Player.class);\n   278→            Join<Player, Team> team = player.join(\"teams\");\n   279→            Join<Team, League> league = team.join(\"league\");\n   280→            cq.where(cb.equal(league.get(\"sport\"), sport));\n   281→            cq.select(player).distinct(true);\n   282→            TypedQuery<Player> q = em.createQuery(cq);\n   283→            List<Player> players = q.getResultList();\n   284→            return copyPlayersToDetails(players);\n   285→        } catch (Exception ex) {\n   286→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   287→        }\n   288→    }\n   289→\n   290→    @Override\n   291→    @GetMapping(value = \"/players/city/{city}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   292→    @Transactional(readOnly = true)\n   293→    public List<PlayerDetails> getPlayersByCity(@PathVariable(\"city\") String city) {\n   294→        logger.info(\"getPlayersByCity\");\n   295→        try {\n   296→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   297→            Root<Player> player = cq.from(Player.class);\n   298→            Join<Player, Team> team = player.join(\"teams\");\n   299→            cq.where(cb.equal(team.get(\"city\"), city));\n   300→            cq.select(player).distinct(true);\n   301→            TypedQuery<Player> q = em.createQuery(cq);\n   302→            List<Player> players = q.getResultList();\n   303→            return copyPlayersToDetails(players);\n   304→        } catch (Exception ex) {\n   305→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   306→        }\n   307→    }\n   308→\n   309→    @Override\n   310→    @GetMapping(value = \"/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   311→    @Transactional(readOnly = true)\n   312→    public List<PlayerDetails> getAllPlayers() {\n   313→        logger.info(\"getAllPlayers\");\n   314→        try {\n   315→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   316→            Root<Player> player = cq.from(Player.class);\n   317→            cq.select(player);\n   318→            TypedQuery<Player> q = em.createQuery(cq);\n   319→            List<Player> players = q.getResultList();\n   320→            return copyPlayersToDetails(players);\n   321→        } catch (Exception ex) {\n   322→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   323→        }\n   324→    }\n   325→\n   326→    @Override\n   327→    @GetMapping(value = \"/players/not-on-team\", produces = MediaType.APPLICATION_JSON_VALUE)\n   328→    @Transactional(readOnly = true)\n   329→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   330→        logger.info(\"getPlayersNotOnTeam\");\n   331→        try {\n   332→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   333→            Root<Player> player = cq.from(Player.class);\n   334→            cq.where(cb.isEmpty(player.get(\"teams\")));\n   335→            cq.select(player).distinct(true);\n   336→            TypedQuery<Player> q = em.createQuery(cq);\n   337→            List<Player> players = q.getResultList();\n   338→            return copyPlayersToDetails(players);\n   339→        } catch (Exception ex) {\n   340→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   341→        }\n   342→    }\n   343→\n   344→    @Override\n   345→    @GetMapping(value = \"/players/position/{position}/name/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   346→    @Transactional(readOnly = true)\n   347→    public List<PlayerDetails> getPlayersByPositionAndName(\n   348→            @PathVariable(\"position\") String position,\n   349→            @PathVariable(\"name\") String name) {\n   350→        logger.info(\"getPlayersByPositionAndName\");\n   351→        try {\n   352→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   353→            Root<Player> player = cq.from(Player.class);\n   354→            cq.where(cb.equal(player.get(\"position\"), position),\n   355→                    cb.equal(player.get(\"name\"), name));\n   356→            cq.select(player).distinct(true);\n   357→            TypedQuery<Player> q = em.createQuery(cq);\n   358→            List<Player> players = q.getResultList();\n   359→            return copyPlayersToDetails(players);\n   360→        } catch (Exception ex) {\n   361→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   362→        }\n   363→    }\n   364→\n   365→    @Override\n   366→    @GetMapping(value = \"/player/{playerId}/leagues\", produces = MediaType.APPLICATION_JSON_VALUE)\n   367→    @Transactional(readOnly = true)\n   368→    public List<LeagueDetails> getLeaguesOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   369→        logger.info(\"getLeaguesOfPlayer\");\n   370→        List<LeagueDetails> detailsList = new ArrayList<>();\n   371→        try {\n   372→            CriteriaQuery<League> cq = cb.createQuery(League.class);\n   373→            Root<League> leagueRoot = cq.from(League.class);\n   374→            Join<League, Team> team = leagueRoot.join(\"teams\");\n   375→            Join<Team, Player> player = team.join(\"players\");\n   376→            cq.where(cb.equal(player.get(\"id\"), playerId));\n   377→            cq.select(leagueRoot).distinct(true);\n   378→            TypedQuery<League> q = em.createQuery(cq);\n   379→            List<League> leagues = q.getResultList();\n   380→            if (leagues == null || leagues.isEmpty()) {\n   381→                logger.warning(\"No leagues found for player with ID \" + playerId);\n   382→                return null;\n   383→            }\n   384→            for (League currentLeague : leagues) {\n   385→                detailsList.add(new LeagueDetails(currentLeague.getId(), currentLeague.getName(), currentLeague.getSport()));\n   386→            }\n   387→            return detailsList;\n   388→        } catch (Exception ex) {\n   389→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   390→        }\n   391→    }\n   392→\n   393→    @Override\n   394→    @GetMapping(value = \"/player/{playerId}/sports\", produces = MediaType.APPLICATION_JSON_VALUE)\n   395→    @Transactional(readOnly = true)\n   396→    public List<String> getSportsOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   397→        logger.info(\"getSportsOfPlayer\");\n   398→        try {\n   399→            CriteriaQuery<String> cq = cb.createQuery(String.class);\n   400→            Root<Player> player = cq.from(Player.class);\n   401→            Join<Player, Team> team = player.join(\"teams\");\n   402→            Join<Team, League> league = team.join(\"league\");\n   403→            cq.where(cb.equal(player.get(\"id\"), playerId));\n   404→            cq.select(league.get(\"sport\")).distinct(true);\n   405→            TypedQuery<String> q = em.createQuery(cq);\n   406→            return q.getResultList();\n   407→        } catch (Exception ex) {\n   408→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   409→        }\n   410→    }\n   411→\n   412→    @Override\n   413→    @PostMapping(value = \"/team/league/{leagueId}\", consumes = MediaType.APPLICATION_JSON_VALUE,\n   414→            produces = MediaType.APPLICATION_JSON_VALUE)\n   415→    @Transactional\n   416→    public void createTeamInLeague(@RequestBody TeamDetails teamDetails, @PathVariable(\"leagueId\") String leagueId) {\n   417→        logger.info(\"createTeamInLeague\");\n   418→        try {\n   419→            League league = em.find(League.class, leagueId);\n   420→            if (league == null) {\n   421→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   422→            }\n   423→            Team team = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   424→            em.persist(team);\n   425→            team.setLeague(league);\n   426→            league.addTeam(team);\n   427→            em.merge(league);\n   428→            em.flush();\n   429→        } catch (ResponseStatusException ex) {\n   430→            throw ex;\n   431→        } catch (Exception ex) {\n   432→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   433→        }\n   434→    }\n   435→\n   436→    @Override\n   437→    @DeleteMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   438→    @Transactional\n   439→    public void removeTeam(@PathVariable(\"teamId\") String teamId) {\n   440→        logger.info(\"removeTeam\");\n   441→        try {\n   442→            Team team = em.find(Team.class, teamId);\n   443→            if (team == null) {\n   444→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   445→            }\n   446→            for (Player player : team.getPlayers()) {\n   447→                player.dropTeam(team);\n   448→                em.merge(player);\n   449→            }\n   450→            em.remove(team);\n   451→            em.flush();\n   452→        } catch (ResponseStatusException ex) {\n   453→            throw ex;\n   454→        } catch (Exception ex) {\n   455→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   456→        }\n   457→    }\n   458→\n   459→    @Override\n   460→    @GetMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   461→    public TeamDetails getTeam(@PathVariable(\"teamId\") String teamId) {\n   462→        logger.info(\"getTeam\");\n   463→        try {\n   464→            Team team = em.find(Team.class, teamId);\n   465→            if (team == null) {\n   466→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   467→            }\n   468→            return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   469→        } catch (ResponseStatusException ex) {\n   470→            throw ex;\n   471→        } catch (Exception ex) {\n   472→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   473→        }\n   474→    }\n   475→\n   476→    @Override\n   477→    @PostMapping(value = \"/league\", consumes = MediaType.APPLICATION_JSON_VALUE,\n   478→            produces = MediaType.APPLICATION_JSON_VALUE)\n   479→    @Transactional\n   480→    public void createLeague(@RequestBody LeagueDetails leagueDetails) {\n   481→        logger.info(\"createLeague\");\n   482→        try {\n   483→            String sport = leagueDetails.getSport().toLowerCase();\n   484→            if (sport.equals(\"soccer\") || sport.equals(\"swimming\") || sport.equals(\"basketball\") || sport.equals(\"baseball\")) {\n   485→                SummerLeague league = new SummerLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   486→                em.persist(league);\n   487→                em.flush();\n   488→            } else if (sport.equals(\"hockey\") || sport.equals(\"skiing\") || sport.equals(\"snowboarding\")) {\n   489→                WinterLeague league = new WinterLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   490→                em.persist(league);\n   491→                em.flush();\n   492→            } else {\n   493→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   494→            }\n   495→        } catch (Exception ex) {\n   496→            throw new ResponseStatusException(HttpStatus.BAD_REQUEST, ex.getMessage(), ex);\n   497→        }\n   498→    }\n   499→\n   500→    @Override\n   501→    @DeleteMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   502→    @Transactional\n   503→    public void removeLeague(@PathVariable(\"leagueId\") String leagueId) {\n   504→        logger.info(\"removeLeague\");\n   505→        try {\n   506→            League league = em.find(League.class, leagueId);\n   507→            if (league == null) {\n   508→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   509→            }\n   510→            em.remove(league);\n   511→            em.flush();\n   512→        } catch (ResponseStatusException ex) {\n   513→            throw ex;\n   514→        } catch (Exception ex) {\n   515→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   516→        }\n   517→    }\n   518→\n   519→    @Override\n   520→    @GetMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   521→    public LeagueDetails getLeague(@PathVariable(\"leagueId\") String leagueId) {\n   522→        logger.info(\"getLeague\");\n   523→        try {\n   524→            League league = em.find(League.class, leagueId);\n   525→            if (league == null) {\n   526→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   527→            }\n   528→            return new LeagueDetails(league.getId(), league.getName(), league.getSport());\n   529→        } catch (ResponseStatusException ex) {\n   530→            throw ex;\n   531→        } catch (Exception ex) {\n   532→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   533→        }\n   534→    }\n   535→\n   536→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   537→        List<PlayerDetails> detailsList = new ArrayList<>();\n   538→        for (Player player : players) {\n   539→            detailsList.add(new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary()));\n   540→        }\n   541→        return detailsList;\n   542→    }\n   543→}\n   544→"}]},"parent_tool_use_id":null,"session_id":"28b9fbcd-f273-4b6e-b315-c50121e535b0","uuid":"97774114-8d40-4d1b-b1a5-7e3fb322e7f5"}
