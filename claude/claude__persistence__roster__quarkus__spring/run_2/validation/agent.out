roupId>io.netty</groupId>\n    35→                <artifactId>netty-handler</artifactId>\n    36→                <version>4.1.130.Final</version>\n    37→            </dependency>\n    38→\n    39→            <!-- Fix Vert.x CVEs -->\n    40→            <dependency>\n    41→                <groupId>io.vertx</groupId>\n    42→                <artifactId>vertx-web</artifactId>\n    43→                <version>4.5.23</version>  <!-- Latest, or 4.5.22 minimum -->\n    44→            </dependency>\n    45→            <dependency>\n    46→                <groupId>io.vertx</groupId>\n    47→                <artifactId>vertx-web-common</artifactId>\n    48→                <version>4.5.23</version>\n    49→            </dependency>\n    50→            <dependency>\n    51→                <groupId>${quarkus.platform.group-id}</groupId>\n    52→                <artifactId>${quarkus.platform.artifact-id}</artifactId>\n    53→                <version>${quarkus.platform.version}</version>\n    54→                <type>pom</type>\n    55→                <scope>import</scope>\n    56→            </dependency>\n    57→        </dependencies>\n    58→    </dependencyManagement>\n    59→\n    60→    <dependencies>\n    61→        <dependency>\n    62→            <groupId>io.quarkus</groupId>\n    63→            <artifactId>quarkus-hibernate-orm</artifactId>\n    64→        </dependency>\n    65→        <dependency>\n    66→            <groupId>io.quarkus</groupId>\n    67→            <artifactId>quarkus-jdbc-h2</artifactId>\n    68→        </dependency>\n    69→        <dependency>\n    70→            <groupId>io.quarkus</groupId>\n    71→            <artifactId>quarkus-smallrye-health</artifactId>\n    72→        </dependency>\n    73→        <dependency>\n    74→            <groupId>io.quarkus</groupId>\n    75→            <artifactId>quarkus-arc</artifactId>\n    76→        </dependency>\n    77→        <dependency>\n    78→            <groupId>org.hibernate</groupId>\n    79→     