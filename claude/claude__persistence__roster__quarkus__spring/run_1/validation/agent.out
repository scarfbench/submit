 32→import java.util.ArrayList;\n    33→import java.util.Collection;\n    34→import java.util.List;\n    35→import java.util.logging.Logger;\n    36→\n    37→@RestController\n    38→@RequestMapping(\"/roster\")\n    39→public class RequestBean implements Request, Serializable {\n    40→    private static final Logger logger = Logger.getLogger(\"quarkus.tutorial.roster.request.RequestBean\");\n    41→\n    42→    @PersistenceContext\n    43→    private EntityManager em;\n    44→    private CriteriaBuilder cb;\n    45→\n    46→    @PostConstruct\n    47→    private void init() {\n    48→        cb = em.getCriteriaBuilder();\n    49→    }\n    50→\n    51→    @Override\n    52→    @PostMapping(value = \"/player\", consumes = MediaType.APPLICATION_FORM_URLENCODED_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n    53→    @Transactional\n    54→    public void createPlayer(\n    55→            @RequestParam(\"id\") String id,\n    56→            @RequestParam(\"name\") String name,\n    57→            @RequestParam(\"position\") String position,\n    58→            @RequestParam(\"salary\") double salary) {\n    59→        logger.info(\"createPlayer\");\n    60→        try {\n    61→            Player player = new Player(id, name, position, salary);\n    62→            em.persist(player);\n    63→            em.flush();\n    64→        } catch (Exception ex) {\n    65→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    66→        }\n    67→    }\n    68→\n    69→    @Override\n    70→    @PostMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    71→    @Transactional\n    72→    public void addPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n    73→        logger.info(\"addPlayer\");\n    74→        try {\n    75→            Player player = em.find(Player.class, playerId);\n    76→            Team team = em.find(Team.class, teamId);\n    77→            if (player == null || team == null) {\n    78→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n    79→            }\n    80→            team.addPlayer(player);\n    81→            player.addTeam(team);\n    82→            em.merge(player);\n    83→            em.merge(team);\n    84→            em.flush();\n    85→        } catch (ResponseStatusException ex) {\n    86→            throw ex;\n    87→        } catch (Exception ex) {\n    88→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    89→        }\n    90→    }\n    91→\n    92→    @Override\n    93→    @DeleteMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    94→    @Transactional\n    95→    public void removePlayer(@PathVariable(\"playerId\") String playerId) {\n    96→        logger.info(\"removePlayer\");\n    97→        try {\n    98→            Player player = em.find(Player.class, playerId);\n    99→            if (player == null) {\n   100→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n   101→            }\n   102→            Collection<Team> teams = player.getTeams();\n   103→            for (Team team : teams) {\n   104→                team.dropPlayer(player);\n   105→            }\n   106→            em.remove(player);\n   107→            em.flush();\n   108→        } catch (ResponseStatusException ex) {\n   109→            throw ex;\n   110→        } catch (Exception ex) {\n   111→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   112→        }\n   113→    }\n   114→\n   115→    @Override\n   116→    @DeleteMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   117→    @Transactional\n   118→    public void dropPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n   119→        logger.info(\"dropPlayer\");\n   120→        try {\n   121→            Player player = em.find(Player.class, playerId);\n   122→            Team team = em.find(Team.class, teamId);\n   123→            if (player == null || team == null) {\n   124→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n   125→            }\n   126→            team.dropPlayer(player);\n   127→            player.dropTeam(team);\n   128→            em.merge(player);\n   129→            em.merge(team);\n   130→            em.flush();\n   131→        } catch (ResponseStatusException ex) {\n   132→            throw ex;\n   133→        } catch (Exception ex) {\n   134→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   135→        }\n   136→    }\n   137→\n   138→    @Override\n   139→    @GetMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   140→    public PlayerDetails getPlayer(@PathVariable(\"playerId\") String playerId) {\n   141→        logger.info(\"getPlayerDetails\");\n   142→        try {\n   143→            Player player = em.find(Player.class, playerId);\n   144→            if (player == null) {\n   145→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n   146→            }\n   147→            return new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary());\n   148→        } catch (ResponseStatusException ex) {\n   149→            throw ex;\n   150→        } catch (Exception ex) {\n   151→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   152→        }\n   153→    }\n   154→\n   155→    @Override\n   156→    @GetMapping(value = \"/team/{teamId}/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   157→    @Transactional(readOnly = true)\n   158→    public List<PlayerDetails> getPlayersOfTeam(@PathVariable(\"teamId\") String teamId) {\n   159→        logger.info(\"getPlayersOfTeam\");\n   160→        try {\n   161→            Team team = em.find(Team.class, teamId);\n   162→            if (team == null) {\n   163→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   164→            }\n   165→            return copyPlayersToDetails(new ArrayList<>(team.getPlayers()));\n   166→        } catch (ResponseStatusException ex) {\n   167→            throw ex;\n   168→        } catch (Exception ex) {\n   169→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   170→        }\n   171→    }\n   172→\n   173→    @Override\n   174→    @GetMapping(value = \"/league/{leagueId}/teams\", produces = MediaType.APPLICATION_JSON_VALUE)\n   175→    @Transactional(readOnly = true)\n   176→    public List<TeamDetails> getTeamsOfLeague(@PathVariable(\"leagueId\") String leagueId) {\n   177→        logger.info(\"getTeamsOfLeague\");\n   178→        List<TeamDetails> detailsList = new ArrayList<>();\n   179→        try {\n   180→            League league = em.find(League.class, leagueId);\n   181→            if (league == null) {\n   182→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   183→            }\n   184→            for (Team team : league.getTeams()) {\n   185→                detailsList.add(new TeamDetails(team.getId(), team.getName(), team.getCity()));\n   186→            }\n   187→            return detailsList;\n   188→        } catch (ResponseStatusException ex) {\n   189→            throw ex;\n   190→        } catch (Exception ex) {\n   191→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   192→        }\n   193→    }\n   194→\n   195→    @Override\n   196→    @GetMapping(value = \"/players/position/{position}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   197→    public List<PlayerDetails> getPlayersByPosition(@PathVariable(\"position\") String position) {\n   198→        logger.info(\"getPlayersByPosition\");\n   199→        try {\n   200→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   201→            Root<Player> player = cq.from(Player.class);\n   202→            cq.where(cb.equal(player.get(Player_.position), position));\n   203→            cq.select(player);\n   204→            TypedQuery<Player> q = em.createQuery(cq);\n   205→            List<Player> players = q.getResultList();\n   206→            return copyPlayersToDetails(players);\n   207→        } catch (Exception ex) {\n   208→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   209→        }\n   210→    }\n   211→\n   212→    @Override\n   213→    @GetMapping(value = \"/players/salary/higher/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   214→    public List<PlayerDetails> getPlayersByHigherSalary(@PathVariable(\"name\") String name) {\n   215→        logger.info(\"getPlayersByHigherSalary\");\n   216→        try {\n   217→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   218→            Root<Player> player1 = cq.from(Player.class);\n   219→            Root<Player> player2 = cq.from(Player.class);\n   220→            Predicate gtPredicate = cb.greaterThan(player1.get(Player_.salary), player2.get(Player_.salary));\n   221→            Predicate equalPredicate = cb.equal(player2.get(Player_.name), name);\n   222→            cq.where(gtPredicate, equalPredicate);\n   223→            cq.select(player1).distinct(true);\n   224→            TypedQuery<Player> q = em.createQuery(cq);\n   225→            List<Player> players = q.getResultList();\n   226→            return copyPlayersToDetails(players);\n   227→        } catch (Exception ex) {\n   228→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   229→        }\n   230→    }\n   231→\n   232→    @Override\n   233→    @GetMapping(value = \"/players/salary/range\", produces = MediaType.APPLICATION_JSON_VALUE)\n   234→    public List<PlayerDetails> getPlayersBySalaryRange(@RequestParam(\"low\") double low, @RequestParam(\"high\") double high) {\n   235→        logger.info(\"getPlayersBySalaryRange\");\n   236→        try {\n   237→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   238→            Root<Player> player = cq.from(Player.class);\n   239→            cq.where(cb.between(player.get(Player_.salary), low, high));\n   240→            cq.select(player).distinct(true);\n   241→            TypedQuery<Player> q = em.createQuery(cq);\n   242→            List<Player> players = q.getResultList();\n   243→            return copyPlayersToDetails(players);\n   244→        } catch (Exception ex) {\n   245→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   246→        }\n   247→    }\n   248→\n   249→    @Override\n   250→    @GetMapping(value = \"/players/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   251→    @Transactional(readOnly = true)\n   252→    public List<PlayerDetails> getPlayersByLeagueId(@PathVariable(\"leagueId\") String leagueId) {\n   253→        logger.info(\"getPlayersByLeagueId\");\n   254→        try {\n   255→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   256→            Root<Player> player = cq.from(Player.class);\n   257→            Join<Player, Team> team = player.join(Player_.teams);\n   258→            Join<Team, League> league = team.join(Team_.league);\n   259→            cq.where(cb.equal(league.get(League_.id), leagueId));\n   260→            cq.select(player).distinct(true);\n   261→            TypedQuery<Player> q = em.createQuery(cq);\n   262→            List<Player> players = q.getResultList();\n   263→            return copyPlayersToDetails(players);\n   264→        } catch (Exception ex) {\n   265→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   266→        }\n   267→    }\n   268→\n   269→    @Override\n   270→    @GetMapping(value = \"/players/sport/{sport}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   271→    public List<PlayerDetails> getPlayersBySport(@PathVariable(\"sport\") String sport) {\n   272→        logger.info(\"getPlayersBySport\");\n   273→        try {\n   274→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   275→            Root<Player> player = cq.from(Player.class);\n   276→            Join<Player, Team> team = player.join(Player_.teams);\n   277→            Join<Team, League> league = team.join(Team_.league);\n   278→            cq.where(cb.equal(league.get(League_.sport), sport));\n   279→            cq.select(player).distinct(true);\n   280→            TypedQuery<Player> q = em.createQuery(cq);\n   281→            List<Player> players = q.getResultList();\n   282→            return copyPlayersToDetails(players);\n   283→        } catch (Exception ex) {\n   284→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   285→        }\n   286→    }\n   287→\n   288→    @Override\n   289→    @GetMapping(value = \"/players/city/{city}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   290→    public List<PlayerDetails> getPlayersByCity(@PathVariable(\"city\") String city) {\n   291→        logger.info(\"getPlayersByCity\");\n   292→        try {\n   293→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   294→            Root<Player> player = cq.from(Player.class);\n   295→            Join<Player, Team> team = player.join(Player_.teams);\n   296→            cq.where(cb.equal(team.get(Team_.city), city));\n   297→            cq.select(player).distinct(true);\n   298→            TypedQuery<Player> q = em.createQuery(cq);\n   299→            List<Player> players = q.getResultList();\n   300→            return copyPlayersToDetails(players);\n   301→        } catch (Exception ex) {\n   302→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   303→        }\n   304→    }\n   305→\n   306→    @Override\n   307→    @GetMapping(value = \"/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   308→    public List<PlayerDetails> getAllPlayers() {\n   309→        logger.info(\"getAllPlayers\");\n   310→        try {\n   311→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   312→            Root<Player> player = cq.from(Player.class);\n   313→            cq.select(player);\n   314→            TypedQuery<Player> q = em.createQuery(cq);\n   315→            List<Player> players = q.getResultList();\n   316→            return copyPlayersToDetails(players);\n   317→        } catch (Exception ex) {\n   318→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   319→        }\n   320→    }\n   321→\n   322→    @Override\n   323→    @GetMapping(value = \"/players/not-on-team\", produces = MediaType.APPLICATION_JSON_VALUE)\n   324→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   325→        logger.info(\"getPlayersNotOnTeam\");\n   326→        try {\n   327→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   328→            Root<Player> player = cq.from(Player.class);\n   329→            cq.where(cb.isEmpty(player.get(Player_.teams)));\n   330→            cq.select(player).distinct(true);\n   331→            TypedQuery<Player> q = em.createQuery(cq);\n   332→            List<Player> players = q.getResultList();\n   333→            return copyPlayersToDetails(players);\n   334→        } catch (Exception ex) {\n   335→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   336→        }\n   337→    }\n   338→\n   339→    @Override\n   340→    @GetMapping(value = \"/players/position/{position}/name/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   341→    public List<PlayerDetails> getPlayersByPositionAndName(\n   342→            @PathVariable(\"position\") String position,\n   343→            @PathVariable(\"name\") String name) {\n   344→        logger.info(\"getPlayersByPositionAndName\");\n   345→        try {\n   346→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   347→            Root<Player> player = cq.from(Player.class);\n   348→            cq.where(cb.equal(player.get(Player_.position), position),\n   349→                    cb.equal(player.get(Player_.name), name));\n   350→            cq.select(player).distinct(true);\n   351→            TypedQuery<Player> q = em.createQuery(cq);\n   352→            List<Player> players = q.getResultList();\n   353→            return copyPlayersToDetails(players);\n   354→        } catch (Exception ex) {\n   355→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   356→        }\n   357→    }\n   358→\n   359→    @Override\n   360→    @GetMapping(value = \"/player/{playerId}/leagues\", produces = MediaType.APPLICATION_JSON_VALUE)\n   361→    @Transactional(readOnly = true)\n   362→    public List<LeagueDetails> getLeaguesOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   363→        logger.info(\"getLeaguesOfPlayer\");\n   364→        List<LeagueDetails> detailsList = new ArrayList<>();\n   365→        try {\n   366→            CriteriaQuery<League> cq = cb.createQuery(League.class);\n   367→            Root<League> leagueRoot = cq.from(League.class);\n   368→            Join<League, Team> team = leagueRoot.join(League_.teams);\n   369→            Join<Team, Player> player = team.join(Team_.players);\n   370→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   371→            cq.select(leagueRoot).distinct(true);\n   372→            TypedQuery<League> q = em.createQuery(cq);\n   373→            List<League> leagues = q.getResultList();\n   374→            if (leagues == null || leagues.isEmpty()) {\n   375→                logger.warning(\"No leagues found for player with ID \" + playerId);\n   376→                return null;\n   377→            }\n   378→            for (League currentLeague : leagues) {\n   379→                detailsList.add(new LeagueDetails(currentLeague.getId(), currentLeague.getName(), currentLeague.getSport()));\n   380→            }\n   381→            return detailsList;\n   382→        } catch (Exception ex) {\n   383→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   384→        }\n   385→    }\n   386→\n   387→    @Override\n   388→    @GetMapping(value = \"/player/{playerId}/sports\", produces = MediaType.APPLICATION_JSON_VALUE)\n   389→    @Transactional(readOnly = true)\n   390→    public List<String> getSportsOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   391→        logger.info(\"getSportsOfPlayer\");\n   392→        try {\n   393→            CriteriaQuery<String> cq = cb.createQuery(String.class);\n   394→            Root<Player> player = cq.from(Player.class);\n   395→            Join<Player, Team> team = player.join(Player_.teams);\n   396→            Join<Team, League> league = team.join(Team_.league);\n   397→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   398→            cq.select(league.get(League_.sport)).distinct(true);\n   399→            TypedQuery<String> q = em.createQuery(cq);\n   400→            return q.getResultList();\n   401→        } catch (Exception ex) {\n   402→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   403→        }\n   404→    }\n   405→\n   406→    @Override\n   407→    @PostMapping(value = \"/team/league/{leagueId}\", consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n   408→    @Transactional\n   409→    public void createTeamInLeague(@RequestBody TeamDetails teamDetails, @PathVariable(\"leagueId\") String leagueId) {\n   410→        logger.info(\"createTeamInLeague\");\n   411→        try {\n   412→            League league = em.find(League.class, leagueId);\n   413→            if (league == null) {\n   414→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   415→            }\n   416→            Team team = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   417→            em.persist(team);\n   418→            team.setLeague(league);\n   419→            league.addTeam(team);\n   420→            em.merge(league);\n   421→            em.flush();\n   422→        } catch (ResponseStatusException ex) {\n   423→            throw ex;\n   424→        } catch (Exception ex) {\n   425→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   426→        }\n   427→    }\n   428→\n   429→    @Override\n   430→    @DeleteMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   431→    @Transactional\n   432→    public void removeTeam(@PathVariable(\"teamId\") String teamId) {\n   433→        logger.info(\"removeTeam\");\n   434→        try {\n   435→            Team team = em.find(Team.class, teamId);\n   436→            if (team == null) {\n   437→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   438→            }\n   439→            for (Player player : team.getPlayers()) {\n   440→                player.dropTeam(team);\n   441→                em.merge(player);\n   442→            }\n   443→            em.remove(team);\n   444→            em.flush();\n   445→        } catch (ResponseStatusException ex) {\n   446→            throw ex;\n   447→        } catch (Exception ex) {\n   448→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   449→        }\n   450→    }\n   451→\n   452→    @Override\n   453→    @GetMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   454→    public TeamDetails getTeam(@PathVariable(\"teamId\") String teamId) {\n   455→        logger.info(\"getTeam\");\n   456→        try {\n   457→            Team team = em.find(Team.class, teamId);\n   458→            if (team == null) {\n   459→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   460→            }\n   461→            return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   462→        } catch (ResponseStatusException ex) {\n   463→            throw ex;\n   464→        } catch (Exception ex) {\n   465→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   466→        }\n   467→    }\n   468→\n   469→    @Override\n   470→    @PostMapping(value = \"/league\", consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n   471→    @Transactional\n   472→    public void createLeague(@RequestBody LeagueDetails leagueDetails) {\n   473→        logger.info(\"createLeague\");\n   474→        try {\n   475→            String sport = leagueDetails.getSport().toLowerCase();\n   476→            if (sport.equals(\"soccer\") || sport.equals(\"swimming\") || sport.equals(\"basketball\") || sport.equals(\"baseball\")) {\n   477→                SummerLeague league = new SummerLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   478→                em.persist(league);\n   479→                em.flush();\n   480→            } else if (sport.equals(\"hockey\") || sport.equals(\"skiing\") || sport.equals(\"snowboarding\")) {\n   481→                WinterLeague league = new WinterLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   482→                em.persist(league);\n   483→                em.flush();\n   484→            } else {\n   485→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   486→            }\n   487→        } catch (Exception ex) {\n   488→            throw new ResponseStatusException(HttpStatus.BAD_REQUEST, ex.getMessage(), ex);\n   489→        }\n   490→    }\n   491→\n   492→    @Override\n   493→    @DeleteMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   494→    @Transactional\n   495→    public void removeLeague(@PathVariable(\"leagueId\") String leagueId) {\n   496→        logger.info(\"removeLeague\");\n   497→        try {\n   498→            League league = em.find(League.class, leagueId);\n   499→            if (league == null) {\n   500→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   501→            }\n   502→            em.remove(league);\n   503→            em.flush();\n   504→        } catch (ResponseStatusException ex) {\n   505→            throw ex;\n   506→        } catch (Exception ex) {\n   507→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   508→        }\n   509→    }\n   510→\n   511→    @Override\n   512→    @GetMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   513→    public LeagueDetails getLeague(@PathVariable(\"leagueId\") String leagueId) {\n   514→        logger.info(\"getLeague\");\n   515→        try {\n   516→            League league = em.find(League.class, leagueId);\n   517→            if (league == null) {\n   518→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   519→            }\n   520→            return new LeagueDetails(league.getId(), league.getName(), league.getSport());\n   521→        } catch (ResponseStatusException ex) {\n   522→            throw ex;\n   523→        } catch (Exception ex) {\n   524→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   525→        }\n   526→    }\n   527→\n   528→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   529→        List<PlayerDetails> detailsList = new ArrayList<>();\n   530→        for (Player player : players) {\n   531→            detailsList.add(new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary()));\n   532→        }\n   533→        return detailsList;\n   534→    }\n   535→}\n   536→"}]},"parent_tool_use_id":null,"session_id":"fb8c096a-6452-4af1-8ca6-d42f7f308c4a","uuid":"70f3ebc7-9f6f-4ddb-b71b-c3764314e305"}
