ilsList(playerList);\n   482→            System.out.println();\n   483→\n   484→            System.out.println(\"List all players in the city of Truckee:\");\n   485→            playerList = client.target(BASE_URI).path(\"/players/city/Truckee\")\n   486→                    .request(MediaType.APPLICATION_JSON)\n   487→                    .get(new GenericType<List<PlayerDetails>>() {});\n   488→            printDetailsList(playerList);\n   489→            System.out.println();\n   490→\n   491→            System.out.println(\"List all soccer players:\");\n   492→            playerList = client.target(BASE_URI).path(\"/players/sport/Soccer\")\n   493→                    .request(MediaType.APPLICATION_JSON)\n   494→                    .get(new GenericType<List<PlayerDetails>>() {});\n   495→            printDetailsList(playerList);\n   496→            System.out.println();\n   497→\n   498→            System.out.println(\"List all players in league L1:\");\n   499→            playerList = client.target(BASE_URI).path(\"/players/league/L1\")\n   500→                    .request(MediaType.APPLICATION_JSON)\n   501→                    .get(new GenericType<List<PlayerDetails>>() {});\n   502→            printDetailsList(playerList);\n   503→            System.out.println();\n   504→\n   505→            System.out.println(\"List all players making a higher salary than Ian Carlyle:\");\n   506→            playerList = client.target(BASE_URI).path(\"/players/salary/higher/Ian Carlyle\")\n   507→                    .request(MediaType.APPLICATION_JSON)\n   508→                    .get(new GenericType<List<PlayerDetails>>() {});\n   509→            printDetailsList(playerList);\n   510→            System.out.println();\n   511→\n   512→            System.out.println(\"List all players with a salary between 500 and 800:\");\n   513→            playerList = client.target(BASE_URI).path(\"/players/salary/range\")\n   514→                    .queryParam(\"low\", 500.00).queryParam(\