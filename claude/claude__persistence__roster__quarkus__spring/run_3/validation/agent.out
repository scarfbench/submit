32→import java.util.Collection;\n    33→import java.util.List;\n    34→import java.util.logging.Logger;\n    35→\n    36→@RestController\n    37→@RequestMapping(\"/roster\")\n    38→public class RequestBean implements Request {\n    39→    private static final Logger logger = Logger.getLogger(\"quarkus.tutorial.roster.request.RequestBean\");\n    40→\n    41→    @PersistenceContext\n    42→    private EntityManager em;\n    43→    private CriteriaBuilder cb;\n    44→\n    45→    @PostConstruct\n    46→    private void init() {\n    47→        cb = em.getCriteriaBuilder();\n    48→    }\n    49→\n    50→    @Override\n    51→    @PostMapping(value = \"/player\", consumes = MediaType.APPLICATION_FORM_URLENCODED_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n    52→    @Transactional\n    53→    public void createPlayer(\n    54→            @RequestParam(\"id\") String id,\n    55→            @RequestParam(\"name\") String name,\n    56→            @RequestParam(\"position\") String position,\n    57→            @RequestParam(\"salary\") double salary) {\n    58→        logger.info(\"createPlayer\");\n    59→        try {\n    60→            Player player = new Player(id, name, position, salary);\n    61→            em.persist(player);\n    62→            em.flush();\n    63→        } catch (Exception ex) {\n    64→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    65→        }\n    66→    }\n    67→\n    68→    @Override\n    69→    @PostMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    70→    @Transactional\n    71→    public void addPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n    72→        logger.info(\"addPlayer\");\n    73→        try {\n    74→            Player player = em.find(Player.class, playerId);\n    75→            Team team = em.find(Team.class, teamId);\n    76→            if (player == null || team == null) {\n    77→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n    78→            }\n    79→            team.addPlayer(player);\n    80→            player.addTeam(team);\n    81→            em.merge(player);\n    82→            em.merge(team);\n    83→            em.flush();\n    84→        } catch (ResponseStatusException ex) {\n    85→            throw ex;\n    86→        } catch (Exception ex) {\n    87→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n    88→        }\n    89→    }\n    90→\n    91→    @Override\n    92→    @DeleteMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n    93→    @Transactional\n    94→    public void removePlayer(@PathVariable(\"playerId\") String playerId) {\n    95→        logger.info(\"removePlayer\");\n    96→        try {\n    97→            Player player = em.find(Player.class, playerId);\n    98→            if (player == null) {\n    99→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n   100→            }\n   101→            Collection<Team> teams = player.getTeams();\n   102→            for (Team team : teams) {\n   103→                team.dropPlayer(player);\n   104→            }\n   105→            em.remove(player);\n   106→            em.flush();\n   107→        } catch (ResponseStatusException ex) {\n   108→            throw ex;\n   109→        } catch (Exception ex) {\n   110→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   111→        }\n   112→    }\n   113→\n   114→    @Override\n   115→    @DeleteMapping(value = \"/player/{playerId}/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   116→    @Transactional\n   117→    public void dropPlayer(@PathVariable(\"playerId\") String playerId, @PathVariable(\"teamId\") String teamId) {\n   118→        logger.info(\"dropPlayer\");\n   119→        try {\n   120→            Player player = em.find(Player.class, playerId);\n   121→            Team team = em.find(Team.class, teamId);\n   122→            if (player == null || team == null) {\n   123→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player or Team not found\");\n   124→            }\n   125→            team.dropPlayer(player);\n   126→            player.dropTeam(team);\n   127→            em.merge(player);\n   128→            em.merge(team);\n   129→            em.flush();\n   130→        } catch (ResponseStatusException ex) {\n   131→            throw ex;\n   132→        } catch (Exception ex) {\n   133→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   134→        }\n   135→    }\n   136→\n   137→    @Override\n   138→    @GetMapping(value = \"/player/{playerId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   139→    public PlayerDetails getPlayer(@PathVariable(\"playerId\") String playerId) {\n   140→        logger.info(\"getPlayerDetails\");\n   141→        try {\n   142→            Player player = em.find(Player.class, playerId);\n   143→            if (player == null) {\n   144→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Player not found\");\n   145→            }\n   146→            return new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary());\n   147→        } catch (ResponseStatusException ex) {\n   148→            throw ex;\n   149→        } catch (Exception ex) {\n   150→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   151→        }\n   152→    }\n   153→\n   154→    @Override\n   155→    @GetMapping(value = \"/team/{teamId}/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   156→    public List<PlayerDetails> getPlayersOfTeam(@PathVariable(\"teamId\") String teamId) {\n   157→        logger.info(\"getPlayersOfTeam\");\n   158→        try {\n   159→            Team team = em.find(Team.class, teamId);\n   160→            if (team == null) {\n   161→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   162→            }\n   163→            return copyPlayersToDetails((List<Player>) team.getPlayers());\n   164→        } catch (ResponseStatusException ex) {\n   165→            throw ex;\n   166→        } catch (Exception ex) {\n   167→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   168→        }\n   169→    }\n   170→\n   171→    @Override\n   172→    @GetMapping(value = \"/league/{leagueId}/teams\", produces = MediaType.APPLICATION_JSON_VALUE)\n   173→    public List<TeamDetails> getTeamsOfLeague(@PathVariable(\"leagueId\") String leagueId) {\n   174→        logger.info(\"getTeamsOfLeague\");\n   175→        List<TeamDetails> detailsList = new ArrayList<>();\n   176→        try {\n   177→            League league = em.find(League.class, leagueId);\n   178→            if (league == null) {\n   179→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   180→            }\n   181→            for (Team team : league.getTeams()) {\n   182→                detailsList.add(new TeamDetails(team.getId(), team.getName(), team.getCity()));\n   183→            }\n   184→            return detailsList;\n   185→        } catch (ResponseStatusException ex) {\n   186→            throw ex;\n   187→        } catch (Exception ex) {\n   188→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   189→        }\n   190→    }\n   191→\n   192→    @Override\n   193→    @GetMapping(value = \"/players/position/{position}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   194→    public List<PlayerDetails> getPlayersByPosition(@PathVariable(\"position\") String position) {\n   195→        logger.info(\"getPlayersByPosition\");\n   196→        try {\n   197→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   198→            Root<Player> player = cq.from(Player.class);\n   199→            cq.where(cb.equal(player.get(Player_.position), position));\n   200→            cq.select(player);\n   201→            TypedQuery<Player> q = em.createQuery(cq);\n   202→            List<Player> players = q.getResultList();\n   203→            return copyPlayersToDetails(players);\n   204→        } catch (Exception ex) {\n   205→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   206→        }\n   207→    }\n   208→\n   209→    @Override\n   210→    @GetMapping(value = \"/players/salary/higher/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   211→    public List<PlayerDetails> getPlayersByHigherSalary(@PathVariable(\"name\") String name) {\n   212→        logger.info(\"getPlayersByHigherSalary\");\n   213→        try {\n   214→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   215→            Root<Player> player1 = cq.from(Player.class);\n   216→            Root<Player> player2 = cq.from(Player.class);\n   217→            Predicate gtPredicate = cb.greaterThan(player1.get(Player_.salary), player2.get(Player_.salary));\n   218→            Predicate equalPredicate = cb.equal(player2.get(Player_.name), name);\n   219→            cq.where(gtPredicate, equalPredicate);\n   220→            cq.select(player1).distinct(true);\n   221→            TypedQuery<Player> q = em.createQuery(cq);\n   222→            List<Player> players = q.getResultList();\n   223→            return copyPlayersToDetails(players);\n   224→        } catch (Exception ex) {\n   225→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   226→        }\n   227→    }\n   228→\n   229→    @Override\n   230→    @GetMapping(value = \"/players/salary/range\", produces = MediaType.APPLICATION_JSON_VALUE)\n   231→    public List<PlayerDetails> getPlayersBySalaryRange(@RequestParam(\"low\") double low, @RequestParam(\"high\") double high) {\n   232→        logger.info(\"getPlayersBySalaryRange\");\n   233→        try {\n   234→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   235→            Root<Player> player = cq.from(Player.class);\n   236→            cq.where(cb.between(player.get(Player_.salary), low, high));\n   237→            cq.select(player).distinct(true);\n   238→            TypedQuery<Player> q = em.createQuery(cq);\n   239→            List<Player> players = q.getResultList();\n   240→            return copyPlayersToDetails(players);\n   241→        } catch (Exception ex) {\n   242→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   243→        }\n   244→    }\n   245→\n   246→    @Override\n   247→    @GetMapping(value = \"/players/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   248→    @Transactional\n   249→    public List<PlayerDetails> getPlayersByLeagueId(@PathVariable(\"leagueId\") String leagueId) {\n   250→        logger.info(\"getPlayersByLeagueId\");\n   251→        try {\n   252→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   253→            Root<Player> player = cq.from(Player.class);\n   254→            Join<Player, Team> team = player.join(Player_.teams);\n   255→            Join<Team, League> league = team.join(Team_.league);\n   256→            cq.where(cb.equal(league.get(League_.id), leagueId));\n   257→            cq.select(player).distinct(true);\n   258→            TypedQuery<Player> q = em.createQuery(cq);\n   259→            List<Player> players = q.getResultList();\n   260→            return copyPlayersToDetails(players);\n   261→        } catch (Exception ex) {\n   262→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   263→        }\n   264→    }\n   265→\n   266→    @Override\n   267→    @GetMapping(value = \"/players/sport/{sport}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   268→    public List<PlayerDetails> getPlayersBySport(@PathVariable(\"sport\") String sport) {\n   269→        logger.info(\"getPlayersBySport\");\n   270→        try {\n   271→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   272→            Root<Player> player = cq.from(Player.class);\n   273→            Join<Player, Team> team = player.join(Player_.teams);\n   274→            Join<Team, League> league = team.join(Team_.league);\n   275→            cq.where(cb.equal(league.get(League_.sport), sport));\n   276→            cq.select(player).distinct(true);\n   277→            TypedQuery<Player> q = em.createQuery(cq);\n   278→            List<Player> players = q.getResultList();\n   279→            return copyPlayersToDetails(players);\n   280→        } catch (Exception ex) {\n   281→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   282→        }\n   283→    }\n   284→\n   285→    @Override\n   286→    @GetMapping(value = \"/players/city/{city}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   287→    public List<PlayerDetails> getPlayersByCity(@PathVariable(\"city\") String city) {\n   288→        logger.info(\"getPlayersByCity\");\n   289→        try {\n   290→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   291→            Root<Player> player = cq.from(Player.class);\n   292→            Join<Player, Team> team = player.join(Player_.teams);\n   293→            cq.where(cb.equal(team.get(Team_.city), city));\n   294→            cq.select(player).distinct(true);\n   295→            TypedQuery<Player> q = em.createQuery(cq);\n   296→            List<Player> players = q.getResultList();\n   297→            return copyPlayersToDetails(players);\n   298→        } catch (Exception ex) {\n   299→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   300→        }\n   301→    }\n   302→\n   303→    @Override\n   304→    @GetMapping(value = \"/players\", produces = MediaType.APPLICATION_JSON_VALUE)\n   305→    public List<PlayerDetails> getAllPlayers() {\n   306→        logger.info(\"getAllPlayers\");\n   307→        try {\n   308→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   309→            Root<Player> player = cq.from(Player.class);\n   310→            cq.select(player);\n   311→            TypedQuery<Player> q = em.createQuery(cq);\n   312→            List<Player> players = q.getResultList();\n   313→            return copyPlayersToDetails(players);\n   314→        } catch (Exception ex) {\n   315→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   316→        }\n   317→    }\n   318→\n   319→    @Override\n   320→    @GetMapping(value = \"/players/not-on-team\", produces = MediaType.APPLICATION_JSON_VALUE)\n   321→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   322→        logger.info(\"getPlayersNotOnTeam\");\n   323→        try {\n   324→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   325→            Root<Player> player = cq.from(Player.class);\n   326→            cq.where(cb.isEmpty(player.get(Player_.teams)));\n   327→            cq.select(player).distinct(true);\n   328→            TypedQuery<Player> q = em.createQuery(cq);\n   329→            List<Player> players = q.getResultList();\n   330→            return copyPlayersToDetails(players);\n   331→        } catch (Exception ex) {\n   332→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   333→        }\n   334→    }\n   335→\n   336→    @Override\n   337→    @GetMapping(value = \"/players/position/{position}/name/{name}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   338→    public List<PlayerDetails> getPlayersByPositionAndName(\n   339→            @PathVariable(\"position\") String position,\n   340→            @PathVariable(\"name\") String name) {\n   341→        logger.info(\"getPlayersByPositionAndName\");\n   342→        try {\n   343→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   344→            Root<Player> player = cq.from(Player.class);\n   345→            cq.where(cb.equal(player.get(Player_.position), position),\n   346→                    cb.equal(player.get(Player_.name), name));\n   347→            cq.select(player).distinct(true);\n   348→            TypedQuery<Player> q = em.createQuery(cq);\n   349→            List<Player> players = q.getResultList();\n   350→            return copyPlayersToDetails(players);\n   351→        } catch (Exception ex) {\n   352→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   353→        }\n   354→    }\n   355→\n   356→    @Override\n   357→    @GetMapping(value = \"/player/{playerId}/leagues\", produces = MediaType.APPLICATION_JSON_VALUE)\n   358→    public List<LeagueDetails> getLeaguesOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   359→        logger.info(\"getLeaguesOfPlayer\");\n   360→        List<LeagueDetails> detailsList = new ArrayList<>();\n   361→        try {\n   362→            CriteriaQuery<League> cq = cb.createQuery(League.class);\n   363→            Root<League> leagueRoot = cq.from(League.class);\n   364→            Join<League, Team> team = leagueRoot.join(League_.teams);\n   365→            Join<Team, Player> player = team.join(Team_.players);\n   366→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   367→            cq.select(leagueRoot).distinct(true);\n   368→            TypedQuery<League> q = em.createQuery(cq);\n   369→            List<League> leagues = q.getResultList();\n   370→            if (leagues == null || leagues.isEmpty()) {\n   371→                logger.warning(\"No leagues found for player with ID \" + playerId);\n   372→                return null;\n   373→            }\n   374→            for (League currentLeague : leagues) {\n   375→                detailsList.add(new LeagueDetails(currentLeague.getId(), currentLeague.getName(), currentLeague.getSport()));\n   376→            }\n   377→            return detailsList;\n   378→        } catch (Exception ex) {\n   379→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   380→        }\n   381→    }\n   382→\n   383→    @Override\n   384→    @GetMapping(value = \"/player/{playerId}/sports\", produces = MediaType.APPLICATION_JSON_VALUE)\n   385→    public List<String> getSportsOfPlayer(@PathVariable(\"playerId\") String playerId) {\n   386→        logger.info(\"getSportsOfPlayer\");\n   387→        try {\n   388→            CriteriaQuery<String> cq = cb.createQuery(String.class);\n   389→            Root<Player> player = cq.from(Player.class);\n   390→            Join<Player, Team> team = player.join(Player_.teams);\n   391→            Join<Team, League> league = team.join(Team_.league);\n   392→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   393→            cq.select(league.get(League_.sport)).distinct(true);\n   394→            TypedQuery<String> q = em.createQuery(cq);\n   395→            return q.getResultList();\n   396→        } catch (Exception ex) {\n   397→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   398→        }\n   399→    }\n   400→\n   401→    @Override\n   402→    @PostMapping(value = \"/team/league/{leagueId}\", consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n   403→    @Transactional\n   404→    public void createTeamInLeague(@RequestBody TeamDetails teamDetails, @PathVariable(\"leagueId\") String leagueId) {\n   405→        logger.info(\"createTeamInLeague\");\n   406→        try {\n   407→            League league = em.find(League.class, leagueId);\n   408→            if (league == null) {\n   409→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   410→            }\n   411→            Team team = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   412→            em.persist(team);\n   413→            team.setLeague(league);\n   414→            league.addTeam(team);\n   415→            em.merge(league);\n   416→            em.flush();\n   417→        } catch (ResponseStatusException ex) {\n   418→            throw ex;\n   419→        } catch (Exception ex) {\n   420→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   421→        }\n   422→    }\n   423→\n   424→    @Override\n   425→    @DeleteMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   426→    @Transactional\n   427→    public void removeTeam(@PathVariable(\"teamId\") String teamId) {\n   428→        logger.info(\"removeTeam\");\n   429→        try {\n   430→            Team team = em.find(Team.class, teamId);\n   431→            if (team == null) {\n   432→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   433→            }\n   434→            for (Player player : team.getPlayers()) {\n   435→                player.dropTeam(team);\n   436→                em.merge(player);\n   437→            }\n   438→            em.remove(team);\n   439→            em.flush();\n   440→        } catch (ResponseStatusException ex) {\n   441→            throw ex;\n   442→        } catch (Exception ex) {\n   443→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   444→        }\n   445→    }\n   446→\n   447→    @Override\n   448→    @GetMapping(value = \"/team/{teamId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   449→    public TeamDetails getTeam(@PathVariable(\"teamId\") String teamId) {\n   450→        logger.info(\"getTeam\");\n   451→        try {\n   452→            Team team = em.find(Team.class, teamId);\n   453→            if (team == null) {\n   454→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"Team not found\");\n   455→            }\n   456→            return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   457→        } catch (ResponseStatusException ex) {\n   458→            throw ex;\n   459→        } catch (Exception ex) {\n   460→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   461→        }\n   462→    }\n   463→\n   464→    @Override\n   465→    @PostMapping(value = \"/league\", consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n   466→    @Transactional\n   467→    public void createLeague(@RequestBody LeagueDetails leagueDetails) {\n   468→        logger.info(\"createLeague\");\n   469→        try {\n   470→            String sport = leagueDetails.getSport().toLowerCase();\n   471→            if (sport.equals(\"soccer\") || sport.equals(\"swimming\") || sport.equals(\"basketball\") || sport.equals(\"baseball\")) {\n   472→                SummerLeague league = new SummerLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   473→                em.persist(league);\n   474→                em.flush();\n   475→            } else if (sport.equals(\"hockey\") || sport.equals(\"skiing\") || sport.equals(\"snowboarding\")) {\n   476→                WinterLeague league = new WinterLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   477→                em.persist(league);\n   478→                em.flush();\n   479→            } else {\n   480→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   481→            }\n   482→        } catch (Exception ex) {\n   483→            throw new ResponseStatusException(HttpStatus.BAD_REQUEST, ex.getMessage(), ex);\n   484→        }\n   485→    }\n   486→\n   487→    @Override\n   488→    @DeleteMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   489→    @Transactional\n   490→    public void removeLeague(@PathVariable(\"leagueId\") String leagueId) {\n   491→        logger.info(\"removeLeague\");\n   492→        try {\n   493→            League league = em.find(League.class, leagueId);\n   494→            if (league == null) {\n   495→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   496→            }\n   497→            em.remove(league);\n   498→            em.flush();\n   499→        } catch (ResponseStatusException ex) {\n   500→            throw ex;\n   501→        } catch (Exception ex) {\n   502→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   503→        }\n   504→    }\n   505→\n   506→    @Override\n   507→    @GetMapping(value = \"/league/{leagueId}\", produces = MediaType.APPLICATION_JSON_VALUE)\n   508→    public LeagueDetails getLeague(@PathVariable(\"leagueId\") String leagueId) {\n   509→        logger.info(\"getLeague\");\n   510→        try {\n   511→            League league = em.find(League.class, leagueId);\n   512→            if (league == null) {\n   513→                throw new ResponseStatusException(HttpStatus.NOT_FOUND, \"League not found\");\n   514→            }\n   515→            return new LeagueDetails(league.getId(), league.getName(), league.getSport());\n   516→        } catch (ResponseStatusException ex) {\n   517→            throw ex;\n   518→        } catch (Exception ex) {\n   519→            throw new ResponseStatusException(HttpStatus.INTERNAL_SERVER_ERROR, ex.getMessage(), ex);\n   520→        }\n   521→    }\n   522→\n   523→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   524→        List<PlayerDetails> detailsList = new ArrayList<>();\n   525→        for (Player player : players) {\n   526→            detailsList.add(new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary()));\n   527→        }\n   528→        return detailsList;\n   529→    }\n   530→}\n   531→"}]},"parent_tool_use_id":null,"session_id":"b980a48c-449a-4184-94ce-e355b0c87aac","uuid":"fb848d7c-96b3-4b83-83f1-e84feddcddaf"}
