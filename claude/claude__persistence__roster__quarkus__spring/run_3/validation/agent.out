  .get(new GenericType<List<TeamDetails>>() {});\n   412→            printDetailsList(teamList);\n   413→            System.out.println();\n   414→\n   415→            System.out.println(\"List all defenders:\");\n   416→            playerList = client.target(BASE_URI).path(\"/players/position/defender\")\n   417→                    .request(MediaType.APPLICATION_JSON)\n   418→                    .get(new GenericType<List<PlayerDetails>>() {});\n   419→            printDetailsList(playerList);\n   420→            System.out.println();\n   421→\n   422→            System.out.println(\"List the leagues of player P28:\");\n   423→            List<LeagueDetails> leagueList = client.target(BASE_URI).path(\"/player/P28/leagues\")\n   424→                    .request(MediaType.APPLICATION_JSON)\n   425→                    .get(new GenericType<List<LeagueDetails>>() {});\n   426→            printDetailsList(leagueList);\n   427→            System.out.println();\n   428→        } catch (Exception ex) {\n   429→            System.err.println(\"Caught an exception: \" + ex.getMessage());\n   430→        }\n   431→    }\n   432→\n   433→    private void getMoreInfo(Client client) {\n   434→        try {\n   435→            System.out.println(\"Details of league L1:\");\n   436→            LeagueDetails leagueDetails = client.target(BASE_URI).path(\"/league/L1\")\n   437→                    .request(MediaType.APPLICATION_JSON)\n   438→                    .get(LeagueDetails.class);\n   439→            System.out.println(leagueDetails.toString());\n   440→            System.out.println();\n   441→\n   442→            System.out.println(\"Details of team T3:\");\n   443→            TeamDetails teamDetails = client.target(BASE_URI).path(\"/team/T3\")\n   444→                    .request(MediaType.APPLICATION_JSON)\n   445→                    .get(TeamDetails.class);\n   446→            System.out.println(teamDetails.toString());\n   447→            System.out.println();\n   448→\n  