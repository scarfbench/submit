<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">
    <persistence-unit name="daytrader" transaction-type="JTA">
        <jta-data-source>jdbc/TradeDataSource</jta-data-source>
        <class>com.ibm.websphere.samples.daytrader.entities.AccountDataBean</class>
        <class>com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean</class>
        <class>com.ibm.websphere.samples.daytrader.entities.HoldingDataBean</class>
        <class>com.ibm.websphere.samples.daytrader.entities.OrderDataBean</class>
        <class>com.ibm.websphere.samples.daytrader.entities.QuoteDataBean</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="eclipselink.target-database" value="Auto"/>
            <property name="eclipselink.logging.level" value="WARNING"/>
            <property name="eclipselink.ddl-generation" value="create-tables"/>
        </properties>
    </persistence-unit>
</persistence>
