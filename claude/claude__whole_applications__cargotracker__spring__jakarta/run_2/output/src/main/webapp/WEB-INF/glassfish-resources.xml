<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE resources PUBLIC "-//GlassFish.org//DTD GlassFish Application Server 3.1 Resource Definitions//EN"
  "http://glassfish.org/dtds/glassfish-resources_1_5.dtd">
<resources>
    <jdbc-connection-pool name="CargoTrackerPool"
                          res-type="javax.sql.DataSource"
                          datasource-classname="org.h2.jdbcx.JdbcDataSource"
                          max-pool-size="32"
                          steady-pool-size="2"
                          connection-leak-timeout-in-seconds="2">
        <property name="url" value="jdbc:h2:mem:cargo-tracker-database;DB_CLOSE_DELAY=-1"/>
        <property name="user" value="sa"/>
        <property name="password" value=""/>
    </jdbc-connection-pool>

    <jdbc-resource pool-name="CargoTrackerPool"
                   jndi-name="java:app/jdbc/CargoTrackerDatabase"/>
</resources>
