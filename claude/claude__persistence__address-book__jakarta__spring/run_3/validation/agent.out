                  <tr>\n    39→                        <td><h:outputLabel value=\"#{bundle.CreateContactLabel_lastName}\" \n    40→                                           for=\"lastName\" /></td>\n    41→                        <td><h:inputText id=\"lastName\" \n    42→                                         value=\"#{contactController.selected.lastName}\" \n    43→                                         title=\"#{bundle.CreateContactTitle_lastName}\" />\n    44→                        </td>\n    45→                        <td><h:message for=\"lastName\" /></td>\n    46→                    </tr>\n    47→                    <tr>\n    48→                        <td><h:outputLabel value=\"#{bundle.CreateContactLabel_birthday}\" \n    49→                                           for=\"birthday\" /></td>\n    50→                        <td><h:inputText id=\"birthday\" \n    51→                                         value=\"#{contactController.selected.birthday}\" \n    52→                                         title=\"#{bundle.CreateContactTitle_birthday}\" >\n    53→                                <f:convertDateTime pattern=\"MM/dd/yyyy\" />\n    54→                            </h:inputText></td>\n    55→                        <td><h:message for=\"birthday\" /></td>\n    56→                    </tr>\n    57→                    <tr>\n    58→                        <td><h:outputLabel value=\"#{bundle.CreateContactLabel_homePhone}\" \n    59→                                           for=\"homePhone\" /></td>\n    60→                        <td><h:inputText id=\"homePhone\" \n    61→                                         value=\"#{contactController.selected.homePhone}\" \n    62→                                         title=\"#{bundle.CreateContactTitle_homePhone}\" /></td>\n    63→                        <td><h:message for=\"homePhone\" /></td>\n    64→                    </tr>\n    65→                    <tr>\n    66→                        <td><h:outputLabel value=\"#{bundle.CreateContactLabel_mobilePhone}\" \n    67→                                           for=\"mobilePhone\" /></td>\n    68→                        <td><h:inputText id=\"mobilePhone\" \n    69→                                         value=\"#{contactController.selected.mobilePhone}\" \n    70→                                         title=\"#{bundle.CreateContactTitle_mobilePhone}\" /></td>\n    71→                        <td><h:message for=\"mobilePhone\" /></td>\n    72→                    </tr>\n    73→                    <tr>\n    74→                        <td><h:outputLabel value=\"#{bundle.CreateContactLabel_email}\" \n    75→                                           for=\"email\" /></td>\n    76→                        <td><h:inputText id=\"email\" \n    77→                                         value=\"#{contactController.selected.email}\" \n    78→                                         title=\"#{bundle.CreateContactTitle_email}\" /></td>\n    79→                        <td><h:message for=\"email\" /></td>\n    80→                    </tr>\n    81→                </table>\n    82→                <br />\n    83→                <h:commandLink action=\"#{contactController.create}\" value=\"#{bundle.CreateContactSaveLink}\" />\n    84→                <br />\n    85→                <br />\n    86→                <h:commandLink action=\"#{contactController.prepareList}\" value=\"#{bundle.CreateContactShowAllLink}\" immediate=\"true\"/>\n    87→                <br />\n    88→                <br />\n    89→                <h:commandLink value=\"#{bundle.CreateContactIndexLink}\" action=\"/index\" immediate=\"true\" />\n    90→            </h:form>\n    91→            <div class=\"messagecolor\">\n    92→                <h:messages showSummary=\"true\" \n    93→                            showDetail=\"false\"\n    94→                            errorStyle=\"color: #d20005\" \n    95→                            infoStyle=\"color: green\"/>\n  