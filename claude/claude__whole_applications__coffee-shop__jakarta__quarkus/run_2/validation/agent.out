{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012BPXBX3KrbPdabKZtFPj8F","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Smoke tests for the Coffee Shop orders-service (Quarkus migration).\"\"\"\n     3→\n     4→import json\n     5→import os\n     6→import sys\n     7→import time\n     8→import urllib.request\n     9→import urllib.error\n    10→\n    11→BASE = os.environ.get(\"APP_URL\", \"http://localhost:8080\")\n    12→\n    13→passed = 0\n    14→failed = 0\n    15→\n    16→def test(name, fn):\n    17→    global passed, failed\n    18→    try:\n    19→        fn()\n    20→        print(f\"  PASS  {name}\")\n    21→        passed += 1\n    22→    except Exception as e:\n    23→        print(f\"  FAIL  {name}: {e}\")\n    24→        failed += 1\n    25→\n    26→def http(method, path, body=None, expected_status=None):\n    27→    url = BASE.rstrip(\"/\") + path\n    28→    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n    29→    data = json.dumps(body).encode() if body else None\n    30→    req = urllib.request.Request(url, data=data, headers=headers, method=method)\n    31→    try:\n    32→        resp = urllib.request.urlopen(req)\n    33→        resp_body = resp.read().decode()\n    34→        status = resp.getcode()\n    35→    except urllib.error.HTTPError as e:\n    36→        status = e.code\n    37→        resp_body = e.read().decode() if e.fp else \"\"\n    38→    if expected_status and status != expected_status:\n    39→        raise AssertionError(f\"Expected status {expected_status}, got {status}. Body: {resp_body}\")\n    40→    return status, resp_body\n    41→\n    42→# --- Wait for readiness ---\n    43→def wait_for_ready(max_wait=120):\n    44→    \"\"\"Wait for the app to be ready.\"\"\"\n    45→    start = time.time()\n    46→    while time.time() - start < max_wait:\n    47→        try:\n    48→            req = urllib.request.Request(BASE.rstrip(\"/\") + \"/q/health/ready\")\n    49→            resp = urllib.request.urlopen(req, timeout=5)\n    50→            if resp.getcode() == 200:\n    51→                print(f\"App ready after {int(time.time()-start)}s\")\n    52→                return True\n    53→        except Exception:\n    54→            pass\n    55→        # Also try a simple status endpoint\n    56→        try:\n    57→            req = urllib.request.Request(BASE.rstrip(\"/\") + \"/api/status\")\n    58→            resp = urllib.request.urlopen(req, timeout=5)\n    59→            if resp.getcode() == 200:\n    60→                print(f\"App ready (via /api/status) after {int(time.time()-start)}s\")\n    61→                return True\n    62→        except Exception:\n    63→            pass\n    64→        time.sleep(3)\n    65→    print(f\"App did NOT become ready within {max_wait}s\")\n    66→    return False\n    67→\n    68→# --- Tests ---\n    69→def test_health_ready():\n    70→    status, body = http(\"GET\", \"/q/health/ready\")\n    71→    assert status == 200, f\"Health check failed with status {status}\"\n    72→\n    73→def test_health_live():\n    74→    status, body = http(\"GET\", \"/q/health/live\")\n    75→    assert status == 200, f\"Liveness check failed with status {status}\"\n    76→\n    77→def test_create_order():\n    78→    status, body = http(\"POST\", \"/api/orders\",\n    79→                        body={\"customer\": \"Alice\", \"item\": \"Latte\", \"quantity\": 1},\n    80→                        expected_status=202)\n    81→    data = json.loads(body)\n    82→    assert \"id\" in data or \"id\" in str(data), f\"No id in response: {body}\"\n    83→    return data\n    84→\n    85→def test_create_order_food():\n    86→    status, body = http(\"POST\", \"/api/orders\",\n    87→                        body={\"customer\": \"Bob\", \"item\": \"Sandwich\", \"quantity\": 2},\n    88→                        expected_status=202)\n    89→    data = json.loads(body)\n    90→    assert \"id\" in data or \"id\" in str(data), f\"No id in response: {body}\"\n    91→\n    92→def test_get_order():\n    93→    # First create an order\n    94→    status, body = http(\"POST\", \"/api/orders\",\n    95→                        body={\"customer\": \"Charlie\", \"item\": \"Espresso\", \"quantity\": 1})\n    96→    data = json.loads(body)\n    97→    order_id = data.get(\"id\", data.get(\"orderId\"))\n    98→    # Then retrieve it\n    99→    status2, body2 = http(\"GET\", f\"/api/orders/{order_id}\")\n   100→    assert status2 == 200, f\"GET order returned {status2}\"\n   101→    order = json.loads(body2)\n   102→    assert order.get(\"customer\") == \"Charlie\" or str(order_id) in body2\n   103→\n   104→def test_invalid_order():\n   105→    \"\"\"Empty body should return 400.\"\"\"\n   106→    status, body = http(\"POST\", \"/api/orders\",\n   107→                        body={\"customer\": \"\", \"item\": \"\", \"quantity\": 0})\n   108→    assert status == 400, f\"Expected 400 for invalid order, got {status}\"\n   109→\n   110→def test_status_endpoint():\n   111→    \"\"\"Test the status/status endpoint returns OK.\"\"\"\n   112→    try:\n   113→        status, body = http(\"GET\", \"/api/status\")\n   114→        assert status == 200, f\"Status endpoint returned {status}\"\n   115→    except Exception:\n   116→        # Quarkus may not have this - just skip\n   117→        pass\n   118→\n   119→if __name__ == \"__main__\":\n   120→    print(f\"Smoke testing against: {BASE}\")\n   121→    if not wait_for_ready():\n   122→        print(\"ABORT: Application not ready\")\n   123→        sys.exit(1)\n   124→\n   125→    print(\"\\n--- Running smoke tests ---\\n\")\n   126→    test(\"Health readiness\", test_health_ready)\n   127→    test(\"Health liveness\", test_health_live)\n   128→    test(\"Create drink order (barista)\", test_create_order)\n   129→    test(\"Create food order (kitchen)\", test_create_order_food)\n   130→    test(\"Get order by ID\", test_get_order)\n   131→    test(\"Invalid order returns 400\", test_invalid_order)\n   132→    test(\"Status endpoint\", test_status_endpoint)\n   133→\n   134→    print(f\"\\n--- Results: {passed} passed, {failed} failed ---\\n\")\n   135→    sys.exit(0 if failed == 0 else 1)\n   136→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"09dd8e6e-4ff1-445a-9c42-b2dfa0ace457","uuid":"be56eb57-09fb-4aef-b460-3c2af908070e"}
