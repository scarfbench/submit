{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01KmuhzDARfLiekKYkrtg6qW","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Smoke tests for the Coffee Shop orders-service (Quarkus migration).\n     4→These tests verify the REST API endpoints work correctly after migration.\n     5→\"\"\"\n     6→\n     7→import json\n     8→import os\n     9→import sys\n    10→import time\n    11→import urllib.request\n    12→import urllib.error\n    13→\n    14→BASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n    15→PASS = 0\n    16→FAIL = 0\n    17→\n    18→\n    19→def log(status, message):\n    20→    global PASS, FAIL\n    21→    if status == \"PASS\":\n    22→        PASS += 1\n    23→        print(f\"  [PASS] {message}\")\n    24→    else:\n    25→        FAIL += 1\n    26→        print(f\"  [FAIL] {message}\")\n    27→\n    28→\n    29→def request(method, path, body=None, expect_status=None):\n    30→    \"\"\"Helper to make HTTP requests.\"\"\"\n    31→    url = f\"{BASE_URL}{path}\"\n    32→    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n    33→    data = json.dumps(body).encode(\"utf-8\") if body else None\n    34→    req = urllib.request.Request(url, data=data, headers=headers, method=method)\n    35→    try:\n    36→        resp = urllib.request.urlopen(req, timeout=10)\n    37→        resp_body = resp.read().decode(\"utf-8\")\n    38→        status = resp.getcode()\n    39→        return status, resp_body\n    40→    except urllib.error.HTTPError as e:\n    41→        resp_body = e.read().decode(\"utf-8\") if e.fp else \"\"\n    42→        return e.code, resp_body\n    43→    except Exception as e:\n    44→        return None, str(e)\n    45→\n    46→\n    47→def wait_for_ready(max_wait=120):\n    48→    \"\"\"Wait for the application to be ready.\"\"\"\n    49→    print(f\"Waiting for application at {BASE_URL} to be ready...\")\n    50→    start = time.time()\n    51→    while time.time() - start < max_wait:\n    52→        try:\n    53→            status, body = request(\"GET\", \"/health\")\n    54→            if status and status < 500:\n    55→                print(f\"  Application ready after {int(time.time() - start)}s\")\n    56→                return True\n    57→        except Exception:\n    58→            pass\n    59→        # Also try the q/health endpoint (Quarkus default)\n    60→        try:\n    61→            status, body = request(\"GET\", \"/q/health\")\n    62→            if status and status < 500:\n    63→                print(f\"  Application ready after {int(time.time() - start)}s (via /q/health)\")\n    64→                return True\n    65→        except Exception:\n    66→            pass\n    67→        time.sleep(2)\n    68→    print(f\"  Application not ready after {max_wait}s\")\n    69→    return False\n    70→\n    71→\n    72→def test_health():\n    73→    \"\"\"Test health endpoint.\"\"\"\n    74→    print(\"\\n--- Test: Health Check ---\")\n    75→    # Try Quarkus default health paths\n    76→    for path in [\"/health\", \"/q/health\", \"/q/health/ready\"]:\n    77→        status, body = request(\"GET\", path)\n    78→        if status == 200:\n    79→            log(\"PASS\", f\"Health check {path} returned 200\")\n    80→            return\n    81→    log(\"FAIL\", \"No health endpoint returned 200\")\n    82→\n    83→\n    84→def test_create_order():\n    85→    \"\"\"Test creating a new order via POST /api/orders.\"\"\"\n    86→    print(\"\\n--- Test: Create Order ---\")\n    87→    order = {\"customer\": \"TestUser\", \"item\": \"Latte\", \"quantity\": 1}\n    88→    status, body = request(\"POST\", \"/api/orders\", body=order)\n    89→    if status in (200, 201, 202):\n    90→        log(\"PASS\", f\"POST /api/orders returned {status}\")\n    91→        try:\n    92→            data = json.loads(body)\n    93→            if \"id\" in data:\n    94→                log(\"PASS\", f\"Response contains order id: {data['id']}\")\n    95→                return data[\"id\"]\n    96→            else:\n    97→                log(\"FAIL\", f\"Response missing 'id' field: {body}\")\n    98→        except json.JSONDecodeError:\n    99→            log(\"FAIL\", f\"Response is not valid JSON: {body}\")\n   100→    else:\n   101→        log(\"FAIL\", f\"POST /api/orders returned {status}: {body}\")\n   102→    return None\n   103→\n   104→\n   105→def test_get_order(order_id):\n   106→    \"\"\"Test getting an order by ID via GET /api/orders/{id}.\"\"\"\n   107→    print(\"\\n--- Test: Get Order ---\")\n   108→    if order_id is None:\n   109→        log(\"FAIL\", \"Skipped - no order ID from creation test\")\n   110→        return\n   111→    status, body = request(\"GET\", f\"/api/orders/{order_id}\")\n   112→    if status == 200:\n   113→        log(\"PASS\", f\"GET /api/orders/{order_id} returned 200\")\n   114→        try:\n   115→            data = json.loads(body)\n   116→            if data.get(\"customer\") == \"TestUser\":\n   117→                log(\"PASS\", \"Order customer matches\")\n   118→            if data.get(\"item\") == \"Latte\":\n   119→                log(\"PASS\", \"Order item matches\")\n   120→            if data.get(\"status\") == \"PLACED\":\n   121→                log(\"PASS\", \"Order status is PLACED\")\n   122→        except json.JSONDecodeError:\n   123→            log(\"FAIL\", f\"Response is not valid JSON: {body}\")\n   124→    else:\n   125→        log(\"FAIL\", f\"GET /api/orders/{order_id} returned {status}: {body}\")\n   126→\n   127→\n   128→def test_create_food_order():\n   129→    \"\"\"Test creating a food (kitchen) order.\"\"\"\n   130→    print(\"\\n--- Test: Create Food Order (Kitchen) ---\")\n   131→    order = {\"customer\": \"FoodTester\", \"item\": \"Sandwich\", \"quantity\": 2}\n   132→    status, body = request(\"POST\", \"/api/orders\", body=order)\n   133→    if status in (200, 201, 202):\n   134→        log(\"PASS\", f\"POST /api/orders (food) returned {status}\")\n   135→        try:\n   136→            data = json.loads(body)\n   137→            if \"id\" in data:\n   138→                log(\"PASS\", f\"Food order id: {data['id']}\")\n   139→        except json.JSONDecodeError:\n   140→            log(\"FAIL\", f\"Response is not valid JSON: {body}\")\n   141→    else:\n   142→        log(\"FAIL\", f\"POST /api/orders (food) returned {status}: {body}\")\n   143→\n   144→\n   145→def test_validation():\n   146→    \"\"\"Test that validation works (missing required fields).\"\"\"\n   147→    print(\"\\n--- Test: Validation ---\")\n   148→    # Missing 'customer' field\n   149→    order = {\"item\": \"Latte\", \"quantity\": 1}\n   150→    status, body = request(\"POST\", \"/api/orders\", body=order)\n   151→    if status == 400:\n   152→        log(\"PASS\", \"Validation correctly rejected request with missing customer (400)\")\n   153→    elif status in (200, 201, 202):\n   154→        # Some frameworks might accept this - check if customer is empty\n   155→        log(\"FAIL\", f\"Validation did not reject missing customer field, got {status}\")\n   156→    else:\n   157→        log(\"PASS\", f\"Request rejected with status {status} (acceptable)\")\n   158→\n   159→\n   160→def test_static_content():\n   161→    \"\"\"Test that static content is served.\"\"\"\n   162→    print(\"\\n--- Test: Static Content ---\")\n   163→    status, body = request(\"GET\", \"/coffeeshopTemplate.html\")\n   164→    if status == 200:\n   165→        log(\"PASS\", \"Static content served at /coffeeshopTemplate.html\")\n   166→    else:\n   167→        # Not a critical failure for the migration\n   168→        log(\"FAIL\", f\"Static content not available: status {status}\")\n   169→\n   170→\n   171→def main():\n   172→    global PASS, FAIL\n   173→\n   174→    if not wait_for_ready():\n   175→        print(\"\\nFATAL: Application did not start in time\")\n   176→        sys.exit(1)\n   177→\n   178→    test_health()\n   179→    order_id = test_create_order()\n   180→    test_get_order(order_id)\n   181→    test_create_food_order()\n   182→    test_validation()\n   183→    test_static_content()\n   184→\n   185→    print(f\"\\n{'='*50}\")\n   186→    print(f\"Results: {PASS} passed, {FAIL} failed out of {PASS + FAIL} checks\")\n   187→    print(f\"{'='*50}\")\n   188→\n   189→    if FAIL > 0:\n   190→        sys.exit(1)\n   191→    sys.exit(0)\n   192→\n   193→\n   194→if __name__ == \"__main__\":\n   195→    main()\n   196→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c8c0436c-69f4-4378-aa8f-dd3eb0ddb087","uuid":"7525f0cb-152c-4a32-8465-56709d68383e"}
