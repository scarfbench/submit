rkus.messaging.kafka.health.enabled=false\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":150,"cache_read_input_tokens":94178,"cache_creation":{"ephemeral_5m_input_tokens":150,"ephemeral_1h_input_tokens":0},"output_tokens":1351},"context_management":null},"parent_tool_use_id":null,"session_id":"c8c0436c-69f4-4378-aa8f-dd3eb0ddb087","uuid":"96166474-d767-4b83-b5e7-8f99af7ab584"}
