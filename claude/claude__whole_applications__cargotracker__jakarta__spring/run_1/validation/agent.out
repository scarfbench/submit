 getToDate() {\n    return toDate;\n  }\n\n  public void setToDate(LocalDateTime toDate) {\n    this.toDate = toDate;\n  }\n\n  @Override\n  public String toString() {\n    return \"TransitEdge{\"\n        + \"voyageNumber=\"\n        + voyageNumber\n        + \", fromUnLocode=\"\n        + fromUnLocode\n        + \", toUnLocode=\"\n        + toUnLocode\n        + \", fromDate=\"\n        + fromDate\n        + \", toDate=\"\n        + toDate\n        + '}';\n  }\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":4066,"cache_read_input_tokens":13124,"cache_creation":{"ephemeral_5m_input_tokens":4066,"ephemeral_1h_input_tokens":0},"output_tokens":2800},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01CQRHZcGZ1gQdiwRtSUUdQ1","session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"998da366-b049-40b8-a7f1-e591072f3be3"}
