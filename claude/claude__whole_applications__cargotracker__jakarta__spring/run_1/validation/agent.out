{\n    return eventType;\n  }\n\n  public void setEventType(String value) {\n    this.eventType = value;\n  }\n\n  public String getUnLocode() {\n    return unLocode;\n  }\n\n  public void setUnLocode(String value) {\n    this.unLocode = value;\n  }\n\n  public String getVoyageNumber() {\n    return voyageNumber;\n  }\n\n  public void setVoyageNumber(String value) {\n    this.voyageNumber = value;\n  }\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6422,"cache_read_input_tokens":130553,"cache_creation":{"ephemeral_5m_input_tokens":6422,"ephemeral_1h_input_tokens":0},"output_tokens":2172},"context_management":null},"parent_tool_use_id":null,"session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"ca2eb223-e228-4be6-9abf-471d6cdb907b"}
