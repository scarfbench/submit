ges in CHANGELOG.md"}]}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3117,"cache_read_input_tokens":73563,"cache_creation":{"ephemeral_5m_input_tokens":3117,"ephemeral_1h_input_tokens":0},"output_tokens":752},"context_management":null},"parent_tool_use_id":null,"session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"566c9392-2c6c-4e3e-a612-688e2ffb88f6"}
