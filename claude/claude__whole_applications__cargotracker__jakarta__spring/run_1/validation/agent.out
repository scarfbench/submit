{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Dj3PKEcsc7hB1JtdrpUawf","type":"tool_result","content":"     1→package org.eclipse.cargotracker.domain.model.cargo;\n     2→\n     3→import java.io.Serializable;\n     4→import java.time.LocalDateTime;\n     5→import java.time.temporal.ChronoUnit;\n     6→import javax.persistence.Column;\n     7→import javax.persistence.Entity;\n     8→import javax.persistence.GeneratedValue;\n     9→import javax.persistence.Id;\n    10→import javax.persistence.JoinColumn;\n    11→import javax.persistence.ManyToOne;\n    12→import javax.validation.constraints.NotNull;\n    13→import org.apache.commons.lang3.Validate;\n    14→import org.apache.commons.lang3.builder.EqualsBuilder;\n    15→import org.apache.commons.lang3.builder.HashCodeBuilder;\n    16→import org.eclipse.cargotracker.domain.model.location.Location;\n    17→import org.eclipse.cargotracker.domain.model.voyage.Voyage;\n    18→\n    19→@Entity\n    20→public class Leg implements Serializable {\n    21→\n    22→  private static final long serialVersionUID = 1L;\n    23→\n    24→  @Id @GeneratedValue private Long id;\n    25→\n    26→  @ManyToOne\n    27→  @JoinColumn(name = \"voyage_id\")\n    28→  @NotNull\n    29→  private Voyage voyage;\n    30→\n    31→  @ManyToOne\n    32→  @JoinColumn(name = \"load_location_id\")\n    33→  @NotNull\n    34→  private Location loadLocation;\n    35→\n    36→  @ManyToOne\n    37→  @JoinColumn(name = \"unload_location_id\")\n    38→  @NotNull\n    39→  private Location unloadLocation;\n    40→\n    41→  @Column(name = \"load_time\")\n    42→  @NotNull\n    43→  private LocalDateTime loadTime;\n    44→\n    45→  @Column(name = \"unload_time\")\n    46→  @NotNull\n    47→  private LocalDateTime unloadTime;\n    48→\n    49→  public Leg() {\n    50→    // Nothing to initialize.\n    51→  }\n    52→\n    53→  public Leg(\n    54→      Voyage voyage,\n    55→      Location loadLocation,\n    56→      Location unloadLocation,\n    57→      LocalDateTime loadTime,\n    58→      LocalDateTime unloadTime) {\n    59→    Validate.noNullElements(\n    60→        new Object[] {voyage, loadLocation, unloadLocation, loadTime, unloadTime});\n    61→\n    62→    this.voyage = voyage;\n    63→    this.loadLocation = loadLocation;\n    64→    this.unloadLocation = unloadLocation;\n    65→\n    66→    // This is a workaround to a Hibernate issue. when the `LocalDateTime` field is persisted into\n    67→    // the DB, and retrieved from the DB, the values are different by nanoseconds.\n    68→    this.loadTime = loadTime.truncatedTo(ChronoUnit.SECONDS);\n    69→    this.unloadTime = unloadTime.truncatedTo(ChronoUnit.SECONDS);\n    70→  }\n    71→\n    72→  public Voyage getVoyage() {\n    73→    return voyage;\n    74→  }\n    75→\n    76→  public Location getLoadLocation() {\n    77→    return loadLocation;\n    78→  }\n    79→\n    80→  public Location getUnloadLocation() {\n    81→    return unloadLocation;\n    82→  }\n    83→\n    84→  public LocalDateTime getLoadTime() {\n    85→    return this.loadTime;\n    86→  }\n    87→\n    88→  public LocalDateTime getUnloadTime() {\n    89→    return this.unloadTime;\n    90→  }\n    91→\n    92→  private boolean sameValueAs(Leg other) {\n    93→    return other != null\n    94→        && new EqualsBuilder()\n    95→            .append(this.voyage, other.voyage)\n    96→            .append(this.loadLocation, other.loadLocation)\n    97→            .append(this.unloadLocation, other.unloadLocation)\n    98→            .append(this.loadTime, other.loadTime)\n    99→            .append(this.unloadTime, other.unloadTime)\n   100→            .isEquals();\n   101→  }\n   102→\n   103→  @Override\n   104→  public boolean equals(Object o) {\n   105→    if (this == o) {\n   106→      return true;\n   107→    }\n   108→\n   109→    if (o == null || !(o instanceof Leg)) {\n   110→      return false;\n   111→    }\n   112→\n   113→    Leg leg = (Leg) o;\n   114→\n   115→    return sameValueAs(leg);\n   116→  }\n   117→\n   118→  @Override\n   119→  public int hashCode() {\n   120→    return new HashCodeBuilder()\n   121→        .append(voyage)\n   122→        .append(loadLocation)\n   123→        .append(unloadLocation)\n   124→        .append(loadTime)\n   125→        .append(unloadTime)\n   126→        .toHashCode();\n   127→  }\n   128→\n   129→  @Override\n   130→  public String toString() {\n   131→    return \"Leg{\"\n   132→        + \"id=\"\n   133→        + id\n   134→        + \", voyage=\"\n   135→        + voyage\n   136→        + \", loadLocation=\"\n   137→        + loadLocation\n   138→        + \", unloadLocation=\"\n   139→        + unloadLocation\n   140→        + \", loadTime=\"\n   141→        + loadTime\n   142→        + \", unloadTime=\"\n   143→        + unloadTime\n   144→        + '}';\n   145→  }\n   146→}\n   147→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_015xY2XDHV9vTQQdv1Xp54tY","session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"7b89c055-c923-47b4-b0b6-78fd0ceabfb2"}
