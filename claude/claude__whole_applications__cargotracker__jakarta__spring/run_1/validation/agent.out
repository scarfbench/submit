Writer(\n                    new File(\n                        failedDir,\n                        \"failed_\"\n                            + jobName\n                            + \"_\"\n                            + instanceId\n                            + \".csv\"),\n                    true)))) {\n      failed.println(parseException.getLine());\n    }\n  }\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":5734,"cache_read_input_tokens":90760,"cache_creation":{"ephemeral_5m_input_tokens":5734,"ephemeral_1h_input_tokens":0},"output_tokens":4368},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01P9o4BPvGfqGgpY4qAiCPkX","session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"e1b5b856-7e3c-490d-9627-156739a440a4"}
