;\n    22→import org.eclipse.cargotracker.domain.model.location.UnLocode;\n    23→\n    24→/**\n    25→ * At the moment, coordinates are produced by a simple factory. It may be converted to a repository\n    26→ * if coordinates become a domain layer concern.\n    27→ */\n    28→public class CoordinatesFactory {\n    29→\n    30→  private static final Map<String, Coordinates> COORDINATES_MAP;\n    31→\n    32→  private CoordinatesFactory() {\n    33→    /* Prevent instantiation. */\n    34→  }\n    35→\n    36→  public static Coordinates find(Location location) {\n    37→    return find(location.getUnLocode());\n    38→  }\n    39→\n    40→  public static Coordinates find(UnLocode unLocode) {\n    41→    return find(unLocode.getIdString());\n    42→  }\n    43→\n    44→  public static Coordinates find(String unLocode) {\n    45→    return COORDINATES_MAP.get(unLocode);\n    46→  }\n    47→\n    48→  static {\n    49→    Map<String, Coordinates> map = new HashMap<>();\n    50→\n    51→    // TODO [Clean Code] See if there is a service to get the latitude/longitude data from.\n    52→    map.put(HONGKONG.getUnLocode().getIdString(), new Coordinates(22, 114));\n    53→    map.put(MELBOURNE.getUnLocode().getIdString(), new Coordinates(-38, 145));\n    54→    map.put(STOCKHOLM.getUnLocode().getIdString(), new Coordinates(59, 18));\n    55→    map.put(HELSINKI.getUnLocode().getIdString(), new Coordinates(60, 25));\n    56→    map.put(CHICAGO.getUnLocode().getIdString(), new Coordinates(42, -88));\n    57→    map.put(TOKYO.getUnLocode().getIdString(), new Coordinates(36, 140));\n    58→    map.put(HAMBURG.getUnLocode().getIdString(), new Coordinates(54, 10));\n    59→    map.put(SHANGHAI.getUnLocode().getIdString(), new Coordinates(31, 121));\n    60→    map.put(ROTTERDAM.getUnLocode().getIdString(), new Coordinates(52, 5));\n    61→    map.put(GOTHENBURG.getUnLocode().getIdString(), new Coordinates(58, 12));\n    62→    map.put(HANGZOU.getUnLocode().getIdString(), new Coordinates(30, 120));\n    63→    map.put(NEWYORK.getUnLocode().getIdString(), new Coordinates(41, -74));\n    64→    map.put(DALLAS.getUnLocode().getIdString(), new Coordinates(33, -97));\n    65→    map.put(UNKNOWN.getUnLocode().getIdString(), new Coordinates(-90, 0)); // The South Pole.\n    66→\n    67→    COORDINATES_MAP = Collections.unmodifiableMap(map);\n    68→  }\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_bdrk_01P9o4BPvGfqGgpY4qAiCPkX","session_id":"cb64f649-59c6-4f3a-a73b-f24ff02d923c","uuid":"c95a7aa7-820e-498c-941f-9cf9558ef851"}
