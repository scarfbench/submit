long serialVersionUID = 1L;\n    29→\n    30→  @Autowired private BookingServiceFacade bookingServiceFacade;\n    31→\n    32→  private String trackingId;\n    33→  private CargoRoute cargo;\n    34→  private LocalDate arrivalDeadline;\n    35→\n    36→  public String getTrackingId() {\n    37→    return trackingId;\n    38→  }\n    39→\n    40→  public void setTrackingId(String trackingId) {\n    41→    this.trackingId = trackingId;\n    42→  }\n    43→\n    44→  public CargoRoute getCargo() {\n    45→    return cargo;\n    46→  }\n    47→\n    48→  public LocalDate getArrivalDeadline() {\n    49→    return arrivalDeadline;\n    50→  }\n    51→\n    52→  public void setArrivalDeadline(LocalDate arrivalDeadline) {\n    53→    this.arrivalDeadline = arrivalDeadline;\n    54→  }\n    55→\n    56→  public void load() {\n    57→    cargo = bookingServiceFacade.loadCargoForRouting(trackingId);\n    58→    arrivalDeadline = DateConverter.toDate(cargo.getArrivalDeadline());\n    59→  }\n    60→\n    61→  public void changeArrivalDeadline() {\n    62→    bookingServiceFacade.changeDeadline(trackingId, arrivalDeadline);\n    63→    // PrimeFaces dialog closing removed - would be handled by REST API in Spring Boot\n    64→  }\n    65→}\n    66→"}]},"parent_tool_use_id":"toolu_bdrk_017tNw3GqT1JuArZd9x9DxmS","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"22d88cae-bbce-4f31-8404-6e91db0e5c6b"}
