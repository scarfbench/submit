owired private ApplicationEvents applicationEvents;\n    29→\n    30→  @PostMapping(value = \"/reports\", consumes = {\"application/json\", \"application/xml\"})\n    31→  public void submitReport(\n    32→      @NotNull(message = \"Missing handling report.\") @Valid @RequestBody HandlingReport handlingReport) {\n    33→    LocalDateTime completionTime = DateConverter.toDateTime(handlingReport.getCompletionTime());\n    34→    VoyageNumber voyageNumber = null;\n    35→\n    36→    if (handlingReport.getVoyageNumber() != null) {\n    37→      voyageNumber = new VoyageNumber(handlingReport.getVoyageNumber());\n    38→    }\n    39→\n    40→    HandlingEvent.Type type = HandlingEvent.Type.valueOf(handlingReport.getEventType());\n    41→    UnLocode unLocode = new UnLocode(handlingReport.getUnLocode());\n    42→\n    43→    TrackingId trackingId = new TrackingId(handlingReport.getTrackingId());\n    44→\n    45→    HandlingEventRegistrationAttempt attempt =\n    46→        new HandlingEventRegistrationAttempt(\n    47→            LocalDateTime.now(), completionTime, trackingId, voyageNumber, type, unLocode);\n    48→\n    49→    applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n    50→  }\n    51→}\n    52→"}]},"parent_tool_use_id":"toolu_bdrk_01KVSuvnVZ36J4NuwGNUF7jY","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"926b94c8-1bfe-4a71-be9c-573318c9c4b2"}
