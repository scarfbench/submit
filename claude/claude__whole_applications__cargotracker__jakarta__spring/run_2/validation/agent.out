{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_015UVwPN58KhbLZeQwQKf4M6","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import java.io.Serializable;\n     4→import java.util.logging.Level;\n     5→import java.util.logging.Logger;\n     6→import javax.annotation.Resource;\n     7→import javax.enterprise.context.ApplicationScoped;\n     8→import javax.inject.Inject;\n     9→import javax.jms.Destination;\n    10→import javax.jms.JMSContext;\n    11→import org.eclipse.cargotracker.application.ApplicationEvents;\n    12→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    13→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    14→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    15→\n    16→@ApplicationScoped\n    17→public class JmsApplicationEvents implements ApplicationEvents, Serializable {\n    18→\n    19→  private static final long serialVersionUID = 1L;\n    20→  private static final int LOW_PRIORITY = 0;\n    21→  @Inject JMSContext jmsContext;\n    22→\n    23→  @Resource(lookup = \"java:app/jms/CargoHandledQueue\")\n    24→  private Destination cargoHandledQueue;\n    25→\n    26→  @Resource(lookup = \"java:app/jms/MisdirectedCargoQueue\")\n    27→  private Destination misdirectedCargoQueue;\n    28→\n    29→  @Resource(lookup = \"java:app/jms/DeliveredCargoQueue\")\n    30→  private Destination deliveredCargoQueue;\n    31→\n    32→  @Resource(lookup = \"java:app/jms/HandlingEventRegistrationAttemptQueue\")\n    33→  private Destination handlingEventQueue;\n    34→\n    35→  @Inject private Logger logger;\n    36→\n    37→  @Override\n    38→  public void cargoWasHandled(HandlingEvent event) {\n    39→    Cargo cargo = event.getCargo();\n    40→    logger.log(Level.INFO, \"Cargo was handled {0}\", cargo);\n    41→    jmsContext\n    42→        .createProducer()\n    43→        .setPriority(LOW_PRIORITY)\n    44→        .setDisableMessageID(true)\n    45→        .setDisableMessageTimestamp(true)\n    46→        .send(cargoHandledQueue, cargo.getTrackingId().getIdString());\n    47→  }\n    48→\n    49→  @Override\n    50→  public void cargoWasMisdirected(Cargo cargo) {\n    51→    logger.log(Level.INFO, \"Cargo was misdirected {0}\", cargo);\n    52→    jmsContext\n    53→        .createProducer()\n    54→        .setPriority(LOW_PRIORITY)\n    55→        .setDisableMessageID(true)\n    56→        .setDisableMessageTimestamp(true)\n    57→        .send(misdirectedCargoQueue, cargo.getTrackingId().getIdString());\n    58→  }\n    59→\n    60→  @Override\n    61→  public void cargoHasArrived(Cargo cargo) {\n    62→    logger.log(Level.INFO, \"Cargo has arrived {0}\", cargo);\n    63→    jmsContext\n    64→        .createProducer()\n    65→        .setPriority(LOW_PRIORITY)\n    66→        .setDisableMessageID(true)\n    67→        .setDisableMessageTimestamp(true)\n    68→        .send(deliveredCargoQueue, cargo.getTrackingId().getIdString());\n    69→  }\n    70→\n    71→  @Override\n    72→  public void receivedHandlingEventRegistrationAttempt(HandlingEventRegistrationAttempt attempt) {\n    73→    logger.log(Level.INFO, \"Received handling event registration attempt {0}\", attempt);\n    74→    jmsContext\n    75→        .createProducer()\n    76→        .setPriority(LOW_PRIORITY)\n    77→        .setDisableMessageID(true)\n    78→        .setDisableMessageTimestamp(true)\n    79→        .setTimeToLive(1000)\n    80→        .send(handlingEventQueue, attempt);\n    81→  }\n    82→}\n    83→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01WD9HU4zfz66rKcFfgrdxib","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"ae0f4213-7660-4eeb-9b4d-a5e8163b5935"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01C1jGFXy4SWV9SFCs25haSk","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import javax.ejb.ActivationConfigProperty;\n     4→import javax.ejb.MessageDriven;\n     5→import javax.inject.Inject;\n     6→import javax.jms.JMSException;\n     7→import javax.jms.Message;\n     8→import javax.jms.MessageListener;\n     9→import javax.jms.ObjectMessage;\n    10→import org.eclipse.cargotracker.application.HandlingEventService;\n    11→import org.eclipse.cargotracker.domain.model.handling.CannotCreateHandlingEventException;\n    12→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    13→\n    14→/** Consumes handling event registration attempt messages and delegates to proper registration. */\n    15→@MessageDriven(\n    16→    activationConfig = {\n    17→      @ActivationConfigProperty(\n    18→          propertyName = \"destinationType\",\n    19→          propertyValue = \"javax.jms.Queue\"),\n    20→      @ActivationConfigProperty(\n    21→          propertyName = \"destinationLookup\",\n    22→          propertyValue = \"java:app/jms/HandlingEventRegistrationAttemptQueue\")\n    23→    })\n    24→public class HandlingEventRegistrationAttemptConsumer implements MessageListener {\n    25→\n    26→  @Inject private HandlingEventService handlingEventService;\n    27→\n    28→  @Override\n    29→  public void onMessage(Message message) {\n    30→    try {\n    31→      ObjectMessage objectMessage = (ObjectMessage) message;\n    32→      HandlingEventRegistrationAttempt attempt =\n    33→          (HandlingEventRegistrationAttempt) objectMessage.getObject();\n    34→      handlingEventService.registerHandlingEvent(\n    35→          attempt.getCompletionTime(),\n    36→          attempt.getTrackingId(),\n    37→          attempt.getVoyageNumber(),\n    38→          attempt.getUnLocode(),\n    39→          attempt.getType());\n    40→    } catch (JMSException | CannotCreateHandlingEventException e) {\n    41→      // Poison messages will be placed on dead-letter queue.\n    42→      throw new RuntimeException(\"Error occurred processing message\", e);\n    43→    }\n    44→  }\n    45→}\n    46→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01WD9HU4zfz66rKcFfgrdxib","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"0ee427d9-208f-45e1-93a9-4e4e361567c1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WHmYoS99GBdW9pzTujvtGV","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import java.util.logging.Level;\n     4→import java.util.logging.Logger;\n     5→import javax.ejb.ActivationConfigProperty;\n     6→import javax.ejb.MessageDriven;\n     7→import javax.inject.Inject;\n     8→import javax.jms.JMSException;\n     9→import javax.jms.Message;\n    10→import javax.jms.MessageListener;\n    11→\n    12→@MessageDriven(\n    13→    activationConfig = {\n    14→      @ActivationConfigProperty(\n    15→          propertyName = \"destinationType\",\n    16→          propertyValue = \"javax.jms.Queue\"),\n    17→      @ActivationConfigProperty(\n    18→          propertyName = \"destinationLookup\",\n    19→          propertyValue = \"java:app/jms/DeliveredCargoQueue\")\n    20→    })\n    21→public class DeliveredCargoConsumer implements MessageListener {\n    22→\n    23→  @Inject private Logger logger;\n    24→\n    25→  @Override\n    26→  public void onMessage(Message message) {\n    27→    try {\n    28→      logger.log(\n    29→          Level.INFO, \"Cargo with tracking ID {0} delivered.\", message.getBody(String.class));\n    30→    } catch (JMSException ex) {\n    31→      logger.log(Level.WARNING, \"Error processing message.\", ex);\n    32→    }\n    33→  }\n    34→}\n    35→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01WD9HU4zfz66rKcFfgrdxib","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"b0a9bdfe-767c-46f1-bdd5-a61ffdfacc07"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01TWnwfhbWmKqGStoTLsyPzV","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import java.util.logging.Level;\n     4→import java.util.logging.Logger;\n     5→import javax.ejb.ActivationConfigProperty;\n     6→import javax.ejb.MessageDriven;\n     7→import javax.inject.Inject;\n     8→import javax.jms.JMSException;\n     9→import javax.jms.Message;\n    10→import javax.jms.MessageListener;\n    11→import javax.jms.TextMessage;\n    12→import org.eclipse.cargotracker.application.CargoInspectionService;\n    13→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    14→\n    15→/**\n    16→ * Consumes JMS messages and delegates notification of misdirected cargo to the tracking service.\n    17→ *\n    18→ * <p>This is a programmatic hook into the JMS infrastructure to make cargo inspection\n    19→ * message-driven.\n    20→ */\n    21→@MessageDriven(\n    22→    activationConfig = {\n    23→      @ActivationConfigProperty(\n    24→          propertyName = \"destinationType\",\n    25→          propertyValue = \"javax.jms.Queue\"),\n    26→      @ActivationConfigProperty(\n    27→          propertyName = \"destinationLookup\",\n    28→          propertyValue = \"java:app/jms/CargoHandledQueue\")\n    29→    })\n    30→public class CargoHandledConsumer implements MessageListener {\n    31→\n    32→  @Inject private Logger logger;\n    33→\n    34→  @Inject private CargoInspectionService cargoInspectionService;\n    35→\n    36→  @Override\n    37→  public void onMessage(Message message) {\n    38→    try {\n    39→      TextMessage textMessage = (TextMessage) message;\n    40→      String trackingIdString = textMessage.getText();\n    41→\n    42→      cargoInspectionService.inspectCargo(new TrackingId(trackingIdString));\n    43→    } catch (JMSException e) {\n    44→      logger.log(Level.SEVERE, \"Error procesing JMS message\", e);\n    45→    }\n    46→  }\n    47→}\n    48→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01WD9HU4zfz66rKcFfgrdxib","session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"d23b1d92-6b6f-4b4b-ac3b-3833d5034a41"}
