{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01L2UpnBhGSWF2oQPwaMqUBz","type":"tool_result","content":"     1→package org.eclipse.cargotracker.interfaces.handling.mobile;\n     2→\n     3→import static java.util.stream.Collectors.toMap;\n     4→\n     5→import java.io.Serializable;\n     6→import java.time.LocalDateTime;\n     7→import java.util.ArrayList;\n     8→import java.util.Arrays;\n     9→import java.util.Collections;\n    10→import java.util.List;\n    11→import java.util.Map;\n    12→import java.util.function.Function;\n    13→import javax.annotation.PostConstruct;\n    14→import javax.faces.application.FacesMessage;\n    15→import javax.faces.context.FacesContext;\n    16→import javax.faces.model.SelectItem;\n    17→import javax.faces.view.ViewScoped;\n    18→import javax.inject.Inject;\n    19→import javax.inject.Named;\n    20→import org.eclipse.cargotracker.application.ApplicationEvents;\n    21→import org.eclipse.cargotracker.application.util.DateConverter;\n    22→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    23→import org.eclipse.cargotracker.domain.model.cargo.CargoRepository;\n    24→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    25→import org.eclipse.cargotracker.domain.model.cargo.TransportStatus;\n    26→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    27→import org.eclipse.cargotracker.domain.model.location.Location;\n    28→import org.eclipse.cargotracker.domain.model.location.LocationRepository;\n    29→import org.eclipse.cargotracker.domain.model.location.UnLocode;\n    30→import org.eclipse.cargotracker.domain.model.voyage.Voyage;\n    31→import org.eclipse.cargotracker.domain.model.voyage.VoyageNumber;\n    32→import org.eclipse.cargotracker.domain.model.voyage.VoyageRepository;\n    33→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    34→import org.primefaces.event.FlowEvent;\n    35→\n    36→@Named\n    37→@ViewScoped\n    38→public class EventLogger implements Serializable {\n    39→\n    40→  private static final long serialVersionUID = 1L;\n    41→\n    42→  @Inject private CargoRepository cargoRepository;\n    43→  @Inject private LocationRepository locationRepository;\n    44→  @Inject private VoyageRepository voyageRepository;\n    45→  @Inject private ApplicationEvents applicationEvents;\n    46→  @Inject private FacesContext context;\n    47→\n    48→  private List<SelectItem> trackingIds;\n    49→  private List<SelectItem> locations;\n    50→  private List<SelectItem> voyages;\n    51→\n    52→  private String trackingId;\n    53→  private String location;\n    54→  private HandlingEvent.Type eventType;\n    55→  private String voyageNumber;\n    56→  private LocalDateTime completionTime;\n    57→\n    58→  public String getTrackingId() {\n    59→    return trackingId;\n    60→  }\n    61→\n    62→  public void setTrackingId(String trackingId) {\n    63→    this.trackingId = trackingId;\n    64→  }\n    65→\n    66→  public List<SelectItem> getTrackingIds() {\n    67→    return trackingIds;\n    68→  }\n    69→\n    70→  public String getLocation() {\n    71→    return location;\n    72→  }\n    73→\n    74→  public void setLocation(String location) {\n    75→    this.location = location;\n    76→  }\n    77→\n    78→  public List<SelectItem> getLocations() {\n    79→    return locations;\n    80→  }\n    81→\n    82→  // Move this to a separate utility if it is used in other parts of the UI.\n    83→  public Map<HandlingEvent.Type, HandlingEvent.Type> getEventTypes() {\n    84→    return Collections.unmodifiableMap(\n    85→        Arrays.asList(HandlingEvent.Type.values())\n    86→            .stream()\n    87→            .collect(toMap(Function.identity(), Function.identity())));\n    88→  }\n    89→\n    90→  public HandlingEvent.Type getEventType() {\n    91→    return eventType;\n    92→  }\n    93→\n    94→  public void setEventType(HandlingEvent.Type eventType) {\n    95→    this.eventType = eventType;\n    96→  }\n    97→\n    98→  public String getVoyageNumber() {\n    99→    return voyageNumber;\n   100→  }\n   101→\n   102→  public void setVoyageNumber(String voyageNumber) {\n   103→    this.voyageNumber = voyageNumber;\n   104→  }\n   105→\n   106→  public List<SelectItem> getVoyages() {\n   107→    return voyages;\n   108→  }\n   109→\n   110→  public LocalDateTime getCompletionTime() {\n   111→    return completionTime;\n   112→  }\n   113→\n   114→  public void setCompletionTime(LocalDateTime completionTime) {\n   115→    this.completionTime = completionTime;\n   116→  }\n   117→\n   118→  public String getCompletionTimeValue() {\n   119→    return DateConverter.toString(completionTime);\n   120→  }\n   121→\n   122→  public String getCompletionTimePattern() {\n   123→    return DateConverter.DATE_TIME_FORMAT;\n   124→  }\n   125→\n   126→  @PostConstruct\n   127→  public void init() {\n   128→    List<Cargo> cargos = cargoRepository.findAll();\n   129→\n   130→    trackingIds = new ArrayList<>(cargos.size());\n   131→\n   132→    // List only routed cargo that is not claimed yet.\n   133→    cargos\n   134→        .stream()\n   135→        .filter(\n   136→            cargo ->\n   137→                !cargo.getItinerary().getLegs().isEmpty()\n   138→                    && !(cargo\n   139→                        .getDelivery()\n   140→                        .getTransportStatus()\n   141→                        .sameValueAs(TransportStatus.CLAIMED)))\n   142→        .map(cargo -> cargo.getTrackingId().getIdString())\n   143→        .forEachOrdered(trackingId -> trackingIds.add(new SelectItem(trackingId, trackingId)));\n   144→\n   145→    List<Location> locations = locationRepository.findAll();\n   146→\n   147→    this.locations = new ArrayList<>(locations.size());\n   148→\n   149→    locations.forEach(\n   150→        location -> {\n   151→          String locationCode = location.getUnLocode().getIdString();\n   152→          this.locations.add(\n   153→              new SelectItem(locationCode, location.getName() + \" (\" + locationCode + \")\"));\n   154→        });\n   155→\n   156→    List<Voyage> voyages = voyageRepository.findAll();\n   157→\n   158→    this.voyages = new ArrayList<>(voyages.size());\n   159→\n   160→    voyages.forEach(\n   161→        voyage ->\n   162→            this.voyages.add(\n   163→                new SelectItem(\n   164→                    voyage.getVoyageNumber().getIdString(),\n   165→                    voyage.getVoyageNumber().getIdString())));\n   166→  }\n   167→\n   168→  public String onFlowProcess(FlowEvent event) {\n   169→    if (!validate(event.getOldStep())) {\n   170→      return event.getOldStep();\n   171→    }\n   172→\n   173→    if (\"dateTab\".equals(event.getNewStep())) {\n   174→      completionTime = LocalDateTime.now();\n   175→    }\n   176→\n   177→    return event.getNewStep();\n   178→  }\n   179→\n   180→  private boolean validate(final String step) {\n   181→    if (\"voyageTab\".equals(step) && eventType.requiresVoyage() && voyageNumber == null) {\n   182→      FacesMessage message =\n   183→          new FacesMessage(\n   184→              FacesMessage.SEVERITY_ERROR,\n   185→              \"When a cargo is LOADed or UNLOADed a Voyage should be selected, please fix errors to continue.\",\n   186→              \"\");\n   187→      context.addMessage(null, message);\n   188→      return false;\n   189→    }\n   190→\n   191→    return true;\n   192→  }\n   193→\n   194→  public void submit() {\n   195→    VoyageNumber voyage;\n   196→\n   197→    TrackingId trackingId = new TrackingId(this.trackingId);\n   198→    UnLocode location = new UnLocode(this.location);\n   199→\n   200→    if (eventType.requiresVoyage()) {\n   201→      voyage = new VoyageNumber(voyageNumber);\n   202→    } else {\n   203→      voyage = null;\n   204→    }\n   205→\n   206→    HandlingEventRegistrationAttempt attempt =\n   207→        new HandlingEventRegistrationAttempt(\n   208→            LocalDateTime.now(), completionTime, trackingId, voyage, eventType, location);\n   209→\n   210→    applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n   211→\n   212→    FacesContext.getCurrentInstance().addMessage(null, new FacesMessage(\"Event submitted\", \"\"));\n   213→  }\n   214→}\n   215→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"7c2778c9-18d4-4c08-b913-9e098c26f316"}
