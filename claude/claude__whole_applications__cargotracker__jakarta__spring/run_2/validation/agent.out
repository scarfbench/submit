{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01DBwywzUdx9WnycohUKd6Qx","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01LtnjRACKFNpWyGgqbxPG4q","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__cargotracker__jakarta__spring/run_2/output/smoke/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"\nSmoke tests for the Spring Boot Cargo Tracker application.\nTests basic API endpoints and application health after migration from Jakarta EE.\n\"\"\"\n\nimport json\nimport sys\nimport time\nimport requests\n\n\nBASE_URL = None\nCONTEXT_PATH = \"/cargo-tracker\"\n\n\ndef get_base_url():\n    \"\"\"Get the base URL from command line args or default.\"\"\"\n    if len(sys.argv) > 1:\n        return sys.argv[1].rstrip(\"/\")\n    return \"http://localhost:8080\"\n\n\ndef wait_for_app(base_url, timeout=120):\n    \"\"\"Wait for the application to become ready.\"\"\"\n    print(f\"Waiting for application at {base_url} to become ready...\")\n    start = time.time()\n    while time.time() - start < timeout:\n        try:\n            # Try the root or actuator health endpoint\n            resp = requests.get(f\"{base_url}{CONTEXT_PATH}/rest/graph-traversal/shortest-path\",\n                                params={\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"},\n                                timeout=5)\n            if resp.status_code < 500:\n                print(f\"Application is ready (responded with {resp.status_code})\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    print(f\"Application did not become ready within {timeout} seconds\")\n    return False\n\n\ndef test_graph_traversal_shortest_path():\n    \"\"\"Test the graph traversal REST endpoint returns routes.\"\"\"\n    print(\"\\n--- Test: Graph Traversal Shortest Path ---\")\n    url = f\"{BASE_URL}{CONTEXT_PATH}/rest/graph-traversal/shortest-path\"\n    params = {\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"}\n    try:\n        resp = requests.get(url, params=params, timeout=10)\n        print(f\"  Status: {resp.status_code}\")\n        if resp.status_code == 200:\n            data = resp.json()\n            print(f\"  Response contains {len(data)} route(s)\")\n            if len(data) > 0:\n                print(\"  PASS: Graph traversal endpoint returns routes\")\n                return True\n            else:\n                print(\"  FAIL: No routes returned\")\n                return False\n        else:\n            print(f\"  FAIL: Expected 200, got {resp.status_code}\")\n            print(f\"  Body: {resp.text[:500]}\")\n            return False\n    except Exception as e:\n        print(f\"  FAIL: {e}\")\n        return False\n\n\ndef test_handling_report_endpoint():\n    \"\"\"Test that the handling report REST endpoint accepts POST requests.\"\"\"\n    print(\"\\n--- Test: Handling Report Endpoint ---\")\n    url = f\"{BASE_URL}{CONTEXT_PATH}/rest/handling/reports\"\n    payload = {\n        \"completionTime\": \"2024-03-15 00:00\",\n        \"trackingId\": \"ABC123\",\n        \"eventType\": \"RECEIVE\",\n        \"unLocode\": \"CNHKG\",\n        \"voyageNumber\": \"\"\n    }\n    headers = {\"Content-Type\": \"application/json\"}\n    try:\n        resp = requests.post(url, json=payload, headers=headers, timeout=10)\n        print(f\"  Status: {resp.status_code}\")\n        # 200, 201, 202, or 204 all acceptable; 400 means validation which is still working\n        if resp.status_code in (200, 201, 202, 204, 400):\n            print(f\"  PASS: Handling report endpoint is responsive (status {resp.status_code})\")\n            return True\n        else:\n            print(f\"  FAIL: Unexpected status {resp.status_code}\")\n            print(f\"  Body: {resp.text[:500]}\")\n            return False\n    except Exception as e:\n        print(f\"  FAIL: {e}\")\n        return False\n\n\ndef test_application_root():\n    \"\"\"Test that the application root responds.\"\"\"\n    print(\"\\n--- Test: Application Root ---\")\n    url = f\"{BASE_URL}{CONTEXT_PATH}/\"\n    try:\n        resp = requests.get(url, timeout=10, allow_redirects=True)\n        print(f\"  Status: {resp.status_code}\")\n        if resp.status_code < 500:\n            print(f\"  PASS: Application root is accessible (status {resp.status_code})\")\n            return True\n        else:\n            print(f\"  FAIL: Server error {resp.status_code}\")\n            print(f\"  Body: {resp.text[:500]}\")\n            return False\n    except Exception as e:\n        print(f\"  FAIL: {e}\")\n        return False\n\n\ndef test_cargo_tracking_sse_endpoint():\n    \"\"\"Test that the SSE cargo tracking endpoint exists.\"\"\"\n    print(\"\\n--- Test: Cargo Tracking SSE Endpoint ---\")\n    url = f\"{BASE_URL}{CONTEXT_PATH}/rest/cargo/tracking\"\n    try:\n        # SSE endpoint - just check it accepts connections\n        resp = requests.get(url, timeout=5, stream=True,\n                            headers={\"Accept\": \"text/event-stream\"})\n        print(f\"  Status: {resp.status_code}\")\n        resp.close()\n        if resp.status_code == 200:\n            print(\"  PASS: SSE endpoint is accessible\")\n            return True\n        else:\n            # SSE may return different status, just check it's not 404/500\n            if resp.status_code < 500 and resp.status_code != 404:\n                print(f\"  PASS: SSE endpoint responded (status {resp.status_code})\")\n                return True\n            print(f\"  FAIL: SSE endpoint returned {resp.status_code}\")\n            return False\n    except requests.exceptions.ReadTimeout:\n        # Timeout on SSE is actually expected behavior (it's a streaming endpoint)\n        print(\"  PASS: SSE endpoint accepted connection (timed out reading as expected)\")\n        return True\n    except Exception as e:\n        print(f\"  FAIL: {e}\")\n        return False\n\n\ndef main():\n    global BASE_URL\n    BASE_URL = get_base_url()\n\n    print(f\"Running smoke tests against {BASE_URL}\")\n    print(\"=\" * 60)\n\n    # Wait for app to be ready\n    if not wait_for_app(BASE_URL):\n        print(\"\\nFATAL: Application not ready. Exiting.\")\n        sys.exit(1)\n\n    results = []\n\n    # Run all tests\n    results.append((\"Application Root\", test_application_root()))\n    results.append((\"Graph Traversal\", test_graph_traversal_shortest_path()))\n    results.append((\"Handling Report\", test_handling_report_endpoint()))\n    results.append((\"SSE Cargo Tracking\", test_cargo_tracking_sse_endpoint()))\n\n    # Summary\n    print(\"\\n\" + \"=\" * 60)\n    print(\"SMOKE TEST RESULTS\")\n    print(\"=\" * 60)\n    passed = 0\n    failed = 0\n    for name, result in results:\n        status = \"PASS\" if result else \"FAIL\"\n        print(f\"  [{status}] {name}\")\n        if result:\n            passed += 1\n        else:\n            failed += 1\n\n    print(f\"\\nTotal: {passed} passed, {failed} failed out of {len(results)}\")\n\n    if failed > 0:\n        print(\"\\nSome smoke tests FAILED!\")\n        sys.exit(1)\n    else:\n        print(\"\\nAll smoke tests PASSED!\")\n        sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":566,"cache_read_input_tokens":28865,"cache_creation":{"ephemeral_5m_input_tokens":566,"ephemeral_1h_input_tokens":0},"output_tokens":2032},"context_management":null},"parent_tool_use_id":null,"session_id":"18f7ec53-4184-4cad-96bc-6843d85e3d1e","uuid":"dcaebe19-510b-42cc-8531-4f1238f2a424"}
