nLocode() {\n    51→    return toUnLocode;\n    52→  }\n    53→\n    54→  public void setToUnLocode(String toUnLocode) {\n    55→    this.toUnLocode = toUnLocode;\n    56→  }\n    57→\n    58→  public LocalDateTime getFromDate() {\n    59→    return fromDate;\n    60→  }\n    61→\n    62→  public void setFromDate(LocalDateTime fromDate) {\n    63→    this.fromDate = fromDate;\n    64→  }\n    65→\n    66→  public LocalDateTime getToDate() {\n    67→    return toDate;\n    68→  }\n    69→\n    70→  public void setToDate(LocalDateTime toDate) {\n    71→    this.toDate = toDate;\n    72→  }\n    73→\n    74→  @Override\n    75→  public String toString() {\n    76→    return \"TransitEdge{\"\n    77→        + \"voyageNumber=\"\n    78→        + voyageNumber\n    79→        + \", fromUnLocode=\"\n    80→        + fromUnLocode\n    81→        + \", toUnLocode=\"\n    82→        + toUnLocode\n    83→        + \", fromDate=\"\n    84→        + fromDate\n    85→        + \", toDate=\"\n    86→        + toDate\n    87→        + '}';\n    88→  }\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_bdrk_01KhmE1DhzTn2EKQVW8SAwmW","session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"d53df9e8-aeb2-4bd7-ad68-d283555a4872"}
