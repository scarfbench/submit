      logger.log(Level.WARNING, \"Can''t inspect non-existing cargo {0}\", trackingId);\n    31→      return;\n    32→    }\n    33→    HandlingHistory handlingHistory =\n    34→        handlingEventRepository.lookupHandlingHistoryOfCargo(trackingId);\n    35→    cargo.deriveDeliveryProgress(handlingHistory);\n    36→    if (cargo.getDelivery().isMisdirected()) {\n    37→      applicationEvents.cargoWasMisdirected(cargo);\n    38→    }\n    39→    if (cargo.getDelivery().isUnloadedAtDestination()) {\n    40→      applicationEvents.cargoHasArrived(cargo);\n    41→    }\n    42→    cargoRepository.store(cargo);\n    43→  }\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_bdrk_01HzJoSxvNXYmAc4vzHtPgjV","session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"54ebd670-b3f4-425d-9d03-6d7c07526d94"}
