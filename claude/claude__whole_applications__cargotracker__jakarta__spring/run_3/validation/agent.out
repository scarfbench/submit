{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01WDVL9qAbjAEHX93UoTb9o8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01Gb6UoMgJRFjo59Jn7DjaRd","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__cargotracker__jakarta__spring/run_3/output/smoke/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"Smoke tests for Cargo Tracker Spring Boot application.\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport requests\n\nBASE_URL = os.environ.get(\"BASE_URL\", \"http://localhost:8080\")\n\npassed = 0\nfailed = 0\nerrors = []\n\n\ndef test(name, func):\n    global passed, failed\n    try:\n        func()\n        passed += 1\n        print(f\"  PASS: {name}\")\n    except AssertionError as e:\n        failed += 1\n        errors.append(f\"{name}: {e}\")\n        print(f\"  FAIL: {name} - {e}\")\n    except Exception as e:\n        failed += 1\n        errors.append(f\"{name}: {e}\")\n        print(f\"  ERROR: {name} - {e}\")\n\n\ndef wait_for_app(max_wait=120):\n    \"\"\"Wait for the application to be ready.\"\"\"\n    print(f\"Waiting for app at {BASE_URL}...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            r = requests.get(f\"{BASE_URL}/actuator/health\", timeout=5)\n            if r.status_code == 200:\n                print(f\"App is ready (took {int(time.time() - start)}s)\")\n                return True\n        except requests.exceptions.ConnectionError:\n            pass\n        except requests.exceptions.Timeout:\n            pass\n        time.sleep(2)\n    print(f\"App did not become ready within {max_wait}s\")\n    return False\n\n\nclass AssertionError(Exception):\n    pass\n\n\ndef assert_eq(actual, expected, msg=\"\"):\n    if actual != expected:\n        raise AssertionError(f\"{msg}: expected {expected}, got {actual}\")\n\n\ndef assert_true(val, msg=\"\"):\n    if not val:\n        raise AssertionError(f\"{msg}: expected truthy value\")\n\n\ndef assert_status(r, expected, msg=\"\"):\n    if r.status_code != expected:\n        raise AssertionError(\n            f\"{msg}: expected status {expected}, got {r.status_code}. Body: {r.text[:200]}\"\n        )\n\n\n# ---- Tests ----\n\ndef test_health_endpoint():\n    r = requests.get(f\"{BASE_URL}/actuator/health\", timeout=10)\n    assert_status(r, 200, \"Health check\")\n    data = r.json()\n    assert_eq(data.get(\"status\"), \"UP\", \"Health status\")\n\n\ndef test_list_locations():\n    r = requests.get(f\"{BASE_URL}/api/booking/locations\", timeout=10)\n    assert_status(r, 200, \"List locations\")\n    data = r.json()\n    assert_true(len(data) > 0, \"Should have locations\")\n\n\ndef test_list_cargos():\n    r = requests.get(f\"{BASE_URL}/api/booking/cargos\", timeout=10)\n    assert_status(r, 200, \"List cargos\")\n    data = r.json()\n    assert_true(len(data) >= 0, \"Should return cargo list\")\n\n\ndef test_list_tracking_ids():\n    r = requests.get(f\"{BASE_URL}/api/booking/tracking-ids\", timeout=10)\n    assert_status(r, 200, \"List tracking IDs\")\n    data = r.json()\n    assert_true(isinstance(data, list), \"Should return a list\")\n\n\ndef test_track_known_cargo():\n    \"\"\"Track a cargo that was loaded via sample data (ABC123).\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/booking/cargo/ABC123/status\", timeout=10)\n    if r.status_code == 200:\n        data = r.json()\n        assert_true(\"trackingId\" in data, \"Should have trackingId field\")\n    # 404 is also acceptable if sample data not loaded yet\n\n\ndef test_cargo_details_for_routing():\n    \"\"\"Get cargo details for routing (ABC123).\"\"\"\n    r = requests.get(f\"{BASE_URL}/api/booking/cargo/ABC123\", timeout=10)\n    if r.status_code == 200:\n        data = r.json()\n        assert_true(\"trackingId\" in data, \"Should have trackingId\")\n\n\ndef test_book_new_cargo():\n    \"\"\"Book a new cargo.\"\"\"\n    payload = {\n        \"origin\": \"USCHI\",\n        \"destination\": \"JNTKO\",\n        \"arrivalDeadline\": \"2026-12-01\"\n    }\n    r = requests.post(\n        f\"{BASE_URL}/api/booking/cargos\",\n        json=payload,\n        timeout=10\n    )\n    assert_status(r, 200, \"Book new cargo\")\n    data = r.json()\n    assert_true(\"trackingId\" in data, \"Should return tracking ID\")\n    return data[\"trackingId\"]\n\n\ndef test_graph_traversal():\n    \"\"\"Test the pathfinder graph traversal endpoint.\"\"\"\n    r = requests.get(\n        f\"{BASE_URL}/api/graph-traversal/shortest-path\",\n        params={\"origin\": \"CNHKG\", \"destination\": \"FIHEL\"},\n        timeout=10\n    )\n    assert_status(r, 200, \"Graph traversal\")\n    data = r.json()\n    assert_true(isinstance(data, list), \"Should return list of paths\")\n\n\ndef test_handling_report():\n    \"\"\"Submit a handling report.\"\"\"\n    payload = {\n        \"completionTime\": \"3/15/2026 12:00 PM\",\n        \"trackingId\": \"ABC123\",\n        \"eventType\": \"UNLOAD\",\n        \"unLocode\": \"USDAL\",\n        \"voyageNumber\": \"0200T\"\n    }\n    r = requests.post(\n        f\"{BASE_URL}/api/handling/reports\",\n        json=payload,\n        timeout=10\n    )\n    # Accept 200 or 204\n    assert_true(r.status_code in [200, 204], f\"Handling report: got {r.status_code}\")\n\n\ndef main():\n    print(f\"\\n{'='*60}\")\n    print(f\"Cargo Tracker Smoke Tests\")\n    print(f\"Base URL: {BASE_URL}\")\n    print(f\"{'='*60}\\n\")\n\n    if not wait_for_app():\n        print(\"FATAL: Application did not start. Aborting tests.\")\n        sys.exit(1)\n\n    # Give the app a moment to finish loading sample data\n    time.sleep(5)\n\n    print(\"\\nRunning tests...\\n\")\n\n    test(\"Health endpoint\", test_health_endpoint)\n    test(\"List locations\", test_list_locations)\n    test(\"List cargos\", test_list_cargos)\n    test(\"List tracking IDs\", test_list_tracking_ids)\n    test(\"Track known cargo (ABC123)\", test_track_known_cargo)\n    test(\"Cargo details for routing\", test_cargo_details_for_routing)\n    test(\"Book new cargo\", test_book_new_cargo)\n    test(\"Graph traversal\", test_graph_traversal)\n    test(\"Handling report\", test_handling_report)\n\n    print(f\"\\n{'='*60}\")\n    print(f\"Results: {passed} passed, {failed} failed\")\n    if errors:\n        print(\"\\nFailures:\")\n        for e in errors:\n            print(f\"  - {e}\")\n    print(f\"{'='*60}\\n\")\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":313,"cache_read_input_tokens":74596,"cache_creation":{"ephemeral_5m_input_tokens":313,"ephemeral_1h_input_tokens":0},"output_tokens":2002},"context_management":null},"parent_tool_use_id":null,"session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"5e551a33-6aa0-4d1a-a06f-b67ed5077dbb"}
