Deadline must be in the future.\")\n          LocalDate deadline);\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":9412,"cache_read_input_tokens":10421,"cache_creation":{"ephemeral_5m_input_tokens":9412,"ephemeral_1h_input_tokens":0},"output_tokens":9271},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01HzJoSxvNXYmAc4vzHtPgjV","session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"031f7303-aa0c-4f84-bc6d-dd92579e8f4e"}
