7→\n    28→  @Override\n    29→  public void registerHandlingEvent(\n    30→      LocalDateTime completionTime,\n    31→      TrackingId trackingId,\n    32→      VoyageNumber voyageNumber,\n    33→      UnLocode unLocode,\n    34→      HandlingEvent.Type type)\n    35→      throws CannotCreateHandlingEventException {\n    36→    LocalDateTime registrationTime = LocalDateTime.now();\n    37→    HandlingEvent event =\n    38→        handlingEventFactory.createHandlingEvent(\n    39→            registrationTime, completionTime, trackingId, voyageNumber, unLocode, type);\n    40→    handlingEventRepository.store(event);\n    41→    applicationEvents.cargoWasHandled(event);\n    42→    logger.info(\"Registered handling event\");\n    43→  }\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_bdrk_01HzJoSxvNXYmAc4vzHtPgjV","session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"3e7d0cc8-6bd3-4bd2-ad26-abbe8072ab6e"}
