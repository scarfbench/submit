Deadline must be in the future.\")\n          LocalDate deadline);\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":13274,"cache_read_input_tokens":30226,"cache_creation":{"ephemeral_5m_input_tokens":13274,"ephemeral_1h_input_tokens":0},"output_tokens":9262},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01HzJoSxvNXYmAc4vzHtPgjV","session_id":"08d2657a-d0d7-410a-941f-d00e90a603b3","uuid":"71ab3b9a-7648-46d2-b27f-dace27235aa8"}
