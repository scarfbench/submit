\n    37→                .getResultList();\n    38→        return results.isEmpty() ? null : results.get(0);\n    39→    }\n    40→\n    41→    public void deleteAllByOrderId(Integer orderId) {\n    42→        em.createQuery(\"DELETE FROM LineItem l WHERE l.customerOrder.orderId = :orderId\")\n    43→                .setParameter(\"orderId\", orderId)\n    44→                .executeUpdate();\n    45→        em.flush();\n    46→    }\n    47→\n    48→    public LineItem save(LineItem lineItem) {\n    49→        if (lineItem.getCustomerOrder() != null) {\n    50→            // Check if it exists\n    51→            try {\n    52→                em.persist(lineItem);\n    53→            } catch (Exception e) {\n    54→                return em.merge(lineItem);\n    55→            }\n    56→        }\n    57→        return lineItem;\n    58→    }\n    59→}\n    60→"}]},"parent_tool_use_id":null,"session_id":"8913198c-9d1c-4b4e-afa3-ca816a8bda5a","uuid":"8c4b5bea-88bc-4c3f-81c7-7bff257b14d5"}
