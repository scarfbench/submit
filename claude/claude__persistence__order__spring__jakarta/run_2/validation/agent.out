 assert resp.status_code == 200, f\"Expected 200, got {resp.status_code}\"\n    body = resp.text\n    assert \"1111\" in body or \"4312\" in body, \\\n        \"Page should contain initial order IDs (1111 or 4312)\"\n    print(\"[PASS] Order page contains initialized data\")\n    return True\n\n\ndef test_order_page_has_form():\n    \"\"\"Test that the order page has the create order form elements.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/order.xhtml\", timeout=10)\n    assert resp.status_code == 200, f\"Expected 200, got {resp.status_code}\"\n    body = resp.text\n    assert \"Submit\" in body or \"submit\" in body.lower(), \\\n        \"Page should contain submit button\"\n    print(\"[PASS] Order page has form elements\")\n    return True\n\n\ndef test_line_item_page():\n    \"\"\"Test that the line item page template loads.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/lineItem.xhtml\", timeout=10)\n    assert resp.status_code in [200, 302], \\\n        f\"Expected 200 or 302, got {resp.status_code}\"\n    print(\"[PASS] Line item page is accessible\")\n    return True\n\n\ndef test_vendor_search():\n    \"\"\"Test that the vendor search area exists on the page.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/order.xhtml\", timeout=10)\n    assert resp.status_code == 200, f\"Expected 200, got {resp.status_code}\"\n    body = resp.text\n    assert \"Vendor\" in body or \"vendor\" in body.lower(), \\\n        \"Page should contain vendor search section\"\n    print(\"[PASS] Vendor search section present\")\n    return True\n\n\ndef test_discount_info():\n    \"\"\"Test that discount information is present on the page.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/order.xhtml\", timeout=10)\n    assert resp.status_code == 200, f\"Expected 200, got {resp.status_code}\"\n    body = resp.text\n    assert \"%\" in body, \"Page should contain discount percentages\"\n    print(\"[PASS] Discount information present\")\n    return True\n\n\ndef test_shipment_info():\n    \"\"\"Test that shipment info is present on the page.\"\"\"\n    resp = requests.get(f\"{BASE_URL}/order.xhtml\", timeout=10)\n    assert resp.status_code == 200, f\"Expected 200, got {resp.status_code}\"\n    body = resp.text\n    assert \"New Court\" in body or \"90000\" in body, \\\n        \"Page should contain shipment info from initialized data\"\n    print(\"[PASS] Shipment info present\")\n    return True\n\n\ndef main():\n    print(\"=\" * 60)\n    print(\"Smoke Tests - Order Management Jakarta EE Application\")\n    print(\"=\" * 60)\n    print(f\"Base URL: {BASE_URL}\")\n    print()\n\n    if not wait_for_app():\n        sys.exit(1)\n\n    tests = [\n        test_order_page,\n        test_order_page_has_data,\n        test_order_page_has_form,\n        test_line_item_page,\n        test_vendor_search,\n        test_discount_info,\n        test_shipment_info,\n    ]\n\n    passed = 0\n    failed = 0\n    errors = []\n\n    for test in tests:\n        try:\n            test()\n            passed += 1\n        except AssertionError as e:\n            failed += 1\n            errors.append(f\"  {test.__name__}: {e}\")\n            print(f\"[FAIL] {test.__name__}: {e}\")\n        except Exception as e:\n            failed += 1\n            errors.append(f\"  {test.__name__}: {e}\")\n            print(f\"[ERROR] {test.__name__}: {e}\")\n\n    print()\n    print(\"=\" * 60)\n    print(f\"Results: {passed} passed, {failed} failed out of {len(tests)} tests\")\n    print(\"=\" * 60)\n\n    if errors:\n        print(\"\\nFailures:\")\n        for err in errors:\n            print(err)\n\n    sys.exit(0 if failed == 0 else 1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":631,"cache_read_input_tokens":50645,"cache_creation":{"ephemeral_5m_input_tokens":631,"ephemeral_1h_input_tokens":0},"output_tokens":1626},"context_management":null},"parent_tool_use_id":null,"se