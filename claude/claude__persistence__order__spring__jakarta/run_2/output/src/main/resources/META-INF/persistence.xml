<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="orderPU" transaction-type="JTA">
        <jta-data-source>jdbc/orderDS</jta-data-source>
        <class>com.example.orderspring.entity.CustomerOrder</class>
        <class>com.example.orderspring.entity.LineItem</class>
        <class>com.example.orderspring.entity.Part</class>
        <class>com.example.orderspring.entity.VendorPart</class>
        <class>com.example.orderspring.entity.Vendor</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="eclipselink.logging.level" value="FINE"/>
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.target-database" value="org.eclipse.persistence.platform.database.H2Platform"/>
        </properties>
    </persistence-unit>
</persistence>
