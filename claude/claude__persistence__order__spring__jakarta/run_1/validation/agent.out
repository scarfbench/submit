\", orderId)\n    36→                .getResultList();\n    37→        return results.isEmpty() ? null : results.get(0);\n    38→    }\n    39→\n    40→    public void deleteAllByOrderId(Integer orderId) {\n    41→        em.createQuery(\"DELETE FROM LineItem l WHERE l.customerOrder.orderId = :orderId\")\n    42→          .setParameter(\"orderId\", orderId)\n    43→          .executeUpdate();\n    44→        em.flush();\n    45→    }\n    46→\n    47→    public LineItem save(LineItem lineItem) {\n    48→        LineItem existing = findLineItemById(lineItem.getItemId(),\n    49→            lineItem.getCustomerOrder() != null ? lineItem.getCustomerOrder().getOrderId() : null);\n    50→        if (existing == null) {\n    51→            em.persist(lineItem);\n    52→            return lineItem;\n    53→        } else {\n    54→            return em.merge(lineItem);\n    55→        }\n    56→    }\n    57→}\n    58→"}]},"parent_tool_use_id":null,"session_id":"c75ef7e1-cdcb-4fc9-ba4d-53d982e17ac3","uuid":"942893ec-5def-4a07-97b3-48fe19a65c39"}
