ndor existing = em.find(Vendor.class, vendor.getVendorId());\n    39→        if (existing == null) {\n    40→            em.persist(vendor);\n    41→            return vendor;\n    42→        } else {\n    43→            return em.merge(vendor);\n    44→        }\n    45→    }\n    46→}\n    47→"}]},"parent_tool_use_id":null,"session_id":"c75ef7e1-cdcb-4fc9-ba4d-53d982e17ac3","uuid":"0e412e80-ce88-42bd-9b70-cc2eb04f35e6"}
