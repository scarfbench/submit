<?xml version="1.0" encoding="UTF-8"?>
<server description="Order Jakarta EE Application">

    <featureManager>
        <feature>jakartaee-10.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="8080"
                  httpsPort="9443"
                  host="*" />

    <!-- H2 Database Library -->
    <library id="h2Lib">
        <fileset dir="${server.config.dir}/lib" includes="h2-*.jar"/>
    </library>

    <!-- DataSource Configuration using generic properties -->
    <dataSource id="orderDS" jndiName="jdbc/orderDB" type="javax.sql.DataSource">
        <jdbcDriver libraryRef="h2Lib"/>
        <properties URL="jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1" user="sa" password=""/>
    </dataSource>

    <!-- Application -->
    <webApplication id="order-jakarta" location="order-jakarta.war" contextRoot="/">
        <classloader commonLibraryRef="h2Lib"/>
    </webApplication>

    <!-- Basic user registry to satisfy ORB requirement for EJB -->
    <basicRegistry id="basic" realm="BasicRealm"/>

    <!-- Logging -->
    <logging traceSpecification="*=info:com.example.orderspring.*=fine"/>
</server>
