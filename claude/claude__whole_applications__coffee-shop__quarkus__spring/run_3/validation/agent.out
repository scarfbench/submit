rRepository kitchenOrderRepository) {\n    32→        this.eventPublisher = eventPublisher;\n    33→        this.kitchenOrderRepository = kitchenOrderRepository;\n    34→    }\n    35→\n    36→    @EventListener\n    37→    @Async\n    38→    @Transactional\n    39→    public void handleKitchenOrderIn(KitchenOrderInEvent event) {\n    40→        onOrderIn(event.getOrderInJson());\n    41→    }\n    42→\n    43→    @Override\n    44→    @Transactional\n    45→    public void onOrderIn(String orderInJson) {\n    46→        OrderIn orderIn = JsonUtil.fromJson(orderInJson, OrderIn.class);\n    47→        KitchenOrder kitchenOrder = new KitchenOrder(orderIn.orderId, orderIn.item, Instant.now());\n    48→        LOGGER.debug(\"order in : {}\", orderIn);\n    49→        try {\n    50→            Thread.sleep(calculateDelay(orderIn.item));\n    51→        } catch (InterruptedException e) {\n    52→            Thread.currentThread().interrupt();\n    53→            LOGGER.error(\"Interrupted while processing order\", e);\n    54→        }\n    55→        OrderUp orderUp = new OrderUp(\n    56→                orderIn.orderId,\n    57→                orderIn.itemId,\n    58→                orderIn.item,\n    59→                orderIn.name,\n    60→                Instant.now(),\n    61→                madeBy);\n    62→        kitchenOrder.setTimeUp(Instant.now());\n    63→        kitchenOrderRepository.save(kitchenOrder);\n    64→        eventPublisher.publishEvent(new OrderUpEvent(this, JsonUtil.toJson(orderUp)));\n    65→    }\n    66→\n    67→    private int calculateDelay(final Item item) {\n    68→        switch (item) {\n    69→            case CROISSANT: return 7000;\n    70→            case CROISSANT_CHOCOLATE: return 7000;\n    71→            case CAKEPOP: return 5000;\n    72→            case MUFFIN: return 7000;\n    73→            default: return 3000;\n    74→        }\n    75→    }\n    76→}\n    77→"}]},"parent_tool_use_id":"toolu_bdrk_01WXrKKzKXcmLW34rztmn2n2"