tring orderInJson) {\n    35→        OrderIn orderIn = JsonUtil.fromJson(orderInJson, OrderIn.class);\n    36→        BaristaItem baristaItem = new BaristaItem();\n    37→        baristaItem.setItem(orderIn.item.toString());\n    38→        baristaItem.setTimeIn(Instant.now());\n    39→        LOGGER.debug(\"order in : {}\", orderIn);\n    40→        try {\n    41→            Thread.sleep(calculateDelay(orderIn.item));\n    42→        } catch (InterruptedException e) {\n    43→            Thread.currentThread().interrupt();\n    44→            LOGGER.error(\"Interrupted while processing order\", e);\n    45→        }\n    46→        OrderUp orderUp = new OrderUp(\n    47→                orderIn.orderId,\n    48→                orderIn.itemId,\n    49→                orderIn.item,\n    50→                orderIn.name,\n    51→                Instant.now(),\n    52→                madeBy);\n    53→        baristaItem.setTimeUp(Instant.now());\n    54→        baristaRepository.save(baristaItem);\n    55→        eventPublisher.publishEvent(new OrderUpEvent(this, JsonUtil.toJson(orderUp)));\n    56→    }\n    57→\n    58→    private int calculateDelay(final Item item) {\n    59→        switch (item) {\n    60→            case COFFEE_BLACK: return 5000;\n    61→            case COFFEE_WITH_ROOM: return 5000;\n    62→            case ESPRESSO: return 7000;\n    63→            case ESPRESSO_DOUBLE: return 7000;\n    64→            case CAPPUCCINO: return 10000;\n    65→            default: return 3000;\n    66→        }\n    67→    }\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_bdrk_01WXrKKzKXcmLW34rztmn2n2","session_id":"df095e3b-f7e3-4e4b-a52d-37a5c6ff1041","uuid":"405bab46-991a-4a32-981c-44a706c03c85"}
