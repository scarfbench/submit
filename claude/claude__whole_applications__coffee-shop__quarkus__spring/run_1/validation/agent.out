      eventBusService.registerKitchenInHandler(this::onOrderIn);\n    37→    }\n    38→\n    39→    @Transactional\n    40→    public void onOrderIn(final String orderInJson) {\n    41→        OrderIn orderIn = JsonUtil.fromJson(orderInJson, OrderIn.class);\n    42→        KitchenOrder kitchenOrder = new KitchenOrder(orderIn.orderId, orderIn.item, Instant.now());\n    43→        LOGGER.debug(\"order in : {}\", orderIn);\n    44→        try {\n    45→            Thread.sleep(calculateDelay(orderIn.item));\n    46→        } catch (InterruptedException e) {\n    47→            Thread.currentThread().interrupt();\n    48→        }\n    49→        OrderUp orderUp = new OrderUp(\n    50→                orderIn.orderId,\n    51→                orderIn.itemId,\n    52→                orderIn.item,\n    53→                orderIn.name,\n    54→                Instant.now(),\n    55→                madeBy);\n    56→        kitchenOrder.setTimeUp(Instant.now());\n    57→        kitchenOrderRepository.save(kitchenOrder);\n    58→        eventBusService.sendToOrdersUp(JsonUtil.toJson(orderUp));\n    59→    }\n    60→\n    61→    private int calculateDelay(final Item item) {\n    62→        switch (item) {\n    63→            case CROISSANT:\n    64→                return 7000;\n    65→            case CROISSANT_CHOCOLATE:\n    66→                return 7000;\n    67→            case CAKEPOP:\n    68→                return 5000;\n    69→            case MUFFIN:\n    70→                return 7000;\n    71→            default:\n    72→                return 3000;\n    73→        }\n    74→    }\n    75→}\n    76→"}]},"parent_tool_use_id":"toolu_bdrk_017q7gW47eNqthNXmFskqhJa","session_id":"243793b8-1f2f-4a19-bc0b-f6e1ac6e38fc","uuid":"2375c48f-f0a2-48e6-83aa-ed954f136f79"}
