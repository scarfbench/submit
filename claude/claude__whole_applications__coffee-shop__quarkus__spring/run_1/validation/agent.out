blic void onOrderIn(final String orderInJson) {\n    37→        OrderIn orderIn = JsonUtil.fromJson(orderInJson, OrderIn.class);\n    38→        BaristaItem baristaItem = new BaristaItem();\n    39→        baristaItem.setItem(orderIn.item.toString());\n    40→        baristaItem.setTimeIn(Instant.now());\n    41→        LOGGER.debug(\"order in : {}\", orderIn);\n    42→        try {\n    43→            Thread.sleep(calculateDelay(orderIn.item));\n    44→        } catch (InterruptedException e) {\n    45→            Thread.currentThread().interrupt();\n    46→        }\n    47→        OrderUp orderUp = new OrderUp(\n    48→                orderIn.orderId,\n    49→                orderIn.itemId,\n    50→                orderIn.item,\n    51→                orderIn.name,\n    52→                Instant.now(),\n    53→                madeBy);\n    54→        baristaItem.setTimeUp(Instant.now());\n    55→        baristaRepository.save(baristaItem);\n    56→        eventBusService.sendToOrdersUp(JsonUtil.toJson(orderUp));\n    57→    }\n    58→\n    59→    private int calculateDelay(final Item item) {\n    60→        switch (item) {\n    61→            case COFFEE_BLACK:\n    62→                return 5000;\n    63→            case COFFEE_WITH_ROOM:\n    64→                return 5000;\n    65→            case ESPRESSO:\n    66→                return 7000;\n    67→            case ESPRESSO_DOUBLE:\n    68→                return 7000;\n    69→            case CAPPUCCINO:\n    70→                return 10000;\n    71→            default:\n    72→                return 3000;\n    73→        }\n    74→    }\n    75→}\n    76→"}]},"parent_tool_use_id":"toolu_bdrk_017q7gW47eNqthNXmFskqhJa","session_id":"243793b8-1f2f-4a19-bc0b-f6e1ac6e38fc","uuid":"5a82666b-d6c0-4960-86bd-5e509c39ea1f"}
