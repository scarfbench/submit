edBy = \"order\", cascade = CascadeType.ALL)\n    44→    @Where(clause = \"line_item_type = 'BARISTA'\")\n    45→    private List<LineItem> baristaLineItems;\n    46→\n    47→    @OneToMany(fetch = FetchType.EAGER, mappedBy = \"order\", cascade = CascadeType.ALL)\n    48→    @Where(clause = \"line_item_type = 'KITCHEN'\")\n    49→    private List<LineItem> kitchenLineItems;\n    50→\n    51→    protected Order() {\n    52→    }\n    53→\n    54→    private Order(String orderId) {\n    55→        this.orderId = orderId;\n    56→        this.timestamp = Instant.now();\n    57→    }\n    58→\n    59→    public static OrderEventResult from(final PlaceOrderCommand placeOrderCommand) {\n    60→\n    61→        Order order = new Order(placeOrderCommand.getId());\n    62→        order.setOrderSource(placeOrderCommand.getOrderSource());\n    63→        order.setLocation(placeOrderCommand.getLocation());\n    64→        order.setTimestamp(placeOrderCommand.getTimestamp());\n    65→        order.setOrderStatus(OrderStatus.IN_PROGRESS);\n    66→\n    67→        OrderEventResult orderEventResult = new OrderEventResult();\n    68→\n    69→        if (placeOrderCommand.getBaristaItems().isPresent()) {\n    70→            LOGGER.debug(\"createOrderFromCommand adding beverages {}\", placeOrderCommand.getBaristaItems().get().size());\n    71→            LOGGER.debug(\"adding Barista LineItems\");\n    72→            placeOrderCommand.getBaristaItems().get().forEach(commandItem -> {\n    73→                LOGGER.debug(\"createOrderFromCommand adding baristaItem from {}\", commandItem.toString());\n    74→                LineItem lineItem = new LineItem(commandItem.item, commandItem.name, commandItem.price, ItemStatus.IN_PROGRESS, order);\n    75→                lineItem.setLineItemType(\"BARISTA\");\n    76→                order.addBaristaLineItem(lineItem);\n    77→                LOGGER.debug(\"added LineItem: {}\", order.getBaristaLineItems().get().size());\n    78→                orderEventResult.addBaristaTicket(new OrderIn(order.getOrderId(), lineItem.getItemId(), lineItem.getItem(), lineItem.getName()));\n    79→                LOGGER.debug(\"Added Barista Ticket to OrderEventResult: {}\", orderEventResult.getBaristaTickets().get().size());\n    80→                orderEventResult.addUpdate(new OrderUpdate(order.getOrderId(), lineItem.getItemId(), lineItem.getName(), lineItem.getItem(), OrderStatus.IN_PROGRESS));\n    81→                LOGGER.debug(\"Added Order Update to OrderEventResult: \", orderEventResult.getOrderUpdates().size());\n    82→            });\n    83→        }\n    84→        LOGGER.debug(\"adding Kitchen LineItems\");\n    85→        if (placeOrderCommand.getKitchenItems().isPresent()) {\n    86→            LOGGER.debug(\"createOrderFromCommand adding kitchenOrders {}\", placeOrderCommand.getKitchenItems().get().size());\n    87→            placeOrderCommand.getKitchenItems().get().forEach(commandItem -> {\n    88→                LOGGER.debug(\"createOrderFromCommand adding kitchenItem from {}\", commandItem.toString());\n    89→                LineItem lineItem = new LineItem(commandItem.item, commandItem.name, commandItem.price, ItemStatus.IN_PROGRESS, order);\n    90→                lineItem.setLineItemType(\"KITCHEN\");\n    91→                order.addKitchenLineItem(lineItem);\n    92→                orderEventResult.addKitchenTicket(new OrderIn(order.getOrderId(), lineItem.getItemId(), lineItem.getItem(), lineItem.getName()));\n    93→                orderEventResult.addUpdate(new OrderUpdate(order.getOrderId(), lineItem.getItemId(), lineItem.getName(), lineItem.getItem(), OrderStatus.IN_PROGRESS));\n    94→            });\n    95→        }\n    96→\n    97→        orderEventResult.setOrder(order);\n    98→        LOGGER.debug(\"returning {}\", orderEventResult);\n    99→        return orderEventResult;\n   100→    }\n   101→\n   102→    public OrderEventResult apply(final OrderUp orderUp) {\n   103→\n   104→        LOGGER.debug(\"applying orderUp: {}\", orderUp);\n   105→        OrderEventResult orderEventResult = new OrderEventResult();\n   106→\n   107→        orderEventResult.addUpdate(new OrderUpdate(\n   108→                orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item,\n   109→                OrderStatus.FULFILLED, orderUp.madeBy));\n   110→\n   111→        if (this.getBaristaLineItems().isPresent()) {\n   112→            this.getBaristaLineItems().get().forEach(baristaLineItem -> {\n   113→                if (baristaLineItem.getItemId().equals(orderUp.itemId)) {\n   114→                    baristaLineItem.setItemStatus(ItemStatus.FULFILLED);\n   115→                    orderEventResult.addUpdate(new OrderUpdate(orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item, OrderStatus.FULFILLED, orderUp.madeBy));\n   116→                }\n   117→            });\n   118→        }\n   119→        if (this.getKitchenLineItems().isPresent()) {\n   120→            this.getKitchenLineItems().get().forEach(kitchenLineItem -> {\n   121→                if (kitchenLineItem.getItemId().equals(orderUp.itemId)) {\n   122→                    kitchenLineItem.setItemStatus(ItemStatus.FULFILLED);\n   123→                    orderEventResult.addUpdate(new OrderUpdate(orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item, OrderStatus.FULFILLED, orderUp.madeBy));\n   124→                }\n   125→            });\n   126→        }\n   127→\n   128→        if (this.getBaristaLineItems().isPresent() && this.getKitchenLineItems().isPresent()) {\n   129→            if(Stream.concat(this.baristaLineItems.stream(), this.kitchenLineItems.stream())\n   130→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   131→                this.setOrderStatus(OrderStatus.FULFILLED);\n   132→            }\n   133→        }else if (this.getBaristaLineItems().isPresent()) {\n   134→            if(this.baristaLineItems.stream()\n   135→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   136→                this.setOrderStatus(OrderStatus.FULFILLED);\n   137→            }\n   138→        }else if (this.getKitchenLineItems().isPresent()) {\n   139→            if(this.kitchenLineItems.stream()\n   140→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   141→                this.setOrderStatus(OrderStatus.FULFILLED);\n   142→            }\n   143→        }\n   144→\n   145→        orderEventResult.setOrder(this);\n   146→        return orderEventResult;\n   147→    }\n   148→\n   149→    public void addBaristaLineItem(LineItem lineItem) {\n   150→        if (this.baristaLineItems == null) { this.baristaLineItems = new ArrayList<>(); }\n   151→        lineItem.setOrder(this);\n   152→        lineItem.setLineItemType(\"BARISTA\");\n   153→        this.baristaLineItems.add(lineItem);\n   154→    }\n   155→\n   156→    public void addKitchenLineItem(LineItem lineItem) {\n   157→        if (this.kitchenLineItems == null) { this.kitchenLineItems = new ArrayList<>(); }\n   158→        lineItem.setOrder(this);\n   159→        lineItem.setLineItemType(\"KITCHEN\");\n   160→        this.kitchenLineItems.add(lineItem);\n   161→    }\n   162→\n   163→    public Optional<String> getLoyaltyMemberId() { return Optional.ofNullable(loyaltyMemberId); }\n   164→    public Optional<List<LineItem>> getBaristaLineItems() { return Optional.ofNullable(baristaLineItems); }\n   165→    public Optional<List<LineItem>> getKitchenLineItems() { return Optional.ofNullable(kitchenLineItems); }\n   166→\n   167→    @Override\n   168→    public String toString() {\n   169→        final StringBuilder sb = new StringBuilder(\"Order{\");\n   170→        sb.append(\"orderId='\").append(orderId).append('\\'');\n   171→        sb.append(\", orderSource=\").append(orderSource);\n   172→        sb.append(\", loyaltyMemberId='\").append(loyaltyMemb