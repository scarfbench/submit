nfo\nmanagement.endpoint.health.show-details=always\n\n# ---------------- Jackson ----------------\nspring.jackson.serialization.write-dates-as-timestamps=false\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":254,"cache_read_input_tokens":126928,"cache_creation":{"ephemeral_5m_input_tokens":254,"ephemeral_1h_input_tokens":0},"output_tokens":679},"context_management":null},"parent_tool_use_id":null,"session_id":"a1c50a88-828f-43a6-8dbe-524f630482b2","uuid":"4cc07e59-faa0-4aaf-97b1-03887484ca15"}
