{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012cT3LwYBzk6Tw5JZoi5Bo9","type":"tool_result","content":"     1→# ---------------- Application Properties ----------------\n     2→# URL for SSE\n     3→%dev.streamUrl=http://localhost:8080/dashboard/stream\n     4→%test.streamUrl=http://localhost:8081/dashboard/stream\n     5→streamUrl=${STREAM_URL:http://localhost:8080/dashboard/stream}\n     6→%dev.orderUrl=http://localhost:8080/api/order\n     7→%test.orderUrl=http://localhost:8081/api/order\n     8→orderUrl=${ORDER_URL}\n     9→%dev.storeId=ATLANTA\n    10→%test.storeId=ATLANTA\n    11→storeId=${STORE_ID:ATLANTA}\n    12→\n    13→# ---------------- HTTP / CORS ----------------\n    14→quarkus.http.cors.enabled=true\n    15→%dev.quarkus.http.cors.origins=http://localhost\n    16→%test.quarkus.http.cors.origins=http://localhost\n    17→quarkus.http.cors.origins=${CORS_ORIGINS}\n    18→quarkus.http.cors.methods=GET,PUT,POST\n    19→quarkus.http.cors.headers=X-Custom,accept,origin,authorization,content-type,x-requested-with\n    20→quarkus.http.cors.exposed-headers=Content-Disposition\n    21→quarkus.http.cors.access-control-max-age=24H\n    22→\n    23→# ---------------- Logging ----------------\n    24→quarkus.log.console.format=%-5p [%c{2.}] (%t) %s%e%n\n    25→quarkus.log.level=INFO\n    26→quarkus.log.category.\"io.quarkuscoffeeshop\".level=DEBUG\n    27→quarkus.log.category.\"io.quarkuscoffeeshop.utils\".level=WARNING\n    28→\n    29→# ---------------- Datasources (DEV uses H2 for smoke tests) ----------------\n    30→# Default DS -> schema=coffeeshop\n    31→%dev.quarkus.datasource.db-kind=h2\n    32→%dev.quarkus.datasource.jdbc.url=jdbc:h2:mem:coffeeshop;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\n    33→%dev.quarkus.datasource.username=sa\n    34→%dev.quarkus.datasource.password=\n    35→%dev.quarkus.datasource.jdbc.max-size=16\n    36→%dev.quarkus.hibernate-orm.log.sql=true\n    37→%dev.quarkus.hibernate-orm.schema-management.strategy=drop-and-create\n    38→\n    39→# Named DS -> barista\n    40→%dev.quarkus.datasource.barista.db-kind=h2\n    41→%dev.quarkus.datasource.barista.jdbc.url=jdbc:h2:mem:barista;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\n    42→%dev.quarkus.datasource.barista.username=sa\n    43→%dev.quarkus.datasource.barista.password=\n    44→%dev.quarkus.datasource.barista.jdbc.max-size=16\n    45→\n    46→# Named DS -> kitchen\n    47→%dev.quarkus.datasource.kitchen.db-kind=h2\n    48→%dev.quarkus.datasource.kitchen.jdbc.url=jdbc:h2:mem:kitchen;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE\n    49→%dev.quarkus.datasource.kitchen.username=sa\n    50→%dev.quarkus.datasource.kitchen.password=\n    51→%dev.quarkus.datasource.kitchen.jdbc.max-size=16\n    52→\n    53→# ---------------- Test ----------------\n    54→%test.quarkus.datasource.db-kind=postgresql\n    55→%test.quarkus.datasource.jdbc.url=jdbc:postgresql://localhost:5432/coffeeshopdb?currentSchema=coffeeshop\n    56→%test.quarkus.datasource.username=coffeeshopuser\n    57→%test.quarkus.datasource.password=redhat-21\n    58→%test.quarkus.datasource.jdbc.max-size=16\n    59→%test.quarkus.hibernate-orm.log.sql=true\n    60→%test.quarkus.hibernate-orm.schema-management.strategy=drop-and-create\n    61→\n    62→%test.quarkus.datasource.barista.db-kind=postgresql\n    63→%test.quarkus.datasource.barista.jdbc.url=jdbc:postgresql://localhost:5432/coffeeshopdb?currentSchema=barista\n    64→%test.quarkus.datasource.barista.username=coffeeshopuser\n    65→%test.quarkus.datasource.barista.password=redhat-21\n    66→%test.quarkus.datasource.barista.jdbc.max-size=16\n    67→\n    68→%test.quarkus.datasource.kitchen.db-kind=postgresql\n    69→%test.quarkus.datasource.kitchen.jdbc.url=jdbc:postgresql://localhost:5432/coffeeshopdb?currentSchema=kitchen\n    70→%test.quarkus.datasource.kitchen.username=coffeeshopuser\n    71→%test.quarkus.datasource.kitchen.password=redhat-21\n    72→%test.quarkus.datasource.kitchen.jdbc.max-size=16\n    73→\n    74→# ---------------- Prod (env-driven) ----------------\n    75→%prod.quarkus.datasource.db-kind=postgresql\n    76→%prod.quarkus.datasource.jdbc.url=${PGSQL_URL}\n    77→%prod.quarkus.datasource.jdbc.max-size=16\n    78→%prod.quarkus.datasource.username=${PGSQL_USER}\n    79→%prod.quarkus.datasource.password=${PGSQL_PASSWORD}\n    80→%prod.quarkus.hibernate-orm.log.sql=true\n    81→\n    82→%prod.quarkus.datasource.barista.db-kind=postgresql\n    83→%prod.quarkus.datasource.barista.jdbc.url=${PGSQL_URL_BARISTA}\n    84→%prod.quarkus.datasource.barista.username=${PGSQL_USER_BARISTA}\n    85→%prod.quarkus.datasource.barista.password=${PGSQL_PASSWORD_BARISTA}\n    86→%prod.quarkus.datasource.barista.jdbc.max-size=16\n    87→\n    88→%prod.quarkus.datasource.kitchen.db-kind=postgresql\n    89→%prod.quarkus.datasource.kitchen.jdbc.url=${PGSQL_URL_KITCHEN}\n    90→%prod.quarkus.datasource.kitchen.username=${PGSQL_USER_KITCHEN}\n    91→%prod.quarkus.datasource.kitchen.password=${PGSQL_PASSWORD_KITCHEN}\n    92→%prod.quarkus.datasource.kitchen.jdbc.max-size=16\n    93→\n    94→# ---------------- Kafka ----------------\n    95→mp.messaging.outgoing.barista-outpost.topic=barista-in\n    96→mp.messaging.incoming.orders-up.connector=smallrye-kafka\n    97→mp.messaging.incoming.orders-up.topic=orders-up\n    98→quarkus.kafka.devservices.image-name=docker.io/redpandadata/redpanda:v23.2.14\n    99→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01SH9ELiqXgDGgFXMgUxMPfJ","session_id":"a1c50a88-828f-43a6-8dbe-524f630482b2","uuid":"d5dc377b-c316-43b6-b839-b9279954c808"}
