 = \"order\", cascade = CascadeType.ALL)\n    44→    private List<LineItem> baristaLineItems;\n    45→\n    46→    @OneToMany(fetch = FetchType.EAGER, mappedBy = \"order\", cascade = CascadeType.ALL)\n    47→    private List<LineItem> kitchenLineItems;\n    48→\n    49→    protected Order() {\n    50→    }\n    51→\n    52→    private Order(String orderId) {\n    53→        this.orderId = orderId;\n    54→        this.timestamp = Instant.now();\n    55→    }\n    56→\n    57→    public static OrderEventResult from(final PlaceOrderCommand placeOrderCommand) {\n    58→\n    59→        Order order = new Order(placeOrderCommand.getId());\n    60→        order.setOrderSource(placeOrderCommand.getOrderSource());\n    61→        order.setLocation(placeOrderCommand.getLocation());\n    62→        order.setTimestamp(placeOrderCommand.getTimestamp());\n    63→        order.setOrderStatus(OrderStatus.IN_PROGRESS);\n    64→\n    65→        OrderEventResult orderEventResult = new OrderEventResult();\n    66→\n    67→        if (placeOrderCommand.getBaristaItems().isPresent()) {\n    68→            LOGGER.debug(\"createOrderFromCommand adding beverages {}\", placeOrderCommand.getBaristaItems().get().size());\n    69→            LOGGER.debug(\"adding Barista LineItems\");\n    70→            placeOrderCommand.getBaristaItems().get().forEach(commandItem -> {\n    71→                LOGGER.debug(\"createOrderFromCommand adding baristaItem from {}\", commandItem.toString());\n    72→                LineItem lineItem = new LineItem(commandItem.item, commandItem.name, commandItem.price, ItemStatus.IN_PROGRESS, order);\n    73→                order.addBaristaLineItem(lineItem);\n    74→                LOGGER.debug(\"added LineItem: {}\", order.getBaristaLineItems().get().size());\n    75→                orderEventResult.addBaristaTicket(new OrderIn(order.getOrderId(), lineItem.getItemId(), lineItem.getItem(), lineItem.getName()));\n    76→                LOGGER.debug(\"Added Barista Ticket to OrderEventResult: {}\", orderEventResult.getBaristaTickets().get().size());\n    77→                orderEventResult.addUpdate(new OrderUpdate(order.getOrderId(), lineItem.getItemId(), lineItem.getName(), lineItem.getItem(), OrderStatus.IN_PROGRESS));\n    78→                LOGGER.debug(\"Added Order Update to OrderEventResult: \", orderEventResult.getOrderUpdates().size());\n    79→            });\n    80→        }\n    81→        LOGGER.debug(\"adding Kitchen LineItems\");\n    82→        if (placeOrderCommand.getKitchenItems().isPresent()) {\n    83→            LOGGER.debug(\"createOrderFromCommand adding kitchenOrders {}\", placeOrderCommand.getKitchenItems().get().size());\n    84→            placeOrderCommand.getKitchenItems().get().forEach(commandItem -> {\n    85→                LOGGER.debug(\"createOrderFromCommand adding kitchenItem from {}\", commandItem.toString());\n    86→                LineItem lineItem = new LineItem(commandItem.item, commandItem.name, commandItem.price, ItemStatus.IN_PROGRESS, order);\n    87→                order.addKitchenLineItem(lineItem);\n    88→                orderEventResult.addKitchenTicket(new OrderIn(order.getOrderId(), lineItem.getItemId(), lineItem.getItem(), lineItem.getName()));\n    89→                orderEventResult.addUpdate(new OrderUpdate(order.getOrderId(), lineItem.getItemId(), lineItem.getName(), lineItem.getItem(), OrderStatus.IN_PROGRESS));\n    90→            });\n    91→        }\n    92→\n    93→        orderEventResult.setOrder(order);\n    94→        LOGGER.debug(\"returning {}\", orderEventResult);\n    95→        return orderEventResult;\n    96→    }\n    97→\n    98→    public OrderEventResult apply(final OrderUp orderUp) {\n    99→\n   100→        LOGGER.debug(\"applying orderUp: {}\", orderUp);\n   101→        OrderEventResult orderEventResult = new OrderEventResult();\n   102→\n   103→        orderEventResult.addUpdate(new OrderUpdate(\n   104→                orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item,\n   105→                OrderStatus.FULFILLED, orderUp.madeBy));\n   106→\n   107→        if (this.getBaristaLineItems().isPresent()) {\n   108→            this.getBaristaLineItems().get().forEach(baristaLineItem -> {\n   109→                if (baristaLineItem.getItemId().equals(orderUp.itemId)) {\n   110→                    baristaLineItem.setItemStatus(ItemStatus.FULFILLED);\n   111→                    orderEventResult.addUpdate(new OrderUpdate(orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item, OrderStatus.FULFILLED, orderUp.madeBy));\n   112→                }\n   113→            });\n   114→        }\n   115→        if (this.getKitchenLineItems().isPresent()) {\n   116→            this.getKitchenLineItems().get().forEach(kitchenLineItem -> {\n   117→                if (kitchenLineItem.getItemId().equals(orderUp.itemId)) {\n   118→                    kitchenLineItem.setItemStatus(ItemStatus.FULFILLED);\n   119→                    orderEventResult.addUpdate(new OrderUpdate(orderUp.orderId, orderUp.itemId, orderUp.name, orderUp.item, OrderStatus.FULFILLED, orderUp.madeBy));\n   120→                }\n   121→            });\n   122→        }\n   123→\n   124→        if (this.getBaristaLineItems().isPresent() && this.getKitchenLineItems().isPresent()) {\n   125→            if(Stream.concat(this.baristaLineItems.stream(), this.kitchenLineItems.stream())\n   126→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   127→                this.setOrderStatus(OrderStatus.FULFILLED);\n   128→            }\n   129→        }else if (this.getBaristaLineItems().isPresent()) {\n   130→            if(this.baristaLineItems.stream()\n   131→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   132→                this.setOrderStatus(OrderStatus.FULFILLED);\n   133→            }\n   134→        }else if (this.getKitchenLineItems().isPresent()) {\n   135→            if(this.kitchenLineItems.stream()\n   136→                    .allMatch(lineItem -> lineItem.getItemStatus().equals(ItemStatus.FULFILLED))){\n   137→                this.setOrderStatus(OrderStatus.FULFILLED);\n   138→            }\n   139→        }\n   140→\n   141→        orderEventResult.setOrder(this);\n   142→        return orderEventResult;\n   143→    }\n   144→\n   145→    public void addBaristaLineItem(LineItem lineItem) {\n   146→        if (this.baristaLineItems == null) { this.baristaLineItems = new ArrayList<>(); }\n   147→        lineItem.setOrder(this);\n   148→        this.baristaLineItems.add(lineItem);\n   149→    }\n   150→\n   151→    public void addKitchenLineItem(LineItem lineItem) {\n   152→        if (this.kitchenLineItems == null) { this.kitchenLineItems = new ArrayList<>(); }\n   153→        lineItem.setOrder(this);\n   154→        this.kitchenLineItems.add(lineItem);\n   155→    }\n   156→\n   157→    public Optional<String> getLoyaltyMemberId() { return Optional.ofNullable(loyaltyMemberId); }\n   158→    public Optional<List<LineItem>> getBaristaLineItems() { return Optional.ofNullable(baristaLineItems); }\n   159→    public Optional<List<LineItem>> getKitchenLineItems() { return Optional.ofNullable(kitchenLineItems); }\n   160→\n   161→    @Override\n   162→    public String toString() {\n   163→        final StringBuilder sb = new StringBuilder(\"Order{\");\n   164→        sb.append(\"orderId='\").append(orderId).append('\\'');\n   165→        sb.append(\", orderSource=\").append(orderSource);\n   166→        sb.append(\", loyaltyMemberId='\").append(loyaltyMemberId).append('\\'');\n   167→        sb.append(\", timestamp=\").append(timestamp);\n   168→        sb.append(\", orderStatus=\").append(orderStatus);\n   169→        sb.append(\", location=\").append(location);\n   170→        sb.append('}');\n   171→        return sb.toString();\n   172→    }\n   173→\n   174→    @Override\n   175→    public boolean equals(Object o) {\n   176→        if (this == o) return true;\n   177→        if (o == null || getClass() != o.getClass()) return false;\n   178→        Order order = (Order) o;\n   179→        return orderId != null ? orderId.equals(order.orderId) : order.orderId == null;\n   180→    }\n   181→\n   182→    @Override\n   183→    public int hashCode() {\n   184→        return orderId != null ? orderId.hashCode() : 0;\n   185→    }\n   186→\n   187→    public String getOrderId() { return orderId; }\n   188→    public void setOrderId(String orderId) { this.orderId = orderId; }\n   189→    public OrderSource getOrderSource() { return orderSource; }\n   190→    public void setOrderSource(OrderSource orderSource) { this.orderSource = orderSource; }\n   191→    public void setLoyaltyMemberId(String loyaltyMemberId) { this.loyaltyMemberId = loyaltyMemberId; }\n   192→    public Instant getTimestamp() { return timestamp; }\n   193→    public void setTimestamp(Instant timestamp) { this.timestamp = timestamp; }\n   194→    public OrderStatus getOrderStatus() { return orderStatus; }\n   195→    public void setOrderStatus(OrderStatus orderStatus) { this.orderStatus = orderStatus; }\n   196→    public Location getLocation() { return location; }\n   197→    public void setLocation(Location location) { this.location = location; }\n   198→    public void setBaristaLineItems(List<LineItem> baristaLineLineItems) { this.baristaLineItems = baristaLineLineItems; }\n   199→    public void setKitchenLineItems(List<LineItem> kitchenLineLineItems) { this.kitchenLineItems = kitchenLineLineItems; }\n   200→}\n   201→"}]},"parent_tool_use_id":null,"session_id":"a1c50a88-828f-43a6-8dbe-524f630482b2","uuid":"e8b97d0c-5ed8-4d0a-aebf-565ecf12a055"}
