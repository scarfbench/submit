{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01UqMNdmFBqwAfp7SreZEkgr","type":"tool_result","content":"     1→/*\n     2→ * Copyright (c), Eclipse Foundation, Inc. and its licensors.\n     3→ *\n     4→ * All rights reserved.\n     5→ *\n     6→ * This program and the accompanying materials are made available under the\n     7→ * terms of the Eclipse Distribution License v1.0, which is available at\n     8→ * https://www.eclipse.org/org/documents/edl-v10.php\n     9→ *\n    10→ * SPDX-License-Identifier: BSD-3-Clause\n    11→ */\n    12→package jakarta.tutorial.addressbook.web;\n    13→\n    14→import java.io.Serializable;\n    15→import java.util.ResourceBundle;\n    16→\n    17→import jakarta.ejb.EJB;\n    18→import jakarta.enterprise.context.SessionScoped;\n    19→import jakarta.faces.component.UIComponent;\n    20→import jakarta.faces.context.FacesContext;\n    21→import jakarta.faces.convert.Converter;\n    22→import jakarta.faces.convert.FacesConverter;\n    23→import jakarta.faces.model.DataModel;\n    24→import jakarta.faces.model.ListDataModel;\n    25→import jakarta.faces.model.SelectItem;\n    26→import jakarta.inject.Named;\n    27→import jakarta.tutorial.addressbook.ejb.ContactFacade;\n    28→import jakarta.tutorial.addressbook.entity.Contact;\n    29→import jakarta.tutorial.addressbook.web.util.JsfUtil;\n    30→import jakarta.tutorial.addressbook.web.util.PaginationHelper;\n    31→\n    32→@Named\n    33→@SessionScoped\n    34→public class ContactController implements Serializable {\n    35→    private static final long serialVersionUID = -8163374738411860012L;\n    36→    private Contact current;\n    37→    private DataModel items = null;\n    38→    @EJB private ContactFacade ejbFacade;\n    39→    private PaginationHelper pagination;\n    40→    private int selectedItemIndex;\n    41→\n    42→    public ContactController() {\n    43→    }\n    44→\n    45→    public Contact getSelected() {\n    46→        if (current == null) {\n    47→            current = new Contact();\n    48→            selectedItemIndex = -1;\n    49→        }\n    50→        return current;\n    51→    }\n    52→\n    53→    private ContactFacade getFacade() {\n    54→        return ejbFacade;\n    55→    }\n    56→\n    57→    public PaginationHelper getPagination() {\n    58→        if (pagination == null) {\n    59→            pagination = new PaginationHelper(10) {\n    60→\n    61→                @Override\n    62→                public int getItemsCount() {\n    63→                    return getFacade().count();\n    64→                }\n    65→\n    66→                @Override\n    67→                public DataModel createPageDataModel() {\n    68→                    return new ListDataModel(getFacade().findRange(new int[]{getPageFirstItem(), getPageFirstItem()+getPageSize()}));\n    69→                }\n    70→            };\n    71→        }\n    72→        return pagination;\n    73→    }\n    74→\n    75→    public String prepareList() {\n    76→        recreateModel();\n    77→        return \"List\";\n    78→    }\n    79→\n    80→    public String prepareView() {\n    81→        current = (Contact)getItems().getRowData();\n    82→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n    83→        return \"View\";\n    84→    }\n    85→\n    86→    public String prepareCreate() {\n    87→        current = new Contact();\n    88→        selectedItemIndex = -1;\n    89→        return \"Create\";\n    90→    }\n    91→\n    92→    public String create() {\n    93→        try {\n    94→            getFacade().create(current);\n    95→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactCreated\"));\n    96→            return prepareCreate();\n    97→        } catch (Exception e) {\n    98→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n    99→            return null;\n   100→        }\n   101→    }\n   102→\n   103→    public String prepareEdit() {\n   104→        current = (Contact)getItems().getRowData();\n   105→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n   106→        return \"Edit\";\n   107→    }\n   108→\n   109→    public String update() {\n   110→        try {\n   111→            getFacade().edit(current);\n   112→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactUpdated\"));\n   113→            return \"View\";\n   114→        } catch (Exception e) {\n   115→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n   116→            return null;\n   117→        }\n   118→    }\n   119→\n   120→    public String destroy() {\n   121→        current = (Contact)getItems().getRowData();\n   122→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n   123→        performDestroy();\n   124→        recreateModel();\n   125→        return \"List\";\n   126→    }\n   127→\n   128→    public String destroyAndView() {\n   129→        performDestroy();\n   130→        recreateModel();\n   131→        updateCurrentItem();\n   132→        if (selectedItemIndex >= 0) {\n   133→            return \"View\";\n   134→        } else {\n   135→            // all items were removed - go back to list\n   136→            recreateModel();\n   137→            return \"List\";\n   138→        }\n   139→    }\n   140→\n   141→    private void performDestroy() {\n   142→        try {\n   143→            getFacade().remove(current);\n   144→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactDeleted\"));\n   145→        } catch (Exception e) {\n   146→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n   147→        }\n   148→    }\n   149→\n   150→    private void updateCurrentItem() {\n   151→        int count = getFacade().count();\n   152→        if (selectedItemIndex >= count) {\n   153→            // selected index cannot be bigger than number of items:\n   154→            selectedItemIndex = count-1;\n   155→            // go to previous page if last page disappeared:\n   156→            if (pagination.getPageFirstItem() >= count) {\n   157→                pagination.previousPage();\n   158→            }\n   159→        }\n   160→        if (selectedItemIndex >= 0) {\n   161→            current = getFacade().findRange(new int[]{selectedItemIndex, selectedItemIndex+1}).get(0);\n   162→        }\n   163→    }\n   164→\n   165→    public DataModel getItems() {\n   166→        if (items == null) {\n   167→            items = getPagination().createPageDataModel();\n   168→        }\n   169→        return items;\n   170→    }\n   171→\n   172→    private void recreateModel() {\n   173→        items = null;\n   174→    }\n   175→\n   176→    public String next() {\n   177→        getPagination().nextPage();\n   178→        recreateModel();\n   179→        return \"List\";\n   180→    }\n   181→\n   182→    public String previous() {\n   183→        getPagination().previousPage();\n   184→        recreateModel();\n   185→        return \"List\";\n   186→    }\n   187→\n   188→    public SelectItem[] getItemsAvailableSelectMany() {\n   189→        return JsfUtil.getSelectItems(ejbFacade.findAll(), false);\n   190→    }\n   191→\n   192→    public SelectItem[] getItemsAvailableSelectOne() {\n   193→        return JsfUtil.getSelectItems(ejbFacade.findAll(), true);\n   194→    }\n   195→\n   196→    @FacesConverter(forClass=Contact.class)\n   197→    public static class ContactControllerConverter implements Converter<Contact> {\n   198→\n   199→        @Override\n   200→        public Contact getAsObject(FacesContext facesContext, UIComponent component, String value) {\n   201→            if (value == null || value.length() == 0) {\n   202→                return null;\n   203→            }\n   204→            ContactController controller = (ContactController)facesContext.getApplication().getELResolver().\n   205→                    getValue(facesContext.getELContext(), null, \"contactController\");\n   206→            return controller.ejbFacade.find(getKey(value));\n   207→        }\n   208→\n   209→        java.lang.Long getKey(String value) {\n   210→            java.lang.Long key;\n   211→            key = Long.valueOf(value);\n   212→            return key;\n   213→        }\n   214→\n   215→        String getStringKey(java.lang.Long value) {\n   216→            StringBuilder sb = new StringBuilder();\n   217→            sb.append(value);\n   218→            return sb.toString();\n   219→        }\n   220→\n   221→        @Override\n   222→        public String getAsString(FacesContext facesContext, UIComponent component, Contact object) {\n   223→            if (object == null) {\n   224→                return null;\n   225→            }\n   226→            if (object instanceof Contact) {\n   227→                Contact o = (Contact) object;\n   228→                return getStringKey(o.getId());\n   229→            } else {\n   230→                throw new IllegalArgumentException(\"object \" + \n   231→                        object + \n   232→                        \" is of type \" + \n   233→                        object.getClass().getName() + \n   234→                        \"; expected type: \" +\n   235→                        ContactController.class.getName());\n   236→            }\n   237→        }\n   238→\n   239→    }\n   240→\n   241→}\n   242→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions abo