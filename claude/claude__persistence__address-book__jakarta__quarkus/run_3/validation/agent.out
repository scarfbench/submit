{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_014t75ptWndFcesKgSL81NtD","type":"tool_result","content":"     1→/*\n     2→ * Copyright (c), Eclipse Foundation, Inc. and its licensors.\n     3→ *\n     4→ * All rights reserved.\n     5→ *\n     6→ * This program and the accompanying materials are made available under the\n     7→ * terms of the Eclipse Distribution License v1.0, which is available at\n     8→ * https://www.eclipse.org/org/documents/edl-v10.php\n     9→ *\n    10→ * SPDX-License-Identifier: BSD-3-Clause\n    11→ */\n    12→package jakarta.tutorial.addressbook.entity;\n    13→\n    14→import java.io.Serializable;\n    15→import java.util.Date;\n    16→\n    17→import jakarta.persistence.Entity;\n    18→import jakarta.persistence.GeneratedValue;\n    19→import jakarta.persistence.GenerationType;\n    20→import jakarta.persistence.Id;\n    21→import jakarta.persistence.Temporal;\n    22→import jakarta.persistence.TemporalType;\n    23→import jakarta.validation.constraints.NotNull;\n    24→import jakarta.validation.constraints.Past;\n    25→import jakarta.validation.constraints.Pattern;\n    26→\n    27→/**\n    28→ *\n    29→ * @author ian\n    30→ */\n    31→@Entity\n    32→public class Contact implements Serializable {\n    33→\n    34→    private static final long serialVersionUID = -825634229676522580L;\n    35→    @Id\n    36→    @GeneratedValue(strategy = GenerationType.AUTO)\n    37→    private Long id;\n    38→    @NotNull\n    39→    protected String firstName;\n    40→    @NotNull\n    41→    protected String lastName;\n    42→    @Pattern(regexp = \"[a-z0-9!#$%&'*+/=?^_`{|}~-]+(?:\\\\.\"\n    43→            + \"[a-z0-9!#$%&'*+/=?^_`{|}~-]+)*@\"\n    44→            + \"(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\\\\.)+[a-z0-9]\"\n    45→            + \"(?:[a-z0-9-]*[a-z0-9])?\",\n    46→            message = \"{invalid.email}\")\n    47→    protected String email;\n    48→    @Pattern(regexp = \"^\\\\(?(\\\\d{3})\\\\)?[- ]?(\\\\d{3})[- ]?(\\\\d{4})$\",\n    49→            message = \"{invalid.phonenumber}\")\n    50→    protected String mobilePhone;\n    51→    @Pattern(regexp = \"^\\\\(?(\\\\d{3})\\\\)?[- ]?(\\\\d{3})[- ]?(\\\\d{4})$\",\n    52→            message = \"{invalid.phonenumber}\")\n    53→    protected String homePhone;\n    54→    @Temporal(TemporalType.DATE)\n    55→    @Past\n    56→    protected Date birthday;\n    57→\n    58→    /**\n    59→     * Get the value of birthday\n    60→     *\n    61→     * @return the value of birthday\n    62→     */\n    63→    public Date getBirthday() {\n    64→        return birthday;\n    65→    }\n    66→\n    67→    /**\n    68→     * Set the value of birthday\n    69→     *\n    70→     * @param birthday new value of birthday\n    71→     */\n    72→    public void setBirthday(Date birthday) {\n    73→        this.birthday = birthday;\n    74→    }\n    75→\n    76→    /**\n    77→     * Get the value of homePhone\n    78→     *\n    79→     * @return the value of homePhone\n    80→     */\n    81→    public String getHomePhone() {\n    82→        return homePhone;\n    83→    }\n    84→\n    85→    /**\n    86→     * Set the value of homePhone\n    87→     *\n    88→     * @param homePhone new value of homePhone\n    89→     */\n    90→    public void setHomePhone(String homePhone) {\n    91→        this.homePhone = homePhone;\n    92→    }\n    93→\n    94→    /**\n    95→     * Get the value of mobilePhone\n    96→     *\n    97→     * @return the value of mobilePhone\n    98→     */\n    99→    public String getMobilePhone() {\n   100→        return mobilePhone;\n   101→    }\n   102→\n   103→    /**\n   104→     * Set the value of mobilePhone\n   105→     *\n   106→     * @param mobilePhone new value of mobilePhone\n   107→     */\n   108→    public void setMobilePhone(String mobilePhone) {\n   109→        this.mobilePhone = mobilePhone;\n   110→    }\n   111→\n   112→    /**\n   113→     * Get the value of email\n   114→     *\n   115→     * @return the value of email\n   116→     */\n   117→    public String getEmail() {\n   118→        return email;\n   119→    }\n   120→\n   121→    /**\n   122→     * Set the value of email\n   123→     *\n   124→     * @param email new value of email\n   125→     */\n   126→    public void setEmail(String email) {\n   127→        this.email = email;\n   128→    }\n   129→\n   130→    /**\n   131→     * Get the value of lastName\n   132→     *\n   133→     * @return the value of lastName\n   134→     */\n   135→    public String getLastName() {\n   136→        return lastName;\n   137→    }\n   138→\n   139→    /**\n   140→     * Set the value of lastName\n   141→     *\n   142→     * @param lastName new value of lastName\n   143→     */\n   144→    public void setLastName(String lastName) {\n   145→        this.lastName = lastName;\n   146→    }\n   147→\n   148→    /**\n   149→     * Get the value of firstName\n   150→     *\n   151→     * @return the value of firstName\n   152→     */\n   153→    public String getFirstName() {\n   154→        return firstName;\n   155→    }\n   156→\n   157→    /**\n   158→     * Set the value of firstName\n   159→     *\n   160→     * @param firstName new value of firstName\n   161→     */\n   162→    public void setFirstName(String firstName) {\n   163→        this.firstName = firstName;\n   164→    }\n   165→\n   166→    public Long getId() {\n   167→        return id;\n   168→    }\n   169→\n   170→    public void setId(Long id) {\n   171→        this.id = id;\n   172→    }\n   173→\n   174→    @Override\n   175→    public int hashCode() {\n   176→        int hash = 0;\n   177→        hash += (id != null ? id.hashCode() : 0);\n   178→        return hash;\n   179→    }\n   180→\n   181→    @Override\n   182→    public boolean equals(Object object) {\n   183→        // TODO: Warning - this method won't work in the case the id fields are not set\n   184→        if (!(object instanceof Contact)) {\n   185→            return false;\n   186→        }\n   187→        Contact other = (Contact) object;\n   188→        if ((this.id == null && other.id != null) || (this.id != null && !this.id.equals(other.id))) {\n   189→            return false;\n   190→        }\n   191→        return true;\n   192→    }\n   193→\n   194→    @Override\n   195→    public String toString() {\n   196→        return \"addressbook.entity.Contact[id=\" + id + \"]\";\n   197→    }\n   198→\n   199→}\n   200→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"314f2b2c-e085-4b6f-9fe7-abb949e7403d","uuid":"97518bb9-d9bd-4fab-98da-a69a1ab12eae"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_019Ue51vvDJcxNPSb6KoHCsD","type":"tool_result","content":"     1→/*\n     2→ * Copyright (c), Eclipse Foundation, Inc. and its licensors.\n     3→ *\n     4→ * All rights reserved.\n     5→ *\n     6→ * This program and the accompanying materials are made available under the\n     7→ * terms of the Eclipse Distribution License v1.0, which is available at\n     8→ * https://www.eclipse.org/org/documents/edl-v10.php\n     9→ *\n    10→ * SPDX-License-Identifier: BSD-3-Clause\n    11→ */\n    12→package jakarta.tutorial.addressbook.web;\n    13→\n    14→import java.io.Serializable;\n    15→import java.util.ResourceBundle;\n    16→\n    17→import jakarta.ejb.EJB;\n    18→import jakarta.enterprise.context.SessionScoped;\n    19→import jakarta.faces.component.UIComponent;\n    20→import jakarta.faces.context.FacesContext;\n    21→import jakarta.faces.convert.Converter;\n    22→import jakarta.faces.convert.FacesConverter;\n    23→import jakarta.faces.model.DataModel;\n    24→import jakarta.faces.model.ListDataModel;\n    25→import jakarta.faces.model.SelectItem;\n    26→import jakarta.inject.Named;\n    27→import jakarta.tutorial.addressbook.ejb.ContactFacade;\n    28→import jakarta.tutorial.addressbook.entity.Contact;\n    29→import jakarta.tutorial.addressbook.web.util.JsfUtil;\n    30→import jakarta.tutorial.addressbook.web.util.PaginationHelper;\n    31→\n    32→@Named\n    33→@SessionScoped\n    34→public class ContactController implements Serializable {\n    35→    private static final long serialVersionUID = -8163374738411860012L;\n    36→    private Contact current;\n    37→    private DataModel items = null;\n    38→    @EJB private ContactFacade ejbFacade;\n    39→    private PaginationHelper pagination;\n    40→    private int selectedItemIndex;\n    41→\n    42→    public ContactController() {\n    43→    }\n    44→\n    45→    public Contact getSelected() {\n    46→        if (current == null) {\n    47→            current = new Contact();\n    48→            selectedItemIndex = -1;\n    49→        }\n    50→        return current;\n    51→    }\n    52→\n    53→    private ContactFacade getFacade() {\n    54→        return ejbFacade;\n    55→    }\n    56→\n    57→    public PaginationHelper getPagination() {\n    58→        if (pagination == null) {\n    59→            pagination = new PaginationHelper(10) {\n    60→\n    61→                @Override\n    62→                public int getItemsCount() {\n    63→                    return getFacade().count();\n    64→                }\n    65→\n    66→                @Override\n    67→                public DataModel createPageDataModel() {\n    68→                    return new ListDataModel(getFacade().findRange(new int[]{getPageFirstItem(), getPageFirstItem()+getPageSize()}));\n    69→                }\n    70→            };\n    71→        }\n    72→        return pagination;\n    73→    }\n    74→\n    75→    public String prepareList() {\n    76→        recreateModel();\n    77→        return \"List\";\n    78→    }\n    79→\n    80→    public String prepareView() {\n    81→        current = (Contact)getItems().getRowData();\n    82→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n    83→        return \"View\";\n    84→    }\n    85→\n    86→    public String prepareCreate() {\n    87→        current = new Contact();\n    88→        selectedItemIndex = -1;\n    89→        return \"Create\";\n    90→    }\n    91→\n    92→    public String create() {\n    93→        try {\n    94→            getFacade().create(current);\n    95→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactCreated\"));\n    96→            return prepareCreate();\n    97→        } catch (Exception e) {\n    98→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n    99→            return null;\n   100→        }\n   101→    }\n   102→\n   103→    public String prepareEdit() {\n   104→        current = (Contact)getItems().getRowData();\n   105→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n   106→        return \"Edit\";\n   107→    }\n   108→\n   109→    public String update() {\n   110→        try {\n   111→            getFacade().edit(current);\n   112→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactUpdated\"));\n   113→            return \"View\";\n   114→        } catch (Exception e) {\n   115→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n   116→            return null;\n   117→        }\n   118→    }\n   119→\n   120→    public String destroy() {\n   121→        current = (Contact)getItems().getRowData();\n   122→        selectedItemIndex = pagination.getPageFirstItem() + getItems().getRowIndex();\n   123→        performDestroy();\n   124→        recreateModel();\n   125→        return \"List\";\n   126→    }\n   127→\n   128→    public String destroyAndView() {\n   129→        performDestroy();\n   130→        recreateModel();\n   131→        updateCurrentItem();\n   132→        if (selectedItemIndex >= 0) {\n   133→            return \"View\";\n   134→        } else {\n   135→            // all items were removed - go back to list\n   136→            recreateModel();\n   137→            return \"List\";\n   138→        }\n   139→    }\n   140→\n   141→    private void performDestroy() {\n   142→        try {\n   143→            getFacade().remove(current);\n   144→            JsfUtil.addSuccessMessage(ResourceBundle.getBundle(\"/Bundle\").getString(\"ContactDeleted\"));\n   145→        } catch (Exception e) {\n   146→            JsfUtil.addErrorMessage(e, ResourceBundle.getBundle(\"/Bundle\").getString(\"PersistenceErrorOccured\"));\n   147→        }\n   148→    }\n   149→\n   150→    private void updateCurrentItem() {\n   151→        int count = getFacade().count();\n   152→        if (selectedItemIndex >= count) {\n   153→            // selected index cannot be bigger than number of items:\n   154→            selectedItemIndex = count-1;\n   155→            // go to previous page if last page disappeared:\n   156→            if (pagination.getPageFirstItem() >= count) {\n   157→                pagination.previousPage();\n   158→            }\n   159→        }\n   160→        if (selectedItemIndex >= 0) {\n   161→            current = getFacade().findRange(new int[]{selectedItemIndex, selectedItemIndex+1}).get(0);\n   162→        }\n   163→    }\n   164→\n   165→    public DataModel getItems() {\n   166→        if (items == null) {\n   167→            items = getPagination().createPageDataModel();\n   168→        }\n   169→        return items;\n   170→    }\n   171→\n   172→    private void recreateModel() {\n   173→        items = null;\n   174→    }\n   175→\n   176→    public String next() {\n   177→        getPagination().nextPage();\n   178→        recreateModel();\n   179→        return \"List\";\n   180→    }\n   181→\n   182→    public String previous() {\n   183→        getPagination().previousPage();\n   184→        recreateModel();\n   185→        return \"List\";\n   186→    }\n   187→\n   188→    public SelectItem[] getItemsAvailableSelectMany() {\n   189→        return JsfUtil.getSelectItems(ejbFacade.findAll(), false);\n   190→    }\n   191→\n   192→    public SelectItem[] getItemsAvailableSelectOne() {\n   193→        return JsfUtil.getSelectItems(ejbFacade.findAll(), true);\n   194→    }\n   195→\n   196→    @FacesConverter(forClass=Contact.class)\n   197→    public static class ContactControllerConverter implements Converter<Contact> {\n   198→\n   199→        @Override\n   200→        public Contact getAsObject(FacesContext facesContext, UIComponent component, String value) {\n   201→            if (value == null || value.length() == 0) {\n   202→                return null;\n   203→            }\n   204→            ContactController controller = (ContactController)facesContext.getApplication().getELResolver().\n   205→                    getValue(facesContext.getELContext(), null, \"contactController\");\n   206→            return controller.ejbFacade.find(getKey(value));\n   207→        }\n   208→\n   209→        java.lang.Long getKey(String value) {\n   210→            java.lang.Long key;\n   211→            key = Long.valueOf(value);\n   212→            return key;\n   213→        }\n   214→\n   215→        String getStringKey(java.lang.Long value) {\n   216→            StringBuilder sb = new StringBuilder();\n   217→            sb.append(value);\n   218→            return sb.toString();\n   219→        }\n   220→\n   221→        @Override\n   222→        public String getAsString(FacesContext facesContext, UIComponent component, Contact object) {\n   223→            if (object == null) {\n   224→                return null;\n   225→            }\n   226→            if (object instanceof Contact) {\n   227→                Contact o = (Contact) object;\n   228→                return getStringKey(o.getId());\n   229→            } else {\n   230→                throw new IllegalArgumentException(\"object \" + \n   231→                        object + \n   232→                        \" is of type \" + \n   233→                        object.getClass().getName() + \n   234→                        \"; expected type: \" +\n   235→                        ContactController.class.getName());\n   236→            }\n   237→        }\n   238→\n   239→    }\n   240→\n   241→}\n   242→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"314f2b2c-e085-4b6f-9fe7-abb949e7403d","uuid":"bd67f072-c366-4e21-8e7c-52305c18a43c"}
