{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_019Jbn9F2GrHnSLhH4XwU8js","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_011AaZ5vqZtXyjDL9sU3KKJ9","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__persistence__address-book__jakarta__quarkus/run_2/output/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"\nSmoke tests for the Quarkus Address Book application.\nTests all CRUD operations on the /contacts REST API.\n\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\n\nBASE_URL = os.environ.get(\"APP_URL\", \"http://localhost:8080\")\n\n\ndef make_request(path, method=\"GET\", data=None, expected_status=None):\n    \"\"\"Make an HTTP request and return (status_code, response_body).\"\"\"\n    url = f\"{BASE_URL}{path}\"\n    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n\n    if data is not None:\n        body = json.dumps(data).encode(\"utf-8\")\n    else:\n        body = None\n\n    req = urllib.request.Request(url, data=body, headers=headers, method=method)\n    try:\n        resp = urllib.request.urlopen(req)\n        status = resp.getcode()\n        resp_body = resp.read().decode(\"utf-8\")\n    except urllib.error.HTTPError as e:\n        status = e.code\n        resp_body = e.read().decode(\"utf-8\")\n\n    if expected_status and status != expected_status:\n        print(f\"  FAIL: Expected status {expected_status}, got {status}\")\n        print(f\"  Response: {resp_body[:500]}\")\n        return None, None\n    return status, resp_body\n\n\ndef wait_for_app(max_wait=120):\n    \"\"\"Wait for the application to start.\"\"\"\n    print(f\"Waiting for app at {BASE_URL} ...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            req = urllib.request.Request(f\"{BASE_URL}/q/health/ready\")\n            resp = urllib.request.urlopen(req, timeout=5)\n            if resp.getcode() == 200:\n                print(\"  App is ready!\")\n                return True\n        except Exception:\n            pass\n        time.sleep(2)\n    print(\"  FAIL: App did not become ready in time\")\n    return False\n\n\ndef test_health():\n    \"\"\"Test health endpoint.\"\"\"\n    print(\"TEST: Health check\")\n    status, body = make_request(\"/q/health\", expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert data[\"status\"] == \"UP\", f\"Health status is not UP: {data['status']}\"\n        print(\"  PASS\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_list_empty():\n    \"\"\"Test listing contacts when empty.\"\"\"\n    print(\"TEST: List contacts (empty)\")\n    status, body = make_request(\"/contacts\", expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert isinstance(data, list), \"Expected a list\"\n        print(f\"  PASS (got {len(data)} contacts)\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_create_contact():\n    \"\"\"Test creating a contact.\"\"\"\n    print(\"TEST: Create contact\")\n    contact_data = {\n        \"firstName\": \"John\",\n        \"lastName\": \"Doe\",\n        \"email\": \"john.doe@example.com\",\n        \"mobilePhone\": \"555-123-4567\",\n        \"homePhone\": \"555-987-6543\",\n    }\n    status, body = make_request(\"/contacts\", method=\"POST\", data=contact_data, expected_status=201)\n    if status == 201:\n        data = json.loads(body)\n        assert data[\"firstName\"] == \"John\", f\"firstName mismatch: {data.get('firstName')}\"\n        assert data[\"lastName\"] == \"Doe\", f\"lastName mismatch: {data.get('lastName')}\"\n        assert data[\"email\"] == \"john.doe@example.com\", f\"email mismatch: {data.get('email')}\"\n        assert \"id\" in data and data[\"id\"] is not None, \"id should be set\"\n        print(f\"  PASS (created id={data['id']})\")\n        return data[\"id\"]\n    print(\"  FAIL\")\n    return None\n\n\ndef test_get_contact(contact_id):\n    \"\"\"Test getting a single contact.\"\"\"\n    print(f\"TEST: Get contact id={contact_id}\")\n    status, body = make_request(f\"/contacts/{contact_id}\", expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert data[\"id\"] == contact_id, f\"id mismatch: expected {contact_id}, got {data.get('id')}\"\n        assert data[\"firstName\"] == \"John\"\n        assert data[\"lastName\"] == \"Doe\"\n        print(\"  PASS\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_update_contact(contact_id):\n    \"\"\"Test updating a contact.\"\"\"\n    print(f\"TEST: Update contact id={contact_id}\")\n    updated_data = {\n        \"firstName\": \"Jane\",\n        \"lastName\": \"Smith\",\n        \"email\": \"jane.smith@example.com\",\n        \"mobilePhone\": \"555-111-2222\",\n        \"homePhone\": \"555-333-4444\",\n    }\n    status, body = make_request(f\"/contacts/{contact_id}\", method=\"PUT\", data=updated_data, expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert data[\"firstName\"] == \"Jane\", f\"firstName not updated: {data.get('firstName')}\"\n        assert data[\"lastName\"] == \"Smith\", f\"lastName not updated: {data.get('lastName')}\"\n        assert data[\"email\"] == \"jane.smith@example.com\", f\"email not updated: {data.get('email')}\"\n        print(\"  PASS\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_list_after_create():\n    \"\"\"Test listing contacts after creating one.\"\"\"\n    print(\"TEST: List contacts (after create)\")\n    status, body = make_request(\"/contacts\", expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert len(data) >= 1, f\"Expected at least 1 contact, got {len(data)}\"\n        print(f\"  PASS (got {len(data)} contacts)\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_count():\n    \"\"\"Test count endpoint.\"\"\"\n    print(\"TEST: Count contacts\")\n    status, body = make_request(\"/contacts/count\", expected_status=200)\n    if status == 200:\n        count = int(body)\n        assert count >= 1, f\"Expected count >= 1, got {count}\"\n        print(f\"  PASS (count={count})\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_create_second_contact():\n    \"\"\"Test creating a second contact.\"\"\"\n    print(\"TEST: Create second contact\")\n    contact_data = {\n        \"firstName\": \"Alice\",\n        \"lastName\": \"Wonder\",\n        \"email\": \"alice@example.com\",\n        \"mobilePhone\": \"555-000-1111\",\n    }\n    status, body = make_request(\"/contacts\", method=\"POST\", data=contact_data, expected_status=201)\n    if status == 201:\n        data = json.loads(body)\n        print(f\"  PASS (created id={data['id']})\")\n        return data[\"id\"]\n    print(\"  FAIL\")\n    return None\n\n\ndef test_delete_contact(contact_id):\n    \"\"\"Test deleting a contact.\"\"\"\n    print(f\"TEST: Delete contact id={contact_id}\")\n    status, body = make_request(f\"/contacts/{contact_id}\", method=\"DELETE\", expected_status=204)\n    if status == 204:\n        print(\"  PASS\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_get_deleted(contact_id):\n    \"\"\"Test that deleted contact is not found.\"\"\"\n    print(f\"TEST: Get deleted contact id={contact_id} (expect 404)\")\n    status, body = make_request(f\"/contacts/{contact_id}\", expected_status=404)\n    if status == 404:\n        print(\"  PASS\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef test_validation():\n    \"\"\"Test validation: missing required fields.\"\"\"\n    print(\"TEST: Validation - missing required fields\")\n    bad_data = {\n        \"email\": \"bad-email\",\n    }\n    status, body = make_request(\"/contacts\", method=\"POST\", data=bad_data)\n    if status == 400:\n        print(\"  PASS (got 400 as expected)\")\n        return True\n    print(f\"  FAIL (expected 400, got {status})\")\n    return False\n\n\ndef test_pagination():\n    \"\"\"Test pagination.\"\"\"\n    print(\"TEST: Pagination\")\n    status, body = make_request(\"/contacts?page=0&size=10\", expected_status=200)\n    if status == 200:\n        data = json.loads(body)\n        assert isinstance(data, list), \"Expected a list\"\n        print(f\"  PASS (got {len(data)} contacts)\")\n        return True\n    print(\"  FAIL\")\n    return False\n\n\ndef main():\n    if not wait_for_app():\n        sys.exit(1)\n\n    passed = 0\n    failed = 0\n    total = 0\n\n    def run(test_func, *args):\n        nonlocal passed, failed, total\n        total += 1\n        try:\n            result = test_func(*args)\n            if result is not None and result is not False:\n                passed += 1\n                return result\n            else:\n                failed += 1\n                return None\n        except Exception as e:\n            print(f\"  EXCEPTION: {e}\")\n            failed += 1\n            return None\n\n    # Run tests\n    run(test_health)\n    run(test_list_empty)\n\n    contact_id = run(test_create_contact)\n    if contact_id:\n        run(test_get_contact, contact_id)\n        run(test_update_contact, contact_id)\n\n    run(test_list_after_create)\n    run(test_count)\n\n    second_id = run(test_create_second_contact)\n\n    run(test_pagination)\n    run(test_validation)\n\n    if contact_id:\n        run(test_delete_contact, contact_id)\n        run(test_get_deleted, contact_id)\n\n    if second_id:\n        run(test_delete_contact, second_id)\n\n    print(f\"\\n{'='*50}\")\n    print(f\"Results: {passed}/{total} passed, {failed} failed\")\n    print(f\"{'='*50}\")\n\n    if failed > 0:\n        sys.exit(1)\n    print(\"All smoke tests passed!\")\n    sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":472,"cache_read_input_tokens":45510,"cache_creation":{"ephemeral_5m_input_tokens":472,"ephemeral_1h_input_tokens":0},"output_tokens":2830},"context_management":null},"parent_tool_use_id":null,"session_id":"a4d68ab5-7a1d-4b4a-ab1e-eeb798077cae","uuid":"13af559e-ec06-4ec7-8ac7-48f8dc4b7d46"}
