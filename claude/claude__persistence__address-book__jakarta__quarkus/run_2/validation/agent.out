 38→      <groupId>io.quarkus</groupId>\n    39→      <artifactId>quarkus-rest-jackson</artifactId>\n    40→    </dependency>\n    41→\n    42→    <!-- Hibernate ORM with Panache -->\n    43→    <dependency>\n    44→      <groupId>io.quarkus</groupId>\n    45→      <artifactId>quarkus-hibernate-orm-panache</artifactId>\n    46→    </dependency>\n    47→\n    48→    <!-- Bean Validation -->\n    49→    <dependency>\n    50→      <groupId>io.quarkus</groupId>\n    51→      <artifactId>quarkus-hibernate-validator</artifactId>\n    52→    </dependency>\n    53→\n    54→    <!-- H2 Database -->\n    55→    <dependency>\n    56→      <groupId>io.quarkus</groupId>\n    57→      <artifactId>quarkus-jdbc-h2</artifactId>\n    58→    </dependency>\n    59→\n    60→    <!-- Health check -->\n    61→    <dependency>\n    62→      <groupId>io.quarkus</groupId>\n    63→      <artifactId>quarkus-smallrye-health</artifactId>\n    64→    </dependency>\n    65→\n    66→    <!-- Arc (CDI) - included transitively but explicit for clarity -->\n    67→    <dependency>\n    68→      <groupId>io.quarkus</groupId>\n    69→      <artifactId>quarkus-arc</artifactId>\n    70→    </dependency>\n    71→\n    72→    <!-- Test dependencies -->\n    73→    <dependency>\n    74→      <groupId>io.quarkus</groupId>\n    75→      <artifactId>quarkus-junit5</artifactId>\n    76→      <scope>test</scope>\n    77→    </dependency>\n    78→    <dependency>\n    79→      <groupId>io.rest-assured</groupId>\n    80→      <artifactId>rest-assured</artifactId>\n    81→      <scope>test</scope>\n    82→    </dependency>\n    83→  </dependencies>\n    84→\n    85→  <build>\n    86→    <plugins>\n    87→      <plugin>\n    88→        <groupId>io.quarkus.platform</groupId>\n    89→        <artifactId>quarkus-maven-plugin</artifactId>\n    90→        <version>${quarkus.platform.version}</version>\n    91→        <extensions>true</extensions>\n    92→        <executions>\n    93→          <execution>\n    94→            <goals>\n    95→              <goal>build</goal>\n    96→              <goal>generate-code</goal>\n    97→              <goal>generate-code-tests</goal>\n    98→            </goals>\n    99→          </execution>\n   100→        </executions>\n   101→      </plugin>\n   102→\n   103→      <plugin>\n   104→        <groupId>org.apache.maven.plugins</groupId>\n   105→        <artifactId>maven-compiler-plugin</artifactId>\n   106→        <version>${compiler-plugin.version}</version>\n   107→        <configuration>\n   108→          <compilerArgs>\n   109→            <arg>-parameters</arg>\n   110→          </compilerArgs>\n   111→          <source>17</source>\n   112→          <target>17</target>\n   113→        </configuration>\n   114→      </plugin>\n   115→\n   116→      <plugin>\n   117→        <groupId>org.apache.maven.plugins</groupId>\n   118→        <artifactId>maven-surefire-plugin</artifactId>\n   119→        <version>${surefire-plugin.version}</version>\n   120→        <configuration>\n   121→          <systemPropertyVariables>\n   122→            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   123→          </systemPropertyVariables>\n   124→        </configuration>\n   125→      </plugin>\n   126→    </plugins>\n   127→  </build>\n   128→</project>\n   129→"}]},"parent_tool_use_id":null,"session_id":"a4d68ab5-7a1d-4b4a-ab1e-eeb798077cae","uuid":"bf93c6e9-7bb0-46cb-8be2-c7d70cd22fc0"}
