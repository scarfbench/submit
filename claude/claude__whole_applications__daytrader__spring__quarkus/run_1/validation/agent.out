{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Q1gfFPrpwWAGPthEDupdxh","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.BufferedReader;\n    19→import java.io.IOException;\n    20→import java.io.InputStream;\n    21→import java.io.InputStreamReader;\n    22→import java.math.BigDecimal;\n    23→import java.sql.Connection;\n    24→import java.sql.DatabaseMetaData;\n    25→import java.sql.PreparedStatement;\n    26→import java.sql.ResultSet;\n    27→import java.sql.SQLException;\n    28→import java.sql.Statement;\n    29→import java.util.ArrayList;\n    30→\n    31→import org.springframework.beans.factory.annotation.Autowired;\n    32→import javax.sql.DataSource;\n    33→\n    34→import org.springframework.stereotype.Service;\n    35→\n    36→import com.ibm.websphere.samples.daytrader.beans.RunStatsDataBean;\n    37→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    38→import com.ibm.websphere.samples.daytrader.interfaces.TradeDB;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    41→import com.ibm.websphere.samples.daytrader.util.Log;\n    42→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    43→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    44→\n    45→/**\n    46→ * TradeBuildDB uses operations provided by the TradeApplication to (a) create\n    47→ * the Database tables\n    48→ * (b)populate a DayTrader database without creating the tables. Specifically, a\n    49→ * new DayTrader User population is created using UserIDs of the form \"uid:xxx\"\n    50→ * where xxx is a sequential number (e.g. uid:0, uid:1, etc.). New stocks are\n    51→ * also created of the\n    52→ * form \"s:xxx\", again where xxx represents sequential numbers (e.g. s:1, s:2,\n    53→ * etc.)\n    54→ */\n    55→@Service\n    56→public class TradeDirectDBUtils implements TradeDB {\n    57→\n    58→  // For Wildfly - add java:/ to this resource.\n    59→\n    60→  @Autowired\n    61→  private DataSource datasource;\n    62→\n    63→  @Autowired\n    64→  @TradeJDBC\n    65→  TradeServices ts;\n    66→\n    67→  @Override\n    68→  public String checkDBProductName() throws Exception {\n    69→    String dbProductName = null;\n    70→    try (Connection conn = datasource.getConnection()) {\n    71→      DatabaseMetaData dbmd = conn.getMetaData();\n    72→      dbProductName = dbmd.getDatabaseProductName();\n    73→    } catch (SQLException e) {\n    74→      Log.error(e, \"TradeDirect:checkDBProductName() -- Error checking the Daytrader Database Product Name\");\n    75→    }\n    76→    return dbProductName;\n    77→  }\n    78→\n    79→  /**\n    80→   * Re-create the DayTrader db tables and populate them OR just populate a\n    81→   * DayTrader DB, logging to the provided output stream\n    82→   */\n    83→  public void buildDB(java.io.PrintWriter out, InputStream ddlFile) throws Exception {\n    84→    String symbol, companyName;\n    85→    int errorCount = 0; // Give up gracefully after 10 errors\n    86→\n    87→    // TradeStatistics.statisticsEnabled=false; // disable statistics\n    88→    out.println(\n    89→        \"<HEAD><BR><EM> TradeBuildDB: Building DayTrader Database...</EM><BR> This operation will take several minutes. Please wait...</HEAD>\");\n    90→    out.println(\"<BODY>\");\n    91→\n    92→    if (ddlFile != null) {\n    93→      // out.println(\"<BR>TradeBuildDB: **** warPath= \"+warPath+\" ****</BR></BODY>\");\n    94→\n    95→      boolean success = false;\n    96→\n    97→      Object[] sqlBuffer = null;\n    98→\n    99→      // parse the DDL file and fill the SQL commands into a buffer\n   100→      try {\n   101→        sqlBuffer = parseDDLToBuffer(ddlFile);\n   102→      } catch (Exception e) {\n   103→        Log.error(e, \"TradeBuildDB: Unable to parse DDL file\");\n   104→        out.println(\"<BR>TradeBuildDB: **** Unable to parse DDL file for the specified database ****</BR></BODY>\");\n   105→        return;\n   106→      }\n   107→      if ((sqlBuffer == null) || (sqlBuffer.length == 0)) {\n   108→        out.println(\n   109→            \"<BR>TradeBuildDB: **** Parsing DDL file returned empty buffer, please check that a valid DB specific DDL file is available and retry ****</BR></BODY>\");\n   110→        return;\n   111→      }\n   112→\n   113→      // send the sql commands buffer to drop and recreate the Daytrader tables\n   114→      out.println(\"<BR>TradeBuildDB: **** Dropping and Recreating the DayTrader tables... ****</BR>\");\n   115→      try {\n   116→        success = recreateDBTables(sqlBuffer, out);\n   117→      } catch (Exception e) {\n   118→        Log.error(e,\n   119→            \"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   120→        out.println(\n   121→            \"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   122→        return;\n   123→      }\n   124→      if (!success) {\n   125→        out.println(\n   126→            \"<BR>TradeBuildDB: **** Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing ****</BR></BODY>\");\n   127→        return;\n   128→      }\n   129→      out.println(\n   130→          \"<BR>TradeBuildDB: **** DayTrader tables successfully created! ****</BR><BR><b> Please Stop and Re-start your Daytrader application (or your application server) and then use the \\\"Repopulate Daytrader Database\\\" link to populate your database.</b></BR><BR><BR></BODY>\");\n   131→      return;\n   132→    } // end of createDBTables\n   133→\n   134→    out.println(\"<BR>TradeBuildDB: **** Creating \" + TradeConfig.getMAX_QUOTES() + \" Quotes ****</BR>\");\n   135→    // Attempt to delete all of the Trade users and Trade Quotes first\n   136→    try {\n   137→      resetTrade(true);\n   138→    } catch (Exception e) {\n   139→      Log.error(e, \"TradeBuildDB: Unable to delete Trade users (uid:0, uid:1, ...) and Trade Quotes (s:0, s:1, ...)\");\n   140→    }\n   141→    for (int i = 0; i < TradeConfig.getMAX_QUOTES(); i++) {\n   142→      symbol = \"s:\" + i;\n   143→      companyName = \"S\" + i + \" Incorporated\";\n   144→      try {\n   145→        ts.createQuote(symbol, companyName, new java.math.BigDecimal(TradeConfig.rndPrice()));\n   146→        if (i % 10 == 0) {\n   147→          out.print(\".....\" + symbol);\n   148→          if (i % 100 == 0) {\n   149→            out.println(\" -<BR>\");\n   150→            out.flush();\n   151→          }\n   152→        }\n   153→      } catch (Exception e) {\n   154→        if (errorCount++ >= 10) {\n   155→          String error = \"Populate Trade DB aborting after 10 create quote errors. Check the EJB datasource configuration. Check the log for details <BR><BR> Exception is: <BR> \"\n   156→              + e.toString();\n   157→          Log.error(e, error);\n   158→          throw e;\n   159→        }\n   160→      }\n   161→    }\n   162→    out.println(\"<BR>\");\n   163→    out.println(\"<BR>**** Registering \" + TradeConfig.getMAX_USERS() + \" Users **** \");\n   164→    errorCount = 0; // reset for user registrations\n   165→\n   166→    // Registration is a formal operation in Trade 2.\n   167→    for (int i = 0; i < TradeConfig.getMAX_USERS(); i++) {\n   168→      String userID = \"uid:\" + i;\n   169→      String fullname = TradeConfig.rndFullName();\n   170→      String email = TradeConfig.rndEmail(userID);\n   171→      String address = TradeConfig.rndAddress();\n   172→      String creditcard = TradeConfig.rndCreditCard();\n   173→      double initialBalance = (double) (TradeConfig.rndInt(100000)) + 200000;\n   174→      if (i == 0) {\n   175→        initialBalance = 1000000; // uid:0 starts with a cool million.\n   176→      }\n   177→      try {\n   178→        AccountDataBean accountData = ts.register(userID, \"xxx\", fullname, address, email, creditcard,\n   179→            new BigDecimal(initialBalance));\n   180→\n   181→        if (accountData != null) {\n   182→          if (i % 50 == 0) {\n   183→            out.print(\"<BR>Account# \" + accountData.getAccountID() + \" userID=\" + userID);\n   184→          } // end-if\n   185→\n   186→          int holdings = TradeConfig.rndInt(TradeConfig.getMAX_HOLDINGS() + 1); // 0-MAX_HOLDING (inclusive), avg\n   187→                                                                                // holdings per user = (MAX-0)/2\n   188→          double quantity = 0;\n   189→\n   190→          for (int j = 0; j < holdings; j++) {\n   191→            symbol = TradeConfig.rndSymbol();\n   192→            quantity = TradeConfig.rndQuantity();\n   193→            ts.buy(userID, symbol, quantity, TradeConfig.getOrderProcessingMode());\n   194→          } // end-for\n   195→          if (i % 50 == 0) {\n   196→            out.println(\" has \" + holdings + \" holdings.\");\n   197→            out.flush();\n   198→          } // end-if\n   199→        } else {\n   200→          out.println(\"<BR>UID \" + userID + \" already registered.</BR>\");\n   201→          out.flush();\n   202→        } // end-if\n   203→\n   204→      } catch (Exception e) {\n   205→        if (errorCount++ >= 10) {\n   206→          String error = \"Populate Trade DB aborting after 10 user registration errors. Check the log for details. <BR><BR> Exception is: <BR>\"\n   207→              + e.toString();\n   208→          Log.error(e, error);\n   209→          throw e;\n   210→        }\n   211→      }\n   212→    } // end-for\n   213→    out.println(\"</BODY>\");\n   214→  }\n   215→\n   216→  private boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n   217→    // Clear MDB Statistics\n   218→    MDBStats.getInstance().reset();\n   219→\n   220→    Connection conn = null;\n   221→    boolean success = false;\n   222→    try {\n   223→      conn = datasource.getConnection();\n   224→      Statement stmt = conn.createStatement();\n   225→      int bufferLength = sqlBuffer.length;\n   226→      for (int i = 0; i < bufferLength; i++) {\n   227→        try {\n   228→          stmt.executeUpdate((String) sqlBuffer[i]);\n   229→          // commit(conn);\n   230→        } catch (SQLException ex) {\n   231→          // Ignore DROP statements as tables won't always exist.\n   232→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n   233→            Log.error(\n   234→                \"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i],\n   235→                ex);\n   236→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i]\n   237→                + \"</I> . Check log for details.</BR>\");\n   238→          }\n   239→        }\n   240→      }\n   241→      stmt.close();\n   242→      conn.commit();\n   243→      success = true;\n   244→    } catch (Exception e) {\n   245→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n   246→    } finally {\n   247→      conn.close();\n   248→    }\n   249→    return success;\n   250→  }\n   251→\n   252→  public RunStatsDataBean resetTrade(boolean deleteAll) throws Exception {\n   253→    // Clear MDB Statistics\n   254→    MDBStats.getInstance().reset();\n   255→    // Reset Trade\n   256→\n   257→    RunStatsDataBean runStatsData = new RunStatsDataBean();\n   258→    Connection conn = null;\n   259→    try {\n   260→\n   261→      conn = datasource.getConnection();\n   262→      conn.setAutoCommit(false);\n   263→      PreparedStatement stmt = null;\n   264→      ResultSet rs = null;\n   265→\n   266→      if (deleteAll) {\n   267→        try {\n   268→          stmt = getStatement(conn, \"delete from quoteejb\");\n   269→          stmt.executeUpdate();\n   270→          stmt.close();\n   271→          stmt = getStatement(conn, \"delete from accountejb\");\n   272→          stmt.executeUpdate();\n   273→          stmt.close();\n   274→          stmt = getStatement(conn, \"delete from accountprofileejb\");\n   275→          stmt.executeUpdate();\n   276→          stmt.close();\n   277→          stmt = getStatement(conn, \"delete from holdingejb\");\n   278→          stmt.executeUpdate();\n   279→          stmt.close();\n   280→          stmt = getStatement(conn, \"delete from orderejb\");\n   281→          stmt.executeUpdate();\n   282→          stmt.close();\n   283→          // FUTURE: - DuplicateKeyException - For now, don't start at\n   284→          // zero as KeySequenceDirect and KeySequenceBean will still\n   285→          // give out\n   286→          // the cached Block and then notice this change. Better\n   287→          // solution is\n   288→          // to signal both classes to drop their cached blocks\n   289→          // stmt = getStatement(conn, \"delete from keygenejb\");\n   290→          // stmt.executeUpdate();\n   291→          // stmt.close();\n   292→          conn.commit();\n   293→        } catch (Exception e) {\n   294→          Log.error(e,\n   295→              \"TradeDirect:resetTrade(deleteAll) -- Error deleting Trade users and stock from the Trade database\");\n   296→        }\n   297→        return runStatsData;\n   298→      }\n   299→\n   300→      stmt = getStatement(conn, \"delete from holdingejb where holdingejb.account_accountid is null\");\n   301→      stmt.executeUpdate();\n   302→      stmt.close();\n   303→\n   304→      // Count and Delete newly registered users (users w/ id that start\n   305→      // \"ru:%\":\n   306→      stmt = getStatement(conn, \"delete from accountprofileejb where userid like 'ru:%'\");\n   307→      stmt.executeUpdate();\n   308→      stmt.close();\n   309→\n   310→      stmt = getStatement(conn,\n   311→          \"delete from orderejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   312→      stmt.executeUpdate();\n   313→      stmt.close();\n   314→\n   315→      stmt = getStatement(conn,\n   316→          \"delete from holdingejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   317→      stmt.executeUpdate();\n   318→      stmt.close();\n   319→\n   320→      stmt = getStatement(conn, \"delete from accountejb where profile_userid like 'ru:%'\");\n   321→      int newUserCount = stmt.executeUpdate();\n   322→      runStatsData.setNewUserCount(newUserCount);\n   323→      stmt.close();\n   324→\n   325→      // Count of trade users\n   326→      stmt = getStatement(conn,\n   327→          \"select count(accountid) as \\\"tradeUserCount\\\" from accountejb a where a.profile_userid like 'uid:%'\");\n   328→      rs = stmt.executeQuery();\n   329→      rs.next();\n   330→      int tradeUserCount = rs.getInt(\"tradeUserCount\");\n   331→      runStatsData.setTradeUserCount(tradeUserCount);\n   332→      stmt.close();\n   333→\n   334→      rs.close();\n   335→      // Count of trade stocks\n   336→      stmt = getStatement(conn,\n   337→          \"select count(symbol) as \\\"tradeStockCount\\\" from quoteejb a where a.symbol like 's:%'\");\n   338→      rs = stmt.executeQuery();\n   339→      rs.next();\n   340→      int tradeStockCount = rs.getInt(\"tradeStockCount\");\n   341→      runStatsData.setTradeStockCount(tradeStockCount);\n   342→      stmt.close();\n   343→\n   344→      // Count of trade users login, logout\n   345→      stmt = getStatement(conn,\n   346→          \"select sum(loginCount) as \\\"sumLoginCount\\\", sum(logoutCount) as \\\"sumLogoutCount\\\" from accountejb a where  a.profile_userID like 'uid:%'\");\n   347→      rs = stmt.executeQuery();\n   348→      rs.next();\n   349→      int sumLoginCount = rs.getInt(\"sumLoginCount\");\n   350→      int sumLogoutCount = rs.getInt(\"sumLogoutCount\");\n   351→      runStatsData.setSumLoginCount(sumLoginCount);\n   352→      runStatsData.setSumLogoutCount(sumLogoutCount);\n   353→      stmt.close();\n   354→\n   355→      rs.close();\n   356→      // Update logoutcount and loginCount back to zero\n   357→\n   358→      stmt = getStatement(conn, \"update accountejb set logoutCount=0,loginCount=0 where profile_userID like 'uid:%'\");\n   359→      stmt.executeUpdate();\n   360→      stmt.close();\n   361→\n   362→      // count holdings for trade users\n   363→      stmt = getStatement(conn,\n   364→          \"select count(holdingid) as \\\"holdingCount\\\" from holdingejb h where h.account_accountid in \"\n   365→              + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   366→\n   367→      rs = stmt.executeQuery();\n   368→      rs.next();\n   369→      int holdingCount = rs.getInt(\"holdingCount\");\n   370→      runStatsData.setHoldingCount(holdingCount);\n   371→      stmt.close();\n   372→      rs.close();\n   373→\n   374→      // count orders for trade users\n   375→      stmt = getStatement(conn, \"select count(orderid) as \\\"orderCount\\\" from orderejb o where o.account_accountid in \"\n   376→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   377→\n   378→      rs = stmt.executeQuery();\n   379→      rs.next();\n   380→      int orderCount = rs.getInt(\"orderCount\");\n   381→      runStatsData.setOrderCount(orderCount);\n   382→      stmt.close();\n   383→      rs.close();\n   384→\n   385→      // count orders by type for trade users\n   386→      stmt = getStatement(conn, \"select count(orderid) \\\"buyOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   387→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='buy')\");\n   388→\n   389→      rs = stmt.executeQuery();\n   390→      rs.next();\n   391→      int buyOrderCount = rs.getInt(\"buyOrderCount\");\n   392→      runStatsData.setBuyOrderCount(buyOrderCount);\n   393→      stmt.close();\n   394→      rs.close();\n   395→\n   396→      // count orders by type for trade users\n   397→      stmt = getStatement(conn, \"select count(orderid) \\\"sellOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   398→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='sell')\");\n   399→\n   400→      rs = stmt.executeQuery();\n   401→      rs.next();\n   402→      int sellOrderCount = rs.getInt(\"sellOrderCount\");\n   403→      runStatsData.setSellOrderCount(sellOrderCount);\n   404→      stmt.close();\n   405→      rs.close();\n   406→\n   407→      // Delete cancelled orders\n   408→      stmt = getStatement(conn, \"delete from orderejb where orderStatus='cancelled'\");\n   409→      int cancelledOrderCount = stmt.executeUpdate();\n   410→      runStatsData.setCancelledOrderCount(cancelledOrderCount);\n   411→      stmt.close();\n   412→      rs.close();\n   413→\n   414→      // count open orders by type for trade users\n   415→      stmt = getStatement(conn, \"select count(orderid) \\\"openOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   416→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \"\n   417→          + \" (o.orderStatus='open')\");\n   418→\n   419→      rs = stmt.executeQuery();\n   420→      rs.next();\n   421→      int openOrderCount = rs.getInt(\"openOrderCount\");\n   422→      runStatsData.setOpenOrderCount(openOrderCount);\n   423→\n   424→      stmt.close();\n   425→      rs.close();\n   426→      // Delete orders for holding which have been purchased and sold\n   427→      stmt = getStatement(conn, \"delete from orderejb where holding_holdingid is null\");\n   428→      int deletedOrderCount = stmt.executeUpdate();\n   429→      runStatsData.setDeletedOrderCount(deletedOrderCount);\n   430→      stmt.close();\n   431→      rs.close();\n   432→\n   433→      conn.commit();\n   434→\n   435→      System.out.println(\"TradeDirect:reset Run stats data\\n\\n\" + runStatsData);\n   436→    } catch (Exception e) {\n   437→      Log.error(e, \"Failed to reset Trade\");\n   438→      conn.rollback();\n   439→      throw e;\n   440→    } finally {\n   441→      conn.close();\n   442→    }\n   443→    return runStatsData;\n   444→\n   445→  }\n   446→\n   447→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n   448→    return conn.prepareStatement(sql);\n   449→  }\n   450→\n   451→  public Object[] parseDDLToBuffer(InputStream ddlFile) throws Exception {\n   452→    BufferedReader br = null;\n   453→    ArrayList<String> sqlBuffer = new ArrayList<String>(30); // initial capacity 30 assuming we have 30 ddl-sql\n   454→                                                             // statements to read\n   455→\n   456→    try {\n   457→      br = new BufferedReader(new InputStreamReader(ddlFile));\n   458→      String s;\n   459→      String sql = new String();\n   460→      while ((s = br.readLine()) != null) {\n   461→        s = s.trim();\n   462→        if ((s.length() != 0) && (s.charAt(0) != '#')) // Empty lines or lines starting with \"#\" are ignored\n   463→        {\n   464→          sql = sql + \" \" + s;\n   465→          if (s.endsWith(\";\")) { // reached end of sql statement\n   466→            sql = sql.replace(';', ' '); // remove the semicolon\n   467→            sqlBuffer.add(sql);\n   468→            sql = \"\";\n   469→          }\n   470→        }\n   471→      }\n   472→    } catch (IOException ex) {\n   473→      Log.error(\"TradeBuildDB:parseDDLToBuffer Exeception during open/read of File: \" + ddlFile, ex);\n   474→      throw ex;\n   475→    } finally {\n   476→      if (br != null) {\n   477→        try {\n   478→          br.close();\n   479→        } catch (IOException ex) {\n   480→          Log.error(\"TradeBuildDB:parseDDLToBuffer Failed to close BufferedReader\", ex);\n   481→        }\n   482→      }\n   483→    }\n   484→    return sqlBuffer.toArray();\n   485→  }\n   486→}\n   487→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"54727131-0367-4f85-80a2-dd69317d877c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Rc1hJdf3rzc8Yqw2HTHUfv","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import org.springframework.beans.factory.annotation.Autowired;\n    19→import org.springframework.context.annotation.Scope;\n    20→import org.springframework.stereotype.Component;\n    21→\n    22→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    23→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    24→\n    25→import jakarta.inject.Inject;\n    26→import jakarta.transaction.UserTransaction;\n    27→\n    28→@Component\n    29→@Scope(\"prototype\")\n    30→public class AsyncOrder implements Runnable {\n    31→\n    32→  @Inject\n    33→  @TradeJDBC\n    34→  TradeServices tradeService;\n    35→\n    36→  @Autowired(required = false)\n    37→  UserTransaction ut;\n    38→\n    39→  Integer orderID;\n    40→  boolean twoPhase;\n    41→\n    42→  public void setProperties(Integer orderID, boolean twoPhase) {\n    43→    this.orderID = orderID;\n    44→    this.twoPhase = twoPhase;\n    45→  }\n    46→\n    47→  @Override\n    48→  public void run() {\n    49→\n    50→    try {\n    51→      if (ut != null) ut.begin();\n    52→      tradeService.completeOrder(orderID, twoPhase);\n    53→      if (ut != null) ut.commit();\n    54→    } catch (Exception e) {\n    55→\n    56→      try {\n    57→        if (ut != null) ut.rollback();\n    58→      } catch (Exception e1) {\n    59→        try {\n    60→          throw new Exception(e1);\n    61→        } catch (Exception e2) {\n    62→          e2.printStackTrace();\n    63→        }\n    64→      }\n    65→      try {\n    66→        throw new Exception(e);\n    67→      } catch (Exception e1) {\n    68→        // TODO Auto-generated catch block\n    69→        e1.printStackTrace();\n    70→      }\n    71→    }\n    72→  }\n    73→}\n    74→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"61c8b306-bbbe-4ada-88a8-9fde6b5a1598"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MRyXyLCyCFvdct9BaygMTQ","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.util.concurrent.Future;\n    19→\n    20→import org.springframework.beans.factory.ObjectFactory;\n    21→import org.springframework.beans.factory.annotation.Autowired;\n    22→import org.springframework.beans.factory.annotation.Qualifier;\n    23→import org.springframework.core.task.AsyncTaskExecutor;\n    24→import org.springframework.stereotype.Component;\n    25→\n    26→@Component\n    27→public class AsyncOrderSubmitter {\n    28→\n    29→  @Autowired\n    30→  @Qualifier(\"ManagedExecutorService\") // Matching the bean name here\n    31→  private AsyncTaskExecutor mes;\n    32→\n    33→  @Autowired\n    34→  private ObjectFactory<AsyncOrder> asyncOrderFactory;\n    35→\n    36→  public Future<?> submitOrder(Integer orderID, boolean twoPhase) {\n    37→  AsyncOrder task = asyncOrderFactory.getObject();\n    38→  task.setProperties(orderID, twoPhase);\n    39→  return mes.submit(task);\n    40→  }\n    41→}\n    42→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"6690839e-263b-40b7-8bbd-c450edc75f5f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XRre8nmy9VaFRbrWUstDSq","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.sql.Connection;\n    19→import java.sql.PreparedStatement;\n    20→import java.sql.ResultSet;\n    21→import java.util.Collection;\n    22→import java.util.HashMap;\n    23→import java.util.Iterator;\n    24→\n    25→import com.ibm.websphere.samples.daytrader.util.KeyBlock;\n    26→import com.ibm.websphere.samples.daytrader.util.Log;\n    27→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    28→\n    29→public class KeySequenceDirect {\n    30→\n    31→    private static HashMap<String, Collection<?>> keyMap = new HashMap<String, Collection<?>>();\n    32→\n    33→    public static synchronized Integer getNextID(Connection conn, String keyName, boolean inSession, boolean inGlobalTxn) throws Exception {\n    34→        Integer nextID = null;\n    35→        // First verify we have allocated a block of keys\n    36→        // for this key name\n    37→        // Then verify the allocated block has not been depleted\n    38→        // allocate a new block if necessary\n    39→        if (keyMap.containsKey(keyName) == false) {\n    40→            allocNewBlock(conn, keyName, inSession, inGlobalTxn);\n    41→        }\n    42→        Collection<?> block = keyMap.get(keyName);\n    43→\n    44→        Iterator<?> ids = block.iterator();\n    45→        if (ids.hasNext() == false) {\n    46→            ids = allocNewBlock(conn, keyName, inSession, inGlobalTxn).iterator();\n    47→        }\n    48→        // get and return a new unique key\n    49→        nextID = (Integer) ids.next();\n    50→\n    51→        \n    52→        Log.trace(\"KeySequenceDirect:getNextID inSession(\" + inSession + \") - return new PK ID for Entity type: \" + keyName + \" ID=\" + nextID);\n    53→        \n    54→        return nextID;\n    55→    }\n    56→\n    57→    private static Collection<?> allocNewBlock(Connection conn, String keyName, boolean inSession, boolean inGlobalTxn) throws Exception {\n    58→        try {\n    59→\n    60→            if (inGlobalTxn == false && !inSession) {\n    61→                conn.commit(); // commit any pending txns\n    62→            }\n    63→\n    64→            PreparedStatement stmt = conn.prepareStatement(getKeyForUpdateSQL);\n    65→            stmt.setString(1, keyName);\n    66→            ResultSet rs = stmt.executeQuery();\n    67→\n    68→            if (!rs.next()) {\n    69→                // No keys found for this name - create a new one\n    70→                PreparedStatement stmt2 = conn.prepareStatement(createKeySQL);\n    71→                int keyVal = 0;\n    72→                stmt2.setString(1, keyName);\n    73→                stmt2.setInt(2, keyVal);\n    74→                stmt2.executeUpdate();\n    75→                stmt2.close();\n    76→                stmt.close();\n    77→                stmt = conn.prepareStatement(getKeyForUpdateSQL);\n    78→                stmt.setString(1, keyName);\n    79→                rs = stmt.executeQuery();\n    80→                rs.next();\n    81→            }\n    82→\n    83→            int keyVal = rs.getInt(\"keyval\");\n    84→\n    85→            stmt.close();\n    86→\n    87→            stmt = conn.prepareStatement(updateKeyValueSQL);\n    88→            stmt.setInt(1, keyVal + TradeConfig.KEYBLOCKSIZE);\n    89→            stmt.setString(2, keyName);\n    90→            stmt.executeUpdate();\n    91→            stmt.close();\n    92→\n    93→            Collection<?> block = new KeyBlock(keyVal, keyVal + TradeConfig.KEYBLOCKSIZE - 1);\n    94→            keyMap.put(keyName, block);\n    95→\n    96→            if (inGlobalTxn == false && !inSession) {\n    97→                conn.commit();\n    98→            }\n    99→\n   100→            return block;\n   101→        } catch (Exception e) {\n   102→            String error = \"KeySequenceDirect:allocNewBlock - failure to allocate new block of keys for Entity type: \" + keyName;\n   103→            Log.error(e, error);\n   104→            throw new Exception(error + e.toString());\n   105→        }\n   106→    }\n   107→\n   108→    private static final String getKeyForUpdateSQL = \"select * from keygenejb kg where kg.keyname = ?  for update\";\n   109→\n   110→    private static final String createKeySQL = \"insert into keygenejb \" + \"( keyname, keyval ) \" + \"VALUES (  ?  ,  ? )\";\n   111→\n   112→    private static final String updateKeyValueSQL = \"update keygenejb set keyval = ? \" + \"where keyname = ?\";\n   113→\n   114→}\n   115→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"df6231db-9304-4005-a589-69ea68d8332c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_014watDMTZ5tVWRm5cm7qxzS","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.session2direct;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.Collection;\n    20→import java.util.concurrent.Future;\n    21→\n    22→import org.springframework.stereotype.Service;\n    23→\n    24→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    25→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    26→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    27→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    28→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    29→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    30→import com.ibm.websphere.samples.daytrader.impl.ejb3.AsyncScheduledOrderSubmitter;\n    31→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    32→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    33→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    34→import com.ibm.websphere.samples.daytrader.interfaces.TradeSession2Direct;\n    35→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    36→\n    37→import jakarta.inject.Inject;\n    38→import jakarta.transaction.Transactional;\n    39→import jakarta.validation.constraints.NotNull;\n    40→\n    41→@Service(\"Session to Direct\")\n    42→@TradeSession2Direct\n    43→@Trace\n    44→@Transactional\n    45→public class DirectSLSBBean implements TradeServices {\n    46→\n    47→  @Inject\n    48→  @TradeJDBC\n    49→  TradeServices tradeDirect;\n    50→\n    51→  @Inject\n    52→  AsyncScheduledOrderSubmitter asyncEJBOrderSubmitter;\n    53→\n    54→  @Override\n    55→  public int getImpl() {\n    56→    return TradeConfig.SESSION_TO_DIRECT;\n    57→  }\n    58→\n    59→  @Override\n    60→  public MarketSummaryDataBean getMarketSummary() throws Exception {\n    61→    tradeDirect.setInSession(true);\n    62→    return tradeDirect.getMarketSummary();\n    63→  }\n    64→\n    65→  @Override\n    66→  public OrderDataBean createOrder(AccountDataBean account, QuoteDataBean quote, HoldingDataBean holding,\n    67→      String orderType, double quantity) throws Exception {\n    68→    tradeDirect.setInSession(true);\n    69→    return tradeDirect.createOrder(account, quote, holding, orderType, quantity);\n    70→  }\n    71→\n    72→  @Override\n    73→  @NotNull\n    74→  public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) throws Exception {\n    75→    tradeDirect.setInSession(true);\n    76→    OrderDataBean orderdata = tradeDirect.buy(userID, symbol, quantity, orderProcessingMode);\n    77→\n    78→    if (orderProcessingMode == TradeConfig.ASYNCH) {\n    79→      this.completeOrderAsync(orderdata.getOrderID(), false);\n    80→    }\n    81→\n    82→    return orderdata;\n    83→  }\n    84→\n    85→  @Override\n    86→  @NotNull\n    87→  public OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception {\n    88→    tradeDirect.setInSession(true);\n    89→    OrderDataBean orderdata = tradeDirect.sell(userID, holdingID, orderProcessingMode);\n    90→\n    91→    if (orderProcessingMode == TradeConfig.ASYNCH) {\n    92→      this.completeOrderAsync(orderdata.getOrderID(), false);\n    93→    }\n    94→    return orderdata;\n    95→\n    96→  }\n    97→\n    98→  @Override\n    99→  public void queueOrder(Integer orderID, boolean twoPhase) throws Exception {\n   100→    tradeDirect.setInSession(true);\n   101→    tradeDirect.queueOrder(orderID, twoPhase);\n   102→\n   103→  }\n   104→\n   105→  @Override\n   106→  public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   107→    tradeDirect.setInSession(true);\n   108→    return tradeDirect.completeOrder(orderID, twoPhase);\n   109→  }\n   110→\n   111→  @Override\n   112→  public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   113→    asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   114→    return null;\n   115→  }\n   116→\n   117→  @Override\n   118→  public void cancelOrder(Integer orderID, boolean twoPhase) throws Exception {\n   119→    tradeDirect.setInSession(true);\n   120→    tradeDirect.cancelOrder(orderID, twoPhase);\n   121→\n   122→  }\n   123→\n   124→  @Override\n   125→  public void orderCompleted(String userID, Integer orderID) throws Exception {\n   126→    tradeDirect.setInSession(true);\n   127→    tradeDirect.orderCompleted(userID, orderID);\n   128→\n   129→  }\n   130→\n   131→  @Override\n   132→  public Collection<?> getOrders(String userID) throws Exception {\n   133→    tradeDirect.setInSession(true);\n   134→    return tradeDirect.getOrders(userID);\n   135→  }\n   136→\n   137→  @Override\n   138→  public Collection<?> getClosedOrders(String userID) throws Exception {\n   139→    tradeDirect.setInSession(true);\n   140→    return tradeDirect.getClosedOrders(userID);\n   141→  }\n   142→\n   143→  @Override\n   144→  public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception {\n   145→    tradeDirect.setInSession(true);\n   146→    return tradeDirect.createQuote(symbol, companyName, price);\n   147→  }\n   148→\n   149→  @Override\n   150→  public QuoteDataBean getQuote(String symbol) throws Exception {\n   151→    tradeDirect.setInSession(true);\n   152→    return tradeDirect.getQuote(symbol);\n   153→  }\n   154→\n   155→  @Override\n   156→  public Collection<?> getAllQuotes() throws Exception {\n   157→    tradeDirect.setInSession(true);\n   158→    return tradeDirect.getAllQuotes();\n   159→  }\n   160→\n   161→  @Override\n   162→  public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal newPrice, double sharesTraded)\n   163→      throws Exception {\n   164→    tradeDirect.setInSession(true);\n   165→    return tradeDirect.updateQuotePriceVolume(symbol, newPrice, sharesTraded);\n   166→  }\n   167→\n   168→  @Override\n   169→  public Collection<HoldingDataBean> getHoldings(String userID) throws Exception {\n   170→    tradeDirect.setInSession(true);\n   171→    return tradeDirect.getHoldings(userID);\n   172→  }\n   173→\n   174→  @Override\n   175→  public HoldingDataBean getHolding(Integer holdingID) throws Exception {\n   176→    tradeDirect.setInSession(true);\n   177→    return tradeDirect.getHolding(holdingID);\n   178→  }\n   179→\n   180→  @Override\n   181→  public AccountDataBean getAccountData(String userID) throws Exception {\n   182→    tradeDirect.setInSession(true);\n   183→    return tradeDirect.getAccountData(userID);\n   184→  }\n   185→\n   186→  @Override\n   187→  public AccountProfileDataBean getAccountProfileData(String userID) throws Exception {\n   188→    tradeDirect.setInSession(true);\n   189→    return tradeDirect.getAccountProfileData(userID);\n   190→  }\n   191→\n   192→  @Override\n   193→  public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception {\n   194→    tradeDirect.setInSession(true);\n   195→    return tradeDirect.updateAccountProfile(profileData);\n   196→  }\n   197→\n   198→  @Override\n   199→  public AccountDataBean login(String userID, String password) throws Exception {\n   200→    tradeDirect.setInSession(true);\n   201→    return tradeDirect.login(userID, password);\n   202→  }\n   203→\n   204→  @Override\n   205→  public void logout(String userID) throws Exception {\n   206→    tradeDirect.setInSession(true);\n   207→    tradeDirect.logout(userID);\n   208→  }\n   209→\n   210→  @Override\n   211→  public AccountDataBean register(String userID, String password, String fullname, String address, String email,\n   212→      String creditcard, BigDecimal openBalance) throws Exception {\n   213→    tradeDirect.setInSession(true);\n   214→    return tradeDirect.register(userID, password, fullname, address, email, creditcard, openBalance);\n   215→  }\n   216→\n   217→  @Override\n   218→  public QuoteDataBean pingTwoPhase(String symbol) throws Exception {\n   219→    throw new UnsupportedOperationException();\n   220→  }\n   221→\n   222→  @Override\n   223→  public double investmentReturn(double rnd1, double rnd2) throws Exception {\n   224→    throw new UnsupportedOperationException();\n   225→  }\n   226→\n   227→  @Override\n   228→  public void setInSession(boolean inSession) {\n   229→    throw new UnsupportedOperationException(\"DirectSLSBBean::setInGlobalTxn not supported\");\n   230→  }\n   231→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"fab4d4c8-0335-4dfa-b03c-34162b061dd4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01W2sLD2YYCYUz4cQjLzkLuj","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.sql.Connection;\n    21→import java.sql.PreparedStatement;\n    22→import java.sql.ResultSet;\n    23→import java.sql.SQLException;\n    24→import java.sql.Statement;\n    25→import java.sql.Timestamp;\n    26→import java.util.ArrayList;\n    27→import java.util.Collection;\n    28→import java.util.concurrent.Future;\n    29→\n    30→import jakarta.annotation.Resource;\n    31→import jakarta.jms.JMSException;\n    32→import jakarta.jms.TextMessage;\n    33→import javax.sql.DataSource;\n    34→\n    35→import org.springframework.beans.factory.annotation.Autowired;\n    36→import org.springframework.context.ApplicationEventPublisher;\n    37→import org.springframework.jms.core.JmsTemplate;\n    38→import org.springframework.stereotype.Service;\n    39→\n    40→import jakarta.transaction.UserTransaction;\n    41→import jakarta.validation.constraints.NotNull;\n    42→\n    43→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    44→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    45→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    46→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    47→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    48→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    49→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    50→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    51→import com.ibm.websphere.samples.daytrader.events.MarketSummaryUpdateEvent;\n    52→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    53→import com.ibm.websphere.samples.daytrader.util.Log;\n    54→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    55→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    56→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    57→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    58→\n    59→/**\n    60→ * TradeDirect uses direct JDBC and JMS access to a\n    61→ * <code>javax.sql.DataSource</code> to implement the business methods of the\n    62→ * Trade online broker application. These business methods represent the\n    63→ * features and operations that can be performed by customers of the brokerage\n    64→ * such as login, logout, get a stock quote, buy or sell a stock, etc. and are\n    65→ * specified in the {@link com.ibm.websphere.samples.daytrader.TradeServices}\n    66→ * interface\n    67→ *\n    68→ * Note: In order for this class to be thread-safe, a new TradeJDBC must be\n    69→ * created for each call to a method from the TradeInterface interface.\n    70→ * Otherwise, pooled connections may not be released.\n    71→ *\n    72→ * @see com.ibm.websphere.samples.daytrader.TradeServices\n    73→ *\n    74→ */\n    75→\n    76→@Service(\"Direct (JDBC)\")\n    77→@TradeJDBC\n    78→@Trace\n    79→public class TradeDirect implements TradeServices, Serializable {\n    80→  /**\n    81→   * \n    82→   */\n    83→  private static final long serialVersionUID = -8089049090952927985L;\n    84→\n    85→  // This lock is used to serialize market summary operations.\n    86→  private static final Object marketSummaryLock = new Object();\n    87→  private static long nextMarketSummary = System.currentTimeMillis();\n    88→  private static MarketSummaryDataBean cachedMSDB = MarketSummaryDataBean.getRandomInstance();\n    89→\n    90→  private static BigDecimal ZERO = new BigDecimal(0.0);\n    91→  private boolean inGlobalTxn = false;\n    92→  private boolean inSession = false;\n    93→\n    94→  @Autowired\n    95→  private DataSource datasource;\n    96→\n    97→  @Autowired(required = false)\n    98→  private UserTransaction txn;\n    99→\n   100→  @Autowired\n   101→  RecentQuotePriceChangeList recentQuotePriceChangeList;\n   102→\n   103→  @Autowired\n   104→  AsyncOrderSubmitter asyncOrderSubmitter;\n   105→\n   106→  @Autowired\n   107→  ApplicationEventPublisher publisher;\n   108→\n   109→  @Override\n   110→  public MarketSummaryDataBean getMarketSummary() throws Exception {\n   111→\n   112→    if (TradeConfig.getMarketSummaryInterval() == 0) {\n   113→      return getMarketSummaryInternal();\n   114→    }\n   115→    if (TradeConfig.getMarketSummaryInterval() < 0) {\n   116→      return cachedMSDB;\n   117→    }\n   118→\n   119→    /**\n   120→     * This is a little funky. If its time to fetch a new Market summary\n   121→     * then we'll synchronize access to make sure only one requester does\n   122→     * it. Others will merely return the old copy until the new\n   123→     * MarketSummary has been executed.\n   124→     */\n   125→\n   126→    long currentTime = System.currentTimeMillis();\n   127→\n   128→    if (currentTime > nextMarketSummary) {\n   129→      long oldNextMarketSummary = nextMarketSummary;\n   130→      boolean fetch = false;\n   131→\n   132→      synchronized (marketSummaryLock) {\n   133→        /**\n   134→         * Is it still ahead or did we miss lose the race? If we lost\n   135→         * then let's get out of here as the work has already been done.\n   136→         */\n   137→        if (oldNextMarketSummary == nextMarketSummary) {\n   138→          fetch = true;\n   139→          nextMarketSummary += TradeConfig.getMarketSummaryInterval() * 1000;\n   140→\n   141→          /**\n   142→           * If the server has been idle for a while then its possible\n   143→           * that nextMarketSummary could be way off. Rather than try\n   144→           * and play catch up we'll simply get in sync with the\n   145→           * current time + the interval.\n   146→           */\n   147→          if (nextMarketSummary < currentTime) {\n   148→            nextMarketSummary = currentTime + TradeConfig.getMarketSummaryInterval() * 1000;\n   149→          }\n   150→        }\n   151→      }\n   152→\n   153→      /**\n   154→       * If we're the lucky one then let's update the MarketSummary\n   155→       */\n   156→      if (fetch) {\n   157→        cachedMSDB = getMarketSummaryInternal();\n   158→\n   159→      }\n   160→    }\n   161→\n   162→    return cachedMSDB;\n   163→  }\n   164→\n   165→  /**\n   166→   * @see TradeServices#getMarketSummary()\n   167→   */\n   168→\n   169→  public MarketSummaryDataBean getMarketSummaryInternal() throws Exception {\n   170→\n   171→    MarketSummaryDataBean marketSummaryData = null;\n   172→    Connection conn = null;\n   173→    try {\n   174→\n   175→      Log.trace(\"TradeDirect:getMarketSummary - inSession(\" + this.inSession + \")\");\n   176→\n   177→      conn = getConn();\n   178→      PreparedStatement stmt = getStatement(conn, getTSIAQuotesOrderByChangeSQL, ResultSet.TYPE_SCROLL_INSENSITIVE,\n   179→          ResultSet.CONCUR_READ_ONLY);\n   180→\n   181→      ArrayList<QuoteDataBean> topGainersData = new ArrayList<QuoteDataBean>(5);\n   182→      ArrayList<QuoteDataBean> topLosersData = new ArrayList<QuoteDataBean>(5);\n   183→\n   184→      ResultSet rs = stmt.executeQuery();\n   185→\n   186→      int count = 0;\n   187→      while (rs.next() && (count++ < 5)) {\n   188→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   189→        topLosersData.add(quoteData);\n   190→      }\n   191→\n   192→      stmt.close();\n   193→      stmt = getStatement(conn, \"select * from quoteejb q order by q.change1 DESC\", ResultSet.TYPE_SCROLL_INSENSITIVE,\n   194→          ResultSet.CONCUR_READ_ONLY);\n   195→      rs = stmt.executeQuery();\n   196→\n   197→      count = 0;\n   198→      while (rs.next() && (count++ < 5)) {\n   199→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   200→        topGainersData.add(quoteData);\n   201→      }\n   202→\n   203→      /*\n   204→       * rs.last(); count = 0; while (rs.previous() && (count++ < 5) ) {\n   205→       * QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   206→       * topGainersData.add(quoteData); }\n   207→       */\n   208→\n   209→      stmt.close();\n   210→\n   211→      BigDecimal TSIA = ZERO;\n   212→      BigDecimal openTSIA = ZERO;\n   213→      double volume = 0.0;\n   214→\n   215→      if ((topGainersData.size() > 0) || (topLosersData.size() > 0)) {\n   216→\n   217→        stmt = getStatement(conn, getTSIASQL);\n   218→        rs = stmt.executeQuery();\n   219→\n   220→        if (!rs.next()) {\n   221→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIASQL -- no results\");\n   222→        } else {\n   223→          TSIA = rs.getBigDecimal(\"TSIA\");\n   224→        }\n   225→        stmt.close();\n   226→\n   227→        stmt = getStatement(conn, getOpenTSIASQL);\n   228→        rs = stmt.executeQuery();\n   229→\n   230→        if (!rs.next()) {\n   231→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getOpenTSIASQL -- no results\");\n   232→        } else {\n   233→          openTSIA = rs.getBigDecimal(\"openTSIA\");\n   234→        }\n   235→        stmt.close();\n   236→\n   237→        stmt = getStatement(conn, getTSIATotalVolumeSQL);\n   238→        rs = stmt.executeQuery();\n   239→\n   240→        if (!rs.next()) {\n   241→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIATotalVolumeSQL -- no results\");\n   242→        } else {\n   243→          volume = rs.getDouble(\"totalVolume\");\n   244→        }\n   245→        stmt.close();\n   246→      }\n   247→      commit(conn);\n   248→\n   249→      marketSummaryData = new MarketSummaryDataBean(TSIA, openTSIA, volume, topGainersData, topLosersData);\n   250→      publisher.publishEvent(new MarketSummaryUpdateEvent(\"MarketSummaryUpdate\"));\n   251→    }\n   252→\n   253→    catch (Exception e) {\n   254→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n   255→      rollBack(conn, e);\n   256→    } finally {\n   257→      releaseConn(conn);\n   258→    }\n   259→    return marketSummaryData;\n   260→\n   261→  }\n   262→\n   263→  /**\n   264→   * @see TradeServices#buy(String, String, double)\n   265→   */\n   266→  @Override\n   267→  @NotNull\n   268→  public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) throws Exception {\n   269→\n   270→    final Connection conn = getConn();\n   271→    OrderDataBean orderData = null;\n   272→\n   273→    BigDecimal total;\n   274→\n   275→    try {\n   276→\n   277→      Log.trace(\"TradeDirect:buy - inSession(\" + this.inSession + \")\");// , userID, symbol, new Double(quantity));\n   278→\n   279→  if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE && txn != null) {\n   280→\n   281→        Log.trace(\"TradeDirect:buy create/begin global transaction\");\n   282→\n   283→        txn.begin();\n   284→        setInGlobalTxn(true);\n   285→      }\n   286→\n   287→      // conn = getConn();\n   288→\n   289→      AccountDataBean accountData = getAccountData(conn, userID);\n   290→      QuoteDataBean quoteData = getQuoteData(conn, symbol);\n   291→      HoldingDataBean holdingData = null; // the buy operation will create\n   292→      // the holding\n   293→\n   294→      orderData = createOrder(accountData, quoteData, holdingData, \"buy\", quantity);\n   295→\n   296→      // Update -- account should be credited during completeOrder\n   297→      BigDecimal price = quoteData.getPrice();\n   298→      BigDecimal orderFee = orderData.getOrderFee();\n   299→      total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   300→      // subtract total from account balance\n   301→      creditAccountBalance(conn, accountData, total.negate());\n   302→      final Integer orderID = orderData.getOrderID();\n   303→\n   304→      try {\n   305→\n   306→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   307→          completeOrder(conn, orderData.getOrderID());\n   308→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   309→          completeOrderAsync(orderID, true);\n   310→        } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   311→          queueOrder(orderID, true); // 2-phase\n   312→        }\n   313→      } catch (JMSException je) {\n   314→        Log.error(\"TradeBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed to queueOrder\", je);\n   315→\n   316→        cancelOrder(conn, orderData.getOrderID());\n   317→      }\n   318→\n   319→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   320→\n   321→      if (getInGlobalTxn()) {\n   322→\n   323→        Log.trace(\"TradeDirect:buy committing global transaction\");\n   324→\n   325→        if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE && txn != null) {\n   326→          txn.commit();\n   327→          setInGlobalTxn(false);\n   328→        }\n   329→      } else {\n   330→        commit(conn);\n   331→      }\n   332→    } catch (Exception e) {\n   333→      Log.error(\"TradeDirect:buy error - rolling back\", e);\n   334→      if (getInGlobalTxn()) {\n   335→        if (txn != null) txn.rollback();\n   336→      } else {\n   337→        rollBack(conn, e);\n   338→      }\n   339→    } finally {\n   340→      releaseConn(conn);\n   341→    }\n   342→\n   343→    return orderData;\n   344→  }\n   345→\n   346→  /**\n   347→   * @see TradeServices#sell(String, Integer)\n   348→   */\n   349→  @Override\n   350→  @NotNull\n   351→  public OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception {\n   352→    Connection conn = null;\n   353→    OrderDataBean orderData = null;\n   354→    // UserTransaction txn = null;\n   355→\n   356→    /*\n   357→     * total = (quantity * purchasePrice) + orderFee\n   358→     */\n   359→    BigDecimal total;\n   360→\n   361→    try {\n   362→\n   363→      Log.trace(\"TradeDirect:sell - inSession(\" + this.inSession + \")\", userID, holdingID);\n   364→\n   365→  if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE && txn != null) {\n   366→\n   367→        Log.trace(\"TradeDirect:sell create/begin global transaction\");\n   368→\n   369→        txn.begin();\n   370→        setInGlobalTxn(true);\n   371→      }\n   372→\n   373→      conn = getConn();\n   374→\n   375→      AccountDataBean accountData = getAccountData(conn, userID);\n   376→      HoldingDataBean holdingData = getHoldingData(conn, holdingID.intValue());\n   377→      QuoteDataBean quoteData = null;\n   378→      if (holdingData != null) {\n   379→        quoteData = getQuoteData(conn, holdingData.getQuoteID());\n   380→      }\n   381→\n   382→      if ((accountData == null) || (holdingData == null) || (quoteData == null)) {\n   383→        String error = \"TradeDirect:sell -- error selling stock -- unable to find:  \\n\\taccount=\" + accountData\n   384→            + \"\\n\\tholding=\" + holdingData\n   385→            + \"\\n\\tquote=\" + quoteData + \"\\nfor user: \" + userID + \" and holdingID: \" + holdingID;\n   386→        Log.debug(error);\n   387→        if (getInGlobalTxn()) {\n   388→          if (txn != null) txn.rollback();\n   389→        } else {\n   390→          rollBack(conn, new Exception(error));\n   391→        }\n   392→        orderData = new OrderDataBean();\n   393→        orderData.setOrderStatus(\"cancelled\");\n   394→        return orderData;\n   395→      }\n   396→\n   397→      double quantity = holdingData.getQuantity();\n   398→\n   399→      orderData = createOrder(accountData, quoteData, holdingData, \"sell\", quantity);\n   400→\n   401→      // Set the holdingSymbol purchaseDate to selling to signify the sell\n   402→      // is \"inflight\"\n   403→      updateHoldingStatus(conn, holdingData.getHoldingID(), holdingData.getQuoteID());\n   404→\n   405→      // UPDATE -- account should be credited during completeOrder\n   406→      BigDecimal price = quoteData.getPrice();\n   407→      BigDecimal orderFee = orderData.getOrderFee();\n   408→      total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   409→      creditAccountBalance(conn, accountData, total);\n   410→\n   411→      try {\n   412→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   413→          completeOrder(conn, orderData.getOrderID());\n   414→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   415→          this.completeOrderAsync(orderData.getOrderID(), true);\n   416→        } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   417→          queueOrder(orderData.getOrderID(), true);\n   418→        }\n   419→      } catch (JMSException je) {\n   420→        Log.error(\"TradeBean:sell(\" + userID + \",\" + holdingID + \") --> failed to queueOrder\", je);\n   421→\n   422→        cancelOrder(conn, orderData.getOrderID());\n   423→      }\n   424→\n   425→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   426→\n   427→  if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE && txn != null) {\n   428→\n   429→        Log.trace(\"TradeDirect:sell committing global transaction\");\n   430→\n   431→        txn.commit();\n   432→        setInGlobalTxn(false);\n   433→      } else {\n   434→        commit(conn);\n   435→      }\n   436→    } catch (Exception e) {\n   437→      Log.error(\"TradeDirect:sell error\", e);\n   438→      if (getInGlobalTxn()) {\n   439→        if (txn != null) txn.rollback();\n   440→      } else {\n   441→        rollBack(conn, e);\n   442→      }\n   443→    } finally {\n   444→      releaseConn(conn);\n   445→    }\n   446→\n   447→    return orderData;\n   448→  }\n   449→\n   450→  /**\n   451→   * @see TradeServices#queueOrder(Integer)\n   452→   */\n   453→  @Override\n   454→  public void queueOrder(Integer orderID, boolean twoPhase) throws Exception {\n   455→\n   456→    Log.trace(\"TradeDirect:queueOrder - inSession(\" + this.inSession + \")\", orderID);\n   457→    JmsTemplate t = new JmsTemplate();\n   458→\n   459→    t.send(\"TradeBrokerQueue\", context -> {\n   460→      TextMessage message = context.createTextMessage();\n   461→\n   462→      message.setStringProperty(\"command\", \"neworder\");\n   463→      message.setIntProperty(\"orderID\", orderID);\n   464→      message.setBooleanProperty(\"twoPhase\", twoPhase);\n   465→      message.setBooleanProperty(\"direct\", true);\n   466→      message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   467→      message.setText(\"neworder: orderID=\" + orderID + \" runtimeMode=Direct twoPhase=\" + twoPhase);\n   468→      return message;\n   469→    });\n   470→  }\n   471→\n   472→  /**\n   473→   * @see TradeServices#completeOrder(Integer)\n   474→   */\n   475→  @Override\n   476→  public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   477→    OrderDataBean orderData = null;\n   478→    Connection conn = null;\n   479→\n   480→    try { // twoPhase\n   481→\n   482→      Log.trace(\"TradeDirect:completeOrder - inSession(\" + this.inSession + \")\", orderID);\n   483→\n   484→      setInGlobalTxn(!inSession && twoPhase);\n   485→      conn = getConn();\n   486→\n   487→      orderData = completeOrder(conn, orderID);\n   488→\n   489→      commit(conn);\n   490→\n   491→    } catch (Exception e) {\n   492→      Log.error(\"TradeDirect:completeOrder -- error completing order\", e);\n   493→      rollBack(conn, e);\n   494→      cancelOrder(orderID, twoPhase);\n   495→    } finally {\n   496→      releaseConn(conn);\n   497→    }\n   498→\n   499→    return orderData;\n   500→\n   501→  }\n   502→\n   503→  @Override\n   504→  public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   505→    if (!inSession) {\n   506→      asyncOrderSubmitter.submitOrder(orderID, twoPhase);\n   507→    }\n   508→    return null;\n   509→  }\n   510→\n   511→  private OrderDataBean completeOrder(Connection conn, Integer orderID) throws Exception {\n   512→    // conn = getConn();\n   513→    OrderDataBean orderData = null;\n   514→\n   515→    Log.trace(\"TradeDirect:completeOrderInternal - inSession(\" + this.inSession + \")\", orderID);\n   516→\n   517→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n   518→    stmt.setInt(1, orderID.intValue());\n   519→\n   520→    ResultSet rs = stmt.executeQuery();\n   521→\n   522→    if (!rs.next()) {\n   523→      Log.error(\"TradeDirect:completeOrder -- unable to find order: \" + orderID);\n   524→      stmt.close();\n   525→      return orderData;\n   526→    }\n   527→    orderData = getOrderDataFromResultSet(rs);\n   528→\n   529→    String orderType = orderData.getOrderType();\n   530→    String orderStatus = orderData.getOrderStatus();\n   531→\n   532→    // if (order.isCompleted())\n   533→    if ((orderStatus.compareToIgnoreCase(\"completed\") == 0) || (orderStatus.compareToIgnoreCase(\"alertcompleted\") == 0)\n   534→        || (orderStatus.compareToIgnoreCase(\"cancelled\") == 0)) {\n   535→      throw new Exception(\"TradeDirect:completeOrder -- attempt to complete Order that is already completed\");\n   536→    }\n   537→\n   538→    int accountID = rs.getInt(\"account_accountID\");\n   539→    String quoteID = rs.getString(\"quote_symbol\");\n   540→    int holdingID = rs.getInt(\"holding_holdingID\");\n   541→\n   542→    BigDecimal price = orderData.getPrice();\n   543→    double quantity = orderData.getQuantity();\n   544→\n   545→    // get the data for the account and quote\n   546→    // the holding will be created for a buy or extracted for a sell\n   547→\n   548→    /*\n   549→     * Use the AccountID and Quote Symbol from the Order AccountDataBean\n   550→     * accountData = getAccountData(accountID, conn); QuoteDataBean\n   551→     * quoteData = getQuoteData(conn, quoteID);\n   552→     */\n   553→  String userID = getAccountProfileData(conn, Integer.valueOf(accountID)).getUserID();\n   554→\n   555→    HoldingDataBean holdingData = null;\n   556→\n   557→    Log.trace(\"TradeDirect:completeOrder--> Completing Order \" + orderData.getOrderID() + \"\\n\\t Order info: \"\n   558→        + orderData + \"\\n\\t Account info: \"\n   559→        + accountID + \"\\n\\t Quote info: \" + quoteID);\n   560→\n   561→    // if (order.isBuy())\n   562→    if (orderType.compareToIgnoreCase(\"buy\") == 0) {\n   563→      /*\n   564→       * Complete a Buy operation - create a new Holding for the Account -\n   565→       * deduct the Order cost from the Account balance\n   566→       */\n   567→\n   568→      holdingData = createHolding(conn, accountID, quoteID, quantity, price);\n   569→      updateOrderHolding(conn, orderID.intValue(), holdingData.getHoldingID().intValue());\n   570→      updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   571→      updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), orderData.getQuantity());\n   572→    }\n   573→\n   574→    // if (order.isSell()) {\n   575→    if (orderType.compareToIgnoreCase(\"sell\") == 0) {\n   576→      /*\n   577→       * Complete a Sell operation - remove the Holding from the Account -\n   578→       * deposit the Order proceeds to the Account balance\n   579→       */\n   580→      holdingData = getHoldingData(conn, holdingID);\n   581→      if (holdingData == null) {\n   582→        Log.debug(\"TradeDirect:completeOrder:sell -- user: \" + userID + \" already sold holding: \" + holdingID);\n   583→        updateOrderStatus(conn, orderData.getOrderID(), \"cancelled\");\n   584→      } else {\n   585→        removeHolding(conn, holdingID, orderID.intValue());\n   586→        updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   587→        updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(),\n   588→            orderData.getQuantity());\n   589→      }\n   590→\n   591→    }\n   592→\n   593→    Log.trace(\"TradeDirect:completeOrder--> Completed Order \" + orderData.getOrderID() + \"\\n\\t Order info: \" + orderData\n   594→        + \"\\n\\t Account info: \"\n   595→        + accountID + \"\\n\\t Quote info: \" + quoteID + \"\\n\\t Holding info: \" + holdingData);\n   596→\n   597→    stmt.close();\n   598→\n   599→    commit(conn);\n   600→\n   601→    return orderData;\n   602→  }\n   603→\n   604→  /**\n   605→   * @see TradeServices#cancelOrder(Integer, boolean)\n   606→   */\n   607→  @Override\n   608→  public void cancelOrder(Integer orderID, boolean twoPhase) throws Exception {\n   609→\n   610→    Connection conn = null;\n   611→    try {\n   612→\n   613→      Log.trace(\"TradeDirect:cancelOrder - inSession(\" + this.inSession + \")\", orderID);\n   614→\n   615→      setInGlobalTxn(!inSession && twoPhase);\n   616→      conn = getConn();\n   617→      cancelOrder(conn, orderID);\n   618→      commit(conn);\n   619→\n   620→    } catch (Exception e) {\n   621→      Log.error(\"TradeDirect:cancelOrder -- error cancelling order: \" + orderID, e);\n   622→      rollBack(conn, e);\n   623→    } finally {\n   624→      releaseConn(conn);\n   625→    }\n   626→  }\n   627→\n   628→  private void cancelOrder(Connection conn, Integer orderID) throws Exception {\n   629→    updateOrderStatus(conn, orderID, \"cancelled\");\n   630→  }\n   631→\n   632→  @Override\n   633→  public void orderCompleted(String userID, Integer orderID) throws Exception {\n   634→    throw new UnsupportedOperationException(\"TradeDirect:orderCompleted method not supported\");\n   635→  }\n   636→\n   637→  private HoldingDataBean createHolding(Connection conn, int accountID, String symbol, double quantity,\n   638→      BigDecimal purchasePrice) throws Exception {\n   639→\n   640→    Timestamp purchaseDate = new Timestamp(System.currentTimeMillis());\n   641→    PreparedStatement stmt = getStatement(conn, createHoldingSQL);\n   642→\n   643→    Integer holdingID = KeySequenceDirect.getNextID(conn, \"holding\", inSession, getInGlobalTxn());\n   644→    stmt.setInt(1, holdingID.intValue());\n   645→    stmt.setTimestamp(2, purchaseDate);\n   646→    stmt.setBigDecimal(3, purchasePrice);\n   647→    stmt.setDouble(4, quantity);\n   648→    stmt.setString(5, symbol);\n   649→    stmt.setInt(6, accountID);\n   650→    stmt.executeUpdate();\n   651→\n   652→    stmt.close();\n   653→\n   654→    return getHoldingData(conn, holdingID.intValue());\n   655→  }\n   656→\n   657→  private void removeHolding(Connection conn, int holdingID, int orderID) throws Exception {\n   658→    PreparedStatement stmt = getStatement(conn, removeHoldingSQL);\n   659→\n   660→    stmt.setInt(1, holdingID);\n   661→    stmt.executeUpdate();\n   662→    stmt.close();\n   663→\n   664→    // set the HoldingID to NULL for the purchase and sell order now that\n   665→    // the holding as been removed\n   666→    stmt = getStatement(conn, removeHoldingFromOrderSQL);\n   667→\n   668→    stmt.setInt(1, holdingID);\n   669→    stmt.executeUpdate();\n   670→    stmt.close();\n   671→\n   672→  }\n   673→\n   674→  public OrderDataBean createOrder(AccountDataBean accountData, QuoteDataBean quoteData, HoldingDataBean holdingData,\n   675→      String orderType,\n   676→      double quantity) throws Exception {\n   677→    OrderDataBean orderData = null;\n   678→    Connection conn = null;\n   679→    try {\n   680→\n   681→      conn = getConn();\n   682→      Timestamp currentDate = new Timestamp(System.currentTimeMillis());\n   683→\n   684→      PreparedStatement stmt = getStatement(conn, createOrderSQL);\n   685→\n   686→      Integer orderID = KeySequenceDirect.getNextID(conn, \"order\", inSession, getInGlobalTxn());\n   687→      stmt.setInt(1, orderID.intValue());\n   688→      stmt.setString(2, orderType);\n   689→      stmt.setString(3, \"open\");\n   690→      stmt.setTimestamp(4, currentDate);\n   691→      stmt.setDouble(5, quantity);\n   692→  stmt.setBigDecimal(6, quoteData.getPrice().setScale(FinancialUtils.SCALE, java.math.RoundingMode.HALF_UP));\n   693→      stmt.setBigDecimal(7, TradeConfig.getOrderFee(orderType));\n   694→      stmt.setInt(8, accountData.getAccountID().intValue());\n   695→      if (holdingData == null) {\n   696→        stmt.setNull(9, java.sql.Types.INTEGER);\n   697→      } else {\n   698→        stmt.setInt(9, holdingData.getHoldingID().intValue());\n   699→      }\n   700→      stmt.setString(10, quoteData.getSymbol());\n   701→      stmt.executeUpdate();\n   702→\n   703→      orderData = getOrderData(conn, orderID.intValue());\n   704→\n   705→      stmt.close();\n   706→\n   707→      commit(conn);\n   708→    } catch (Exception e) {\n   709→      Log.error(\"TradeDirect:createOrder -- error getting user orders\", e);\n   710→      rollBack(conn, e);\n   711→    } finally {\n   712→      releaseConn(conn);\n   713→    }\n   714→\n   715→    return orderData;\n   716→  }\n   717→\n   718→  /**\n   719→   * @see TradeServices#getOrders(String)\n   720→   */\n   721→  @Override\n   722→  public Collection<OrderDataBean> getOrders(String userID) throws Exception {\n   723→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   724→    Connection conn = null;\n   725→    try {\n   726→      Log.trace(\"TradeDirect:getOrders - inSession(\" + this.inSession + \")\", userID);\n   727→\n   728→      conn = getConn();\n   729→      PreparedStatement stmt = getStatement(conn, getOrdersByUserSQL);\n   730→      stmt.setString(1, userID);\n   731→\n   732→      ResultSet rs = stmt.executeQuery();\n   733→\n   734→      // TODO: return top 5 orders for now -- next version will add a\n   735→      // getAllOrders method\n   736→      // also need to get orders sorted by order id descending\n   737→      int i = 0;\n   738→      while ((rs.next()) && (i++ < 5)) {\n   739→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   740→        orderDataBeans.add(orderData);\n   741→      }\n   742→\n   743→      stmt.close();\n   744→      commit(conn);\n   745→\n   746→    } catch (Exception e) {\n   747→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   748→      rollBack(conn, e);\n   749→    } finally {\n   750→      releaseConn(conn);\n   751→    }\n   752→    return orderDataBeans;\n   753→  }\n   754→\n   755→  /**\n   756→   * @see TradeServices#getClosedOrders(String)\n   757→   */\n   758→  @Override\n   759→  public Collection<OrderDataBean> getClosedOrders(String userID) throws Exception {\n   760→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   761→    Connection conn = null;\n   762→    try {\n   763→\n   764→      Log.trace(\"TradeDirect:getClosedOrders - inSession(\" + this.inSession + \")\", userID);\n   765→\n   766→      conn = getConn();\n   767→      PreparedStatement stmt = getStatement(conn, getClosedOrdersSQL);\n   768→      stmt.setString(1, userID);\n   769→\n   770→      ResultSet rs = stmt.executeQuery();\n   771→\n   772→      while (rs.next()) {\n   773→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   774→        orderData.setOrderStatus(\"completed\");\n   775→        updateOrderStatus(conn, orderData.getOrderID(), orderData.getOrderStatus());\n   776→        orderDataBeans.add(orderData);\n   777→\n   778→      }\n   779→\n   780→      stmt.close();\n   781→      commit(conn);\n   782→    } catch (Exception e) {\n   783→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   784→      rollBack(conn, e);\n   785→    } finally {\n   786→      releaseConn(conn);\n   787→    }\n   788→    return orderDataBeans;\n   789→  }\n   790→\n   791→  /**\n   792→   * @see TradeServices#createQuote(String, String, BigDecimal)\n   793→   */\n   794→  @Override\n   795→  public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception {\n   796→\n   797→    QuoteDataBean quoteData = null;\n   798→    Connection conn = null;\n   799→    try {\n   800→\n   801→      Log.trace(\"TradeDirect:createQuote - inSession(\" + this.inSession + \")\");\n   802→\n   803→  price = price.setScale(FinancialUtils.SCALE, java.math.RoundingMode.HALF_UP);\n   804→      double volume = 0.0, change = 0.0;\n   805→\n   806→      conn = getConn();\n   807→      PreparedStatement stmt = getStatement(conn, createQuoteSQL);\n   808→      stmt.setString(1, symbol); // symbol\n   809→      stmt.setString(2, companyName); // companyName\n   810→      stmt.setDouble(3, volume); // volume\n   811→      stmt.setBigDecimal(4, price); // price\n   812→      stmt.setBigDecimal(5, price); // open\n   813→      stmt.setBigDecimal(6, price); // low\n   814→      stmt.setBigDecimal(7, price); // high\n   815→      stmt.setDouble(8, change); // change\n   816→\n   817→      stmt.executeUpdate();\n   818→      stmt.close();\n   819→      commit(conn);\n   820→\n   821→      quoteData = new QuoteDataBean(symbol, companyName, volume, price, price, price, price, change);\n   822→    } catch (Exception e) {\n   823→      Log.error(\"TradeDirect:createQuote -- error creating quote\", e);\n   824→    } finally {\n   825→      releaseConn(conn);\n   826→    }\n   827→    return quoteData;\n   828→  }\n   829→\n   830→  /**\n   831→   * @see TradeServices#getQuote(String)\n   832→   */\n   833→\n   834→  @Override\n   835→  public QuoteDataBean getQuote(String symbol) throws Exception {\n   836→    QuoteDataBean quoteData = null;\n   837→    Connection conn = null;\n   838→\n   839→    try {\n   840→\n   841→      Log.trace(\"TradeDirect:getQuote - inSession(\" + this.inSession + \")\", symbol);\n   842→\n   843→      conn = getConn();\n   844→      quoteData = getQuote(conn, symbol);\n   845→      commit(conn);\n   846→    } catch (Exception e) {\n   847→      Log.error(\"TradeDirect:getQuote -- error getting quote\", e);\n   848→      rollBack(conn, e);\n   849→    } finally {\n   850→      releaseConn(conn);\n   851→    }\n   852→    return quoteData;\n   853→  }\n   854→\n   855→  private QuoteDataBean getQuote(Connection conn, String symbol) throws Exception {\n   856→    QuoteDataBean quoteData = null;\n   857→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n   858→    stmt.setString(1, symbol); // symbol\n   859→\n   860→    ResultSet rs = stmt.executeQuery();\n   861→\n   862→    if (!rs.next()) {\n   863→      Log.error(\"TradeDirect:getQuote -- failure no result.next() for symbol: \" + symbol);\n   864→    } else {\n   865→      quoteData = getQuoteDataFromResultSet(rs);\n   866→    }\n   867→\n   868→    stmt.close();\n   869→\n   870→    return quoteData;\n   871→  }\n   872→\n   873→  private QuoteDataBean getQuoteForUpdate(Connection conn, String symbol) throws Exception {\n   874→    QuoteDataBean quoteData = null;\n   875→    PreparedStatement stmt = getStatement(conn, getQuoteForUpdateSQL);\n   876→    stmt.setString(1, symbol); // symbol\n   877→\n   878→    ResultSet rs = stmt.executeQuery();\n   879→\n   880→    if (!rs.next()) {\n   881→      Log.error(\"TradeDirect:getQuote -- failure no result.next()\");\n   882→    } else {\n   883→      quoteData = getQuoteDataFromResultSet(rs);\n   884→    }\n   885→\n   886→    stmt.close();\n   887→\n   888→    return quoteData;\n   889→  }\n   890→\n   891→  /**\n   892→   * @see TradeServices#getAllQuotes(String)\n   893→   */\n   894→  @Override\n   895→  public Collection<QuoteDataBean> getAllQuotes() throws Exception {\n   896→    Collection<QuoteDataBean> quotes = new ArrayList<QuoteDataBean>();\n   897→    QuoteDataBean quoteData = null;\n   898→\n   899→    Connection conn = null;\n   900→    try {\n   901→      conn = getConn();\n   902→\n   903→      PreparedStatement stmt = getStatement(conn, getAllQuotesSQL);\n   904→\n   905→      ResultSet rs = stmt.executeQuery();\n   906→\n   907→      while (!rs.next()) {\n   908→        quoteData = getQuoteDataFromResultSet(rs);\n   909→        quotes.add(quoteData);\n   910→      }\n   911→\n   912→      stmt.close();\n   913→    } catch (Exception e) {\n   914→      Log.error(\"TradeDirect:getAllQuotes\", e);\n   915→      rollBack(conn, e);\n   916→    } finally {\n   917→      releaseConn(conn);\n   918→    }\n   919→\n   920→    return quotes;\n   921→  }\n   922→\n   923→  /**\n   924→   * @see TradeServices#getHoldings(String)\n   925→   */\n   926→  @Override\n   927→  public Collection<HoldingDataBean> getHoldings(String userID) throws Exception {\n   928→    Collection<HoldingDataBean> holdingDataBeans = new ArrayList<HoldingDataBean>();\n   929→    Connection conn = null;\n   930→    try {\n   931→\n   932→      Log.trace(\"TradeDirect:getHoldings - inSession(\" + this.inSession + \")\", userID);\n   933→\n   934→      conn = getConn();\n   935→      PreparedStatement stmt = getStatement(conn, getHoldingsForUserSQL);\n   936→      stmt.setString(1, userID);\n   937→\n   938→      ResultSet rs = stmt.executeQuery();\n   939→\n   940→      while (rs.next()) {\n   941→        HoldingDataBean holdingData = getHoldingDataFromResultSet(rs);\n   942→        holdingDataBeans.add(holdingData);\n   943→      }\n   944→\n   945→      stmt.close();\n   946→      commit(conn);\n   947→\n   948→    } catch (Exception e) {\n   949→      Log.error(\"TradeDirect:getHoldings -- error getting user holings\", e);\n   950→      rollBack(conn, e);\n   951→    } finally {\n   952→      releaseConn(conn);\n   953→    }\n   954→    return holdingDataBeans;\n   955→  }\n   956→\n   957→  /**\n   958→   * @see TradeServices#getHolding(Integer)\n   959→   */\n   960→  @Override\n   961→  public HoldingDataBean getHolding(Integer holdingID) throws Exception {\n   962→    HoldingDataBean holdingData = null;\n   963→    Connection conn = null;\n   964→    try {\n   965→\n   966→      Log.trace(\"TradeDirect:getHolding - inSession(\" + this.inSession + \")\", holdingID);\n   967→\n   968→      conn = getConn();\n   969→      holdingData = getHoldingData(holdingID.intValue());\n   970→\n   971→      commit(conn);\n   972→\n   973→    } catch (Exception e) {\n   974→      Log.error(\"TradeDirect:getHolding -- error getting holding \" + holdingID + \"\", e);\n   975→      rollBack(conn, e);\n   976→    } finally {\n   977→      releaseConn(conn);\n   978→    }\n   979→    return holdingData;\n   980→  }\n   981→\n   982→  /**\n   983→   * @see TradeServices#getAccountData(String)\n   984→   */\n   985→  @Override\n   986→  public AccountDataBean getAccountData(String userID) throws Exception {\n   987→    try {\n   988→      AccountDataBean accountData = null;\n   989→      Connection conn = null;\n   990→      try {\n   991→\n   992→        Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", userID);\n   993→\n   994→        conn = getConn();\n   995→        accountData = getAccountData(conn, userID);\n   996→        commit(conn);\n   997→\n   998→      } catch (Exception e) {\n   999→        Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1000→        rollBack(conn, e);\n  1001→      } finally {\n  1002→        releaseConn(conn);\n  1003→      }\n  1004→      return accountData;\n  1005→    } catch (Exception e) {\n  1006→      throw new Exception(e.getMessage(), e);\n  1007→    }\n  1008→  }\n  1009→\n  1010→  private AccountDataBean getAccountData(Connection conn, String userID) throws Exception {\n  1011→    PreparedStatement stmt = getStatement(conn, getAccountForUserSQL);\n  1012→    stmt.setString(1, userID);\n  1013→    ResultSet rs = stmt.executeQuery();\n  1014→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1015→    stmt.close();\n  1016→    return accountData;\n  1017→  }\n  1018→\n  1019→  /**\n  1020→   * @see TradeServices#getAccountData(String)\n  1021→   */\n  1022→  public AccountDataBean getAccountData(int accountID) throws Exception {\n  1023→    AccountDataBean accountData = null;\n  1024→    Connection conn = null;\n  1025→    try {\n  1026→\n  1027→  Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", Integer.valueOf(accountID));\n  1028→\n  1029→      conn = getConn();\n  1030→      accountData = getAccountData(accountID, conn);\n  1031→      commit(conn);\n  1032→\n  1033→    } catch (Exception e) {\n  1034→      Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1035→      rollBack(conn, e);\n  1036→    } finally {\n  1037→      releaseConn(conn);\n  1038→    }\n  1039→    return accountData;\n  1040→  }\n  1041→\n  1042→  private AccountDataBean getAccountData(int accountID, Connection conn) throws Exception {\n  1043→    PreparedStatement stmt = getStatement(conn, getAccountSQL);\n  1044→    stmt.setInt(1, accountID);\n  1045→    ResultSet rs = stmt.executeQuery();\n  1046→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1047→    stmt.close();\n  1048→    return accountData;\n  1049→  }\n  1050→\n  1051→  private QuoteDataBean getQuoteData(Connection conn, String symbol) throws Exception {\n  1052→    QuoteDataBean quoteData = null;\n  1053→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n  1054→    stmt.setString(1, symbol);\n  1055→    ResultSet rs = stmt.executeQuery();\n  1056→    if (!rs.next()) {\n  1057→      Log.error(\"TradeDirect:getQuoteData -- could not find quote for symbol=\" + symbol);\n  1058→    } else {\n  1059→      quoteData = getQuoteDataFromResultSet(rs);\n  1060→    }\n  1061→    stmt.close();\n  1062→    return quoteData;\n  1063→  }\n  1064→\n  1065→  private HoldingDataBean getHoldingData(int holdingID) throws Exception {\n  1066→    HoldingDataBean holdingData = null;\n  1067→    Connection conn = null;\n  1068→    try {\n  1069→      conn = getConn();\n  1070→      holdingData = getHoldingData(conn, holdingID);\n  1071→      commit(conn);\n  1072→    } catch (Exception e) {\n  1073→      Log.error(\"TradeDirect:getHoldingData -- error getting data\", e);\n  1074→      rollBack(conn, e);\n  1075→    } finally {\n  1076→      releaseConn(conn);\n  1077→    }\n  1078→    return holdingData;\n  1079→  }\n  1080→\n  1081→  private HoldingDataBean getHoldingData(Connection conn, int holdingID) throws Exception {\n  1082→    HoldingDataBean holdingData = null;\n  1083→    PreparedStatement stmt = getStatement(conn, getHoldingSQL);\n  1084→    stmt.setInt(1, holdingID);\n  1085→    ResultSet rs = stmt.executeQuery();\n  1086→    if (!rs.next()) {\n  1087→      // already sold\n  1088→      Log.debug(\"TradeDirect:getHoldingData -- no results -- holdingID=\" + holdingID);\n  1089→    } else {\n  1090→      holdingData = getHoldingDataFromResultSet(rs);\n  1091→    }\n  1092→\n  1093→    stmt.close();\n  1094→    return holdingData;\n  1095→  }\n  1096→\n  1097→  private OrderDataBean getOrderData(Connection conn, int orderID) throws Exception {\n  1098→    OrderDataBean orderData = null;\n  1099→\n  1100→    Log.trace(\"TradeDirect:getOrderData(conn, \" + orderID + \")\");\n  1101→\n  1102→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n  1103→    stmt.setInt(1, orderID);\n  1104→    ResultSet rs = stmt.executeQuery();\n  1105→    if (!rs.next()) {\n  1106→      // already sold\n  1107→      Log.error(\"TradeDirect:getOrderData -- no results for orderID:\" + orderID);\n  1108→    } else {\n  1109→      orderData = getOrderDataFromResultSet(rs);\n  1110→    }\n  1111→    stmt.close();\n  1112→    return orderData;\n  1113→  }\n  1114→\n  1115→  /**\n  1116→   * @see TradeServices#getAccountProfileData(String)\n  1117→   */\n  1118→  @Override\n  1119→  public AccountProfileDataBean getAccountProfileData(String userID) throws Exception {\n  1120→    AccountProfileDataBean accountProfileData = null;\n  1121→    Connection conn = null;\n  1122→\n  1123→    try {\n  1124→\n  1125→      Log.trace(\"TradeDirect:getAccountProfileData - inSession(\" + this.inSession + \")\", userID);\n  1126→\n  1127→      conn = getConn();\n  1128→      accountProfileData = getAccountProfileData(conn, userID);\n  1129→      commit(conn);\n  1130→    } catch (Exception e) {\n  1131→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1132→      rollBack(conn, e);\n  1133→    } finally {\n  1134→      releaseConn(conn);\n  1135→    }\n  1136→    return accountProfileData;\n  1137→  }\n  1138→\n  1139→  private AccountProfileDataBean getAccountProfileData(Connection conn, String userID) throws Exception {\n  1140→    PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1141→    stmt.setString(1, userID);\n  1142→\n  1143→    ResultSet rs = stmt.executeQuery();\n  1144→\n  1145→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1146→    stmt.close();\n  1147→    return accountProfileData;\n  1148→  }\n  1149→\n  1150→  private AccountProfileDataBean getAccountProfileData(Connection conn, Integer accountID) throws Exception {\n  1151→    PreparedStatement stmt = getStatement(conn, getAccountProfileForAccountSQL);\n  1152→    stmt.setInt(1, accountID.intValue());\n  1153→\n  1154→    ResultSet rs = stmt.executeQuery();\n  1155→\n  1156→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1157→    stmt.close();\n  1158→    return accountProfileData;\n  1159→  }\n  1160→\n  1161→  /**\n  1162→   * @see TradeServices#updateAccountProfile(AccountProfileDataBean)\n  1163→   */\n  1164→  @Override\n  1165→  public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception {\n  1166→    AccountProfileDataBean accountProfileData = null;\n  1167→    Connection conn = null;\n  1168→\n  1169→    try {\n  1170→\n  1171→      Log.trace(\"TradeDirect:updateAccountProfileData - inSession(\" + this.inSession + \")\", profileData.getUserID());\n  1172→\n  1173→      conn = getConn();\n  1174→      updateAccountProfile(conn, profileData);\n  1175→\n  1176→      accountProfileData = getAccountProfileData(conn, profileData.getUserID());\n  1177→      commit(conn);\n  1178→    } catch (Exception e) {\n  1179→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1180→      rollBack(conn, e);\n  1181→    } finally {\n  1182→      releaseConn(conn);\n  1183→    }\n  1184→    return accountProfileData;\n  1185→  }\n  1186→\n  1187→  private void creditAccountBalance(Connection conn, AccountDataBean accountData, BigDecimal credit) throws Exception {\n  1188→    PreparedStatement stmt = getStatement(conn, creditAccountBalanceSQL);\n  1189→\n  1190→    stmt.setBigDecimal(1, credit);\n  1191→    stmt.setInt(2, accountData.getAccountID().intValue());\n  1192→\n  1193→    stmt.executeUpdate();\n  1194→    stmt.close();\n  1195→\n  1196→  }\n  1197→\n  1198→  // Set Timestamp to zero to denote sell is inflight\n  1199→  // UPDATE -- could add a \"status\" attribute to holding\n  1200→  private void updateHoldingStatus(Connection conn, Integer holdingID, String symbol) throws Exception {\n  1201→    Timestamp ts = new Timestamp(0);\n  1202→    PreparedStatement stmt = getStatement(conn, \"update holdingejb set purchasedate= ? where holdingid = ?\");\n  1203→\n  1204→    stmt.setTimestamp(1, ts);\n  1205→    stmt.setInt(2, holdingID.intValue());\n  1206→    stmt.executeUpdate();\n  1207→    stmt.close();\n  1208→  }\n  1209→\n  1210→  private void updateOrderStatus(Connection conn, Integer orderID, String status) throws Exception {\n  1211→    PreparedStatement stmt = getStatement(conn, updateOrderStatusSQL);\n  1212→\n  1213→    stmt.setString(1, status);\n  1214→    stmt.setTimestamp(2, new Timestamp(System.currentTimeMillis()));\n  1215→    stmt.setInt(3, orderID.intValue());\n  1216→    stmt.executeUpdate();\n  1217→    stmt.close();\n  1218→  }\n  1219→\n  1220→  private void updateOrderHolding(Connection conn, int orderID, int holdingID) throws Exception {\n  1221→    PreparedStatement stmt = getStatement(conn, updateOrderHoldingSQL);\n  1222→\n  1223→    stmt.setInt(1, holdingID);\n  1224→    stmt.setInt(2, orderID);\n  1225→    stmt.executeUpdate();\n  1226→    stmt.close();\n  1227→  }\n  1228→\n  1229→  private void updateAccountProfile(Connection conn, AccountProfileDataBean profileData) throws Exception {\n  1230→    PreparedStatement stmt = getStatement(conn, updateAccountProfileSQL);\n  1231→\n  1232→    stmt.setString(1, profileData.getPassword());\n  1233→    stmt.setString(2, profileData.getFullName());\n  1234→    stmt.setString(3, profileData.getAddress());\n  1235→    stmt.setString(4, profileData.getEmail());\n  1236→    stmt.setString(5, profileData.getCreditCard());\n  1237→    stmt.setString(6, profileData.getUserID());\n  1238→\n  1239→    stmt.executeUpdate();\n  1240→    stmt.close();\n  1241→  }\n  1242→\n  1243→  @Override\n  1244→  public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded)\n  1245→      throws Exception {\n  1246→    return updateQuotePriceVolumeInt(symbol, changeFactor, sharesTraded, TradeConfig.getPublishQuotePriceChange());\n  1247→  }\n  1248→\n  1249→  /**\n  1250→   * Update a quote's price and volume\n  1251→   *\n  1252→   * @param symbol\n  1253→   *                                The PK of the quote\n  1254→   * @param changeFactor\n  1255→   *                                the percent to change the old price by\n  1256→   *                                (between 50% and 150%)\n  1257→   * @param sharedTraded\n  1258→   *                                the ammount to add to the current volume\n  1259→   * @param publishQuotePriceChange\n  1260→   *                                used by the PingJDBCWrite Primitive to ensure\n  1261→   *                                no JMS is used,\n  1262→   *                                should be true for all normal calls to this\n  1263→   *                                API\n  1264→   */\n  1265→  public QuoteDataBean updateQuotePriceVolumeInt(String symbol, BigDecimal changeFactor, double sharesTraded,\n  1266→      boolean publishQuotePriceChange)\n  1267→      throws Exception {\n  1268→\n  1269→    if (TradeConfig.getUpdateQuotePrices() == false) {\n  1270→      return new QuoteDataBean();\n  1271→    }\n  1272→\n  1273→    QuoteDataBean quoteData = null;\n  1274→    Connection conn = null;\n  1275→\n  1276→    try {\n  1277→      Log.trace(\"TradeDirect:updateQuotePriceVolume - inSession(\" + this.inSession + \")\", symbol, changeFactor,\n  1278→          Double.valueOf(sharesTraded));\n  1279→\n  1280→      conn = getConn();\n  1281→\n  1282→      quoteData = getQuoteForUpdate(conn, symbol);\n  1283→      BigDecimal oldPrice = quoteData.getPrice();\n  1284→      BigDecimal openPrice = quoteData.getOpen();\n  1285→\n  1286→      double newVolume = quoteData.getVolume() + sharesTraded;\n  1287→\n  1288→      if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n  1289→        changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n  1290→      } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n  1291→        changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n  1292→      }\n  1293→\n  1294→  BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, java.math.RoundingMode.HALF_UP);\n  1295→      double change = newPrice.subtract(openPrice).doubleValue();\n  1296→\n  1297→      updateQuotePriceVolume(conn, quoteData.getSymbol(), newPrice, newVolume, change);\n  1298→      quoteData = getQuote(conn, symbol);\n  1299→\n  1300→      commit(conn);\n  1301→\n  1302→      if (publishQuotePriceChange) {\n  1303→        publishQuotePriceChange(quoteData, oldPrice, changeFactor, sharesTraded);\n  1304→      }\n  1305→\n  1306→      recentQuotePriceChangeList.add(quoteData);\n  1307→\n  1308→    } catch (Exception e) {\n  1309→      Log.error(\"TradeDirect:updateQuotePriceVolume -- error updating quote price/volume for symbol:\" + symbol);\n  1310→      rollBack(conn, e);\n  1311→      throw e;\n  1312→    } finally {\n  1313→      releaseConn(conn);\n  1314→    }\n  1315→    return quoteData;\n  1316→  }\n  1317→\n  1318→  private void updateQuotePriceVolume(Connection conn, String symbol, BigDecimal newPrice, double newVolume,\n  1319→      double change) throws Exception {\n  1320→\n  1321→    PreparedStatement stmt = getStatement(conn, updateQuotePriceVolumeSQL);\n  1322→\n  1323→    stmt.setBigDecimal(1, newPrice);\n  1324→    stmt.setDouble(2, change);\n  1325→    stmt.setDouble(3, newVolume);\n  1326→    stmt.setString(4, symbol);\n  1327→\n  1328→    stmt.executeUpdate();\n  1329→    stmt.close();\n  1330→  }\n  1331→\n  1332→  private void publishQuotePriceChange(QuoteDataBean quoteData, BigDecimal oldPrice, BigDecimal changeFactor,\n  1333→      double sharesTraded) throws Exception {\n  1334→\n  1335→    Log.trace(\"TradeDirect:publishQuotePrice PUBLISHING to MDB quoteData = \" + quoteData);\n  1336→\n  1337→    JmsTemplate jmsTemplate = new JmsTemplate();\n  1338→\n  1339→    jmsTemplate.send(\"TradeStreamerTopic\", context -> {\n  1340→      TextMessage message = context.createTextMessage();\n  1341→\n  1342→      message.setStringProperty(\"command\", \"updateQuote\");\n  1343→      message.setStringProperty(\"symbol\", quoteData.getSymbol());\n  1344→      message.setStringProperty(\"company\", quoteData.getCompanyName());\n  1345→      message.setStringProperty(\"price\", quoteData.getPrice().toString());\n  1346→      message.setStringProperty(\"oldPrice\", oldPrice.toString());\n  1347→      message.setStringProperty(\"open\", quoteData.getOpen().toString());\n  1348→      message.setStringProperty(\"low\", quoteData.getLow().toString());\n  1349→      message.setStringProperty(\"high\", quoteData.getHigh().toString());\n  1350→      message.setDoubleProperty(\"volume\", quoteData.getVolume());\n  1351→\n  1352→      message.setStringProperty(\"changeFactor\", changeFactor.toString());\n  1353→      message.setDoubleProperty(\"sharesTraded\", sharesTraded);\n  1354→      message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n  1355→      message.setText(\"Update Stock price for \" + quoteData.getSymbol() + \" old price = \" + oldPrice + \" new price = \"\n  1356→          + quoteData.getPrice());\n  1357→      return message;\n  1358→    });\n  1359→  }\n  1360→\n  1361→  /**\n  1362→   * @see TradeServices#login(String, String)\n  1363→   */\n  1364→\n  1365→  @Override\n  1366→  public AccountDataBean login(String userID, String password) throws Exception {\n  1367→\n  1368→    AccountDataBean accountData = null;\n  1369→    Connection conn = null;\n  1370→    try {\n  1371→      Log.trace(\"TradeDirect:login - inSession(\" + this.inSession + \")\", userID, password);\n  1372→\n  1373→      conn = getConn();\n  1374→      PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1375→      stmt.setString(1, userID);\n  1376→\n  1377→      ResultSet rs = stmt.executeQuery();\n  1378→      if (!rs.next()) {\n  1379→        Log.error(\"TradeDirect:login -- failure to find account for\" + userID);\n  1380→        throw new Exception(\"Cannot find account for\" + userID);\n  1381→      }\n  1382→\n  1383→      String pw = rs.getString(\"passwd\");\n  1384→      stmt.close();\n  1385→      if ((pw == null) || (pw.equals(password) == false)) {\n  1386→        String error = \"TradeDirect:Login failure for user: \" + userID + \"\\n\\tIncorrect password-->\" + userID + \":\"\n  1387→            + password;\n  1388→        Log.error(error);\n  1389→        throw new Exception(error);\n  1390→      }\n  1391→\n  1392→      stmt = getStatement(conn, loginSQL);\n  1393→      stmt.setTimestamp(1, new Timestamp(System.currentTimeMillis()));\n  1394→      stmt.setString(2, userID);\n  1395→\n  1396→      stmt.executeUpdate();\n  1397→      stmt.close();\n  1398→\n  1399→      stmt = getStatement(conn, getAccountForUserSQL);\n  1400→      stmt.setString(1, userID);\n  1401→      rs = stmt.executeQuery();\n  1402→\n  1403→      accountData = getAccountDataFromResultSet(rs);\n  1404→\n  1405→      stmt.close();\n  1406→\n  1407→      commit(conn);\n  1408→    } catch (Exception e) {\n  1409→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n  1410→      rollBack(conn, e);\n  1411→    } finally {\n  1412→      releaseConn(conn);\n  1413→    }\n  1414→    return accountData;\n  1415→\n  1416→    /*\n  1417→     * setLastLogin( new Timestamp(System.currentTimeMillis()) );\n  1418→     * setLoginCount( getLoginCount() + 1 );\n  1419→     */\n  1420→  }\n  1421→\n  1422→  /**\n  1423→   * @see TradeServices#logout(String)\n  1424→   */\n  1425→  @Override\n  1426→  public void logout(String userID) throws Exception {\n  1427→    Log.trace(\"TradeDirect:logout - inSession(\" + this.inSession + \")\", userID);\n  1428→\n  1429→    Connection conn = null;\n  1430→    try {\n  1431→      conn = getConn();\n  1432→      PreparedStatement stmt = getStatement(conn, logoutSQL);\n  1433→      stmt.setString(1, userID);\n  1434→      stmt.executeUpdate();\n  1435→      stmt.close();\n  1436→\n  1437→      commit(conn);\n  1438→    } catch (Exception e) {\n  1439→      Log.error(\"TradeDirect:logout -- error logging out user\", e);\n  1440→      rollBack(conn, e);\n  1441→    } finally {\n  1442→      releaseConn(conn);\n  1443→    }\n  1444→  }\n  1445→\n  1446→  /**\n  1447→   * @see TradeServices#register(String, String, String, String, String,\n  1448→   *      String, BigDecimal, boolean)\n  1449→   */\n  1450→\n  1451→  @Override\n  1452→  public AccountDataBean register(String userID, String password, String fullname, String address, String email,\n  1453→      String creditcard, BigDecimal openBalance)\n  1454→      throws Exception {\n  1455→\n  1456→    AccountDataBean accountData = null;\n  1457→    Connection conn = null;\n  1458→    try {\n  1459→      Log.trace(\"TradeDirect:register - inSession(\" + this.inSession + \")\");\n  1460→\n  1461→      conn = getConn();\n  1462→      PreparedStatement stmt = getStatement(conn, createAccountSQL);\n  1463→\n  1464→      Integer accountID = KeySequenceDirect.getNextID(conn, \"account\", inSession, getInGlobalTxn());\n  1465→      BigDecimal balance = openBalance;\n  1466→      Timestamp creationDate = new Timestamp(System.currentTimeMillis());\n  1467→      Timestamp lastLogin = creationDate;\n  1468→      int loginCount = 0;\n  1469→      int logoutCount = 0;\n  1470→\n  1471→      stmt.setInt(1, accountID.intValue());\n  1472→      stmt.setTimestamp(2, creationDate);\n  1473→      stmt.setBigDecimal(3, openBalance);\n  1474→      stmt.setBigDecimal(4, balance);\n  1475→      stmt.setTimestamp(5, lastLogin);\n  1476→      stmt.setInt(6, loginCount);\n  1477→      stmt.setInt(7, logoutCount);\n  1478→      stmt.setString(8, userID);\n  1479→      stmt.executeUpdate();\n  1480→      stmt.close();\n  1481→\n  1482→      stmt = getStatement(conn, createAccountProfileSQL);\n  1483→      stmt.setString(1, userID);\n  1484→      stmt.setString(2, password);\n  1485→      stmt.setString(3, fullname);\n  1486→      stmt.setString(4, address);\n  1487→      stmt.setString(5, email);\n  1488→      stmt.setString(6, creditcard);\n  1489→      stmt.executeUpdate();\n  1490→      stmt.close();\n  1491→\n  1492→      commit(conn);\n  1493→\n  1494→      accountData = new AccountDataBean(accountID, loginCount, logoutCount, lastLogin, creationDate, balance,\n  1495→          openBalance, userID);\n  1496→\n  1497→    } catch (Exception e) {\n  1498→      Log.error(\"TradeDirect:register -- error registering new user\", e);\n  1499→    } finally {\n  1500→      releaseConn(conn);\n  1501→    }\n  1502→    return accountData;\n  1503→  }\n  1504→\n  1505→  private AccountDataBean getAccountDataFromResultSet(ResultSet rs) throws Exception {\n  1506→    AccountDataBean accountData = null;\n  1507→\n  1508→    if (!rs.next()) {\n  1509→      Log.error(\"TradeDirect:getAccountDataFromResultSet -- cannot find account data\");\n  1510→    } else {\n  1511→  accountData = new AccountDataBean(Integer.valueOf(rs.getInt(\"accountID\")), rs.getInt(\"loginCount\"),\n  1512→          rs.getInt(\"logoutCount\"),\n  1513→          rs.getTimestamp(\"lastLogin\"), rs.getTimestamp(\"creationDate\"), rs.getBigDecimal(\"balance\"),\n  1514→          rs.getBigDecimal(\"openBalance\"),\n  1515→          rs.getString(\"profile_userID\"));\n  1516→    }\n  1517→    return accountData;\n  1518→  }\n  1519→\n  1520→  private AccountProfileDataBean getAccountProfileDataFromResultSet(ResultSet rs) throws Exception {\n  1521→    AccountProfileDataBean accountProfileData = null;\n  1522→\n  1523→    if (!rs.next()) {\n  1524→      Log.error(\"TradeDirect:getAccountProfileDataFromResultSet -- cannot find accountprofile data\");\n  1525→    } else {\n  1526→      accountProfileData = new AccountProfileDataBean(rs.getString(\"userID\"), rs.getString(\"passwd\"),\n  1527→          rs.getString(\"fullName\"), rs.getString(\"address\"),\n  1528→          rs.getString(\"email\"), rs.getString(\"creditCard\"));\n  1529→    }\n  1530→\n  1531→    return accountProfileData;\n  1532→  }\n  1533→\n  1534→  private HoldingDataBean getHoldingDataFromResultSet(ResultSet rs) throws Exception {\n  1535→    HoldingDataBean holdingData = null;\n  1536→\n  1537→  holdingData = new HoldingDataBean(Integer.valueOf(rs.getInt(\"holdingID\")), rs.getDouble(\"quantity\"),\n  1538→        rs.getBigDecimal(\"purchasePrice\"),\n  1539→        rs.getTimestamp(\"purchaseDate\"), rs.getString(\"quote_symbol\"));\n  1540→    return holdingData;\n  1541→  }\n  1542→\n  1543→  private QuoteDataBean getQuoteDataFromResultSet(ResultSet rs) throws Exception {\n  1544→    QuoteDataBean quoteData = null;\n  1545→\n  1546→    quoteData = new QuoteDataBean(rs.getString(\"symbol\"), rs.getString(\"companyName\"), rs.getDouble(\"volume\"),\n  1547→        rs.getBigDecimal(\"price\"),\n  1548→        rs.getBigDecimal(\"open1\"), rs.getBigDecimal(\"low\"), rs.getBigDecimal(\"high\"), rs.getDouble(\"change1\"));\n  1549→    return quoteData;\n  1550→  }\n  1551→\n  1552→  private OrderDataBean getOrderDataFromResultSet(ResultSet rs) throws Exception {\n  1553→    OrderDataBean orderData = null;\n  1554→\n  1555→  orderData = new OrderDataBean(Integer.valueOf(rs.getInt(\"orderID\")), rs.getString(\"orderType\"),\n  1556→        rs.getString(\"orderStatus\"), rs.getTimestamp(\"openDate\"),\n  1557→        rs.getTimestamp(\"completionDate\"), rs.getDouble(\"quantity\"), rs.getBigDecimal(\"price\"),\n  1558→        rs.getBigDecimal(\"orderFee\"),\n  1559→        rs.getString(\"quote_symbol\"));\n  1560→    return orderData;\n  1561→  }\n  1562→\n  1563→  public boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n  1564→    // Clear MDB Statistics\n  1565→    MDBStats.getInstance().reset();\n  1566→\n  1567→    Connection conn = null;\n  1568→    boolean success = false;\n  1569→    try {\n  1570→\n  1571→      Log.trace(\"TradeDirect:recreateDBTables\");\n  1572→\n  1573→      conn = getConn();\n  1574→      Statement stmt = conn.createStatement();\n  1575→      int bufferLength = sqlBuffer.length;\n  1576→      for (int i = 0; i < bufferLength; i++) {\n  1577→        try {\n  1578→          stmt.executeUpdate((String) sqlBuffer[i]);\n  1579→          // commit(conn);\n  1580→        } catch (SQLException ex) {\n  1581→          // Ignore DROP statements as tables won't always exist.\n  1582→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n  1583→            Log.error(\n  1584→                \"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i],\n  1585→                ex);\n  1586→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i]\n  1587→                + \"</I> . Check log for details.</BR>\");\n  1588→          }\n  1589→        }\n  1590→      }\n  1591→      stmt.close();\n  1592→      commit(conn);\n  1593→      success = true;\n  1594→    } catch (Exception e) {\n  1595→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n  1596→    } finally {\n  1597→      releaseConn(conn);\n  1598→    }\n  1599→    return success;\n  1600→  }\n  1601→\n  1602→  ;\n  1603→\n  1604→  private void releaseConn(Connection conn) throws Exception {\n  1605→    try {\n  1606→      if (conn != null) {\n  1607→        conn.close();\n  1608→        if (Log.doTrace()) {\n  1609→          synchronized (lock) {\n  1610→            connCount--;\n  1611→          }\n  1612→          Log.trace(\"TradeDirect:releaseConn -- connection closed, connCount=\" + connCount);\n  1613→        }\n  1614→      }\n  1615→    } catch (Exception e) {\n  1616→      Log.error(\"TradeDirect:releaseConnection -- failed to close connection\", e);\n  1617→    }\n  1618→  }\n  1619→\n  1620→  /*\n  1621→   * Allocate a new connection to the datasource\n  1622→   */\n  1623→  private static int connCount = 0;\n  1624→\n  1625→  private static final Object lock = new Object();\n  1626→\n  1627→  private Connection getConn() throws Exception {\n  1628→\n  1629→    Connection conn = datasource.getConnection();\n  1630→\n  1631→    if (!this.inGlobalTxn) {\n  1632→      conn.setAutoCommit(false);\n  1633→    }\n  1634→    if (Log.doTrace()) {\n  1635→      synchronized (lock) {\n  1636→        connCount++;\n  1637→      }\n  1638→      Log.trace(\"TradeDirect:getConn -- new connection allocated, IsolationLevel=\" + conn.getTransactionIsolation()\n  1639→          + \" connectionCount = \" + connCount);\n  1640→    }\n  1641→\n  1642→    return conn;\n  1643→  }\n  1644→\n  1645→  public Connection getConnPublic() throws Exception {\n  1646→    return getConn();\n  1647→  }\n  1648→\n  1649→  /*\n  1650→   * Commit the provided connection if not under Global Transaction scope -\n  1651→   * conn.commit() is not allowed in a global transaction. the txn manager\n  1652→   * will perform the commit\n  1653→   */\n  1654→  private void commit(Connection conn) throws Exception {\n  1655→    if (!inSession) {\n  1656→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1657→        conn.commit();\n  1658→      }\n  1659→    }\n  1660→  }\n  1661→\n  1662→  /*\n  1663→   * Rollback the statement for the given connection\n  1664→   */\n  1665→  private void rollBack(Connection conn, Exception e) throws Exception {\n  1666→    if (!inSession) {\n  1667→      Log.log(\"TradeDirect:rollBack -- rolling back conn due to previously caught exception -- inGlobalTxn=\"\n  1668→          + getInGlobalTxn());\n  1669→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1670→        conn.rollback();\n  1671→      } else {\n  1672→        throw e; // Throw the exception\n  1673→        // so the Global txn manager will rollBack\n  1674→      }\n  1675→    }\n  1676→  }\n  1677→\n  1678→  /*\n  1679→   * Allocate a new prepared statment for this connection\n  1680→   */\n  1681→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n  1682→    return conn.prepareStatement(sql);\n  1683→  }\n  1684→\n  1685→  private PreparedStatement getStatement(Connection conn, String sql, int type, int concurrency) throws Exception {\n  1686→    return conn.prepareStatement(sql, type, concurrency);\n  1687→  }\n  1688→\n  1689→  private static final String createQuoteSQL = \"insert into quoteejb \"\n  1690→      + \"( symbol, companyName, volume, price, open1, low, high, change1 ) \"\n  1691→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1692→\n  1693→  private static final String createAccountSQL = \"insert into accountejb \"\n  1694→      + \"( accountid, creationDate, openBalance, balance, lastLogin, loginCount, logoutCount, profile_userid) \"\n  1695→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1696→\n  1697→  private static final String createAccountProfileSQL = \"insert into accountprofileejb \"\n  1698→      + \"( userid, passwd, fullname, address, email, creditcard ) \"\n  1699→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1700→\n  1701→  private static final String createHoldingSQL = \"insert into holdingejb \"\n  1702→      + \"( holdingid, purchaseDate, purchasePrice, quantity, quote_symbol, account_accountid ) \"\n  1703→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ? )\";\n  1704→\n  1705→  private static final String createOrderSQL = \"insert into orderejb \"\n  1706→      + \"( orderid, ordertype, orderstatus, opendate, quantity, price, orderfee, account_accountid,  holding_holdingid, quote_symbol) \"\n  1707→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  , ? , ? , ?)\";\n  1708→\n  1709→  private static final String removeHoldingSQL = \"delete from holdingejb where holdingid = ?\";\n  1710→\n  1711→  private static final String removeHoldingFromOrderSQL = \"update orderejb set holding_holdingid=null where holding_holdingid = ?\";\n  1712→\n  1713→  private static final String updateAccountProfileSQL = \"update accountprofileejb set \"\n  1714→      + \"passwd = ?, fullname = ?, address = ?, email = ?, creditcard = ? \"\n  1715→      + \"where userid = (select profile_userid from accountejb a \" + \"where a.profile_userid=?)\";\n  1716→\n  1717→  private static final String loginSQL = \"update accountejb set lastLogin=?, logincount=logincount+1 \"\n  1718→      + \"where profile_userid=?\";\n  1719→\n  1720→  private static final String logoutSQL = \"update accountejb set logoutcount=logoutcount+1 \" + \"where profile_userid=?\";\n  1721→\n  1722→  private static final String getAccountSQL = \"select * from accountejb a where a.accountid = ?\";\n  1723→\n  1724→  private static final String getAccountProfileSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1725→      + \"(select profile_userid from accountejb a where a.profile_userid=?)\";\n  1726→\n  1727→  private static final String getAccountProfileForAccountSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1728→      + \"(select profile_userid from accountejb a where a.accountid=?)\";\n  1729→\n  1730→  private static final String getAccountForUserSQL = \"select * from accountejb a where a.profile_userid = \"\n  1731→      + \"( select userid from accountprofileejb ap where ap.userid = ?)\";\n  1732→\n  1733→  private static final String getHoldingSQL = \"select * from holdingejb h where h.holdingid = ?\";\n  1734→\n  1735→  private static final String getHoldingsForUserSQL = \"select * from holdingejb h where h.account_accountid = \"\n  1736→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1737→\n  1738→  private static final String getOrderSQL = \"select * from orderejb o where o.orderid = ?\";\n  1739→\n  1740→  private static final String getOrdersByUserSQL = \"select * from orderejb o where o.account_accountid = \"\n  1741→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1742→\n  1743→  private static final String getClosedOrdersSQL = \"select * from orderejb o \"\n  1744→      + \"where o.orderstatus = 'closed' AND o.account_accountid = \"\n  1745→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1746→\n  1747→  private static final String getQuoteSQL = \"select * from quoteejb q where q.symbol=?\";\n  1748→\n  1749→  private static final String getAllQuotesSQL = \"select * from quoteejb q\";\n  1750→\n  1751→  private static final String getQuoteForUpdateSQL = \"select * from quoteejb q where q.symbol=? For Update\";\n  1752→\n  1753→  private static final String getTSIAQuotesOrderByChangeSQL = \"select * from quoteejb q order by q.change1\";\n  1754→\n  1755→  private static final String getTSIASQL = \"select SUM(price)/count(*) as TSIA from quoteejb q \";\n  1756→\n  1757→  private static final String getOpenTSIASQL = \"select SUM(open1)/count(*) as openTSIA from quoteejb q \";\n  1758→\n  1759→  private static final String getTSIATotalVolumeSQL = \"select SUM(volume) as totalVolume from quoteejb q \";\n  1760→\n  1761→  private static final String creditAccountBalanceSQL = \"update accountejb set \" + \"balance = balance + ? \"\n  1762→      + \"where accountid = ?\";\n  1763→\n  1764→  private static final String updateOrderStatusSQL = \"update orderejb set \" + \"orderstatus = ?, completiondate = ? \"\n  1765→      + \"where orderid = ?\";\n  1766→\n  1767→  private static final String updateOrderHoldingSQL = \"update orderejb set \" + \"holding_holdingID = ? \"\n  1768→      + \"where orderid = ?\";\n  1769→\n  1770→  private static final String updateQuotePriceVolumeSQL = \"update quoteejb set \" + \"price = ?, change1 = ?, volume = ? \"\n  1771→      + \"where symbol = ?\";\n  1772→\n  1773→  /**\n  1774→   * Gets the inGlobalTxn\n  1775→   *\n  1776→   * @return Returns a boolean\n  1777→   */\n  1778→  private boolean getInGlobalTxn() {\n  1779→    return inGlobalTxn;\n  1780→  }\n  1781→\n  1782→  /**\n  1783→   * Sets the inGlobalTxn\n  1784→   *\n  1785→   * @param inGlobalTxn\n  1786→   *                    The inGlobalTxn to set\n  1787→   */\n  1788→  private void setInGlobalTxn(boolean inGlobalTxn) {\n  1789→    this.inGlobalTxn = inGlobalTxn;\n  1790→  }\n  1791→\n  1792→  public void setInSession(boolean inSession) {\n  1793→    this.inSession = inSession;\n  1794→  }\n  1795→\n  1796→  @Override\n  1797→  public int getImpl() {\n  1798→    return TradeConfig.DIRECT;\n  1799→  }\n  1800→\n  1801→  @Override\n  1802→  public QuoteDataBean pingTwoPhase(String symbol) {\n  1803→    throw new UnsupportedOperationException();\n  1804→  }\n  1805→\n  1806→  @Override\n  1807→  public double investmentReturn(double rnd1, double rnd2) {\n  1808→    throw new UnsupportedOperationException();\n  1809→  }\n  1810→}\n  1811→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"34edf4e1-225c-4cb5-97a7-ff14313e2756"}
