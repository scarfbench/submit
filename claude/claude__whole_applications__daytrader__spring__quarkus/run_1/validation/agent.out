{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01P2meLFgLMopsGjqW169McU","type":"tool_result","content":"     1→package com.ibm.websphere.samples.daytrader.jms;\n     2→\n     3→import java.util.Map;\n     4→\n     5→import jakarta.annotation.PostConstruct;\n     6→import jakarta.jms.Message;\n     7→import jakarta.jms.TextMessage;\n     8→\n     9→import org.springframework.beans.factory.annotation.Autowired;\n    10→import org.springframework.context.ApplicationContext;\n    11→import org.springframework.jms.annotation.JmsListener;\n    12→import org.springframework.stereotype.Service;\n    13→\n    14→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    15→import com.ibm.websphere.samples.daytrader.util.Log;\n    16→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    17→import com.ibm.websphere.samples.daytrader.util.TimerStat;\n    18→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    19→\n    20→@Service\n    21→public class DTBroker3Listener {\n    22→\n    23→    private final MDBStats mdbStats = MDBStats.getInstance();\n    24→    private int statInterval = 10000;\n    25→\n    26→    private final ApplicationContext ctx;\n    27→    private final Map<String, TradeServices> services;\n    28→    private TradeServices trade;\n    29→\n    30→    @Autowired\n    31→    public DTBroker3Listener(ApplicationContext ctx, Map<String, TradeServices> services) {\n    32→        this.ctx = ctx;\n    33→        this.services = services;\n    34→    }\n    35→\n    36→    @PostConstruct\n    37→    void bootstrapTradeServices() {\n    38→        String[] modes = TradeConfig.getRunTimeModeNames();\n    39→        String modeName = modes[TradeConfig.getRunTimeMode()];\n    40→        TradeServices candidate = services.get(modeName);\n    41→        if (candidate == null) {\n    42→            try { candidate = ctx.getBean(modeName, TradeServices.class); } catch (Exception ignored) {}\n    43→        }\n    44→        if (candidate == null && services.size() == 1) {\n    45→            candidate = services.values().iterator().next();\n    46→        }\n    47→        this.trade = candidate;\n    48→        Log.log(\"DTBroker3Listener: selected TradeServices = \" +\n    49→                (trade != null ? trade.getClass().getName() : \"<none>\") +\n    50→                \" (mode=\" + modeName + \")\");\n    51→    }\n    52→\n    53→    @JmsListener(destination = \"TradeBrokerQueue\", containerFactory = \"queueFactory\")\n    54→    public void onBrokerQueueMessage(Message message) {\n    55→        try {\n    56→            String body = (message instanceof TextMessage) ? ((TextMessage) message).getText() : \"<non-text>\";\n    57→            String command = message.getStringProperty(\"command\");\n    58→\n    59→            Log.trace(\"DTBroker3MDB:onMessage -- received --> \" + body + \" command--> \" + command + \" <--\");\n    60→\n    61→            if (message.getJMSRedelivered()) {\n    62→                Log.log(\"DTBroker3MDB: redelivered due to rollback:\\n\" + body);\n    63→                // Parity with EJB: ignore redeliveries if needed\n    64→                return;\n    65→            }\n    66→            if (command == null) {\n    67→                Log.debug(\"DTBroker3MDB:onMessage -- null command. Message-->\" + message);\n    68→                return;\n    69→            }\n    70→\n    71→            if (command.equalsIgnoreCase(\"neworder\")) {\n    72→                Integer orderID = message.propertyExists(\"orderID\") ? message.getIntProperty(\"orderID\") : null;\n    73→                boolean twoPhase = message.propertyExists(\"twoPhase\") && message.getBooleanProperty(\"twoPhase\");\n    74→                boolean direct = message.propertyExists(\"direct\") && message.getBooleanProperty(\"direct\");\n    75→                long publishTime = message.propertyExists(\"publishTime\") ? message.getLongProperty(\"publishTime\") : -1L;\n    76→                long receiveTime = System.currentTimeMillis();\n    77→\n    78→                try {\n    79→                    Log.trace(\"DTBroker3MDB:onMessage - completing order \" + orderID\n    80→                            + \" twoPhase=\" + twoPhase + \" direct=\" + direct);\n    81→\n    82→                    if (trade == null) throw new IllegalStateException(\"No TradeServices bean selected\");\n    83→                    trade.completeOrder(orderID, twoPhase);\n    84→\n    85→                    TimerStat s = mdbStats.addTiming(\"DTBroker3MDB:neworder\", publishTime, receiveTime);\n    86→                    if ((s.getCount() % statInterval) == 0) {\n    87→                        Log.log(\" DTBroker3MDB: processed \" + statInterval + \" stock trading orders.\"\n    88→                                + \" Total = \" + s.getCount()\n    89→                                + \" Time (s): min=\" + s.getMinSecs()\n    90→                                + \" max=\" + s.getMaxSecs()\n    91→                                + \" avg=\" + s.getAvgSecs());\n    92→                    }\n    93→                } catch (Exception e) {\n    94→                    Log.error(\"DTBroker3MDB:onMessage Exception completing order: \" + orderID + \"\\n\", e);\n    95→                    // Signal rollback → redelivery (needs transacted listener)\n    96→                    throw new RuntimeException(\"Rollback to redeliver\", e);\n    97→                }\n    98→\n    99→            } else if (command.equalsIgnoreCase(\"ping\")) {\n   100→                Log.trace(\"DTBroker3MDB:onMessage test command -- \" + body);\n   101→\n   102→                long publishTime = message.propertyExists(\"publishTime\") ? message.getLongProperty(\"publishTime\") : -1L;\n   103→                long receiveTime = System.currentTimeMillis();\n   104→\n   105→                TimerStat s = mdbStats.addTiming(\"DTBroker3MDB:ping\", publishTime, receiveTime);\n   106→                if ((s.getCount() % statInterval) == 0) {\n   107→                    Log.log(\" DTBroker3MDB: received \" + statInterval + \" ping messages.\"\n   108→                            + \" Total = \" + s.getCount()\n   109→                            + \" Time (s): min=\" + s.getMinSecs()\n   110→                            + \" max=\" + s.getMaxSecs()\n   111→                            + \" avg=\" + s.getAvgSecs());\n   112→                }\n   113→            } else {\n   114→                Log.error(\"DTBroker3MDB:onMessage - unknown command --> \" + command + \" <-- body=\" + body);\n   115→            }\n   116→\n   117→        } catch (RuntimeException rte) {\n   118→            throw rte; // ensures rollback when transacted\n   119→        } catch (Throwable t) {\n   120→            Log.error(\"DTBroker3MDB: Error in listener\", t);\n   121→            throw new RuntimeException(\"Rollback to redeliver\", t);\n   122→        }\n   123→    }\n   124→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"6f1e6d12-e3ae-42d4-9c52-298a42aa2422"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01TZcmVYCtXTgNkqCfAShTWo","type":"tool_result","content":"     1→package com.ibm.websphere.samples.daytrader.jms;\n     2→\n     3→import jakarta.jms.Message;\n     4→import jakarta.jms.TextMessage;\n     5→import org.springframework.jms.annotation.JmsListener;\n     6→import org.springframework.stereotype.Service;\n     7→\n     8→import com.ibm.websphere.samples.daytrader.util.Log;\n     9→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    10→import com.ibm.websphere.samples.daytrader.util.TimerStat;\n    11→\n    12→@Service\n    13→public class DTStreamer3Listener {\n    14→\n    15→    private final MDBStats mdbStats = MDBStats.getInstance();\n    16→    private int statInterval = 10000;\n    17→\n    18→    @JmsListener(destination = \"TradeStreamerTopic\", containerFactory = \"topicFactory\")\n    19→    public void onStreamerTopicEvent(Message message) {\n    20→        try {\n    21→            String body = (message instanceof TextMessage) ? ((TextMessage) message).getText() : \"<non-text>\";\n    22→            String command = message.getStringProperty(\"command\");\n    23→\n    24→            Log.trace(\"DTStreamer3MDB:onMessage -- received message -->\" + body + \" command-->\" + command + \"<--\");\n    25→\n    26→            if (command == null) {\n    27→                Log.debug(\"DTStreamer3MDB:onMessage -- received message with null command. Message-->\" + message);\n    28→                return;\n    29→            }\n    30→\n    31→            if (command.equalsIgnoreCase(\"updateQuote\")) {\n    32→                Log.trace(\"DTStreamer3MDB:onMessage -- updateQuote --> \" + body\n    33→                        + \"\\n\\t symbol = \" + message.getStringProperty(\"symbol\")\n    34→                        + \"\\n\\t current price = \" + message.getStringProperty(\"price\")\n    35→                        + \"\\n\\t old price = \" + message.getStringProperty(\"oldPrice\"));\n    36→\n    37→                long publishTime = message.getLongProperty(\"publishTime\");\n    38→                long receiveTime = System.currentTimeMillis();\n    39→                TimerStat s = mdbStats.addTiming(\"DTStreamer3MDB:updateQuote\", publishTime, receiveTime);\n    40→\n    41→                if ((s.getCount() % statInterval) == 0) {\n    42→                    Log.log(\" DTStreamer3MDB: \" + statInterval + \" prices updated:\"\n    43→                            + \" Total message count = \" + s.getCount()\n    44→                            + \" Time (s): min=\" + s.getMinSecs()\n    45→                            + \" max=\" + s.getMaxSecs()\n    46→                            + \" avg=\" + s.getAvgSecs());\n    47→                }\n    48→\n    49→            } else if (command.equalsIgnoreCase(\"ping\")) {\n    50→                Log.trace(\"DTStreamer3MDB:onMessage received ping -- \" + body);\n    51→\n    52→                long publishTime = message.getLongProperty(\"publishTime\");\n    53→                long receiveTime = System.currentTimeMillis();\n    54→                TimerStat s = mdbStats.addTiming(\"DTStreamer3MDB:ping\", publishTime, receiveTime);\n    55→\n    56→                if ((s.getCount() % statInterval) == 0) {\n    57→                    Log.log(\" DTStreamer3MDB: received \" + statInterval + \" ping messages.\"\n    58→                            + \" Total message count = \" + s.getCount()\n    59→                            + \" Time (s): min=\" + s.getMinSecs()\n    60→                            + \" max=\" + s.getMaxSecs()\n    61→                            + \" avg=\" + s.getAvgSecs());\n    62→                }\n    63→\n    64→            } else {\n    65→                Log.error(\"DTStreamer3MDB:onMessage - unknown message command=\" + command + \" body=\" + body);\n    66→            }\n    67→\n    68→        } catch (Throwable t) {\n    69→            Log.error(\"DTStreamer3MDB: Exception\", t);\n    70→            // For redelivery behavior on topic, wire error handlers if desired.\n    71→        }\n    72→    }\n    73→}\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"578040f1-2ddd-4433-a3d1-72fcce80793e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01UgKLiMm5sc6C81uWFBDFv5","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    19→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    20→import com.ibm.websphere.samples.daytrader.events.MarketSummaryUpdateEvent;\n    21→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    22→import com.ibm.websphere.samples.daytrader.util.Log;\n    23→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    24→import jakarta.persistence.EntityManager;\n    25→import jakarta.persistence.PersistenceContext;\n    26→import jakarta.persistence.TypedQuery;\n    27→import jakarta.persistence.criteria.CriteriaBuilder;\n    28→import jakarta.persistence.criteria.CriteriaQuery;\n    29→import jakarta.persistence.criteria.Root;\n    30→import java.math.BigDecimal;\n    31→import java.math.RoundingMode;\n    32→import java.util.ArrayList;\n    33→import java.util.List;\n    34→import java.util.concurrent.locks.ReentrantReadWriteLock;\n    35→import java.util.concurrent.locks.ReentrantReadWriteLock.ReadLock;\n    36→import java.util.concurrent.locks.ReentrantReadWriteLock.WriteLock;\n    37→import org.springframework.beans.factory.annotation.Autowired;\n    38→import org.springframework.context.ApplicationEventPublisher;\n    39→import org.springframework.scheduling.annotation.Scheduled;\n    40→import org.springframework.stereotype.Service;\n    41→import org.springframework.transaction.annotation.Transactional;\n    42→\n    43→@Service\n    44→public class MarketSummarySingleton {\n    45→\n    46→    private MarketSummaryDataBean marketSummaryDataBean;\n    47→    private final ReentrantReadWriteLock rwLock = new ReentrantReadWriteLock();\n    48→    private final ReadLock readLock = rwLock.readLock();\n    49→    private final WriteLock writeLock = rwLock.writeLock();\n    50→\n    51→    @PersistenceContext\n    52→    private EntityManager entityManager;\n    53→\n    54→    @Autowired\n    55→    ApplicationEventPublisher publisher;\n    56→\n    57→    /* Update Market Summary every 20 seconds */\n    58→    @Scheduled(cron = \"*/20 * * * * *\")\n    59→    @Transactional(readOnly = true)\n    60→    private void updateMarketSummary() {\n    61→        Log.trace(\n    62→            \"MarketSummarySingleton:updateMarketSummary -- updating market summary\"\n    63→        );\n    64→\n    65→        if (TradeConfig.getRunTimeMode() != TradeConfig.EJB3) {\n    66→            Log.trace(\n    67→                \"MarketSummarySingleton:updateMarketSummary -- Not EJB3 Mode, so not updating\"\n    68→            );\n    69→            return; // Only do the actual work if in EJB3 Mode\n    70→        }\n    71→\n    72→        List<QuoteDataBean> quotes;\n    73→\n    74→        try {\n    75→            // Find Trade Stock Index Quotes (Top 100 quotes) ordered by their change in\n    76→            // value\n    77→            CriteriaBuilder criteriaBuilder =\n    78→                entityManager.getCriteriaBuilder();\n    79→            CriteriaQuery<QuoteDataBean> criteriaQuery =\n    80→                criteriaBuilder.createQuery(QuoteDataBean.class);\n    81→            Root<QuoteDataBean> quoteRoot = criteriaQuery.from(\n    82→                QuoteDataBean.class\n    83→            );\n    84→            criteriaQuery.orderBy(\n    85→                criteriaBuilder.desc(quoteRoot.get(\"change1\"))\n    86→            );\n    87→            criteriaQuery.select(quoteRoot);\n    88→            TypedQuery<QuoteDataBean> q = entityManager.createQuery(\n    89→                criteriaQuery\n    90→            );\n    91→            quotes = q.getResultList();\n    92→        } catch (Exception e) {\n    93→            Log.debug(\n    94→                \"Warning: The database has not been configured. If this is the first time the application has been started, please create and populate the database tables. Then restart the server.\"\n    95→            );\n    96→            return;\n    97→        }\n    98→\n    99→        QuoteDataBean[] quoteArray = quotes.toArray(QuoteDataBean[]::new);\n   100→        ArrayList<QuoteDataBean> topGainers = new ArrayList<>(5);\n   101→        ArrayList<QuoteDataBean> topLosers = new ArrayList<>(5);\n   102→        BigDecimal TSIA = FinancialUtils.ZERO;\n   103→        BigDecimal openTSIA = FinancialUtils.ZERO;\n   104→        double totalVolume = 0.0;\n   105→\n   106→        if (quoteArray.length > 5) {\n   107→            for (int i = 0; i < 5; i++) {\n   108→                topGainers.add(quoteArray[i]);\n   109→            }\n   110→            for (\n   111→                int i = quoteArray.length - 1;\n   112→                i >= quoteArray.length - 5;\n   113→                i--\n   114→            ) {\n   115→                topLosers.add(quoteArray[i]);\n   116→            }\n   117→\n   118→            for (QuoteDataBean quote : quoteArray) {\n   119→                BigDecimal price = quote.getPrice();\n   120→                BigDecimal open = quote.getOpen();\n   121→                double volume = quote.getVolume();\n   122→                TSIA = TSIA.add(price);\n   123→                openTSIA = openTSIA.add(open);\n   124→                totalVolume += volume;\n   125→                TSIA = TSIA.divide(\n   126→                    new BigDecimal(quoteArray.length),\n   127→                    RoundingMode.HALF_UP\n   128→                );\n   129→                openTSIA = openTSIA.divide(\n   130→                    new BigDecimal(quoteArray.length),\n   131→                    RoundingMode.HALF_UP\n   132→                );\n   133→                openTSIA = openTSIA.divide(\n   134→                    new BigDecimal(quoteArray.length),\n   135→                    RoundingMode.HALF_UP\n   136→                );\n   137→            }\n   138→\n   139→            setMarketSummaryDataBean(\n   140→                new MarketSummaryDataBean(\n   141→                    TSIA,\n   142→                    openTSIA,\n   143→                    totalVolume,\n   144→                    topGainers,\n   145→                    topLosers\n   146→                )\n   147→            );\n   148→            publisher.publishEvent(\n   149→                new MarketSummaryUpdateEvent(\"MarketSummaryUpdate\")\n   150→            );\n   151→        }\n   152→    }\n   153→\n   154→    public MarketSummaryDataBean getMarketSummaryDataBean() {\n   155→        readLock.lock();\n   156→        if (marketSummaryDataBean == null) {\n   157→            updateMarketSummary();\n   158→        }\n   159→\n   160→        return marketSummaryDataBean;\n   161→    }\n   162→\n   163→    public void setMarketSummaryDataBean(\n   164→        MarketSummaryDataBean marketSummaryDataBean\n   165→    ) {\n   166→        writeLock.lock();\n   167→        this.marketSummaryDataBean = marketSummaryDataBean;\n   168→    }\n   169→}\n   170→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"dde19cf2-3f76-4661-bb6e-9c29e3067989"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01DpXXZu3e7EmeqBsgdKXB2E","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    19→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    20→import java.util.Map;\n    21→import org.springframework.beans.factory.annotation.Autowired;\n    22→import org.springframework.context.annotation.Scope;\n    23→import org.springframework.stereotype.Component;\n    24→\n    25→@Component\n    26→@Scope(\"prototype\")\n    27→public class AsyncScheduledOrder implements Runnable {\n    28→\n    29→    @Autowired\n    30→    private Map<String, TradeServices> tradeService;\n    31→\n    32→    Integer orderID;\n    33→    boolean twoPhase;\n    34→\n    35→    public void setProperties(Integer orderID, boolean twoPhase) {\n    36→        this.orderID = orderID;\n    37→        this.twoPhase = twoPhase;\n    38→    }\n    39→\n    40→    @Override\n    41→    public void run() {\n    42→        try {\n    43→            tradeService\n    44→                .get(\n    45→                    TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()]\n    46→                )\n    47→                .completeOrder(orderID, twoPhase);\n    48→        } catch (Exception e) {\n    49→            e.printStackTrace();\n    50→        }\n    51→    }\n    52→}\n    53→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"595833bf-da60-4f33-bd5e-2aa5f171db9e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01ALgcpPUn5Hp4cvVfVanZ4A","type":"tool_result","content":"     1→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n     2→\n     3→import java.time.Instant;\n     4→import java.util.concurrent.Future;\n     5→import org.springframework.beans.factory.annotation.Autowired;\n     6→import org.springframework.scheduling.TaskScheduler;\n     7→import org.springframework.stereotype.Component;\n     8→import org.springframework.web.context.annotation.RequestScope;\n     9→\n    10→@Component\n    11→@RequestScope\n    12→public class AsyncScheduledOrderSubmitter {\n    13→\n    14→    // --- REMOVE ---\n    15→    // @Resource\n    16→    // private ManagedScheduledExecutorService mes;\n    17→\n    18→    // +++ ADD +++\n    19→    @Autowired\n    20→    private TaskScheduler mes;\n    21→\n    22→    // --- REMOVE ---\n    23→    // @Inject\n    24→\n    25→    // +++ ADD +++\n    26→    @Autowired\n    27→    private AsyncScheduledOrder asyncOrder;\n    28→\n    29→    public Future<?> submitOrder(Integer orderID, boolean twoPhase) {\n    30→        asyncOrder.setProperties(orderID, twoPhase);\n    31→        return mes.schedule(asyncOrder, Instant.now().plusMillis(500));\n    32→    }\n    33→}\n    34→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"42721c16-27ff-49a8-8d0a-d4a953f3c45c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01QsybAAAGk8uH4MA819bfMx","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    19→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    20→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    21→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    22→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    23→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    24→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    25→import com.ibm.websphere.samples.daytrader.interfaces.TradeEJB;\n    26→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    27→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    28→import com.ibm.websphere.samples.daytrader.util.Log;\n    29→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    30→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    31→import jakarta.jms.ConnectionFactory;\n    32→import jakarta.jms.TextMessage;\n    33→import jakarta.persistence.EntityManager;\n    34→import jakarta.persistence.PersistenceContext;\n    35→import jakarta.persistence.TypedQuery;\n    36→import jakarta.persistence.criteria.CriteriaBuilder;\n    37→import jakarta.persistence.criteria.CriteriaQuery;\n    38→import jakarta.persistence.criteria.Root;\n    39→import jakarta.transaction.RollbackException;\n    40→\n    41→import java.math.BigDecimal;\n    42→import java.sql.Timestamp;\n    43→import java.util.Collection;\n    44→import java.util.Comparator;\n    45→import java.util.Iterator;\n    46→import java.util.List;\n    47→import java.util.Date;\n    48→import java.util.concurrent.Future;\n    49→import org.springframework.beans.factory.annotation.Autowired;\n    50→import org.springframework.jms.core.JmsTemplate;\n    51→import org.springframework.stereotype.Service;\n    52→import org.springframework.transaction.annotation.Propagation;\n    53→import org.springframework.transaction.annotation.Transactional;\n    54→\n    55→@Service(\"Full EJB3\")\n    56→@TradeEJB\n    57→@Trace\n    58→@Transactional\n    59→public class TradeSLSBBean implements TradeServices {\n    60→\n    61→    @Autowired\n    62→    private ConnectionFactory connectionFactory;\n    63→\n    64→    @PersistenceContext\n    65→    private EntityManager entityManager;\n    66→\n    67→    // Not needed\n    68→    // @Resource\n    69→    // private SessionContext context;\n    70→\n    71→    @Autowired\n    72→    private MarketSummarySingleton marketSummarySingleton;\n    73→\n    74→    @Autowired\n    75→    AsyncScheduledOrderSubmitter asyncEJBOrderSubmitter;\n    76→\n    77→    @Autowired\n    78→    RecentQuotePriceChangeList recentQuotePriceChangeList;\n    79→\n    80→    @Override\n    81→    public MarketSummaryDataBean getMarketSummary() {\n    82→        return marketSummarySingleton.getMarketSummaryDataBean();\n    83→    }\n    84→\n    85→    @Override\n    86→    public OrderDataBean buy(\n    87→            String userID,\n    88→            String symbol,\n    89→            double quantity,\n    90→            int orderProcessingMode) {\n    91→        OrderDataBean order = null;\n    92→        BigDecimal total;\n    93→        try {\n    94→            AccountProfileDataBean profile = entityManager.find(\n    95→                    AccountProfileDataBean.class,\n    96→                    userID);\n    97→            AccountDataBean account = profile.getAccount();\n    98→            QuoteDataBean quote = entityManager.find(\n    99→                    QuoteDataBean.class,\n   100→                    symbol);\n   101→            HoldingDataBean holding = null; // The holding will be created by\n   102→            // this buy order\n   103→\n   104→            order = createOrder(account, quote, holding, \"buy\", quantity);\n   105→\n   106→            // UPDATE - account should be credited during completeOrder\n   107→            BigDecimal price = quote.getPrice();\n   108→            BigDecimal orderFee = order.getOrderFee();\n   109→            BigDecimal balance = account.getBalance();\n   110→            total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   111→            account.setBalance(balance.subtract(total));\n   112→            final Integer orderID = order.getOrderID();\n   113→\n   114→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   115→                completeOrder(orderID, false);\n   116→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   117→                completeOrderAsync(orderID, false);\n   118→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   119→                queueOrder(orderID, true);\n   120→            }\n   121→        } catch (Exception e) {\n   122→            Log.error(\n   123→                    \"TradeSLSBBean:buy(\" +\n   124→                            userID +\n   125→                            \",\" +\n   126→                            symbol +\n   127→                            \",\" +\n   128→                            quantity +\n   129→                            \") --> failed\",\n   130→                    e);\n   131→            /* On exception - cancel the order */\n   132→            // TODO figure out how to do this with JPA\n   133→            // if (order != null) order.cancel();\n   134→            throw new RuntimeException(e);\n   135→        }\n   136→        return order;\n   137→    }\n   138→\n   139→    @Override\n   140→    public OrderDataBean sell(\n   141→            final String userID,\n   142→            final Integer holdingID,\n   143→            int orderProcessingMode) {\n   144→        OrderDataBean order = null;\n   145→        BigDecimal total;\n   146→        try {\n   147→            AccountProfileDataBean profile = entityManager.find(\n   148→                    AccountProfileDataBean.class,\n   149→                    userID);\n   150→            AccountDataBean account = profile.getAccount();\n   151→\n   152→            HoldingDataBean holding = entityManager.find(\n   153→                    HoldingDataBean.class,\n   154→                    holdingID);\n   155→\n   156→            if (holding == null) {\n   157→                Log.debug(\n   158→                        \"TradeSLSBBean:sell User \" +\n   159→                                userID +\n   160→                                \" attempted to sell holding \" +\n   161→                                holdingID +\n   162→                                \" which has already been sold\");\n   163→\n   164→                OrderDataBean orderData = new OrderDataBean();\n   165→                orderData.setOrderStatus(\"cancelled\");\n   166→                entityManager.persist(orderData);\n   167→\n   168→                return orderData;\n   169→            }\n   170→\n   171→            QuoteDataBean quote = holding.getQuote();\n   172→            double quantity = holding.getQuantity();\n   173→\n   174→            order = createOrder(account, quote, holding, \"sell\", quantity);\n   175→\n   176→            // UPDATE the holding purchase data to signify this holding is\n   177→            // \"inflight\" to be sold\n   178→            // -- could add a new holdingStatus attribute to holdingEJB\n   179→            holding.setPurchaseDate(new java.sql.Timestamp(0));\n   180→\n   181→            // UPDATE - account should be credited during completeOrder\n   182→            BigDecimal price = quote.getPrice();\n   183→            BigDecimal orderFee = order.getOrderFee();\n   184→            BigDecimal balance = account.getBalance();\n   185→            total = (new BigDecimal(quantity).multiply(price)).subtract(\n   186→                    orderFee);\n   187→            account.setBalance(balance.add(total));\n   188→            final Integer orderID = order.getOrderID();\n   189→\n   190→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   191→                completeOrder(orderID, false);\n   192→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   193→                completeOrderAsync(orderID, false);\n   194→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   195→                queueOrder(orderID, true);\n   196→            }\n   197→        } catch (Exception e) {\n   198→            Log.error(\n   199→                    \"TradeSLSBBean:sell(\" +\n   200→                            userID +\n   201→                            \",\" +\n   202→                            holdingID +\n   203→                            \") --> failed\",\n   204→                    e);\n   205→            // if (order != null) order.cancel();\n   206→            // UPDATE - handle all exceptions like:\n   207→            throw new RuntimeException(\n   208→                    \"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \")\",\n   209→                    e);\n   210→        }\n   211→        return order;\n   212→    }\n   213→\n   214→    public void queueOrder(Integer orderID, boolean twoPhase) {\n   215→        // 2 phase\n   216→        JmsTemplate jmsTemplate = new JmsTemplate(connectionFactory);\n   217→        // Set a a queue\n   218→        jmsTemplate.setPubSubDomain(false);\n   219→\n   220→        jmsTemplate.send(\"TradeBrokerQueue\", session -> {\n   221→            TextMessage m = session.createTextMessage();\n   222→            m.setStringProperty(\"command\", \"neworder\");\n   223→            m.setIntProperty(\"orderID\", orderID);\n   224→            m.setBooleanProperty(\"twoPhase\", twoPhase);\n   225→            m.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   226→            m.setText(\"neworder: orderID=\" + orderID + \" runtimeMode=EJB twoPhase=\" + twoPhase);\n   227→            return m;\n   228→        });\n   229→    }\n   230→\n   231→    @Override\n   232→    public OrderDataBean completeOrder(Integer orderID, boolean twoPhase)\n   233→            throws Exception {\n   234→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   235→\n   236→        if (order == null) {\n   237→            System.out.println(\"error\");\n   238→            throw new RuntimeException(\n   239→                    \"Error: attempt to complete Order that is null\\n\" + order);\n   240→        }\n   241→\n   242→        order.getQuote();\n   243→\n   244→        if (order.isCompleted()) {\n   245→            throw new RuntimeException(\n   246→                    \"Error: attempt to complete Order that is already completed\\n\" +\n   247→                            order);\n   248→        }\n   249→\n   250→        AccountDataBean account = order.getAccount();\n   251→        QuoteDataBean quote = order.getQuote();\n   252→        HoldingDataBean holding = order.getHolding();\n   253→        BigDecimal price = order.getPrice();\n   254→        double quantity = order.getQuantity();\n   255→\n   256→        if (order.isBuy()) {\n   257→            /*\n   258→             * Complete a Buy operation - create a new Holding for the Account -\n   259→             * deduct the Order cost from the Account balance\n   260→             */\n   261→\n   262→            HoldingDataBean newHolding = createHolding(\n   263→                    account,\n   264→                    quote,\n   265→                    quantity,\n   266→                    price);\n   267→            order.setHolding(newHolding);\n   268→            order.setOrderStatus(\"closed\");\n   269→            order.setCompletionDate(\n   270→                    new java.sql.Timestamp(System.currentTimeMillis()));\n   271→            updateQuotePriceVolume(\n   272→                    quote.getSymbol(),\n   273→                    TradeConfig.getRandomPriceChangeFactor(),\n   274→                    quantity);\n   275→        }\n   276→\n   277→        if (order.isSell()) {\n   278→            /*\n   279→             * Complete a Sell operation - remove the Holding from the Account -\n   280→             * deposit the Order proceeds to the Account balance\n   281→             */\n   282→            if (holding == null) {\n   283→                Log.debug(\n   284→                        \"TradeSLSBBean:completeOrder -- Unable to sell order \" +\n   285→                                order.getOrderID() +\n   286→                                \" holding already sold\");\n   287→                order.cancel();\n   288→                // throw new RuntimeException(\"TradeSLSBBean:completeOrder -- Unable to sell order \"\n   289→                // + order.getOrderID() + \" holding already sold\");\n   290→            } else {\n   291→                entityManager.remove(holding);\n   292→                order.setHolding(null);\n   293→                order.setOrderStatus(\"closed\");\n   294→                order.setCompletionDate(\n   295→                        new java.sql.Timestamp(System.currentTimeMillis()));\n   296→                updateQuotePriceVolume(\n   297→                        quote.getSymbol(),\n   298→                        TradeConfig.getRandomPriceChangeFactor(),\n   299→                        quantity);\n   300→            }\n   301→        }\n   302→\n   303→        Log.trace(\n   304→                \"TradeSLSBBean:completeOrder--> Completed Order \" +\n   305→                        order.getOrderID() +\n   306→                        \"\\n\\t Order info: \" +\n   307→                        order +\n   308→                        \"\\n\\t Account info: \" +\n   309→                        account +\n   310→                        \"\\n\\t Quote info: \" +\n   311→                        quote +\n   312→                        \"\\n\\t Holding info: \" +\n   313→                        holding);\n   314→\n   315→        return order;\n   316→    }\n   317→\n   318→    @Override\n   319→    public Future<OrderDataBean> completeOrderAsync(\n   320→            Integer orderID,\n   321→            boolean twoPhase) throws Exception {\n   322→        asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   323→        return null;\n   324→    }\n   325→\n   326→    @Override\n   327→    public void cancelOrder(Integer orderID, boolean twoPhase) {\n   328→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   329→        order.cancel();\n   330→    }\n   331→\n   332→    @Override\n   333→    public void orderCompleted(String userID, Integer orderID) {\n   334→        throw new UnsupportedOperationException(\n   335→                \"TradeSLSBBean:orderCompleted method not supported\");\n   336→    }\n   337→\n   338→    @Override\n   339→    public Collection<OrderDataBean> getOrders(String userID) {\n   340→        AccountProfileDataBean profile = entityManager.find(\n   341→                AccountProfileDataBean.class,\n   342→                userID);\n   343→        AccountDataBean account = profile.getAccount();\n   344→        return account.getOrders();\n   345→    }\n   346→\n   347→    @Override\n   348→    public Collection<OrderDataBean> getClosedOrders(String userID) {\n   349→        try {\n   350→            /*\n   351→             * I want to do a CriteriaUpdate here, but there are issues with JBoss/Hibernate\n   352→             */\n   353→            CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   354→            CriteriaQuery<OrderDataBean> criteriaQuery = criteriaBuilder.createQuery(OrderDataBean.class);\n   355→            Root<OrderDataBean> orders = criteriaQuery.from(\n   356→                    OrderDataBean.class);\n   357→            criteriaQuery.select(orders);\n   358→            criteriaQuery.where(\n   359→                    criteriaBuilder.equal(\n   360→                            orders.get(\"orderStatus\"),\n   361→                            criteriaBuilder.parameter(String.class, \"p_status\")),\n   362→                    criteriaBuilder.equal(\n   363→                            orders.get(\"account\").get(\"profile\").get(\"userID\"),\n   364→                            criteriaBuilder.parameter(String.class, \"p_userid\")));\n   365→\n   366→            TypedQuery<OrderDataBean> q = entityManager.createQuery(\n   367→                    criteriaQuery);\n   368→            q.setParameter(\"p_status\", \"closed\");\n   369→            q.setParameter(\"p_userid\", userID);\n   370→            List<OrderDataBean> results = q.getResultList();\n   371→\n   372→            Iterator<OrderDataBean> itr = results.iterator();\n   373→            // Spin through the orders to remove or mark completed\n   374→            while (itr.hasNext()) {\n   375→                OrderDataBean order = itr.next();\n   376→                // TODO: Investigate ConncurrentModification Exceptions\n   377→                if (TradeConfig.getLongRun()) {\n   378→                    // Added this for Longruns (to prevent orderejb growth)\n   379→                    entityManager.remove(order);\n   380→                } else {\n   381→                    order.setOrderStatus(\"completed\");\n   382→                }\n   383→            }\n   384→\n   385→            return results;\n   386→        } catch (Exception e) {\n   387→            Log.error(\"TradeSLSBBean.getClosedOrders\", e);\n   388→            throw new RuntimeException(\"TradeSLSBBean.getClosedOrders - error\", e);\n   389→        }\n   390→    }\n   391→\n   392→    @Override\n   393→    public QuoteDataBean createQuote(\n   394→            String symbol,\n   395→            String companyName,\n   396→            BigDecimal price) {\n   397→        try {\n   398→            QuoteDataBean quote = new QuoteDataBean(\n   399→                    symbol,\n   400→                    companyName,\n   401→                    0,\n   402→                    price,\n   403→                    price,\n   404→                    price,\n   405→                    price,\n   406→                    0);\n   407→            entityManager.persist(quote);\n   408→\n   409→            Log.trace(\"TradeSLSBBean:createQuote-->\" + quote);\n   410→\n   411→            return quote;\n   412→        } catch (Exception e) {\n   413→            Log.error(\n   414→                    \"TradeSLSBBean:createQuote -- exception creating Quote\",\n   415→                    e);\n   416→            throw new RuntimeException(e);\n   417→        }\n   418→    }\n   419→\n   420→    @Override\n   421→    public QuoteDataBean getQuote(String symbol) {\n   422→        return entityManager.find(QuoteDataBean.class, symbol);\n   423→    }\n   424→\n   425→    @Override\n   426→    public Collection<QuoteDataBean> getAllQuotes() {\n   427→        TypedQuery<QuoteDataBean> query = entityManager.createNamedQuery(\n   428→                \"quoteejb.allQuotes\",\n   429→                QuoteDataBean.class);\n   430→        return query.getResultList();\n   431→    }\n   432→\n   433→    @Override\n   434→    public QuoteDataBean updateQuotePriceVolume(\n   435→            String symbol,\n   436→            BigDecimal changeFactor,\n   437→            double sharesTraded) {\n   438→        if (!TradeConfig.getUpdateQuotePrices()) {\n   439→            return new QuoteDataBean();\n   440→        }\n   441→\n   442→        Log.trace(\"TradeSLSBBean:updateQuote\", symbol, changeFactor);\n   443→\n   444→        TypedQuery<QuoteDataBean> q = entityManager.createNamedQuery(\n   445→                \"quoteejb.quoteForUpdate\",\n   446→                QuoteDataBean.class);\n   447→        q.setParameter(1, symbol);\n   448→        QuoteDataBean quote = q.getSingleResult();\n   449→\n   450→        BigDecimal oldPrice = quote.getPrice();\n   451→        BigDecimal openPrice = quote.getOpen();\n   452→\n   453→        if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n   454→            changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   455→        } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n   456→            changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   457→        }\n   458→\n   459→        BigDecimal newPrice = changeFactor\n   460→                .multiply(oldPrice)\n   461→                .setScale(2, BigDecimal.ROUND_HALF_UP);\n   462→\n   463→        quote.setPrice(newPrice);\n   464→        quote.setChange(newPrice.subtract(openPrice).doubleValue());\n   465→        quote.setVolume(quote.getVolume() + sharesTraded);\n   466→        entityManager.merge(quote);\n   467→\n   468→        if (TradeConfig.getPublishQuotePriceChange()) {\n   469→            publishQuotePriceChange(\n   470→                    quote,\n   471→                    oldPrice,\n   472→                    changeFactor,\n   473→                    sharesTraded);\n   474→        }\n   475→\n   476→        recentQuotePriceChangeList.add(quote);\n   477→\n   478→        return quote;\n   479→    }\n   480→\n   481→    @Override\n   482→    public Collection<HoldingDataBean> getHoldings(String userID) {\n   483→        CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   484→        CriteriaQuery<HoldingDataBean> criteriaQuery = criteriaBuilder.createQuery(HoldingDataBean.class);\n   485→        Root<HoldingDataBean> holdings = criteriaQuery.from(\n   486→                HoldingDataBean.class);\n   487→        criteriaQuery.where(\n   488→                criteriaBuilder.equal(\n   489→                        holdings.get(\"account\").get(\"profile\").get(\"userID\"),\n   490→                        criteriaBuilder.parameter(String.class, \"p_userid\")));\n   491→        criteriaQuery.select(holdings);\n   492→\n   493→        TypedQuery<HoldingDataBean> typedQuery = entityManager.createQuery(\n   494→                criteriaQuery);\n   495→        typedQuery.setParameter(\"p_userid\", userID);\n   496→        return typedQuery.getResultList();\n   497→    }\n   498→\n   499→    @Override\n   500→    public HoldingDataBean getHolding(Integer holdingID) {\n   501→        return entityManager.find(HoldingDataBean.class, holdingID);\n   502→    }\n   503→\n   504→    @Override\n   505→    public AccountDataBean getAccountData(String userID) {\n   506→        AccountProfileDataBean profile = entityManager.find(\n   507→                AccountProfileDataBean.class,\n   508→                userID);\n   509→        AccountDataBean account = profile.getAccount();\n   510→\n   511→        // Added to populate transient field for account\n   512→        account.setProfileID(profile.getUserID());\n   513→\n   514→        return account;\n   515→    }\n   516→\n   517→    @Override\n   518→    public AccountProfileDataBean getAccountProfileData(String userID) {\n   519→        return entityManager.find(AccountProfileDataBean.class, userID);\n   520→    }\n   521→\n   522→    @Override\n   523→    public AccountProfileDataBean updateAccountProfile(\n   524→            AccountProfileDataBean profileData) {\n   525→        AccountProfileDataBean temp = entityManager.find(\n   526→                AccountProfileDataBean.class,\n   527→                profileData.getUserID());\n   528→        temp.setAddress(profileData.getAddress());\n   529→        temp.setPassword(profileData.getPassword());\n   530→        temp.setFullName(profileData.getFullName());\n   531→        temp.setCreditCard(profileData.getCreditCard());\n   532→        temp.setEmail(profileData.getEmail());\n   533→\n   534→        entityManager.merge(temp);\n   535→\n   536→        return temp;\n   537→    }\n   538→\n   539→    @Override\n   540→    public AccountDataBean login(String userID, String password)\n   541→            throws RollbackException {\n   542→        AccountProfileDataBean profile = entityManager.find(\n   543→                AccountProfileDataBean.class,\n   544→                userID);\n   545→        if (profile == null) {\n   546→            throw new RuntimeException(\"No such user: \" + userID);\n   547→        }\n   548→\n   549→        AccountDataBean account = profile.getAccount();\n   550→        account.login(password);\n   551→\n   552→        Log.trace(\n   553→                \"TradeSLSBBean:login(\" +\n   554→                        userID +\n   555→                        \",\" +\n   556→                        password +\n   557→                        \") success\" +\n   558→                        account);\n   559→\n   560→        return account;\n   561→    }\n   562→\n   563→    @Override\n   564→    public void logout(String userID) {\n   565→        AccountProfileDataBean profile = entityManager.find(\n   566→                AccountProfileDataBean.class,\n   567→                userID);\n   568→        AccountDataBean account = profile.getAccount();\n   569→        account.logout();\n   570→\n   571→        Log.trace(\"TradeSLSBBean:logout(\" + userID + \") success\");\n   572→    }\n   573→\n   574→    @Override\n   575→    public AccountDataBean register(\n   576→            String userID,\n   577→            String password,\n   578→            String fullname,\n   579→            String address,\n   580→            String email,\n   581→            String creditcard,\n   582→            BigDecimal openBalance) {\n   583→        AccountDataBean account = null;\n   584→        AccountProfileDataBean profile = null;\n   585→\n   586→        // Check to see if a profile with the desired userID already exists\n   587→        profile = entityManager.find(AccountProfileDataBean.class, userID);\n   588→\n   589→        if (profile != null) {\n   590→            Log.error(\n   591→                    \"Failed to register new Account - AccountProfile with userID(\" +\n   592→                            userID +\n   593→                            \") already exists\");\n   594→            return null;\n   595→        } else {\n   596→            profile = new AccountProfileDataBean(\n   597→                    userID,\n   598→                    password,\n   599→                    fullname,\n   600→                    address,\n   601→                    email,\n   602→                    creditcard);\n   603→            account = new AccountDataBean(\n   604→                    0,\n   605→                    0,\n   606→                    null,\n   607→                    new Timestamp(System.currentTimeMillis()),\n   608→                    openBalance,\n   609→                    openBalance,\n   610→                    userID);\n   611→\n   612→            profile.setAccount(account);\n   613→            account.setProfile(profile);\n   614→\n   615→            entityManager.persist(profile);\n   616→            entityManager.persist(account);\n   617→        }\n   618→\n   619→        return account;\n   620→    }\n   621→\n   622→    @Transactional(propagation = Propagation.REQUIRES_NEW)\n   623→    public void publishQuotePriceChange(\n   624→            QuoteDataBean quote,\n   625→            BigDecimal oldPrice,\n   626→            BigDecimal changeFactor,\n   627→            double sharesTraded) {\n   628→        if (!TradeConfig.getPublishQuotePriceChange()) {\n   629→            return;\n   630→        }\n   631→        JmsTemplate t = new JmsTemplate(connectionFactory);\n   632→        t.setPubSubDomain(true); // This is a queue!\n   633→\n   634→        t.send(\"TradeStreamerTopic\", session -> {\n   635→            TextMessage message = session.createTextMessage();\n   636→            message.setStringProperty(\"command\", \"updateQuote\");\n   637→            message.setStringProperty(\"symbol\", quote.getSymbol());\n   638→            message.setStringProperty(\"company\", quote.getCompanyName());\n   639→            message.setStringProperty(\"price\", quote.getPrice().toString());\n   640→            message.setStringProperty(\"oldPrice\", oldPrice.toString());\n   641→            message.setStringProperty(\"open\", quote.getOpen().toString());\n   642→            message.setStringProperty(\"low\", quote.getLow().toString());\n   643→            message.setStringProperty(\"high\", quote.getHigh().toString());\n   644→            message.setDoubleProperty(\"volume\", quote.getVolume());\n   645→            message.setStringProperty(\"changeFactor\", changeFactor.toString());\n   646→            message.setDoubleProperty(\"sharesTraded\", sharesTraded);\n   647→            message.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   648→            message.setText(\n   649→                    \"Update Stock price for \" +\n   650→                            quote.getSymbol() +\n   651→                            \" old price = \" +\n   652→                            oldPrice +\n   653→                            \" new price = \" +\n   654→                            quote.getPrice());\n   655→            return message;\n   656→        });\n   657→\n   658→    }\n   659→\n   660→    public OrderDataBean createOrder(\n   661→            AccountDataBean account,\n   662→            QuoteDataBean quote,\n   663→            HoldingDataBean holding,\n   664→            String orderType,\n   665→            double quantity) {\n   666→        OrderDataBean order;\n   667→\n   668→        try {\n   669→            order = new OrderDataBean(\n   670→                    orderType,\n   671→                    \"open\",\n   672→                    new Timestamp(System.currentTimeMillis()),\n   673→                    null,\n   674→                    quantity,\n   675→                    quote\n   676→                            .getPrice()\n   677→                            .setScale(FinancialUtils.SCALE, FinancialUtils.ROUND),\n   678→                    TradeConfig.getOrderFee(orderType),\n   679→                    account,\n   680→                    quote,\n   681→                    holding);\n   682→            entityManager.persist(order);\n   683→        } catch (Exception e) {\n   684→            Log.error(\n   685→                    \"TradeSLSBBean:createOrder -- failed to create Order. The stock/quote may not exist in the database.\",\n   686→                    e);\n   687→            throw new RuntimeException(\n   688→                    \"TradeSLSBBean:createOrder -- failed to create Order. Check that the symbol exists in the database.\",\n   689→                    e);\n   690→        }\n   691→        return order;\n   692→    }\n   693→\n   694→    private HoldingDataBean createHolding(\n   695→            AccountDataBean account,\n   696→            QuoteDataBean quote,\n   697→            double quantity,\n   698→            BigDecimal purchasePrice) throws Exception {\n   699→        HoldingDataBean newHolding = new HoldingDataBean(\n   700→                quantity,\n   701→                purchasePrice,\n   702→                new Timestamp(System.currentTimeMillis()),\n   703→                account,\n   704→                quote);\n   705→        entityManager.persist(newHolding);\n   706→        return newHolding;\n   707→    }\n   708→\n   709→    @Override\n   710→    public double investmentReturn(double investment, double NetValue)\n   711→            throws Exception {\n   712→        double diff = NetValue - investment;\n   713→        double ir = diff / investment;\n   714→        return ir;\n   715→    }\n   716→\n   717→    @Override\n   718→    public QuoteDataBean pingTwoPhase(String symbol) {\n   719→    QuoteDataBean quoteData = null;\n   720→\n   721→    try {\n   722→        // === DB work (unchanged) ===\n   723→        quoteData = entityManager.find(QuoteDataBean.class, symbol);\n   724→\n   725→        double sharesTraded = (Math.random() * 100) + 1;\n   726→        BigDecimal oldPrice   = quoteData.getPrice();\n   727→        BigDecimal openPrice  = quoteData.getOpen();\n   728→        BigDecimal changeFactor = new BigDecimal(Math.random() * 100);\n   729→\n   730→        BigDecimal newPrice = changeFactor\n   731→            .multiply(oldPrice)\n   732→            .setScale(2, BigDecimal.ROUND_HALF_UP);\n   733→\n   734→        quoteData.setPrice(newPrice);\n   735→        quoteData.setChange(newPrice.subtract(openPrice).doubleValue());\n   736→        quoteData.setVolume(quoteData.getVolume() + sharesTraded);\n   737→        entityManager.merge(quoteData);\n   738→\n   739→        // === JMS send (Spring) ===\n   740→        JmsTemplate t = new JmsTemplate(connectionFactory);\n   741→        t.setPubSubDomain(false); // queue\n   742→\n   743→        // prefer destination by name to avoid needing a Queue bean/JNDI\n   744→        t.send(\"TradeBrokerQueue\", session -> {\n   745→            TextMessage m = session.createTextMessage();\n   746→            m.setStringProperty(\"command\", \"ping\");\n   747→            m.setLongProperty(\"publishTime\", System.currentTimeMillis());\n   748→            m.setText(\"Ping message for TradeBrokerQueue sent from TradeSLSBBean:pingTwoPhase at \" + new Date());\n   749→            return m;\n   750→        });\n   751→\n   752→    } catch (Exception e) {\n   753→        Log.error(\"TradeSLSBBean:pingTwoPhase -- exception caught\", e);\n   754→    }\n   755→\n   756→    return quoteData;\n   757→    }\n   758→\n   759→    class quotePriceComparator implements Comparator<QuoteDataBean> {\n   760→\n   761→        @Override\n   762→        public int compare(QuoteDataBean quote1, QuoteDataBean quote2) {\n   763→            double change1 = quote1.getChange();\n   764→            double change2 = quote2.getChange();\n   765→            return new Double(change2).compareTo(change1);\n   766→        }\n   767→    }\n   768→\n   769→    @Override\n   770→    public int getImpl() {\n   771→        return TradeConfig.EJB3;\n   772→    }\n   773→\n   774→    @Override\n   775→    public void setInSession(boolean inSession) {\n   776→        throw new UnsupportedOperationException(\n   777→                \"TradeSLSBBean::setInGlobalTxn not supported\");\n   778→    }\n   779→}\n   780→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"f1f89b09-76c7-411d-8241-5aa2f3d11d6f"}
