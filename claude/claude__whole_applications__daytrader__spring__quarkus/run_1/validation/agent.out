{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_bdrk_01VPWeu1zYr7duMbGk92JvoU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_013ibfHAT45tYqTvrPqs43gj","name":"Write","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__daytrader__spring__quarkus/run_1/output/smoke.py","content":"#!/usr/bin/env python3\n\"\"\"Smoke tests for DayTrader application migrated to Quarkus.\"\"\"\n\nimport os\nimport sys\nimport time\nimport urllib.request\nimport urllib.error\nimport json\n\nBASE_URL = os.environ.get(\"SMOKE_BASE_URL\", \"http://localhost:8080\")\nCONTEXT = \"/daytrader\"\n\ndef url(path):\n    return f\"{BASE_URL}{CONTEXT}{path}\"\n\ndef get(path, expect_status=200):\n    \"\"\"Make a GET request and return (status_code, body).\"\"\"\n    req = urllib.request.Request(url(path))\n    try:\n        resp = urllib.request.urlopen(req, timeout=15)\n        body = resp.read().decode(\"utf-8\", errors=\"replace\")\n        status = resp.getcode()\n    except urllib.error.HTTPError as e:\n        body = e.read().decode(\"utf-8\", errors=\"replace\") if e.fp else \"\"\n        status = e.code\n    except Exception as e:\n        print(f\"  FAIL: {path} -> Exception: {e}\")\n        return None, str(e)\n\n    if status != expect_status:\n        print(f\"  FAIL: GET {path} -> status {status} (expected {expect_status})\")\n        print(f\"        body (first 200 chars): {body[:200]}\")\n        return status, body\n    return status, body\n\ndef test_health():\n    \"\"\"Test that the app is reachable (root or welcome page).\"\"\"\n    print(\"Test: health/root endpoint\")\n    # Try a simple servlet ping first\n    status, body = get(\"/servlet/PingServlet\")\n    if status == 200:\n        print(\"  PASS: /servlet/PingServlet returned 200\")\n        return True\n    # Fallback: try root\n    status, body = get(\"/\")\n    if status is not None and status < 500:\n        print(f\"  PASS: root returned status {status}\")\n        return True\n    print(\"  FAIL: Could not reach any health endpoint\")\n    return False\n\ndef test_ping_servlet():\n    \"\"\"Test PingServlet is accessible.\"\"\"\n    print(\"Test: PingServlet\")\n    status, body = get(\"/servlet/PingServlet\")\n    if status == 200 and \"Ping\" in body:\n        print(\"  PASS: PingServlet responded with Ping content\")\n        return True\n    # Try alternate path\n    status, body = get(\"/PingServlet\")\n    if status == 200:\n        print(\"  PASS: PingServlet responded at /PingServlet\")\n        return True\n    print(f\"  WARN: PingServlet returned status={status}\")\n    return False\n\ndef test_ping_jsonp():\n    \"\"\"Test PingJSONP servlets.\"\"\"\n    print(\"Test: PingJSONP endpoints\")\n    for path in [\"/servlet/PingJSONPObject\", \"/PingJSONPObject\"]:\n        status, body = get(path)\n        if status == 200:\n            print(f\"  PASS: {path} returned 200\")\n            return True\n    print(\"  WARN: No JSONP endpoint responded\")\n    return False\n\ndef test_config_page():\n    \"\"\"Test config page is accessible (if JSP is enabled).\"\"\"\n    print(\"Test: config page\")\n    status, body = get(\"/config.jsp\")\n    if status == 200:\n        print(\"  PASS: config.jsp returned 200\")\n        return True\n    # JSPs may not work in Quarkus, so this is expected\n    print(f\"  INFO: config.jsp returned {status} (JSPs may not be available in Quarkus)\")\n    return True  # Not a failure since JSPs are optional\n\ndef test_welcome_page():\n    \"\"\"Test welcome page.\"\"\"\n    print(\"Test: welcome page\")\n    for path in [\"/welcome.jsp\", \"/\", \"\"]:\n        status, body = get(path)\n        if status is not None and 200 <= status < 400:\n            print(f\"  PASS: {path or '/'} returned {status}\")\n            return True\n    print(\"  INFO: No welcome page found (expected for Quarkus without JSP)\")\n    return True  # Not critical\n\ndef test_primitives():\n    \"\"\"Test primitive servlets that should work.\"\"\"\n    print(\"Test: Primitive servlets\")\n    passed = 0\n    tested = 0\n    for servlet in [\"PingServlet\", \"PingServletWriter\", \"PingJSONPObject\"]:\n        for prefix in [\"/servlet/\", \"/\"]:\n            tested += 1\n            status, body = get(f\"{prefix}{servlet}\")\n            if status == 200:\n                passed += 1\n                print(f\"  PASS: {prefix}{servlet}\")\n                break\n    print(f\"  Result: {passed} of {len(['PingServlet','PingServletWriter','PingJSONPObject'])} primitive servlets passed\")\n    return passed > 0\n\ndef wait_for_app(max_wait=120):\n    \"\"\"Wait for the application to start.\"\"\"\n    print(f\"Waiting for app at {BASE_URL}{CONTEXT} (max {max_wait}s)...\")\n    start = time.time()\n    while time.time() - start < max_wait:\n        try:\n            req = urllib.request.Request(url(\"/servlet/PingServlet\"))\n            resp = urllib.request.urlopen(req, timeout=5)\n            if resp.getcode() < 500:\n                print(f\"  App is ready (took {int(time.time()-start)}s)\")\n                return True\n        except Exception:\n            pass\n        # Also try root\n        try:\n            req = urllib.request.Request(url(\"/\"))\n            resp = urllib.request.urlopen(req, timeout=5)\n            if resp.getcode() < 500:\n                print(f\"  App is ready (took {int(time.time()-start)}s)\")\n                return True\n        except Exception:\n            pass\n        time.sleep(3)\n    print(f\"  App did not start within {max_wait}s\")\n    return False\n\n\ndef main():\n    if not wait_for_app():\n        print(\"FAIL: Application did not start\")\n        sys.exit(1)\n\n    results = []\n    results.append((\"health\", test_health()))\n    results.append((\"ping_servlet\", test_ping_servlet()))\n    results.append((\"ping_jsonp\", test_ping_jsonp()))\n    results.append((\"welcome_page\", test_welcome_page()))\n    results.append((\"config_page\", test_config_page()))\n    results.append((\"primitives\", test_primitives()))\n\n    print(\"\\n=== SMOKE TEST RESULTS ===\")\n    passed = sum(1 for _, r in results if r)\n    total = len(results)\n    for name, result in results:\n        print(f\"  {'PASS' if result else 'FAIL'}: {name}\")\n    print(f\"\\n{passed}/{total} tests passed\")\n\n    if passed < total:\n        sys.exit(1)\n    sys.exit(0)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":803,"cache_read_input_tokens":117872,"cache_creation":{"ephemeral_5m_input_tokens":803,"ephemeral_1h_input_tokens":0},"output_tokens":1902},"context_management":null},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"172eb262-2832-406c-ba77-7fa9dd615bda"}
