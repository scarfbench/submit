{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01FtJ8ffYh8nKR2qKip9cVpv","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015, 2022.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.web.servlet;\n    17→\n    18→import java.io.IOException;\n    19→import java.util.ArrayList;\n    20→import java.util.Collection;\n    21→import java.util.List;\n    22→\n    23→import jakarta.inject.Inject;\n    24→\n    25→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    26→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    27→import com.ibm.websphere.samples.daytrader.util.Diagnostics;\n    28→import com.ibm.websphere.samples.daytrader.util.Log;\n    29→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    30→\n    31→import jakarta.servlet.Filter;\n    32→import jakarta.servlet.FilterChain;\n    33→import jakarta.servlet.FilterConfig;\n    34→import jakarta.servlet.ServletException;\n    35→import jakarta.servlet.ServletRequest;\n    36→import jakarta.servlet.ServletResponse;\n    37→import jakarta.servlet.annotation.WebFilter;\n    38→import jakarta.servlet.http.HttpServletRequest;\n    39→\n    40→@WebFilter(filterName = \"OrdersAlertFilter\", urlPatterns = \"/app\")\n    41→@Trace\n    42→public class OrdersAlertFilter implements Filter {\n    43→\n    44→    private TradeServices tradeAction;\n    45→\n    46→    @Inject\n    47→    @jakarta.enterprise.inject.Any\n    48→    jakarta.enterprise.inject.Instance<TradeServices> tradeServicesInstance;\n    49→\n    50→    public OrdersAlertFilter() {\n    51→        // Default constructor for servlet container\n    52→    }\n    53→\n    54→    /**\n    55→     * @see Filter#init(FilterConfig)\n    56→     */\n    57→    private FilterConfig filterConfig = null;\n    58→\n    59→    @Override\n    60→    public void init(FilterConfig filterConfig) throws ServletException {\n    61→        this.filterConfig = filterConfig;\n    62→        // Resolve TradeServices implementation by configured runtime mode using CDI\n    63→        String key = TradeConfig.getRunTimeModeNames()[TradeConfig.getRunTimeMode()];\n    64→        for (TradeServices ts : tradeServicesInstance) {\n    65→            String beanName = getBeanName(ts);\n    66→            if (key.equals(beanName)) {\n    67→                this.tradeAction = ts;\n    68→                break;\n    69→            }\n    70→        }\n    71→        if (this.tradeAction == null) {\n    72→            List<String> available = new ArrayList<>();\n    73→            for (TradeServices ts : tradeServicesInstance) {\n    74→                available.add(getBeanName(ts));\n    75→            }\n    76→            throw new IllegalStateException(\"No TradeServices bean named '\" + key + \"' (available: \" + available + \")\");\n    77→        }\n    78→    }\n    79→\n    80→    private String getBeanName(TradeServices ts) {\n    81→        // CDI proxy classes need getSuperclass() to find the actual class with annotations\n    82→        Class<?> clazz = ts.getClass();\n    83→        jakarta.inject.Named named = clazz.getAnnotation(jakarta.inject.Named.class);\n    84→        if (named == null && clazz.getSuperclass() != null) {\n    85→            named = clazz.getSuperclass().getAnnotation(jakarta.inject.Named.class);\n    86→        }\n    87→        if (named != null && !named.value().isEmpty()) {\n    88→            return named.value();\n    89→        }\n    90→        // Check superclass for qualifier annotations too\n    91→        Class<?> realClass = clazz;\n    92→        if (realClass.getSuperclass() != null && realClass.getSuperclass() != Object.class) {\n    93→            realClass = realClass.getSuperclass();\n    94→        }\n    95→        if (realClass.getAnnotation(com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC.class) != null) {\n    96→            return \"Direct (JDBC)\";\n    97→        }\n    98→        if (realClass.getAnnotation(com.ibm.websphere.samples.daytrader.interfaces.TradeEJB.class) != null) {\n    99→            return \"Full EJB3\";\n   100→        }\n   101→        if (realClass.getAnnotation(com.ibm.websphere.samples.daytrader.interfaces.TradeSession2Direct.class) != null) {\n   102→            return \"Session to Direct\";\n   103→        }\n   104→        // Default to simple class name\n   105→        String simpleName = realClass.getSimpleName();\n   106→        return simpleName;\n   107→    }\n   108→\n   109→    /**\n   110→     * @see Filter#doFilter(ServletRequest, ServletResponse, FilterChain)\n   111→     */\n   112→    @Override\n   113→    public void doFilter(\n   114→            ServletRequest req,\n   115→            ServletResponse resp,\n   116→            FilterChain chain) throws IOException, ServletException {\n   117→        if (filterConfig == null) {\n   118→            return;\n   119→        }\n   120→\n   121→        if (TradeConfig.getDisplayOrderAlerts() == true) {\n   122→            try {\n   123→                String action = req.getParameter(\"action\");\n   124→                if (action != null) {\n   125→                    action = action.trim();\n   126→                    if ((action.length() > 0) && (!action.equals(\"logout\"))) {\n   127→                        String userID;\n   128→                        if (action.equals(\"login\")) {\n   129→                            userID = req.getParameter(\"uid\");\n   130→                        } else {\n   131→                            userID = (String) ((HttpServletRequest) req).getSession().getAttribute(\n   132→                                    \"uidBean\");\n   133→                        }\n   134→\n   135→                        if ((userID != null) && (userID.trim().length() > 0)) {\n   136→                            Collection<?> closedOrders = tradeAction.getClosedOrders(userID);\n   137→                            if ((closedOrders != null) &&\n   138→                                    (closedOrders.size() > 0)) {\n   139→                                req.setAttribute(\"closedOrders\", closedOrders);\n   140→                            }\n   141→                            if (Log.doTrace()) {\n   142→                                Log.printCollection(\n   143→                                        \"OrderAlertFilter: userID=\" +\n   144→                                                userID +\n   145→                                                \" closedOrders=\",\n   146→                                        closedOrders);\n   147→                            }\n   148→                        }\n   149→                    }\n   150→                }\n   151→            } catch (Exception e) {\n   152→                Log.error(\n   153→                        e,\n   154→                        \"OrdersAlertFilter - Error checking for closedOrders\");\n   155→            }\n   156→        }\n   157→\n   158→        Diagnostics.checkDiagnostics();\n   159→\n   160→        chain.doFilter(req, resp /* wrapper */);\n   161→    }\n   162→\n   163→    /**\n   164→     * @see Filter#destroy()\n   165→     */\n   166→    @Override\n   167→    public void destroy() {\n   168→        this.filterConfig = null;\n   169→    }\n   170→}\n   171→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"56efa089-e1a8-4ed6-8ae5-0ef3f5d72aa6","uuid":"3e0240f0-c56e-4b49-a346-e0e615dd92e8"}
