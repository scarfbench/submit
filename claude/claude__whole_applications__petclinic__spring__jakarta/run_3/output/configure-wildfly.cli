# WildFly CLI script to configure H2 datasource for PetClinic

# Start in embedded mode
embed-server --server-config=standalone.xml

# WildFly already ships with an H2 driver, so just add the datasource
data-source add --name=PetClinicDS --jndi-name=java:jboss/datasources/PetClinicDS --driver-name=h2 --connection-url=jdbc:h2:mem:petclinic;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE --user-name=sa --password=sa

stop-embedded-server
