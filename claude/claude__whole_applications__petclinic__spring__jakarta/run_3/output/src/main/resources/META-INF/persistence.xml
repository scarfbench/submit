<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="petclinicPU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/PetClinicDS</jta-data-source>

        <class>org.petclinic.model.BaseEntity</class>
        <class>org.petclinic.model.NamedEntity</class>
        <class>org.petclinic.model.Person</class>
        <class>org.petclinic.model.Owner</class>
        <class>org.petclinic.model.Pet</class>
        <class>org.petclinic.model.PetType</class>
        <class>org.petclinic.model.Visit</class>
        <class>org.petclinic.model.Vet</class>
        <class>org.petclinic.model.Specialty</class>

        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
