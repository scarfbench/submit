    52→        List<Pet> petList = petService.getAll();\n    53→        PetListDto dto = this.petEndpointUtil.dtoListFactory(petList);\n    54→        log.info(dto.toString());\n    55→        log.info(\"------------------------------------------------------------\");\n    56→        return dto.getPet();\n    57→    }\n    58→\n    59→    @GET\n    60→    @Path(\"/list+json\")\n    61→    @Produces(MediaType.APPLICATION_JSON)\n    62→    public List<PetDto> getListAsJson() {\n    63→        log.info(\"------------------------------------------------------------\");\n    64→        log.info(\"getList\");\n    65→        log.info(\"------------------------------------------------------------\");\n    66→        List<Pet> petList = petService.getAll();\n    67→        PetListDto dto = this.petEndpointUtil.dtoListFactory(petList);\n    68→        log.info(dto.toString());\n    69→        log.info(\"------------------------------------------------------------\");\n    70→        return dto.getPet();\n    71→    }\n    72→\n    73→    @GET\n    74→    @Path(\"/{id}\")\n    75→    @Produces(MediaType.APPLICATION_JSON)\n    76→    public PetDto getEntity(@PathParam(\"id\") Long id) {\n    77→        log.info(\"------------------------------------------------------------\");\n    78→        log.info(\"getEntity\");\n    79→        log.info(\"------------------------------------------------------------\");\n    80→        return this.petEndpointUtil.dtoFactory(petService.findById(id));\n    81→    }\n    82→\n    83→    @GET\n    84→    @Path(\"/{id}+json\")\n    85→    @Produces(MediaType.APPLICATION_JSON)\n    86→    public PetDto getEntityAsJson(@PathParam(\"id\") Long id) {\n    87→        log.info(\"------------------------------------------------------------\");\n    88→        log.info(\"getEntity\");\n    89→        log.info(\"------------------------------------------------------------\");\n    90→        PetDto oPetDto = this.petEndpointUtil.dtoFactory(petService.fi