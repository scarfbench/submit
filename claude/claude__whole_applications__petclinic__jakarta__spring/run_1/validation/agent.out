    54→public class PetType implements Comparable<PetType>, Serializable {\n    55→\n    56→    public final static String TABLENAME = \"owner_pet_pettype\";\n    57→    public final static String COL_ID = \"id\";\n    58→    public final static String COL_UUID = \"uuid\";\n    59→    public final static String COL_NAME = \"name\";\n    60→    public final static String COL_SEARCHINDEX = \"searchindex\";\n    61→    private static final long serialVersionUID = -2213412509142145275L;\n    62→\n    63→    @Id\n    64→    @GeneratedValue(strategy = GenerationType.SEQUENCE, generator = \"owner_pet_pettype_gen\")\n    65→    @SequenceGenerator(name=\"owner_pet_pettype_gen\", sequenceName=\"owner_pet_pettype_seq\")\n    66→    private Long id;\n    67→\n    68→    @Column(name = COL_UUID, nullable = false, unique = true, length = 36)\n    69→    private UUID uuid;\n    70→\n    71→    @Column(name = COL_SEARCHINDEX, nullable = true)\n    72→    private String searchindex;\n    73→\n    74→    @NotEmpty\n    75→    @Column(name = COL_NAME, nullable = false, unique = true)\n    76→    private String name;\n    77→\n    78→    public static PetType newEntity(){\n    79→        PetType p = new PetType();\n    80→        p.uuid = UUID.randomUUID();\n    81→        p.searchindex = \"\";\n    82→        p.name = \"\";\n    83→        return p;\n    84→    }\n    85→\n    86→    public static PetType newEntity(@NotBlank String name){\n    87→        PetType p = new PetType();\n    88→        p.uuid = UUID.randomUUID();\n    89→        p.searchindex = \"\";\n    90→        p.name = name;\n    91→        return p;\n    92→    }\n    93→\n    94→    public void updateSearchindex() {\n    95→        String[] element = this.getName().split(\"\\\\W\");\n    96→        StringBuilder b = new StringBuilder();\n    97→        for(String e: element){\n    98→            b.append(e);\n    99→            b.append(\" \");\n   100→        }\n   101→        this.setSearchindex(b.toString());\n  