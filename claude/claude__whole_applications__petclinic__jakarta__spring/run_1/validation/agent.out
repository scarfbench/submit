{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01T1w185QnCxMDBHjHkPnmtx","type":"tool_result","content":"     1→package org.woehlke.jakartaee.petclinic.specialty.db;\n     2→\n     3→import jakarta.ejb.Stateless;\n     4→import jakarta.persistence.EntityManager;\n     5→import jakarta.persistence.PersistenceContext;\n     6→import lombok.extern.java.Log;\n     7→import org.woehlke.jakartaee.petclinic.specialty.Specialty;\n     8→\n     9→import jakarta.annotation.PostConstruct;\n    10→import jakarta.annotation.PreDestroy;\n    11→import jakarta.persistence.TypedQuery;\n    12→\n    13→import java.io.Serializable;\n    14→import java.util.List;\n    15→import java.util.UUID;\n    16→\n    17→/**\n    18→ * Created with IntelliJ IDEA.\n    19→ * User: tw\n    20→ * Date: 04.01.14\n    21→ * Time: 12:03\n    22→ * To change this template use File | Settings | File Templates.\n    23→ */\n    24→@Log\n    25→@Stateless\n    26→public class SpecialtyDaoImpl implements SpecialtyDao, Serializable {\n    27→\n    28→    private static final long serialVersionUID = 1355422039564914705L;\n    29→\n    30→    @PersistenceContext(unitName = PERSISTENCE_UNIT_NAME)\n    31→    private EntityManager entityManager;\n    32→\n    33→    @Override\n    34→    public List<Specialty> getAll() {\n    35→        //String qlString = \"select s from Specialty s order by s.name\";\n    36→        TypedQuery<Specialty> q = entityManager.createNamedQuery( \"Specialty.getAll\", Specialty.class);\n    37→        return q.getResultList();\n    38→    }\n    39→\n    40→    @Override\n    41→    public Specialty findById(long id) {\n    42→        Specialty specialty = entityManager.find(Specialty.class, id);\n    43→        return specialty;\n    44→    }\n    45→\n    46→    @Override\n    47→    public Specialty findSpecialtyByName(String name) {\n    48→        //String ql = \"select s from Specialty s where s.name=:name\";\n    49→        TypedQuery<Specialty> query = entityManager.createNamedQuery(\n    50→                \"Specialty.findSpecialtyByName\", Specialty.class\n    51→        );\n    52→        query.setParameter(\"name\", name);\n    53→        return query.getSingleResult();\n    54→    }\n    55→\n    56→    @Override\n    57→    public void delete(long id) {\n    58→        Specialty specialty = entityManager.find(Specialty.class, id);\n    59→        entityManager.remove(specialty);\n    60→    }\n    61→\n    62→    @Override\n    63→    public Specialty addNew(Specialty specialty) {\n    64→        specialty.setUuid(UUID.randomUUID());\n    65→        specialty = updateSearchindex(specialty);\n    66→        log.info(\"addNewSpecialty: \" + specialty.toString());\n    67→        entityManager.persist(specialty);\n    68→        log.info(\"persisted:       \" + specialty.toString());\n    69→        return specialty;\n    70→    }\n    71→\n    72→    @Override\n    73→    public Specialty update(Specialty specialty) {\n    74→        specialty = updateSearchindex(specialty);\n    75→        log.info(\"update: \" + specialty.toString());\n    76→        specialty = entityManager.merge(specialty);\n    77→        log.info(\"merged: \" + specialty.toString());\n    78→        return specialty;\n    79→    }\n    80→\n    81→    //TODO: move method to Specialty classs\n    82→    private Specialty updateSearchindex(Specialty specialty) {\n    83→        String element[] = specialty.getName().split(\"\\\\W\");\n    84→        StringBuilder b = new StringBuilder();\n    85→        for(String e: element){\n    86→            b.append(e);\n    87→            b.append(\" \");\n    88→        }\n    89→        specialty.setSearchindex(b.toString());\n    90→        return specialty;\n    91→    }\n    92→\n    93→    @Override\n    94→    public List<Specialty> search(String searchterm) {\n    95→        log.info(\"search Specialty for: \" + searchterm);\n    96→        //String qlString = \"select v from Speci