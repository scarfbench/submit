   @EJB\n    54→    private PetTypeService entityService;\n    55→\n    56→    private PetType entity;\n    57→    private List<PetType> list;\n    58→    private String searchterm;\n    59→\n    60→\n    61→    @Override\n    62→    public String showDetailsForm(PetType o) {\n    63→        log.info(\"---------------------------------------------------------------------------\");\n    64→        log.info(\"showDetailsForm\");;\n    65→        log.info(\"---------------------------------------------------------------------------\");\n    66→        if (o != null) {\n    67→            this.entity = entityService.findById(o.getId());\n    68→            this.petTypeViewFlow.setFlowStateDetails();\n    69→        } else {\n    70→            this.petTypeViewFlow.setFlowStateList();\n    71→        }\n    72→        return JSF_PAGE;\n    73→    }\n    74→\n    75→    @Override\n    76→    public  String cancelDetails(){\n    77→        log.info(\"---------------------------------------------------------------------------\");\n    78→        log.info(\"cancelDetails\");\n    79→        log.info(\"---------------------------------------------------------------------------\");\n    80→        this.petTypeViewFlow.setFlowStateList();\n    81→        return JSF_PAGE;\n    82→    }\n    83→\n    84→    @Override\n    85→    public String showNewForm() {\n    86→        log.info(\"---------------------------------------------------------------------------\");\n    87→        log.info(\"showNewForm\");\n    88→        log.info(\"---------------------------------------------------------------------------\");\n    89→        this.newEntity();\n    90→        this.petTypeViewFlow.setFlowStateNew();\n    91→        return JSF_PAGE;\n    92→    }\n    93→\n    94→    @Override\n    95→    public String cancelNew() {\n    96→        log.info(\"---------------------------------------------------------------------------\");\n    97→        log.info(\"cancelNew\");\n    98→        log.