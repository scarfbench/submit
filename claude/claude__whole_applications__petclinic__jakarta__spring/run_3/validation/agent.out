                    <configuration>\n  2439→                            <runtimeArtifact>\n  2440→                                <groupId>io.openliberty</groupId>\n  2441→                                <artifactId>openliberty-runtime</artifactId>\n  2442→                                <version>${version.openliberty-runtime}</version>\n  2443→                            </runtimeArtifact>\n  2444→                            <!--<installDirectory>D:/appsvr/wlp</installDirectory>-->\n  2445→                            <!--<installDirectory>${project.build.directory}/liberty/wlp</installDirectory>-->\n  2446→                            <copyDependencies>\n  2447→                                <dependencyGroup>\n  2448→                                    <location>${server.config.dir}</location>\n  2449→                                    <stripVersion>true</stripVersion>\n  2450→                                    <dependency>\n  2451→                                        <groupId>org.postgresql</groupId>\n  2452→                                        <artifactId>postgresql</artifactId>\n  2453→                                    </dependency>\n  2454→                                </dependencyGroup>\n  2455→                            </copyDependencies>\n  2456→                        </configuration>\n  2457→                    </plugin>\n  2458→                    <plugin>\n  2459→                        <groupId>org.apache.maven.plugins</groupId>\n  2460→                        <artifactId>maven-surefire-plugin</artifactId>\n  2461→                        <configuration>\n  2462→                            <skipTests>${skip.unit.tests}</skipTests>\n  2463→                        </configuration>\n  2464→                    </plugin>\n  2465→                    <plugin>\n  2466→                        <groupId>org.apache.maven.plugins</groupId>\n  2467→                        <artifactId>maven-failsafe-plugin</artifactId>\n  2468→                        <dependencies>\n  2469→                            <dependency>\n  2470→                                <groupId>org.junit.jupiter</groupId>\n  2471→                                <artifactId>junit-jupiter-engine</artifactId>\n  2472→                                <version>${junit.version}</version>\n  2473→                            </dependency>\n  2474→                        </dependencies>\n  2475→                    </plugin>\n  2476→                </plugins>\n  2477→            </build>\n  2478→        </profile>\n  2479→\n  2480→        <profile>\n  2481→            <!-- Run with: mvn clean verify -Parq-liberty-managed -->\n  2482→            <id>arq-liberty-managed</id>\n  2483→            <properties>\n  2484→                <skip.unit.tests>true</skip.unit.tests>\n  2485→                <skip.integration.tests>false</skip.integration.tests>\n  2486→                <serverStartTimeout>240</serverStartTimeout>\n  2487→            </properties>\n  2488→            <dependencies>\n  2489→                <dependency>\n  2490→                    <groupId>io.openliberty.arquillian</groupId>\n  2491→                    <artifactId>arquillian-liberty-managed-jakarta</artifactId>\n  2492→                    <version>${version.arquillian-liberty-managed-jakarta}</version>\n  2493→                    <exclusions>\n  2494→                        <exclusion>\n  2495→                            <groupId>org.apache.httpcomponents</groupId>\n  2496→                            <artifactId>httpclient</artifactId>\n  2497→                        </exclusion>\n  2498→                    </exclusions>\n  2499→                </dependency>\n  2500→                <!--It seems OpenLiberty 21.0.0.1 beta switched to use Resteasy as Jakarta Restful WS provider.\n  2501→                But there is no official public version for Jakarta EE 9 in the Maven central repository.\n  2502→                Use Jersey Client in the test codes here.-->\n  2503→                <dependency>\n  2504→                    <groupId>org.glassfish.jersey.media</groupId>\n  2505→                    <artifactId>jersey-media-json-binding</artifactId>\n  2506→                    <version>${jersey.version}</version>\n  2507→                    <scope>test</scope>\n  2508→                </dependency>\n  2509→                <dependency>\n  2510→                    <groupId>org.glassfish.jersey.inject</groupId>\n  2511→                    <artifactId>jersey-hk2</artifactId>\n  2512→                    <version>${jersey.version}</version>\n  2513→                    <scope>test</scope>\n  2514→                </dependency>\n  2515→                <dependency>\n  2516→                    <groupId>org.glassfish.jersey.core</groupId>\n  2517→                    <artifactId>jersey-client</artifactId>\n  2518→                    <version>${jersey.version}</version>\n  2519→                    <scope>test</scope>\n  2520→                </dependency>\n  2521→            </dependencies>\n  2522→            <build>\n  2523→                <finalName>petclinic</finalName>\n  2524→                <defaultGoal>dependency:purge-local-repository clean verify</defaultGoal>\n  2525→                <testResources>\n  2526→                    <testResource>\n  2527→                        <directory>src/test/runtimes/arq-liberty-managed</directory>\n  2528→                        <includes>\n  2529→                            <include>*</include>\n  2530→                        </includes>\n  2531→                        <excludes>\n  2532→                            <exclude>server.xml</exclude>\n  2533→                        </excludes>\n  2534→                    </testResource>\n  2535→                    <testResource>\n  2536→                        <directory>src/test/runtimes/arq-liberty-managed</directory>\n  2537→                        <includes>\n  2538→                            <include>server.xml</include>\n  2539→                        </includes>\n  2540→                        <targetPath>\n  2541→                            ${project.build.directory}/wlp/usr/servers/defaultServer\n  2542→                        </targetPath>\n  2543→                    </testResource>\n  2544→                </testResources>\n  2545→                <plugins>\n  2546→                    <plugin>\n  2547→                        <groupId>org.apache.maven.plugins</groupId>\n  2548→                        <artifactId>maven-dependency-plugin</artifactId>\n  2549→                        <version>${version.maven-dependency-plugin}</version>\n  2550→                        <executions>\n  2551→                            <execution>\n  2552→                                <id>unpack</id>\n  2553→                                <phase>pre-integration-test</phase>\n  2554→                                <goals>\n  2555→                                    <goal>unpack</goal>\n  2556→                                </goals>\n  2557→                                <configuration>\n  2558→                                    <artifactItems>\n  2559→                                        <artifactItem>\n  2560→                                            <groupId>io.openliberty.beta</groupId>\n  2561→                                            <artifactId>openliberty-runtime</artifactId>\n  2562→                                            <version>${liberty.runtime.version}</version>\n  2563→                                            <type>zip</type>\n  2564→                                            <overWrite>false</overWrite>\n  2565→                                            <outputDirectory>${project.build.directory}</outputDirectory>\n  2566→                                        </artifactItem>\n  2567→                                        <artifactItem>\n  2568→                                            <groupId>io.openliberty.arquillian</groupId>\n  2569→                                            <artifactId>arquillian-liberty-support-jakarta