                                    </includes>\n  2629→                                        </resource>\n  2630→                                        <resource>\n  2631→                                            <directory>src/main/runtimes/liberty/resources</directory>\n  2632→                                        </resource>\n  2633→                                    </resources>\n  2634→                                    <overwrite>true</overwrite>\n  2635→                                </configuration>\n  2636→                                <phase>process-resources</phase>\n  2637→                                <goals>\n  2638→                                    <goal>resources</goal>\n  2639→                                </goals>\n  2640→                            </execution>\n  2641→                        </executions>\n  2642→                    </plugin>\n  2643→                    <plugin>\n  2644→                        <groupId>org.apache.maven.plugins</groupId>\n  2645→                        <artifactId>maven-surefire-plugin</artifactId>\n  2646→                        <configuration>\n  2647→                            <skipTests>${skip.unit.tests}</skipTests>\n  2648→                        </configuration>\n  2649→                    </plugin>\n  2650→                    <plugin>\n  2651→                        <groupId>org.apache.maven.plugins</groupId>\n  2652→                        <artifactId>maven-failsafe-plugin</artifactId>\n  2653→                        <version>${version.maven-failsafe-plugin}</version>\n  2654→                        <configuration>\n  2655→                            <environmentVariables>\n  2656→                                <!-- WLP_HOME is not picked by arquillian liberty -->\n  2657→                                <!--<WLP_HOME>${project.build.directory}/wlp</WLP_HOME>-->\n  2658→                            </environmentVariables>\n  2659→                            <systemPropertyVariables>\n  2660→                                <arquillian.launch>liberty-managed</arquillian.launch>\n  2661→                                <java.util.logging.config.file>${project.build.testOutputDirectory}/logging.properties\n  2662→                                </java.util.logging.config.file>\n  2663→                            </systemPropertyVariables>\n  2664→                        </configuration>\n  2665→                    </plugin>\n  2666→                </plugins>\n  2667→            </build>\n  2668→        </profile>\n  2669→\n  2670→        <profile>\n  2671→            <id>wildfly</id>\n  2672→            <properties>\n  2673→                <skip.unit.tests>true</skip.unit.tests>\n  2674→                <skip.integration.tests>true</skip.integration.tests>\n  2675→            </properties>\n  2676→            <dependencyManagement>\n  2677→                <dependencies>\n  2678→                    <dependency>\n  2679→                        <groupId>org.jboss.logmanager</groupId>\n  2680→                        <artifactId>jboss-logmanager</artifactId>\n  2681→                        <version>${version.jboss-logmanager}</version>\n  2682→                        <scope>test</scope>\n  2683→                        <exclusions>\n  2684→                            <exclusion>\n  2685→                                <groupId>org.wildfly.common</groupId>\n  2686→                                <artifactId>wildfly-common</artifactId>\n  2687→                            </exclusion>\n  2688→                        </exclusions>\n  2689→                    </dependency>\n  2690→                    <dependency>\n  2691→                        <groupId>org.postgresql</groupId>\n  2692→                        <artifactId>postgresql</artifactId>\n  2693→                        <version>${version.postgresql.driver}</version>\n  2694→                    </dependency>\n  2695→                    <dependency>\n  2696→                        <groupId>org.jboss.resteasy<