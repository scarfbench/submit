       </build>\n  3164→        </profile>\n  3165→\n  3166→        <profile>\n  3167→            <!-- An optional Arquillian testing profile that executes tests in your\n  3168→                WildFly instance -->\n  3169→            <!-- This profile will start a new WildFly instance, and execute the test,\n  3170→                shutting it down when done -->\n  3171→            <!-- Run with: mvn clean verify -Parq-wildfly-remote -->\n  3172→            <id>arq-wildfly-remote</id>\n  3173→            <properties>\n  3174→                <skip.unit.tests>false</skip.unit.tests>\n  3175→                <skip.integration.tests>false</skip.integration.tests>\n  3176→                <serverProfile>standalone-full.xml</serverProfile>\n  3177→                <serverRoot>${project.build.directory}/wildfly-${wildfly.version}</serverRoot>\n  3178→                <cargo.remote.username>wildfly</cargo.remote.username>\n  3179→                <cargo.remote.password>wildflypwd</cargo.remote.password>\n  3180→                <cargo.jboss.configuration>standalone</cargo.jboss.configuration>\n  3181→                <skipAfterFailureCount>1</skipAfterFailureCount>\n  3182→                <rerunFailingTestsCount>1</rerunFailingTestsCount>\n  3183→                <!--\n  3184→\t\t\t\t<cargo.datasource.datasource.postgresql>\n  3185→\t\t\t\t\tcargo.datasource.driver=org.postgresql.Driver|\n  3186→\t\t\t\t\tcargo.datasource.url=jdbc:postgresql://localhost:5432/petclinic_jakartaee_wildfly\n  3187→\t\t\t\t\tcargo.datasource.jndi=jboss/datasources/PostgreSQLDS|\n  3188→\t\t\t\t\tcargo.datasource.username=petclinic_jakartaee|\n  3189→\t\t\t\t\tcargo.datasource.password=petclinic_jakartaeepwd\n  3190→\t\t\t\t</cargo.datasource.datasource.postgresql>\n  3191→\t\t\t\t-->\n  3192→            </properties>\n  3193→            <dependencies>\n  3194→                <!--<dependency>\n  3195→                    <groupId>io.undertow</groupId>\n  3196→                    <artifactId>undertow-websockets-jsr</artifactId>\n  3197→                    <version>${undertow-websockets-jsr.version}</version>\n  3198→                    <scope>test</scope>\n  3199→                </dependency>-->\n  3200→\n  3201→                <!-- TESTS -->\n  3202→                <!-- JAXRS test need the dependency:resteasy-client -->\n  3203→                <!-- Import the RestEasy Client and jackson2/json-binding/json-p provider, we use test scope\n  3204→                    as we need that for test purposes -->\n  3205→                <!--<dependency>\n  3206→                    <groupId>org.jboss.resteasy</groupId>\n  3207→                    <artifactId>resteasy-client</artifactId>\n  3208→                    <version>${resteasy.version}</version>\n  3209→                    <scope>test</scope>\n  3210→                </dependency>\n  3211→                <dependency>\n  3212→                    <groupId>org.jboss.resteasy</groupId>\n  3213→                    <artifactId>resteasy-jackson2-provider</artifactId>\n  3214→                    <version>${resteasy.version}</version>\n  3215→                    <scope>test</scope>\n  3216→                </dependency>-->\n  3217→                <dependency>\n  3218→                    <groupId>org.jboss.logmanager</groupId>\n  3219→                    <artifactId>jboss-logmanager</artifactId>\n  3220→                    <version>${version.jboss-logmanager}</version>\n  3221→                    <scope>test</scope>\n  3222→                    <exclusions>\n  3223→                        <exclusion>\n  3224→                            <groupId>org.wildfly.common</groupId>\n  3225→                            <artifactId>wildfly-common</artifactId>\n  3226→                        </exclusion>\n  3227→                    </exclusions>\n  3228→                </dependency>\n  3229→                <dependency>\n  3230→                    <groupId>org.wildfly.arquillian</groupId>\n  3231→                    <artifactId>wildfly-arquillian-container-managed</artifactId>\n  3232→                    <version>${version.wildfly-arquillian}</version>\n  3233→                    <scope>test</scope>\n  3234→                </dependency>\n  3235→                <!--\n  3236→\t\t\t\t<dependency>\n  3237→\t\t\t\t\t<groupId>org.jboss.logmanager</groupId>\n  3238→\t\t\t\t\t<artifactId>jboss-logmanager</artifactId>\n  3239→\t\t\t\t\t<version>${version.jboss-logmanager}</version>\n  3240→\t\t\t\t\t<scope>test</scope>\n  3241→\t\t\t\t</dependency>\n  3242→\t\t\t\t-->\n  3243→                <!-- use Jersey client instead -->\n  3244→                <dependency>\n  3245→                    <groupId>org.glassfish.jersey.media</groupId>\n  3246→                    <artifactId>jersey-media-json-binding</artifactId>\n  3247→                    <version>${jersey.version}</version>\n  3248→                    <scope>test</scope>\n  3249→                </dependency>\n  3250→                <dependency>\n  3251→                    <groupId>org.glassfish.jersey.inject</groupId>\n  3252→                    <artifactId>jersey-hk2</artifactId>\n  3253→                    <version>${jersey.version}</version>\n  3254→                    <scope>test</scope>\n  3255→                </dependency>\n  3256→                <dependency>\n  3257→                    <groupId>org.glassfish.jersey.core</groupId>\n  3258→                    <artifactId>jersey-client</artifactId>\n  3259→                    <version>${jersey.version}</version>\n  3260→                    <scope>test</scope>\n  3261→                </dependency>\n  3262→                <dependency>\n  3263→                    <groupId>org.postgresql</groupId>\n  3264→                    <artifactId>postgresql</artifactId>\n  3265→                    <version>${version.postgresql.driver}</version>\n  3266→                </dependency>\n  3267→            </dependencies>\n  3268→            <build>\n  3269→                <finalName>petclinic</finalName>\n  3270→                <defaultGoal>dependency:purge-local-repository clean package verify</defaultGoal>\n  3271→                <testResources>\n  3272→                    <testResource>\n  3273→                        <directory>src/test/runtimes/arq-wildfly-remote</directory>\n  3274→                        <includes>\n  3275→                            <include>*</include>\n  3276→                        </includes>\n  3277→                    </testResource>\n  3278→                </testResources>\n  3279→                <plugins>\n  3280→                    <plugin>\n  3281→                        <groupId>org.apache.maven.plugins</groupId>\n  3282→                        <artifactId>maven-dependency-plugin</artifactId>\n  3283→                        <executions>\n  3284→                            <execution>\n  3285→                                <id>unpack</id>\n  3286→                                <phase>pre-integration-test</phase>\n  3287→                                <goals>\n  3288→                                    <goal>unpack</goal>\n  3289→                                </goals>\n  3290→                                <configuration>\n  3291→                                    <artifactItems>\n  3292→                                        <artifactItem>\n  3293→                                            <groupId>org.wildfly</groupId>\n  3294→                                            <artifactId>wildfly-dist</artifactId>\n  3295→                                            <version>${wildfly.version}</version>\n  3296→                                            <type>zip</type>\n  3297→                                            <overWrite>false</overWrite>\n  3298→                                            <outputDirectory>${project.build.directory}</outputDirectory>\n  3299→                                        </artifactItem>\n  3300→                                    </artifactItems>\n  3301→                                </configuration>\n  3302→                            </execution>\n  3303→                        </executions>\n  3304→                    </plugin>\n  3305→                    <plugin>\n  3306→                        <groupId>org.apache.maven.plugins</groupId>\n  3307→                        <artifactId>maven-resources-plugin</artifactId>\n  3308→                        <executions>\n  3309→                            <execution>\n  3310→                                <id>id-runtimes-resources</id>\n  3311→                                <configuration>\n  3312→                                    <resources>\n  3313→                                        <resource>\n  3314→                                            <directory>src/main/runtimes/wildfly/resources/META-INF</directory>\n  3315→                                        </resource>\n  3316→                                    </resources>\n  3317→                                    <outputDirectory>target/petclinic/WEB-INF/classes/META-INF</outputDirectory>\n  3318→                                    <overwrite>true</overwrite>\n  3319→                                </configuration>\n  3320→                                <phase>prepare-package</phase>\n  3321→                                <goals>\n  3322→                                    <goal>copy-resources</goal>\n  3323→                                </goals>\n  3324→                            </execution>\n  3325→                            <execution>\n  3326→                                <id>id-runtimes-webapps</id>\n  3327→                                <configuration>\n  3328→                                    <resources>\n  3329→                                        <resource>\n  3330→                                            <directory>src/main/runtimes/wildfly/webapp/WEB-INF</directory>\n  3331→                                        </resource>\n  3332→                                    </resources>\n  3333→                                    <outputDirectory>target/petclinic/WEB-INF</outputDirectory>\n  3334→                                    <overwrite>true</overwrite>\n  3335→                                </configuration>\n  3336→                                <phase>prepare-package</phase>\n  3337→                                <goals>\n  3338→                                    <goal>copy-resources</goal>\n  3339→                                </goals>\n  3340→                            </execution>\n  3341→                            <execution>\n  3342→                                <id>default-resources</id>\n  3343→                                <configuration>\n  3344→                                    <propertiesEncoding>UTF-8</propertiesEncoding>\n  3345→                                    <resources>\n  3346→                                        <resource>\n  3347→                                            <directory>src/main/resources</directory>\n  3348→                                            <includes>\n  3349→                                                <include>**/Messages.properties</include>\n  3350→                                                <include>**/Messages_de.properties</include>\n  3351→                                                <include>**/Messages_en.properties</include>\n  3352→                                            </includes>\n  3353→                                        </resource>\n  3354→                                        <resource>\n  3355→                                            <directory>src/main/runtimes/wildfly/resources</directory>\n  3356→                                        </resource>\n  3357→                                    </resources>\n  3358→                                    <overwrite>true</overwrite>\n  3359→                                </configuration>\n  3360→                                <phase>process-resources</phase>\n  3361→                                <goals>\n  3362→                                    <goal>resources</goal>\n  3363→                                </goals>\n  3364→                            </execution>\n  3365→                        </executions>\n  3366→                    </plugin>\n  3367→                    <plugin>\n  3368→                        <groupId>org.apache.maven.plugins</groupId>\n  3369→                        <artifactId>maven-surefire-plugin</artifactId>\n  3370→                        <configuration>\n  3371→                            <skipTests>${skip.unit.tests}</skipTests>\n  3372→                            <systemProperties>\n  3373→                                <property>\n  3374→                                    <name>skipAfterFailureCount</name>\n  3375→                                    <value>1</value>\n  3376→                                </property>\n  3377→                                <!--\n  3378→\t\t\t\t\t\t\t\t<property>\n  3379→\t\t\t\t\t\t\t\t\t<name>rerunFailingTestsCount</name>\n  3380→\t\t\t\t\t\t\t\t\t<value>true</value>\n  3381→\t\t\t\t\t\t\t\t</property>\n  3382→\t\t\t\t\t\t\t\t-->\n  3383→                            </systemProperties>\n  3384→                        </configuration>\n  3385→                    </plugin>\n  3386→                    <plugin>\n  3387→                        <groupId>org.apache.maven.plugins</groupId>\n  3388→                        <artifactId>maven-failsafe-plugin</artifactId>\n  3389→                        <configuration>\n  3390→                            <skipTests>${skip.integration.tests}</skipTests>\n  3391→                            <environmentVariables>\n  3392→                                <JBOSS_HOME>${project.build.directory}/wildfly-${wildfly.version}</JBOSS_HOME>\n  3393→                            </environmentVariables>\n  3394→                            <systemPropertyVariables>\n  3395→                                <arquillian.launch>wildfly-remote</arquillian.launch>\n  3396→                                <serverConfig>standalone-full.xml</serverConfig>\n  3397→                                <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n  3398→                            </systemPropertyVariables>\n  3399→                        </configuration>\n  3400→                    </plugin>\n  3401→                </plugins>\n  3402→            </build>\n  3403→        </profile>\n  3404→\n  3405→\n  3406→        <profile>\n  3407→            <id>glassfish</id>\n  3408→            <properties>\n  3409→                <skip.unit.tests>true</skip.unit.tests>\n  3410→                <skip.integration.tests>true</skip.integration.tests>\n  3411→                <cargo.glassfish.admin.port>4848</cargo.glassfish.admin.port>\n  3412→                <glassfish.home>${project.build.directory}/glassfish-${glassfish.version}</glassfish.home>\n  3413→                <glassfish.domainDir>\n  3414→                    ${project.build.directory}/glassfish-${glassfish.version}/glassfish7/glassfish/domains/domain1\n  3415→                </glassfish.domainDir>\n  3416→            </properties>\n  3417→            <dependencyManagement>\n  3418→                <dependencies>\n  3419→                    <dependency>\n  3420→                        <groupId>org.jboss.logmanager</groupId>\n  3421→                        <artifactId>jboss-logmanager</artifactId>\n  3422→                        <version>${version.jboss-logmanager}</version>\n  3423→                        <scope>test</scope>\n  3424→                    </dependency>\n  3425→                    <dependency>\n  3426→                        <groupId>org.postgresql</groupId>\n  3427→                        <artifactId>postgresql</artifactId>\n  3428→                        <version>${version.postgresql.driver}</version>\n  3429→                    </dependency>\n  3430→                    <dependency>\n  3431→                        <groupId>org.jboss.resteasy</groupId>\n  3432→                        <artifactId>resteasy-client</artifactId>\n  3433→                        <version>${version.org.jboss.resteasy}</version>\n  3434→                        <scope>test</scope>\n  3435→                    </dependency>\n  3436→                    <dependency>\n  3437→                        <groupId>org.jboss.resteasy</groupId>\n  3438→                        <artifactId>resteasy-json-binding-provider</artifactId>\n  3439→                        <version>${version.org.jboss.resteasy}</version>\n  3440→                        <scope>test</scope>\n  3441→                    </dependency>\n  3442→                    <dependency>\n  3443→                        <groupId>org.jboss.resteasy</groupId>\n  3444→                        <artifactId>resteasy-jaxb-provider</artifactId>\n  3445→                        <version>${version.org.jboss.resteasy}</version>\n  3446→                        <scope>test</scope>\n  3447→                    </dependency>\n  3448→                    <dependency>\n  3449→                        <groupId>org.glassfish</groupId>\n  3450→                        <artifactId>jakarta.json</artifactId>\n  3451→                        <version>${version.jakarta.json}</version>\n  3452→                        <scope>test</scope>\n  3453→                    </dependency>\n  3454→                    <!--\n  3455→\t\t\t\t\t<dependency>\n  3456→\t\t\t\t\t\t<groupId>org.apache.commons</groupId>\n  3457→\t\t\t\t\t\t<artifactId>commons-lang3</artifactId>\n  3458→\t\t\t\t\t\t<version>${version.apache.commons.commons-lang3}</version>\n  3459→\t\t\t\t\t</dependency>\n  3460→\t\t\t\t\t-->\n  3461→                </dependencies>\n  3462→            </dependencyManagement>\n  3463→            <dependencies>\n  3464→                <dependency>\n  3465→                    <groupId>org.jboss.logmanager</groupId>\n  3466→                    <artifactId>jboss-logmanager</artifactId>\n  3467→                    <scope>test</scope>\n  3468→                </dependency>\n  3469→                <dependency>\n  3470→                    <groupId>org.jboss.resteasy</groupId>\n  3471→                    <artifactId>resteasy-client</artifactId>\n  3472→                    <scope>test</scope>\n  3473→                </dependency>\n  3474→                <dependency>\n  3475→                    <groupId>org.jboss.resteasy</groupId>\n  3476→                    <artifactId>resteasy-json-binding-provider</artifactId>\n  3477→                    <scope>test</scope>\n  3478→                </dependency>\n  3479→                <dependency>\n  3480→                    <groupId>org.jboss.resteasy</groupId>\n  3481→                    <artifactId>resteasy-jaxb-provider</artifactId>\n  3482→                    <scope>test</scope>\n  3483→                </dependency>\n  3484→                <dependency>\n  3485→                    <groupId>org.glassfish</groupId>\n  3486→                    <artifactId>jakarta.json</artifactId>\n  3487→                    <scope>test</scope>\n  3488→                </dependency>\n  3489→                <!--\n  3490→\t\t\t\t<dependency>\n  3491→\t\t\t\t\t<groupId>org.apache.commons</groupId>\n  3492→\t\t\t\t\t<artifactId>commons-lang3</artifactId>\n  3493→\t\t\t\t</dependency>\n  3494→\t\t\t\t-->\n  3495→            </dependencies>\n  3496→            <build>\n  3497→                <finalName>petclinic</finalName>\n  3498→                <defaultGoal>clean dependency:tree package verify org.codehaus.cargo:cargo-maven3-plugin:run\n  3499→                </defaultGoal>\n  3500→                <pluginManagement>\n  3501→                    <plugins>\n  3502→                        <plugin>\n  3503→                            <groupId>org.apache.maven.plugins</groupId>\n  3504→                            <artifactId>maven-resources-plugin</artifactId>\n  3505→                            <version>${version.maven-resources-plugin}</version>\n  3506→                        </plugin>\n  3507→                        <plugin>\n  3508→                            <groupId>org.codehaus.cargo</groupId>\n  3509→                            <artifactId>cargo-maven3-plugin</artifactId>\n  3510→                            <version>${version.cargo-maven3-plugin}</version>\n  3511→                        </plugin>\n  3512→                        <plugin>\n  3513→                            <groupId>org.apache.maven.plugins</groupId>\n  3514→                            <artifactId>maven-deploy-plugin</artifactId>\n  3515→                            <version>${version.maven-deploy-plugin}</version>\n  3516→                        </plugin>\n  3517→                        <plugin>\n  3518→                            <groupId>org.apache.maven.plugins</groupId>\n  3519→                            <artifactId>maven-failsafe-plugin</artifactId>\n  3520→                            <version>${version.maven-failsafe-plugin}</version>\n  3521→                        </plugin>\n  3522→                        <plugin>\n  3523→                            <groupId>org.apache.maven.plugins</groupId>\n  3524→                            <artifactId>maven-surefire-plugin</artifactId>\n  3525→                            <version>${version.maven-surefire-plugin}</version>\n  3526→                        </plugin>\n  3527→                    </plugins>\n  3528→                </pluginManagement>\n  3529→                <plugins>\n  3530→                    <plugin>\n  3531→                        <groupId>org.apache.maven.plugins</groupId>\n  3532→                        <artifactId>maven-resources-plugin</artifactId>\n  3533→                        <executions>\n  3534→                            <execution>\n  3535→                                <id>id-persistence-xml</id>\n  3536→                                <configuration>\n  3537→                                    <resources>\n  3538→                                        <resource>\n  3539→                                            <directory>src/main/runtimes/glassfish/resources/META-INF</directory>\n  3540→                                        </resource>\n  3541→                                    </resources>\n  3542→                                    <outputDirectory>src/main/resources/META-INF</outputDirectory>\n  3543→                                    <overwrite>true</overwrite>\n  3544→                                </configuration>\n  3545→                                <phase>clean</phase>\n  3546→                                <goals>\n  3547→                                    <goal>copy-resources</goal>\n  3548→                                </goals>\n  3549→                            </execution>\n  3550→                            <execution>\n  3551→                                <id>id-runtimes-webapps</id>\n  3552→                                <configuration>\n  3553→                                    <resources>\n  3554→                                        <resource>\n  3555→                                            <directory>src/main/runtimes/glassfish/webapp/WEB-INF</directory>\n  3556→                                        </resource>\n  3557→                                    </resources>\n  3558→                                    <outputDirectory>target/petclinic/WEB-INF</outputDirectory>\n  3559→                                    <overwrite>true</overwrite>\n  3560→                                </configuration>\n  3561→                                <phase>prepare-package</phase>\n  3562→                                <goals>\n  3563→                                    <goal>copy-resources</goal>\n  3564→                                </goals>\n  3565→                            </execution>\n  3566→                            <execution>\n  3567→                                <id>default-resources</id>\n  3568→                                <configuration>\n  3569→                                    <propertiesEncoding>UTF-8</propertiesEncoding>\n  3570→                        