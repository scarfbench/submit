rectory\n    32→WORKDIR /app\n    33→\n    34→# Copy all the assets\n    35→COPY . .\n    36→\n    37→# Build the Spring Boot application (skip tests during build)\n    38→RUN pg_lsclusters | tail -1 | awk '{print $1, $2}' > /tmp/pgver.txt \\\n    39→    && PG_VERSION=$(cut -d' ' -f1 /tmp/pgver.txt) \\\n    40→    && PG_CLUSTER=$(cut -d' ' -f2 /tmp/pgver.txt) \\\n    41→    && pg_ctlcluster ${PG_VERSION} ${PG_CLUSTER} start \\\n    42→    && sleep 2 \\\n    43→    && mvn clean package -DskipTests \\\n    44→    && pg_ctlcluster ${PG_VERSION} ${PG_CLUSTER} stop\n    45→\n    46→RUN if [ -f smoke.py ]; then chmod +x smoke.py; fi\n    47→\n    48→# Start PostgreSQL and run the Spring Boot jar\n    49→CMD pg_lsclusters | tail -1 | awk '{print $1, $2}' > /tmp/pgver.txt \\\n    50→    && PG_VERSION=$(cut -d' ' -f1 /tmp/pgver.txt) \\\n    51→    && PG_CLUSTER=$(cut -d' ' -f2 /tmp/pgver.txt) \\\n    52→    && pg_ctlcluster ${PG_VERSION} ${PG_CLUSTER} start \\\n    53→    && sleep 2 \\\n    54→    && java -jar target/petclinic-spring-10.0.0.18-SNAPSHOT.jar\n    55→"}]},"parent_tool_use_id":null,"session_id":"8a6bcbcb-6946-47c7-9325-248dd051e737","uuid":"a2f62fbf-7c93-4a11-8f79-ca34cb7ce0bd"}
