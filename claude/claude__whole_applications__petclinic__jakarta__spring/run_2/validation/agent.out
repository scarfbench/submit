 lastName;\n\n    @ManyToMany(fetch = FetchType.EAGER)\n    @JoinTable(\n        name = \"vet_specialties\",\n        joinColumns = @JoinColumn(name = \"vet_id\"),\n        inverseJoinColumns = @JoinColumn(name = \"specialty_id\")\n    )\n    @ToString.Exclude\n    private Set<Specialty> specialties = new HashSet<>();\n\n    @PrePersist\n    @PreUpdate\n    public void prePersist() {\n        StringBuilder sb = new StringBuilder();\n        sb.append(this.firstName).append(\" \").append(this.lastName);\n        if (this.specialties != null) {\n            for (Specialty specialty : this.specialties) {\n                sb.append(\" \").append(specialty.getName());\n            }\n        }\n        this.searchindex = sb.toString().toLowerCase();\n    }\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":783,"cache_read_input_tokens":18204,"cache_creation":{"ephemeral_5m_input_tokens":783,"ephemeral_1h_input_tokens":0},"output_tokens":850},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01WjnxDpGTxVv7YaJZqQuaGb","session_id":"f1542671-6929-49f9-9925-fcf6260de3ab","uuid":"af33166a-5054-4bb5-890d-68831a07ab85"}
