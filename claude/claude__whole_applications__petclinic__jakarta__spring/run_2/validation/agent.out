r=all\" />\n    41→\t<logging jsonAccessLogFields=\"logFormat\"/>\n    42→\n    43→\t<remoteFileAccess>\n    44→\t\t<writeDir>${server.config.dir}/dropins</writeDir>\n    45→\t</remoteFileAccess>\n    46→\n    47→\t<serverCommands startServerTimeout=\"240\" stopServerTimeout=\"240\"/>\n    48→\n    49→\t<variable name=\"io_openliberty_guides_system_inMaintenance\" value=\"false\"/>\n    50→\n    51→\t<dataSource id=\"DefaultDataSource\"\n    52→\t            jdbcDriverRef=\"postgresqlDriver\"\n    53→\t            jndiName=\"jdbc/datasources/PostgreSQLDS\"\n    54→\t            transactional=\"true\"\n    55→\t            type=\"javax.sql.ConnectionPoolDataSource\">\n    56→\n    57→\t\t<properties databaseName=\"petclinic_jakartaee_liberty\"\n    58→\t\t            password=\"petclinic_jakartaeepwd\"\n    59→\t\t            portNumber=\"5432\"\n    60→\t\t            serverName=\"localhost\"\n    61→\t\t            user=\"petclinic_jakartaee\"/>\n    62→\t</dataSource>\n    63→\n    64→\t<jdbcDriver id=\"postgresqlDriver\"\n    65→\t            javax.sql.ConnectionPoolDataSource=\"org.postgresql.ds.PGConnectionPoolDataSource\"\n    66→\t            javax.sql.XADataSource=\"org.postgresql.xa.PGXADataSource\"\n    67→\t            libraryRef=\"postgresqlLibrary\"/>\n    68→\n    69→\t<library id=\"postgresqlLibrary\">\n    70→\t\t<file name=\"${server.config.dir}/lib/global/postgresql.jar\"/>\n    71→\t</library>\n    72→\n    73→\t<applicationManager autoExpand=\"true\"/>\n    74→\n    75→\t<trustAssociation id=\"petclinicSso\" disableLtpaCookie=\"false\" />\n    76→\n    77→\t<ssl id=\"defaultSSLConfig\" trustDefaultCerts=\"true\" verifyHostname=\"false\"/>\n    78→\n    79→\t<keyStore id=\"defaultKeyStore\" password=\"mpKeystore\"/>\n    80→\n    81→\t<logging maxFfdcAge=\"2d\"/>\n    82→\n    83→\t<application location=\"petclinic.war\" type=\"war\"\n    84→\t\t\t\t id=\"petclinic.war\"\n    85→\t\t\t\t name=\"petclinic.war\" context-root=\"/petclinic\">\n    86→