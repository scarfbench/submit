{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Gdnzhf5RWhc7uoHogKDMCR","type":"tool_result","content":"     1→package org.woehlke.jakartaee.petclinic.vet;\n     2→\n     3→import lombok.Getter;\n     4→import lombok.Setter;\n     5→import lombok.extern.java.Log;\n     6→import org.primefaces.model.DualListModel;\n     7→import org.woehlke.jakartaee.petclinic.application.conf.PetclinicApplication;\n     8→import org.woehlke.jakartaee.petclinic.application.views.FlashMessagesView;\n     9→import org.woehlke.jakartaee.petclinic.application.views.LanguageView;\n    10→import org.woehlke.jakartaee.petclinic.specialty.Specialty;\n    11→import org.woehlke.jakartaee.petclinic.specialty.db.SpecialtyService;\n    12→import org.woehlke.jakartaee.petclinic.vet.db.VetService;\n    13→\n    14→import jakarta.annotation.PostConstruct;\n    15→import jakarta.annotation.PreDestroy;\n    16→import jakarta.ejb.EJB;\n    17→import jakarta.ejb.EJBException;\n    18→import jakarta.ejb.EJBTransactionRolledbackException;\n    19→import jakarta.enterprise.context.SessionScoped;\n    20→import jakarta.inject.Inject;\n    21→import jakarta.inject.Named;\n    22→import org.woehlke.jakartaee.petclinic.vet.views.VetFlowViewImpl;\n    23→\n    24→import java.io.Serializable;\n    25→import java.util.*;\n    26→\n    27→/**\n    28→ * Created with IntelliJ IDEA.\n    29→ * User: tw\n    30→ * Date: 01.01.14\n    31→ * Time: 22:59\n    32→ * To change this template use File | Settings | File Templates.\n    33→ */\n    34→@Log\n    35→@Getter\n    36→@Setter\n    37→@Named(\"vetView\")\n    38→@SessionScoped\n    39→public class VetViewImpl implements VetView, Serializable {\n    40→\n    41→    private static final long serialVersionUID = 2838339162976374606L;\n    42→\n    43→    @Inject\n    44→    private PetclinicApplication petclinicApplication;\n    45→\n    46→    @Inject\n    47→    private LanguageView languageView;\n    48→\n    49→    @Inject\n    50→    private FlashMessagesView flashMessagesView;\n    51→\n    52→    @Inject\n    53→    private VetFlowViewImpl vetViewFlow;\n    54→\n    55→    @EJB\n    56→    private SpecialtyService specialtyService;\n    57→\n    58→    @EJB\n    59→    private VetService entityService;\n    60→\n    61→\n    62→    private Vet entity;\n    63→    private DualListModel<Specialty> specialtiesPickList;\n    64→    private List<Vet> list;\n    65→    private String searchterm;\n    66→\n    67→\n    68→    @Override\n    69→    public String showDetailsForm(Vet o) {\n    70→        log.info(\"showDetailsForm\");;\n    71→        if (o != null) {\n    72→            this.entity = entityService.findById(o.getId());\n    73→            this.resetSpecialtiesPickList();\n    74→            this.vetViewFlow.setFlowStateDetails();\n    75→        } else {\n    76→            this.vetViewFlow.setFlowStateList();\n    77→        }\n    78→        return JSF_PAGE;\n    79→    }\n    80→\n    81→    @Override\n    82→    public  String cancelDetails(){\n    83→        log.info(\"cancelDetails\");\n    84→        this.vetViewFlow.setFlowStateList();\n    85→        return JSF_PAGE;\n    86→    }\n    87→\n    88→    @Override\n    89→    public String showNewForm() {\n    90→        log.info(\"showNewForm\");\n    91→        this.newEntity();\n    92→        this.resetSpecialtiesPickList();\n    93→        this.vetViewFlow.setFlowStateNew();\n    94→        return JSF_PAGE;\n    95→    }\n    96→\n    97→    @Override\n    98→    public String cancelNew() {\n    99→        log.info(\"cancelNew\");\n   100→        this.vetViewFlow.setFlowStateList();\n   101→        return JSF_PAGE;\n   102→    }\n   103→\n   104→    @Override\n   105→    public String saveNew() {\n   106→        log.info(\"saveNew\");\n   107→        this.saveNewEntity();\n   108→        this.vetViewFlow.setFlowStateDetails();\n   109→        return JSF_PAGE;\n   110→    }\n   111→\n   112→    @Override\n   113→    public String showEditForm() {\n   114→        log.info(\"showEditForm\");\n   115→        if (this.entity != null) {\n   116→            this.resetSpecialtiesPickList();\n   117→            this.vetViewFlow.setFlowStateEdit();\n   118→        } else {\n   119→            this.vetViewFlow.setFlowStateList();\n   120→        }\n   121→        return JSF_PAGE;\n   122→    }\n   123→\n   124→    @Override\n   125→    public String cancelEdited() {\n   126→        log.info(\"cancelEdited\");\n   127→        this.vetViewFlow.setFlowStateDetails();\n   128→        return JSF_PAGE;\n   129→    }\n   130→\n   131→    @Override\n   132→    public String saveEdited() {\n   133→        log.info(\"saveEdited\");\n   134→        this.saveEditedEntity();\n   135→        this.vetViewFlow.setFlowStateDetails();\n   136→        return JSF_PAGE;\n   137→    }\n   138→\n   139→    @Override\n   140→    public String showDeleteForm() {\n   141→        log.info(\"showDeleteForm\");\n   142→        if (this.entity != null) {\n   143→            this.vetViewFlow.setFlowStateDelete();\n   144→        } else {\n   145→            this.vetViewFlow.setFlowStateList();\n   146→        }\n   147→        return JSF_PAGE;\n   148→    }\n   149→\n   150→    @Override\n   151→    public String cancelDelete() {\n   152→        log.info(\"cancelDelete\");\n   153→        this.vetViewFlow.setFlowStateDetails();\n   154→        return JSF_PAGE;\n   155→    }\n   156→\n   157→    @Override\n   158→    public String performDelete() {\n   159→        log.info(\"performDelete\");\n   160→        this.deleteSelectedEntity();\n   161→        this.vetViewFlow.setFlowStateList();\n   162→        return JSF_PAGE;\n   163→    }\n   164→\n   165→    @Override\n   166→    public String clearSearchterm(){\n   167→        log.info(\"clearSearchterm\");\n   168→        this.searchterm = null;\n   169→        this.vetViewFlow.setFlowStateList();\n   170→        return JSF_PAGE;\n   171→    }\n   172→\n   173→    @Override\n   174→    public String search() {\n   175→        log.info(\"search\");\n   176→        this.performSearch();\n   177→        return JSF_PAGE;\n   178→    }\n   179→\n   180→\n   181→    @Override\n   182→    public void loadList() {\n   183→        this.list = this.entityService.getAll();\n   184→    }\n   185→\n   186→    @Override\n   187→    public void newEntity() {\n   188→        log.info(\"newEntity\");\n   189→        this.entity = new Vet();\n   190→    }\n   191→\n   192→    @Override\n   193→    public void saveNewEntity() {\n   194→        log.info(\"saveNewEntity\");\n   195→        try {\n   196→            log.info(\"try to save New: \" + this.entity.toString());\n   197→            this.entity.removeSpecialties();\n   198→            this.entity.setUuid(UUID.randomUUID());\n   199→            this.entity = entityService.addNew(this.entity);\n   200→            this.entity = entityService.findById(this.entity.getId());\n   201→            log.info(\"nr source: \" + this.specialtiesPickList.getSource().size());\n   202→            log.info(\"nr target: \" + this.specialtiesPickList.getTarget().size());\n   203→            for (Specialty specialtyTransient : this.specialtiesPickList.getTarget()) {\n   204→                Specialty specialty = specialtyService.findSpecialtyByName(specialtyTransient.getName());\n   205→                this.entity.addSpecialty(specialty);\n   206→            }\n   207→            this.entity = entityService.update(this.entity);\n   208→            log.info(\"saved New: \" + this.entity.toString());\n   209→            String summaryKey = \"org.woehlke.jakartaee.petclinic.veterinarian.addNew.done\";\n   210→            String summary = this.petclinicApplication.getMsg().getString(summaryKey);\n   211→            flashMessagesView.addInfoMessage(summary, this.entity);\n   212→        } catch (EJBException e) {\n   213→            log.info(e.getMessage() + this.entity.toString());\n   214→            flashMessagesView.addWarnMessage(e, this.entity);\n   215→        }\n   216→    }\n   217→\n   218→    @Override\n   219→    public void saveEditedEntity() {\n   220→        log.info(\"saveEditedEntity\");\n   221→        try {\n   222→            this.entity.removeSpecialties();\n   223→            for (Specialty specialtyTransient : this.specialtiesPickList.getTarget()) {\n   224→                log.info(\" added transient via saveEditedEntity: \" + specialtyTransient.getPrimaryKeyWithId());\n   225→                Specialty specialty = specialtyService.findSpecialtyByName(specialtyTransient.getName());\n   226→                this.entity.addSpecialty(specialty);\n   227→            }\n   228→            this.entity = entityService.update(this.entity);\n   229→            String summaryKey = \"org.woehlke.jakartaee.petclinic.veterinarian.edit.done\";\n   230→            String summary = this.petclinicApplication.getMsg().getString(summaryKey);\n   231→            flashMessagesView.addInfoMessage(summary, this.entity);\n   232→        } catch (EJBException e) {\n   233→            log.info(e.getMessage() + this.entity.toString());\n   234→            flashMessagesView.addWarnMessage(e, this.entity);\n   235→        }\n   236→    }\n   237→\n   238→    @Override\n   239→    public void deleteSelectedEntity() {\n   240→        log.info(\"deleteSelectedEntity\");\n   241→        try {\n   242→            if (this.entity != null) {\n   243→                String msgInfo = this.entity.getPrimaryKey();\n   244→                long id = this.entity.getId();\n   245→                entityService.delete(id);\n   246→                this.entity = null;\n   247→                String summaryKey = \"org.woehlke.jakartaee.petclinic.veterinarian.delete.done\";\n   248→                String summary = this.petclinicApplication.getMsg().getString(summaryKey);\n   249→                flashMessagesView.addInfoMessage(summary, msgInfo);\n   250→            }\n   251→            loadList();\n   252→        } catch (EJBTransactionRolledbackException e) {\n   253→            String summaryKey = \"org.woehlke.jakartaee.petclinic.veterinarian.delete.denied\";\n   254→            String summary = this.petclinicApplication.getMsg().getString(summaryKey);\n   255→            flashMessagesView.addWarnMessage(summary, this.entity);\n   256→        } catch (EJBException e) {\n   257→            flashMessagesView.addErrorMessage(e.getLocalizedMessage(), this.entity);\n   258→        }\n   259→    }\n   260→\n   261→    @Override\n   262→    public void performSearch() {\n   263→        log.info(\"performSearch\");\n   264→        String summaryKey = \"org.woehlke.jakartaee.petclinic.veterinarian.search.done\";\n   265→        String summary = this.petclinicApplication.getMsg().getString(summaryKey);\n   266→        if (searchterm == null || searchterm.isEmpty()) {\n   267→            this.vetViewFlow.setFlowStateList();\n   268→            String missingKey = \"org.woehlke.jakartaee.petclinic.frontend.web.entity.list.searchterm.missing\";\n   269→            String detail = this.petclinicApplication.getMsg().getString(missingKey);\n   270→            flashMessagesView.addInfoMessage(summary, detail);\n   271→        } else {\n   272→            this.vetViewFlow.setFlowStateSearchResult();\n   273→            this.list = entityService.search(searchterm);\n   274→            String foundKey = \"org.woehlke.jakartaee.petclinic.frontend.web.entity.list.searchterm.found\";\n   275→            String resultsKey = \"org.woehlke.jakartaee.petclinic.frontend.web.entity.list.searchterm.results\";\n   276→            String found = this.petclinicApplication.getMsg().getString(foundKey);\n   277→            String results = this.petclinicApplication.getMsg().getString(resultsKey);\n   278→            String detail = found + \" \" + this.list.size() + \" \" + results + \" \" + searchterm;\n   279→            flashMessagesView.addInfoMessage(summary, detail);\n   280→        }\n   281→    }\n   282→\n   283→    public void resetSpecialtiesPickList() {\n   284→        log.info(\"resetSpecialtiesPickList\");\n   285→        List<Specialty> srcList = new ArrayList<>();\n   286→        List<Specialty> targetList = new ArrayList<>();\n   287→        if(this.entity != null) {\n   288→            Long id = this.entity.getId();\n   289→            if (id != null) {\n   290→                this.entity = this.entityService.findById(id);\n   291→                targetList.addAll(this.entity.getSpecialtiesAsList());\n   292→                for (Specialty specialty : this.specialtyService.getAll()) {\n   293→                    if (!targetList.contains(specialty)) {\n   294→                        srcList.add(specialty);\n   295→                    }\n   296→                }\n   297→            } else {\n   298→                srcList.addAll(this.specialtyService.getAll());\n   299→            }\n   300→        } else {\n   301→            srcList.addAll(this.specialtyService.getAll());\n   302→        }\n   303→        this.specialtiesPickList = new DualListModel<>(srcList, targetList);\n   304→    }\n   305→\n   306→    @Override\n   307→    public List<Vet> getList() {\n   308→        if (this.vetViewFlow.isFlowStateSearchResult()) {\n   309→            this.performSearch();\n   310→        } else {\n   311→            this.loadList();\n   312→        }\n   313→        this.flashMessagesView.flashTheMessages();\n   314→        return this.list;\n   315→    }\n   316→\n   317→    @Override\n   318→    public Specialty findSpecialtyByName(String name) {\n   319→        return specialtyService.findSpecialtyByName(name);\n   320→    }\n   321→\n   322→    @Override\n   323→    @PostConstruct\n   324→    public void postConstruct() {\n   325→        log.info(\"postConstruct: \" + VetViewImpl.class.getSimpleName());\n   326→        this.vetViewFlow.setFlowStateList();\n   327→        this.loadList();\n   328→    }\n   329→\n   330→    @Override\n   331→    @PreDestroy\n   332→    public void preDestroy() {\n   333→        log.info(\"preDestroy\");\n   334→    }\n   335→}\n   336→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01SVxxBDxeR7TyCQEsMaznkq","session_id":"f1542671-6929-49f9-9925-fcf6260de3ab","uuid":"fb9bc91f-5a8e-47fb-913f-5245a1bc63a7"}
