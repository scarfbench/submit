ew TagRelationshipEntity(articleEntity, tagEntity));\n    29→  }\n    30→\n    31→  @Override\n    32→  public List<Tag> findArticleTags(Article article) {\n    33→    return entityManager.createQuery(\n    34→            \"from TagRelationshipEntity as tagRelationship where tagRelationship.primaryKey.article.id = :articleId\",\n    35→            TagRelationshipEntity.class)\n    36→        .setParameter(\"articleId\", article.getId())\n    37→        .getResultList()\n    38→        .stream()\n    39→        .map(entityUtils::tag)\n    40→        .collect(Collectors.toList());\n    41→  }\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_bdrk_01VppwGm4r3QYAAJFWrTAD8a","session_id":"e551caab-c624-46bd-b50e-a080c0cd7305","uuid":"77228125-5fe1-4c12-a23a-926ee8fc05d9"}
