 0;\n    30→  }\n    31→\n    32→  @Override\n    33→  public void save(Article article) {\n    34→    final var author = findUserEntityById(article.getAuthor().getId());\n    35→    var entity = new ArticleEntity(article, author);\n    36→    entityManager.persist(entity);\n    37→    entityManager.flush();\n    38→  }\n    39→\n    40→  @Override\n    41→  public Optional<Article> findArticleById(UUID id) {\n    42→    ArticleEntity entity = entityManager.find(ArticleEntity.class, id);\n    43→    return Optional.ofNullable(entity).map(entityUtils::article);\n    44→  }\n    45→\n    46→  @Override\n    47→  public Optional<Article> findBySlug(String slug) {\n    48→    return entityManager.createQuery(\n    49→            \"from ArticleEntity where upper(slug) = :slug\", ArticleEntity.class)\n    50→        .setParameter(\"slug\", slug.toUpperCase().trim())\n    51→        .getResultStream()\n    52→        .findFirst()\n    53→        .map(entityUtils::article);\n    54→  }\n    55→\n    56→  @Override\n    57→  public void update(Article article) {\n    58→    final var articleEntity = findArticleEntityById(article.getId());\n    59→    articleEntity.update(article);\n    60→  }\n    61→\n    62→  @Override\n    63→  public Optional<Article> findByAuthorAndSlug(UUID authorId, String slug) {\n    64→    return entityManager.createQuery(\n    65→            \"from ArticleEntity where author.id = :authorId and upper(slug) = :slug\", ArticleEntity.class)\n    66→        .setParameter(\"authorId\", authorId)\n    67→        .setParameter(\"slug\", slug.toUpperCase().trim())\n    68→        .getResultStream()\n    69→        .findFirst()\n    70→        .map(entityUtils::article);\n    71→  }\n    72→\n    73→  @Override\n    74→  public void delete(Article article) {\n    75→    ArticleEntity entity = entityManager.find(ArticleEntity.class, article.getId());\n    76→    if (entity != null) {\n    77→      entityManager.remove(entity);\n    78→    }\n    79→  }\n    80→\n    81→  @Override\n    82→  public PageResult<Article> findMostRecentArticlesByFilter(ArticleFilter articleFilter) {\n    83→    var query = entityManager.createQuery(\n    84→            \"select articles from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId order by articles.createdAt desc, articles.updatedAt desc\",\n    85→            ArticleEntity.class)\n    86→        .setParameter(\"loggedUserId\", articleFilter.getLoggedUserId())\n    87→        .setFirstResult(articleFilter.getOffset())\n    88→        .setMaxResults(articleFilter.getLimit());\n    89→    var articlesEntity = query.getResultList();\n    90→    var articlesResult = articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n    91→    var total = countByLoggedUser(articleFilter.getLoggedUserId());\n    92→    return new PageResult<>(articlesResult, total);\n    93→  }\n    94→\n    95→  @Override\n    96→  public PageResult<Article> findArticlesByFilter(ArticleFilter filter) {\n    97→    Map<String, Object> params = new LinkedHashMap<>();\n    98→    SimpleQueryBuilder findArticlesQueryBuilder = new SimpleQueryBuilder();\n    99→    findArticlesQueryBuilder.addQueryStatement(\"select articles from ArticleEntity as articles\");\n   100→    configFilterFindArticlesQueryBuilder(\n   101→        findArticlesQueryBuilder, filter.getTags(), filter.getAuthors(), filter.getFavorited(), params);\n   102→    String queryStr = findArticlesQueryBuilder.toQueryString() + \" order by articles.createdAt desc, articles.updatedAt desc\";\n   103→    var query = entityManager.createQuery(queryStr, ArticleEntity.class);\n   104→    params.forEach(query::setParameter);\n   105→    query.setFirstResult(filter.getOffset());\n   106→    query.setMaxResults(filter.getLimit());\n   107→    var articlesEntity = query.getResultList();\n   108→    var articlesResult = articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n   109→    var total = count(filter.getTags(), filter.getAuthors(), filter.getFavorited());\n   110→    return new PageResult<>(articlesResult, total);\n   111→  }\n   112→\n   113→  @Override\n   114→  public long count(List<String> tags, List<String> authors, List<String> favorited) {\n   115→    Map<String, Object> params = new LinkedHashMap<>();\n   116→    SimpleQueryBuilder countArticlesQueryBuilder = new SimpleQueryBuilder();\n   117→    countArticlesQueryBuilder.addQueryStatement(\"select count(distinct articles) from ArticleEntity as articles\");\n   118→    configFilterFindArticlesQueryBuilder(countArticlesQueryBuilder, tags, authors, favorited, params);\n   119→    var query = entityManager.createQuery(countArticlesQueryBuilder.toQueryString(), Long.class);\n   120→    params.forEach(query::setParameter);\n   121→    return query.getSingleResult();\n   122→  }\n   123→\n   124→  public long countByLoggedUser(UUID loggedUserId) {\n   125→    return entityManager.createQuery(\n   126→            \"select count(articles) from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId\",\n   127→            Long.class)\n   128→        .setParameter(\"loggedUserId\", loggedUserId)\n   129→        .getSingleResult();\n   130→  }\n   131→\n   132→  private void configFilterFindArticlesQueryBuilder(\n   133→      SimpleQueryBuilder findArticlesQueryBuilder,\n   134→      List<String> tags, List<String> authors, List<String> favorited,\n   135→      Map<String, Object> params) {\n   136→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   137→        isNotEmpty(tags),\n   138→        \"inner join articles.tags as tags inner join tags.primaryKey.tag as tag\",\n   139→        \"upper(tag.name) in (:tags)\",\n   140→        () -> params.put(\"tags\", toUpperCase(tags)));\n   141→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   142→        isNotEmpty(authors),\n   143→        \"inner join articles.author as authors\",\n   144→        \"upper(authors.username) in (:authors)\",\n   145→        () -> params.put(\"authors\", toUpperCase(authors)));\n   146→    findArticlesQueryBuilder.updateQueryStatementConditional(\n   147→        isNotEmpty(favorited),\n   148→        \"inner join articles.favorites as favorites inner join favorites.primaryKey.user as user\",\n   149→        \"upper(user.username) in (:favorites)\",\n   150→        () -> params.put(\"favorites\", toUpperCase(favorited)));\n   151→  }\n   152→}\n   153→"}]},"parent_tool_use_id":"toolu_bdrk_01VppwGm4r3QYAAJFWrTAD8a","session_id":"e551caab-c624-46bd-b50e-a080c0cd7305","uuid":"c1c2ee17-3c83-4dfc-9730-48f4d838793b"}
