onstructor\n    29→public class ArticlesResource {\n    30→\n    31→  private final FindArticlesByFilter findArticlesByFilter;\n    32→  private final CreateArticle createArticle;\n    33→  private final FindMostRecentArticlesByFilter findMostRecentArticlesByFilter;\n    34→  private final FindArticleBySlug findArticleBySlug;\n    35→  private final UpdateArticleBySlug updateArticleBySlug;\n    36→  private final DeleteArticleBySlug deleteArticleBySlug;\n    37→  private final CreateComment createComment;\n    38→  private final DeleteComment deleteComment;\n    39→  private final FindCommentsByArticleSlug findCommentsByArticleSlug;\n    40→  private final FavoriteArticle favoriteArticle;\n    41→  private final UnfavoriteArticle unfavoriteArticle;\n    42→  @Qualifier(\"noWrapRootValueObjectMapper\") private final ObjectMapper objectMapper;\n    43→  private final ResourceUtils resourceUtils;\n    44→\n    45→  @GetMapping(\"/feed\")\n    46→  public ResponseEntity<String> feed(\n    47→      @RequestParam(defaultValue = \"0\") int offset,\n    48→      @RequestParam(defaultValue = \"0\") int limit,\n    49→      Principal principal)\n    50→      throws JsonProcessingException {\n    51→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    52→    final var articlesFilter =\n    53→        new ArticleFilter(offset, resourceUtils.getLimit(limit), loggedUserId, null, null, null);\n    54→    final var articlesPageResult = findMostRecentArticlesByFilter.handle(articlesFilter);\n    55→    return ResponseEntity.ok(\n    56→        objectMapper.writeValueAsString(\n    57→            resourceUtils.articlesResponse(articlesPageResult, loggedUserId)));\n    58→  }\n    59→\n    60→  @GetMapping\n    61→  public ResponseEntity<String> getArticles(\n    62→      @RequestParam(defaultValue = \"0\") int offset,\n    63→      @RequestParam(defaultValue = \"0\") int limit,\n    64→      @RequestParam(required = false) List<String> tag,\n    65→      @RequestParam(required = false) List<String> author,\n    66→      @RequestParam(required = false) List<String> favorited,\n    67→      Principal principal)\n    68→      throws JsonProcessingException {\n    69→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    70→    final var filter =\n    71→        new ArticleFilter(\n    72→            offset, resourceUtils.getLimit(limit), loggedUserId, tag, author, favorited);\n    73→    final var articlesPageResult = findArticlesByFilter.handle(filter);\n    74→    return ResponseEntity.ok(\n    75→        objectMapper.writeValueAsString(\n    76→            resourceUtils.articlesResponse(articlesPageResult, loggedUserId)));\n    77→  }\n    78→\n    79→  @PostMapping\n    80→  @Transactional\n    81→  public ResponseEntity<?> create(\n    82→      @Valid @RequestBody @NotNull(message = ValidationMessages.REQUEST_BODY_MUST_BE_NOT_NULL)\n    83→          NewArticleRequest newArticleRequest,\n    84→      Principal principal) {\n    85→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    86→    final var article = createArticle.handle(newArticleRequest.toNewArticleInput(loggedUserId));\n    87→    return ResponseEntity.status(HttpStatus.CREATED)\n    88→        .body(resourceUtils.articleResponse(article, loggedUserId));\n    89→  }\n    90→\n    91→  @GetMapping(\"/{slug}\")\n    92→  public ResponseEntity<?> findBySlug(\n    93→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug) {\n    94→    final var article = findArticleBySlug.handle(slug);\n    95→    return ResponseEntity.ok(resourceUtils.articleResponse(article, null));\n    96→  }\n    97→\n    98→  @PutMapping(\"/{slug}\")\n    99→  @Transactional\n   100→  public ResponseEntity<?> update(\n   101→      @PathVariable @NotBlank String slug,\n   102→      @Valid @RequestBody @NotNull UpdateArticleRequest updateArticleRequest,\n   103→      Principal principal) {\n   104→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   105→    final var updatedArticle =\n   106→        updateArticleBySlug.handle(updateArticleRequest.toUpdateArticleInput(loggedUserId, slug));\n   107→    return ResponseEntity.ok(resourceUtils.articleResponse(updatedArticle, null));\n   108→  }\n   109→\n   110→  @DeleteMapping(\"/{slug}\")\n   111→  @Transactional\n   112→  public ResponseEntity<?> delete(\n   113→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   114→      Principal principal) {\n   115→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   116→    deleteArticleBySlug.handle(loggedUserId, slug);\n   117→    return ResponseEntity.ok().build();\n   118→  }\n   119→\n   120→  @GetMapping(\"/{slug}/comments\")\n   121→  public ResponseEntity<String> getCommentsBySlug(\n   122→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   123→      Principal principal)\n   124→      throws JsonProcessingException {\n   125→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   126→    final var comments = findCommentsByArticleSlug.handle(slug);\n   127→    return ResponseEntity.ok(\n   128→        objectMapper.writeValueAsString(resourceUtils.commentsResponse(comments, loggedUserId)));\n   129→  }\n   130→\n   131→  @PostMapping(\"/{slug}/comments\")\n   132→  @Transactional\n   133→  public ResponseEntity<?> createComment(\n   134→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   135→      @Valid @RequestBody NewCommentRequest newCommentRequest,\n   136→      Principal principal) {\n   137→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   138→    final var comment =\n   139→        createComment.handle(newCommentRequest.toNewCommentInput(loggedUserId, slug));\n   140→    return ResponseEntity.ok(resourceUtils.commentResponse(comment, loggedUserId));\n   141→  }\n   142→\n   143→  @DeleteMapping(\"/{slug}/comments/{id}\")\n   144→  @Transactional\n   145→  public ResponseEntity<?> deleteComment(\n   146→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   147→      @PathVariable @NotNull(message = ValidationMessages.COMMENT_ID_MUST_BE_NOT_NULL) UUID id,\n   148→      Principal principal) {\n   149→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   150→    deleteComment.handle(new DeleteCommentInput(id, loggedUserId, slug));\n   151→    return ResponseEntity.ok().build();\n   152→  }\n   153→\n   154→  @PostMapping(\"/{slug}/favorite\")\n   155→  @Transactional\n   156→  public ResponseEntity<?> favoriteArticle(\n   157→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   158→      Principal principal) {\n   159→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   160→    favoriteArticle.handle(slug, loggedUserId);\n   161→    final var article = findArticleBySlug.handle(slug);\n   162→    return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   163→  }\n   164→\n   165→  @DeleteMapping(\"/{slug}/favorite\")\n   166→  @Transactional\n   167→  public ResponseEntity<?> unfavoriteArticle(\n   168→      @PathVariable @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   169→      Principal principal) {\n   170→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   171→    unfavoriteArticle.handle(slug, loggedUserId);\n   172→    final var article = findArticleBySlug.handle(slug);\n   173→    return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   174→  }\n   175→}\n   176→"}]},"parent_tool_use_id":"toolu_bdrk_017kQH6hWNJouvNqrT2Pnbb9","session_id":"e551caab-c624-46bd-b50e-a080c0cd7305","uuid":"c2cf1677-dbde-4eca-9b1c-b5c67b3920ac"}
