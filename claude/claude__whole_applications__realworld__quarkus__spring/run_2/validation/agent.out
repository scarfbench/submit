BE_NOT_BLANK)\n    68→          String username,\n    69→      Principal principal)\n    70→      throws JsonProcessingException {\n    71→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    72→    unfollowUserByUsername.handle(loggedUserId, username);\n    73→    return ResponseEntity.ok()\n    74→        .contentType(MediaType.APPLICATION_JSON)\n    75→        .body(wrapMapper.writeValueAsString(resourceUtils.profileResponse(username, loggedUserId)));\n    76→  }\n    77→}\n    78→"}]},"parent_tool_use_id":null,"session_id":"e551caab-c624-46bd-b50e-a080c0cd7305","uuid":"4297c2e0-c08f-4b44-93ad-745b4d20d377"}
