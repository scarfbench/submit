turn entityManager.createQuery(\n    33→            \"from CommentEntity where id = :commentId and author.id = :authorId\", CommentEntity.class)\n    34→        .setParameter(\"commentId\", commentId)\n    35→        .setParameter(\"authorId\", authorId)\n    36→        .getResultStream()\n    37→        .findFirst()\n    38→        .map(entityUtils::comment);\n    39→  }\n    40→\n    41→  @Override\n    42→  public void delete(Comment comment) {\n    43→    final var commentEntity = findCommentEntityById(comment.getId());\n    44→    entityManager.remove(commentEntity);\n    45→  }\n    46→\n    47→  @Override\n    48→  public List<Comment> findCommentsByArticle(Article article) {\n    49→    return entityManager.createQuery(\n    50→            \"from CommentEntity where article.id = :articleId\", CommentEntity.class)\n    51→        .setParameter(\"articleId\", article.getId())\n    52→        .getResultList()\n    53→        .stream()\n    54→        .map(entityUtils::comment)\n    55→        .collect(Collectors.toList());\n    56→  }\n    57→}\n    58→"}]},"parent_tool_use_id":"toolu_bdrk_01VppwGm4r3QYAAJFWrTAD8a","session_id":"e551caab-c624-46bd-b50e-a080c0cd7305","uuid":"dae5c64a-3e7a-481b-9a7b-ee28c901ff26"}
