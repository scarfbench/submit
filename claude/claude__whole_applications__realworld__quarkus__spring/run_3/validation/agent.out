 f.article.id = :articleId and f.user.id = :currentUserId\", Long.class)\n    28→                .setParameter(\"articleId\", article.getId())\n    29→                .setParameter(\"currentUserId\", currentUserId)\n    30→                .getSingleResult();\n    31→        return count > 0;\n    32→    }\n    33→\n    34→    @Override\n    35→    public long favoritesCount(Article article) {\n    36→        return entityManager.createQuery(\n    37→                        \"select count(f) from FavoriteRelationshipEntity f where f.article.id = :articleId\", Long.class)\n    38→                .setParameter(\"articleId\", article.getId())\n    39→                .getSingleResult();\n    40→    }\n    41→\n    42→    @Override\n    43→    public Optional<FavoriteRelationship> findByArticleIdAndUserId(UUID articleId, UUID currentUserId) {\n    44→        var results = entityManager.createQuery(\n    45→                        \"from FavoriteRelationshipEntity where article.id = :articleId and user.id = :currentUserId\", FavoriteRelationshipEntity.class)\n    46→                .setParameter(\"articleId\", articleId)\n    47→                .setParameter(\"currentUserId\", currentUserId)\n    48→                .getResultList();\n    49→        return results.stream().findFirst().map(entityUtils::favoriteRelationship);\n    50→    }\n    51→\n    52→    @Override\n    53→    public void save(FavoriteRelationship favoriteRelationship) {\n    54→        final var userEntity = findUserEntityById(favoriteRelationship.getUser().getId());\n    55→        final var articleEntity = findArticleEntityById(favoriteRelationship.getArticle().getId());\n    56→        entityManager.persist(new FavoriteRelationshipEntity(userEntity, articleEntity));\n    57→    }\n    58→\n    59→    @Override\n    60→    public void delete(FavoriteRelationship favoriteRelationship) {\n    61→        final var favoriteRelationshipEntity = findFavoriteRelationshipEntityByKey(favoriteRelationship);\n  