ider tokenProvider) {\n    29→        this.createUser = createUser;\n    30→        this.loginUser = loginUser;\n    31→        this.tokenProvider = tokenProvider;\n    32→    }\n    33→\n    34→    @PostMapping(consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n    35→    @Transactional\n    36→    public ResponseEntity<UserResponse> create(@Valid @RequestBody NewUserRequest newUserRequest) {\n    37→        final var user = createUser.handle(newUserRequest.toCreateUserInput());\n    38→        final var token = tokenProvider.createUserToken(user.getId().toString());\n    39→        return ResponseEntity.status(HttpStatus.CREATED).body(new UserResponse(user, token));\n    40→    }\n    41→\n    42→    @PostMapping(value = \"/login\", consumes = MediaType.APPLICATION_JSON_VALUE, produces = MediaType.APPLICATION_JSON_VALUE)\n    43→    public ResponseEntity<UserResponse> login(@Valid @RequestBody LoginRequest loginRequest) {\n    44→        User user;\n    45→        try {\n    46→            user = loginUser.handle(loginRequest.toLoginUserInput());\n    47→        } catch (UserNotFoundException | InvalidPasswordException ex) {\n    48→            throw new BadCredentialsException(\"Unauthorized\");\n    49→        }\n    50→        final var token = tokenProvider.createUserToken(user.getId().toString());\n    51→        return ResponseEntity.ok(new UserResponse(user, token));\n    52→    }\n    53→}\n    54→"}]},"parent_tool_use_id":"toolu_bdrk_019dgv6Zr4tY62fLHA7Nznz9","session_id":"dc68c8b7-f26e-40c7-b046-67d783731ba6","uuid":"34d20a63-406b-4c20-9bbe-9511fa7af468"}
