          \"select count(f) from FollowRelationshipEntity f where f.primaryKey.user.id = :currentUserId and f.primaryKey.followed.id = :followedUserId\", Long.class)\n    29→                .setParameter(\"currentUserId\", currentUserId)\n    30→                .setParameter(\"followedUserId\", followedUserId)\n    31→                .getSingleResult();\n    32→        return count > 0;\n    33→    }\n    34→\n    35→    @Override\n    36→    public void save(FollowRelationship followRelationship) {\n    37→        final var userEntity = findUserEntityById(followRelationship.getUser().getId());\n    38→        final var userToFollowEntity = findUserEntityById(followRelationship.getFollowed().getId());\n    39→        entityManager.persist(new FollowRelationshipEntity(userEntity, userToFollowEntity));\n    40→        entityManager.flush();\n    41→    }\n    42→\n    43→    @Override\n    44→    public Optional<FollowRelationship> findByUsers(User loggedUser, User followedUser) {\n    45→        return findUsersFollowedEntityByUsers(loggedUser, followedUser)\n    46→                .map(this::followingRelationship);\n    47→    }\n    48→\n    49→    @Override\n    50→    public void remove(FollowRelationship followRelationship) {\n    51→        final var usersFollowedEntity =\n    52→                findUsersFollowedEntityByUsers(\n    53→                        followRelationship.getUser(), followRelationship.getFollowed())\n    54→                        .orElseThrow();\n    55→        entityManager.remove(usersFollowedEntity);\n    56→    }\n    57→\n    58→    private Optional<FollowRelationshipEntity> findUsersFollowedEntityByUsers(\n    59→            User loggedUser, User followedUser) {\n    60→        final var loggedUserEntity = findUserEntityById(loggedUser.getId());\n    61→        final var followedEntity = findUserEntityById(followedUser.getId());\n    62→        FollowRelationshipEntityKey key = usersFollowedKey(loggedUserEntity, followedEntity);\n    63→        FollowRelationshipEntity entity = entityManager.find(FollowRelationshipEntity.class, key);\n    64→        return Optional.ofNullable(entity);\n    65→    }\n    66→\n    67→    private FollowRelationship followingRelationship(FollowRelationshipEntity followRelationshipEntity) {\n    68→        final var user = entityUtils.user(followRelationshipEntity.getUser());\n    69→        final var followed = entityUtils.user(followRelationshipEntity.getFollowed());\n    70→        return new FollowRelationship(user, followed);\n    71→    }\n    72→\n    73→    private FollowRelationshipEntityKey usersFollowedKey(UserEntity user, UserEntity followed) {\n    74→        final var primaryKey = new FollowRelationshipEntityKey();\n    75→        primaryKey.setUser(user);\n    76→        primaryKey.setFollowed(followed);\n    77→        return primaryKey;\n    78→    }\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_bdrk_01YAAD7Xs6gL4qHbtHcnyzbG","session_id":"dc68c8b7-f26e-40c7-b046-67d783731ba6","uuid":"90a67f3d-6582-4f5b-86c1-a6d44b5a76a8"}
