ug) = :slug\", Long.class)\n    30→                .setParameter(\"slug\", slug.toUpperCase().trim())\n    31→                .getSingleResult();\n    32→        return count > 0;\n    33→    }\n    34→\n    35→    @Override\n    36→    public void save(Article article) {\n    37→        final var author = findUserEntityById(article.getAuthor().getId());\n    38→        entityManager.persist(new ArticleEntity(article, author));\n    39→        entityManager.flush();\n    40→    }\n    41→\n    42→    @Override\n    43→    public Optional<Article> findArticleById(UUID id) {\n    44→        ArticleEntity entity = entityManager.find(ArticleEntity.class, id);\n    45→        return Optional.ofNullable(entity).map(entityUtils::article);\n    46→    }\n    47→\n    48→    @Override\n    49→    public Optional<Article> findBySlug(String slug) {\n    50→        var results = entityManager.createQuery(\n    51→                        \"from ArticleEntity where upper(slug) = :slug\", ArticleEntity.class)\n    52→                .setParameter(\"slug\", slug.toUpperCase().trim())\n    53→                .getResultList();\n    54→        return results.stream().findFirst().map(entityUtils::article);\n    55→    }\n    56→\n    57→    @Override\n    58→    public void update(Article article) {\n    59→        final var articleEntity = findArticleEntityById(article.getId());\n    60→        articleEntity.update(article);\n    61→        entityManager.merge(articleEntity);\n    62→    }\n    63→\n    64→    @Override\n    65→    public Optional<Article> findByAuthorAndSlug(UUID authorId, String slug) {\n    66→        var results = entityManager.createQuery(\n    67→                        \"from ArticleEntity where author.id = :authorId and upper(slug) = :slug\", ArticleEntity.class)\n    68→                .setParameter(\"authorId\", authorId)\n    69→                .setParameter(\"slug\", slug.toUpperCase().trim())\n    70→                .getResultList();\n    71→        return results.stream().findFirst().map(entityUtils::article);\n    72→    }\n    73→\n    74→    @Override\n    75→    public void delete(Article article) {\n    76→        ArticleEntity entity = entityManager.find(ArticleEntity.class, article.getId());\n    77→        if (entity != null) {\n    78→            entityManager.remove(entity);\n    79→        }\n    80→    }\n    81→\n    82→    @Override\n    83→    public PageResult<Article> findMostRecentArticlesByFilter(ArticleFilter articleFilter) {\n    84→        String jpql = \"select articles from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId order by articles.createdAt desc, articles.updatedAt desc\";\n    85→        var query = entityManager.createQuery(jpql, ArticleEntity.class)\n    86→                .setParameter(\"loggedUserId\", articleFilter.getLoggedUserId())\n    87→                .setFirstResult(articleFilter.getOffset())\n    88→                .setMaxResults(articleFilter.getLimit());\n    89→        var articlesEntity = query.getResultList();\n    90→        var articlesResult = articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n    91→        var total = countByFollowing(articleFilter.getLoggedUserId());\n    92→        return new PageResult<>(articlesResult, total);\n    93→    }\n    94→\n    95→    @Override\n    96→    public PageResult<Article> findArticlesByFilter(ArticleFilter filter) {\n    97→        Map<String, Object> params = new LinkedHashMap<>();\n    98→        SimpleQueryBuilder findArticlesQueryBuilder = new SimpleQueryBuilder();\n    99→        findArticlesQueryBuilder.addQueryStatement(\"select articles from ArticleEntity as articles\");\n   100→        configFilterFindArticlesQueryBuilder(\n   101→                findArticlesQueryBuilder,\n   102→                filter.getTags(),\n   103→                filter.getAuthors(),\n   104→                filter.getFavorited(),\n   105→                params);\n   106→        String jpql = findArticlesQueryBuilder.toQueryString() + \" order by articles.createdAt desc, articles.updatedAt desc\";\n   107→        TypedQuery<ArticleEntity> query = entityManager.createQuery(jpql, ArticleEntity.class);\n   108→        params.forEach(query::setParameter);\n   109→        query.setFirstResult(filter.getOffset());\n   110→        query.setMaxResults(filter.getLimit());\n   111→        var articlesEntity = query.getResultList();\n   112→        var articlesResult = articlesEntity.stream().map(entityUtils::article).collect(Collectors.toList());\n   113→        var total = count(filter.getTags(), filter.getAuthors(), filter.getFavorited());\n   114→        return new PageResult<>(articlesResult, total);\n   115→    }\n   116→\n   117→    @Override\n   118→    public long count(List<String> tags, List<String> authors, List<String> favorited) {\n   119→        Map<String, Object> params = new LinkedHashMap<>();\n   120→        SimpleQueryBuilder countArticlesQueryBuilder = new SimpleQueryBuilder();\n   121→        countArticlesQueryBuilder.addQueryStatement(\"select count(distinct articles) from ArticleEntity as articles\");\n   122→        configFilterFindArticlesQueryBuilder(\n   123→                countArticlesQueryBuilder, tags, authors, favorited, params);\n   124→        var query = entityManager.createQuery(countArticlesQueryBuilder.toQueryString(), Long.class);\n   125→        params.forEach(query::setParameter);\n   126→        return query.getSingleResult();\n   127→    }\n   128→\n   129→    public long countByFollowing(UUID loggedUserId) {\n   130→        return entityManager.createQuery(\n   131→                        \"select count(articles) from ArticleEntity as articles inner join articles.author as author inner join author.followedBy as followedBy where followedBy.user.id = :loggedUserId\", Long.class)\n   132→                .setParameter(\"loggedUserId\", loggedUserId)\n   133→                .getSingleResult();\n   134→    }\n   135→\n   136→    private void configFilterFindArticlesQueryBuilder(\n   137→            SimpleQueryBuilder findArticlesQueryBuilder,\n   138→            List<String> tags,\n   139→            List<String> authors,\n   140→            List<String> favorited,\n   141→            Map<String, Object> params) {\n   142→\n   143→        findArticlesQueryBuilder.updateQueryStatementConditional(\n   144→                isNotEmpty(tags),\n   145→                \"inner join articles.tags as tags inner join tags.primaryKey.tag as tag\",\n   146→                \"upper(tag.name) in (:tags)\",\n   147→                () -> params.put(\"tags\", toUpperCase(tags)));\n   148→\n   149→        findArticlesQueryBuilder.updateQueryStatementConditional(\n   150→                isNotEmpty(authors),\n   151→                \"inner join articles.author as authors\",\n   152→                \"upper(authors.username) in (:authors)\",\n   153→                () -> params.put(\"authors\", toUpperCase(authors)));\n   154→\n   155→        findArticlesQueryBuilder.updateQueryStatementConditional(\n   156→                isNotEmpty(favorited),\n   157→                \"inner join articles.favorites as favorites inner join favorites.primaryKey.user as user\",\n   158→                \"upper(user.username) in (:favorites)\",\n   159→                () -> params.put(\"favorites\", toUpperCase(favorited)));\n   160→    }\n   161→}\n   162→"}]},"parent_tool_use_id":"toolu_bdrk_01YAAD7Xs6gL4qHbtHcnyzbG","session_id":"dc68c8b7-f26e-40c7-b046-67d783731ba6","uuid":"c50e8807-1098-4044-b4f3-b608dfe6e820"}
