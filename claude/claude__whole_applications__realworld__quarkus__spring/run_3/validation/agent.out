ory articleRepository,\n    42→      ModelValidator modelValidator) {\n    43→    return new UpdateArticleBySlugImpl(\n    44→        findArticleBySlug, createSlugByTitle, articleRepository, modelValidator);\n    45→  }\n    46→\n    47→  @Produces\n    48→  @Singleton\n    49→  public DeleteArticleBySlug deleteArticleBySlug(\n    50→      FindArticleByAuthorAndSlug findArticleByAuthorAndSlug, ArticleRepository articleRepository) {\n    51→    return new DeleteArticleBySlugImpl(findArticleByAuthorAndSlug, articleRepository);\n    52→  }\n    53→\n    54→  @Produces\n    55→  @Singleton\n    56→  public FindArticleById findArticleById(ArticleRepository articleRepository) {\n    57→    return new FindArticleByIdImpl(articleRepository);\n    58→  }\n    59→\n    60→  @Produces\n    61→  @Singleton\n    62→  public FindArticleByAuthorAndSlug findArticleByAuthorAndSlug(\n    63→      ArticleRepository articleRepository) {\n    64→    return new FindArticleByAuthorAndSlugImpl(articleRepository);\n    65→  }\n    66→\n    67→  @Produces\n    68→  @Singleton\n    69→  public FindArticleBySlug findArticleBySlug(ArticleRepository articleRepository) {\n    70→    return new FindArticleBySlugImpl(articleRepository);\n    71→  }\n    72→\n    73→  @Produces\n    74→  @Singleton\n    75→  public FindArticleTags findArticleTags(TagRelationshipRepository tagRelationshipRepository) {\n    76→    return new FindArticleTagsImpl(tagRelationshipRepository);\n    77→  }\n    78→\n    79→  @Produces\n    80→  @Singleton\n    81→  public FindMostRecentArticlesByFilter findMostRecentArticlesByFilter(\n    82→      ArticleRepository articleRepository) {\n    83→    return new FindMostRecentArticlesByFilterImpl(articleRepository);\n    84→  }\n    85→\n    86→  @Produces\n    87→  @Singleton\n    88→  public FindArticlesByFilter findArticlesByFilter(ArticleRepository articleRepository) {\n    89→    return new FindArticlesByFilterImpl(articleRepository);\n    90→  }\n    91→\n    92→  @Produces\n    93→  @Singleton\n    94→  public IsArticleFavorited isArticleFavorited(\n    95→      FavoriteRelationshipRepository favoriteRelationshipRepository) {\n    96→    return new IsArticleFavoritedImpl(favoriteRelationshipRepository);\n    97→  }\n    98→\n    99→  @Produces\n   100→  @Singleton\n   101→  public ArticleFavoritesCount articleFavoritesCount(\n   102→      FindArticleById findArticleById,\n   103→      FavoriteRelationshipRepository favoriteRelationshipRepository) {\n   104→    return new ArticleFavoritesCountImpl(findArticleById, favoriteRelationshipRepository);\n   105→  }\n   106→\n   107→  @Produces\n   108→  @Singleton\n   109→  public CreateSlugByTitle createSlugByTitle(\n   110→      ArticleRepository articleRepository, SlugProvider slugProvider) {\n   111→    return new CreateSlugByTitleImpl(articleRepository, slugProvider);\n   112→  }\n   113→\n   114→  @Produces\n   115→  @Singleton\n   116→  public FavoriteArticle favoriteArticle(\n   117→      FindArticleBySlug findArticleBySlug,\n   118→      FindUserById findUserById,\n   119→      FavoriteRelationshipRepository favoriteRelationshipRepository) {\n   120→    return new FavoriteArticleImpl(findArticleBySlug, findUserById, favoriteRelationshipRepository);\n   121→  }\n   122→\n   123→  @Produces\n   124→  @Singleton\n   125→  public UnfavoriteArticle unfavoriteArticle(\n   126→      FindArticleBySlug findArticleBySlug,\n   127→      FavoriteRelationshipRepository favoriteRelationshipRepository) {\n   128→    return new UnfavoriteArticleImpl(findArticleBySlug, favoriteRelationshipRepository);\n   129→  }\n   130→\n   131→  @Produces\n   132→  @Singleton\n   133→  public ArticleModelBuilder articleBuilder(ModelValidator modelValidator) {\n   134→    return new ArticleModelBuilder(modelValidator);\n   135→  }\n   136→}\n   137→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it i