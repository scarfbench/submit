ticles/${slug}/comments`, JSON.stringify({ 'comment': comment }), params);\n   350→\n   351→    expect(response.status, 'create comment status').to.equal(200);\n   352→    expect(response).to.have.validJsonBody();\n   353→    expect(response.json('comment'), 'comment').to.be.an('object');\n   354→    expect(response.json('comment'), 'comment').to.include.keys('id', 'body', 'createdAt', 'updatedAt', 'author');\n   355→    commentId = response.json('comment.id')\n   356→    expect(response.json('comment.body'), 'body').to.be.a('string')\n   357→    expect(response.json('comment.body'), 'body').to.equal('Thank you so much!')\n   358→    expect(response.json('comment.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   359→    expect(response.json('comment.updatedAt'), 'updated at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   360→  });\n   361→  describe('Get Comments for Article', () => {\n   362→\n   363→    let response = session.get(`/articles/${slug}/comments`, params);\n   364→\n   365→    expect(response.status, 'get comment status').to.equal(200);\n   366→    expect(response).to.have.validJsonBody();\n   367→    expect(response.json('comments'), 'comments').to.be.an('array');\n   368→    expect(response.json('comments.0'), 'first comment').to.be.an('object');\n   369→    expect(response.json('comments.0'), 'comment').to.include.keys('id', 'body', 'createdAt', 'updatedAt', 'author');\n   370→    expect(response.json('comments.0.body'), 'body').to.be.a('string')\n   371→    expect(response.json('comments.0.body'), 'body').to.equal('Thank you so much!')\n   372→    expect(response.json('comments.0.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   373→    expect(response.json('commen