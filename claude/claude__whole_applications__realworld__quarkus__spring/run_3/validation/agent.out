  expect(response.json('article.tagList'), 'tagList').to.have.members(['training', 'dragons'])\n   300→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.be.a('number')\n   301→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.equal(0)\n   302→  });\n   303→  describe('Favorite article', () => {\n   304→\n   305→    let response = session.post(`/articles/${slug}/favorite`, params);\n   306→\n   307→    expect(response.status, 'update article status').to.equal(200);\n   308→    expect(response).to.have.validJsonBody();\n   309→    expect(response.json('article'), 'article').to.be.an('object');\n   310→    expect(response.json('article'), 'article').to.include.keys('title', 'slug', 'body', 'createdAt', 'updatedAt', 'description', 'tagList', 'author', 'favorited', 'favoritesCount');\n   311→    expect(response.json('article.title'), 'title').to.equal('How to train your dragon')\n   312→    expect(response.json('article.slug'), 'slug').to.equal(slug)\n   313→    expect(response.json('article.body'), 'body').to.equal('With two hands');\n   314→    expect(response.json('article.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   315→    expect(response.json('article.updatedAt'), 'updated at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   316→    expect(response.json('article.description'), 'description').to.equal('Ever wonder how?')\n   317→    expect(response.json('article.tagList'), 'tagList').to.be.an('array')\n   318→    expect(response.json('article.tagList'), 'tagList').to.have.members(['training', 'dragons'])\n   319→    expect(response.json('article.favorited'), 'favorited').to.be.true\n   320→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.be.a('number')\n   321→    expect(response.json('article.favoritesCount'), '