edUserId)\n    31→        .getSingleResult();\n    32→    return count > 0;\n    33→  }\n    34→\n    35→  @Override\n    36→  public void save(FollowRelationship followRelationship) {\n    37→    final var userEntity = entityManager.find(UserEntity.class, followRelationship.getUser().getId());\n    38→    final var userToFollowEntity = entityManager.find(UserEntity.class, followRelationship.getFollowed().getId());\n    39→    entityManager.persist(new FollowRelationshipEntity(userEntity, userToFollowEntity));\n    40→    entityManager.flush();\n    41→  }\n    42→\n    43→  @Override\n    44→  public Optional<FollowRelationship> findByUsers(User loggedUser, User followedUser) {\n    45→    return findFollowEntity(loggedUser, followedUser)\n    46→        .map(this::toFollowRelationship);\n    47→  }\n    48→\n    49→  @Override\n    50→  public void remove(FollowRelationship followRelationship) {\n    51→    final var entity = findFollowEntity(\n    52→        followRelationship.getUser(), followRelationship.getFollowed())\n    53→        .orElseThrow();\n    54→    entityManager.remove(entity);\n    55→  }\n    56→\n    57→  private Optional<FollowRelationshipEntity> findFollowEntity(User loggedUser, User followedUser) {\n    58→    final var loggedUserEntity = entityManager.find(UserEntity.class, loggedUser.getId());\n    59→    final var followedEntity = entityManager.find(UserEntity.class, followedUser.getId());\n    60→    final var primaryKey = new FollowRelationshipEntityKey();\n    61→    primaryKey.setUser(loggedUserEntity);\n    62→    primaryKey.setFollowed(followedEntity);\n    63→    return Optional.ofNullable(entityManager.find(FollowRelationshipEntity.class, primaryKey));\n    64→  }\n    65→\n    66→  private FollowRelationship toFollowRelationship(FollowRelationshipEntity entity) {\n    67→    final var user = entityUtils.user(entity.getUser());\n    68→    final var followed = entityUtils.user(entity.getFollowed());\n    69→    return new FollowRelationship(user, followed);\n    70→  }\n    71→}\n    72→"}]},"parent_tool_use_id":"toolu_bdrk_01VhW2FHGUAKMzAk3BBrxJib","session_id":"77854f62-3341-42f0-ba47-aba7925f4b32","uuid":"80cd7781-59d8-42f9-ad82-01ed2f8caf3f"}
