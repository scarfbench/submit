  expect(response.json('article.tagList'), 'tagList').to.have.members(['training', 'dragons'])\n   300→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.be.a('number')\n   301→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.equal(0)\n   302→  });\n   303→  describe('Favorite article', () => {\n   304→\n   305→    let response = session.post(`/articles/${slug}/favorite`, params);\n   306→\n   307→    expect(response.status, 'update article status').to.equal(200);\n   308→    expect(response).to.have.validJsonBody();\n   309→    expect(response.json('article'), 'article').to.be.an('object');\n   310→    expect(response.json('article'), 'article').to.include.keys('title', 'slug', 'body', 'createdAt', 'updatedAt', 'description', 'tagList', 'author', 'favorited', 'favoritesCount');\n   311→    expect(response.json('article.title'), 'title').to.equal('How to train your dragon')\n   312→    expect(response.json('article.slug'), 'slug').to.equal(slug)\n   313→    expect(response.json('article.body'), 'body').to.equal('With two hands');\n   314→    expect(response.json('article.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   315→    expect(response.json('article.updatedAt'), 'updated at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   316→    expect(response.json('article.description'), 'description').to.equal('Ever wonder how?')\n   317→    expect(response.json('article.tagList'), 'tagList').to.be.an('array')\n   318→    expect(response.json('article.tagList'), 'tagList').to.have.members(['training', 'dragons'])\n   319→    expect(response.json('article.favorited'), 'favorited').to.be.true\n   320→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.be.a('number')\n   321→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.equal(1)\n   322→  });\n   323→  describe('Unfavorite article', () => {\n   324→\n   325→    let response = session.delete(`/articles/${slug}/favorite`, params);\n   326→\n   327→    expect(response.status, 'update article status').to.equal(200);\n   328→    expect(response).to.have.validJsonBody();\n   329→    expect(response.json('article'), 'article').to.be.an('object');\n   330→    expect(response.json('article'), 'article').to.include.keys('title', 'slug', 'body', 'createdAt', 'updatedAt', 'description', 'tagList', 'author', 'favorited', 'favoritesCount');\n   331→    expect(response.json('article.title'), 'title').to.equal('How to train your dragon')\n   332→    expect(response.json('article.slug'), 'slug').to.equal(slug)\n   333→    expect(response.json('article.body'), 'body').to.equal('With two hands');\n   334→    expect(response.json('article.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   335→    expect(response.json('article.updatedAt'), 'updated at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   336→    expect(response.json('article.description'), 'description').to.equal('Ever wonder how?')\n   337→    expect(response.json('article.tagList'), 'tagList').to.be.an('array')\n   338→    expect(response.json('article.tagList'), 'tagList').to.have.members(['training', 'dragons'])\n   339→    expect(response.json('article.favorited'), 'favorited').to.be.false\n   340→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.be.a('number')\n   341→    expect(response.json('article.favoritesCount'), 'favoritesCount').to.equal(0)\n   342→  });\n   343→  describe('Create Comment for Article', () => {\n   344→\n   345→    let comment = {\n   346→      body: `Thank you so much!`,\n   347→    };\n   348→\n   349→    let response = session.post(`/articles/${slug}/comments`, JSON.stringify({ 'comment': comment }), params);\n   350→\n   351→    expect(response.status, 'create comment status').to.equal(200);\n   352→    expect(response).to.have.validJsonBody();\n   353→    expect(response.json('comment'), 'comment').to.be.an('object');\n   354→    expect(response.json('comment'), 'comment').to.include.keys('id', 'body', 'createdAt', 'updatedAt', 'author');\n   355→    commentId = response.json('comment.id')\n   356→    expect(response.json('comment.body'), 'body').to.be.a('string')\n   357→    expect(response.json('comment.body'), 'body').to.equal('Thank you so much!')\n   358→    expect(response.json('comment.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   359→    expect(response.json('comment.updatedAt'), 'updated at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   360→  });\n   361→  describe('Get Comments for Article', () => {\n   362→\n   363→    let response = session.get(`/articles/${slug}/comments`, params);\n   364→\n   365→    expect(response.status, 'get comment status').to.equal(200);\n   366→    expect(response).to.have.validJsonBody();\n   367→    expect(response.json('comments'), 'comments').to.be.an('array');\n   368→    expect(response.json('comments.0'), 'first comment').to.be.an('object');\n   369→    expect(response.json('comments.0'), 'comment').to.include.keys('id', 'body', 'createdAt', 'updatedAt', 'author');\n   370→    expect(response.json('comments.0.body'), 'body').to.be.a('string')\n   371→    expect(response.json('comments.0.body'), 'body').to.equal('Thank you so much!')\n   372→    expect(response.json('comments.0.createdAt'), 'created at is an ISO 8601 timestamp').to.match(/^\\d{4,}-[01]\\d-[0-3]\\dT[0-2]\\d:[0-5]\\d:[0-5]\\d.\\d+(?:[+-][0-2]\\d:[0-5]\\d|Z)$/)\n   373→    expect(response.json('commen