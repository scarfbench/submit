            .subject(subject)\n    44→                .claim(\"groups\", List.of(\"USER\"))\n    45→                .issuedAt(new Date())\n    46→                .expiration(new Date(System.currentTimeMillis() + 86400000)) // 24 hours\n    47→                .signWith(privateKey, Jwts.SIG.RS256)\n    48→                .compact();\n    49→    }\n    50→\n    51→    public String getSubjectFromToken(String token) {\n    52→        Claims claims = Jwts.parser()\n    53→                .verifyWith(publicKey)\n    54→                .build()\n    55→                .parseSignedClaims(token)\n    56→                .getPayload();\n    57→        return claims.getSubject();\n    58→    }\n    59→\n    60→    public boolean validateToken(String token) {\n    61→        try {\n    62→            Jwts.parser()\n    63→                    .verifyWith(publicKey)\n    64→                    .build()\n    65→                    .parseSignedClaims(token);\n    66→            return true;\n    67→        } catch (Exception e) {\n    68→            return false;\n    69→        }\n    70→    }\n    71→\n    72→    private PrivateKey loadPrivateKey() throws Exception {\n    73→        String keyContent;\n    74→        try (InputStream is = privateKeyResource.getInputStream()) {\n    75→            keyContent = new String(is.readAllBytes(), StandardCharsets.UTF_8);\n    76→        }\n    77→        keyContent = keyContent\n    78→                .replace(\"-----BEGIN PRIVATE KEY-----\", \"\")\n    79→                .replace(\"-----END PRIVATE KEY-----\", \"\")\n    80→                .replaceAll(\"\\\\s\", \"\");\n    81→        byte[] keyBytes = Base64.getDecoder().decode(keyContent);\n    82→        PKCS8EncodedKeySpec spec = new PKCS8EncodedKeySpec(keyBytes);\n    83→        KeyFactory kf = KeyFactory.getInstance(\"RSA\");\n    84→        return kf.generatePrivate(spec);\n    85→    }\n    86→\n    87→    private PublicKey loadPublicKey() throws Exception {\n    88→        String keyContent;\n    89→        try (InputStream is = publicKeyResource.getInputStream()) {\n    90→            keyContent = new String(is.readAllBytes(), StandardCharsets.UTF_8);\n    91→        }\n    92→        keyContent = keyContent\n    93→                .replace(\"-----BEGIN PUBLIC KEY-----\", \"\")\n    94→                .replace(\"-----END PUBLIC KEY-----\", \"\")\n    95→                .replaceAll(\"\\\\s\", \"\");\n    96→        byte[] keyBytes = Base64.getDecoder().decode(keyContent);\n    97→        X509EncodedKeySpec spec = new X509EncodedKeySpec(keyBytes);\n    98→        KeyFactory kf = KeyFactory.getInstance(\"RSA\");\n    99→        return kf.generatePublic(spec);\n   100→    }\n   101→}\n   102→"}]},"parent_tool_use_id":"toolu_bdrk_012KfdF9JWXxr5ZXdW7kSuCz","session_id":"77854f62-3341-42f0-ba47-aba7925f4b32","uuid":"2319c849-e1a4-4ac6-aeb6-bef67894c8c2"}
