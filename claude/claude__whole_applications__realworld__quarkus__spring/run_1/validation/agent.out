ateArticle createArticle;\n    31→  private final FindMostRecentArticlesByFilter findMostRecentArticlesByFilter;\n    32→  private final FindArticleBySlug findArticleBySlug;\n    33→  private final UpdateArticleBySlug updateArticleBySlug;\n    34→  private final DeleteArticleBySlug deleteArticleBySlug;\n    35→  private final CreateComment createComment;\n    36→  private final DeleteComment deleteComment;\n    37→  private final FindCommentsByArticleSlug findCommentsByArticleSlug;\n    38→  private final FavoriteArticle favoriteArticle;\n    39→  private final UnfavoriteArticle unfavoriteArticle;\n    40→  private final ObjectMapper noWrapRootValueObjectMapper;\n    41→  private final ResourceUtils resourceUtils;\n    42→\n    43→  @GetMapping(\"/feed\")\n    44→  public ResponseEntity<String> feed(\n    45→      @RequestParam(defaultValue = \"0\") int offset,\n    46→      @RequestParam(defaultValue = \"0\") int limit,\n    47→      Principal principal) throws JsonProcessingException {\n    48→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    49→    final var articlesFilter =\n    50→        new ArticleFilter(offset, resourceUtils.getLimit(limit), loggedUserId, null, null, null);\n    51→    final var articlesPageResult = findMostRecentArticlesByFilter.handle(articlesFilter);\n    52→    return ResponseEntity.ok(\n    53→        noWrapRootValueObjectMapper.writeValueAsString(\n    54→            resourceUtils.articlesResponse(articlesPageResult, loggedUserId)));\n    55→  }\n    56→\n    57→  @GetMapping\n    58→  public ResponseEntity<String> getArticles(\n    59→      @RequestParam(defaultValue = \"0\") int offset,\n    60→      @RequestParam(defaultValue = \"0\") int limit,\n    61→      @RequestParam(required = false) List<String> tag,\n    62→      @RequestParam(required = false) List<String> author,\n    63→      @RequestParam(required = false) List<String> favorited,\n    64→      Principal principal) throws JsonProcessingException {\n    65→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    66→    final var filter =\n    67→        new ArticleFilter(\n    68→            offset, resourceUtils.getLimit(limit), loggedUserId, tag, author, favorited);\n    69→    final var articlesPageResult = findArticlesByFilter.handle(filter);\n    70→    return ResponseEntity.ok(\n    71→        noWrapRootValueObjectMapper.writeValueAsString(\n    72→            resourceUtils.articlesResponse(articlesPageResult, loggedUserId)));\n    73→  }\n    74→\n    75→  @PostMapping\n    76→  @Transactional\n    77→  public ResponseEntity<Object> create(\n    78→      @Valid @RequestBody NewArticleRequest newArticleRequest,\n    79→      Principal principal) {\n    80→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    81→    final var article = createArticle.handle(newArticleRequest.toNewArticleInput(loggedUserId));\n    82→    return ResponseEntity.status(HttpStatus.CREATED)\n    83→        .body(resourceUtils.articleResponse(article, loggedUserId));\n    84→  }\n    85→\n    86→  @GetMapping(\"/{slug}\")\n    87→  public ResponseEntity<Object> findBySlug(@PathVariable String slug) {\n    88→    final var article = findArticleBySlug.handle(slug);\n    89→    return ResponseEntity.ok(resourceUtils.articleResponse(article, null));\n    90→  }\n    91→\n    92→  @PutMapping(\"/{slug}\")\n    93→  @Transactional\n    94→  public ResponseEntity<Object> update(\n    95→      @PathVariable String slug,\n    96→      @Valid @RequestBody UpdateArticleRequest updateArticleRequest,\n    97→      Principal principal) {\n    98→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n    99→    final var updatedArticle =\n   100→        updateArticleBySlug.handle(updateArticleRequest.toUpdateArticleInput(loggedUserId, slug));\n   101→    return ResponseEntity.ok(resourceUtils.articleResponse(updatedArticle, null));\n   102→  }\n   103→\n   104→  @DeleteMapping(\"/{slug}\")\n   105→  @Transactional\n   106→  public ResponseEntity<Void> delete(@PathVariable String slug, Principal principal) {\n   107→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   108→    deleteArticleBySlug.handle(loggedUserId, slug);\n   109→    return ResponseEntity.ok().build();\n   110→  }\n   111→\n   112→  @GetMapping(\"/{slug}/comments\")\n   113→  public ResponseEntity<String> getCommentsBySlug(\n   114→      @PathVariable String slug, Principal principal) throws JsonProcessingException {\n   115→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   116→    final var comments = findCommentsByArticleSlug.handle(slug);\n   117→    return ResponseEntity.ok(\n   118→        noWrapRootValueObjectMapper.writeValueAsString(\n   119→            resourceUtils.commentsResponse(comments, loggedUserId)));\n   120→  }\n   121→\n   122→  @PostMapping(\"/{slug}/comments\")\n   123→  @Transactional\n   124→  public ResponseEntity<Object> createComment(\n   125→      @PathVariable String slug,\n   126→      @Valid @RequestBody NewCommentRequest newCommentRequest,\n   127→      Principal principal) {\n   128→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   129→    final var comment =\n   130→        createComment.handle(newCommentRequest.toNewCommentInput(loggedUserId, slug));\n   131→    return ResponseEntity.ok(resourceUtils.commentResponse(comment, loggedUserId));\n   132→  }\n   133→\n   134→  @DeleteMapping(\"/{slug}/comments/{id}\")\n   135→  @Transactional\n   136→  public ResponseEntity<Void> deleteComment(\n   137→      @PathVariable String slug,\n   138→      @PathVariable UUID id,\n   139→      Principal principal) {\n   140→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   141→    deleteComment.handle(new DeleteCommentInput(id, loggedUserId, slug));\n   142→    return ResponseEntity.ok().build();\n   143→  }\n   144→\n   145→  @PostMapping(\"/{slug}/favorite\")\n   146→  @Transactional\n   147→  public ResponseEntity<Object> favoriteArticle(\n   148→      @PathVariable String slug, Principal principal) {\n   149→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   150→    favoriteArticle.handle(slug, loggedUserId);\n   151→    final var article = findArticleBySlug.handle(slug);\n   152→    return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   153→  }\n   154→\n   155→  @DeleteMapping(\"/{slug}/favorite\")\n   156→  @Transactional\n   157→  public ResponseEntity<Object> unfavoriteArticle(\n   158→      @PathVariable String slug, Principal principal) {\n   159→    final var loggedUserId = resourceUtils.getLoggedUserId(principal);\n   160→    unfavoriteArticle.handle(slug, loggedUserId);\n   161→    final var article = findArticleBySlug.handle(slug);\n   162→    return ResponseEntity.ok(resourceUtils.articleResponse(article, loggedUserId));\n   163→  }\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_bdrk_0143v2QXh2jTeshrVXPivYY6","session_id":"77854f62-3341-42f0-ba47-aba7925f4b32","uuid":"4e71b07e-c4aa-4e37-b920-b2233ec4988a"}
