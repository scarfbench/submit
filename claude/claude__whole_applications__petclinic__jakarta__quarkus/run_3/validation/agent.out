({\n    42→        @NamedQuery(\n    43→                name = \"Owner.getAll\",\n    44→                query = \"select o from Owner o order by o.lastName,o.firstName asc\"\n    45→        ),\n    46→        @NamedQuery(\n    47→                name = \"Owner.search\",\n    48→                query = \"select o from Owner o where o.searchindex like :searchterm order by o.lastName,o.firstName asc\"\n    49→        )\n    50→})\n    51→@EntityListeners(OwnerListener.class)\n    52→public class Owner extends EntityBaseObject implements Comparable<Owner>, Serializable {\n    53→\n    54→    public final static String TABLENAME = \"owner\";\n    55→    public final static String COL_ID = \"id\";\n    56→    public final static String COL_UUID = \"uuid\";\n    57→    public final static String COL_FIRSTNAME = \"first_name\";\n    58→    public final static String COL_LASTNAME = \"lastName\";\n    59→    public final static String COL_ADDRESS = \"address\";\n    60→    public final static String COL_HOUSENUMBER = \"housenumber\";\n    61→    public final static String COL_ADDRESS_INFO = \"address_info\";\n    62→    public final static String COL_CITY = \"city\";\n    63→    public final static String COL_ZIPCODE = \"zipcode\";\n    64→    public final static String COL_PHONENUMBER = \"phonenumber\";\n    65→    public final static String COL_EMAIL = \"email\";\n    66→    public final static String COL_SEARCHINDEX = \"searchindex\";\n    67→    private static final long serialVersionUID = 7995827646591579744L;\n    68→\n    69→    @Id\n    70→    @GeneratedValue(strategy = GenerationType.SEQUENCE, generator = \"owner_gen\")\n    71→    @SequenceGenerator(name=\"owner_gen\", sequenceName=\"owner_seq\")\n    72→    private Long id;\n    73→\n    74→    @Column(name = COL_UUID, nullable = false, unique = true, length = 36)\n    75→    private UUID uuid;\n    76→\n    77→    @Column(name = COL_SEARCHINDEX)\n    78→    private String searchindex;\n    79→\n    80→    @Column(name = COL_FIRSTNAME, nullable = false)\n    81→    @NotEmpty\n    82→    private String firstName;\n    83→\n    84→    @Column(name = COL_LASTNAME, nullable = false)\n    85→    @NotEmpty\n    86→    private String lastName;\n    87→\n    88→    @Column(name = COL_ADDRESS, nullable = false)\n    89→    @NotEmpty\n    90→    private String address;\n    91→\n    92→    @Column(name = COL_HOUSENUMBER, nullable = false)\n    93→    @NotEmpty\n    94→    private String houseNumber;\n    95→\n    96→    @Column(name = COL_ADDRESS_INFO)\n    97→    private String addressInfo;\n    98→\n    99→    @Column(name = COL_CITY, nullable = false)\n   100→    @NotEmpty\n   101→    private String city;\n   102→\n   103→    @Column(name = COL_ZIPCODE, nullable = false)\n   104→    @NotEmpty\n   105→    @Pattern(regexp = \"\\\\w{1,7}\\\\s{0,1}\\\\w{1,7}\\\\s{0,1}\\\\w{1,7}\", message = \"{invalid.zipCode}\")\n   106→    private String zipCode;\n   107→\n   108→    @Column(name = COL_PHONENUMBER, nullable = false)\n   109→    @NotEmpty\n   110→    @Pattern(regexp = \"\\\\+[1-9][0-9]\\\\s{0,1}[0-9]{0,5}\\\\s{0,1}[0-9]{4,16}\", message = \"{invalid.phoneNumber}\")\n   111→    private String phoneNumber;\n   112→\n   113→    @Column(name = COL_EMAIL, nullable = false, unique = true)\n   114→    @NotEmpty\n   115→    @Email\n   116→    private String email;\n   117→\n   118→    @Transient\n   119→    public String getFullname() { return this.lastName + \", \" + this.firstName; }\n   120→\n   121→    @Transient\n   122→    public String getTableName() { return TABLENAME; }\n   123→\n   124→    @Transient\n   125→    public String getPrimaryKey() { return \"\" + this.getFullName() + \" ( \" + this.getCity() + \" ) \"; }\n   126→\n   127→    public void setPrimaryKey(String primaryKey) {}\n   128→\n   129→    @Transient\n   130→    public String getPrimaryKeyWithId() { return this.getPrimaryKey() + \"(\" + this.getId() + \",\" + this.getUuid() + \")\"; }\n   131→\n   132→    @Override\n   133→    public void updateSearchindex() {\n   134→        List<String> l = new ArrayList<>();\n   135→        l.add(this.getFirstName());\n   136→        l.add(this.getLastName());\n   137→        l.add(this.getAddress());\n   138→        if (null != this.getAddressInfo()) { l.add(this.getAddressInfo()); }\n   139→        l.add(this.getHouseNumber());\n   140→        l.add(this.getZipCode());\n   141→        l.add(this.getCity());\n   142→        l.add(this.getPhoneNumber());\n   143→        l.add(this.getEmail());\n   144→        StringBuilder b = new StringBuilder();\n   145→        for (String ll : l) {\n   146→            for (String e : ll.split(\"\\\\W\")) { b.append(e); b.append(\" \"); }\n   147→        }\n   148→        this.setSearchindex(b.toString());\n   149→    }\n   150→\n   151→    @Transient\n   152→    public String getFullName() { return this.lastName + \", \" + this.firstName; }\n   153→\n   154→    @Override\n   155→    public boolean equals(Object o) {\n   156→        if (this == o) return true;\n   157→        if (!(o instanceof Owner)) return false;\n   158→        Owner owner = (Owner) o;\n   159→        return getFirstName().equals(owner.getFirstName()) && getLastName().equals(owner.getLastName()) && Objects.equals(getAddress(), owner.getAddress()) && Objects.equals(getHouseNumber(), owner.getHouseNumber()) && Objects.equals(getAddressInfo(), owner.getAddressInfo()) && Objects.equals(getCity(), owner.getCity()) && Objects.equals(getZipCode(), owner.getZipCode()) && getPhoneNumber().equals(owner.getPhoneNumber()) && getEmail().equals(owner.getEmail());\n   160→    }\n   161→\n   162→    @Override\n   163→    public int hashCode() { return Objects.hash(getFirstName(), getLastName(), getAddress(), getHouseNumber(), getAddressInfo(), getCity(), getZipCode(), getPhoneNumber(), getEmail()); }\n   164→\n   165→    @Override\n   166→    public int compareTo(Owner o) { return this.getFullname().compareTo(o.getFullname()); }\n   167→}\n   168→"}]},"