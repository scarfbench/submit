ache_read_input_tokens":73983,"cache_creation":{"ephemeral_5m_input_tokens":957,"ephemeral_1h_input_tokens":0},"output_tokens":540},"context_management":null},"parent_tool_use_id":null,"session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"bd807369-557a-4922-a350-8ed6254faa7a"}
