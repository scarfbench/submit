→        petType.setUuid(UUID.randomUUID());\n    52→        if(petType.getId() != null){\n    53→            throw new IllegalArgumentException(\"new PetType Entity must not have a PetType.id before persistings\");\n    54→        }\n    55→        entityManager.persist(petType);\n    56→        return petType;\n    57→    }\n    58→\n    59→    @Override\n    60→    public PetType findById(long id) {\n    61→        return entityManager.find(PetType.class, id);\n    62→    }\n    63→\n    64→    @Override\n    65→    public PetType update(PetType petType) {\n    66→        log.info(\"update PetType: \" + petType.toString());\n    67→        if(petType.getId() == null){\n    68→            throw new IllegalArgumentException(\"new PetType Entity must have a PetType.id before merging\");\n    69→        }\n    70→        return entityManager.merge(petType);\n    71→    }\n    72→\n    73→    @Override\n    74→    public List<PetType> search(String searchterm) {\n    75→        log.info(\"search PetType for: \" + searchterm);\n    76→        TypedQuery<PetType> q = entityManager.createNamedQuery( \"PetType.search\", PetType.class);\n    77→        q.setParameter(\"searchterm\", \"%\" + searchterm + \"%\");\n    78→        List<PetType> list = q.getResultList();\n    79→        return list;\n    80→    }\n    81→\n    82→    @Override\n    83→    public void resetSearchIndex() {\n    84→    }\n    85→\n    86→    @Override\n    87→    public PetType findByName(String name) {\n    88→        TypedQuery<PetType> query = entityManager.createNamedQuery( \"PetType.findByName\", PetType.class);\n    89→        query.setParameter(\"name\", name);\n    90→        return query.getSingleResult();\n    91→    }\n    92→\n    93→\n    94→    @PostActivate\n    95→    public void handlePostActivate() {\n    96→        log.info(\"PostActivate: \"+PetTypeDaoImpl.class.getSimpleName());\n    97→    }\n    98→\n    99→    @PrePassivate\n   100→    public void handlePrePassivate() {\n  