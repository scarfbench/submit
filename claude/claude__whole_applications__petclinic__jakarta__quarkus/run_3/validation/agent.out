{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_018L2Eey2c99o7iCw154n6Bz","type":"tool_result","content":"     1→package org.woehlke.jakartaee.petclinic.owner.api;\n     2→\n     3→\n     4→import jakarta.ejb.EJB;\n     5→import jakarta.ejb.Stateless;\n     6→import jakarta.json.bind.Jsonb;\n     7→import jakarta.json.bind.JsonbBuilder;\n     8→import jakarta.json.bind.JsonbException;\n     9→import jakarta.xml.bind.JAXBContext;\n    10→import jakarta.xml.bind.JAXBException;\n    11→import jakarta.xml.bind.Marshaller;\n    12→import lombok.extern.java.Log;\n    13→import org.woehlke.jakartaee.petclinic.owner.Owner;\n    14→import org.woehlke.jakartaee.petclinic.owner.db.OwnerService;\n    15→import org.woehlke.jakartaee.petclinic.pet.Pet;\n    16→import org.woehlke.jakartaee.petclinic.pet.api.PetEndpointUtil;\n    17→\n    18→import java.io.Serializable;\n    19→import java.io.StringWriter;\n    20→import java.util.ArrayList;\n    21→import java.util.List;\n    22→\n    23→\n    24→@Log\n    25→@Stateless\n    26→public class OwnerEndpointUtil implements Serializable {\n    27→\n    28→    private static final long serialVersionUID = 532726561254887897L;\n    29→\n    30→    @EJB\n    31→    private  PetEndpointUtil petEndpointUtil;\n    32→\n    33→    @EJB\n    34→    private OwnerService ownerService;\n    35→\n    36→    public OwnerDto dtoFactory(Owner o) {\n    37→        OwnerDto dto = new OwnerDto();\n    38→        dto.setId(o.getId());\n    39→        dto.setUuid(o.getUuid());\n    40→        dto.setFirstName(o.getFirstName());\n    41→        dto.setLastName(o.getLastName());\n    42→        dto.setAddress(o.getAddress());\n    43→        dto.setAddressInfo(o.getAddressInfo());\n    44→        dto.setHouseNumber(o.getHouseNumber());\n    45→        dto.setCity(o.getCity());\n    46→        dto.setZipCode(o.getZipCode());\n    47→        dto.setPhoneNumber(o.getPhoneNumber());\n    48→        List<Pet> petList = ownerService.getPetsAsList(o);\n    49→        dto.setPetList(this.petEndpointUtil.dtoListFactory(petList));\n    50→        return dto;\n    51→    }\n    52→\n    53→    public OwnerListDto dtoListFactory(List<Owner> sList) {\n    54→        List<OwnerDto> dtoList = new ArrayList<>();\n    55→        for (Owner o : sList) {\n    56→            OwnerDto dto = this.dtoFactory(o);\n    57→            dtoList.add(dto);\n    58→        }\n    59→        return new OwnerListDto(dtoList);\n    60→    }\n    61→\n    62→    public String dtoJsonFactory(OwnerDto dto) throws JsonbException {\n    63→        Jsonb jsonb = JsonbBuilder.create();\n    64→        return jsonb.toJson(dto);\n    65→    }\n    66→\n    67→    public String dtoListJsonFactory(OwnerListDto dtoList) throws JsonbException {\n    68→        Jsonb jsonb = JsonbBuilder.create();\n    69→        return jsonb.toJson(dtoList);\n    70→    }\n    71→\n    72→    public String dtoXmlFactory(OwnerDto dto) throws JAXBException {\n    73→        JAXBContext jc = JAXBContext.newInstance(OwnerDto.class);\n    74→        Marshaller m = jc.createMarshaller();\n    75→        StringWriter stringWriter = new StringWriter();\n    76→        m.marshal(dto, stringWriter);\n    77→        return stringWriter.toString();\n    78→    }\n    79→\n    80→    public String dtoListXmlFactory(OwnerListDto dtoList) throws JAXBException {\n    81→        JAXBContext jc = JAXBContext.newInstance(OwnerListDto.class);\n    82→        Marshaller m = jc.createMarshaller();\n    83→        StringWriter stringWriter = new StringWriter();\n    84→        m.marshal(dtoList, stringWriter);\n    85→        return stringWriter.toString();\n    86→    }\n    87→}\n    88→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"1b696e05-8d09-4c00-bdca-192bf72afc21"}
