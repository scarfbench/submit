e petType) {\n    45→        log.info(\"update PetType: \" + petType.toString());\n    46→        return entityManager.merge(petType);\n    47→    }\n    48→\n    49→    @Override\n    50→    @Transactional\n    51→    public void delete(long id) {\n    52→        PetType p = entityManager.find(PetType.class, id);\n    53→        log.info(\"delete PetType: \" + p.toString());\n    54→        entityManager.remove(p);\n    55→    }\n    56→\n    57→    @Override\n    58→    public PetType findByName(String name) {\n    59→        TypedQuery<PetType> q = entityManager.createNamedQuery(\"PetType.findByName\", PetType.class);\n    60→        q.setParameter(\"name\", name);\n    61→        List<PetType> list = q.getResultList();\n    62→        return list.isEmpty() ? null : list.get(0);\n    63→    }\n    64→\n    65→    @Override\n    66→    public List<PetType> search(String searchterm) {\n    67→        TypedQuery<PetType> q = entityManager.createNamedQuery(\"PetType.search\", PetType.class);\n    68→        q.setParameter(\"searchterm\", \"%\" + searchterm + \"%\");\n    69→        return q.getResultList();\n    70→    }\n    71→\n    72→    @Override\n    73→    public void resetSearchIndex() {}\n    74→\n    75→    @PostConstruct\n    76→    public void postConstruct() { log.info(\"postConstruct: \" + PetTypeDaoImpl.class.getSimpleName()); }\n    77→\n    78→    @PreDestroy\n    79→    public void preDestroy() { log.info(\"preDestroy: \" + PetTypeDaoImpl.class.getSimpleName()); }\n    80→}\n    81→"}]},"parent_tool_use_id":"toolu_bdrk_01BVxsuvScFF2RgfTY7nWEXd","session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"0da9f3a6-06ad-4ad9-b4e0-3cedd95fdb5b"}
