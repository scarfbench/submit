ic class Pet extends EntityBaseObject implements EntityBase, Comparable<Pet>, Serializable {\n    36→\n    37→    public final static String TABLENAME = \"owner_pet\";\n    38→    public final static String COL_ID = \"id\";\n    39→    public final static String COL_UUID = \"uuid\";\n    40→    public final static String COL_NAME = \"name\";\n    41→    public final static String COL_BIRTH_DATE = \"birth_date\";\n    42→    public final static String COL_PETTYPE_ID = \"owner_pet_pettype_id\";\n    43→    public final static String COL_OWNER_ID = \"owner_id\";\n    44→    public final static String COL_SEARCHINDEX = \"searchindex\";\n    45→    private static final long serialVersionUID = 1007513582768464905L;\n    46→\n    47→    @Id\n    48→    @GeneratedValue(strategy = GenerationType.SEQUENCE, generator = \"owner_pet_gen\")\n    49→    @SequenceGenerator(name = \"owner_pet_gen\", sequenceName = \"owner_pet_seq\")\n    50→    private Long id;\n    51→\n    52→    @Column(name = COL_UUID, nullable = false, unique = true, length = 36)\n    53→    private UUID uuid;\n    54→\n    55→    @Column(name = COL_SEARCHINDEX, nullable = true)\n    56→    private String searchindex;\n    57→\n    58→    @NotNull\n    59→    @Column(name = COL_BIRTH_DATE, columnDefinition = \"DATE\", nullable = false)\n    60→    @Temporal(TemporalType.DATE)\n    61→    protected Date birthDate;\n    62→\n    63→    @NotNull\n    64→    @NotEmpty\n    65→    @Column(name = COL_NAME, nullable = false)\n    66→    private String name;\n    67→\n    68→    @NotNull\n    69→    @ManyToOne(fetch = FetchType.EAGER, cascade = {CascadeType.REFRESH, CascadeType.DETACH, CascadeType.MERGE}, targetEntity = PetType.class, optional = false)\n    70→    @JoinColumn(name = COL_PETTYPE_ID)\n    71→    private PetType type;\n    72→\n    73→    @NotNull\n    74→    @ManyToOne(fetch = FetchType.EAGER, cascade = {CascadeType.REFRESH, CascadeType.DETACH, CascadeType.MERGE}, targetEntity = Owner.class, optional = false)\n    75→    @JoinColumn(name = COL_OWNER_ID)\n    76→    private Owner owner;\n    77→\n    78→    @Transient\n    79→    public String getTableName() { return TABLENAME; }\n    80→\n    81→    @Transient\n    82→    public String getPrimaryKey() { return \"\" + this.getBirthDate().toInstant().toString() + \" ( \" + this.getName() + \")\"; }\n    83→\n    84→    @Transient\n    85→    public String getPrimaryKeyWithId() { return this.getPrimaryKey() + \"(\" + this.getId() + \",\" + this.getUuid() + \")\"; }\n    86→\n    87→    @Override\n    88→    public void updateSearchindex() {\n    89→        String[] element = this.getName().split(\"\\\\W\");\n    90→        StringBuilder b = new StringBuilder();\n    91→        for (String e : element) { b.append(e); b.append(\" \"); }\n    92→        this.setSearchindex(b.toString());\n    93→    }\n    94→\n    95→    @Override\n    96→    public boolean equals(Object o) {\n    97→        if (this == o) return true;\n    98→        if (!(o instanceof Pet)) return false;\n    99→        Pet pet = (Pet) o;\n   100→        return Objects.equals(getBirthDate(), pet.getBirthDate()) && Objects.equals(getName(), pet.getName()) && Objects.equals(getType(), pet.getType()) && Objects.equals(getOwner(), pet.getOwner());\n   101→    }\n   102→\n   103→    @Override\n   104→    public int hashCode() { return Objects.hash(getBirthDate(), getName(), getType(), getOwner()); }\n   105→\n   106→    @Override\n   107→    public int compareTo(Pet o) { return this.getName().compareTo(o.getName()); }\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_bdrk_01Jtmwy4C55pn26VP51FvkAw","session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"b1452047-e99f-4bf5-ba2a-d54bff202897"}
