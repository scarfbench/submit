to dto = this.dtoFactory(vet);\n            dtoList.add(dto);\n        }\n        return new VetListDto(dtoList);\n    }\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":7943,"cache_read_input_tokens":18292,"cache_creation":{"ephemeral_5m_input_tokens":7943,"ephemeral_1h_input_tokens":0},"output_tokens":3465},"context_management":null},"parent_tool_use_id":"toolu_bdrk_012zv1JZKtc6pA5NHL9ZZ36c","session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"eca1c715-f5f5-4103-a1b3-535728f98f46"}
