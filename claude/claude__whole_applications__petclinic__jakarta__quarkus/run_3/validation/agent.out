rializable {\n    34→\n    35→    public final static String TABLENAME = \"owner_pet_pettype\";\n    36→    public final static String COL_ID = \"id\";\n    37→    public final static String COL_UUID = \"uuid\";\n    38→    public final static String COL_NAME = \"name\";\n    39→    public final static String COL_SEARCHINDEX = \"searchindex\";\n    40→    private static final long serialVersionUID = -836560513920170023L;\n    41→\n    42→    @Id\n    43→    @GeneratedValue(strategy = GenerationType.SEQUENCE, generator = \"owner_pet_pettype_gen\")\n    44→    @SequenceGenerator(name = \"owner_pet_pettype_gen\", sequenceName = \"owner_pet_pettype_seq\")\n    45→    private Long id;\n    46→\n    47→    @Column(name = COL_UUID, nullable = false, unique = true, length = 36)\n    48→    private UUID uuid;\n    49→\n    50→    @Column(name = COL_SEARCHINDEX)\n    51→    private String searchindex;\n    52→\n    53→    @NotEmpty\n    54→    @Column(name = COL_NAME, unique = true, nullable = false)\n    55→    private String name;\n    56→\n    57→    @Transient\n    58→    public String getTableName() { return TABLENAME; }\n    59→\n    60→    @Transient\n    61→    public String getPrimaryKey() { return this.getName(); }\n    62→\n    63→    @Transient\n    64→    public String getPrimaryKeyWithId() { return this.getPrimaryKey() + \"(\" + this.getId() + \",\" + this.getUuid() + \")\"; }\n    65→\n    66→    @Override\n    67→    public void updateSearchindex() {\n    68→        String[] element = this.getName().split(\"\\\\W\");\n    69→        StringBuilder b = new StringBuilder();\n    70→        for (String e : element) { b.append(e); b.append(\" \"); }\n    71→        this.setSearchindex(b.toString());\n    72→    }\n    73→\n    74→    public static PetType newEntity() {\n    75→        PetType o = new PetType();\n    76→        o.setUuid(UUID.randomUUID());\n    77→        return o;\n    78→    }\n    79→\n    80→    public static PetType newEntity(String name) {\n    81→        PetType o = new PetType();\n    82→        o.setUuid(UUID.randomUUID());\n    83→        o.setName(name);\n    84→        return o;\n    85→    }\n    86→\n    87→    @Override\n    88→    public boolean equals(Object o) {\n    89→        if (this == o) return true;\n    90→        if (!(o instanceof PetType)) return false;\n    91→        PetType petType = (PetType) o;\n    92→        return getName().equals(petType.getName());\n    93→    }\n    94→\n    95→    @Override\n    96→    public int hashCode() { return Objects.hash(getName()); }\n    97→\n    98→    @Override\n    99→    public int compareTo(PetType o) { return this.getName().compareTo(o.getName()); }\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_bdrk_01BVxsuvScFF2RgfTY7nWEXd","session_id":"c5bd7990-ebbe-4b4c-8bc8-ce64a20596ca","uuid":"038204f8-65e0-4e00-a8c6-9d7f4828f1dc"}
