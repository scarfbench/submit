{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01LRb728RvuXzSKzgnF7z6Cw","type":"tool_result","content":"     1→package org.woehlke.jakartaee.petclinic.application.framework.views;\n     2→\n     3→import lombok.Getter;\n     4→import lombok.extern.java.Log;\n     5→\n     6→import java.io.Serializable;\n     7→\n     8→/**\n     9→ *\n    10→ */\n    11→@Log\n    12→public abstract class CrudFlowViewImpl implements CrudFlowView, Serializable {\n    13→\n    14→    private static final long serialVersionUID = -143286438L;\n    15→\n    16→    private CrudFlowState flowState;\n    17→\n    18→    public CrudFlowState getFlowState() {\n    19→        if (this.flowState == null) {\n    20→            this.flowState = CrudFlowState.LIST;\n    21→        }\n    22→        return flowState;\n    23→    }\n    24→\n    25→    @Override\n    26→    public boolean isFlowStateList() {\n    27→        return CrudFlowState.LIST == this.getFlowState();\n    28→    }\n    29→\n    30→    @Override\n    31→    public boolean isFlowStateDetails(){\n    32→        return CrudFlowState.DETAILS  == this.getFlowState();\n    33→    }\n    34→\n    35→    @Override\n    36→    public boolean isFlowStateNew() {\n    37→        return CrudFlowState.NEW == this.getFlowState();\n    38→    }\n    39→\n    40→    @Override\n    41→    public boolean isFlowStateEdit() {\n    42→        return CrudFlowState.EDIT == this.getFlowState();\n    43→    }\n    44→\n    45→    @Override\n    46→    public boolean isFlowStateDelete() {\n    47→        return CrudFlowState.DELETE == this.getFlowState();\n    48→    }\n    49→\n    50→    @Override\n    51→    public boolean isFlowStateSearchResult() {\n    52→        return CrudFlowState.LIST_SEARCH_RESULT == this.getFlowState();\n    53→    }\n    54→\n    55→\n    56→    public void logFlowState(){\n    57→        String msg = \"flowState: \" + this.flowState.name();\n    58→        log.info(msg);\n    59→    }\n    60→