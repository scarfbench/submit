{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01JygH1ENzm2evFRsv1DXYYP","type":"tool_result","content":"     1→-- Sequences\n     2→CREATE SEQUENCE IF NOT EXISTS specialty_seq START WITH 100 INCREMENT BY 50;\n     3→CREATE SEQUENCE IF NOT EXISTS owner_pet_pettype_seq START WITH 100 INCREMENT BY 50;\n     4→CREATE SEQUENCE IF NOT EXISTS vet_seq START WITH 100 INCREMENT BY 50;\n     5→CREATE SEQUENCE IF NOT EXISTS owner_seq START WITH 100 INCREMENT BY 50;\n     6→CREATE SEQUENCE IF NOT EXISTS owner_pet_seq START WITH 100 INCREMENT BY 50;\n     7→CREATE SEQUENCE IF NOT EXISTS owner_pet_visit_seq START WITH 100 INCREMENT BY 50;\n     8→\n     9→-- Specialties\n    10→INSERT INTO specialty (id, uuid, name, searchindex) VALUES (1, 'a1111111-1111-1111-1111-111111111111', 'radiology', 'radiology ');\n    11→INSERT INTO specialty (id, uuid, name, searchindex) VALUES (2, 'a2222222-2222-2222-2222-222222222222', 'surgery', 'surgery ');\n    12→INSERT INTO specialty (id, uuid, name, searchindex) VALUES (3, 'a3333333-3333-3333-3333-333333333333', 'dentistry', 'dentistry ');\n    13→\n    14→-- Pet Types\n    15→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (1, 'b1111111-1111-1111-1111-111111111111', 'cat', 'cat ');\n    16→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (2, 'b2222222-2222-2222-2222-222222222222', 'dog', 'dog ');\n    17→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (3, 'b3333333-3333-3333-3333-333333333333', 'lizard', 'lizard ');\n    18→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (4, 'b4444444-4444-4444-4444-444444444444', 'snake', 'snake ');\n    19→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (5, 'b5555555-5555-5555-5555-555555555555', 'bird', 'bird ');\n    20→INSERT INTO owner_pet_pettype (id, uuid, name, searchindex) VALUES (6, 'b6666666-6666-6666-6666-666666666666', 'hamster', 'hamster ');\n    21→\n    22→-- Vets\n    23→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (1, 'c1111111-1111-1111-1111-111111111111', 'James', 'Carter', 'James Carter ');\n    24→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (2, 'c2222222-2222-2222-2222-222222222222', 'Helen', 'Leary', 'Helen Leary radiology ');\n    25→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (3, 'c3333333-3333-3333-3333-333333333333', 'Linda', 'Douglas', 'Linda Douglas dentistry surgery ');\n    26→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (4, 'c4444444-4444-4444-4444-444444444444', 'Rafael', 'Ortega', 'Rafael Ortega surgery ');\n    27→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (5, 'c5555555-5555-5555-5555-555555555555', 'Henry', 'Stevens', 'Henry Stevens radiology ');\n    28→INSERT INTO vet (id, uuid, first_name, \"lastName\", searchindex) VALUES (6, 'c6666666-6666-6666-6666-666666666666', 'Sharon', 'Jenkins', 'Sharon Jenkins ');\n    29→\n    30→-- Vet Specialties\n    31→INSERT INTO vet_specialties (vet_id, specialty_id) VALUES (2, 1);\n    32→INSERT INTO vet_specialties (vet_id, specialty_id) VALUES (3, 2);\n    33→INSERT INTO vet_specialties (vet_id, specialty_id) VALUES (3, 3);\n    34→INSERT INTO vet_specialties (vet_id, specialty_id) VALUES (4, 2);\n    35→INSERT INTO vet_specialties (vet_id, specialty_id) VALUES (5, 1);\n    36→\n    37→-- Owners\n    38→INSERT INTO owner (id, uuid, first_name, \"lastName\", address, housenumber, address_info, city, zipcode, phonenumber, email, searchindex) VALUES (1, 'd1111111-1111-1111-1111-111111111111', 'George', 'Franklin', '110 W. Liberty St.', '1', NULL, 'Madison', '53711', '+49 1234 567890', 'george.franklin@example.com', 'George Franklin 110 W Liberty St 1 Madison 53711 49 1234 567890 george franklin example com ');\n    39→INSERT INTO owner (id, uuid, first_name, \"lastName\", address, housenumber, address_info, city, zipcode, phonenumber, 