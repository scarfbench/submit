logFlowState(){\n    60→        String msg = \"flowState: \" + this.flowState.name();\n    61→        log.info(msg);\n    62→    }\n    63→\n    64→    @Override\n    65→    public boolean isFlowStateNewPet() {\n    66→        return this.getFlowState() == OwnerFlowState.NEW_PET;\n    67→    }\n    68→\n    69→    @Override\n    70→    public boolean isFlowStateEditPet() {\n    71→        return this.getFlowState() == OwnerFlowState.EDIT_PET;\n    72→    }\n    73→\n    74→    @Override\n    75→    public boolean isFlowStateNewVisit() {\n    76→        return this.getFlowState() == OwnerFlowState.NEW_VISIT;\n    77→    }\n    78→\n    79→    @Override\n    80→    public void setFlowStateNewVisit() {\n    81→        this.flowState = OwnerFlowState.NEW_VISIT;\n    82→        logFlowState();\n    83→    }\n    84→\n    85→    @Override\n    86→    public void setFlowStateNewPet() {\n    87→        this.flowState = OwnerFlowState.NEW_PET;\n    88→        logFlowState();\n    89→    }\n    90→\n    91→    @Override\n    92→    public void setFlowStateEditPet() {\n    93→        this.flowState = OwnerFlowState.EDIT_PET;\n    94→        logFlowState();\n    95→    }\n    96→\n    97→    @Override\n    98→    public void setFlowStateList() {\n    99→        this.flowState = OwnerFlowState.LIST;\n   100→        logFlowState();\n   101→    }\n   102→\n   103→    @Override\n   104→    public void setFlowStateDetails() {\n   105→        this.flowState = OwnerFlowState.DETAILS;\n   106→        logFlowState();\n   107→    }\n   108→\n   109→    @Override\n   110→    public void setFlowStateNew() {\n   111→        this.flowState = OwnerFlowState.NEW_OWNER;\n   112→        logFlowState();\n   113→    }\n   114→\n   115→    @Override\n   116→    public void setFlowStateEdit() {\n   117→        this.flowState = OwnerFlowState.EDIT_OWNER;\n   118→        logFlowState();\n   119→    }\n   120→\n   121→    @Override\n   122→    public void setFlowStateDelete() {\n   123→        this.flowState = OwnerFlowState.DELETE_OWNER;\n   124→        logFlowState();\n   125→    }\n   126→\n   127→    @Override\n   128→    public void setFlowStateSearchResult() {\n   129→        this.flowState = OwnerFlowState.LIST_SEARCH_RESULT;\n   130→        logFlowState();\n   131→    }\n   132→\n   133→    public boolean isRenderPanelDetailsOwner() {\n   134→        return this.isFlowStateDetails();\n   135→    }\n   136→\n   137→    public boolean isRenderPanelAddNewOwner() {\n   138→        return this.isFlowStateNew();\n   139→    }\n   140→\n   141→    public boolean isRenderPanelEditOwner() {\n   142→        return this.isFlowStateEdit();\n   143→    }\n   144→\n   145→    public boolean isRenderPanelOwner() {\n   146→        return false;\n   147→    }\n   148→\n   149→    public boolean isRenderPanelOwnerList() {\n   150→        return true;\n   151→    }\n   152→\n   153→    public boolean isRenderPanelEditOwnersPet() {\n   154→        return this.isFlowStateEditPet();\n   155→    }\n   156→\n   157→    public boolean isRenderPanelAddNewOwnersPet() {\n   158→        return this.isFlowStateNewPet();\n   159→    }\n   160→\n   161→    public boolean isRenderPanelAddNewOwnersPetVisit() {\n   162→        return this.isFlowStateNewVisit();\n   163→    }\n   164→}\n   165→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01LybypoCqVuNsHeZ1jT7hbG","session_id":"faf55576-b919-4f0c-9954-ff7c05fa2fb1","uuid":"c98d3664-9816-4b8f-ad27-58846361da77"}
