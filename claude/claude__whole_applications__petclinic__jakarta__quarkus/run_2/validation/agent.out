erialization**: Support for both JSON (JSON-B) and XML (JAXB) formats"}]}]},"parent_tool_use_id":null,"session_id":"b5335c7b-0969-4f64-b148-77b8530ff921","uuid":"941fa528-8a41-43d2-8d34-5693bb6a84cd"}
