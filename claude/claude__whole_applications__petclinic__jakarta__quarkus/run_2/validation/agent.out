2026-03-14 08:52:13,026 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mINSERT\u001b[0m \u001b[34mINTO\u001b[0m vet_specialties (vet_id, specialty_id) \u001b[34mVALUES\u001b[0m (1, 4)\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mINSERT\u001b[0m \u001b[34mINTO\u001b[0m vet_specialties (vet_id, specialty_id) \u001b[34mVALUES\u001b[0m (1, 4)\n2026-03-14 08:52:13,028 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mINSERT\u001b[0m \u001b[34mINTO\u001b[0m vet_specialties (vet_id, specialty_id) \u001b[34mVALUES\u001b[0m (2, 7)\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mINSERT\u001b[0m \u001b[34mINTO\u001b[0m vet_specialties (vet_id, specialty_id) \u001b[34mVALUES\u001b[0m (2, 7)\n2026-03-14 08:52:13,030 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_seq RESTART \u001b[34mWITH\u001b[0m 100\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_seq RESTART \u001b[34mWITH\u001b[0m 100\n2026-03-14 08:52:13,033 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_seq RESTART \u001b[34mWITH\u001b[0m 100\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_seq RESTART \u001b[34mWITH\u001b[0m 100\n2026-03-14 08:52:13,036 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_pettype_seq RESTART \u001b[34mWITH\u001b[0m 100\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_pettype_seq RESTART \u001b[34mWITH\u001b[0m 100\n2026-03-14 08:52:13,041 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_visit_seq RESTART \u001b[34mWITH\u001b[0m 100\n\u001b[35m[Hibernate]\u001b[0m \u001b[34mALTER\u001b[0m \u001b[34mSEQUENCE\u001b[0m owner_pet_visit_seq RESTART \u001b[34mWITH\u001b[0m 100\n2026-03-14 08:52:13,044 DEBUG [org.hib.SQL] (JPA Startup Thread) \u001b[34mALTER