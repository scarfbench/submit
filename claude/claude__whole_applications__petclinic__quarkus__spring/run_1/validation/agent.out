  <dependencies>\n    34→    <dependency>\n    35→      <groupId>io.quarkus</groupId>\n    36→      <artifactId>quarkus-rest</artifactId>\n    37→    </dependency>\n    38→    <dependency>\n    39→      <groupId>io.quarkus</groupId>\n    40→      <artifactId>quarkus-rest-jackson</artifactId>\n    41→    </dependency>\n    42→    <dependency>\n    43→      <groupId>io.quarkus</groupId>\n    44→      <artifactId>quarkus-rest-qute</artifactId>\n    45→    </dependency>\n    46→\n    47→    <dependency>\n    48→      <groupId>io.quarkus</groupId>\n    49→      <artifactId>quarkus-hibernate-orm-panache</artifactId>\n    50→    </dependency>\n    51→    <dependency>\n    52→      <groupId>io.quarkus</groupId>\n    53→      <artifactId>quarkus-hibernate-validator</artifactId>\n    54→    </dependency>\n    55→\n    56→    <dependency>\n    57→      <groupId>io.quarkus</groupId>\n    58→      <artifactId>quarkus-jdbc-postgresql</artifactId>\n    59→    </dependency>\n    60→    <!-- H2 for dev mode (smoke tests) -->\n    61→    <dependency>\n    62→      <groupId>io.quarkus</groupId>\n    63→      <artifactId>quarkus-jdbc-h2</artifactId>\n    64→    </dependency>\n    65→\n    66→    <!-- container stuff -->\n    67→    <dependency>\n    68→      <groupId>io.quarkus</groupId>\n    69→      <artifactId>quarkus-container-image-jib</artifactId>\n    70→    </dependency>\n    71→    <dependency>\n    72→      <groupId>io.quarkus</groupId>\n    73→      <artifactId>quarkus-kubernetes</artifactId>\n    74→    </dependency>\n    75→\n    76→    <!-- Webjars -->\n    77→    <dependency>\n    78→      <groupId>io.quarkus</groupId>\n    79→      <artifactId>quarkus-web-dependency-locator</artifactId>\n    80→    </dependency>\n    81→    <dependency>\n    82→      <groupId>org.webjars.npm</groupId>\n    83→      <artifactId>bootstrap</artifactId>\n    84→      <version>${webjars-bootstrap.version}</version>\n    85→    </dependency>\n    86→    <dependency>\n    87→      <groupId>org.webjars.npm</groupId>\n    88→      <artifactId>font-awesome</artifactId>\n    89→      <version>${webjars-font-awesome.version}</version>\n    90→    </dependency>\n    91→\n    92→    <dependency>\n    93→      <groupId>io.quarkus</groupId>\n    94→      <artifactId>quarkus-junit5</artifactId>\n    95→      <scope>test</scope>\n    96→    </dependency>\n    97→    <dependency>\n    98→      <groupId>io.rest-assured</groupId>\n    99→      <artifactId>rest-assured</artifactId>\n   100→      <scope>test</scope>\n   101→    </dependency>\n   102→  </dependencies>\n   103→  <build>\n   104→    <plugins>\n   105→      <plugin>\n   106→        <groupId>io.quarkus</groupId>\n   107→        <artifactId>quarkus-maven-plugin</artifactId>\n   108→        <version>${quarkus.platform.version}</version>\n   109→        <extensions>true</extensions>\n   110→        <executions>\n   111→          <execution>\n   112→            <goals>\n   113→              <goal>build</goal>\n   114→              <goal>generate-code</goal>\n   115→              <goal>generate-code-tests</goal>\n   116→            </goals>\n   117→          </execution>\n   118→        </executions>\n   119→      </plugin>\n   120→      <plugin>\n   121→        <artifactId>maven-compiler-plugin</artifactId>\n   122→        <version>${compiler-plugin.version}</version>\n   123→      </plugin>\n   124→      <plugin>\n   125→        <artifactId>maven-surefire-plugin</artifactId>\n   126→        <version>${surefire-plugin.version}</version>\n   127→        <configuration>\n   128→          <systemPropertyVariables>\n   129→            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   130→            <maven.home>${maven.home}</maven.home>\n   131→          </systemPropertyVariables>\n   132→        </configuration>\n   133→      </plugin>\n   134→    </plugins>\n   135→  </build>\n   136→  <profiles>\n   137→    <profile>\n   138→      <id>native</id>\n   139→      <activation