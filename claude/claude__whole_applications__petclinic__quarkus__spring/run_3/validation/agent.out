.webjars.npm</groupId>\n    88→      <artifactId>font-awesome</artifactId>\n    89→      <version>${webjars-font-awesome.version}</version>\n    90→    </dependency>\n    91→\n    92→    <dependency>\n    93→      <groupId>io.quarkus</groupId>\n    94→      <artifactId>quarkus-junit5</artifactId>\n    95→      <scope>test</scope>\n    96→    </dependency>\n    97→    <dependency>\n    98→      <groupId>io.rest-assured</groupId>\n    99→      <artifactId>rest-assured</artifactId>\n   100→      <scope>test</scope>\n   101→    </dependency>\n   102→  </dependencies>\n   103→  <build>\n   104→    <plugins>\n   105→      <plugin>\n   106→        <groupId>io.quarkus</groupId>\n   107→        <artifactId>quarkus-maven-plugin</artifactId>\n   108→        <version>${quarkus.platform.version}</version>\n   109→        <extensions>true</extensions>\n   110→        <executions>\n   111→          <execution>\n   112→            <goals>\n   113→              <goal>build</goal>\n   114→              <goal>generate-code</goal>\n   115→              <goal>generate-code-tests</goal>\n   116→            </goals>\n   117→          </execution>\n   118→        </executions>\n   119→      </plugin>\n   120→      <plugin>\n   121→        <artifactId>maven-compiler-plugin</artifactId>\n   122→        <version>${compiler-plugin.version}</version>\n   123→      </plugin>\n   124→      <plugin>\n   125→        <artifactId>maven-surefire-plugin</artifactId>\n   126→        <version>${surefire-plugin.version}</version>\n   127→        <configuration>\n   128→          <systemPropertyVariables>\n   129→            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   130→            <maven.home>${maven.home}</maven.home>\n   131→          </systemPropertyVariables>\n   132→        </configuration>\n   133→      </plugin>\n   134→    </plugins>\n   135→  </build>\n   136→  <profiles>\n   137→    <profile>\n   138→      <id>native</id>\n   139→      <activation>\n   140→        <property>\n   141→          <name>native</name>\n   142→        </property>\n   143→      </activation>\n   144→      <build>\n   145→        <plugins>\n   146→          <plugin>\n   147→            <artifactId>maven-failsafe-plugin</artifactId>\n   148→            <version>${surefire-plugin.version}</version>\n   149→            <executions>\n   150→              <execution>\n   151→                <goals>\n   152→                  <goal>integration-test</goal>\n   153→                  <goal>verify</goal>\n   154→                </goals>\n   155→                <configuration>\n   156→                  <systemPropertyVariables>\n   157→                    <native.image.path>${project.build.directory}/${project.build.finalName}-runner</native.image.path>\n   158→                    <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   159→                    <maven.home>${maven.home}</maven.home>\n   160→                  </systemPropertyVariables>\n   161→                </configuration>\n   162→              </execution>\n   163→            </executions>\n   164→          </plugin>\n   165→        </plugins>\n   166→      </build>\n   167→      <properties>\n   168→        <quarkus.package.type>native</quarkus.package.type>\n   169→      </properties>\n   170→    </profile>\n   171→\n   172→    <profile>\n   173→      <id>css</id>\n   174→      <build>\n   175→        <plugins>\n   176→          <plugin>\n   177→            <groupId>org.apache.maven.plugins</groupId>\n   178→            <artifactId>maven-dependency-plugin</artifactId>\n   179→            <executions>\n   180→              <execution>\n   181→                <id>unpack</id>\n   182→                <?m2e execute onConfiguration,onIncremental?>\n   183→                <phase>generate-resources</phase>\n   184→                <goals>\n   185→                  <goal>unpack</goal>\n   186→                </goals>\n   187→                <configuration>\n   188→                  <artifactItems>\n   189→                    <artifactItem>\n   190→                      <groupId>org.webjars.npm</groupId>\n   191→                      <artifactId>bootstrap</artifactId>\n   192→                      <version>${webjars-bootstrap.version}</version>\n   193→                    </artifactItem>\n   194→                  </artifactItems>\n   195→                  <outputDirectory>${project.build.directory}/webjars</outputDirectory>\n   196→                </configuration>\n   197→              </execution>\n   198→            </executions>\n   199→          </plugin>\n   200→\n   201→          <plugin>\n   202→            <groupId>com.gitlab.haynes</groupId>\n   203→            <artifactId>libsass-maven-plugin</artifactId>\n   204→            <version>0.2.26</version>\n   205→            <executions>\n   206→              <execution>\n   207→                <phase>generate-resources</phase>\n   208→                <?m2e execute onConfiguration,onIncremental?>\n   209→                <goals>\n   210→                  <goal>compile</goal>\n   211→                </goals>\n   212→              </execution>\n   213→            </executions>\n   214→            <configuration>\n   215→              <inputPath>${basedir}/src/main/scss/</inputPath>\n   216→              <outputPath>${basedir}/src/main/resources/META-INF/resources/css/</outputPath>\n   217→              <includePath>${project.build.directory}/webjars/META-INF/resources/webjars/bootstrap/${webjars-bootstrap.version}/scss/</includePath>\n   218→            </configuration>\n   219→          </plugin>\n   220→        </plugins>\n   221→      </build>\n   222→    </profile>\n   223→\n   224→  </profiles>\n   225→</project>\n   226→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01TK8wd92JDfXyknycussato","session_id":"d5033181-b1d4-4ac6-8656-753e13eb13fa","uuid":"382a0925-0a07-4168-8eeb-89fc2cc253eb"}
