{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01SL4W55134sQRZ25YqQEh7b","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Smoke tests for DayTrader Jakarta EE application.\n     4→Tests core functionality: health, quotes, trading, accounts.\n     5→\"\"\"\n     6→\n     7→import sys\n     8→import time\n     9→import requests\n    10→import json\n    11→\n    12→BASE_URL = None\n    13→\n    14→def get_base_url():\n    15→    \"\"\"Get base URL from command line or environment.\"\"\"\n    16→    global BASE_URL\n    17→    if len(sys.argv) > 1:\n    18→        BASE_URL = sys.argv[1].rstrip('/')\n    19→    else:\n    20→        import os\n    21→        port = os.environ.get('APP_PORT', '8080')\n    22→        BASE_URL = f\"http://localhost:{port}\"\n    23→    return BASE_URL\n    24→\n    25→\n    26→def wait_for_app(timeout=120):\n    27→    \"\"\"Wait for the application to become available.\"\"\"\n    28→    print(f\"Waiting for application at {BASE_URL} (timeout={timeout}s)...\")\n    29→    start = time.time()\n    30→    while time.time() - start < timeout:\n    31→        try:\n    32→            r = requests.get(f\"{BASE_URL}/rest/trade/market\", timeout=5)\n    33→            if r.status_code in (200, 500):\n    34→                print(f\"Application is responding (status={r.status_code})\")\n    35→                # Give it a moment for DB population to complete\n    36→                time.sleep(5)\n    37→                return True\n    38→        except requests.exceptions.ConnectionError:\n    39→            pass\n    40→        except requests.exceptions.Timeout:\n    41→            pass\n    42→        time.sleep(2)\n    43→    print(\"ERROR: Application did not start within timeout\")\n    44→    return False\n    45→\n    46→\n    47→def test_market_summary():\n    48→    \"\"\"Test GET /rest/trade/market - market summary endpoint.\"\"\"\n    49→    print(\"\\n--- Test: Market Summary ---\")\n    50→    try:\n    51→        r = requests.get(f\"{BASE_URL}/rest/trade/market\", timeout=10)\n    52→        print(f\"  Status: {r.status_code}\")\n    53→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    54→        data = r.json()\n    55→        print(f\"  TSIA: {data.get('tsia', 'N/A')}\")\n    56→        print(f\"  PASS\")\n    57→        return True\n    58→    except Exception as e:\n    59→        print(f\"  FAIL: {e}\")\n    60→        return False\n    61→\n    62→\n    63→def test_get_quote():\n    64→    \"\"\"Test GET /rest/quotes/s:0 - get a stock quote.\"\"\"\n    65→    print(\"\\n--- Test: Get Quote ---\")\n    66→    try:\n    67→        r = requests.get(f\"{BASE_URL}/rest/quotes/s:0\", timeout=10)\n    68→        print(f\"  Status: {r.status_code}\")\n    69→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    70→        data = r.json()\n    71→        assert len(data) > 0, \"Expected at least one quote\"\n    72→        quote = data[0]\n    73→        print(f\"  Symbol: {quote.get('symbol', 'N/A')}\")\n    74→        print(f\"  Price: {quote.get('price', 'N/A')}\")\n    75→        assert quote.get('symbol') == 's:0', f\"Expected symbol s:0, got {quote.get('symbol')}\"\n    76→        print(f\"  PASS\")\n    77→        return True\n    78→    except Exception as e:\n    79→        print(f\"  FAIL: {e}\")\n    80→        return False\n    81→\n    82→\n    83→def test_get_multiple_quotes():\n    84→    \"\"\"Test GET /rest/quotes/s:0,s:1,s:2 - get multiple quotes.\"\"\"\n    85→    print(\"\\n--- Test: Get Multiple Quotes ---\")\n    86→    try:\n    87→        r = requests.get(f\"{BASE_URL}/rest/quotes/s:0,s:1,s:2\", timeout=10)\n    88→        print(f\"  Status: {r.status_code}\")\n    89→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n    90→        data = r.json()\n    91→        print(f\"  Quotes returned: {len(data)}\")\n    92→        assert len(data) == 3, f\"Expected 3 quotes, got {len(data)}\"\n    93→        print(f\"  PASS\")\n    94→        return True\n    95→    except Exception as e:\n    96→        print(f\"  FAIL: {e}\")\n    97→        return False\n    98→\n    99→\n   100→def test_login():\n   101→    \"\"\"Test POST /rest/trade/login - user login.\"\"\"\n   102→    print(\"\\n--- Test: Login ---\")\n   103→    try:\n   104→        r = requests.post(f\"{BASE_URL}/rest/trade/login\",\n   105→                         data={\"userID\": \"uid:0\", \"password\": \"xxx\"},\n   106→                         timeout=10)\n   107→        print(f\"  Status: {r.status_code}\")\n   108→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   109→        data = r.json()\n   110→        print(f\"  Account ID: {data.get('accountID', 'N/A')}\")\n   111→        print(f\"  PASS\")\n   112→        return True\n   113→    except Exception as e:\n   114→        print(f\"  FAIL: {e}\")\n   115→        return False\n   116→\n   117→\n   118→def test_get_account():\n   119→    \"\"\"Test GET /rest/trade/account/uid:0 - get account data.\"\"\"\n   120→    print(\"\\n--- Test: Get Account ---\")\n   121→    try:\n   122→        r = requests.get(f\"{BASE_URL}/rest/trade/account/uid:0\", timeout=10)\n   123→        print(f\"  Status: {r.status_code}\")\n   124→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   125→        data = r.json()\n   126→        print(f\"  Balance: {data.get('balance', 'N/A')}\")\n   127→        print(f\"  PASS\")\n   128→        return True\n   129→    except Exception as e:\n   130→        print(f\"  FAIL: {e}\")\n   131→        return False\n   132→\n   133→\n   134→def test_get_account_profile():\n   135→    \"\"\"Test GET /rest/trade/account/uid:0/profile - get profile data.\"\"\"\n   136→    print(\"\\n--- Test: Get Account Profile ---\")\n   137→    try:\n   138→        r = requests.get(f\"{BASE_URL}/rest/trade/account/uid:0/profile\", timeout=10)\n   139→        print(f\"  Status: {r.status_code}\")\n   140→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   141→        data = r.json()\n   142→        print(f\"  UserID: {data.get('userID', 'N/A')}\")\n   143→        assert data.get('userID') == 'uid:0', f\"Expected uid:0, got {data.get('userID')}\"\n   144→        print(f\"  PASS\")\n   145→        return True\n   146→    except Exception as e:\n   147→        print(f\"  FAIL: {e}\")\n   148→        return False\n   149→\n   150→\n   151→def test_get_holdings():\n   152→    \"\"\"Test GET /rest/trade/account/uid:0/holdings - get holdings.\"\"\"\n   153→    print(\"\\n--- Test: Get Holdings ---\")\n   154→    try:\n   155→        r = requests.get(f\"{BASE_URL}/rest/trade/account/uid:0/holdings\", timeout=10)\n   156→        print(f\"  Status: {r.status_code}\")\n   157→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   158→        data = r.json()\n   159→        print(f\"  Holdings count: {len(data)}\")\n   160→        print(f\"  PASS\")\n   161→        return True\n   162→    except Exception as e:\n   163→        print(f\"  FAIL: {e}\")\n   164→        return False\n   165→\n   166→\n   167→def test_buy_stock():\n   168→    \"\"\"Test POST /rest/trade/buy - buy stock.\"\"\"\n   169→    print(\"\\n--- Test: Buy Stock ---\")\n   170→    try:\n   171→        r = requests.post(f\"{BASE_URL}/rest/trade/buy\",\n   172→                         data={\"userID\": \"uid:0\", \"symbol\": \"s:1\", \"quantity\": \"10.0\"},\n   173→                         timeout=10)\n   174→        print(f\"  Status: {r.status_code}\")\n   175→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   176→        data = r.json()\n   177→        print(f\"  Order ID: {data.get('orderID', 'N/A')}\")\n   178→        print(f\"  Order Type: {data.get('orderType', 'N/A')}\")\n   179→        print(f\"  Order Status: {data.get('orderStatus', 'N/A')}\")\n   180→        print(f\"  PASS\")\n   181→        return True\n   182→    except Exception as e:\n   183→        print(f\"  FAIL: {e}\")\n   184→        return False\n   185→\n   186→\n   187→def test_get_orders():\n   188→    \"\"\"Test GET /rest/trade/account/uid:0/orders - get orders.\"\"\"\n   189→    print(\"\\n--- Test: Get Orders ---\")\n   190→    try:\n   191→        r = requests.get(f\"{BASE_URL}/rest/trade/account/uid:0/orders\", timeout=10)\n   192→        print(f\"  Status: {r.status_code}\")\n   193→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   194→        data = r.json()\n   195→        print(f\"  Orders count: {len(data)}\")\n   196→        assert len(data) > 0, \"Expected at least one order after buy\"\n   197→        print(f\"  PASS\")\n   198→        return True\n   199→    except Exception as e:\n   200→        print(f\"  FAIL: {e}\")\n   201→        return False\n   202→\n   203→\n   204→def test_register():\n   205→    \"\"\"Test POST /rest/trade/register - register new user.\"\"\"\n   206→    print(\"\\n--- Test: Register New User ---\")\n   207→    try:\n   208→        r = requests.post(f\"{BASE_URL}/rest/trade/register\",\n   209→                         data={\n   210→                             \"userID\": \"testuser1\",\n   211→                             \"password\": \"testpass\",\n   212→                             \"fullname\": \"Test User\",\n   213→                             \"address\": \"123 Test St\",\n   214→                             \"email\": \"test@test.com\",\n   215→                             \"creditcard\": \"1111-2222-3333-4444\",\n   216→                             \"openBalance\": \"50000.00\"\n   217→                         },\n   218→                         timeout=10)\n   219→        print(f\"  Status: {r.status_code}\")\n   220→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   221→        data = r.json()\n   222→        print(f\"  Account ID: {data.get('accountID', 'N/A')}\")\n   223→        print(f\"  PASS\")\n   224→        return True\n   225→    except Exception as e:\n   226→        print(f\"  FAIL: {e}\")\n   227→        return False\n   228→\n   229→\n   230→def test_logout():\n   231→    \"\"\"Test POST /rest/trade/logout/uid:0 - logout.\"\"\"\n   232→    print(\"\\n--- Test: Logout ---\")\n   233→    try:\n   234→        r = requests.post(f\"{BASE_URL}/rest/trade/logout/uid:0\", timeout=10)\n   235→        print(f\"  Status: {r.status_code}\")\n   236→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   237→        print(f\"  PASS\")\n   238→        return True\n   239→    except Exception as e:\n   240→        print(f\"  FAIL: {e}\")\n   241→        return False\n   242→\n   243→\n   244→def test_web_app():\n   245→    \"\"\"Test GET /rest/app - web UI endpoint.\"\"\"\n   246→    print(\"\\n--- Test: Web App ---\")\n   247→    try:\n   248→        r = requests.get(f\"{BASE_URL}/rest/app\", timeout=10)\n   249→        print(f\"  Status: {r.status_code}\")\n   250→        assert r.status_code == 200, f\"Expected 200, got {r.status_code}\"\n   251→        assert \"DayTrader\" in r.text, \"Expected 'DayTrader' in response\"\n   252→        print(f\"  PASS\")\n   253→        return True\n   254→    except Exception as e:\n   255→        print(f\"  FAIL: {e}\")\n   256→        return False\n   257→\n   258→\n   259→def main():\n   260→    get_base_url()\n   261→    print(f\"=== DayTrader Smoke Tests ===\")\n   262→    print(f\"Base URL: {BASE_URL}\")\n   263→\n   264→    if not wait_for_app():\n   265→        print(\"\\nFATAL: Application not available\")\n   266→        sys.exit(1)\n   267→\n   268→    tests = [\n   269→        test_market_summary,\n   270→        test_get_quote,\n   271→        test_get_multiple_quotes,\n   272→        test_login,\n   273→        test_get_account,\n   274→        test_get_account_profile,\n   275→        test_get_holdings,\n   276→        test_buy_stock,\n   277→        test_get_orders,\n   278→        test_register,\n   279→        test_logout,\n   280→        test_web_app,\n   281→    ]\n   282→\n   283→    passed = 0\n   284→    failed = 0\n   285→    for test in tests:\n   286→        try:\n   287→            if test():\n   288→                passed += 1\n   289→            else:\n   290→                failed += 1\n   291→        except Exception as e:\n   292→            print(f\"  UNEXPECTED ERROR: {e}\")\n   293→            failed += 1\n   294→\n   295→    print(f\"\\n=== Results ===\")\n   296→    print(f\"Passed: {passed}/{len(tests)}\")\n   297→    print(f\"Failed: {failed}/{len(tests)}\")\n   298→\n   299→    if failed > 0:\n   300→        sys.exit(1)\n   301→    else:\n   302→        print(\"All smoke tests passed!\")\n   303→        sys.exit(0)\n   304→\n   305→\n   306→if __name__ == \"__main__\":\n   307→    main()\n   308→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"5f5d25db-e6da-4791-948f-7a43a4b6df60"}
