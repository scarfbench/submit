{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01C7vSkgqMoGMucw8C7KBR81","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.BufferedReader;\n    19→import java.io.IOException;\n    20→import java.io.InputStream;\n    21→import java.io.InputStreamReader;\n    22→import java.math.BigDecimal;\n    23→import java.sql.Connection;\n    24→import java.sql.DatabaseMetaData;\n    25→import java.sql.PreparedStatement;\n    26→import java.sql.ResultSet;\n    27→import java.sql.SQLException;\n    28→import java.sql.Statement;\n    29→import java.util.ArrayList;\n    30→\n    31→import jakarta.enterprise.context.ApplicationScoped;\n    32→import jakarta.inject.Inject;\n    33→import javax.sql.DataSource;\n    34→\n    35→import io.agroal.api.AgroalDataSource;\n    36→\n    37→import com.ibm.websphere.samples.daytrader.beans.RunStatsDataBean;\n    38→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.TradeDB;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    41→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    42→import com.ibm.websphere.samples.daytrader.util.Log;\n    43→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    45→\n    46→/**\n    47→ * TradeBuildDB uses operations provided by the TradeApplication to (a) create the Database tables\n    48→ * (b)populate a DayTrader database without creating the tables. Specifically, a\n    49→ * new DayTrader User population is created using UserIDs of the form \"uid:xxx\"\n    50→ * where xxx is a sequential number (e.g. uid:0, uid:1, etc.). New stocks are also created of the\n    51→ * form \"s:xxx\", again where xxx represents sequential numbers (e.g. s:1, s:2, etc.)\n    52→ */\n    53→@ApplicationScoped\n    54→public class TradeDirectDBUtils implements TradeDB {\n    55→\n    56→  // MIGRATION: @Resource DataSource -> @Inject AgroalDataSource\n    57→  @Inject\n    58→  AgroalDataSource datasource;\n    59→\n    60→  @Inject \n    61→  @TradeJDBC\n    62→  TradeServices ts;\n    63→\n    64→  public String checkDBProductName() throws Exception {\n    65→    Connection conn = null;\n    66→    String dbProductName = null;\n    67→\n    68→    try {\n    69→\n    70→      conn = datasource.getConnection();\n    71→      DatabaseMetaData dbmd = conn.getMetaData();\n    72→      dbProductName = dbmd.getDatabaseProductName();\n    73→    } catch (SQLException e) {\n    74→      Log.error(e, \"TradeDirect:checkDBProductName() -- Error checking the Daytrader Database Product Name\");\n    75→    } finally {\n    76→      conn.close();\n    77→    }\n    78→    return dbProductName;\n    79→  }\n    80→\n    81→\n    82→  /**\n    83→   * Re-create the DayTrader db tables and populate them OR just populate a DayTrader DB, logging to the provided output stream\n    84→   */\n    85→  public void buildDB(java.io.PrintWriter out, InputStream ddlFile) throws Exception {\n    86→    String symbol, companyName;\n    87→    int errorCount = 0; // Give up gracefully after 10 errors\n    88→\n    89→    //  TradeStatistics.statisticsEnabled=false;  // disable statistics\n    90→    out.println(\"<HEAD><BR><EM> TradeBuildDB: Building DayTrader Database...</EM><BR> This operation will take several minutes. Please wait...</HEAD>\");\n    91→    out.println(\"<BODY>\");\n    92→\n    93→    if (ddlFile != null) {\n    94→      //out.println(\"<BR>TradeBuildDB: **** warPath= \"+warPath+\" ****</BR></BODY>\");\n    95→\n    96→      boolean success = false;\n    97→\n    98→      Object[] sqlBuffer = null;\n    99→\n   100→      //parse the DDL file and fill the SQL commands into a buffer\n   101→      try {\n   102→        sqlBuffer = parseDDLToBuffer(ddlFile);\n   103→      } catch (Exception e) {\n   104→        Log.error(e, \"TradeBuildDB: Unable to parse DDL file\");\n   105→        out.println(\"<BR>TradeBuildDB: **** Unable to parse DDL file for the specified database ****</BR></BODY>\");\n   106→        return;\n   107→      }\n   108→      if ((sqlBuffer == null) || (sqlBuffer.length == 0)) {\n   109→        out.println(\"<BR>TradeBuildDB: **** Parsing DDL file returned empty buffer, please check that a valid DB specific DDL file is available and retry ****</BR></BODY>\");\n   110→        return;\n   111→      }\n   112→\n   113→      // send the sql commands buffer to drop and recreate the Daytrader tables\n   114→      out.println(\"<BR>TradeBuildDB: **** Dropping and Recreating the DayTrader tables... ****</BR>\");\n   115→      try {\n   116→        success = recreateDBTables(sqlBuffer, out);\n   117→      } catch (Exception e) {\n   118→        Log.error(e, \"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   119→        out.println(\"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   120→        return;\n   121→      }\n   122→      if (!success) {\n   123→        out.println(\"<BR>TradeBuildDB: **** Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing ****</BR></BODY>\");\n   124→        return;\n   125→      }\n   126→      out.println(\"<BR>TradeBuildDB: **** DayTrader tables successfully created! ****</BR><BR><b> Please Stop and Re-start your Daytrader application (or your application server) and then use the \\\"Repopulate Daytrader Database\\\" link to populate your database.</b></BR><BR><BR></BODY>\");\n   127→      return;\n   128→    } // end of createDBTables\n   129→\n   130→    out.println(\"<BR>TradeBuildDB: **** Creating \" + TradeConfig.getMAX_QUOTES() + \" Quotes ****</BR>\");\n   131→    //Attempt to delete all of the Trade users and Trade Quotes first\n   132→    try {\n   133→      resetTrade(true);\n   134→    } catch (Exception e) {\n   135→      Log.error(e, \"TradeBuildDB: Unable to delete Trade users (uid:0, uid:1, ...) and Trade Quotes (s:0, s:1, ...)\");\n   136→    }\n   137→    for (int i = 0; i < TradeConfig.getMAX_QUOTES(); i++) {\n   138→      symbol = \"s:\" + i;\n   139→      companyName = \"S\" + i + \" Incorporated\";\n   140→      try {\n   141→        ts.createQuote(symbol, companyName, new java.math.BigDecimal(TradeConfig.rndPrice()));\n   142→        if (i % 10 == 0) {\n   143→          out.print(\".....\" + symbol);\n   144→          if (i % 100 == 0) {\n   145→            out.println(\" -<BR>\");\n   146→            out.flush();\n   147→          }\n   148→        }\n   149→      } catch (Exception e) {\n   150→        if (errorCount++ >= 10) {\n   151→          String error = \"Populate Trade DB aborting after 10 create quote errors. Check the EJB datasource configuration. Check the log for details <BR><BR> Exception is: <BR> \"\n   152→              + e.toString();\n   153→          Log.error(e, error);\n   154→          throw e;\n   155→        }\n   156→      }\n   157→    }\n   158→    out.println(\"<BR>\");\n   159→    out.println(\"<BR>**** Registering \" + TradeConfig.getMAX_USERS() + \" Users **** \");\n   160→    errorCount = 0; //reset for user registrations\n   161→\n   162→    // Registration is a formal operation in Trade 2.\n   163→    for (int i = 0; i < TradeConfig.getMAX_USERS(); i++) {\n   164→      String userID = \"uid:\" + i;\n   165→      String fullname = TradeConfig.rndFullName();\n   166→      String email = TradeConfig.rndEmail(userID);\n   167→      String address = TradeConfig.rndAddress();\n   168→      String creditcard = TradeConfig.rndCreditCard();\n   169→      double initialBalance = (double) (TradeConfig.rndInt(100000)) + 200000;\n   170→      if (i == 0) {\n   171→        initialBalance = 1000000; // uid:0 starts with a cool million.\n   172→      }\n   173→      try {\n   174→        AccountDataBean accountData = ts.register(userID, \"xxx\", fullname, address, email, creditcard, new BigDecimal(initialBalance));\n   175→\n   176→        if (accountData != null) {\n   177→          if (i % 50 == 0) {\n   178→            out.print(\"<BR>Account# \" + accountData.getAccountID() + \" userID=\" + userID);\n   179→          } // end-if\n   180→\n   181→          int holdings = TradeConfig.rndInt(TradeConfig.getMAX_HOLDINGS() + 1); // 0-MAX_HOLDING (inclusive), avg holdings per user = (MAX-0)/2\n   182→          double quantity = 0;\n   183→\n   184→          for (int j = 0; j < holdings; j++) {\n   185→            symbol = TradeConfig.rndSymbol();\n   186→            quantity = TradeConfig.rndQuantity();\n   187→            ts.buy(userID, symbol, quantity, TradeConfig.getOrderProcessingMode());\n   188→          } // end-for\n   189→          if (i % 50 == 0) {\n   190→            out.println(\" has \" + holdings + \" holdings.\");\n   191→            out.flush();\n   192→          } // end-if\n   193→        } else {\n   194→          out.println(\"<BR>UID \" + userID + \" already registered.</BR>\");\n   195→          out.flush();\n   196→        } // end-if\n   197→\n   198→      } catch (Exception e) {\n   199→        if (errorCount++ >= 10) {\n   200→          String error = \"Populate Trade DB aborting after 10 user registration errors. Check the log for details. <BR><BR> Exception is: <BR>\"\n   201→              + e.toString();\n   202→          Log.error(e, error);\n   203→          throw e;\n   204→        }\n   205→      }\n   206→    } // end-for\n   207→    out.println(\"</BODY>\");\n   208→  }\n   209→\n   210→  private boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n   211→    // Clear MDB Statistics\n   212→    MDBStats.getInstance().reset();\n   213→\n   214→    Connection conn = null;\n   215→    boolean success = false;\n   216→    try {\n   217→      conn = datasource.getConnection();\n   218→      Statement stmt = conn.createStatement();\n   219→      int bufferLength = sqlBuffer.length;\n   220→      for (int i = 0; i < bufferLength; i++) {\n   221→        try {\n   222→          stmt.executeUpdate((String) sqlBuffer[i]);\n   223→          // commit(conn);\n   224→        } catch (SQLException ex) {\n   225→          // Ignore DROP statements as tables won't always exist.\n   226→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n   227→            Log.error(\"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i], ex);\n   228→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i] + \"</I> . Check log for details.</BR>\");\n   229→          }\n   230→        }\n   231→      }\n   232→      stmt.close();\n   233→      conn.commit();\n   234→      success = true;\n   235→    } catch (Exception e) {\n   236→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n   237→    } finally {\n   238→      conn.close();\n   239→    }\n   240→    return success;\n   241→  }\n   242→\n   243→\n   244→  public RunStatsDataBean resetTrade(boolean deleteAll) throws Exception {\n   245→    // Clear MDB Statistics\n   246→    MDBStats.getInstance().reset();\n   247→    // Reset Trade\n   248→\n   249→    RunStatsDataBean runStatsData = new RunStatsDataBean();\n   250→    Connection conn = null;\n   251→    try {\n   252→\n   253→      conn = datasource.getConnection();\n   254→      conn.setAutoCommit(false);\n   255→      PreparedStatement stmt = null;\n   256→      ResultSet rs = null;\n   257→\n   258→      if (deleteAll) {\n   259→        try {\n   260→          stmt = getStatement(conn, \"delete from quoteejb\");\n   261→          stmt.executeUpdate();\n   262→          stmt.close();\n   263→          stmt = getStatement(conn, \"delete from accountejb\");\n   264→          stmt.executeUpdate();\n   265→          stmt.close();\n   266→          stmt = getStatement(conn, \"delete from accountprofileejb\");\n   267→          stmt.executeUpdate();\n   268→          stmt.close();\n   269→          stmt = getStatement(conn, \"delete from holdingejb\");\n   270→          stmt.executeUpdate();\n   271→          stmt.close();\n   272→          stmt = getStatement(conn, \"delete from orderejb\");\n   273→          stmt.executeUpdate();\n   274→          stmt.close();\n   275→          // FUTURE: - DuplicateKeyException - For now, don't start at\n   276→          // zero as KeySequenceDirect and KeySequenceBean will still\n   277→          // give out\n   278→          // the cached Block and then notice this change. Better\n   279→          // solution is\n   280→          // to signal both classes to drop their cached blocks\n   281→          // stmt = getStatement(conn, \"delete from keygenejb\");\n   282→          // stmt.executeUpdate();\n   283→          // stmt.close();\n   284→          conn.commit();\n   285→        } catch (Exception e) {\n   286→          Log.error(e, \"TradeDirect:resetTrade(deleteAll) -- Error deleting Trade users and stock from the Trade database\");\n   287→        }\n   288→        return runStatsData;\n   289→      }\n   290→\n   291→      stmt = getStatement(conn, \"delete from holdingejb where holdingejb.account_accountid is null\");\n   292→      stmt.executeUpdate();\n   293→      stmt.close();\n   294→\n   295→      // Count and Delete newly registered users (users w/ id that start\n   296→      // \"ru:%\":\n   297→      stmt = getStatement(conn, \"delete from accountprofileejb where userid like 'ru:%'\");\n   298→      stmt.executeUpdate();\n   299→      stmt.close();\n   300→\n   301→      stmt = getStatement(conn, \"delete from orderejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   302→      stmt.executeUpdate();\n   303→      stmt.close();\n   304→\n   305→      stmt = getStatement(conn,\n   306→          \"delete from holdingejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   307→      stmt.executeUpdate();\n   308→      stmt.close();\n   309→\n   310→      stmt = getStatement(conn, \"delete from accountejb where profile_userid like 'ru:%'\");\n   311→      int newUserCount = stmt.executeUpdate();\n   312→      runStatsData.setNewUserCount(newUserCount);\n   313→      stmt.close();\n   314→\n   315→      // Count of trade users\n   316→      stmt = getStatement(conn, \"select count(accountid) as \\\"tradeUserCount\\\" from accountejb a where a.profile_userid like 'uid:%'\");\n   317→      rs = stmt.executeQuery();\n   318→      rs.next();\n   319→      int tradeUserCount = rs.getInt(\"tradeUserCount\");\n   320→      runStatsData.setTradeUserCount(tradeUserCount);\n   321→      stmt.close();\n   322→\n   323→      rs.close();\n   324→      // Count of trade stocks\n   325→      stmt = getStatement(conn, \"select count(symbol) as \\\"tradeStockCount\\\" from quoteejb a where a.symbol like 's:%'\");\n   326→      rs = stmt.executeQuery();\n   327→      rs.next();\n   328→      int tradeStockCount = rs.getInt(\"tradeStockCount\");\n   329→      runStatsData.setTradeStockCount(tradeStockCount);\n   330→      stmt.close();\n   331→\n   332→      // Count of trade users login, logout\n   333→      stmt = getStatement(conn,\n   334→          \"select sum(loginCount) as \\\"sumLoginCount\\\", sum(logoutCount) as \\\"sumLogoutCount\\\" from accountejb a where  a.profile_userID like 'uid:%'\");\n   335→      rs = stmt.executeQuery();\n   336→      rs.next();\n   337→      int sumLoginCount = rs.getInt(\"sumLoginCount\");\n   338→      int sumLogoutCount = rs.getInt(\"sumLogoutCount\");\n   339→      runStatsData.setSumLoginCount(sumLoginCount);\n   340→      runStatsData.setSumLogoutCount(sumLogoutCount);\n   341→      stmt.close();\n   342→\n   343→      rs.close();\n   344→      // Update logoutcount and loginCount back to zero\n   345→\n   346→      stmt = getStatement(conn, \"update accountejb set logoutCount=0,loginCount=0 where profile_userID like 'uid:%'\");\n   347→      stmt.executeUpdate();\n   348→      stmt.close();\n   349→\n   350→      // count holdings for trade users\n   351→      stmt = getStatement(conn, \"select count(holdingid) as \\\"holdingCount\\\" from holdingejb h where h.account_accountid in \"\n   352→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   353→\n   354→      rs = stmt.executeQuery();\n   355→      rs.next();\n   356→      int holdingCount = rs.getInt(\"holdingCount\");\n   357→      runStatsData.setHoldingCount(holdingCount);\n   358→      stmt.close();\n   359→      rs.close();\n   360→\n   361→      // count orders for trade users\n   362→      stmt = getStatement(conn, \"select count(orderid) as \\\"orderCount\\\" from orderejb o where o.account_accountid in \"\n   363→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   364→\n   365→      rs = stmt.executeQuery();\n   366→      rs.next();\n   367→      int orderCount = rs.getInt(\"orderCount\");\n   368→      runStatsData.setOrderCount(orderCount);\n   369→      stmt.close();\n   370→      rs.close();\n   371→\n   372→      // count orders by type for trade users\n   373→      stmt = getStatement(conn, \"select count(orderid) \\\"buyOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   374→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='buy')\");\n   375→\n   376→      rs = stmt.executeQuery();\n   377→      rs.next();\n   378→      int buyOrderCount = rs.getInt(\"buyOrderCount\");\n   379→      runStatsData.setBuyOrderCount(buyOrderCount);\n   380→      stmt.close();\n   381→      rs.close();\n   382→\n   383→      // count orders by type for trade users\n   384→      stmt = getStatement(conn, \"select count(orderid) \\\"sellOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   385→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='sell')\");\n   386→\n   387→      rs = stmt.executeQuery();\n   388→      rs.next();\n   389→      int sellOrderCount = rs.getInt(\"sellOrderCount\");\n   390→      runStatsData.setSellOrderCount(sellOrderCount);\n   391→      stmt.close();\n   392→      rs.close();\n   393→\n   394→      // Delete cancelled orders\n   395→      stmt = getStatement(conn, \"delete from orderejb where orderStatus='cancelled'\");\n   396→      int cancelledOrderCount = stmt.executeUpdate();\n   397→      runStatsData.setCancelledOrderCount(cancelledOrderCount);\n   398→      stmt.close();\n   399→      rs.close();\n   400→\n   401→      // count open orders by type for trade users\n   402→      stmt = getStatement(conn, \"select count(orderid) \\\"openOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   403→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderStatus='open')\");\n   404→\n   405→      rs = stmt.executeQuery();\n   406→      rs.next();\n   407→      int openOrderCount = rs.getInt(\"openOrderCount\");\n   408→      runStatsData.setOpenOrderCount(openOrderCount);\n   409→\n   410→      stmt.close();\n   411→      rs.close();\n   412→      // Delete orders for holding which have been purchased and sold\n   413→      stmt = getStatement(conn, \"delete from orderejb where holding_holdingid is null\");\n   414→      int deletedOrderCount = stmt.executeUpdate();\n   415→      runStatsData.setDeletedOrderCount(deletedOrderCount);\n   416→      stmt.close();\n   417→      rs.close();\n   418→\n   419→      conn.commit();\n   420→\n   421→      System.out.println(\"TradeDirect:reset Run stats data\\n\\n\" + runStatsData);\n   422→    } catch (Exception e) {\n   423→      Log.error(e, \"Failed to reset Trade\");\n   424→      conn.rollback();\n   425→      throw e;\n   426→    } finally {\n   427→      conn.close();\n   428→    }\n   429→    return runStatsData;\n   430→\n   431→  }\n   432→\n   433→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n   434→    return conn.prepareStatement(sql);\n   435→  }\n   436→\n   437→  public Object[] parseDDLToBuffer(InputStream ddlFile) throws Exception {\n   438→    BufferedReader br = null;\n   439→    ArrayList<String> sqlBuffer = new ArrayList<String>(30); //initial capacity 30 assuming we have 30 ddl-sql statements to read\n   440→\n   441→    try {\n   442→      br = new BufferedReader(new InputStreamReader(ddlFile));\n   443→      String s;\n   444→      String sql = new String();\n   445→      while ((s = br.readLine()) != null) {\n   446→        s = s.trim();\n   447→        if ((s.length() != 0) && (s.charAt(0) != '#')) // Empty lines or lines starting with \"#\" are ignored\n   448→        {\n   449→          sql = sql + \" \" + s;\n   450→          if (s.endsWith(\";\")) { // reached end of sql statement\n   451→            sql = sql.replace(';', ' '); //remove the semicolon\n   452→            sqlBuffer.add(sql);\n   453→            sql = \"\";\n   454→          }\n   455→        }\n   456→      }\n   457→    } catch (IOException ex) {\n   458→      Log.error(\"TradeBuildDB:parseDDLToBuffer Exeception during open/read of File: \" + ddlFile, ex);\n   459→      throw ex;\n   460→    } finally {\n   461→      if (br != null) {\n   462→        try {\n   463→          br.close();\n   464→        } catch (IOException ex) {\n   465→          Log.error(\"TradeBuildDB:parseDDLToBuffer Failed to close BufferedReader\", ex);\n   466→        }\n   467→      }\n   468→    }\n   469→    return sqlBuffer.toArray();\n   470→  }\n   471→}\n   472→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"c046262c-d5dd-434d-8894-b8c4e13046b9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_013bG93XZRkdzK7NY6nHEuqM","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.interfaces;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.util.Collection;\n    20→import java.util.concurrent.Future;\n    21→\n    22→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    23→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    24→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    25→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    26→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    27→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    28→\n    29→/**\n    30→ * TradeServices interface specifies the business methods provided by the Trade\n    31→ * online broker application. These business methods represent the features and\n    32→ * operations that can be performed by customers of the brokerage such as login,\n    33→ * logout, get a stock quote, buy or sell a stock, etc. This interface is\n    34→ * implemented by {@link Trade} providing an EJB implementation of these\n    35→ * business methods and also by {@link TradeDirect} providing a JDBC\n    36→ * implementation.\n    37→ *\n    38→ * @see TradeDirect\n    39→ * @see TradeSLSB\n    40→ *\n    41→ */\n    42→\n    43→public interface TradeServices {\n    44→\n    45→    /**\n    46→     * Compute and return a snapshot of the current market conditions This\n    47→     * includes the TSIA - an index of the price of the top 100 Trade stock\n    48→     * quotes The openTSIA ( the index at the open) The volume of shares traded,\n    49→     * Top Stocks gain and loss\n    50→     *\n    51→     * @return A snapshot of the current market summary\n    52→     */\n    53→    MarketSummaryDataBean getMarketSummary() throws Exception;\n    54→\n    55→    /**\n    56→     * Create an order (buy or sell)\n    57→     *\n    58→     * @param accoount\n    59→     *            the accountdatabean\n    60→     * @param quote\n    61→     *            the quptedatabean\n    62→     * @param holding\n    63→     *            the holdingdatabean\n    64→     * @param orderType\n    65→     *            buy or sell\n    66→     * @param quantity\n    67→     *            quantity            \n    68→     * @return Collection OrderDataBeans providing detailed order information\n    69→     */\n    70→    OrderDataBean createOrder(AccountDataBean account, QuoteDataBean quote, HoldingDataBean holding, String orderType,\n    71→        double quantity) throws Exception;\n    72→    \n    73→    /**\n    74→     * Purchase a stock and create a new holding for the given user. Given a\n    75→     * stock symbol and quantity to purchase, retrieve the current quote price,\n    76→     * debit the user's account balance, and add holdings to user's portfolio.\n    77→     * buy/sell are asynchronous, using J2EE messaging, A new order is created\n    78→     * and submitted for processing to the TradeBroker\n    79→     *\n    80→     * @param userID\n    81→     *            the customer requesting the stock purchase\n    82→     * @param symbol\n    83→     *            the symbol of the stock being purchased\n    84→     * @param quantity\n    85→     *            the quantity of shares to purchase\n    86→     * @return OrderDataBean providing the status of the newly created buy order\n    87→     */\n    88→\n    89→    OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) throws Exception;\n    90→\n    91→    /**\n    92→     * Sell a stock holding and removed the holding for the given user. Given a\n    93→     * Holding, retrieve current quote, credit user's account, and reduce\n    94→     * holdings in user's portfolio.\n    95→     *\n    96→     * @param userID\n    97→     *            the customer requesting the sell\n    98→     * @param holdingID\n    99→     *            the users holding to be sold\n   100→     * @return OrderDataBean providing the status of the newly created sell\n   101→     *         order\n   102→     */\n   103→    OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception;\n   104→\n   105→    /**\n   106→     * Queue the Order identified by orderID to be processed\n   107→     *\n   108→     * Orders are submitted through JMS to a Trading Broker and completed\n   109→     * asynchronously. This method queues the order for processing\n   110→     *\n   111→     * The boolean twoPhase specifies to the server implementation whether or\n   112→     * not the method is to participate in a global transaction\n   113→     *\n   114→     * @param orderID\n   115→     *            the Order being queued for processing\n   116→     * @return OrderDataBean providing the status of the completed order\n   117→     */\n   118→    void queueOrder(Integer orderID, boolean twoPhase) throws Exception;\n   119→\n   120→    /**\n   121→     * Complete the Order identified by orderID. This method completes\n   122→     * the order For a buy, the stock is purchased creating a holding and the\n   123→     * users account is debited For a sell, the stock holding is removed and the\n   124→     * users account is credited with the proceeds\n   125→     *\n   126→     * The boolean twoPhase specifies to the server implementation whether or\n   127→     * not the method is to participate in a global transaction\n   128→     *\n   129→     * @param orderID\n   130→     *            the Order to complete\n   131→     * @return OrderDataBean providing the status of the completed order\n   132→     */\n   133→    OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception;\n   134→\n   135→    /**\n   136→     * Complete the Order identefied by orderID Orders are completed \n   137→     * asynchronously. This method completes\n   138→     * the order For a buy, the stock is purchased creating a holding and the\n   139→     * users account is debited For a sell, the stock holding is removed and the\n   140→     * users account is credited with the proceeds\n   141→     *\n   142→     * The boolean twoPhase specifies to the server implementation whether or\n   143→     * not the method is to participate in a global transaction\n   144→     *\n   145→     * @param orderID\n   146→     *            the Order to complete\n   147→     * @return OrderDataBean providing the status of the completed order\n   148→     */\n   149→    Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception;\n   150→    \n   151→    /**\n   152→     * Cancel the Order identefied by orderID\n   153→     *\n   154→     * The boolean twoPhase specifies to the server implementation whether or\n   155→     * not the method is to participate in a global transaction\n   156→     *\n   157→     * @param orderID\n   158→     *            the Order to complete\n   159→     * @return OrderDataBean providing the status of the completed order\n   160→     */\n   161→    void cancelOrder(Integer orderID, boolean twoPhase) throws Exception;\n   162→\n   163→    /**\n   164→     * Signify an order has been completed for the given userID\n   165→     *\n   166→     * @param userID\n   167→     *            the user for which an order has completed\n   168→     * @param orderID\n   169→     *            the order which has completed\n   170→     *\n   171→     */\n   172→    void orderCompleted(String userID, Integer orderID) throws Exception;\n   173→\n   174→    /**\n   175→     * Get the collection of all orders for a given account\n   176→     *\n   177→     * @param userID\n   178→     *            the customer account to retrieve orders for\n   179→     * @return Collection OrderDataBeans providing detailed order information\n   180→     */\n   181→    Collection<?> getOrders(String userID) throws Exception;\n   182→\n   183→    /**\n   184→     * Get the collection of completed orders for a given account that need to\n   185→     * be alerted to the user\n   186→     *\n   187→     * @param userID\n   188→     *            the customer account to retrieve orders for\n   189→     * @return Collection OrderDataBeans providing detailed order information\n   190→     */\n   191→    Collection<?> getClosedOrders(String userID) throws Exception;\n   192→\n   193→    /**\n   194→     * Given a market symbol, price, and details, create and return a new\n   195→     * {@link QuoteDataBean}\n   196→     *\n   197→     * @param symbol\n   198→     *            the symbol of the stock\n   199→     * @param price\n   200→     *            the current stock price\n   201→     * @param details\n   202→     *            a short description of the stock or company\n   203→     * @return a new QuoteDataBean or null if Quote could not be created\n   204→     */\n   205→    QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception;\n   206→\n   207→    /**\n   208→     * Return a {@link QuoteDataBean} describing a current quote for the given\n   209→     * stock symbol\n   210→     *\n   211→     * @param symbol\n   212→     *            the stock symbol to retrieve the current Quote\n   213→     * @return the QuoteDataBean\n   214→     */\n   215→    QuoteDataBean getQuote(String symbol) throws Exception;\n   216→\n   217→    /**\n   218→     * Return a {@link java.util.Collection} of {@link QuoteDataBean} describing\n   219→     * all current quotes\n   220→     *\n   221→     * @return A collection of QuoteDataBean\n   222→     */\n   223→    Collection<?> getAllQuotes() throws Exception;\n   224→\n   225→    /**\n   226→     * Update the stock quote price and volume for the specified stock symbol\n   227→     *\n   228→     * @param symbol\n   229→     *            for stock quote to update\n   230→     * @param price\n   231→     *            the updated quote price\n   232→     * @return the QuoteDataBean describing the stock\n   233→     */\n   234→    QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal newPrice, double sharesTraded) throws Exception;\n   235→\n   236→    /**\n   237→     * Return the portfolio of stock holdings for the specified customer as a\n   238→     * collection of HoldingDataBeans\n   239→     *\n   240→     * @param userID\n   241→     *            the customer requesting the portfolio\n   242→     * @return Collection of the users portfolio of stock holdings\n   243→     */\n   244→    Collection<HoldingDataBean> getHoldings(String userID) throws Exception;\n   245→\n   246→    /**\n   247→     * Return a specific user stock holding identifed by the holdingID\n   248→     *\n   249→     * @param holdingID\n   250→     *            the holdingID to return\n   251→     * @return a HoldingDataBean describing the holding\n   252→     */\n   253→    HoldingDataBean getHolding(Integer holdingID) throws Exception;\n   254→\n   255→    /**\n   256→     * Return an AccountDataBean object for userID describing the account\n   257→     *\n   258→     * @param userID\n   259→     *            the account userID to lookup\n   260→     * @return User account data in AccountDataBean\n   261→     */\n   262→    AccountDataBean getAccountData(String userID) throws Exception;\n   263→\n   264→    /**\n   265→     * Return an AccountProfileDataBean for userID providing the users profile\n   266→     *\n   267→     * @param userID\n   268→     *            the account userID to lookup\n   269→     * @param User\n   270→     *            account profile data in AccountProfileDataBean\n   271→     */\n   272→    AccountProfileDataBean getAccountProfileData(String userID) throws Exception;\n   273→\n   274→    /**\n   275→     * Update userID's account profile information using the provided\n   276→     * AccountProfileDataBean object\n   277→     *\n   278→     * @param userID\n   279→     *            the account userID to lookup\n   280→     * @param User\n   281→     *            account profile data in AccountProfileDataBean\n   282→     */\n   283→    AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception;\n   284→\n   285→    /**\n   286→     * Attempt to authenticate and login a user with the given password\n   287→     *\n   288→     * @param userID\n   289→     *            the customer to login\n   290→     * @param password\n   291→     *            the password entered by the customer for authentication\n   292→     * @return User account data in AccountDataBean\n   293→     */\n   294→    AccountDataBean login(String userID, String password) throws Exception;\n   295→\n   296→    /**\n   297→     * Logout the given user\n   298→     *\n   299→     * @param userID\n   300→     *            the customer to logout\n   301→     * @return the login status\n   302→     */\n   303→\n   304→    void logout(String userID) throws Exception;\n   305→\n   306→    /**\n   307→     * Register a new Trade customer. Create a new user profile, user registry\n   308→     * entry, account with initial balance, and empty portfolio.\n   309→     *\n   310→     * @param userID\n   311→     *            the new customer to register\n   312→     * @param password\n   313→     *            the customers password\n   314→     * @param fullname\n   315→     *            the customers fullname\n   316→     * @param address\n   317→     *            the customers street address\n   318→     * @param email\n   319→     *            the customers email address\n   320→     * @param creditcard\n   321→     *            the customers creditcard number\n   322→     * @param initialBalance\n   323→     *            the amount to charge to the customers credit to open the\n   324→     *            account and set the initial balance\n   325→     * @return the userID if successful, null otherwise\n   326→     */\n   327→    AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance)\n   328→            throws Exception;\n   329→\n   330→    \n   331→    int getImpl();\n   332→\n   333→    QuoteDataBean pingTwoPhase(String symbol) throws Exception;\n   334→\n   335→    double investmentReturn(double rnd1, double rnd2) throws Exception;\n   336→\n   337→    void setInSession(boolean inSession);\n   338→}\n   339→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"9c86fa45-6bef-4473-8de8-200ab6f30888"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01J5Co6rh9pEBR23Dd6Ssaok","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.interfaces;\n    17→\n    18→import java.lang.annotation.Retention;\n    19→import java.lang.annotation.Target;\n    20→\n    21→import jakarta.inject.Qualifier;\n    22→\n    23→import static java.lang.annotation.ElementType.FIELD;\n    24→import static java.lang.annotation.ElementType.METHOD;\n    25→import static java.lang.annotation.ElementType.PARAMETER;\n    26→import static java.lang.annotation.ElementType.TYPE;\n    27→import static java.lang.annotation.RetentionPolicy.RUNTIME;\n    28→\n    29→@Qualifier\n    30→@Retention(RUNTIME)\n    31→@Target({TYPE, METHOD, FIELD, PARAMETER})\n    32→public @interface TradeSession2Direct {}\n    33→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"7a9ecdf3-070f-45ef-b5ed-72772029e121"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012esBU9kpJfqZGkd9a5Xapq","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.sql.Timestamp;\n    20→import java.util.Collection;\n    21→import java.util.Comparator;\n    22→import java.util.Iterator;\n    23→import java.util.List;\n    24→import java.util.concurrent.Future;\n    25→\n    26→import jakarta.enterprise.context.ApplicationScoped;\n    27→import jakarta.inject.Inject;\n    28→import jakarta.persistence.EntityManager;\n    29→import jakarta.persistence.PersistenceContext;\n    30→import jakarta.persistence.TypedQuery;\n    31→import jakarta.persistence.criteria.CriteriaBuilder;\n    32→import jakarta.persistence.criteria.CriteriaQuery;\n    33→import jakarta.persistence.criteria.Root;\n    34→import jakarta.transaction.RollbackException;\n    35→import jakarta.transaction.Transactional;\n    36→import jakarta.validation.constraints.NotNull;\n    37→\n    38→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.TradeEJB;\n    41→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    42→import com.ibm.websphere.samples.daytrader.messaging.MessageProducerService;\n    43→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    44→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    45→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    46→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    47→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    48→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    49→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    50→import com.ibm.websphere.samples.daytrader.util.Log;\n    51→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    52→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    53→\n    54→import jakarta.enterprise.inject.Default;\n    55→\n    56→@ApplicationScoped\n    57→@Default\n    58→@TradeEJB\n    59→@RuntimeMode(\"Full EJB3\")\n    60→@Trace\n    61→@Transactional\n    62→public class TradeSLSBBean implements TradeServices {\n    63→\n    64→    @Inject\n    65→    MessageProducerService messageProducer;\n    66→\n    67→    @PersistenceContext(unitName = \"daytrader\")\n    68→    EntityManager entityManager;\n    69→\n    70→    @Inject\n    71→    MarketSummarySingleton marketSummarySingleton;\n    72→\n    73→    @Inject\n    74→    AsyncScheduledOrderSubmitter asyncEJBOrderSubmitter;\n    75→\n    76→    @Inject\n    77→    RecentQuotePriceChangeList recentQuotePriceChangeList;\n    78→\n    79→    @Override\n    80→    public MarketSummaryDataBean getMarketSummary() {\n    81→        return marketSummarySingleton.getMarketSummaryDataBean();\n    82→    }\n    83→\n    84→    @Override\n    85→    @NotNull\n    86→    public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) {\n    87→        OrderDataBean order = null;\n    88→        BigDecimal total;\n    89→        try {\n    90→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n    91→            AccountDataBean account = profile.getAccount();\n    92→            QuoteDataBean quote = entityManager.find(QuoteDataBean.class, symbol);\n    93→            HoldingDataBean holding = null;\n    94→\n    95→            order = createOrder(account, quote, holding, \"buy\", quantity);\n    96→\n    97→            BigDecimal price = quote.getPrice();\n    98→            BigDecimal orderFee = order.getOrderFee();\n    99→            BigDecimal balance = account.getBalance();\n   100→            total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   101→            account.setBalance(balance.subtract(total));\n   102→            final Integer orderID = order.getOrderID();\n   103→\n   104→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   105→                completeOrder(orderID, false);\n   106→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   107→                completeOrderAsync(orderID, false);\n   108→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   109→                queueOrder(orderID, true);\n   110→            }\n   111→        } catch (Exception e) {\n   112→            Log.error(\"TradeSLSBBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed\", e);\n   113→            throw new RuntimeException(e);\n   114→        }\n   115→        return order;\n   116→    }\n   117→\n   118→    @Override\n   119→    @NotNull\n   120→    public OrderDataBean sell(final String userID, final Integer holdingID, int orderProcessingMode) {\n   121→        OrderDataBean order = null;\n   122→        BigDecimal total;\n   123→        try {\n   124→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   125→            AccountDataBean account = profile.getAccount();\n   126→\n   127→            HoldingDataBean holding = entityManager.find(HoldingDataBean.class, holdingID);\n   128→\n   129→            if (holding == null) {\n   130→                Log.debug(\"TradeSLSBBean:sell User \" + userID + \" attempted to sell holding \" + holdingID + \" which has already been sold\");\n   131→                OrderDataBean orderData = new OrderDataBean();\n   132→                orderData.setOrderStatus(\"cancelled\");\n   133→                entityManager.persist(orderData);\n   134→                return orderData;\n   135→            }\n   136→\n   137→            QuoteDataBean quote = holding.getQuote();\n   138→            double quantity = holding.getQuantity();\n   139→\n   140→            order = createOrder(account, quote, holding, \"sell\", quantity);\n   141→\n   142→            holding.setPurchaseDate(new java.sql.Timestamp(0));\n   143→\n   144→            BigDecimal price = quote.getPrice();\n   145→            BigDecimal orderFee = order.getOrderFee();\n   146→            BigDecimal balance = account.getBalance();\n   147→            total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   148→            account.setBalance(balance.add(total));\n   149→            final Integer orderID = order.getOrderID();\n   150→\n   151→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   152→                completeOrder(orderID, false);\n   153→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   154→                completeOrderAsync(orderID, false);\n   155→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   156→                queueOrder(orderID, true);\n   157→            }\n   158→        } catch (Exception e) {\n   159→            Log.error(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \") --> failed\", e);\n   160→            throw new RuntimeException(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \")\", e);\n   161→        }\n   162→        return order;\n   163→    }\n   164→\n   165→    public void queueOrder(Integer orderID, boolean twoPhase) {\n   166→        messageProducer.queueOrderForProcessing(orderID, twoPhase);\n   167→    }\n   168→\n   169→    @Override\n   170→    public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   171→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   172→\n   173→        if (order == null) {\n   174→            throw new RuntimeException(\"Error: attempt to complete Order that is null\\n\" + order);\n   175→        }\n   176→\n   177→        order.getQuote();\n   178→\n   179→        if (order.isCompleted()) {\n   180→            throw new RuntimeException(\"Error: attempt to complete Order that is already completed\\n\" + order);\n   181→        }\n   182→\n   183→        AccountDataBean account = order.getAccount();\n   184→        QuoteDataBean quote = order.getQuote();\n   185→        HoldingDataBean holding = order.getHolding();\n   186→        BigDecimal price = order.getPrice();\n   187→        double quantity = order.getQuantity();\n   188→\n   189→        if (order.isBuy()) {\n   190→            HoldingDataBean newHolding = createHolding(account, quote, quantity, price);\n   191→            order.setHolding(newHolding);\n   192→            order.setOrderStatus(\"closed\");\n   193→            order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   194→            updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   195→        }\n   196→\n   197→        if (order.isSell()) {\n   198→            if (holding == null) {\n   199→                Log.debug(\"TradeSLSBBean:completeOrder -- Unable to sell order \" + order.getOrderID() + \" holding already sold\");\n   200→                order.cancel();\n   201→            } else {\n   202→                entityManager.remove(holding);\n   203→                order.setHolding(null);\n   204→                order.setOrderStatus(\"closed\");\n   205→                order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   206→                updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   207→            }\n   208→        }\n   209→\n   210→        Log.trace(\"TradeSLSBBean:completeOrder--> Completed Order \" + order.getOrderID() + \"\\n\\t Order info: \" + order + \"\\n\\t Account info: \" + account\n   211→            + \"\\n\\t Quote info: \" + quote + \"\\n\\t Holding info: \" + holding);\n   212→\n   213→        return order;\n   214→    }\n   215→\n   216→    @Override\n   217→    public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   218→        asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   219→        return null;\n   220→    }\n   221→\n   222→    @Override\n   223→    public void cancelOrder(Integer orderID, boolean twoPhase) {\n   224→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   225→        order.cancel();\n   226→    }\n   227→\n   228→    @Override\n   229→    public void orderCompleted(String userID, Integer orderID) {\n   230→        throw new UnsupportedOperationException(\"TradeSLSBBean:orderCompleted method not supported\");\n   231→    }\n   232→\n   233→    @Override\n   234→    public Collection<OrderDataBean> getOrders(String userID) {\n   235→        TypedQuery<OrderDataBean> query = entityManager.createQuery(\n   236→            \"SELECT o FROM orderejb o WHERE o.account.profile.userID = :userID ORDER BY o.openDate DESC\",\n   237→            OrderDataBean.class);\n   238→        query.setParameter(\"userID\", userID);\n   239→        return query.getResultList();\n   240→    }\n   241→\n   242→    @Override\n   243→    public Collection<OrderDataBean> getClosedOrders(String userID) {\n   244→        try {\n   245→            CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   246→            CriteriaQuery<OrderDataBean> criteriaQuery = criteriaBuilder.createQuery(OrderDataBean.class);\n   247→            Root<OrderDataBean> orders = criteriaQuery.from(OrderDataBean.class);\n   248→            criteriaQuery.select(orders);\n   249→            criteriaQuery.where(\n   250→                    criteriaBuilder.equal(orders.get(\"orderStatus\"),\n   251→                            criteriaBuilder.parameter(String.class, \"p_status\")),\n   252→                    criteriaBuilder.equal(orders.get(\"account\").get(\"profile\").get(\"userID\"),\n   253→                            criteriaBuilder.parameter(String.class, \"p_userid\")));\n   254→\n   255→            TypedQuery<OrderDataBean> q = entityManager.createQuery(criteriaQuery);\n   256→            q.setParameter(\"p_status\", \"closed\");\n   257→            q.setParameter(\"p_userid\", userID);\n   258→            List<OrderDataBean> results = q.getResultList();\n   259→\n   260→            Iterator<OrderDataBean> itr = results.iterator();\n   261→            while (itr.hasNext()) {\n   262→                OrderDataBean order = itr.next();\n   263→                if (TradeConfig.getLongRun()) {\n   264→                    entityManager.remove(order);\n   265→                } else {\n   266→                    order.setOrderStatus(\"completed\");\n   267→                }\n   268→            }\n   269→            return results;\n   270→        } catch (Exception e) {\n   271→            Log.error(\"TradeSLSBBean.getClosedOrders\", e);\n   272→            throw new RuntimeException(\"TradeSLSBBean.getClosedOrders - error\", e);\n   273→        }\n   274→    }\n   275→\n   276→    @Override\n   277→    public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) {\n   278→        try {\n   279→            QuoteDataBean quote = new QuoteDataBean(symbol, companyName, 0, price, price, price, price, 0);\n   280→            entityManager.persist(quote);\n   281→            Log.trace(\"TradeSLSBBean:createQuote-->\" + quote);\n   282→            return quote;\n   283→        } catch (Exception e) {\n   284→            Log.error(\"TradeSLSBBean:createQuote -- exception creating Quote\", e);\n   285→            throw new RuntimeException(e);\n   286→        }\n   287→    }\n   288→\n   289→    @Override\n   290→    public QuoteDataBean getQuote(String symbol) {\n   291→        return entityManager.find(QuoteDataBean.class, symbol);\n   292→    }\n   293→\n   294→    @Override\n   295→    public Collection<QuoteDataBean> getAllQuotes() {\n   296→        TypedQuery<QuoteDataBean> query = entityManager.createNamedQuery(\"quoteejb.allQuotes\", QuoteDataBean.class);\n   297→        return query.getResultList();\n   298→    }\n   299→\n   300→    @Override\n   301→    public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded) {\n   302→        if (!TradeConfig.getUpdateQuotePrices()) {\n   303→            return new QuoteDataBean();\n   304→        }\n   305→\n   306→        Log.trace(\"TradeSLSBBean:updateQuote\", symbol, changeFactor);\n   307→\n   308→        TypedQuery<QuoteDataBean> q = entityManager.createNamedQuery(\"quoteejb.quoteForUpdate\", QuoteDataBean.class);\n   309→        q.setParameter(1, symbol);\n   310→        QuoteDataBean quote = q.getSingleResult();\n   311→\n   312→        BigDecimal oldPrice = quote.getPrice();\n   313→        BigDecimal openPrice = quote.getOpen();\n   314→\n   315→        if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n   316→            changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   317→        } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n   318→            changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   319→        }\n   320→\n   321→        BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   322→\n   323→        quote.setPrice(newPrice);\n   324→        quote.setChange(newPrice.subtract(openPrice).doubleValue());\n   325→        quote.setVolume(quote.getVolume() + sharesTraded);\n   326→        entityManager.merge(quote);\n   327→\n   328→        if (TradeConfig.getPublishQuotePriceChange()) {\n   329→            publishQuotePriceChange(quote, oldPrice, changeFactor, sharesTraded);\n   330→        }\n   331→\n   332→        recentQuotePriceChangeList.add(quote);\n   333→\n   334→        return quote;\n   335→    }\n   336→\n   337→    @Override\n   338→    public Collection<@NotNull HoldingDataBean> getHoldings(String userID) {\n   339→        CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   340→        CriteriaQuery<HoldingDataBean> criteriaQuery = criteriaBuilder.createQuery(HoldingDataBean.class);\n   341→        Root<HoldingDataBean> holdings = criteriaQuery.from(HoldingDataBean.class);\n   342→        criteriaQuery.where(\n   343→                criteriaBuilder.equal(holdings.get(\"account\").get(\"profile\").get(\"userID\"),\n   344→                        criteriaBuilder.parameter(String.class, \"p_userid\")));\n   345→        criteriaQuery.select(holdings);\n   346→\n   347→        TypedQuery<HoldingDataBean> typedQuery = entityManager.createQuery(criteriaQuery);\n   348→        typedQuery.setParameter(\"p_userid\", userID);\n   349→        return typedQuery.getResultList();\n   350→    }\n   351→\n   352→    @Override\n   353→    public HoldingDataBean getHolding(Integer holdingID) {\n   354→        return entityManager.find(HoldingDataBean.class, holdingID);\n   355→    }\n   356→\n   357→    @Override\n   358→    public AccountDataBean getAccountData(String userID) {\n   359→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   360→        AccountDataBean account = profile.getAccount();\n   361→        account.setProfileID(profile.getUserID());\n   362→        return account;\n   363→    }\n   364→\n   365→    @Override\n   366→    public AccountProfileDataBean getAccountProfileData(String userID) {\n   367→        return entityManager.find(AccountProfileDataBean.class, userID);\n   368→    }\n   369→\n   370→    @Override\n   371→    public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) {\n   372→        AccountProfileDataBean temp = entityManager.find(AccountProfileDataBean.class, profileData.getUserID());\n   373→        temp.setAddress(profileData.getAddress());\n   374→        temp.setPassword(profileData.getPassword());\n   375→        temp.setFullName(profileData.getFullName());\n   376→        temp.setCreditCard(profileData.getCreditCard());\n   377→        temp.setEmail(profileData.getEmail());\n   378→        entityManager.merge(temp);\n   379→        return temp;\n   380→    }\n   381→\n   382→    @Override\n   383→    public AccountDataBean login(String userID, String password) throws RollbackException {\n   384→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   385→        if (profile == null) {\n   386→            throw new RuntimeException(\"No such user: \" + userID);\n   387→        }\n   388→        AccountDataBean account = profile.getAccount();\n   389→        account.login(password);\n   390→        Log.trace(\"TradeSLSBBean:login(\" + userID + \",\" + password + \") success\" + account);\n   391→        return account;\n   392→    }\n   393→\n   394→    @Override\n   395→    public void logout(String userID) {\n   396→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   397→        AccountDataBean account = profile.getAccount();\n   398→        account.logout();\n   399→        Log.trace(\"TradeSLSBBean:logout(\" + userID + \") success\");\n   400→    }\n   401→\n   402→    @Override\n   403→    public AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance) {\n   404→        AccountDataBean account = null;\n   405→        AccountProfileDataBean profile = null;\n   406→\n   407→        profile = entityManager.find(AccountProfileDataBean.class, userID);\n   408→\n   409→        if (profile != null) {\n   410→            Log.error(\"Failed to register new Account - AccountProfile with userID(\" + userID + \") already exists\");\n   411→            return null;\n   412→        } else {\n   413→            profile = new AccountProfileDataBean(userID, password, fullname, address, email, creditcard);\n   414→            account = new AccountDataBean(0, 0, null, new Timestamp(System.currentTimeMillis()), openBalance, openBalance, userID);\n   415→\n   416→            profile.setAccount(account);\n   417→            account.setProfile(profile);\n   418→\n   419→            entityManager.persist(profile);\n   420→            entityManager.persist(account);\n   421→        }\n   422→\n   423→        return account;\n   424→    }\n   425→\n   426→    @Transactional(Transactional.TxType.REQUIRES_NEW)\n   427→    public void publishQuotePriceChange(QuoteDataBean quote, BigDecimal oldPrice, BigDecimal changeFactor, double sharesTraded) {\n   428→        if (!TradeConfig.getPublishQuotePriceChange()) {\n   429→            return;\n   430→        }\n   431→        messageProducer.publishQuotePriceChange(\n   432→            quote.getSymbol(),\n   433→            quote.getCompanyName(),\n   434→            quote.getPrice(),\n   435→            oldPrice,\n   436→            quote.getOpen(),\n   437→            quote.getLow(),\n   438→            quote.getHigh(),\n   439→            quote.getVolume(),\n   440→            changeFactor,\n   441→            sharesTraded\n   442→        );\n   443→    }\n   444→\n   445→    public OrderDataBean createOrder(AccountDataBean account, QuoteDataBean quote, HoldingDataBean holding, String orderType, double quantity) {\n   446→        OrderDataBean order;\n   447→        try {\n   448→            order = new OrderDataBean(orderType, \"open\", new Timestamp(System.currentTimeMillis()), null, quantity, quote.getPrice().setScale(\n   449→                    FinancialUtils.SCALE, FinancialUtils.ROUND), TradeConfig.getOrderFee(orderType), account, quote, holding);\n   450→            entityManager.persist(order);\n   451→        } catch (Exception e) {\n   452→            Log.error(\"TradeSLSBBean:createOrder -- failed to create Order.\", e);\n   453→            throw new RuntimeException(\"TradeSLSBBean:createOrder -- failed to create Order.\", e);\n   454→        }\n   455→        return order;\n   456→    }\n   457→\n   458→    private HoldingDataBean createHolding(AccountDataBean account, QuoteDataBean quote, double quantity, BigDecimal purchasePrice) throws Exception {\n   459→        HoldingDataBean newHolding = new HoldingDataBean(quantity, purchasePrice, new Timestamp(System.currentTimeMillis()), account, quote);\n   460→        entityManager.persist(newHolding);\n   461→        return newHolding;\n   462→    }\n   463→\n   464→    @Override\n   465→    public double investmentReturn(double investment, double NetValue) throws Exception {\n   466→        double diff = NetValue - investment;\n   467→        double ir = diff / investment;\n   468→        return ir;\n   469→    }\n   470→\n   471→    @Override\n   472→    public QuoteDataBean pingTwoPhase(String symbol) throws Exception {\n   473→        QuoteDataBean quoteData = null;\n   474→        try {\n   475→            quoteData = entityManager.find(QuoteDataBean.class, symbol);\n   476→            double sharesTraded = (Math.random() * 100) + 1;\n   477→            BigDecimal oldPrice = quoteData.getPrice();\n   478→            BigDecimal openPrice = quoteData.getOpen();\n   479→            BigDecimal changeFactor = new BigDecimal(Math.random() * 100);\n   480→            BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   481→            quoteData.setPrice(newPrice);\n   482→            quoteData.setChange(newPrice.subtract(openPrice).doubleValue());\n   483→            quoteData.setVolume(quoteData.getVolume() + sharesTraded);\n   484→            entityManager.merge(quoteData);\n   485→            messageProducer.sendBrokerPing(\"Ping message sent from TradeSLSBBean:pingTwoPhase at \" + new java.util.Date());\n   486→        } catch (Exception e) {\n   487→            Log.error(\"TradeSLSBBean:pingTwoPhase -- exception caught\", e);\n   488→        }\n   489→        return quoteData;\n   490→    }\n   491→\n   492→    class quotePriceComparator implements Comparator<QuoteDataBean> {\n   493→        @Override\n   494→        public int compare(QuoteDataBean quote1, QuoteDataBean quote2) {\n   495→            double change1 = quote1.getChange();\n   496→            double change2 = quote2.getChange();\n   497→            return new Double(change2).compareTo(change1);\n   498→        }\n   499→    }\n   500→\n   501→    @Override\n   502→    public int getImpl() {\n   503→        return TradeConfig.EJB3;\n   504→    }\n   505→\n   506→    @Override\n   507→    public void setInSession(boolean inSession) {\n   508→        throw new UnsupportedOperationException(\"TradeSLSBBean::setInGlobalTxn not supported\");\n   509→    }\n   510→}\n   511→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"a20793d9-ae40-416b-bf97-ab458cf900b8"}
