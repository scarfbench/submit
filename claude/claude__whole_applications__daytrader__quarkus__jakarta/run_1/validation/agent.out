onfig;\n    42→\n    43→@Entity(name = \"holdingejb\")\n    44→@Table(name = \"holdingejb\")\n    45→public class HoldingDataBean implements Serializable {\n    46→\n    47→    private static final long serialVersionUID = -2338411656251935480L;\n    48→\n    49→    // MIGRATION: Simplified ID generation for Quarkus\n    50→    @Id\n    51→    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    52→    @Column(name = \"HOLDINGID\", nullable = false)\n    53→    private Integer holdingID;\n    54→\n    55→    @NotNull\n    56→    @Positive\n    57→    @Column(name = \"QUANTITY\", nullable = false)\n    58→    private double quantity;\n    59→\n    60→    @Column(name = \"PURCHASEPRICE\")\n    61→    @Positive\n    62→    private BigDecimal purchasePrice;\n    63→\n    64→    @Column(name = \"PURCHASEDATE\")\n    65→    @Temporal(TemporalType.TIMESTAMP)\n    66→    @PastOrPresent\n    67→    private Date purchaseDate;\n    68→\n    69→    @Transient\n    70→    private String quoteID;\n    71→\n    72→    @JsonIgnore\n    73→    @ManyToOne(fetch = FetchType.LAZY)\n    74→    @JoinColumn(name = \"ACCOUNT_ACCOUNTID\")\n    75→    private AccountDataBean account;\n    76→\n    77→    @ManyToOne(fetch = FetchType.EAGER)\n    78→    @JoinColumn(name = \"QUOTE_SYMBOL\")\n    79→    private QuoteDataBean quote;\n    80→\n    81→    public HoldingDataBean() {\n    82→    }\n    83→\n    84→    public HoldingDataBean(Integer holdingID, double quantity, BigDecimal purchasePrice, \n    85→            Date purchaseDate, String quoteID) {\n    86→        setHoldingID(holdingID);\n    87→        setQuantity(quantity);\n    88→        setPurchasePrice(purchasePrice);\n    89→        setPurchaseDate(purchaseDate);\n    90→        setQuoteID(quoteID);\n    91→    }\n    92→\n    93→    public HoldingDataBean(double quantity, BigDecimal purchasePrice, Date purchaseDate, \n    94→            AccountDataBean account, QuoteDataBean quote) {\n    95→        setQuantity(quantity);\n    96→        setPurchasePrice(purchasePrice);\n    97→        setPurchaseDate(purchaseDate);\n    98→        setAccount(account);\n    99→        setQuote(quote);\n   100→    }\n   101→\n   102→    public static HoldingDataBean getRandomInstance() {\n   103→        return new HoldingDataBean(\n   104→            Integer.valueOf(TradeConfig.rndInt(100000)),\n   105→            TradeConfig.rndQuantity(),\n   106→            TradeConfig.rndBigDecimal(1000.0f),\n   107→            new java.util.Date(TradeConfig.rndInt(Integer.MAX_VALUE)),\n   108→            TradeConfig.rndSymbol()\n   109→        );\n   110→    }\n   111→\n   112→    @Override\n   113→    public String toString() {\n   114→        return \"\\n\\tHolding Data for holding: \" + getHoldingID() \n   115→            + \"\\n\\t\\t      quantity:\" + getQuantity() \n   116→            + \"\\n\\t\\t purchasePrice:\" + getPurchasePrice()\n   117→            + \"\\n\\t\\t  purchaseDate:\" + getPurchaseDate() \n   118→            + \"\\n\\t\\t       quoteID:\" + getQuoteID();\n   119→    }\n   120→\n   121→    public String toHTML() {\n   122→        return \"<BR>Holding Data for holding: \" + getHoldingID() + \"</B>\" \n   123→            + \"<LI>      quantity:\" + getQuantity() + \"</LI>\" \n   124→            + \"<LI> purchasePrice:\" + getPurchasePrice() + \"</LI>\" \n   125→            + \"<LI>  purchaseDate:\" + getPurchaseDate() + \"</LI>\" \n   126→            + \"<LI>       quoteID:\" + getQuoteID() + \"</LI>\";\n   127→    }\n   128→\n   129→    public void print() {\n   130→        Log.log(this.toString());\n   131→    }\n   132→\n   133→    public Integer getHoldingID() {\n   134→        return holdingID;\n   135→    }\n   136→\n   137→    public void setHoldingID(Integer holdingID) {\n   138→        this.holdingID = holdingID;\n   139→    }\n   140→\n   141→    public double getQuantity() {\n   142→        return quantity;\n   143→    }\n   144→\n   145→    public void setQuantity(double quantity) {\n   146→        this.quantity = quantity;\n   147→    }\n   148→\n   149→    public BigDecimal getPurchasePrice() {\n   150→        return purchasePrice;\n   151→    }\n   152→\n   153→    public void setPurchasePrice(BigDecimal purchasePrice) {\n   154→        this.purchasePrice = purchasePrice;\n   155→    }\n   156→\n   157→    public Date getPurchaseDate() {\n   158→        return purchaseDate;\n   159→    }\n   160→\n   161→    public void setPurchaseDate(Date purchaseDate) {\n   162→        this.purchaseDate = purchaseDate;\n   163→    }\n   164→\n   165→    public String getQuoteID() {\n   166→        if (quote != null) {\n   167→            return quote.getSymbol();\n   168→        }\n   169→        return quoteID;\n   170→    }\n   171→\n   172→    public void setQuoteID(String quoteID) {\n   173→        this.quoteID = quoteID;\n   174→    }\n   175→\n   176→    public AccountDataBean getAccount() {\n   177→        return account;\n   178→    }\n   179→\n   180→    public void setAccount(AccountDataBean account) {\n   181→        this.account = account;\n   182→    }\n   183→\n   184→    public QuoteDataBean getQuote() {\n   185→        return quote;\n   186→    }\n   187→\n   188→    public void setQuote(QuoteDataBean quote) {\n   189→        this.quote = quote;\n   190→    }\n   191→\n   192→    @Override\n   193→    public int hashCode() {\n   194→        int hash = 0;\n   195→        hash += (this.holdingID != null ? this.holdingID.hashCode() : 0);\n   196→        return hash;\n   197→    }\n   198→\n   199→    @Override\n   200→    public boolean equals(Object object) {\n   201→        if (!(object instanceof HoldingDataBean)) {\n   202→            return false;\n   203→        }\n   204→        HoldingDataBean other = (HoldingDataBean) object;\n   205→        if (this.holdingID != other.holdingID && (this.holdingID == null || !this.holdingID.equals(other.holdingID))) {\n   206→            return false;\n   207→        }\n   208→        return true;\n   209→    }\n   210→}\n   211→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01GXMEe2L2LoFwh8taupKyQ7","session_id":"0505b85d-7bd5-4c52-85f6-40bd7ce1ee5d","uuid":"f0bf7215-1664-44e4-a400-c18f7eade88a"}
