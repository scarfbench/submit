sphere.samples.daytrader.util.Log;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    45→\n    46→@Entity(name = \"accountejb\")\n    47→@Table(name = \"accountejb\")\n    48→public class AccountDataBean implements Serializable {\n    49→\n    50→    private static final long serialVersionUID = 8437841265136840545L;\n    51→\n    52→    // MIGRATION: Simplified ID generation - Quarkus/Hibernate handles this better with IDENTITY\n    53→    @Id\n    54→    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    55→    @Column(name = \"ACCOUNTID\", nullable = false)\n    56→    private Integer accountID;\n    57→\n    58→    @NotNull\n    59→    @PositiveOrZero\n    60→    @Column(name = \"LOGINCOUNT\", nullable = false)\n    61→    private int loginCount;\n    62→\n    63→    @NotNull\n    64→    @PositiveOrZero\n    65→    @Column(name = \"LOGOUTCOUNT\", nullable = false)\n    66→    private int logoutCount;\n    67→\n    68→    @Column(name = \"LASTLOGIN\")\n    69→    @Temporal(TemporalType.TIMESTAMP)\n    70→    @PastOrPresent\n    71→    private Date lastLogin;\n    72→\n    73→    @Column(name = \"CREATIONDATE\")\n    74→    @Temporal(TemporalType.TIMESTAMP)\n    75→    @PastOrPresent\n    76→    private Date creationDate;\n    77→\n    78→    @Column(name = \"BALANCE\")\n    79→    private BigDecimal balance;\n    80→\n    81→    @Column(name = \"OPENBALANCE\")\n    82→    private BigDecimal openBalance;\n    83→\n    84→    @JsonIgnore\n    85→    @OneToMany(mappedBy = \"account\", fetch = FetchType.LAZY)\n    86→    private Collection<OrderDataBean> orders;\n    87→\n    88→    @JsonIgnore\n    89→    @OneToMany(mappedBy = \"account\", fetch = FetchType.LAZY)\n    90→    private Collection<HoldingDataBean> holdings;\n    91→\n    92→    @JsonIgnore\n    93→    @OneToOne(fetch = FetchType.LAZY)\n    94→    @JoinColumn(name = \"PROFILE_USERID\")\n    95→    private AccountProfileDataBean profile;\n    96→\n    97→    @Transient\n    98→    private String profileID;\n    99→\n   100→    public AccountDataBean() {\n   101→    }\n   102→\n   103→    public AccountDataBean(Integer accountID, int loginCount, int logoutCount, \n   104→            Date lastLogin, Date creationDate, BigDecimal balance, \n   105→            BigDecimal openBalance, String profileID) {\n   106→        setAccountID(accountID);\n   107→        setLoginCount(loginCount);\n   108→        setLogoutCount(logoutCount);\n   109→        setLastLogin(lastLogin);\n   110→        setCreationDate(creationDate);\n   111→        setBalance(balance);\n   112→        setOpenBalance(openBalance);\n   113→        setProfileID(profileID);\n   114→    }\n   115→\n   116→    public AccountDataBean(int loginCount, int logoutCount, Date lastLogin, \n   117→            Date creationDate, BigDecimal balance, BigDecimal openBalance, \n   118→            String profileID) {\n   119→        setLoginCount(loginCount);\n   120→        setLogoutCount(logoutCount);\n   121→        setLastLogin(lastLogin);\n   122→        setCreationDate(creationDate);\n   123→        setBalance(balance);\n   124→        setOpenBalance(openBalance);\n   125→        setProfileID(profileID);\n   126→    }\n   127→\n   128→    public void login(String password) {\n   129→        AccountProfileDataBean profile = getProfile();\n   130→        if (profile == null) {\n   131→            throw new RuntimeException(\"AccountDataBean:login -- Cannot find profile\");\n   132→        }\n   133→        if (!password.equals(profile.getPassword())) {\n   134→            throw new RuntimeException(\"AccountDataBean:login -- Password does not match\");\n   135→        }\n   136→        setLoginCount(getLoginCount() + 1);\n   137→        setLastLogin(new Date());\n   138→    }\n   139→\n   140→    public void logout() {\n   141→        setLogoutCount(getLogoutCount() + 1);\n   142→    }\n   143→\n   144→    @Override\n   145→    public String toString() {\n   146→        return \"AccountDataBean [accountID=\" + accountID + \", loginCount=\" + loginCount \n   147→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin \n   148→            + \", creationDate=\" + creationDate + \", balance=\" + balance \n   149→            + \", openBalance=\" + openBalance + \"]\";\n   150→    }\n   151→\n   152→    public String toHTML() {\n   153→        return \"<BR>AccountData [accountID=\" + accountID + \", loginCount=\" + loginCount\n   154→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin\n   155→            + \", creationDate=\" + creationDate + \", balance=\" + balance\n   156→            + \", openBalance=\" + openBalance + \"]\";\n   157→    }\n   158→\n   159→    // Getters and Setters\n   160→    public Integer getAccountID() {\n   161→        return accountID;\n   162→    }\n   163→\n   164→    public void setAccountID(Integer accountID) {\n   165→        this.accountID = accountID;\n   166→    }\n   167→\n   168→    public int getLoginCount() {\n   169→        return loginCount;\n   170→    }\n   171→\n   172→    public void setLoginCount(int loginCount) {\n   173→        this.loginCount = loginCount;\n   174→    }\n   175→\n   176→    public int getLogoutCount() {\n   177→        return logoutCount;\n   178→    }\n   179→\n   180→    public void setLogoutCount(int logoutCount) {\n   181→        this.logoutCount = logoutCount;\n   182→    }\n   183→\n   184→    public Date getLastLogin() {\n   185→        return lastLogin;\n   186→    }\n   187→\n   188→    public void setLastLogin(Date lastLogin) {\n   189→        this.lastLogin = lastLogin;\n   190→    }\n   191→\n   192→    public Date getCreationDate() {\n   193→        return creationDate;\n   194→    }\n   195→\n   196→    public void setCreationDate(Date creationDate) {\n   197→        this.creationDate = creationDate;\n   198→    }\n   199→\n   200→    public BigDecimal getBalance() {\n   201→        return balance;\n   202→    }\n   203→\n   204→    public void setBalance(BigDecimal balance) {\n   205→        this.balance = balance;\n   206→    }\n   207→\n   208→    public BigDecimal getOpenBalance() {\n   209→        return openBalance;\n   210→    }\n   211→\n   212→    public void setOpenBalance(BigDecimal openBalance) {\n   213→        this.openBalance = openBalance;\n   214→    }\n   215→\n   216→    public Collection<OrderDataBean> getOrders() {\n   217→        return orders;\n   218→    }\n   219→\n   220→    public void setOrders(Collection<OrderDataBean> orders) {\n   221→        this.orders = orders;\n   222→    }\n   223→\n   224→    public Collection<HoldingDataBean> getHoldings() {\n   225→        return holdings;\n   226→    }\n   227→\n   228→    public void setHoldings(Collection<HoldingDataBean> holdings) {\n   229→        this.holdings = holdings;\n   230→    }\n   231→\n   232→    public AccountProfileDataBean getProfile() {\n   233→        return profile;\n   234→    }\n   235→\n   236→    public void setProfile(AccountProfileDataBean profile) {\n   237→        this.profile = profile;\n   238→    }\n   239→\n   240→    public String getProfileID() {\n   241→        return profileID;\n   242→    }\n   243→\n   244→    public void setProfileID(String profileID) {\n   245→        this.profileID = profileID;\n   246→    }\n   247→\n   248→    @Override\n   249→    public int hashCode() {\n   250→        int hash = 0;\n   251→        hash += (this.accountID != null ? this.accountID.hashCode() : 0);\n   252→        return hash;\n   253→    }\n   254→\n   255→    @Override\n   256→    public boolean equals(Object object) {\n   257→        if (!(object instanceof AccountDataBean)) {\n   258→            return false;\n   259→        }\n   260→        AccountDataBean other = (AccountDataBean) object;\n   261→        if (this.accountID != null && !this.accountID.equals(other.accountID)) {\n   262→            return false;\n   263→        }\n   264→        return true;\n   265→    }\n   266→}\n   267