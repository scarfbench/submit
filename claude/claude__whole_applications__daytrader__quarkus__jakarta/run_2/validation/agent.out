{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01HaSs2AcmrMED21nsG3Q9aH","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Smoke tests for DayTrader Jakarta EE application.\n     4→Tests core REST API endpoints to verify the migrated application is functional.\n     5→\"\"\"\n     6→\n     7→import requests\n     8→import sys\n     9→import time\n    10→import json\n    11→\n    12→BASE_URL = sys.argv[1] if len(sys.argv) > 1 else \"http://localhost:8080\"\n    13→\n    14→def log(msg):\n    15→    print(f\"[SMOKE] {msg}\")\n    16→\n    17→def test_endpoint(name, method, url, expected_status=200, data=None, headers=None, allow_statuses=None):\n    18→    \"\"\"Test a single endpoint and return True if it passes.\"\"\"\n    19→    try:\n    20→        if method == \"GET\":\n    21→            resp = requests.get(url, headers=headers, timeout=15)\n    22→        elif method == \"POST\":\n    23→            resp = requests.post(url, data=data, headers=headers, timeout=15)\n    24→        else:\n    25→            log(f\"  FAIL [{name}]: Unknown method {method}\")\n    26→            return False\n    27→\n    28→        if allow_statuses:\n    29→            if resp.status_code in allow_statuses:\n    30→                log(f\"  PASS [{name}]: status={resp.status_code}\")\n    31→                return True\n    32→            else:\n    33→                log(f\"  FAIL [{name}]: status={resp.status_code}, expected one of {allow_statuses}\")\n    34→                log(f\"        Response: {resp.text[:500]}\")\n    35→                return False\n    36→\n    37→        if resp.status_code == expected_status:\n    38→            log(f\"  PASS [{name}]: status={resp.status_code}\")\n    39→            return True\n    40→        else:\n    41→            log(f\"  FAIL [{name}]: status={resp.status_code}, expected {expected_status}\")\n    42→            log(f\"        Response: {resp.text[:500]}\")\n    43→            return False\n    44→    except Exception as e:\n    45→        log(f\"  FAIL [{name}]: {e}\")\n    46→        return False\n    47→\n    48→def wait_for_app(url, max_wait=120):\n    49→    \"\"\"Wait for the application to be ready.\"\"\"\n    50→    log(f\"Waiting for app at {url} (max {max_wait}s)...\")\n    51→    start = time.time()\n    52→    while time.time() - start < max_wait:\n    53→        try:\n    54→            resp = requests.get(url, timeout=5)\n    55→            if resp.status_code < 500:\n    56→                log(f\"App is ready (status={resp.status_code}, took {int(time.time()-start)}s)\")\n    57→                return True\n    58→        except:\n    59→            pass\n    60→        time.sleep(3)\n    61→    log(f\"App did not become ready within {max_wait}s\")\n    62→    return False\n    63→\n    64→def main():\n    65→    log(f\"Starting smoke tests against {BASE_URL}\")\n    66→\n    67→    # Wait for app to be ready - try multiple endpoints\n    68→    ready = False\n    69→    for path in [\"/rest/trade/market\", \"/rest/app\", \"/health\", \"/\"]:\n    70→        try:\n    71→            resp = requests.get(f\"{BASE_URL}{path}\", timeout=5)\n    72→            if resp.status_code < 500:\n    73→                ready = True\n    74→                break\n    75→        except:\n    76→            pass\n    77→\n    78→    if not ready:\n    79→        if not wait_for_app(f\"{BASE_URL}/rest/trade/market\"):\n    80→            # Try alternate health paths\n    81→            if not wait_for_app(f\"{BASE_URL}/rest/app\"):\n    82→                log(\"FATAL: Application not reachable\")\n    83→                sys.exit(1)\n    84→\n    85→    passed = 0\n    86→    failed = 0\n    87→    total = 0\n    88→\n    89→    # Test 1: Market Summary\n    90→    log(\"\\n--- Test: Market Summary ---\")\n    91→    total += 1\n    92→    if test_endpoint(\"GET /rest/trade/market\", \"GET\", f\"{BASE_URL}/rest/trade/market\",\n    93→                     allow_statuses=[200]):\n    94→        passed += 1\n    95→    else:\n    96→        failed += 1\n    97→\n    98→    # Test 2: Get quotes\n    99→    log(\"\\n--- Test: Get Quotes ---\")\n   100→    total += 1\n   101→    if test_endpoint(\"GET /rest/quotes/s:0\", \"GET\", f\"{BASE_URL}/rest/quotes/s:0\",\n   102→                     allow_statuses=[200]):\n   103→        passed += 1\n   104→    else:\n   105→        failed += 1\n   106→\n   107→    # Test 3: Get multiple quotes\n   108→    log(\"\\n--- Test: Get Multiple Quotes ---\")\n   109→    total += 1\n   110→    if test_endpoint(\"GET /rest/quotes/s:0,s:1,s:2\", \"GET\", f\"{BASE_URL}/rest/quotes/s:0,s:1,s:2\",\n   111→                     allow_statuses=[200]):\n   112→        passed += 1\n   113→    else:\n   114→        failed += 1\n   115→\n   116→    # Test 4: Login\n   117→    log(\"\\n--- Test: Login ---\")\n   118→    total += 1\n   119→    if test_endpoint(\"POST /rest/trade/login\", \"POST\", f\"{BASE_URL}/rest/trade/login\",\n   120→                     data={\"userID\": \"uid:0\", \"password\": \"xxx\"},\n   121→                     headers={\"Content-Type\": \"application/x-www-form-urlencoded\"},\n   122→                     allow_statuses=[200]):\n   123→        passed += 1\n   124→    else:\n   125→        failed += 1\n   126→\n   127→    # Test 5: Get Account\n   128→    log(\"\\n--- Test: Get Account ---\")\n   129→    total += 1\n   130→    if test_endpoint(\"GET /rest/trade/account/uid:0\", \"GET\", f\"{BASE_URL}/rest/trade/account/uid:0\",\n   131→                     allow_statuses=[200]):\n   132→        passed += 1\n   133→    else:\n   134→        failed += 1\n   135→\n   136→    # Test 6: Get Account Profile\n   137→    log(\"\\n--- Test: Get Account Profile ---\")\n   138→    total += 1\n   139→    if test_endpoint(\"GET /rest/trade/account/uid:0/profile\", \"GET\",\n   140→                     f\"{BASE_URL}/rest/trade/account/uid:0/profile\",\n   141→                     allow_statuses=[200]):\n   142→        passed += 1\n   143→    else:\n   144→        failed += 1\n   145→\n   146→    # Test 7: Get Holdings\n   147→    log(\"\\n--- Test: Get Holdings ---\")\n   148→    total += 1\n   149→    if test_endpoint(\"GET /rest/trade/account/uid:0/holdings\", \"GET\",\n   150→                     f\"{BASE_URL}/rest/trade/account/uid:0/holdings\",\n   151→                     allow_statuses=[200]):\n   152→        passed += 1\n   153→    else:\n   154→        failed += 1\n   155→\n   156→    # Test 8: Get Orders\n   157→    log(\"\\n--- Test: Get Orders ---\")\n   158→    total += 1\n   159→    if test_endpoint(\"GET /rest/trade/account/uid:0/orders\", \"GET\",\n   160→                     f\"{BASE_URL}/rest/trade/account/uid:0/orders\",\n   161→                     allow_statuses=[200]):\n   162→        passed += 1\n   163→    else:\n   164→        failed += 1\n   165→\n   166→    # Test 9: Buy stock\n   167→    log(\"\\n--- Test: Buy Stock ---\")\n   168→    total += 1\n   169→    if test_endpoint(\"POST /rest/trade/buy\", \"POST\", f\"{BASE_URL}/rest/trade/buy\",\n   170→                     data={\"userID\": \"uid:0\", \"symbol\": \"s:0\", \"quantity\": \"10.0\"},\n   171→                     headers={\"Content-Type\": \"application/x-www-form-urlencoded\"},\n   172→                     allow_statuses=[200]):\n   173→        passed += 1\n   174→    else:\n   175→        failed += 1\n   176→\n   177→    # Test 10: Register new user\n   178→    log(\"\\n--- Test: Register ---\")\n   179→    total += 1\n   180→    if test_endpoint(\"POST /rest/trade/register\", \"POST\", f\"{BASE_URL}/rest/trade/register\",\n   181→                     data={\"userID\": \"testuser1\", \"password\": \"testpass\", \"fullname\": \"Test User\",\n   182→                           \"address\": \"123 Test St\", \"email\": \"test@test.com\",\n   183→                           \"creditcard\": \"1234-5678-9012-3456\", \"openBalance\": \"100000.00\"},\n   184→                     headers={\"Content-Type\": \"application/x-www-form-urlencoded\"},\n   185→                     allow_statuses=[200]):\n   186→        passed += 1\n   187→    else:\n   188→        failed += 1\n   189→\n   190→    # Test 11: Logout\n   191→    log(\"\\n--- Test: Logout ---\")\n   192→    total += 1\n   193→    if test_endpoint(\"POST /rest/trade/logout/uid:0\", \"POST\", f\"{BASE_URL}/rest/trade/logout/uid:0\",\n   194→                     allow_statuses=[200, 204]):\n   195→        passed += 1\n   196→    else:\n   197→        failed += 1\n   198→\n   199→    # Test 12: Web App page\n   200→    log(\"\\n--- Test: Web App Welcome ---\")\n   201→    total += 1\n   202→    if test_endpoint(\"GET /rest/app\", \"GET\", f\"{BASE_URL}/rest/app\",\n   203→                     allow_statuses=[200]):\n   204→        passed += 1\n   205→    else:\n   206→        failed += 1\n   207→\n   208→    # Summary\n   209→    log(f\"\\n{'='*50}\")\n   210→    log(f\"RESULTS: {passed}/{total} passed, {failed}/{total} failed\")\n   211→    log(f\"{'='*50}\")\n   212→\n   213→    if failed > 0:\n   214→        log(\"SMOKE TESTS FAILED\")\n   215→        sys.exit(1)\n   216→    else:\n   217→        log(\"ALL SMOKE TESTS PASSED\")\n   218→        sys.exit(0)\n   219→\n   220→if __name__ == \"__main__\":\n   221→    main()\n   222→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"90a9af65-6da1-4e2c-a260-395a08c2b37f"}
