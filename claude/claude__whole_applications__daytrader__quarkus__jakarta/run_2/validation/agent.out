der.entities.AccountDataBean;\n    37→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    38→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    39→import com.ibm.websphere.samples.daytrader.util.Log;\n    40→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    41→\n    42→/**\n    43→ * Populates the database with initial data on application startup.\n    44→ * Uses Bean-Managed Transactions for reliability on Open Liberty.\n    45→ * Tables are created by EclipseLink DDL generation (create-tables).\n    46→ */\n    47→@Singleton\n    48→@Startup\n    49→@TransactionManagement(TransactionManagementType.BEAN)\n    50→public class DatabasePopulator {\n    51→\n    52→    @PersistenceContext(unitName = \"daytrader\")\n    53→    EntityManager em;\n    54→\n    55→    @Resource\n    56→    UserTransaction utx;\n    57→\n    58→    @Resource(lookup = \"jdbc/TradeDataSource\")\n    59→    DataSource dataSource;\n    60→\n    61→    @Inject\n    62→    @ConfigProperty(name = \"trade.db.populate.on.startup\", defaultValue = \"true\")\n    63→    boolean populateOnStartup;\n    64→\n    65→    @Inject\n    66→    @ConfigProperty(name = \"trade.max.users\", defaultValue = \"50\")\n    67→    int maxUsers;\n    68→\n    69→    @Inject\n    70→    @ConfigProperty(name = \"trade.max.quotes\", defaultValue = \"100\")\n    71→    int maxQuotes;\n    72→\n    73→    @PostConstruct\n    74→    void onStart() {\n    75→        if (!populateOnStartup) {\n    76→            Log.log(\"Database population disabled via configuration\");\n    77→            return;\n    78→        }\n    79→\n    80→        // Create the keygenejb table (not managed by JPA)\n    81→        createKeygenTable();\n    82→\n    83→        // Check if database already has data\n    84→        try {\n    85→            utx.begin();\n    86→            Number quoteCount = (Number) em.createNativeQuery(\"SELECT COUNT(*) FROM quoteejb\").getSingleResult();\n    87→            utx.commit();\n    88→            if (quoteCount.longValue() > 0) {\n    89→                Log.log(\"Database already populated with \" + quoteCount + \" quotes. Skipping population.\");\n    90→                return;\n    91→            }\n    92→        } catch (Exception e) {\n    93→            try { utx.rollback(); } catch (Exception re) { /* ignore */ }\n    94→            Log.log(\"Proceeding with database population...\");\n    95→        }\n    96→\n    97→        Log.log(\"TradeBuildDB: Populating DayTrader Database on startup...\");\n    98→\n    99→        try {\n   100→            utx.begin();\n   101→            populateQuotes();\n   102→            utx.commit();\n   103→            Log.log(\"TradeBuildDB: Quotes populated successfully\");\n   104→        } catch (Exception e) {\n   105→            try { utx.rollback(); } catch (Exception re) { /* ignore */ }\n   106→            Log.error(e, \"TradeBuildDB: Error populating quotes\");\n   107→            return;\n   108→        }\n   109→\n   110→        try {\n   111→            utx.begin();\n   112→            populateUsers();\n   113→            utx.commit();\n   114→            Log.log(\"TradeBuildDB: Users populated successfully\");\n   115→        } catch (Exception e) {\n   116→            try { utx.rollback(); } catch (Exception re) { /* ignore */ }\n   117→            Log.error(e, \"TradeBuildDB: Error populating users\");\n   118→            return;\n   119→        }\n   120→\n   121→        Log.log(\"TradeBuildDB: Database population complete!\");\n   122→    }\n   123→\n   124→    private void createKeygenTable() {\n   125→        try (Connection conn = dataSource.getConnection()) {\n   126→            conn.setAutoCommit(true);\n   127→            Statement stmt = conn.createStatement();\n   128→            stmt.executeUpdate(\"CREATE TABLE IF NOT EXISTS keygenejb (\"\n   129→                + \"KEYNAME VARCHAR(255) NOT NULL PRIMARY KEY, \"\n   130→                + \"KEYVAL INTEGER NOT NULL)\");\n   131→            stmt.close();\n   132→            Log.log(\"TradeBuildDB: keygenejb table ready\");\n   133→        } catch (Exception e) {\n   134→            Log.error(e, \"TradeBuildDB: Error creating keygenejb table\");\n   135→        }\n   136→    }\n   137→\n   138→    private void populateQuotes() {\n   139→        Log.log(\"TradeBuildDB: Creating \" + maxQuotes + \" Quotes...\");\n   140→\n   141→        for (int i = 0; i < maxQuotes; i++) {\n   142→            String symbol = \"s:\" + i;\n   143→            String companyName = \"S\" + i + \" Incorporated\";\n   144→            BigDecimal price = new BigDecimal(TradeConfig.rndPrice());\n   145→\n   146→            QuoteDataBean quote = new QuoteDataBean();\n   147→            quote.setSymbol(symbol);\n   148→            quote.setCompanyName(companyName);\n   149→            quote.setPrice(price);\n   150→            quote.setOpen(price);\n   151→            quote.setLow(price);\n   152→            quote.setHigh(price);\n   153→            quote.setChange(0.0);\n   154→            quote.setVolume(0.0);\n   155→\n   156→            em.persist(quote);\n   157→\n   158→            if (i % 10 == 0) {\n   159→                Log.log(\"Created quote: \" + symbol);\n   160→            }\n   161→        }\n   162→        em.flush();\n   163→    }\n   164→\n   165→    private void populateUsers() {\n   166→        Log.log(\"TradeBuildDB: Registering \" + maxUsers + \" Users...\");\n   167→\n   168→        for (int i = 0; i < maxUsers; i++) {\n   169→            String userID = \"uid:\" + i;\n   170→            String fullname = TradeConfig.rndFullName();\n   171→            String email = TradeConfig.rndEmail(userID);\n   172→            String address = TradeConfig.rndAddress();\n   173→            String creditcard = TradeConfig.rndCreditCard();\n   174→            BigDecimal initialBalance = new BigDecimal((double) (TradeConfig.rndInt(100000)) + 200000);\n   175→\n   176→            if (i == 0) {\n   177→                initialBalance = new BigDecimal(1000000);\n   178→            }\n   179→\n   180→            AccountProfileDataBean profile = new AccountProfileDataBean();\n   181→            profile.setUserID(userID);\n   182→            profile.setPassword(\"xxx\");\n   183→            profile.setFullName(fullname);\n   184→            profile.setAddress(address);\n   185→            profile.setEmail(email);\n   186→            profile.setCreditCard(creditcard);\n   187→            em.persist(profile);\n   188→\n   189→            AccountDataBean account = new AccountDataBean();\n   190→            account.setProfile(profile);\n   191→            account.setCreationDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   192→            account.setLastLogin(new java.sql.Timestamp(System.currentTimeMillis()));\n   193→            account.setBalance(initialBalance);\n   194→            account.setOpenBalance(initialBalance);\n   195→            account.setLoginCount(0);\n   196→            account.setLogoutCount(0);\n   197→            em.persist(account);\n   198→\n   199→            if (i % 10 == 0) {\n   200→                Log.log(\"Registered user: \" + userID + \" with balance: \" + initialBalance);\n   201→            }\n   202→        }\n   203→        em.flush();\n   204→    }\n   205→}\n   206→"}]},"parent_tool_use_id":null,"session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"dc84daf6-826e-41b2-b35d-3336f25a3d87"}
