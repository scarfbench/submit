ean [accountID=\" + accountID + \", loginCount=\" + loginCount \n   147→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin \n   148→            + \", creationDate=\" + creationDate + \", balance=\" + balance \n   149→            + \", openBalance=\" + openBalance + \"]\";\n   150→    }\n   151→\n   152→    public String toHTML() {\n   153→        return \"<BR>AccountData [accountID=\" + accountID + \", loginCount=\" + loginCount\n   154→            + \", logoutCount=\" + logoutCount + \", lastLogin=\" + lastLogin\n   155→            + \", creationDate=\" + creationDate + \", balance=\" + balance\n   156→            + \", openBalance=\" + openBalance + \"]\";\n   157→    }\n   158→\n   159→    // Getters and Setters\n   160→    public Integer getAccountID() {\n   161→        return accountID;\n   162→    }\n   163→\n   164→    public void setAccountID(Integer accountID) {\n   165→        this.accountID = accountID;\n   166→    }\n   167→\n   168→    public int getLoginCount() {\n   169→        return loginCount;\n   170→    }\n   171→\n   172→    public void setLoginCount(int loginCount) {\n   173→        this.loginCount = loginCount;\n   174→    }\n   175→\n   176→    public int getLogoutCount() {\n   177→        return logoutCount;\n   178→    }\n   179→\n   180→    public void setLogoutCount(int logoutCount) {\n   181→        this.logoutCount = logoutCount;\n   182→    }\n   183→\n   184→    public Date getLastLogin() {\n   185→        return lastLogin;\n   186→    }\n   187→\n   188→    public void setLastLogin(Date lastLogin) {\n   189→        this.lastLogin = lastLogin;\n   190→    }\n   191→\n   192→    public Date getCreationDate() {\n   193→        return creationDate;\n   194→    }\n   195→\n   196→    public void setCreationDate(Date creationDate) {\n   197→        this.creationDate = creationDate;\n   198→    }\n   199→\n   200→    public BigDecimal getBalance() {\n   201→        return balance;\n   202→    }\n   203→\n   204→  