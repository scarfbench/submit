{"type":"assistant","message":{"model":"claude-sonnet-4-5-20250929","id":"msg_bdrk_01HiPszLH2TJryHvLiU8WFth","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_bdrk_01811XtGwGcAqzp8aLbK7oa4","name":"Read","input":{"file_path":"/home/bmcginn/git/scarf-latest/scarbench-evals/final/prompt_claude__whole_applications__daytrader__quarkus__jakarta/run_2/output/src/main/java/com/ibm/websphere/samples/daytrader/impl/direct/TradeDirectDBUtils.java"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1532,"cache_read_input_tokens":11009,"cache_creation":{"ephemeral_5m_input_tokens":1532,"ephemeral_1h_input_tokens":0},"output_tokens":280},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01JoEemWzH4ddq46J3MvUgrU","session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"361ad63d-7747-44a8-a2e2-4294bf7cd9ab"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01811XtGwGcAqzp8aLbK7oa4","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2019.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.BufferedReader;\n    19→import java.io.IOException;\n    20→import java.io.InputStream;\n    21→import java.io.InputStreamReader;\n    22→import java.math.BigDecimal;\n    23→import java.sql.Connection;\n    24→import java.sql.DatabaseMetaData;\n    25→import java.sql.PreparedStatement;\n    26→import java.sql.ResultSet;\n    27→import java.sql.SQLException;\n    28→import java.sql.Statement;\n    29→import java.util.ArrayList;\n    30→\n    31→import jakarta.enterprise.context.ApplicationScoped;\n    32→import jakarta.inject.Inject;\n    33→import javax.sql.DataSource;\n    34→\n    35→import io.agroal.api.AgroalDataSource;\n    36→\n    37→import com.ibm.websphere.samples.daytrader.beans.RunStatsDataBean;\n    38→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    39→import com.ibm.websphere.samples.daytrader.interfaces.TradeDB;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    41→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    42→import com.ibm.websphere.samples.daytrader.util.Log;\n    43→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    44→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    45→\n    46→/**\n    47→ * TradeBuildDB uses operations provided by the TradeApplication to (a) create the Database tables\n    48→ * (b)populate a DayTrader database without creating the tables. Specifically, a\n    49→ * new DayTrader User population is created using UserIDs of the form \"uid:xxx\"\n    50→ * where xxx is a sequential number (e.g. uid:0, uid:1, etc.). New stocks are also created of the\n    51→ * form \"s:xxx\", again where xxx represents sequential numbers (e.g. s:1, s:2, etc.)\n    52→ */\n    53→@ApplicationScoped\n    54→public class TradeDirectDBUtils implements TradeDB {\n    55→\n    56→  // MIGRATION: @Resource DataSource -> @Inject AgroalDataSource\n    57→  @Inject\n    58→  AgroalDataSource datasource;\n    59→\n    60→  @Inject \n    61→  @TradeJDBC\n    62→  TradeServices ts;\n    63→\n    64→  public String checkDBProductName() throws Exception {\n    65→    Connection conn = null;\n    66→    String dbProductName = null;\n    67→\n    68→    try {\n    69→\n    70→      conn = datasource.getConnection();\n    71→      DatabaseMetaData dbmd = conn.getMetaData();\n    72→      dbProductName = dbmd.getDatabaseProductName();\n    73→    } catch (SQLException e) {\n    74→      Log.error(e, \"TradeDirect:checkDBProductName() -- Error checking the Daytrader Database Product Name\");\n    75→    } finally {\n    76→      conn.close();\n    77→    }\n    78→    return dbProductName;\n    79→  }\n    80→\n    81→\n    82→  /**\n    83→   * Re-create the DayTrader db tables and populate them OR just populate a DayTrader DB, logging to the provided output stream\n    84→   */\n    85→  public void buildDB(java.io.PrintWriter out, InputStream ddlFile) throws Exception {\n    86→    String symbol, companyName;\n    87→    int errorCount = 0; // Give up gracefully after 10 errors\n    88→\n    89→    //  TradeStatistics.statisticsEnabled=false;  // disable statistics\n    90→    out.println(\"<HEAD><BR><EM> TradeBuildDB: Building DayTrader Database...</EM><BR> This operation will take several minutes. Please wait...</HEAD>\");\n    91→    out.println(\"<BODY>\");\n    92→\n    93→    if (ddlFile != null) {\n    94→      //out.println(\"<BR>TradeBuildDB: **** warPath= \"+warPath+\" ****</BR></BODY>\");\n    95→\n    96→      boolean success = false;\n    97→\n    98→      Object[] sqlBuffer = null;\n    99→\n   100→      //parse the DDL file and fill the SQL commands into a buffer\n   101→      try {\n   102→        sqlBuffer = parseDDLToBuffer(ddlFile);\n   103→      } catch (Exception e) {\n   104→        Log.error(e, \"TradeBuildDB: Unable to parse DDL file\");\n   105→        out.println(\"<BR>TradeBuildDB: **** Unable to parse DDL file for the specified database ****</BR></BODY>\");\n   106→        return;\n   107→      }\n   108→      if ((sqlBuffer == null) || (sqlBuffer.length == 0)) {\n   109→        out.println(\"<BR>TradeBuildDB: **** Parsing DDL file returned empty buffer, please check that a valid DB specific DDL file is available and retry ****</BR></BODY>\");\n   110→        return;\n   111→      }\n   112→\n   113→      // send the sql commands buffer to drop and recreate the Daytrader tables\n   114→      out.println(\"<BR>TradeBuildDB: **** Dropping and Recreating the DayTrader tables... ****</BR>\");\n   115→      try {\n   116→        success = recreateDBTables(sqlBuffer, out);\n   117→      } catch (Exception e) {\n   118→        Log.error(e, \"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   119→        out.println(\"TradeBuildDB: Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing\");\n   120→        return;\n   121→      }\n   122→      if (!success) {\n   123→        out.println(\"<BR>TradeBuildDB: **** Unable to drop and recreate DayTrader Db Tables, please check for database consistency before continuing ****</BR></BODY>\");\n   124→        return;\n   125→      }\n   126→      out.println(\"<BR>TradeBuildDB: **** DayTrader tables successfully created! ****</BR><BR><b> Please Stop and Re-start your Daytrader application (or your application server) and then use the \\\"Repopulate Daytrader Database\\\" link to populate your database.</b></BR><BR><BR></BODY>\");\n   127→      return;\n   128→    } // end of createDBTables\n   129→\n   130→    out.println(\"<BR>TradeBuildDB: **** Creating \" + TradeConfig.getMAX_QUOTES() + \" Quotes ****</BR>\");\n   131→    //Attempt to delete all of the Trade users and Trade Quotes first\n   132→    try {\n   133→      resetTrade(true);\n   134→    } catch (Exception e) {\n   135→      Log.error(e, \"TradeBuildDB: Unable to delete Trade users (uid:0, uid:1, ...) and Trade Quotes (s:0, s:1, ...)\");\n   136→    }\n   137→    for (int i = 0; i < TradeConfig.getMAX_QUOTES(); i++) {\n   138→      symbol = \"s:\" + i;\n   139→      companyName = \"S\" + i + \" Incorporated\";\n   140→      try {\n   141→        ts.createQuote(symbol, companyName, new java.math.BigDecimal(TradeConfig.rndPrice()));\n   142→        if (i % 10 == 0) {\n   143→          out.print(\".....\" + symbol);\n   144→          if (i % 100 == 0) {\n   145→            out.println(\" -<BR>\");\n   146→            out.flush();\n   147→          }\n   148→        }\n   149→      } catch (Exception e) {\n   150→        if (errorCount++ >= 10) {\n   151→          String error = \"Populate Trade DB aborting after 10 create quote errors. Check the EJB datasource configuration. Check the log for details <BR><BR> Exception is: <BR> \"\n   152→              + e.toString();\n   153→          Log.error(e, error);\n   154→          throw e;\n   155→        }\n   156→      }\n   157→    }\n   158→    out.println(\"<BR>\");\n   159→    out.println(\"<BR>**** Registering \" + TradeConfig.getMAX_USERS() + \" Users **** \");\n   160→    errorCount = 0; //reset for user registrations\n   161→\n   162→    // Registration is a formal operation in Trade 2.\n   163→    for (int i = 0; i < TradeConfig.getMAX_USERS(); i++) {\n   164→      String userID = \"uid:\" + i;\n   165→      String fullname = TradeConfig.rndFullName();\n   166→      String email = TradeConfig.rndEmail(userID);\n   167→      String address = TradeConfig.rndAddress();\n   168→      String creditcard = TradeConfig.rndCreditCard();\n   169→      double initialBalance = (double) (TradeConfig.rndInt(100000)) + 200000;\n   170→      if (i == 0) {\n   171→        initialBalance = 1000000; // uid:0 starts with a cool million.\n   172→      }\n   173→      try {\n   174→        AccountDataBean accountData = ts.register(userID, \"xxx\", fullname, address, email, creditcard, new BigDecimal(initialBalance));\n   175→\n   176→        if (accountData != null) {\n   177→          if (i % 50 == 0) {\n   178→            out.print(\"<BR>Account# \" + accountData.getAccountID() + \" userID=\" + userID);\n   179→          } // end-if\n   180→\n   181→          int holdings = TradeConfig.rndInt(TradeConfig.getMAX_HOLDINGS() + 1); // 0-MAX_HOLDING (inclusive), avg holdings per user = (MAX-0)/2\n   182→          double quantity = 0;\n   183→\n   184→          for (int j = 0; j < holdings; j++) {\n   185→            symbol = TradeConfig.rndSymbol();\n   186→            quantity = TradeConfig.rndQuantity();\n   187→            ts.buy(userID, symbol, quantity, TradeConfig.getOrderProcessingMode());\n   188→          } // end-for\n   189→          if (i % 50 == 0) {\n   190→            out.println(\" has \" + holdings + \" holdings.\");\n   191→            out.flush();\n   192→          } // end-if\n   193→        } else {\n   194→          out.println(\"<BR>UID \" + userID + \" already registered.</BR>\");\n   195→          out.flush();\n   196→        } // end-if\n   197→\n   198→      } catch (Exception e) {\n   199→        if (errorCount++ >= 10) {\n   200→          String error = \"Populate Trade DB aborting after 10 user registration errors. Check the log for details. <BR><BR> Exception is: <BR>\"\n   201→              + e.toString();\n   202→          Log.error(e, error);\n   203→          throw e;\n   204→        }\n   205→      }\n   206→    } // end-for\n   207→    out.println(\"</BODY>\");\n   208→  }\n   209→\n   210→  private boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n   211→    // Clear MDB Statistics\n   212→    MDBStats.getInstance().reset();\n   213→\n   214→    Connection conn = null;\n   215→    boolean success = false;\n   216→    try {\n   217→      conn = datasource.getConnection();\n   218→      Statement stmt = conn.createStatement();\n   219→      int bufferLength = sqlBuffer.length;\n   220→      for (int i = 0; i < bufferLength; i++) {\n   221→        try {\n   222→          stmt.executeUpdate((String) sqlBuffer[i]);\n   223→          // commit(conn);\n   224→        } catch (SQLException ex) {\n   225→          // Ignore DROP statements as tables won't always exist.\n   226→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n   227→            Log.error(\"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i], ex);\n   228→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i] + \"</I> . Check log for details.</BR>\");\n   229→          }\n   230→        }\n   231→      }\n   232→      stmt.close();\n   233→      conn.commit();\n   234→      success = true;\n   235→    } catch (Exception e) {\n   236→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n   237→    } finally {\n   238→      conn.close();\n   239→    }\n   240→    return success;\n   241→  }\n   242→\n   243→\n   244→  public RunStatsDataBean resetTrade(boolean deleteAll) throws Exception {\n   245→    // Clear MDB Statistics\n   246→    MDBStats.getInstance().reset();\n   247→    // Reset Trade\n   248→\n   249→    RunStatsDataBean runStatsData = new RunStatsDataBean();\n   250→    Connection conn = null;\n   251→    try {\n   252→\n   253→      conn = datasource.getConnection();\n   254→      conn.setAutoCommit(false);\n   255→      PreparedStatement stmt = null;\n   256→      ResultSet rs = null;\n   257→\n   258→      if (deleteAll) {\n   259→        try {\n   260→          stmt = getStatement(conn, \"delete from quoteejb\");\n   261→          stmt.executeUpdate();\n   262→          stmt.close();\n   263→          stmt = getStatement(conn, \"delete from accountejb\");\n   264→          stmt.executeUpdate();\n   265→          stmt.close();\n   266→          stmt = getStatement(conn, \"delete from accountprofileejb\");\n   267→          stmt.executeUpdate();\n   268→          stmt.close();\n   269→          stmt = getStatement(conn, \"delete from holdingejb\");\n   270→          stmt.executeUpdate();\n   271→          stmt.close();\n   272→          stmt = getStatement(conn, \"delete from orderejb\");\n   273→          stmt.executeUpdate();\n   274→          stmt.close();\n   275→          // FUTURE: - DuplicateKeyException - For now, don't start at\n   276→          // zero as KeySequenceDirect and KeySequenceBean will still\n   277→          // give out\n   278→          // the cached Block and then notice this change. Better\n   279→          // solution is\n   280→          // to signal both classes to drop their cached blocks\n   281→          // stmt = getStatement(conn, \"delete from keygenejb\");\n   282→          // stmt.executeUpdate();\n   283→          // stmt.close();\n   284→          conn.commit();\n   285→        } catch (Exception e) {\n   286→          Log.error(e, \"TradeDirect:resetTrade(deleteAll) -- Error deleting Trade users and stock from the Trade database\");\n   287→        }\n   288→        return runStatsData;\n   289→      }\n   290→\n   291→      stmt = getStatement(conn, \"delete from holdingejb where holdingejb.account_accountid is null\");\n   292→      stmt.executeUpdate();\n   293→      stmt.close();\n   294→\n   295→      // Count and Delete newly registered users (users w/ id that start\n   296→      // \"ru:%\":\n   297→      stmt = getStatement(conn, \"delete from accountprofileejb where userid like 'ru:%'\");\n   298→      stmt.executeUpdate();\n   299→      stmt.close();\n   300→\n   301→      stmt = getStatement(conn, \"delete from orderejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   302→      stmt.executeUpdate();\n   303→      stmt.close();\n   304→\n   305→      stmt = getStatement(conn,\n   306→          \"delete from holdingejb where account_accountid in (select accountid from accountejb a where a.profile_userid like 'ru:%')\");\n   307→      stmt.executeUpdate();\n   308→      stmt.close();\n   309→\n   310→      stmt = getStatement(conn, \"delete from accountejb where profile_userid like 'ru:%'\");\n   311→      int newUserCount = stmt.executeUpdate();\n   312→      runStatsData.setNewUserCount(newUserCount);\n   313→      stmt.close();\n   314→\n   315→      // Count of trade users\n   316→      stmt = getStatement(conn, \"select count(accountid) as \\\"tradeUserCount\\\" from accountejb a where a.profile_userid like 'uid:%'\");\n   317→      rs = stmt.executeQuery();\n   318→      rs.next();\n   319→      int tradeUserCount = rs.getInt(\"tradeUserCount\");\n   320→      runStatsData.setTradeUserCount(tradeUserCount);\n   321→      stmt.close();\n   322→\n   323→      rs.close();\n   324→      // Count of trade stocks\n   325→      stmt = getStatement(conn, \"select count(symbol) as \\\"tradeStockCount\\\" from quoteejb a where a.symbol like 's:%'\");\n   326→      rs = stmt.executeQuery();\n   327→      rs.next();\n   328→      int tradeStockCount = rs.getInt(\"tradeStockCount\");\n   329→      runStatsData.setTradeStockCount(tradeStockCount);\n   330→      stmt.close();\n   331→\n   332→      // Count of trade users login, logout\n   333→      stmt = getStatement(conn,\n   334→          \"select sum(loginCount) as \\\"sumLoginCount\\\", sum(logoutCount) as \\\"sumLogoutCount\\\" from accountejb a where  a.profile_userID like 'uid:%'\");\n   335→      rs = stmt.executeQuery();\n   336→      rs.next();\n   337→      int sumLoginCount = rs.getInt(\"sumLoginCount\");\n   338→      int sumLogoutCount = rs.getInt(\"sumLogoutCount\");\n   339→      runStatsData.setSumLoginCount(sumLoginCount);\n   340→      runStatsData.setSumLogoutCount(sumLogoutCount);\n   341→      stmt.close();\n   342→\n   343→      rs.close();\n   344→      // Update logoutcount and loginCount back to zero\n   345→\n   346→      stmt = getStatement(conn, \"update accountejb set logoutCount=0,loginCount=0 where profile_userID like 'uid:%'\");\n   347→      stmt.executeUpdate();\n   348→      stmt.close();\n   349→\n   350→      // count holdings for trade users\n   351→      stmt = getStatement(conn, \"select count(holdingid) as \\\"holdingCount\\\" from holdingejb h where h.account_accountid in \"\n   352→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   353→\n   354→      rs = stmt.executeQuery();\n   355→      rs.next();\n   356→      int holdingCount = rs.getInt(\"holdingCount\");\n   357→      runStatsData.setHoldingCount(holdingCount);\n   358→      stmt.close();\n   359→      rs.close();\n   360→\n   361→      // count orders for trade users\n   362→      stmt = getStatement(conn, \"select count(orderid) as \\\"orderCount\\\" from orderejb o where o.account_accountid in \"\n   363→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')\");\n   364→\n   365→      rs = stmt.executeQuery();\n   366→      rs.next();\n   367→      int orderCount = rs.getInt(\"orderCount\");\n   368→      runStatsData.setOrderCount(orderCount);\n   369→      stmt.close();\n   370→      rs.close();\n   371→\n   372→      // count orders by type for trade users\n   373→      stmt = getStatement(conn, \"select count(orderid) \\\"buyOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   374→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='buy')\");\n   375→\n   376→      rs = stmt.executeQuery();\n   377→      rs.next();\n   378→      int buyOrderCount = rs.getInt(\"buyOrderCount\");\n   379→      runStatsData.setBuyOrderCount(buyOrderCount);\n   380→      stmt.close();\n   381→      rs.close();\n   382→\n   383→      // count orders by type for trade users\n   384→      stmt = getStatement(conn, \"select count(orderid) \\\"sellOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   385→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderType='sell')\");\n   386→\n   387→      rs = stmt.executeQuery();\n   388→      rs.next();\n   389→      int sellOrderCount = rs.getInt(\"sellOrderCount\");\n   390→      runStatsData.setSellOrderCount(sellOrderCount);\n   391→      stmt.close();\n   392→      rs.close();\n   393→\n   394→      // Delete cancelled orders\n   395→      stmt = getStatement(conn, \"delete from orderejb where orderStatus='cancelled'\");\n   396→      int cancelledOrderCount = stmt.executeUpdate();\n   397→      runStatsData.setCancelledOrderCount(cancelledOrderCount);\n   398→      stmt.close();\n   399→      rs.close();\n   400→\n   401→      // count open orders by type for trade users\n   402→      stmt = getStatement(conn, \"select count(orderid) \\\"openOrderCount\\\"from orderejb o where (o.account_accountid in \"\n   403→          + \"(select accountid from accountejb a where a.profile_userid like 'uid:%')) AND \" + \" (o.orderStatus='open')\");\n   404→\n   405→      rs = stmt.executeQuery();\n   406→      rs.next();\n   407→      int openOrderCount = rs.getInt(\"openOrderCount\");\n   408→      runStatsData.setOpenOrderCount(openOrderCount);\n   409→\n   410→      stmt.close();\n   411→      rs.close();\n   412→      // Delete orders for holding which have been purchased and sold\n   413→      stmt = getStatement(conn, \"delete from orderejb where holding_holdingid is null\");\n   414→      int deletedOrderCount = stmt.executeUpdate();\n   415→      runStatsData.setDeletedOrderCount(deletedOrderCount);\n   416→      stmt.close();\n   417→      rs.close();\n   418→\n   419→      conn.commit();\n   420→\n   421→      System.out.println(\"TradeDirect:reset Run stats data\\n\\n\" + runStatsData);\n   422→    } catch (Exception e) {\n   423→      Log.error(e, \"Failed to reset Trade\");\n   424→      conn.rollback();\n   425→      throw e;\n   426→    } finally {\n   427→      conn.close();\n   428→    }\n   429→    return runStatsData;\n   430→\n   431→  }\n   432→\n   433→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n   434→    return conn.prepareStatement(sql);\n   435→  }\n   436→\n   437→  public Object[] parseDDLToBuffer(InputStream ddlFile) throws Exception {\n   438→    BufferedReader br = null;\n   439→    ArrayList<String> sqlBuffer = new ArrayList<String>(30); //initial capacity 30 assuming we have 30 ddl-sql statements to read\n   440→\n   441→    try {\n   442→      br = new BufferedReader(new InputStreamReader(ddlFile));\n   443→      String s;\n   444→      String sql = new String();\n   445→      while ((s = br.readLine()) != null) {\n   446→        s = s.trim();\n   447→        if ((s.length() != 0) && (s.charAt(0) != '#')) // Empty lines or lines starting with \"#\" are ignored\n   448→        {\n   449→          sql = sql + \" \" + s;\n   450→          if (s.endsWith(\";\")) { // reached end of sql statement\n   451→            sql = sql.replace(';', ' '); //remove the semicolon\n   452→            sqlBuffer.add(sql);\n   453→            sql = \"\";\n   454→          }\n   455→        }\n   456→      }\n   457→    } catch (IOException ex) {\n   458→      Log.error(\"TradeBuildDB:parseDDLToBuffer Exeception during open/read of File: \" + ddlFile, ex);\n   459→      throw ex;\n   460→    } finally {\n   461→      if (br != null) {\n   462→        try {\n   463→          br.close();\n   464→        } catch (IOException ex) {\n   465→          Log.error(\"TradeBuildDB:parseDDLToBuffer Failed to close BufferedReader\", ex);\n   466→        }\n   467→      }\n   468→    }\n   469→    return sqlBuffer.toArray();\n   470→  }\n   471→}\n   472→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01JoEemWzH4ddq46J3MvUgrU","session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"03a508e2-2f05-42a4-9fb0-df60f43ef71e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WCQEEEnqcDhexfPAeTAXZZ","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.direct;\n    17→\n    18→import java.io.Serializable;\n    19→import java.math.BigDecimal;\n    20→import java.sql.Connection;\n    21→import java.sql.PreparedStatement;\n    22→import java.sql.ResultSet;\n    23→import java.sql.SQLException;\n    24→import java.sql.Statement;\n    25→import java.sql.Timestamp;\n    26→import java.util.ArrayList;\n    27→import java.util.Collection;\n    28→import java.util.concurrent.Future;\n    29→\n    30→import jakarta.annotation.Resource;\n    31→import jakarta.enterprise.context.Dependent;\n    32→import jakarta.enterprise.event.Event;\n    33→import jakarta.enterprise.event.NotificationOptions;\n    34→import jakarta.inject.Inject;\n    35→import javax.sql.DataSource;\n    36→import jakarta.transaction.UserTransaction;\n    37→import jakarta.validation.constraints.NotNull;\n    38→\n    39→import io.quarkus.narayana.jta.QuarkusTransaction;\n    40→\n    41→import com.ibm.websphere.samples.daytrader.messaging.MessageProducerService;\n    42→\n    43→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    44→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    45→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    46→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    47→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    48→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    49→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    50→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    51→import com.ibm.websphere.samples.daytrader.util.Log;\n    52→import com.ibm.websphere.samples.daytrader.util.MDBStats;\n    53→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    54→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    55→import com.ibm.websphere.samples.daytrader.interfaces.MarketSummaryUpdate;\n    56→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    57→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    58→import com.ibm.websphere.samples.daytrader.interfaces.TradeJDBC;\n    59→\n    60→/**\n    61→ * TradeDirect uses direct JDBC and JMS access to a\n    62→ * <code>javax.sql.DataSource</code> to implement the business methods of the\n    63→ * Trade online broker application. These business methods represent the\n    64→ * features and operations that can be performed by customers of the brokerage\n    65→ * such as login, logout, get a stock quote, buy or sell a stock, etc. and are\n    66→ * specified in the {@link com.ibm.websphere.samples.daytrader.TradeServices}\n    67→ * interface\n    68→ *\n    69→ * Note: In order for this class to be thread-safe, a new TradeJDBC must be\n    70→ * created for each call to a method from the TradeInterface interface.\n    71→ * Otherwise, pooled connections may not be released.\n    72→ *\n    73→ * @see com.ibm.websphere.samples.daytrader.TradeServices\n    74→ *\n    75→ */\n    76→\n    77→// TradeDirect is injectable only via @TradeJDBC qualifier (no @Default)\n    78→// This prevents ambiguity with TradeSLSBBean which is the @Default implementation\n    79→@Dependent\n    80→@TradeJDBC\n    81→@RuntimeMode(\"Direct (JDBC)\")\n    82→@Trace\n    83→public class TradeDirect implements TradeServices, Serializable {\n    84→  /**\n    85→   * \n    86→   */\n    87→  private static final long serialVersionUID = -8089049090952927985L;\n    88→\n    89→  //This lock is used to serialize market summary operations.\n    90→  private static final Integer marketSummaryLock = new Integer(0);\n    91→  private static long nextMarketSummary = System.currentTimeMillis();\n    92→  private static MarketSummaryDataBean cachedMSDB = MarketSummaryDataBean.getRandomInstance();\n    93→\n    94→  private static BigDecimal ZERO = new BigDecimal(0.0);\n    95→  private boolean inGlobalTxn = false;\n    96→  private boolean inSession = false;\n    97→\n    98→  // MIGRATION: JMS resources replaced with MessageProducerService\n    99→  // Original Jakarta EE used JMS QueueConnectionFactory and TopicConnectionFactory\n   100→  // Quarkus uses SmallRye Reactive Messaging via MessageProducerService\n   101→\n   102→  @Inject\n   103→  private DataSource datasource;\n   104→\n   105→  @Inject\n   106→  private UserTransaction txn;\n   107→\n   108→  @Inject\n   109→  RecentQuotePriceChangeList recentQuotePriceChangeList;\n   110→  \n   111→  @Inject \n   112→  AsyncOrderSubmitter asyncOrderSubmitter;  \n   113→  \n   114→  @Inject\n   115→  @MarketSummaryUpdate\n   116→  Event<String> mkSummaryUpdateEvent;\n   117→  \n   118→  // MIGRATION: ManagedExecutorService -> use CDI Event async\n   119→  // For market summary updates, we use CDI Event.fireAsync()\n   120→  \n   121→  @Inject\n   122→  MessageProducerService messageProducer;\n   123→  \n   124→\n   125→  @Override\n   126→  public MarketSummaryDataBean getMarketSummary() throws Exception {\n   127→\n   128→    if (TradeConfig.getMarketSummaryInterval() == 0) {\n   129→      return getMarketSummaryInternal();\n   130→    }\n   131→    if (TradeConfig.getMarketSummaryInterval() < 0) {\n   132→      return cachedMSDB;\n   133→    }\n   134→\n   135→    /**\n   136→     * This is a little funky. If its time to fetch a new Market summary\n   137→     * then we'll synchronize access to make sure only one requester does\n   138→     * it. Others will merely return the old copy until the new\n   139→     * MarketSummary has been executed.\n   140→     */\n   141→\n   142→    long currentTime = System.currentTimeMillis();\n   143→\n   144→    if (currentTime > nextMarketSummary) {\n   145→      long oldNextMarketSummary = nextMarketSummary;\n   146→      boolean fetch = false;\n   147→\n   148→      synchronized (marketSummaryLock) {\n   149→        /**\n   150→         * Is it still ahead or did we miss lose the race? If we lost\n   151→         * then let's get out of here as the work has already been done.\n   152→         */\n   153→        if (oldNextMarketSummary == nextMarketSummary) {\n   154→          fetch = true;\n   155→          nextMarketSummary += TradeConfig.getMarketSummaryInterval() * 1000;\n   156→\n   157→          /**\n   158→           * If the server has been idle for a while then its possible\n   159→           * that nextMarketSummary could be way off. Rather than try\n   160→           * and play catch up we'll simply get in sync with the\n   161→           * current time + the interval.\n   162→           */\n   163→          if (nextMarketSummary < currentTime) {\n   164→            nextMarketSummary = currentTime + TradeConfig.getMarketSummaryInterval() * 1000;\n   165→          }\n   166→        }\n   167→      }\n   168→\n   169→      /**\n   170→       * If we're the lucky one then let's update the MarketSummary\n   171→       */\n   172→      if (fetch) {\n   173→        cachedMSDB = getMarketSummaryInternal();\n   174→  \n   175→      }\n   176→    }\n   177→\n   178→    return cachedMSDB;\n   179→  }\n   180→\n   181→\n   182→\n   183→  /**\n   184→   * @see TradeServices#getMarketSummary()\n   185→   */\n   186→\n   187→  public MarketSummaryDataBean getMarketSummaryInternal() throws Exception {\n   188→\n   189→    MarketSummaryDataBean marketSummaryData = null;\n   190→    Connection conn = null;\n   191→    try {\n   192→\n   193→      Log.trace(\"TradeDirect:getMarketSummary - inSession(\" + this.inSession + \")\");\n   194→\n   195→      conn = getConn();\n   196→      PreparedStatement stmt = getStatement(conn, getTSIAQuotesOrderByChangeSQL, ResultSet.TYPE_SCROLL_INSENSITIVE, ResultSet.CONCUR_READ_ONLY);\n   197→\n   198→      ArrayList<QuoteDataBean> topGainersData = new ArrayList<QuoteDataBean>(5);\n   199→      ArrayList<QuoteDataBean> topLosersData = new ArrayList<QuoteDataBean>(5);\n   200→\n   201→      ResultSet rs = stmt.executeQuery();\n   202→\n   203→      int count = 0;\n   204→      while (rs.next() && (count++ < 5)) {\n   205→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   206→        topLosersData.add(quoteData);\n   207→      }\n   208→\n   209→      stmt.close();\n   210→      stmt = getStatement(conn, \"select * from quoteejb q order by q.change1 DESC\", ResultSet.TYPE_SCROLL_INSENSITIVE, ResultSet.CONCUR_READ_ONLY);\n   211→      rs = stmt.executeQuery();\n   212→\n   213→      count = 0;\n   214→      while (rs.next() && (count++ < 5)) {\n   215→        QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   216→        topGainersData.add(quoteData);\n   217→      }\n   218→\n   219→      /*\n   220→       * rs.last(); count = 0; while (rs.previous() && (count++ < 5) ) {\n   221→       * QuoteDataBean quoteData = getQuoteDataFromResultSet(rs);\n   222→       * topGainersData.add(quoteData); }\n   223→       */\n   224→\n   225→      stmt.close();\n   226→\n   227→      BigDecimal TSIA = ZERO;\n   228→      BigDecimal openTSIA = ZERO;\n   229→      double volume = 0.0;\n   230→\n   231→      if ((topGainersData.size() > 0) || (topLosersData.size() > 0)) {\n   232→\n   233→        stmt = getStatement(conn, getTSIASQL);\n   234→        rs = stmt.executeQuery();\n   235→\n   236→        if (!rs.next()) {\n   237→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIASQL -- no results\");\n   238→        } else {\n   239→          TSIA = rs.getBigDecimal(\"TSIA\");\n   240→        }\n   241→        stmt.close();\n   242→\n   243→        stmt = getStatement(conn, getOpenTSIASQL);\n   244→        rs = stmt.executeQuery();\n   245→\n   246→        if (!rs.next()) {\n   247→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getOpenTSIASQL -- no results\");\n   248→        } else {\n   249→          openTSIA = rs.getBigDecimal(\"openTSIA\");\n   250→        }\n   251→        stmt.close();\n   252→\n   253→        stmt = getStatement(conn, getTSIATotalVolumeSQL);\n   254→        rs = stmt.executeQuery();\n   255→\n   256→        if (!rs.next()) {\n   257→          Log.error(\"TradeDirect:getMarketSummary -- error w/ getTSIATotalVolumeSQL -- no results\");\n   258→        } else {\n   259→          volume = rs.getDouble(\"totalVolume\");\n   260→        }\n   261→        stmt.close();\n   262→      }\n   263→      commit(conn);\n   264→\n   265→      marketSummaryData = new MarketSummaryDataBean(TSIA, openTSIA, volume, topGainersData, topLosersData);\n   266→      // MIGRATION: ManagedExecutorService -> use simple fireAsync\n   267→      mkSummaryUpdateEvent.fireAsync(\"MarketSummaryUpdate\");\n   268→\n   269→    }\n   270→\n   271→    catch (Exception e) {\n   272→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n   273→      rollBack(conn, e);\n   274→    } finally {\n   275→      releaseConn(conn);\n   276→    }\n   277→    return marketSummaryData;\n   278→\n   279→  }\n   280→\n   281→  /**\n   282→   * @see TradeServices#buy(String, String, double)\n   283→   */\n   284→  @Override\n   285→  @NotNull\n   286→  public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) throws Exception {\n   287→\n   288→    final Connection conn = getConn();\n   289→    OrderDataBean orderData = null;\n   290→\n   291→    BigDecimal total;\n   292→\n   293→    try {\n   294→\n   295→      Log.trace(\"TradeDirect:buy - inSession(\" + this.inSession + \")\");//, userID, symbol, new Double(quantity));\n   296→\n   297→\n   298→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   299→\n   300→        Log.trace(\"TradeDirect:buy create/begin global transaction\");\n   301→\n   302→\n   303→        txn.begin();\n   304→        setInGlobalTxn(true);\n   305→      }\n   306→\n   307→      //conn = getConn();\n   308→\n   309→      AccountDataBean accountData = getAccountData(conn, userID);\n   310→      QuoteDataBean quoteData = getQuoteData(conn, symbol);\n   311→      HoldingDataBean holdingData = null; // the buy operation will create\n   312→      // the holding\n   313→\n   314→      orderData = createOrder(accountData, quoteData, holdingData, \"buy\", quantity);\n   315→\n   316→      // Update -- account should be credited during completeOrder\n   317→      BigDecimal price = quoteData.getPrice();\n   318→      BigDecimal orderFee = orderData.getOrderFee();\n   319→      total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   320→      // subtract total from account balance\n   321→      creditAccountBalance(conn, accountData, total.negate());\n   322→      final Integer orderID = orderData.getOrderID();\n   323→\n   324→      try {\n   325→\n   326→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   327→          completeOrder(conn, orderData.getOrderID());\n   328→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   329→          completeOrderAsync(orderID, true);\n   330→        } else  if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   331→          queueOrder(orderID, true); // 2-phase\n   332→        } \n   333→      } catch (Exception je) {\n   334→        // MIGRATION: JMSException -> Exception (no JMS in Quarkus)\n   335→        Log.error(\"TradeBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed to queueOrder\", je);\n   336→\n   337→\n   338→        cancelOrder(conn, orderData.getOrderID());\n   339→      }\n   340→\n   341→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   342→\n   343→      if (getInGlobalTxn()) {\n   344→        \n   345→        Log.trace(\"TradeDirect:buy committing global transaction\");\n   346→        \n   347→        if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   348→          txn.commit();\n   349→          setInGlobalTxn(false);\n   350→        }\n   351→      } else {\n   352→        commit(conn);\n   353→      }\n   354→    } catch (Exception e) {\n   355→      Log.error(\"TradeDirect:buy error - rolling back\", e);\n   356→      if (getInGlobalTxn()) {\n   357→        txn.rollback();\n   358→      } else {\n   359→        rollBack(conn, e);\n   360→      }\n   361→    } finally {\n   362→      releaseConn(conn);\n   363→    }\n   364→\n   365→    return orderData;\n   366→  }\n   367→\n   368→  /**\n   369→   * @see TradeServices#sell(String, Integer)\n   370→   */\n   371→  @Override\n   372→  @NotNull\n   373→  public OrderDataBean sell(String userID, Integer holdingID, int orderProcessingMode) throws Exception {\n   374→    Connection conn = null;\n   375→    OrderDataBean orderData = null;\n   376→    //UserTransaction txn = null;\n   377→\n   378→    /*\n   379→     * total = (quantity * purchasePrice) + orderFee\n   380→     */\n   381→    BigDecimal total;\n   382→\n   383→    try {\n   384→     \n   385→      Log.trace(\"TradeDirect:sell - inSession(\" + this.inSession + \")\", userID, holdingID);\n   386→      \n   387→\n   388→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   389→       \n   390→        Log.trace(\"TradeDirect:sell create/begin global transaction\");\n   391→        \n   392→        txn.begin();\n   393→        setInGlobalTxn(true);\n   394→      }\n   395→\n   396→      conn = getConn();\n   397→\n   398→      AccountDataBean accountData = getAccountData(conn, userID);\n   399→      HoldingDataBean holdingData = getHoldingData(conn, holdingID.intValue());\n   400→      QuoteDataBean quoteData = null;\n   401→      if (holdingData != null) {\n   402→        quoteData = getQuoteData(conn, holdingData.getQuoteID());\n   403→      }\n   404→\n   405→      if ((accountData == null) || (holdingData == null) || (quoteData == null)) {\n   406→        String error = \"TradeDirect:sell -- error selling stock -- unable to find:  \\n\\taccount=\" + accountData + \"\\n\\tholding=\" + holdingData\n   407→            + \"\\n\\tquote=\" + quoteData + \"\\nfor user: \" + userID + \" and holdingID: \" + holdingID;\n   408→        Log.debug(error);\n   409→        if (getInGlobalTxn()) {\n   410→          txn.rollback();\n   411→        } else {\n   412→          rollBack(conn, new Exception(error));\n   413→        }\n   414→        orderData = new OrderDataBean();\n   415→        orderData.setOrderStatus(\"cancelled\");\n   416→        return orderData;\n   417→      }\n   418→\n   419→      double quantity = holdingData.getQuantity();\n   420→\n   421→      orderData = createOrder(accountData, quoteData, holdingData, \"sell\", quantity);\n   422→\n   423→      // Set the holdingSymbol purchaseDate to selling to signify the sell\n   424→      // is \"inflight\"\n   425→      updateHoldingStatus(conn, holdingData.getHoldingID(), holdingData.getQuoteID());\n   426→\n   427→      // UPDATE -- account should be credited during completeOrder\n   428→      BigDecimal price = quoteData.getPrice();\n   429→      BigDecimal orderFee = orderData.getOrderFee();\n   430→      total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   431→      creditAccountBalance(conn, accountData, total);\n   432→\n   433→      try {\n   434→        if (orderProcessingMode == TradeConfig.SYNCH) {\n   435→          completeOrder(conn, orderData.getOrderID());\n   436→        } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   437→          this.completeOrderAsync(orderData.getOrderID(), true);\n   438→        } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   439→          queueOrder(orderData.getOrderID(), true);\n   440→        } \n   441→      } catch (Exception je) {\n   442→        // MIGRATION: JMSException -> Exception (no JMS in Quarkus)\n   443→        Log.error(\"TradeBean:sell(\" + userID + \",\" + holdingID + \") --> failed to queueOrder\", je);\n   444→\n   445→        cancelOrder(conn, orderData.getOrderID());\n   446→      }\n   447→\n   448→      orderData = getOrderData(conn, orderData.getOrderID().intValue());\n   449→\n   450→      if (!inSession && orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   451→       \n   452→        Log.trace(\"TradeDirect:sell committing global transaction\");\n   453→        \n   454→        txn.commit();\n   455→        setInGlobalTxn(false);\n   456→      } else {\n   457→        commit(conn);\n   458→      }\n   459→    } catch (Exception e) {\n   460→      Log.error(\"TradeDirect:sell error\", e);\n   461→      if (getInGlobalTxn()) {\n   462→        txn.rollback();\n   463→      } else {\n   464→        rollBack(conn, e);\n   465→      }\n   466→    } finally {\n   467→      releaseConn(conn);\n   468→    }\n   469→\n   470→    return orderData;\n   471→  }\n   472→\n   473→  /**\n   474→   * @see TradeServices#queueOrder(Integer)\n   475→   */\n   476→  @Override\n   477→  public void queueOrder(Integer orderID, boolean twoPhase) throws Exception {\n   478→\n   479→   \n   480→    Log.trace(\"TradeDirect:queueOrder - inSession(\" + this.inSession + \")\", orderID);\n   481→    \n   482→    // MIGRATION: JMS Queue -> Reactive Messaging via MessageProducerService\n   483→    // Original: Create JMSContext, TextMessage, set properties, send to queue\n   484→    // Quarkus: Simply call messageProducer.queueOrderForProcessing()\n   485→    messageProducer.queueOrderForProcessing(orderID, twoPhase);\n   486→  }\n   487→\n   488→  /**\n   489→   * @see TradeServices#completeOrder(Integer)\n   490→   */\n   491→  @Override\n   492→  public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   493→    OrderDataBean orderData = null;\n   494→    Connection conn = null;\n   495→\n   496→    try { // twoPhase\n   497→\n   498→    \n   499→      Log.trace(\"TradeDirect:completeOrder - inSession(\" + this.inSession + \")\", orderID);\n   500→      \n   501→      setInGlobalTxn(!inSession && twoPhase);\n   502→      conn = getConn();\n   503→\n   504→      orderData = completeOrder(conn, orderID);\n   505→\n   506→      commit(conn);\n   507→\n   508→    } catch (Exception e) {\n   509→      Log.error(\"TradeDirect:completeOrder -- error completing order\", e);\n   510→      rollBack(conn, e);\n   511→      cancelOrder(orderID, twoPhase);\n   512→    } finally {\n   513→      releaseConn(conn);\n   514→    }\n   515→\n   516→    return orderData;\n   517→\n   518→  }\n   519→\n   520→  @Override\n   521→  public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   522→    if (!inSession) {\n   523→      asyncOrderSubmitter.submitOrder(orderID, twoPhase);\n   524→    }\n   525→    return null;\n   526→  }\n   527→\n   528→\n   529→  private OrderDataBean completeOrder(Connection conn, Integer orderID) throws Exception {\n   530→    //conn = getConn();\n   531→    OrderDataBean orderData = null;\n   532→   \n   533→    Log.trace(\"TradeDirect:completeOrderInternal - inSession(\" + this.inSession + \")\", orderID);\n   534→    \n   535→\n   536→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n   537→    stmt.setInt(1, orderID.intValue());\n   538→\n   539→    ResultSet rs = stmt.executeQuery();\n   540→\n   541→    if (!rs.next()) {\n   542→      Log.error(\"TradeDirect:completeOrder -- unable to find order: \" + orderID);\n   543→      stmt.close();\n   544→      return orderData;\n   545→    }\n   546→    orderData = getOrderDataFromResultSet(rs);\n   547→\n   548→    String orderType = orderData.getOrderType();\n   549→    String orderStatus = orderData.getOrderStatus();\n   550→\n   551→    // if (order.isCompleted())\n   552→    if ((orderStatus.compareToIgnoreCase(\"completed\") == 0) || (orderStatus.compareToIgnoreCase(\"alertcompleted\") == 0)\n   553→        || (orderStatus.compareToIgnoreCase(\"cancelled\") == 0)) {\n   554→      throw new Exception(\"TradeDirect:completeOrder -- attempt to complete Order that is already completed\");\n   555→    }\n   556→\n   557→    int accountID = rs.getInt(\"account_accountID\");\n   558→    String quoteID = rs.getString(\"quote_symbol\");\n   559→    int holdingID = rs.getInt(\"holding_holdingID\");\n   560→\n   561→    BigDecimal price = orderData.getPrice();\n   562→    double quantity = orderData.getQuantity();\n   563→\n   564→    // get the data for the account and quote\n   565→    // the holding will be created for a buy or extracted for a sell\n   566→\n   567→    /*\n   568→     * Use the AccountID and Quote Symbol from the Order AccountDataBean\n   569→     * accountData = getAccountData(accountID, conn); QuoteDataBean\n   570→     * quoteData = getQuoteData(conn, quoteID);\n   571→     */\n   572→    String userID = getAccountProfileData(conn, new Integer(accountID)).getUserID();\n   573→\n   574→    HoldingDataBean holdingData = null;\n   575→\n   576→   \n   577→    Log.trace(\"TradeDirect:completeOrder--> Completing Order \" + orderData.getOrderID() + \"\\n\\t Order info: \" + orderData + \"\\n\\t Account info: \"\n   578→          + accountID + \"\\n\\t Quote info: \" + quoteID);\n   579→    \n   580→\n   581→    // if (order.isBuy())\n   582→    if (orderType.compareToIgnoreCase(\"buy\") == 0) {\n   583→      /*\n   584→       * Complete a Buy operation - create a new Holding for the Account -\n   585→       * deduct the Order cost from the Account balance\n   586→       */\n   587→\n   588→      holdingData = createHolding(conn, accountID, quoteID, quantity, price);\n   589→      updateOrderHolding(conn, orderID.intValue(), holdingData.getHoldingID().intValue());\n   590→      updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   591→      updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), orderData.getQuantity());\n   592→    }\n   593→\n   594→    // if (order.isSell()) {\n   595→    if (orderType.compareToIgnoreCase(\"sell\") == 0) {\n   596→      /*\n   597→       * Complete a Sell operation - remove the Holding from the Account -\n   598→       * deposit the Order proceeds to the Account balance\n   599→       */\n   600→      holdingData = getHoldingData(conn, holdingID);\n   601→      if (holdingData == null) {\n   602→        Log.debug(\"TradeDirect:completeOrder:sell -- user: \" + userID + \" already sold holding: \" + holdingID);\n   603→        updateOrderStatus(conn, orderData.getOrderID(), \"cancelled\");\n   604→      } else {\n   605→        removeHolding(conn, holdingID, orderID.intValue());\n   606→        updateOrderStatus(conn, orderData.getOrderID(), \"closed\");\n   607→        updateQuotePriceVolume(orderData.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), orderData.getQuantity());\n   608→      }\n   609→\n   610→    } \n   611→\n   612→\n   613→\n   614→    Log.trace(\"TradeDirect:completeOrder--> Completed Order \" + orderData.getOrderID() + \"\\n\\t Order info: \" + orderData + \"\\n\\t Account info: \"\n   615→          + accountID + \"\\n\\t Quote info: \" + quoteID + \"\\n\\t Holding info: \" + holdingData);\n   616→    \n   617→    stmt.close();\n   618→\n   619→    commit(conn);\n   620→\n   621→\n   622→\n   623→    return orderData;\n   624→  }\n   625→\n   626→  /**\n   627→   * @see TradeServices#cancelOrder(Integer, boolean)\n   628→   */\n   629→  @Override\n   630→  public void cancelOrder(Integer orderID, boolean twoPhase) throws Exception {\n   631→\n   632→    Connection conn = null;\n   633→    try {\n   634→     \n   635→      Log.trace(\"TradeDirect:cancelOrder - inSession(\" + this.inSession + \")\", orderID);\n   636→      \n   637→      setInGlobalTxn(!inSession && twoPhase);\n   638→      conn = getConn();\n   639→      cancelOrder(conn, orderID);\n   640→      commit(conn);\n   641→\n   642→    } catch (Exception e) {\n   643→      Log.error(\"TradeDirect:cancelOrder -- error cancelling order: \" + orderID, e);\n   644→      rollBack(conn, e);\n   645→    } finally {\n   646→      releaseConn(conn);\n   647→    }\n   648→  }\n   649→\n   650→  private void cancelOrder(Connection conn, Integer orderID) throws Exception {\n   651→    updateOrderStatus(conn, orderID, \"cancelled\");\n   652→  }\n   653→\n   654→  @Override\n   655→  public void orderCompleted(String userID, Integer orderID) throws Exception {\n   656→    throw new UnsupportedOperationException(\"TradeDirect:orderCompleted method not supported\");\n   657→  }\n   658→\n   659→  private HoldingDataBean createHolding(Connection conn, int accountID, String symbol, double quantity, BigDecimal purchasePrice) throws Exception {\n   660→\n   661→    Timestamp purchaseDate = new Timestamp(System.currentTimeMillis());\n   662→    PreparedStatement stmt = getStatement(conn, createHoldingSQL);\n   663→\n   664→    Integer holdingID = KeySequenceDirect.getNextID(conn, \"holding\", inSession, getInGlobalTxn());\n   665→    stmt.setInt(1, holdingID.intValue());\n   666→    stmt.setTimestamp(2, purchaseDate);\n   667→    stmt.setBigDecimal(3, purchasePrice);\n   668→    stmt.setDouble(4, quantity);\n   669→    stmt.setString(5, symbol);\n   670→    stmt.setInt(6, accountID);\n   671→    stmt.executeUpdate();\n   672→\n   673→    stmt.close();\n   674→\n   675→    return getHoldingData(conn, holdingID.intValue());\n   676→  }\n   677→\n   678→  private void removeHolding(Connection conn, int holdingID, int orderID) throws Exception {\n   679→    PreparedStatement stmt = getStatement(conn, removeHoldingSQL);\n   680→\n   681→    stmt.setInt(1, holdingID);\n   682→    stmt.executeUpdate();\n   683→    stmt.close();\n   684→\n   685→    // set the HoldingID to NULL for the purchase and sell order now that\n   686→    // the holding as been removed\n   687→    stmt = getStatement(conn, removeHoldingFromOrderSQL);\n   688→\n   689→    stmt.setInt(1, holdingID);\n   690→    stmt.executeUpdate();\n   691→    stmt.close();\n   692→\n   693→  }\n   694→\n   695→  public OrderDataBean createOrder(AccountDataBean accountData, QuoteDataBean quoteData, HoldingDataBean holdingData, String orderType,\n   696→      double quantity) throws Exception {\n   697→    OrderDataBean orderData = null;\n   698→    Connection conn = null;\n   699→    try {\n   700→\n   701→      conn = getConn();\n   702→      Timestamp currentDate = new Timestamp(System.currentTimeMillis());\n   703→\n   704→      PreparedStatement stmt = getStatement(conn, createOrderSQL);\n   705→\n   706→      Integer orderID = KeySequenceDirect.getNextID(conn, \"order\", inSession, getInGlobalTxn());\n   707→      stmt.setInt(1, orderID.intValue());\n   708→      stmt.setString(2, orderType);\n   709→      stmt.setString(3, \"open\");\n   710→      stmt.setTimestamp(4, currentDate);\n   711→      stmt.setDouble(5, quantity);\n   712→      stmt.setBigDecimal(6, quoteData.getPrice().setScale(FinancialUtils.SCALE, FinancialUtils.ROUND));\n   713→      stmt.setBigDecimal(7, TradeConfig.getOrderFee(orderType));\n   714→      stmt.setInt(8, accountData.getAccountID().intValue());\n   715→      if (holdingData == null) {\n   716→        stmt.setNull(9, java.sql.Types.INTEGER);\n   717→      } else {\n   718→        stmt.setInt(9, holdingData.getHoldingID().intValue());\n   719→      }\n   720→      stmt.setString(10, quoteData.getSymbol());\n   721→      stmt.executeUpdate();\n   722→\n   723→      orderData = getOrderData(conn, orderID.intValue());\n   724→\n   725→      stmt.close();\n   726→\n   727→      commit(conn);\n   728→    } catch (Exception e) {\n   729→      Log.error(\"TradeDirect:createOrder -- error getting user orders\", e);\n   730→      rollBack(conn, e);\n   731→    } finally {\n   732→      releaseConn(conn);\n   733→    }\n   734→\n   735→    return orderData;\n   736→  }\n   737→\n   738→  /**\n   739→   * @see TradeServices#getOrders(String)\n   740→   */\n   741→  @Override\n   742→  public Collection<OrderDataBean> getOrders(String userID) throws Exception {\n   743→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   744→    Connection conn = null;\n   745→    try {\n   746→      Log.trace(\"TradeDirect:getOrders - inSession(\" + this.inSession + \")\", userID);\n   747→      \n   748→\n   749→      conn = getConn();\n   750→      PreparedStatement stmt = getStatement(conn, getOrdersByUserSQL);\n   751→      stmt.setString(1, userID);\n   752→\n   753→      ResultSet rs = stmt.executeQuery();\n   754→\n   755→      // TODO: return top 5 orders for now -- next version will add a\n   756→      // getAllOrders method\n   757→      // also need to get orders sorted by order id descending\n   758→      int i = 0;\n   759→      while ((rs.next()) && (i++ < 5)) {\n   760→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   761→        orderDataBeans.add(orderData);\n   762→      }\n   763→\n   764→      stmt.close();\n   765→      commit(conn);\n   766→\n   767→    } catch (Exception e) {\n   768→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   769→      rollBack(conn, e);\n   770→    } finally {\n   771→      releaseConn(conn);\n   772→    }\n   773→    return orderDataBeans;\n   774→  }\n   775→\n   776→  /**\n   777→   * @see TradeServices#getClosedOrders(String)\n   778→   */\n   779→  @Override\n   780→  public Collection<OrderDataBean> getClosedOrders(String userID) throws Exception {\n   781→    Collection<OrderDataBean> orderDataBeans = new ArrayList<OrderDataBean>();\n   782→    Connection conn = null;\n   783→    try {\n   784→\n   785→      Log.trace(\"TradeDirect:getClosedOrders - inSession(\" + this.inSession + \")\", userID);\n   786→      \n   787→\n   788→      conn = getConn();\n   789→      PreparedStatement stmt = getStatement(conn, getClosedOrdersSQL);\n   790→      stmt.setString(1, userID);\n   791→\n   792→      ResultSet rs = stmt.executeQuery();\n   793→\n   794→      while (rs.next()) {\n   795→        OrderDataBean orderData = getOrderDataFromResultSet(rs);\n   796→        orderData.setOrderStatus(\"completed\");\n   797→        updateOrderStatus(conn, orderData.getOrderID(), orderData.getOrderStatus());\n   798→        orderDataBeans.add(orderData);\n   799→\n   800→      }\n   801→\n   802→      stmt.close();\n   803→      commit(conn);\n   804→    } catch (Exception e) {\n   805→      Log.error(\"TradeDirect:getOrders -- error getting user orders\", e);\n   806→      rollBack(conn, e);\n   807→    } finally {\n   808→      releaseConn(conn);\n   809→    }\n   810→    return orderDataBeans;\n   811→  }\n   812→\n   813→  /**\n   814→   * @see TradeServices#createQuote(String, String, BigDecimal)\n   815→   */\n   816→  @Override\n   817→  public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) throws Exception {\n   818→\n   819→    QuoteDataBean quoteData = null;\n   820→    Connection conn = null;\n   821→    try {\n   822→\n   823→      Log.trace(\"TradeDirect:createQuote - inSession(\" + this.inSession + \")\");\n   824→      \n   825→\n   826→      price = price.setScale(FinancialUtils.SCALE, FinancialUtils.ROUND);\n   827→      double volume = 0.0, change = 0.0;\n   828→\n   829→      conn = getConn();\n   830→      PreparedStatement stmt = getStatement(conn, createQuoteSQL);\n   831→      stmt.setString(1, symbol); // symbol\n   832→      stmt.setString(2, companyName); // companyName\n   833→      stmt.setDouble(3, volume); // volume\n   834→      stmt.setBigDecimal(4, price); // price\n   835→      stmt.setBigDecimal(5, price); // open\n   836→      stmt.setBigDecimal(6, price); // low\n   837→      stmt.setBigDecimal(7, price); // high\n   838→      stmt.setDouble(8, change); // change\n   839→\n   840→      stmt.executeUpdate();\n   841→      stmt.close();\n   842→      commit(conn);\n   843→\n   844→      quoteData = new QuoteDataBean(symbol, companyName, volume, price, price, price, price, change);\n   845→    } catch (Exception e) {\n   846→      Log.error(\"TradeDirect:createQuote -- error creating quote\", e);\n   847→    } finally {\n   848→      releaseConn(conn);\n   849→    }\n   850→    return quoteData;\n   851→  }\n   852→\n   853→  /**\n   854→   * @see TradeServices#getQuote(String)\n   855→   */\n   856→\n   857→  @Override\n   858→  public QuoteDataBean getQuote(String symbol) throws Exception {\n   859→    QuoteDataBean quoteData = null;\n   860→    Connection conn = null;\n   861→\n   862→    try {\n   863→     \n   864→      Log.trace(\"TradeDirect:getQuote - inSession(\" + this.inSession + \")\", symbol);\n   865→    \n   866→\n   867→      conn = getConn();\n   868→      quoteData = getQuote(conn, symbol);\n   869→      commit(conn);\n   870→    } catch (Exception e) {\n   871→      Log.error(\"TradeDirect:getQuote -- error getting quote\", e);\n   872→      rollBack(conn, e);\n   873→    } finally {\n   874→      releaseConn(conn);\n   875→    }\n   876→    return quoteData;\n   877→  }\n   878→\n   879→  private QuoteDataBean getQuote(Connection conn, String symbol) throws Exception {\n   880→    QuoteDataBean quoteData = null;\n   881→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n   882→    stmt.setString(1, symbol); // symbol\n   883→\n   884→    ResultSet rs = stmt.executeQuery();\n   885→\n   886→    if (!rs.next()) {\n   887→      Log.error(\"TradeDirect:getQuote -- failure no result.next() for symbol: \" + symbol);\n   888→    } else {\n   889→      quoteData = getQuoteDataFromResultSet(rs);\n   890→    }\n   891→\n   892→    stmt.close();\n   893→\n   894→    return quoteData;\n   895→  }\n   896→\n   897→  private QuoteDataBean getQuoteForUpdate(Connection conn, String symbol) throws Exception {\n   898→    QuoteDataBean quoteData = null;\n   899→    PreparedStatement stmt = getStatement(conn, getQuoteForUpdateSQL);\n   900→    stmt.setString(1, symbol); // symbol\n   901→\n   902→    ResultSet rs = stmt.executeQuery();\n   903→\n   904→    if (!rs.next()) {\n   905→      Log.error(\"TradeDirect:getQuote -- failure no result.next()\");\n   906→    } else {\n   907→      quoteData = getQuoteDataFromResultSet(rs);\n   908→    }\n   909→\n   910→    stmt.close();\n   911→\n   912→    return quoteData;\n   913→  }\n   914→\n   915→  /**\n   916→   * @see TradeServices#getAllQuotes(String)\n   917→   */\n   918→  @Override\n   919→  public Collection<QuoteDataBean> getAllQuotes() throws Exception {\n   920→    Collection<QuoteDataBean> quotes = new ArrayList<QuoteDataBean>();\n   921→    QuoteDataBean quoteData = null;\n   922→\n   923→    Connection conn = null;\n   924→    try {\n   925→      conn = getConn();\n   926→\n   927→      PreparedStatement stmt = getStatement(conn, getAllQuotesSQL);\n   928→\n   929→      ResultSet rs = stmt.executeQuery();\n   930→\n   931→      while (!rs.next()) {\n   932→        quoteData = getQuoteDataFromResultSet(rs);\n   933→        quotes.add(quoteData);\n   934→      }\n   935→\n   936→      stmt.close();\n   937→    } catch (Exception e) {\n   938→      Log.error(\"TradeDirect:getAllQuotes\", e);\n   939→      rollBack(conn, e);\n   940→    } finally {\n   941→      releaseConn(conn);\n   942→    }\n   943→\n   944→    return quotes;\n   945→  }\n   946→\n   947→  /**\n   948→   * @see TradeServices#getHoldings(String)\n   949→   */\n   950→  @Override\n   951→  public Collection<HoldingDataBean> getHoldings(String userID) throws Exception {\n   952→    Collection<HoldingDataBean> holdingDataBeans = new ArrayList<HoldingDataBean>();\n   953→    Connection conn = null;\n   954→    try {\n   955→    \n   956→      Log.trace(\"TradeDirect:getHoldings - inSession(\" + this.inSession + \")\", userID);\n   957→      \n   958→\n   959→      conn = getConn();\n   960→      PreparedStatement stmt = getStatement(conn, getHoldingsForUserSQL);\n   961→      stmt.setString(1, userID);\n   962→\n   963→      ResultSet rs = stmt.executeQuery();\n   964→\n   965→      while (rs.next()) {\n   966→        HoldingDataBean holdingData = getHoldingDataFromResultSet(rs);\n   967→        holdingDataBeans.add(holdingData);\n   968→      }\n   969→\n   970→      stmt.close();\n   971→      commit(conn);\n   972→\n   973→    } catch (Exception e) {\n   974→      Log.error(\"TradeDirect:getHoldings -- error getting user holings\", e);\n   975→      rollBack(conn, e);\n   976→    } finally {\n   977→      releaseConn(conn);\n   978→    }\n   979→    return holdingDataBeans;\n   980→  }\n   981→\n   982→  /**\n   983→   * @see TradeServices#getHolding(Integer)\n   984→   */\n   985→  @Override\n   986→  public HoldingDataBean getHolding(Integer holdingID) throws Exception {\n   987→    HoldingDataBean holdingData = null;\n   988→    Connection conn = null;\n   989→    try {\n   990→\n   991→      Log.trace(\"TradeDirect:getHolding - inSession(\" + this.inSession + \")\", holdingID);\n   992→      \n   993→\n   994→      conn = getConn();\n   995→      holdingData = getHoldingData(holdingID.intValue());\n   996→\n   997→      commit(conn);\n   998→\n   999→    } catch (Exception e) {\n  1000→      Log.error(\"TradeDirect:getHolding -- error getting holding \" + holdingID + \"\", e);\n  1001→      rollBack(conn, e);\n  1002→    } finally {\n  1003→      releaseConn(conn);\n  1004→    }\n  1005→    return holdingData;\n  1006→  }\n  1007→\n  1008→  /**\n  1009→   * @see TradeServices#getAccountData(String)\n  1010→   */\n  1011→  @Override\n  1012→  public AccountDataBean getAccountData(String userID) throws Exception {\n  1013→    try {\n  1014→      AccountDataBean accountData = null;\n  1015→      Connection conn = null;\n  1016→      try {\n  1017→\n  1018→        Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", userID);\n  1019→        \n  1020→\n  1021→        conn = getConn();\n  1022→        accountData = getAccountData(conn, userID);\n  1023→        commit(conn);\n  1024→\n  1025→      } catch (Exception e) {\n  1026→        Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1027→        rollBack(conn, e);\n  1028→      } finally {\n  1029→        releaseConn(conn);\n  1030→      }\n  1031→      return accountData;\n  1032→    } catch (Exception e) {\n  1033→      throw new Exception(e.getMessage(), e);\n  1034→    }\n  1035→  }\n  1036→\n  1037→  private AccountDataBean getAccountData(Connection conn, String userID) throws Exception {\n  1038→    PreparedStatement stmt = getStatement(conn, getAccountForUserSQL);\n  1039→    stmt.setString(1, userID);\n  1040→    ResultSet rs = stmt.executeQuery();\n  1041→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1042→    stmt.close();\n  1043→    return accountData;\n  1044→  }\n  1045→\n  1046→  /**\n  1047→   * @see TradeServices#getAccountData(String)\n  1048→   */\n  1049→  public AccountDataBean getAccountData(int accountID) throws Exception {\n  1050→    AccountDataBean accountData = null;\n  1051→    Connection conn = null;\n  1052→    try {\n  1053→     \n  1054→      Log.trace(\"TradeDirect:getAccountData - inSession(\" + this.inSession + \")\", new Integer(accountID));\n  1055→\n  1056→      conn = getConn();\n  1057→      accountData = getAccountData(accountID, conn);\n  1058→      commit(conn);\n  1059→\n  1060→    } catch (Exception e) {\n  1061→      Log.error(\"TradeDirect:getAccountData -- error getting account data\", e);\n  1062→      rollBack(conn, e);\n  1063→    } finally {\n  1064→      releaseConn(conn);\n  1065→    }\n  1066→    return accountData;\n  1067→  }\n  1068→\n  1069→  private AccountDataBean getAccountData(int accountID, Connection conn) throws Exception {\n  1070→    PreparedStatement stmt = getStatement(conn, getAccountSQL);\n  1071→    stmt.setInt(1, accountID);\n  1072→    ResultSet rs = stmt.executeQuery();\n  1073→    AccountDataBean accountData = getAccountDataFromResultSet(rs);\n  1074→    stmt.close();\n  1075→    return accountData;\n  1076→  }\n  1077→\n  1078→  private QuoteDataBean getQuoteData(Connection conn, String symbol) throws Exception {\n  1079→    QuoteDataBean quoteData = null;\n  1080→    PreparedStatement stmt = getStatement(conn, getQuoteSQL);\n  1081→    stmt.setString(1, symbol);\n  1082→    ResultSet rs = stmt.executeQuery();\n  1083→    if (!rs.next()) {\n  1084→      Log.error(\"TradeDirect:getQuoteData -- could not find quote for symbol=\" + symbol);\n  1085→    } else {\n  1086→      quoteData = getQuoteDataFromResultSet(rs);\n  1087→    }\n  1088→    stmt.close();\n  1089→    return quoteData;\n  1090→  }\n  1091→\n  1092→  private HoldingDataBean getHoldingData(int holdingID) throws Exception {\n  1093→    HoldingDataBean holdingData = null;\n  1094→    Connection conn = null;\n  1095→    try {\n  1096→      conn = getConn();\n  1097→      holdingData = getHoldingData(conn, holdingID);\n  1098→      commit(conn);\n  1099→    } catch (Exception e) {\n  1100→      Log.error(\"TradeDirect:getHoldingData -- error getting data\", e);\n  1101→      rollBack(conn, e);\n  1102→    } finally {\n  1103→      releaseConn(conn);\n  1104→    }\n  1105→    return holdingData;\n  1106→  }\n  1107→\n  1108→  private HoldingDataBean getHoldingData(Connection conn, int holdingID) throws Exception {\n  1109→    HoldingDataBean holdingData = null;\n  1110→    PreparedStatement stmt = getStatement(conn, getHoldingSQL);\n  1111→    stmt.setInt(1, holdingID);\n  1112→    ResultSet rs = stmt.executeQuery();\n  1113→    if (!rs.next()) {\n  1114→      // already sold\n  1115→      Log.debug(\"TradeDirect:getHoldingData -- no results -- holdingID=\" + holdingID);\n  1116→    } else {\n  1117→      holdingData = getHoldingDataFromResultSet(rs);\n  1118→    }\n  1119→\n  1120→    stmt.close();\n  1121→    return holdingData;\n  1122→  }\n  1123→  \n  1124→  private OrderDataBean getOrderData(Connection conn, int orderID) throws Exception {\n  1125→    OrderDataBean orderData = null;\n  1126→    \n  1127→    Log.trace(\"TradeDirect:getOrderData(conn, \" + orderID + \")\");\n  1128→   \n  1129→    PreparedStatement stmt = getStatement(conn, getOrderSQL);\n  1130→    stmt.setInt(1, orderID);\n  1131→    ResultSet rs = stmt.executeQuery();\n  1132→    if (!rs.next()) {\n  1133→      // already sold\n  1134→      Log.error(\"TradeDirect:getOrderData -- no results for orderID:\" + orderID);\n  1135→    } else {\n  1136→      orderData = getOrderDataFromResultSet(rs);\n  1137→    }\n  1138→    stmt.close();\n  1139→    return orderData;\n  1140→  }\n  1141→\n  1142→  /**\n  1143→   * @see TradeServices#getAccountProfileData(String)\n  1144→   */\n  1145→  @Override\n  1146→  public AccountProfileDataBean getAccountProfileData(String userID) throws Exception {\n  1147→    AccountProfileDataBean accountProfileData = null;\n  1148→    Connection conn = null;\n  1149→\n  1150→    try {\n  1151→     \n  1152→      Log.trace(\"TradeDirect:getAccountProfileData - inSession(\" + this.inSession + \")\", userID);\n  1153→      \n  1154→\n  1155→      conn = getConn();\n  1156→      accountProfileData = getAccountProfileData(conn, userID);\n  1157→      commit(conn);\n  1158→    } catch (Exception e) {\n  1159→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1160→      rollBack(conn, e);\n  1161→    } finally {\n  1162→      releaseConn(conn);\n  1163→    }\n  1164→    return accountProfileData;\n  1165→  }\n  1166→\n  1167→  private AccountProfileDataBean getAccountProfileData(Connection conn, String userID) throws Exception {\n  1168→    PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1169→    stmt.setString(1, userID);\n  1170→\n  1171→    ResultSet rs = stmt.executeQuery();\n  1172→\n  1173→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1174→    stmt.close();\n  1175→    return accountProfileData;\n  1176→  }\n  1177→  \n  1178→  private AccountProfileDataBean getAccountProfileData(Connection conn, Integer accountID) throws Exception {\n  1179→    PreparedStatement stmt = getStatement(conn, getAccountProfileForAccountSQL);\n  1180→    stmt.setInt(1, accountID.intValue());\n  1181→\n  1182→    ResultSet rs = stmt.executeQuery();\n  1183→\n  1184→    AccountProfileDataBean accountProfileData = getAccountProfileDataFromResultSet(rs);\n  1185→    stmt.close();\n  1186→    return accountProfileData;\n  1187→  }\n  1188→\n  1189→  /**\n  1190→   * @see TradeServices#updateAccountProfile(AccountProfileDataBean)\n  1191→   */\n  1192→  @Override\n  1193→  public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) throws Exception {\n  1194→    AccountProfileDataBean accountProfileData = null;\n  1195→    Connection conn = null;\n  1196→\n  1197→    try {\n  1198→      \n  1199→      Log.trace(\"TradeDirect:updateAccountProfileData - inSession(\" + this.inSession + \")\", profileData.getUserID());\n  1200→\n  1201→      conn = getConn();\n  1202→      updateAccountProfile(conn, profileData);\n  1203→\n  1204→      accountProfileData = getAccountProfileData(conn, profileData.getUserID());\n  1205→      commit(conn);\n  1206→    } catch (Exception e) {\n  1207→      Log.error(\"TradeDirect:getAccountProfileData -- error getting profile data\", e);\n  1208→      rollBack(conn, e);\n  1209→    } finally {\n  1210→      releaseConn(conn);\n  1211→    }\n  1212→    return accountProfileData;\n  1213→  }\n  1214→\n  1215→  private void creditAccountBalance(Connection conn, AccountDataBean accountData, BigDecimal credit) throws Exception {\n  1216→    PreparedStatement stmt = getStatement(conn, creditAccountBalanceSQL);\n  1217→\n  1218→    stmt.setBigDecimal(1, credit);\n  1219→    stmt.setInt(2, accountData.getAccountID().intValue());\n  1220→\n  1221→    stmt.executeUpdate();\n  1222→    stmt.close();\n  1223→\n  1224→  }\n  1225→\n  1226→  // Set Timestamp to zero to denote sell is inflight\n  1227→  // UPDATE -- could add a \"status\" attribute to holding\n  1228→  private void updateHoldingStatus(Connection conn, Integer holdingID, String symbol) throws Exception {\n  1229→    Timestamp ts = new Timestamp(0);\n  1230→    PreparedStatement stmt = getStatement(conn, \"update holdingejb set purchasedate= ? where holdingid = ?\");\n  1231→\n  1232→    stmt.setTimestamp(1, ts);\n  1233→    stmt.setInt(2, holdingID.intValue());\n  1234→    stmt.executeUpdate();\n  1235→    stmt.close();\n  1236→  }\n  1237→\n  1238→  private void updateOrderStatus(Connection conn, Integer orderID, String status) throws Exception {\n  1239→    PreparedStatement stmt = getStatement(conn, updateOrderStatusSQL);\n  1240→\n  1241→    stmt.setString(1, status);\n  1242→    stmt.setTimestamp(2, new Timestamp(System.currentTimeMillis()));\n  1243→    stmt.setInt(3, orderID.intValue());\n  1244→    stmt.executeUpdate();\n  1245→    stmt.close();\n  1246→  }\n  1247→\n  1248→  private void updateOrderHolding(Connection conn, int orderID, int holdingID) throws Exception {\n  1249→    PreparedStatement stmt = getStatement(conn, updateOrderHoldingSQL);\n  1250→\n  1251→    stmt.setInt(1, holdingID);\n  1252→    stmt.setInt(2, orderID);\n  1253→    stmt.executeUpdate();\n  1254→    stmt.close();\n  1255→  }\n  1256→\n  1257→  private void updateAccountProfile(Connection conn, AccountProfileDataBean profileData) throws Exception {\n  1258→    PreparedStatement stmt = getStatement(conn, updateAccountProfileSQL);\n  1259→\n  1260→    stmt.setString(1, profileData.getPassword());\n  1261→    stmt.setString(2, profileData.getFullName());\n  1262→    stmt.setString(3, profileData.getAddress());\n  1263→    stmt.setString(4, profileData.getEmail());\n  1264→    stmt.setString(5, profileData.getCreditCard());\n  1265→    stmt.setString(6, profileData.getUserID());\n  1266→\n  1267→    stmt.executeUpdate();\n  1268→    stmt.close();\n  1269→  }\n  1270→\n  1271→  @Override\n  1272→  public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded) throws Exception {\n  1273→    return updateQuotePriceVolumeInt(symbol, changeFactor, sharesTraded, TradeConfig.getPublishQuotePriceChange());\n  1274→  }\n  1275→\n  1276→  /**\n  1277→   * Update a quote's price and volume\n  1278→   *\n  1279→   * @param symbol\n  1280→   *            The PK of the quote\n  1281→   * @param changeFactor\n  1282→   *            the percent to change the old price by (between 50% and 150%)\n  1283→   * @param sharedTraded\n  1284→   *            the ammount to add to the current volume\n  1285→   * @param publishQuotePriceChange\n  1286→   *            used by the PingJDBCWrite Primitive to ensure no JMS is used,\n  1287→   *            should be true for all normal calls to this API\n  1288→   */\n  1289→  public QuoteDataBean updateQuotePriceVolumeInt(String symbol, BigDecimal changeFactor, double sharesTraded, boolean publishQuotePriceChange)\n  1290→      throws Exception {\n  1291→\n  1292→    if (TradeConfig.getUpdateQuotePrices() == false) {\n  1293→      return new QuoteDataBean();\n  1294→    }\n  1295→\n  1296→    QuoteDataBean quoteData = null;\n  1297→    Connection conn = null;\n  1298→\n  1299→    try {\n  1300→      Log.trace(\"TradeDirect:updateQuotePriceVolume - inSession(\" + this.inSession + \")\", symbol, changeFactor, new Double(sharesTraded));\n  1301→\n  1302→      conn = getConn();\n  1303→\n  1304→      quoteData = getQuoteForUpdate(conn, symbol);\n  1305→      BigDecimal oldPrice = quoteData.getPrice();\n  1306→      BigDecimal openPrice = quoteData.getOpen();\n  1307→\n  1308→      double newVolume = quoteData.getVolume() + sharesTraded;\n  1309→\n  1310→      if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n  1311→        changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n  1312→      } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n  1313→        changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n  1314→      }\n  1315→\n  1316→      BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n  1317→      double change = newPrice.subtract(openPrice).doubleValue();\n  1318→\n  1319→      updateQuotePriceVolume(conn, quoteData.getSymbol(), newPrice, newVolume, change);\n  1320→      quoteData = getQuote(conn, symbol);\n  1321→\n  1322→      commit(conn);\n  1323→\n  1324→      if (publishQuotePriceChange) {\n  1325→        publishQuotePriceChange(quoteData, oldPrice, changeFactor, sharesTraded);\n  1326→      }\n  1327→\n  1328→      recentQuotePriceChangeList.add(quoteData);\n  1329→      \n  1330→    } catch (Exception e) {\n  1331→      Log.error(\"TradeDirect:updateQuotePriceVolume -- error updating quote price/volume for symbol:\" + symbol);\n  1332→      rollBack(conn, e);\n  1333→      throw e;\n  1334→    } finally {\n  1335→      releaseConn(conn);\n  1336→    }\n  1337→    return quoteData;\n  1338→  }\n  1339→\n  1340→  private void updateQuotePriceVolume(Connection conn, String symbol, BigDecimal newPrice, double newVolume, double change) throws Exception {\n  1341→\n  1342→    PreparedStatement stmt = getStatement(conn, updateQuotePriceVolumeSQL);\n  1343→\n  1344→    stmt.setBigDecimal(1, newPrice);\n  1345→    stmt.setDouble(2, change);\n  1346→    stmt.setDouble(3, newVolume);\n  1347→    stmt.setString(4, symbol);\n  1348→\n  1349→    stmt.executeUpdate();\n  1350→    stmt.close();\n  1351→  }\n  1352→\n  1353→  private void publishQuotePriceChange(QuoteDataBean quoteData, BigDecimal oldPrice, BigDecimal changeFactor, double sharesTraded) throws Exception {\n  1354→\n  1355→    Log.trace(\"TradeDirect:publishQuotePrice PUBLISHING to MDB quoteData = \" + quoteData);       \n  1356→\n  1357→    // MIGRATION: JMS Topic -> Reactive Messaging via MessageProducerService\n  1358→    // Original: Create JMSContext, TextMessage, set properties, send to topic\n  1359→    // Quarkus: Simply call messageProducer.publishQuotePriceChange()\n  1360→    messageProducer.publishQuotePriceChange(\n  1361→        quoteData.getSymbol(),\n  1362→        quoteData.getCompanyName(),\n  1363→        quoteData.getPrice(),\n  1364→        oldPrice,\n  1365→        quoteData.getOpen(),\n  1366→        quoteData.getLow(),\n  1367→        quoteData.getHigh(),\n  1368→        quoteData.getVolume(),\n  1369→        changeFactor,\n  1370→        sharesTraded\n  1371→    );\n  1372→  }\n  1373→\n  1374→  /**\n  1375→   * @see TradeServices#login(String, String)\n  1376→   */\n  1377→\n  1378→  @Override\n  1379→  public AccountDataBean login(String userID, String password) throws Exception {\n  1380→\n  1381→    AccountDataBean accountData = null;\n  1382→    Connection conn = null;\n  1383→    try {\n  1384→      Log.trace(\"TradeDirect:login - inSession(\" + this.inSession + \")\", userID, password);\n  1385→\n  1386→      conn = getConn();\n  1387→      PreparedStatement stmt = getStatement(conn, getAccountProfileSQL);\n  1388→      stmt.setString(1, userID);\n  1389→\n  1390→      ResultSet rs = stmt.executeQuery();\n  1391→      if (!rs.next()) {\n  1392→        Log.error(\"TradeDirect:login -- failure to find account for\" + userID);\n  1393→        // MIGRATION: javax.ejb.FinderException -> RuntimeException (no EJB in Quarkus)\n  1394→        throw new RuntimeException(\"Cannot find account for \" + userID);\n  1395→      }\n  1396→\n  1397→      String pw = rs.getString(\"passwd\");\n  1398→      stmt.close();\n  1399→      if ((pw == null) || (pw.equals(password) == false)) {\n  1400→        String error = \"TradeDirect:Login failure for user: \" + userID + \"\\n\\tIncorrect password-->\" + userID + \":\" + password;\n  1401→        Log.error(error);\n  1402→        throw new Exception(error);\n  1403→      }\n  1404→\n  1405→      stmt = getStatement(conn, loginSQL);\n  1406→      stmt.setTimestamp(1, new Timestamp(System.currentTimeMillis()));\n  1407→      stmt.setString(2, userID);\n  1408→\n  1409→      stmt.executeUpdate();\n  1410→      stmt.close();\n  1411→\n  1412→      stmt = getStatement(conn, getAccountForUserSQL);\n  1413→      stmt.setString(1, userID);\n  1414→      rs = stmt.executeQuery();\n  1415→\n  1416→      accountData = getAccountDataFromResultSet(rs);\n  1417→\n  1418→      stmt.close();\n  1419→\n  1420→      commit(conn);\n  1421→    } catch (Exception e) {\n  1422→      Log.error(\"TradeDirect:login -- error logging in user\", e);\n  1423→      rollBack(conn, e);\n  1424→    } finally {\n  1425→      releaseConn(conn);\n  1426→    }\n  1427→    return accountData;\n  1428→\n  1429→    /*\n  1430→     * setLastLogin( new Timestamp(System.currentTimeMillis()) );\n  1431→     * setLoginCount( getLoginCount() + 1 );\n  1432→     */\n  1433→  }\n  1434→\n  1435→  /**\n  1436→   * @see TradeServices#logout(String)\n  1437→   */\n  1438→  @Override\n  1439→  public void logout(String userID) throws Exception {\n  1440→    Log.trace(\"TradeDirect:logout - inSession(\" + this.inSession + \")\", userID);\n  1441→    \n  1442→    Connection conn = null;\n  1443→    try {\n  1444→      conn = getConn();\n  1445→      PreparedStatement stmt = getStatement(conn, logoutSQL);\n  1446→      stmt.setString(1, userID);\n  1447→      stmt.executeUpdate();\n  1448→      stmt.close();\n  1449→\n  1450→      commit(conn);\n  1451→    } catch (Exception e) {\n  1452→      Log.error(\"TradeDirect:logout -- error logging out user\", e);\n  1453→      rollBack(conn, e);\n  1454→    } finally {\n  1455→      releaseConn(conn);\n  1456→    }\n  1457→  }\n  1458→\n  1459→  /**\n  1460→   * @see TradeServices#register(String, String, String, String, String,\n  1461→   *      String, BigDecimal, boolean)\n  1462→   */\n  1463→\n  1464→  @Override\n  1465→  public AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance)\n  1466→      throws Exception {\n  1467→\n  1468→    AccountDataBean accountData = null;\n  1469→    Connection conn = null;\n  1470→    try {\n  1471→      Log.trace(\"TradeDirect:register - inSession(\" + this.inSession + \")\");  \n  1472→\n  1473→      conn = getConn();\n  1474→      PreparedStatement stmt = getStatement(conn, createAccountSQL);\n  1475→\n  1476→      Integer accountID = KeySequenceDirect.getNextID(conn, \"account\", inSession, getInGlobalTxn());\n  1477→      BigDecimal balance = openBalance;\n  1478→      Timestamp creationDate = new Timestamp(System.currentTimeMillis());\n  1479→      Timestamp lastLogin = creationDate;\n  1480→      int loginCount = 0;\n  1481→      int logoutCount = 0;\n  1482→\n  1483→      stmt.setInt(1, accountID.intValue());\n  1484→      stmt.setTimestamp(2, creationDate);\n  1485→      stmt.setBigDecimal(3, openBalance);\n  1486→      stmt.setBigDecimal(4, balance);\n  1487→      stmt.setTimestamp(5, lastLogin);\n  1488→      stmt.setInt(6, loginCount);\n  1489→      stmt.setInt(7, logoutCount);\n  1490→      stmt.setString(8, userID);\n  1491→      stmt.executeUpdate();\n  1492→      stmt.close();\n  1493→\n  1494→      stmt = getStatement(conn, createAccountProfileSQL);\n  1495→      stmt.setString(1, userID);\n  1496→      stmt.setString(2, password);\n  1497→      stmt.setString(3, fullname);\n  1498→      stmt.setString(4, address);\n  1499→      stmt.setString(5, email);\n  1500→      stmt.setString(6, creditcard);\n  1501→      stmt.executeUpdate();\n  1502→      stmt.close();\n  1503→\n  1504→      commit(conn);\n  1505→\n  1506→      accountData = new AccountDataBean(accountID, loginCount, logoutCount, lastLogin, creationDate, balance, openBalance, userID);\n  1507→\n  1508→    } catch (Exception e) {\n  1509→      Log.error(\"TradeDirect:register -- error registering new user\", e);\n  1510→    } finally {\n  1511→      releaseConn(conn);\n  1512→    }\n  1513→    return accountData;\n  1514→  }\n  1515→\n  1516→  private AccountDataBean getAccountDataFromResultSet(ResultSet rs) throws Exception {\n  1517→    AccountDataBean accountData = null;\n  1518→\n  1519→    if (!rs.next()) {\n  1520→      Log.error(\"TradeDirect:getAccountDataFromResultSet -- cannot find account data\");\n  1521→    } else {\n  1522→      accountData = new AccountDataBean(new Integer(rs.getInt(\"accountID\")), rs.getInt(\"loginCount\"), rs.getInt(\"logoutCount\"),\n  1523→          rs.getTimestamp(\"lastLogin\"), rs.getTimestamp(\"creationDate\"), rs.getBigDecimal(\"balance\"), rs.getBigDecimal(\"openBalance\"),\n  1524→          rs.getString(\"profile_userID\"));\n  1525→    }\n  1526→    return accountData;\n  1527→  }\n  1528→\n  1529→  private AccountProfileDataBean getAccountProfileDataFromResultSet(ResultSet rs) throws Exception {\n  1530→    AccountProfileDataBean accountProfileData = null;\n  1531→\n  1532→    if (!rs.next()) {\n  1533→      Log.error(\"TradeDirect:getAccountProfileDataFromResultSet -- cannot find accountprofile data\");\n  1534→    } else {\n  1535→      accountProfileData = new AccountProfileDataBean(rs.getString(\"userID\"), rs.getString(\"passwd\"), rs.getString(\"fullName\"), rs.getString(\"address\"),\n  1536→          rs.getString(\"email\"), rs.getString(\"creditCard\"));\n  1537→    }\n  1538→\n  1539→    return accountProfileData;\n  1540→  }\n  1541→\n  1542→  private HoldingDataBean getHoldingDataFromResultSet(ResultSet rs) throws Exception {\n  1543→    HoldingDataBean holdingData = null;\n  1544→\n  1545→    holdingData = new HoldingDataBean(new Integer(rs.getInt(\"holdingID\")), rs.getDouble(\"quantity\"), rs.getBigDecimal(\"purchasePrice\"),\n  1546→        rs.getTimestamp(\"purchaseDate\"), rs.getString(\"quote_symbol\"));\n  1547→    return holdingData;\n  1548→  }\n  1549→\n  1550→  private QuoteDataBean getQuoteDataFromResultSet(ResultSet rs) throws Exception {\n  1551→    QuoteDataBean quoteData = null;\n  1552→\n  1553→    quoteData = new QuoteDataBean(rs.getString(\"symbol\"), rs.getString(\"companyName\"), rs.getDouble(\"volume\"), rs.getBigDecimal(\"price\"),\n  1554→        rs.getBigDecimal(\"open1\"), rs.getBigDecimal(\"low\"), rs.getBigDecimal(\"high\"), rs.getDouble(\"change1\"));\n  1555→    return quoteData;\n  1556→  }\n  1557→\n  1558→  private OrderDataBean getOrderDataFromResultSet(ResultSet rs) throws Exception {\n  1559→    OrderDataBean orderData = null;\n  1560→\n  1561→    orderData = new OrderDataBean(new Integer(rs.getInt(\"orderID\")), rs.getString(\"orderType\"), rs.getString(\"orderStatus\"), rs.getTimestamp(\"openDate\"),\n  1562→        rs.getTimestamp(\"completionDate\"), rs.getDouble(\"quantity\"), rs.getBigDecimal(\"price\"), rs.getBigDecimal(\"orderFee\"),\n  1563→        rs.getString(\"quote_symbol\"));\n  1564→    return orderData;\n  1565→  }\n  1566→\n  1567→  public boolean recreateDBTables(Object[] sqlBuffer, java.io.PrintWriter out) throws Exception {\n  1568→    // Clear MDB Statistics\n  1569→    MDBStats.getInstance().reset();\n  1570→\n  1571→    Connection conn = null;\n  1572→    boolean success = false;\n  1573→    try {\n  1574→     \n  1575→      Log.trace(\"TradeDirect:recreateDBTables\");\n  1576→\n  1577→      conn = getConn();\n  1578→      Statement stmt = conn.createStatement();\n  1579→      int bufferLength = sqlBuffer.length;\n  1580→      for (int i = 0; i < bufferLength; i++) {\n  1581→        try {\n  1582→          stmt.executeUpdate((String) sqlBuffer[i]);\n  1583→          // commit(conn);\n  1584→        } catch (SQLException ex) {\n  1585→          // Ignore DROP statements as tables won't always exist.\n  1586→          if (((String) sqlBuffer[i]).indexOf(\"DROP \") < 0) {\n  1587→            Log.error(\"TradeDirect:recreateDBTables SQL Exception thrown on executing the foll sql command: \" + sqlBuffer[i], ex);\n  1588→            out.println(\"<BR>SQL Exception thrown on executing the foll sql command: <I>\" + sqlBuffer[i] + \"</I> . Check log for details.</BR>\");\n  1589→          }\n  1590→        }\n  1591→      }\n  1592→      stmt.close();\n  1593→      commit(conn);\n  1594→      success = true;\n  1595→    } catch (Exception e) {\n  1596→      Log.error(e, \"TradeDirect:recreateDBTables() -- Error dropping and recreating the database tables\");\n  1597→    } finally {\n  1598→      releaseConn(conn);\n  1599→    }\n  1600→    return success;\n  1601→  }\n  1602→\n  1603→  ;\n  1604→\n  1605→\n  1606→\n  1607→  private void releaseConn(Connection conn) throws Exception {\n  1608→    try {\n  1609→      if (conn != null) {\n  1610→        conn.close();\n  1611→        if (Log.doTrace()) {\n  1612→          synchronized (lock) {\n  1613→            connCount--;\n  1614→          }\n  1615→          Log.trace(\"TradeDirect:releaseConn -- connection closed, connCount=\" + connCount);\n  1616→        }\n  1617→      }\n  1618→    } catch (Exception e) {\n  1619→      Log.error(\"TradeDirect:releaseConnection -- failed to close connection\", e);\n  1620→    }\n  1621→  }\n  1622→\n  1623→\n  1624→  /*\n  1625→   * Allocate a new connection to the datasource\n  1626→   */\n  1627→  private static int connCount = 0;\n  1628→\n  1629→  private static Integer lock = new Integer(0);\n  1630→\n  1631→  private Connection getConn() throws Exception {\n  1632→\n  1633→    Connection conn = datasource.getConnection();      \n  1634→\n  1635→    if (!this.inGlobalTxn) {\n  1636→      conn.setAutoCommit(false);\n  1637→    }\n  1638→    if (Log.doTrace()) {\n  1639→      synchronized (lock) {\n  1640→        connCount++;\n  1641→      }\n  1642→      Log.trace(\"TradeDirect:getConn -- new connection allocated, IsolationLevel=\" + conn.getTransactionIsolation() + \" connectionCount = \" + connCount);\n  1643→    }\n  1644→\n  1645→    return conn;\n  1646→  }\n  1647→\n  1648→  public Connection getConnPublic() throws Exception {\n  1649→    return getConn();\n  1650→  }\n  1651→\n  1652→  /*\n  1653→   * Commit the provided connection if not under Global Transaction scope -\n  1654→   * conn.commit() is not allowed in a global transaction. the txn manager\n  1655→   * will perform the commit\n  1656→   */\n  1657→  private void commit(Connection conn) throws Exception {\n  1658→    if (!inSession) {\n  1659→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1660→        conn.commit();\n  1661→      }\n  1662→    }\n  1663→  }\n  1664→\n  1665→  /*\n  1666→   * Rollback the statement for the given connection\n  1667→   */\n  1668→  private void rollBack(Connection conn, Exception e) throws Exception {\n  1669→    if (!inSession) {\n  1670→      Log.log(\"TradeDirect:rollBack -- rolling back conn due to previously caught exception -- inGlobalTxn=\" + getInGlobalTxn());\n  1671→      if ((getInGlobalTxn() == false) && (conn != null)) {\n  1672→        conn.rollback();\n  1673→      } else {\n  1674→        throw e; // Throw the exception\n  1675→        // so the Global txn manager will rollBack\n  1676→      }\n  1677→    }\n  1678→  }\n  1679→\n  1680→  /*\n  1681→   * Allocate a new prepared statment for this connection\n  1682→   */\n  1683→  private PreparedStatement getStatement(Connection conn, String sql) throws Exception {\n  1684→    return conn.prepareStatement(sql);\n  1685→  }\n  1686→\n  1687→  private PreparedStatement getStatement(Connection conn, String sql, int type, int concurrency) throws Exception {\n  1688→    return conn.prepareStatement(sql, type, concurrency);\n  1689→  }\n  1690→\n  1691→  private static final String createQuoteSQL = \"insert into quoteejb \" + \"( symbol, companyName, volume, price, open1, low, high, change1 ) \"\n  1692→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1693→\n  1694→  private static final String createAccountSQL = \"insert into accountejb \"\n  1695→      + \"( accountid, creationDate, openBalance, balance, lastLogin, loginCount, logoutCount, profile_userid) \"\n  1696→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1697→\n  1698→  private static final String createAccountProfileSQL = \"insert into accountprofileejb \" + \"( userid, passwd, fullname, address, email, creditcard ) \"\n  1699→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  )\";\n  1700→\n  1701→  private static final String createHoldingSQL = \"insert into holdingejb \"\n  1702→      + \"( holdingid, purchaseDate, purchasePrice, quantity, quote_symbol, account_accountid ) \" + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ? )\";\n  1703→\n  1704→  private static final String createOrderSQL = \"insert into orderejb \"\n  1705→      + \"( orderid, ordertype, orderstatus, opendate, quantity, price, orderfee, account_accountid,  holding_holdingid, quote_symbol) \"\n  1706→      + \"VALUES (  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  ,  ?  , ? , ? , ?)\";\n  1707→\n  1708→  private static final String removeHoldingSQL = \"delete from holdingejb where holdingid = ?\";\n  1709→\n  1710→  private static final String removeHoldingFromOrderSQL = \"update orderejb set holding_holdingid=null where holding_holdingid = ?\";\n  1711→\n  1712→  private static final String updateAccountProfileSQL = \"update accountprofileejb set \" + \"passwd = ?, fullname = ?, address = ?, email = ?, creditcard = ? \"\n  1713→      + \"where userid = (select profile_userid from accountejb a \" + \"where a.profile_userid=?)\";\n  1714→\n  1715→  private static final String loginSQL = \"update accountejb set lastLogin=?, logincount=logincount+1 \" + \"where profile_userid=?\";\n  1716→\n  1717→  private static final String logoutSQL = \"update accountejb set logoutcount=logoutcount+1 \" + \"where profile_userid=?\";\n  1718→\n  1719→  private static final String getAccountSQL = \"select * from accountejb a where a.accountid = ?\";\n  1720→\n  1721→  private static final String getAccountProfileSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1722→      + \"(select profile_userid from accountejb a where a.profile_userid=?)\";\n  1723→\n  1724→  private static final String getAccountProfileForAccountSQL = \"select * from accountprofileejb ap where ap.userid = \"\n  1725→      + \"(select profile_userid from accountejb a where a.accountid=?)\";\n  1726→\n  1727→  private static final String getAccountForUserSQL = \"select * from accountejb a where a.profile_userid = \"\n  1728→      + \"( select userid from accountprofileejb ap where ap.userid = ?)\";\n  1729→\n  1730→  private static final String getHoldingSQL = \"select * from holdingejb h where h.holdingid = ?\";\n  1731→\n  1732→  private static final String getHoldingsForUserSQL = \"select * from holdingejb h where h.account_accountid = \"\n  1733→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1734→\n  1735→  private static final String getOrderSQL = \"select * from orderejb o where o.orderid = ?\";\n  1736→\n  1737→  private static final String getOrdersByUserSQL = \"select * from orderejb o where o.account_accountid = \"\n  1738→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1739→\n  1740→  private static final String getClosedOrdersSQL = \"select * from orderejb o \" + \"where o.orderstatus = 'closed' AND o.account_accountid = \"\n  1741→      + \"(select a.accountid from accountejb a where a.profile_userid = ?)\";\n  1742→\n  1743→  private static final String getQuoteSQL = \"select * from quoteejb q where q.symbol=?\";\n  1744→\n  1745→  private static final String getAllQuotesSQL = \"select * from quoteejb q\";\n  1746→\n  1747→  private static final String getQuoteForUpdateSQL = \"select * from quoteejb q where q.symbol=? For Update\";\n  1748→\n  1749→  private static final String getTSIAQuotesOrderByChangeSQL = \"select * from quoteejb q order by q.change1\";\n  1750→\n  1751→  private static final String getTSIASQL = \"select SUM(price)/count(*) as TSIA from quoteejb q \";\n  1752→\n  1753→  private static final String getOpenTSIASQL = \"select SUM(open1)/count(*) as openTSIA from quoteejb q \";\n  1754→\n  1755→  private static final String getTSIATotalVolumeSQL = \"select SUM(volume) as totalVolume from quoteejb q \";\n  1756→\n  1757→  private static final String creditAccountBalanceSQL = \"update accountejb set \" + \"balance = balance + ? \" + \"where accountid = ?\";\n  1758→\n  1759→  private static final String updateOrderStatusSQL = \"update orderejb set \" + \"orderstatus = ?, completiondate = ? \" + \"where orderid = ?\";\n  1760→\n  1761→  private static final String updateOrderHoldingSQL = \"update orderejb set \" + \"holding_holdingID = ? \" + \"where orderid = ?\";\n  1762→\n  1763→  private static final String updateQuotePriceVolumeSQL = \"update quoteejb set \" + \"price = ?, change1 = ?, volume = ? \" + \"where symbol = ?\";\n  1764→\n  1765→  /**\n  1766→   * Gets the inGlobalTxn\n  1767→   *\n  1768→   * @return Returns a boolean\n  1769→   */\n  1770→  private boolean getInGlobalTxn() {\n  1771→    return inGlobalTxn;\n  1772→  }\n  1773→\n  1774→  /**\n  1775→   * Sets the inGlobalTxn\n  1776→   *\n  1777→   * @param inGlobalTxn\n  1778→   *            The inGlobalTxn to set\n  1779→   */\n  1780→  private void setInGlobalTxn(boolean inGlobalTxn) {\n  1781→    this.inGlobalTxn = inGlobalTxn;\n  1782→  }\n  1783→  \n  1784→  public void setInSession(boolean inSession) {\n  1785→    this.inSession = inSession;\n  1786→  }\n  1787→\n  1788→  @Override\n  1789→  public int getImpl() {\n  1790→    return TradeConfig.DIRECT;\n  1791→  }\n  1792→\n  1793→\n  1794→\n  1795→  @Override\n  1796→  public QuoteDataBean pingTwoPhase(String symbol) {\n  1797→    throw new UnsupportedOperationException();\n  1798→  }\n  1799→\n  1800→\n  1801→\n  1802→  @Override\n  1803→  public double investmentReturn(double rnd1, double rnd2) {\n  1804→    throw new UnsupportedOperationException();\n  1805→  }   \n  1806→}\n  1807→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01JoEemWzH4ddq46J3MvUgrU","session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"0ecb54b4-63bf-455e-99ea-c31ba13a7e32"}
