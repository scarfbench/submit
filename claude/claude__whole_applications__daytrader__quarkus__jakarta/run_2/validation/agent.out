Bean;\n    35→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    36→import com.ibm.websphere.samples.daytrader.util.Log;\n    37→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    38→\n    39→/**\n    40→ * Populates the database with initial data on application startup.\n    41→ * Uses Bean-Managed Transactions to avoid issues with singleton PostConstruct\n    42→ * transaction rollback on Open Liberty.\n    43→ */\n    44→@Singleton\n    45→@Startup\n    46→@TransactionManagement(TransactionManagementType.BEAN)\n    47→public class DatabasePopulator {\n    48→\n    49→    @PersistenceContext(unitName = \"daytrader\")\n    50→    EntityManager em;\n    51→\n    52→    @Resource\n    53→    UserTransaction utx;\n    54→\n    55→    @Inject\n    56→    @ConfigProperty(name = \"trade.db.populate.on.startup\", defaultValue = \"true\")\n    57→    boolean populateOnStartup;\n    58→\n    59→    @Inject\n    60→    @ConfigProperty(name = \"trade.max.users\", defaultValue = \"50\")\n    61→    int maxUsers;\n    62→\n    63→    @Inject\n    64→    @ConfigProperty(name = \"trade.max.quotes\", defaultValue = \"100\")\n    65→    int maxQuotes;\n    66→\n    67→    @PostConstruct\n    68→    void onStart() {\n    69→        if (!populateOnStartup) {\n    70→            Log.log(\"Database population disabled via configuration\");\n    71→            return;\n    72→        }\n    73→\n    74→        // Check if database already has data\n    75→        try {\n    76→            utx.begin();\n    77→            Number quoteCount = (Number) em.createNativeQuery(\"SELECT COUNT(*) FROM quoteejb\").getSingleResult();\n    78→            utx.commit();\n    79→            if (quoteCount.longValue() > 0) {\n    80→                Log.log(\"Database already populated with \" + quoteCount + \" quotes. Skipping population.\");\n    81→                return;\n    82→            }\n    83→        } catch (Exception e) {\n    84→            // Table may not exist yet or other issue, try to rollback and proceed\n    85→            try { utx.rollback(); } catch (Exception re) { /* ignore */ }\n    86→            Log.log(\"Database tables may be newly created, proceeding with population...\");\n    87→        }\n    88→\n    89→        Log.log(\"TradeBuildDB: Populating DayTrader Database on startup...\");\n    90→\n    91→        try {\n    92→            utx.begin();\n    93→            populateQuotes();\n    94→            populateUsers();\n    95→            utx.commit();\n    96→            Log.log(\"TradeBuildDB: Database population complete!\");\n    97→        } catch (Exception e) {\n    98→            try { utx.rollback(); } catch (Exception re) { /* ignore */ }\n    99→            Log.error(e, \"TradeBuildDB: Error populating database\");\n   100→        }\n   101→    }\n   102→\n   103→    private void populateQuotes() {\n   104→        Log.log(\"TradeBuildDB: Creating \" + maxQuotes + \" Quotes...\");\n   105→\n   106→        for (int i = 0; i < maxQuotes; i++) {\n   107→            String symbol = \"s:\" + i;\n   108→            String companyName = \"S\" + i + \" Incorporated\";\n   109→            BigDecimal price = new BigDecimal(TradeConfig.rndPrice());\n   110→\n   111→            QuoteDataBean quote = new QuoteDataBean();\n   112→            quote.setSymbol(symbol);\n   113→            quote.setCompanyName(companyName);\n   114→            quote.setPrice(price);\n   115→            quote.setOpen(price);\n   116→            quote.setLow(price);\n   117→            quote.setHigh(price);\n   118→            quote.setChange(0.0);\n   119→            quote.setVolume(0.0);\n   120→\n   121→            em.persist(quote);\n   122→\n   123→            if (i % 10 == 0) {\n   124→                Log.log(\"Created quote: \" + symbol);\n   125→            }\n   126→        }\n   127→        em.flush();\n   128→    }\n   129→\n   130→    private void populateUsers() {\n   131→        Log.log(\"TradeBuildDB: Registering \" + maxUsers + \" Users...\");\n   132→\n   133→        for (int i = 0; i < maxUsers; i++) {\n   134→            String userID = \"uid:\" + i;\n   135→            String fullname = TradeConfig.rndFullName();\n   136→            String email = TradeConfig.rndEmail(userID);\n   137→            String address = TradeConfig.rndAddress();\n   138→            String creditcard = TradeConfig.rndCreditCard();\n   139→            BigDecimal initialBalance = new BigDecimal((double) (TradeConfig.rndInt(100000)) + 200000);\n   140→\n   141→            if (i == 0) {\n   142→                initialBalance = new BigDecimal(1000000);\n   143→            }\n   144→\n   145→            AccountProfileDataBean profile = new AccountProfileDataBean();\n   146→            profile.setUserID(userID);\n   147→            profile.setPassword(\"xxx\");\n   148→            profile.setFullName(fullname);\n   149→            profile.setAddress(address);\n   150→            profile.setEmail(email);\n   151→            profile.setCreditCard(creditcard);\n   152→            em.persist(profile);\n   153→\n   154→            AccountDataBean account = new AccountDataBean();\n   155→            account.setProfile(profile);\n   156→            account.setCreationDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   157→            account.setLastLogin(new java.sql.Timestamp(System.currentTimeMillis()));\n   158→            account.setBalance(initialBalance);\n   159→            account.setOpenBalance(initialBalance);\n   160→            account.setLoginCount(0);\n   161→            account.setLogoutCount(0);\n   162→            em.persist(account);\n   163→\n   164→            if (i % 10 == 0) {\n   165→                Log.log(\"Registered user: \" + userID + \" with balance: \" + initialBalance);\n   166→            }\n   167→        }\n   168→        em.flush();\n   169→    }\n   170→}\n   171→"}]},"parent_tool_use_id":null,"session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"0