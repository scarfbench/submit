R, \"\n   165→                + \"QUOTE_SYMBOL VARCHAR(255), \"\n   166→                + \"CONSTRAINT FK_HOLD_ACCT FOREIGN KEY (ACCOUNT_ACCOUNTID) REFERENCES accountejb(ACCOUNTID), \"\n   167→                + \"CONSTRAINT FK_HOLD_QUOTE FOREIGN KEY (QUOTE_SYMBOL) REFERENCES quoteejb(SYMBOL))\");\n   168→\n   169→            stmt.executeUpdate(\"CREATE TABLE IF NOT EXISTS orderejb (\"\n   170→                + \"ORDERID INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY, \"\n   171→                + \"ORDERTYPE VARCHAR(255), \"\n   172→                + \"ORDERSTATUS VARCHAR(255), \"\n   173→                + \"OPENDATE TIMESTAMP, \"\n   174→                + \"COMPLETIONDATE TIMESTAMP, \"\n   175→                + \"QUANTITY DOUBLE NOT NULL, \"\n   176→                + \"PRICE DECIMAL(14,2), \"\n   177→                + \"ORDERFEE DECIMAL(14,2), \"\n   178→                + \"ACCOUNT_ACCOUNTID INTEGER, \"\n   179→                + \"QUOTE_SYMBOL VARCHAR(255), \"\n   180→                + \"HOLDING_HOLDINGID INTEGER, \"\n   181→                + \"CONSTRAINT FK_ORD_ACCT FOREIGN KEY (ACCOUNT_ACCOUNTID) REFERENCES accountejb(ACCOUNTID), \"\n   182→                + \"CONSTRAINT FK_ORD_QUOTE FOREIGN KEY (QUOTE_SYMBOL) REFERENCES quoteejb(SYMBOL), \"\n   183→                + \"CONSTRAINT FK_ORD_HOLD FOREIGN KEY (HOLDING_HOLDINGID) REFERENCES holdingejb(HOLDINGID))\");\n   184→\n   185→            // Create keygenejb table for direct JDBC key generation\n   186→            stmt.executeUpdate(\"CREATE TABLE IF NOT EXISTS keygenejb (\"\n   187→                + \"KEYNAME VARCHAR(255) NOT NULL PRIMARY KEY, \"\n   188→                + \"KEYVAL INTEGER NOT NULL)\");\n   189→\n   190→            stmt.close();\n   191→            Log.log(\"TradeBuildDB: Database tables created successfully\");\n   192→        } catch (Exception e) {\n   193→            Log.error(e, \"TradeBuildDB: Error creating database tables\");\n   194→        }\n   195→    }\n   196→\n   197→    private void populateQuotes() {\n   198→        Log.log(\"TradeBuildDB: Creating \" + maxQuotes + \" Quotes...\");\n   199→\n   200→        for (int i = 0; i < maxQuotes; i++) {\n   201→            String symbol = \"s:\" + i;\n   202→            String companyName = \"S\" + i + \" Incorporated\";\n   203→            BigDecimal price = new BigDecimal(TradeConfig.rndPrice());\n   204→\n   205→            QuoteDataBean quote = new QuoteDataBean();\n   206→            quote.setSymbol(symbol);\n   207→            quote.setCompanyName(companyName);\n   208→            quote.setPrice(price);\n   209→            quote.setOpen(price);\n   210→            quote.setLow(price);\n   211→            quote.setHigh(price);\n   212→            quote.setChange(0.0);\n   213→            quote.setVolume(0.0);\n   214→\n   215→            em.persist(quote);\n   216→\n   217→            if (i % 10 == 0) {\n   218→                Log.log(\"Created quote: \" + symbol);\n   219→            }\n   220→        }\n   221→        em.flush();\n   222→    }\n   223→\n   224→    private void populateUsers() {\n   225→        Log.log(\"TradeBuildDB: Registering \" + maxUsers + \" Users...\");\n   226→\n   227→        for (int i = 0; i < maxUsers; i++) {\n   228→            String userID = \"uid:\" + i;\n   229→            String fullname = TradeConfig.rndFullName();\n   230→            String email = TradeConfig.rndEmail(userID);\n   231→            String address = TradeConfig.rndAddress();\n   232→            String creditcard = TradeConfig.rndCreditCard();\n   233→            BigDecimal initialBalance = new BigDecimal((double) (TradeConfig.rndInt(100000)) + 200000);\n   234→\n   235→            if (i == 0) {\n   236→                initialBalance = new BigDecimal(1000000);\n   237→            }\n   238→\n   239→            AccountProfileDataBean profile = new AccountProfileDataBean();\n   240→            profile.setUserID(userID);\n   241→            profile.setPassword(\"xxx\");\n   242→            profile.setFullName(fullname);\n   243→            profile.setAddress(address);\n   244→            profile.setEmail(email);\n   245→            profile.setCreditCard(creditcard);\n   246→            em.persist(profile);\n   247→\n   248→            AccountDataBean account = new AccountDataBean();\n   249→            account.setProfile(profile);\n   250→            account.setCreationDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   251→            account.setLastLogin(new java.sql.Timestamp(System.currentTimeMillis()));\n   252→            account.setBalance(initialBalance);\n   253→            account.setOpenBalance(initialBalance);\n   254→            account.setLoginCount(0);\n   255→            account.setLogoutCount(0);\n   256→            em.persist(account);\n   257→\n   258→            if (i % 10 == 0) {\n   259→                Log.log(\"Registered user: \" + userID + \" with balance: \" + initialBalance);\n   260→            }\n   261→        }\n   262→        em.flush();\n   263→    }\n   264→}\n   265→"}]},"parent_tool_use_id":null,"session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"9b384902-68a7-4778-9c27-81ec027f05c1"}
