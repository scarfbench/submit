{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_018q9gNv8KM7AFSsL5kL94xz","type":"tool_result","content":"     1→/**\n     2→ * (C) Copyright IBM Corporation 2015.\n     3→ *\n     4→ * Licensed under the Apache License, Version 2.0 (the \"License\");\n     5→ * you may not use this file except in compliance with the License.\n     6→ * You may obtain a copy of the License at\n     7→ *\n     8→ * http://www.apache.org/licenses/LICENSE-2.0\n     9→ *\n    10→ * Unless required by applicable law or agreed to in writing, software\n    11→ * distributed under the License is distributed on an \"AS IS\" BASIS,\n    12→ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n    13→ * See the License for the specific language governing permissions and\n    14→ * limitations under the License.\n    15→ */\n    16→package com.ibm.websphere.samples.daytrader.impl.ejb3;\n    17→\n    18→import java.math.BigDecimal;\n    19→import java.sql.Timestamp;\n    20→import java.util.Collection;\n    21→import java.util.Comparator;\n    22→import java.util.Iterator;\n    23→import java.util.List;\n    24→import java.util.concurrent.Future;\n    25→\n    26→// MIGRATION: javax.* -> jakarta.*\n    27→// MIGRATION: EJB annotations -> CDI + @Transactional\n    28→import jakarta.enterprise.context.ApplicationScoped;\n    29→import jakarta.inject.Inject;\n    30→import jakarta.persistence.EntityManager;\n    31→import jakarta.persistence.TypedQuery;\n    32→import jakarta.persistence.criteria.CriteriaBuilder;\n    33→import jakarta.persistence.criteria.CriteriaQuery;\n    34→import jakarta.persistence.criteria.Root;\n    35→import jakarta.transaction.RollbackException;\n    36→import jakarta.transaction.Transactional;\n    37→import jakarta.validation.constraints.NotNull;\n    38→\n    39→import com.ibm.websphere.samples.daytrader.interfaces.RuntimeMode;\n    40→import com.ibm.websphere.samples.daytrader.interfaces.Trace;\n    41→import com.ibm.websphere.samples.daytrader.interfaces.TradeEJB;\n    42→import com.ibm.websphere.samples.daytrader.interfaces.TradeServices;\n    43→import com.ibm.websphere.samples.daytrader.messaging.MessageProducerService;\n    44→import com.ibm.websphere.samples.daytrader.beans.MarketSummaryDataBean;\n    45→import com.ibm.websphere.samples.daytrader.entities.AccountDataBean;\n    46→import com.ibm.websphere.samples.daytrader.entities.AccountProfileDataBean;\n    47→import com.ibm.websphere.samples.daytrader.entities.HoldingDataBean;\n    48→import com.ibm.websphere.samples.daytrader.entities.OrderDataBean;\n    49→import com.ibm.websphere.samples.daytrader.entities.QuoteDataBean;\n    50→import com.ibm.websphere.samples.daytrader.util.FinancialUtils;\n    51→import com.ibm.websphere.samples.daytrader.util.Log;\n    52→import com.ibm.websphere.samples.daytrader.util.RecentQuotePriceChangeList;\n    53→import com.ibm.websphere.samples.daytrader.util.TradeConfig;\n    54→\n    55→import jakarta.enterprise.inject.Default;\n    56→\n    57→// MIGRATION: @Stateless -> @ApplicationScoped\n    58→// MIGRATION: @TransactionAttribute(REQUIRED) -> @Transactional\n    59→// MIGRATION: @TransactionManagement removed (CDI uses declarative transactions)\n    60→// This is the default/primary TradeServices implementation\n    61→// @Default added explicitly since custom qualifiers remove implicit @Default\n    62→@ApplicationScoped\n    63→@Default\n    64→@TradeEJB\n    65→@RuntimeMode(\"Full EJB3\")\n    66→@Trace\n    67→@Transactional\n    68→public class TradeSLSBBean implements TradeServices {\n    69→\n    70→    // MIGRATION: JMS resources replaced with MessageProducerService\n    71→    @Inject\n    72→    MessageProducerService messageProducer;\n    73→\n    74→    @Inject\n    75→    EntityManager entityManager;\n    76→\n    77→    // MIGRATION: @EJB -> @Inject\n    78→    @Inject\n    79→    MarketSummarySingleton marketSummarySingleton;\n    80→\n    81→    @Inject \n    82→    AsyncScheduledOrderSubmitter asyncEJBOrderSubmitter;\n    83→\n    84→    @Inject\n    85→    RecentQuotePriceChangeList recentQuotePriceChangeList;\n    86→\n    87→    @Override\n    88→    public MarketSummaryDataBean getMarketSummary() {\n    89→        return marketSummarySingleton.getMarketSummaryDataBean();\n    90→    }\n    91→\n    92→    @Override\n    93→    @NotNull\n    94→    public OrderDataBean buy(String userID, String symbol, double quantity, int orderProcessingMode) {\n    95→        OrderDataBean order = null;\n    96→        BigDecimal total;\n    97→        try {\n    98→\n    99→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   100→            AccountDataBean account = profile.getAccount();\n   101→            QuoteDataBean quote = entityManager.find(QuoteDataBean.class, symbol);\n   102→            HoldingDataBean holding = null; // The holding will be created by\n   103→            // this buy order\n   104→\n   105→            order = createOrder(account, quote, holding, \"buy\", quantity);\n   106→ \n   107→            // UPDATE - account should be credited during completeOrder\n   108→            BigDecimal price = quote.getPrice();\n   109→            BigDecimal orderFee = order.getOrderFee();\n   110→            BigDecimal balance = account.getBalance();\n   111→            total = (new BigDecimal(quantity).multiply(price)).add(orderFee);\n   112→            account.setBalance(balance.subtract(total));\n   113→            final Integer orderID=order.getOrderID();\n   114→\n   115→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   116→              completeOrder(orderID, false);\n   117→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   118→              completeOrderAsync(orderID, false);\n   119→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   120→              queueOrder(orderID, true);\n   121→            }\n   122→        } catch (Exception e) {\n   123→            Log.error(\"TradeSLSBBean:buy(\" + userID + \",\" + symbol + \",\" + quantity + \") --> failed\", e);\n   124→            /* On exception - cancel the order */\n   125→            // TODO figure out how to do this with JPA\n   126→            // if (order != null) order.cancel();\n   127→            throw new RuntimeException(e);\n   128→        }\n   129→        return order;\n   130→    }\n   131→\n   132→    @Override\n   133→    @NotNull\n   134→    public OrderDataBean sell(final String userID, final Integer holdingID, int orderProcessingMode) {\n   135→        OrderDataBean order=null;\n   136→        BigDecimal total;\n   137→        try {\n   138→            AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   139→            AccountDataBean account = profile.getAccount();\n   140→\n   141→            HoldingDataBean holding = entityManager.find(HoldingDataBean.class, holdingID);\n   142→\n   143→            if (holding == null) {\n   144→                Log.debug(\"TradeSLSBBean:sell User \" + userID + \" attempted to sell holding \" + holdingID + \" which has already been sold\");\n   145→\n   146→                OrderDataBean orderData = new OrderDataBean();\n   147→                orderData.setOrderStatus(\"cancelled\");\n   148→                entityManager.persist(orderData);\n   149→\n   150→                return orderData;\n   151→            }\n   152→\n   153→            QuoteDataBean quote = holding.getQuote();\n   154→            double quantity = holding.getQuantity();\n   155→\n   156→            order = createOrder(account, quote, holding, \"sell\", quantity);\n   157→\n   158→            // UPDATE the holding purchase data to signify this holding is\n   159→            // \"inflight\" to be sold\n   160→            // -- could add a new holdingStatus attribute to holdingEJB\n   161→            holding.setPurchaseDate(new java.sql.Timestamp(0));\n   162→\n   163→            // UPDATE - account should be credited during completeOrder\n   164→            BigDecimal price = quote.getPrice();\n   165→            BigDecimal orderFee = order.getOrderFee();\n   166→            BigDecimal balance = account.getBalance();\n   167→            total = (new BigDecimal(quantity).multiply(price)).subtract(orderFee);\n   168→            account.setBalance(balance.add(total));\n   169→            final Integer orderID=order.getOrderID(); \n   170→\n   171→            if (orderProcessingMode == TradeConfig.SYNCH) {\n   172→                completeOrder(orderID, false);\n   173→            } else if (orderProcessingMode == TradeConfig.ASYNCH) {\n   174→                completeOrderAsync(orderID, false);\n   175→            } else if (orderProcessingMode == TradeConfig.ASYNCH_2PHASE) {\n   176→                queueOrder(orderID, true);\n   177→            }\n   178→\n   179→        } catch (Exception e) {\n   180→            Log.error(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \") --> failed\", e);\n   181→            // if (order != null) order.cancel();\n   182→            // UPDATE - handle all exceptions like:\n   183→            // MIGRATION: RuntimeException -> RuntimeException\n   184→            throw new RuntimeException(\"TradeSLSBBean:sell(\" + userID + \",\" + holdingID + \")\", e);\n   185→        }\n   186→        return order;\n   187→    }\n   188→\n   189→    public void queueOrder(Integer orderID, boolean twoPhase) {\n   190→        // MIGRATION: JMS -> MessageProducerService\n   191→        messageProducer.queueOrderForProcessing(orderID, twoPhase);\n   192→    }\n   193→\n   194→    @Override\n   195→    public OrderDataBean completeOrder(Integer orderID, boolean twoPhase) throws Exception {\n   196→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   197→\n   198→        if (order == null) {\n   199→          System.out.println(\"error\");\n   200→            // MIGRATION: RuntimeException -> RuntimeException\n   201→            throw new RuntimeException(\"Error: attempt to complete Order that is null\\n\" + order);\n   202→        }\n   203→\n   204→        order.getQuote();\n   205→\n   206→        if (order.isCompleted()) {\n   207→            throw new RuntimeException(\"Error: attempt to complete Order that is already completed\\n\" + order);\n   208→        }\n   209→\n   210→        AccountDataBean account = order.getAccount();\n   211→        QuoteDataBean quote = order.getQuote();\n   212→        HoldingDataBean holding = order.getHolding();\n   213→        BigDecimal price = order.getPrice();\n   214→        double quantity = order.getQuantity();\n   215→\n   216→        if (order.isBuy()) {\n   217→            /*\n   218→             * Complete a Buy operation - create a new Holding for the Account -\n   219→             * deduct the Order cost from the Account balance\n   220→             */\n   221→\n   222→            HoldingDataBean newHolding = createHolding(account, quote, quantity, price);\n   223→            order.setHolding(newHolding);\n   224→            order.setOrderStatus(\"closed\");\n   225→            order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   226→            updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   227→        }\n   228→\n   229→        if (order.isSell()) {\n   230→            /*\n   231→             * Complete a Sell operation - remove the Holding from the Account -\n   232→             * deposit the Order proceeds to the Account balance\n   233→             */\n   234→            if (holding == null) {\n   235→                Log.debug(\"TradeSLSBBean:completeOrder -- Unable to sell order \" + order.getOrderID() + \" holding already sold\");\n   236→                order.cancel();\n   237→                //throw new RuntimeException(\"TradeSLSBBean:completeOrder -- Unable to sell order \" + order.getOrderID() + \" holding already sold\");\n   238→            } else {\n   239→                entityManager.remove(holding);\n   240→                order.setHolding(null);\n   241→                order.setOrderStatus(\"closed\");\n   242→                order.setCompletionDate(new java.sql.Timestamp(System.currentTimeMillis()));\n   243→                updateQuotePriceVolume(quote.getSymbol(), TradeConfig.getRandomPriceChangeFactor(), quantity);\n   244→            }\n   245→        } \n   246→\n   247→        Log.trace(\"TradeSLSBBean:completeOrder--> Completed Order \" + order.getOrderID() + \"\\n\\t Order info: \" + order + \"\\n\\t Account info: \" + account\n   248→            + \"\\n\\t Quote info: \" + quote + \"\\n\\t Holding info: \" + holding);\n   249→\n   250→        return order;\n   251→    }\n   252→\n   253→    @Override\n   254→    public Future<OrderDataBean> completeOrderAsync(Integer orderID, boolean twoPhase) throws Exception {\n   255→      asyncEJBOrderSubmitter.submitOrder(orderID, twoPhase);\n   256→      return null;\n   257→    }\n   258→\n   259→    @Override\n   260→    public void cancelOrder(Integer orderID, boolean twoPhase) {\n   261→        OrderDataBean order = entityManager.find(OrderDataBean.class, orderID);\n   262→        order.cancel();\n   263→    }\n   264→\n   265→    @Override\n   266→    public void orderCompleted(String userID, Integer orderID) {\n   267→        throw new UnsupportedOperationException(\"TradeSLSBBean:orderCompleted method not supported\");\n   268→    }\n   269→\n   270→    @Override\n   271→    public Collection<OrderDataBean> getOrders(String userID) {\n   272→        // Use a JPQL query to eagerly fetch orders for the user\n   273→        // This avoids lazy loading issues when returning the collection\n   274→        TypedQuery<OrderDataBean> query = entityManager.createQuery(\n   275→            \"SELECT o FROM orderejb o WHERE o.account.profile.userID = :userID ORDER BY o.openDate DESC\",\n   276→            OrderDataBean.class);\n   277→        query.setParameter(\"userID\", userID);\n   278→        return query.getResultList();\n   279→    }\n   280→\n   281→    @Override\n   282→    public Collection<OrderDataBean> getClosedOrders(String userID) {\n   283→\n   284→        try {\n   285→            /* I want to do a CriteriaUpdate here, but there are issues with JBoss/Hibernate */\n   286→            CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   287→            CriteriaQuery<OrderDataBean> criteriaQuery = criteriaBuilder.createQuery(OrderDataBean.class);\n   288→            Root<OrderDataBean> orders = criteriaQuery.from(OrderDataBean.class);\n   289→            criteriaQuery.select(orders);\n   290→            criteriaQuery.where(\n   291→                    criteriaBuilder.equal(orders.get(\"orderStatus\"), \n   292→                            criteriaBuilder.parameter(String.class, \"p_status\")), \n   293→                    criteriaBuilder.equal(orders.get(\"account\").get(\"profile\").get(\"userID\"), \n   294→                            criteriaBuilder.parameter(String.class, \"p_userid\")));\n   295→\n   296→            TypedQuery<OrderDataBean> q = entityManager.createQuery(criteriaQuery);\n   297→            q.setParameter(\"p_status\", \"closed\");\n   298→            q.setParameter(\"p_userid\", userID);\n   299→            List<OrderDataBean> results = q.getResultList();\n   300→\n   301→            Iterator<OrderDataBean> itr = results.iterator();\n   302→            // Spin through the orders to remove or mark completed\n   303→            while (itr.hasNext()) {\n   304→                OrderDataBean order = itr.next();\n   305→                // TODO: Investigate ConncurrentModification Exceptions\n   306→                if (TradeConfig.getLongRun()) {\n   307→                    //Added this for Longruns (to prevent orderejb growth)\n   308→                    entityManager.remove(order); \n   309→                }\n   310→                else {\n   311→                    order.setOrderStatus(\"completed\");\n   312→                }\n   313→            }\n   314→\n   315→            return results;\n   316→        } catch (Exception e) {\n   317→            Log.error(\"TradeSLSBBean.getClosedOrders\", e);\n   318→            throw new RuntimeException(\"TradeSLSBBean.getClosedOrders - error\", e);\n   319→        }\n   320→    }\n   321→\n   322→    @Override\n   323→    public QuoteDataBean createQuote(String symbol, String companyName, BigDecimal price) {\n   324→        try {\n   325→            QuoteDataBean quote = new QuoteDataBean(symbol, companyName, 0, price, price, price, price, 0);\n   326→            entityManager.persist(quote);\n   327→\n   328→            Log.trace(\"TradeSLSBBean:createQuote-->\" + quote);\n   329→\n   330→            return quote;\n   331→        } catch (Exception e) {\n   332→            Log.error(\"TradeSLSBBean:createQuote -- exception creating Quote\", e);\n   333→            throw new RuntimeException(e);\n   334→        }\n   335→    }\n   336→\n   337→    @Override\n   338→    public QuoteDataBean getQuote(String symbol) {\n   339→        return entityManager.find(QuoteDataBean.class, symbol);\n   340→    }\n   341→\n   342→    @Override\n   343→    public Collection<QuoteDataBean> getAllQuotes() {\n   344→        TypedQuery<QuoteDataBean> query = entityManager.createNamedQuery(\"quoteejb.allQuotes\", QuoteDataBean.class);\n   345→        return query.getResultList();\n   346→    }\n   347→\n   348→    @Override\n   349→    public QuoteDataBean updateQuotePriceVolume(String symbol, BigDecimal changeFactor, double sharesTraded) {\n   350→        if (!TradeConfig.getUpdateQuotePrices()) {\n   351→            return new QuoteDataBean();\n   352→        }\n   353→\n   354→        Log.trace(\"TradeSLSBBean:updateQuote\", symbol, changeFactor);\n   355→\n   356→        TypedQuery<QuoteDataBean> q = entityManager.createNamedQuery(\"quoteejb.quoteForUpdate\", QuoteDataBean.class);\n   357→        q.setParameter(1, symbol);\n   358→        QuoteDataBean quote = q.getSingleResult();\n   359→\n   360→        BigDecimal oldPrice = quote.getPrice();\n   361→        BigDecimal openPrice = quote.getOpen();\n   362→\n   363→        if (oldPrice.equals(TradeConfig.PENNY_STOCK_PRICE)) {\n   364→            changeFactor = TradeConfig.PENNY_STOCK_RECOVERY_MIRACLE_MULTIPLIER;\n   365→        } else if (oldPrice.compareTo(TradeConfig.MAXIMUM_STOCK_PRICE) > 0) {\n   366→            changeFactor = TradeConfig.MAXIMUM_STOCK_SPLIT_MULTIPLIER;\n   367→        }\n   368→\n   369→        BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   370→\n   371→        quote.setPrice(newPrice);\n   372→        quote.setChange(newPrice.subtract(openPrice).doubleValue());\n   373→        quote.setVolume(quote.getVolume() + sharesTraded);\n   374→        entityManager.merge(quote);\n   375→\n   376→        if (TradeConfig.getPublishQuotePriceChange()) {\n   377→          publishQuotePriceChange(quote, oldPrice, changeFactor, sharesTraded);\n   378→        }\n   379→\n   380→        recentQuotePriceChangeList.add(quote);\n   381→\n   382→        return quote;\n   383→    }\n   384→\n   385→    @Override\n   386→    public Collection<@NotNull HoldingDataBean> getHoldings(String userID) {\n   387→        CriteriaBuilder criteriaBuilder = entityManager.getCriteriaBuilder();\n   388→        CriteriaQuery<HoldingDataBean> criteriaQuery = criteriaBuilder.createQuery(HoldingDataBean.class);\n   389→        Root<HoldingDataBean> holdings = criteriaQuery.from(HoldingDataBean.class);\n   390→        criteriaQuery.where(\n   391→                criteriaBuilder.equal(holdings.get(\"account\").get(\"profile\").get(\"userID\"), \n   392→                        criteriaBuilder.parameter(String.class, \"p_userid\")));\n   393→        criteriaQuery.select(holdings);\n   394→\n   395→        TypedQuery<HoldingDataBean> typedQuery = entityManager.createQuery(criteriaQuery);\n   396→        typedQuery.setParameter(\"p_userid\", userID);\n   397→        return typedQuery.getResultList();\n   398→    }\n   399→\n   400→    @Override\n   401→    public HoldingDataBean getHolding(Integer holdingID) {\n   402→      return entityManager.find(HoldingDataBean.class, holdingID);\n   403→    }\n   404→\n   405→    @Override\n   406→    public AccountDataBean getAccountData(String userID) {\n   407→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   408→        AccountDataBean account = profile.getAccount();\n   409→\n   410→        // Added to populate transient field for account\n   411→        account.setProfileID(profile.getUserID());\n   412→\n   413→        return account;\n   414→    }\n   415→\n   416→    @Override\n   417→    public AccountProfileDataBean getAccountProfileData(String userID) {\n   418→        return entityManager.find(AccountProfileDataBean.class, userID);\n   419→    }\n   420→\n   421→    @Override\n   422→    public AccountProfileDataBean updateAccountProfile(AccountProfileDataBean profileData) {\n   423→        AccountProfileDataBean temp = entityManager.find(AccountProfileDataBean.class, profileData.getUserID());\n   424→        temp.setAddress(profileData.getAddress());\n   425→        temp.setPassword(profileData.getPassword());\n   426→        temp.setFullName(profileData.getFullName());\n   427→        temp.setCreditCard(profileData.getCreditCard());\n   428→        temp.setEmail(profileData.getEmail());\n   429→\n   430→        entityManager.merge(temp);\n   431→\n   432→        return temp;\n   433→    }\n   434→\n   435→    @Override\n   436→    public AccountDataBean login(String userID, String password) throws RollbackException {\n   437→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   438→        if (profile == null) {\n   439→            throw new RuntimeException(\"No such user: \" + userID);\n   440→        }\n   441→\n   442→        AccountDataBean account = profile.getAccount();\n   443→        account.login(password);\n   444→\n   445→        Log.trace(\"TradeSLSBBean:login(\" + userID + \",\" + password + \") success\" + account);\n   446→\n   447→        return account;\n   448→    }\n   449→\n   450→    @Override\n   451→    public void logout(String userID) {\n   452→        AccountProfileDataBean profile = entityManager.find(AccountProfileDataBean.class, userID);\n   453→        AccountDataBean account = profile.getAccount();\n   454→        account.logout();\n   455→\n   456→        Log.trace(\"TradeSLSBBean:logout(\" + userID + \") success\");\n   457→    }\n   458→\n   459→    @Override\n   460→    public AccountDataBean register(String userID, String password, String fullname, String address, String email, String creditcard, BigDecimal openBalance) {\n   461→        AccountDataBean account = null;\n   462→        AccountProfileDataBean profile = null;\n   463→\n   464→        // Check to see if a profile with the desired userID already exists\n   465→        profile = entityManager.find(AccountProfileDataBean.class, userID);\n   466→\n   467→        if (profile != null) {\n   468→            Log.error(\"Failed to register new Account - AccountProfile with userID(\" + userID + \") already exists\");\n   469→            return null;\n   470→        } else {\n   471→            profile = new AccountProfileDataBean(userID, password, fullname, address, email, creditcard);\n   472→            account = new AccountDataBean(0, 0, null, new Timestamp(System.currentTimeMillis()), openBalance, openBalance, userID);\n   473→\n   474→            profile.setAccount(account);\n   475→            account.setProfile(profile);\n   476→\n   477→            entityManager.persist(profile);\n   478→            entityManager.persist(account);\n   479→        }\n   480→\n   481→        return account;\n   482→    }\n   483→\n   484→    // MIGRATION: @TransactionAttribute(REQUIRES_NEW) -> @Transactional(REQUIRES_NEW)\n   485→    @Transactional(Transactional.TxType.REQUIRES_NEW)\n   486→    public void publishQuotePriceChange(QuoteDataBean quote, BigDecimal oldPrice, BigDecimal changeFactor, double sharesTraded) {\n   487→        if (!TradeConfig.getPublishQuotePriceChange()) {\n   488→            return;\n   489→        }\n   490→\n   491→        // MIGRATION: JMS Topic -> MessageProducerService\n   492→        messageProducer.publishQuotePriceChange(\n   493→            quote.getSymbol(),\n   494→            quote.getCompanyName(),\n   495→            quote.getPrice(),\n   496→            oldPrice,\n   497→            quote.getOpen(),\n   498→            quote.getLow(),\n   499→            quote.getHigh(),\n   500→            quote.getVolume(),\n   501→            changeFactor,\n   502→            sharesTraded\n   503→        );\n   504→    }\n   505→\n   506→    public OrderDataBean createOrder(AccountDataBean account, QuoteDataBean quote, HoldingDataBean holding, String orderType, double quantity) {\n   507→        OrderDataBean order;\n   508→\n   509→        try {\n   510→            order = new OrderDataBean(orderType, \"open\", new Timestamp(System.currentTimeMillis()), null, quantity, quote.getPrice().setScale(\n   511→                    FinancialUtils.SCALE, FinancialUtils.ROUND), TradeConfig.getOrderFee(orderType), account, quote, holding);\n   512→            entityManager.persist(order);\n   513→        } catch (Exception e) {\n   514→            Log.error(\"TradeSLSBBean:createOrder -- failed to create Order. The stock/quote may not exist in the database.\", e);\n   515→            throw new RuntimeException(\"TradeSLSBBean:createOrder -- failed to create Order. Check that the symbol exists in the database.\", e);\n   516→        }\n   517→        return order;\n   518→    }\n   519→\n   520→    private HoldingDataBean createHolding(AccountDataBean account, QuoteDataBean quote, double quantity, BigDecimal purchasePrice) throws Exception {\n   521→        HoldingDataBean newHolding = new HoldingDataBean(quantity, purchasePrice, new Timestamp(System.currentTimeMillis()), account, quote);\n   522→        entityManager.persist(newHolding);\n   523→        return newHolding;\n   524→    }\n   525→\n   526→    @Override\n   527→    public double investmentReturn(double investment, double NetValue) throws Exception {\n   528→        double diff = NetValue - investment;\n   529→        double ir = diff / investment;\n   530→        return ir;\n   531→    }\n   532→\n   533→    @Override\n   534→    public QuoteDataBean pingTwoPhase(String symbol) throws Exception {\n   535→        QuoteDataBean quoteData = null;\n   536→\n   537→        try {\n   538→            // Get a Quote and send a message in a 2-phase commit\n   539→            // MIGRATION: JMS -> MessageProducerService\n   540→            quoteData = entityManager.find(QuoteDataBean.class, symbol);\n   541→            \n   542→            double sharesTraded = (Math.random() * 100) + 1 ;\n   543→            BigDecimal oldPrice = quoteData.getPrice();\n   544→            BigDecimal openPrice = quoteData.getOpen();\n   545→            BigDecimal changeFactor = new BigDecimal (Math.random() * 100);\n   546→\n   547→            BigDecimal newPrice = changeFactor.multiply(oldPrice).setScale(2, BigDecimal.ROUND_HALF_UP);\n   548→\n   549→            quoteData.setPrice(newPrice);\n   550→            quoteData.setChange(newPrice.subtract(openPrice).doubleValue());\n   551→            quoteData.setVolume(quoteData.getVolume() + sharesTraded);\n   552→            entityManager.merge(quoteData);\n   553→\n   554→            messageProducer.sendBrokerPing(\"Ping message sent from TradeSLSBBean:pingTwoPhase at \" + new java.util.Date());\n   555→        } catch (Exception e) {\n   556→            Log.error(\"TradeSLSBBean:pingTwoPhase -- exception caught\", e);\n   557→        }\n   558→\n   559→        return quoteData;\n   560→    }\n   561→\n   562→    class quotePriceComparator implements Comparator<QuoteDataBean> {\n   563→        @Override\n   564→        public int compare(QuoteDataBean quote1, QuoteDataBean quote2) {\n   565→            double change1 = quote1.getChange();\n   566→            double change2 = quote2.getChange();\n   567→            return new Double(change2).compareTo(change1);\n   568→        }\n   569→    }\n   570→\n   571→    @Override\n   572→    public int getImpl() {\n   573→      return TradeConfig.EJB3;\n   574→    }\n   575→\n   576→    @Override\n   577→    public void setInSession(boolean inSession) {\n   578→      throw new UnsupportedOperationException(\"TradeSLSBBean::setInGlobalTxn not supported\");\n   579→    }\n   580→}\n   581→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01YNn66n2h4yBgnSbLqJ6KDJ","session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"fa0b1b80-2602-4428-bf2f-931add203f0e"}
