il.TimerStat;\n    34→\n    35→@TransactionAttribute(TransactionAttributeType.REQUIRED)\n    36→@TransactionManagement(TransactionManagementType.CONTAINER)\n    37→@MessageDriven(activationConfig = {\n    38→    @ActivationConfigProperty(propertyName = \"destinationType\", propertyValue = \"jakarta.jms.Queue\"),\n    39→    @ActivationConfigProperty(propertyName = \"destination\", propertyValue = \"TradeBrokerQueue\"),\n    40→    @ActivationConfigProperty(propertyName = \"acknowledgeMode\", propertyValue = \"Auto-acknowledge\")\n    41→})\n    42→public class DTBroker3MDB implements MessageListener {\n    43→\n    44→    private final MDBStats mdbStats;\n    45→    private int statInterval = 10000;\n    46→\n    47→    @Inject\n    48→    TradeServices trade;\n    49→\n    50→    public DTBroker3MDB() {\n    51→        if (statInterval <= 0) {\n    52→            statInterval = 10000;\n    53→        }\n    54→        mdbStats = MDBStats.getInstance();\n    55→    }\n    56→\n    57→    @PostConstruct\n    58→    void init() {\n    59→        Log.trace(\"DTBroker3MDB:init()\");\n    60→    }\n    61→\n    62→    @Override\n    63→    public void onMessage(Message message) {\n    64→        try {\n    65→            TextMessage textMessage = (TextMessage) message;\n    66→            String command = textMessage.getStringProperty(\"command\");\n    67→\n    68→            Log.trace(\"TradeBroker:onMessage -- received message -->\" + textMessage.getText() + \"command-->\"\n    69→                + command + \"<--\");\n    70→\n    71→            if (command == null) {\n    72→                Log.debug(\"DTBroker3MDB:onMessage -- received message with null command. Message-->\" + message);\n    73→                return;\n    74→            }\n    75→            if (command.equalsIgnoreCase(\"neworder\")) {\n    76→                int orderID = textMessage.getIntProperty(\"orderID\");\n    77→                boolean twoPhase = textMessage.getBooleanProperty(\"twoPhase\");\n    78→                long publishTime = textMessage.getLongProperty(\"publishTime\");\n    79→                long receiveTime = System.currentTimeMillis();\n    80→\n    81→                try {\n    82→                    Log.trace(\"DTBroker3MDB:onMessage - completing order \" + orderID + \" twoPhase=\" + twoPhase);\n    83→                    trade.completeOrder(orderID, twoPhase);\n    84→\n    85→                    TimerStat currentStats = mdbStats.addTiming(\"DTBroker3MDB:neworder\", publishTime, receiveTime);\n    86→                    if ((currentStats.getCount() % statInterval) == 0) {\n    87→                        Log.log(\" DTBroker3MDB: processed \" + statInterval + \" stock trading orders.\" +\n    88→                            \" Total NewOrders process = \" + currentStats.getCount() +\n    89→                            \"Time (in seconds):\" +\n    90→                            \" min: \" + currentStats.getMinSecs() +\n    91→                            \" max: \" + currentStats.getMaxSecs() +\n    92→                            \" avg: \" + currentStats.getAvgSecs());\n    93→                    }\n    94→                } catch (Exception e) {\n    95→                    Log.error(\"DTBroker3MDB:onMessage Exception completing order: \" + orderID + \"\\n\", e);\n    96→                    throw new RuntimeException(\"Failed to complete order: \" + orderID, e);\n    97→                }\n    98→            } else if (command.equalsIgnoreCase(\"ping\")) {\n    99→                Log.trace(\"DTBroker3MDB:onMessage  received test command -- message: \" + textMessage.getText());\n   100→\n   101→                long publishTime = textMessage.getLongProperty(\"publishTime\");\n   102→                long receiveTime = System.currentTimeMillis();\n   103→                TimerStat currentStats = mdbStats.addTiming(\"DTBroker3MDB:ping\", publishTime, receiveTime);\n   104→\n   105→                if ((currentStats.getCount() % statInterval) == 0) {\n   106→                    Log.log(\" DTBroker3MDB: received \" + statInterval + \" ping messages.\" +\n   107→                        \" Total ping message count = \" + currentStats.getCount() +\n   108→                        \" Time (in seconds):\" +\n   109→                        \" min: \" + currentStats.getMinSecs() +\n   110→                        \" max: \" + currentStats.getMaxSecs() +\n   111→                        \" avg: \" + currentStats.getAvgSecs());\n   112→                }\n   113→            } else {\n   114→                Log.error(\"DTBroker3MDB:onMessage - unknown message request command-->\" + command + \"<-- message=\" + textMessage.getText());\n   115→            }\n   116→        } catch (Throwable t) {\n   117→            Log.error(\"DTBroker3MDB: Exception\", t);\n   118→            throw new RuntimeException(\"DTBroker3MDB processing failed\", t);\n   119→        }\n   120→    }\n   121→}\n   122→"}]},"parent_tool_use_id":"toolu_bdrk_01VqvkxmvUkofoFyHWh8LAue","session_id":"cc4c4d58-9b0e-47fb-9764-ecee6ff08c39","uuid":"ee3712bb-a7cd-4ab2-abcf-871481ec7670"}
