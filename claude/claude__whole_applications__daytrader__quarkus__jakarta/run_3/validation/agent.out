igDecimal(TradeConfig.rndPrice());\n    82→\n    83→            QuoteDataBean quote = new QuoteDataBean();\n    84→            quote.setSymbol(symbol);\n    85→            quote.setCompanyName(companyName);\n    86→            quote.setPrice(price);\n    87→            quote.setOpen(price);\n    88→            quote.setLow(price);\n    89→            quote.setHigh(price);\n    90→            quote.setChange(0.0);\n    91→            quote.setVolume(0.0);\n    92→\n    93→            em.persist(quote);\n    94→\n    95→            if (i % 10 == 0) {\n    96→                Log.log(\"Created quote: \" + symbol);\n    97→            }\n    98→        }\n    99→        em.flush();\n   100→    }\n   101→\n   102→    private void populateUsers() {\n   103→        Log.log(\"TradeBuildDB: Registering \" + maxUsers + \" Users...\");\n   104→\n   105→        for (int i = 0; i < maxUsers; i++) {\n   106→            String userID = \"uid:\" + i;\n   107→            String fullname = TradeConfig.rndFullName();\n   108→            String email = TradeConfig.rndEmail(userID);\n   109→            String address = TradeConfig.rndAddress();\n   110→            String creditcard = TradeConfig.rndCreditCard();\n   111→            BigDecimal initialBalance = new BigDecimal((double) (TradeConfig.rndInt(100000)) + 200000);\n   112→\n   113→            if (i == 0) {\n   114→                initialBalance = new BigDecimal(1000000);\n   115→            }\n   116→\n   117→            AccountProfileDataBean profile = new AccountProfileDataBean();\n   118→            profile.setUserID(userID);\n   119→            profile.setPassword(\"xxx\");\n   120→            profile.setFullName(fullname);\n   121→            profile.setAddress(address);\n   122→            profile.setEmail(email);\n   123→            profile.setCreditCard(creditcard);\n   124→            em.persist(profile);\n   125→\n   126→            AccountDataBean account = new AccountDataBean();\n   127→            account.setProfile(