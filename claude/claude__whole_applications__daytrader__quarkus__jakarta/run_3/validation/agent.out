      criteriaQuery.orderBy(criteriaBuilder.desc(quoteRoot.get(\"change1\")));\n    84→      criteriaQuery.select(quoteRoot);\n    85→      TypedQuery<QuoteDataBean> q = entityManager.createQuery(criteriaQuery);\n    86→      quotes = q.getResultList();\n    87→    } catch (Exception e) {\n    88→      Log.debug(\"Warning: The database has not been configured.\");\n    89→      return;\n    90→    }\n    91→\n    92→    QuoteDataBean[] quoteArray = quotes.toArray(new QuoteDataBean[quotes.size()]);\n    93→    ArrayList<QuoteDataBean> topGainers = new ArrayList<QuoteDataBean>(5);\n    94→    ArrayList<QuoteDataBean> topLosers = new ArrayList<QuoteDataBean>(5);\n    95→    BigDecimal TSIA = FinancialUtils.ZERO;\n    96→    BigDecimal openTSIA = FinancialUtils.ZERO;\n    97→    double totalVolume = 0.0;\n    98→\n    99→    if (quoteArray.length > 5) {\n   100→      for (int i = 0; i < 5; i++) {\n   101→        topGainers.add(quoteArray[i]);\n   102→      }\n   103→      for (int i = quoteArray.length - 1; i >= quoteArray.length - 5; i--) {\n   104→        topLosers.add(quoteArray[i]);\n   105→      }\n   106→\n   107→      for (QuoteDataBean quote : quoteArray) {\n   108→        BigDecimal price = quote.getPrice();\n   109→        BigDecimal open = quote.getOpen();\n   110→        double volume = quote.getVolume();\n   111→        TSIA = TSIA.add(price);\n   112→        openTSIA = openTSIA.add(open);\n   113→        totalVolume += volume;\n   114→      }\n   115→      TSIA = TSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   116→      openTSIA = openTSIA.divide(new BigDecimal(quoteArray.length), FinancialUtils.ROUND);\n   117→    }\n   118→\n   119→    setMarketSummaryDataBean(new MarketSummaryDataBean(TSIA, openTSIA, totalVolume, topGainers, topLosers));\n   120→  }\n   121→\n   122→  @Lock(LockType.WRITE)\n   123→  public void setMarketSummaryDataBean(MarketSummaryDataBean marketSummaryDataBean) {\n   124→    this.marketSummaryDataBean = marke