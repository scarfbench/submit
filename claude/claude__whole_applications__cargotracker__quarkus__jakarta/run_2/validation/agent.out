{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012YuSzi3KNTepwQB7QYGgnk","type":"tool_result","content":"     1→package org.eclipse.cargotracker.interfaces.tracking.web;\n     2→\n     3→import static java.nio.charset.StandardCharsets.UTF_8;\n     4→\n     5→import java.io.Serializable;\n     6→import java.io.UnsupportedEncodingException;\n     7→import java.net.URLEncoder;\n     8→import java.util.List;\n     9→import java.util.logging.Level;\n    10→import java.util.logging.Logger;\n    11→import jakarta.faces.view.ViewScoped;\n    12→import jakarta.inject.Inject;\n    13→import jakarta.inject.Named;\n    14→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    15→import org.eclipse.cargotracker.domain.model.cargo.CargoRepository;\n    16→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    17→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    18→import org.eclipse.cargotracker.domain.model.handling.HandlingEventRepository;\n    19→import com.fasterxml.jackson.core.JsonProcessingException;\n    20→import com.fasterxml.jackson.databind.ObjectMapper;\n    21→\n    22→/**\n    23→ * Backing bean for tracking cargo. This interface sits immediately on top of the domain layer,\n    24→ * unlike the booking interface which has a facade and supporting DTOs in between.\n    25→ *\n    26→ * <p>\n    27→ * An adapter class, designed for the tracking use case, is used to wrap the domain model to make it\n    28→ * easier to work with in a web page rendering context. We do not want to apply view rendering\n    29→ * constraints to the design of our domain model and the adapter helps us shield the domain model\n    30→ * classes where needed.\n    31→ *\n    32→ * <p>\n    33→ * In some very simplistic cases, it is fine to not use even an adapter.\n    34→ */\n    35→@Named(\"publicTrack\")\n    36→@ViewScoped\n    37→public class Track implements Serializable {\n    38→\n    39→  private static final long serialVersionUID = 1L;\n    40→\n    41→  @Inject\n    42→  private transient Logger logger;\n    43→\n    44→  @Inject\n    45→  private CargoRepository cargoRepository;\n    46→  @Inject\n    47→  private HandlingEventRepository handlingEventRepository;\n    48→  @Inject\n    49→  private ObjectMapper objectMapper;\n    50→\n    51→  private String trackingId;\n    52→  private CargoTrackingViewAdapter cargo;\n    53→\n    54→  public String getTrackingId() {\n    55→    return trackingId;\n    56→  }\n    57→\n    58→  public void setTrackingId(String trackingId) {\n    59→    if (trackingId != null) {\n    60→      trackingId = trackingId.trim();\n    61→    }\n    62→\n    63→    this.trackingId = trackingId;\n    64→  }\n    65→\n    66→  public CargoTrackingViewAdapter getCargo() {\n    67→    return cargo;\n    68→  }\n    69→\n    70→  public String getCargoAsJson() {\n    71→    try {\n    72→      return URLEncoder.encode(objectMapper.writeValueAsString(cargo), UTF_8.name());\n    73→    } catch (UnsupportedEncodingException | JsonProcessingException ex) {\n    74→      logger.log(Level.WARNING, \"URL encoding error.\", ex);\n    75→      return \"\"; // Should never happen.\n    76→    }\n    77→  }\n    78→\n    79→  public void onTrackById() {\n    80→    Cargo cargo = cargoRepository.find(new TrackingId(trackingId));\n    81→\n    82→    if (cargo != null) {\n    83→      List<HandlingEvent> handlingEvents =\n    84→          handlingEventRepository\n    85→              .lookupHandlingHistoryOfCargo(new TrackingId(trackingId))\n    86→              .getDistinctEventsByCompletionTime();\n    87→      this.cargo = new CargoTrackingViewAdapter(cargo, handlingEvents);\n    88→    } else {\n    89→      this.cargo = null;\n    90→    }\n    91→  }\n    92→}\n    93→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"83d9035c-c20b-4877-bffd-f348c2f149e2","uuid":"4875f448-836a-4a4a-b724-1aaa2212c834"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012dVtWSJb9npijfjL3ZVPXG","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import java.io.Serializable;\n     4→import java.util.logging.Level;\n     5→import java.util.logging.Logger;\n     6→import jakarta.annotation.Resource;\n     7→import jakarta.enterprise.context.ApplicationScoped;\n     8→import jakarta.inject.Inject;\n     9→import jakarta.jms.ConnectionFactory;\n    10→import jakarta.jms.JMSContext;\n    11→import jakarta.jms.Queue;\n    12→import org.eclipse.cargotracker.application.ApplicationEvents;\n    13→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    14→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    15→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    16→\n    17→@ApplicationScoped\n    18→public class JmsApplicationEvents implements ApplicationEvents, Serializable {\n    19→\n    20→  private static final long serialVersionUID = 1L;\n    21→  private static final int LOW_PRIORITY = 0;\n    22→\n    23→  @Inject\n    24→  private ConnectionFactory connectionFactory;\n    25→\n    26→  @Resource(lookup = \"jms/CargoHandledQueue\")\n    27→  private Queue cargoHandledQueue;\n    28→\n    29→  @Resource(lookup = \"jms/MisdirectedCargoQueue\")\n    30→  private Queue misdirectedCargoQueue;\n    31→\n    32→  @Resource(lookup = \"jms/DeliveredCargoQueue\")\n    33→  private Queue deliveredCargoQueue;\n    34→\n    35→  @Resource(lookup = \"jms/HandlingEventRegistrationAttemptQueue\")\n    36→  private Queue handlingEventQueue;\n    37→\n    38→  @Inject\n    39→  private Logger logger;\n    40→\n    41→  @Override\n    42→  public void cargoWasHandled(HandlingEvent event) {\n    43→    Cargo cargo = event.getCargo();\n    44→    logger.log(Level.INFO, \"Cargo was handled {0}\", cargo);\n    45→    try (JMSContext jmsContext = connectionFactory.createContext()) {\n    46→      jmsContext\n    47→          .createProducer()\n    48→          .setPriority(LOW_PRIORITY)\n    49→          .setDisableMessageID(true)\n    50→          .setDisableMessageTimestamp(true)\n    51→          .send(cargoHandledQueue, cargo.getTrackingId().getIdString());\n    52→    }\n    53→  }\n    54→\n    55→  @Override\n    56→  public void cargoWasMisdirected(Cargo cargo) {\n    57→    logger.log(Level.INFO, \"Cargo was misdirected {0}\", cargo);\n    58→    try (JMSContext jmsContext = connectionFactory.createContext()) {\n    59→      jmsContext\n    60→          .createProducer()\n    61→          .setPriority(LOW_PRIORITY)\n    62→          .setDisableMessageID(true)\n    63→          .setDisableMessageTimestamp(true)\n    64→          .send(misdirectedCargoQueue, cargo.getTrackingId().getIdString());\n    65→    }\n    66→  }\n    67→\n    68→  @Override\n    69→  public void cargoHasArrived(Cargo cargo) {\n    70→    logger.log(Level.INFO, \"Cargo has arrived {0}\", cargo);\n    71→    try (JMSContext jmsContext = connectionFactory.createContext()) {\n    72→      jmsContext\n    73→          .createProducer()\n    74→          .setPriority(LOW_PRIORITY)\n    75→          .setDisableMessageID(true)\n    76→          .setDisableMessageTimestamp(true)\n    77→          .send(deliveredCargoQueue, cargo.getTrackingId().getIdString());\n    78→    }\n    79→  }\n    80→\n    81→  @Override\n    82→  public void receivedHandlingEventRegistrationAttempt(HandlingEventRegistrationAttempt attempt) {\n    83→    logger.log(Level.INFO, \"Received handling event registration attempt {0}\", attempt);\n    84→    try (JMSContext jmsContext = connectionFactory.createContext()) {\n    85→      jmsContext\n    86→          .createProducer()\n    87→          .setPriority(LOW_PRIORITY)\n    88→          .setDisableMessageID(true)\n    89→          .setDisableMessageTimestamp(true)\n    90→          .setTimeToLive(1000)\n    91→          .send(handlingEventQueue, jmsContext.createObjectMessage(attempt));\n    92→    }\n    93→  }\n    94→}\n    95→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"83d9035c-c20b-4877-bffd-f348c2f149e2","uuid":"5b959706-a512-475f-988b-7fca4a82883c"}
