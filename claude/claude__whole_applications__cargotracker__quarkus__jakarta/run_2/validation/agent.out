okens":1266,"ephemeral_1h_input_tokens":0},"output_tokens":1172},"context_management":null},"parent_tool_use_id":"toolu_bdrk_012q56QFf7xDBkCgsyeCsAu9","session_id":"83d9035c-c20b-4877-bffd-f348c2f149e2","uuid":"2857ce16-91c7-47d2-91a8-8f07cd0d9db7"}
