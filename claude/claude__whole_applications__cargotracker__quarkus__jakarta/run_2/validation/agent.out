{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01EijQXETenv7YR9z1GcnLHC","type":"tool_result","content":"     1→package org.eclipse.cargotracker.interfaces.handling.mobile;\n     2→\n     3→import static java.util.stream.Collectors.toMap;\n     4→\n     5→import java.io.Serializable;\n     6→import java.time.LocalDateTime;\n     7→import java.util.ArrayList;\n     8→import java.util.Arrays;\n     9→import java.util.Collections;\n    10→import java.util.List;\n    11→import java.util.Map;\n    12→import java.util.function.Function;\n    13→import jakarta.annotation.PostConstruct;\n    14→import jakarta.faces.application.FacesMessage;\n    15→import jakarta.faces.context.FacesContext;\n    16→import jakarta.faces.model.SelectItem;\n    17→import jakarta.faces.view.ViewScoped;\n    18→import jakarta.inject.Inject;\n    19→import jakarta.inject.Named;\n    20→import org.eclipse.cargotracker.application.ApplicationEvents;\n    21→import org.eclipse.cargotracker.application.util.DateConverter;\n    22→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    23→import org.eclipse.cargotracker.domain.model.cargo.TrackingId;\n    24→import org.eclipse.cargotracker.domain.model.cargo.TransportStatus;\n    25→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    26→import org.eclipse.cargotracker.domain.model.location.Location;\n    27→import org.eclipse.cargotracker.domain.model.location.UnLocode;\n    28→import org.eclipse.cargotracker.domain.model.voyage.Voyage;\n    29→import org.eclipse.cargotracker.domain.model.voyage.VoyageNumber;\n    30→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaCargoRepository;\n    31→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaLocationRepository;\n    32→import org.eclipse.cargotracker.infrastructure.persistence.jpa.JpaVoyageRepository;\n    33→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    34→import org.primefaces.event.FlowEvent;\n    35→import io.quarkus.panache.common.Sort;\n    36→\n    37→@Named\n    38→@ViewScoped\n    39→public class EventLogger implements Serializable {\n    40→\n    41→  private static final long serialVersionUID = 1L;\n    42→\n    43→  @Inject\n    44→  private JpaCargoRepository cargoRepository;\n    45→  @Inject\n    46→  private JpaLocationRepository locationRepository;\n    47→  @Inject\n    48→  private JpaVoyageRepository voyageRepository;\n    49→  @Inject\n    50→  private ApplicationEvents applicationEvents;\n    51→  @Inject\n    52→  private FacesContext context;\n    53→\n    54→  private List<SelectItem> trackingIds;\n    55→  private List<SelectItem> locations;\n    56→  private List<SelectItem> voyages;\n    57→\n    58→  private String trackingId;\n    59→  private String location;\n    60→  private HandlingEvent.Type eventType;\n    61→  private String voyageNumber;\n    62→  private LocalDateTime completionTime;\n    63→\n    64→  public String getTrackingId() {\n    65→    return trackingId;\n    66→  }\n    67→\n    68→  public void setTrackingId(String trackingId) {\n    69→    this.trackingId = trackingId;\n    70→  }\n    71→\n    72→  public List<SelectItem> getTrackingIds() {\n    73→    return trackingIds;\n    74→  }\n    75→\n    76→  public String getLocation() {\n    77→    return location;\n    78→  }\n    79→\n    80→  public void setLocation(String location) {\n    81→    this.location = location;\n    82→  }\n    83→\n    84→  public List<SelectItem> getLocations() {\n    85→    return locations;\n    86→  }\n    87→\n    88→  // Move this to a separate utility if it is used in other parts of the UI.\n    89→  public Map<HandlingEvent.Type, HandlingEvent.Type> getEventTypes() {\n    90→    return Collections.unmodifiableMap(\n    91→        Arrays.asList(HandlingEvent.Type.values())\n    92→            .stream()\n    93→            .collect(toMap(Function.identity(), Function.identity())));\n    94→  }\n    95→\n    96→  public HandlingEvent.Type getEventType() {\n    97→    return eventType;\n    98→  }\n    99→\n   100→  public void setEventType(HandlingEvent.Type eventType) {\n   101→    this.eventType = eventType;\n   102→  }\n   103→\n   104→  public String getVoyageNumber() {\n   105→    return voyageNumber;\n   106→  }\n   107→\n   108→  public void setVoyageNumber(String voyageNumber) {\n   109→    this.voyageNumber = voyageNumber;\n   110→  }\n   111→\n   112→  public List<SelectItem> getVoyages() {\n   113→    return voyages;\n   114→  }\n   115→\n   116→  public LocalDateTime getCompletionTime() {\n   117→    return completionTime;\n   118→  }\n   119→\n   120→  public void setCompletionTime(LocalDateTime completionTime) {\n   121→    this.completionTime = completionTime;\n   122→  }\n   123→\n   124→  public String getCompletionTimeValue() {\n   125→    return DateConverter.toString(completionTime);\n   126→  }\n   127→\n   128→  public String getCompletionTimePattern() {\n   129→    return DateConverter.DATE_TIME_FORMAT;\n   130→  }\n   131→\n   132→  @PostConstruct\n   133→  public void init() {\n   134→    List<Cargo> cargos = cargoRepository.listAll();\n   135→\n   136→    trackingIds = new ArrayList<>(cargos.size());\n   137→\n   138→    // List only routed cargo that is not claimed yet.\n   139→    cargos\n   140→        .stream()\n   141→        .filter(\n   142→            cargo -> !cargo.getItinerary().getLegs().isEmpty()\n   143→                && !(cargo\n   144→                    .getDelivery()\n   145→                    .getTransportStatus()\n   146→                    .sameValueAs(TransportStatus.CLAIMED)))\n   147→        .map(cargo -> cargo.getTrackingId().getIdString())\n   148→        .forEachOrdered(trackingId -> trackingIds.add(new SelectItem(trackingId, trackingId)));\n   149→\n   150→    List<Location> locations = locationRepository.listAll();\n   151→\n   152→    this.locations = new ArrayList<>(locations.size());\n   153→\n   154→    locations.forEach(\n   155→        location -> {\n   156→          String locationCode = location.getUnLocode().getIdString();\n   157→          this.locations.add(\n   158→              new SelectItem(locationCode, location.getName() + \" (\" + locationCode + \")\"));\n   159→        });\n   160→\n   161→    List<Voyage> voyages = voyageRepository.listAll(Sort.by(\"voyageNumber\"));\n   162→\n   163→    this.voyages = new ArrayList<>(voyages.size());\n   164→\n   165→    voyages.forEach(\n   166→        voyage -> this.voyages.add(\n   167→            new SelectItem(\n   168→                voyage.getVoyageNumber().getIdString(),\n   169→                voyage.getVoyageNumber().getIdString())));\n   170→  }\n   171→\n   172→  public String onFlowProcess(FlowEvent event) {\n   173→    if (!validate(event.getOldStep())) {\n   174→      return event.getOldStep();\n   175→    }\n   176→\n   177→    if (\"dateTab\".equals(event.getNewStep())) {\n   178→      completionTime = LocalDateTime.now();\n   179→    }\n   180→\n   181→    return event.getNewStep();\n   182→  }\n   183→\n   184→  private boolean validate(final String step) {\n   185→    if (\"voyageTab\".equals(step) && eventType.requiresVoyage() && voyageNumber == null) {\n   186→      FacesMessage message =\n   187→          new FacesMessage(\n   188→              FacesMessage.SEVERITY_ERROR,\n   189→              \"When a cargo is LOADed or UNLOADed a Voyage should be selected, please fix errors to continue.\",\n   190→              \"\");\n   191→      context.addMessage(null, message);\n   192→      return false;\n   193→    }\n   194→\n   195→    return true;\n   196→  }\n   197→\n   198→  public void submit() {\n   199→    VoyageNumber voyage;\n   200→\n   201→    TrackingId trackingId = new TrackingId(this.trackingId);\n   202→    UnLocode location = new UnLocode(this.location);\n   203→\n   204→    if (eventType.requiresVoyage()) {\n   205→      voyage = new VoyageNumber(voyageNumber);\n   206→    } else {\n   207→      voyage = null;\n   208→    }\n   209→\n   210→    HandlingEventRegistrationAttempt attempt =\n   211→        new HandlingEventRegistrationAttempt(\n   212→            LocalDateTime.now(), completionTime, trackingId, voyage, eventType, location);\n   213→\n   214→    applicationEvents.receivedHandlingEventRegistrationAttempt(attempt);\n   215→\n   216→    FacesContext.getCurrentInstance().addMessage(null, new FacesMessage(\"Event submitted\", \"\"));\n   217→  }\n   218→}\n   219→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"83d9035c-c20b-4877-bffd-f348c2f149e2","uuid":"298d2d5c-d501-4210-91a3-7e682eae7f86"}
