{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01VzxFLdKGDvJheHwSksaw5o","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import java.io.Serializable;\n     4→import java.util.logging.Level;\n     5→import java.util.logging.Logger;\n     6→import jakarta.enterprise.context.ApplicationScoped;\n     7→import jakarta.inject.Inject;\n     8→import jakarta.jms.ConnectionFactory;\n     9→import jakarta.jms.JMSContext;\n    10→import org.eclipse.cargotracker.application.ApplicationEvents;\n    11→import org.eclipse.cargotracker.domain.model.cargo.Cargo;\n    12→import org.eclipse.cargotracker.domain.model.handling.HandlingEvent;\n    13→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    14→import org.eclipse.microprofile.config.inject.ConfigProperty;\n    15→\n    16→@ApplicationScoped\n    17→public class JmsApplicationEvents implements ApplicationEvents, Serializable {\n    18→\n    19→  private static final long serialVersionUID = 1L;\n    20→  private static final int LOW_PRIORITY = 0;\n    21→  @Inject\n    22→  private ConnectionFactory connectionFactory;\n    23→\n    24→  @ConfigProperty(name = \"app.jms.CargoHandledQueue\")\n    25→  private String cargoHandledQueue;\n    26→\n    27→  @ConfigProperty(name = \"app.jms.MisdirectedCargoQueue\")\n    28→  private String misdirectedCargoQueue;\n    29→\n    30→  @ConfigProperty(name = \"app.jms.DeliveredCargoQueue\")\n    31→  private String deliveredCargoQueue;\n    32→\n    33→  @ConfigProperty(name = \"app.jms.HandlingEventRegistrationAttemptQueue\")\n    34→  private String handlingEventQueue;\n    35→\n    36→  @Inject\n    37→  private Logger logger;\n    38→\n    39→  @Override\n    40→  public void cargoWasHandled(HandlingEvent event) {\n    41→    Cargo cargo = event.getCargo();\n    42→    logger.log(Level.INFO, \"Cargo was handled {0}\", cargo);\n    43→    try (JMSContext jmsContext = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    44→      jmsContext\n    45→          .createProducer()\n    46→          .setPriority(LOW_PRIORITY)\n    47→          .setDisableMessageID(true)\n    48→          .setDisableMessageTimestamp(true)\n    49→          .send(jmsContext.createQueue(cargoHandledQueue), cargo.getTrackingId().getIdString());\n    50→    }\n    51→  }\n    52→\n    53→  @Override\n    54→  public void cargoWasMisdirected(Cargo cargo) {\n    55→    logger.log(Level.INFO, \"Cargo was misdirected {0}\", cargo);\n    56→    try (JMSContext jmsContext = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    57→      jmsContext\n    58→          .createProducer()\n    59→          .setPriority(LOW_PRIORITY)\n    60→          .setDisableMessageID(true)\n    61→          .setDisableMessageTimestamp(true)\n    62→          .send(jmsContext.createQueue(misdirectedCargoQueue), cargo.getTrackingId().getIdString());\n    63→    }\n    64→  }\n    65→\n    66→  @Override\n    67→  public void cargoHasArrived(Cargo cargo) {\n    68→    logger.log(Level.INFO, \"Cargo has arrived {0}\", cargo);\n    69→    try (JMSContext jmsContext = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    70→      jmsContext\n    71→          .createProducer()\n    72→          .setPriority(LOW_PRIORITY)\n    73→          .setDisableMessageID(true)\n    74→          .setDisableMessageTimestamp(true)\n    75→          .send(jmsContext.createQueue(deliveredCargoQueue), cargo.getTrackingId().getIdString());\n    76→    }\n    77→  }\n    78→\n    79→  @Override\n    80→  public void receivedHandlingEventRegistrationAttempt(HandlingEventRegistrationAttempt attempt) {\n    81→    logger.log(Level.INFO, \"Received handling event registration attempt {0}\", attempt);\n    82→    try (JMSContext jmsContext = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    83→      jmsContext\n    84→          .createProducer()\n    85→          .setPriority(LOW_PRIORITY)\n    86→          .setDisableMessageID(true)\n    87→          .setDisableMessageTimestamp(true)\n    88→          .setTimeToLive(1000)\n    89→          .send(jmsContext.createQueue(handlingEventQueue), attempt);\n    90→    }\n    91→  }\n    92→}\n    93→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01CtQxVe8ne772J5Q4XJD5dJ","session_id":"83d9035c-c20b-4877-bffd-f348c2f149e2","uuid":"a4f92af5-226f-495a-b7f7-4cf7aa158f21"}
