Queue));\n      while (true) {\n        Message message = consumer.receive();\n        logger.log(\n            Level.INFO,\n            \"Rejected registration attempt of cargo with tracking ID {0}.\",\n            message.getBody(String.class));\n      }\n    } catch (JMSException ex) {\n      logger.log(Level.WARNING, \"Error processing message.\", ex);\n    }\n  }\n\n}\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5031,"cache_read_input_tokens":114167,"cache_creation":{"ephemeral_5m_input_tokens":5031,"ephemeral_1h_input_tokens":0},"output_tokens":3612},"context_management":null},"parent_tool_use_id":null,"session_id":"c9dd45e7-15fd-4879-bcb7-e7ebc835a938","uuid":"d312387b-4ef2-4782-a2f7-09e51dc0fff7"}
