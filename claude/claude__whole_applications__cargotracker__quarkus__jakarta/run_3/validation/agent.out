eck https://quarkus.io/guides/quarkus-runtime-base-image for further information about this image.\nsrc/main/docker/Dockerfile.native-micro:13:# docker build -f src/main/docker/Dockerfile.native-micro -t quarkus/cargo-tracker .\nsrc/main/docker/Dockerfile.native-micro:17:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker\nsrc/main/docker/Dockerfile.native-micro:19:# The `quay.io/quarkus/ubi9-quarkus-micro-image:2.0` base image is based on UBI 9.\nsrc/main/docker/Dockerfile.native-micro:20:# To use UBI 8, switch to `quay.io/quarkus/quarkus-micro-image:2.0`.\nsrc/main/docker/Dockerfile.native-micro:22:FROM quay.io/quarkus/ubi9-quarkus-micro-image:2.0\nsrc/main/docker/Dockerfile.native-micro:32:ENTRYPOINT [\"./application\", \"-Dquarkus.http.host=0.0.0.0\"]\nsrc/main/docker/Dockerfile.native:2:# This Dockerfile is used in order to build a container that runs the Quarkus application in native (no JVM) mode.\nsrc/main/docker/Dockerfile.native:10:# docker build -f src/main/docker/Dockerfile.native -t quarkus/cargo-tracker .\nsrc/main/docker/Dockerfile.native:14:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker\nsrc/main/docker/Dockerfile.native:29:ENTRYPOINT [\"./application\", \"-Dquarkus.http.host=0.0.0.0\"]\nsrc/main/docker/Dockerfile.legacy-jar:2:# This Dockerfile is used in order to build a container that runs the Quarkus application in JVM mode\nsrc/main/docker/Dockerfile.legacy-jar:6:# ./mvnw package -Dquarkus.package.jar.type=legacy-jar\nsrc/main/docker/Dockerfile.legacy-jar:10:# docker build -f src/main/docker/Dockerfile.legacy-jar -t quarkus/cargo-tracker-legacy-jar .\nsrc/main/docker/Dockerfile.legacy-jar:14:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker-legacy-jar\nsrc/main/docker/Dockerfile.legacy-jar:23:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker-legacy-jar\nsrc/main/docker/Dockerfile.legacy-jar:87:COPY target/*-runner.jar /deployments/quarkus-run.jar\nsrc/main/docker/Dockerfile.legacy-jar:91:ENV JAVA_OPTS_APPEND=\"-Dquarkus.http.host=0.0.0.0 -Djava.util.logging.manager=org.jboss.logmanager.LogManager\"\nsrc/main/docker/Dockerfile.legacy-jar:92:ENV JAVA_APP_JAR=\"/deployments/quarkus-run.jar\"\nsrc/main/docker/Dockerfile.jvm:2:# This Dockerfile is used in order to build a container that runs the Quarkus application in JVM mode\nsrc/main/docker/Dockerfile.jvm:10:# docker build -f src/main/docker/Dockerfile.jvm -t quarkus/cargo-tracker-jvm .\nsrc/main/docker/Dockerfile.jvm:14:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker-jvm\nsrc/main/docker/Dockerfile.jvm:23:# docker run -i --rm -p 8080:8080 quarkus/cargo-tracker-jvm\nsrc/main/docker/Dockerfile.jvm:87:COPY --chown=185 target/quarkus-app/lib/ /deployments/lib/\nsrc/main/docker/Dockerfile.jvm:88:COPY --chown=185 target/quarkus-app/*.jar /deployments/\nsrc/main/docker/Dockerfile.jvm:89:COPY --chown=185 target/quarkus-app/app/ /deployments/app/\nsrc/main/docker/Dockerfile.jvm:90:COPY --chown=185 target/quarkus-app/quarkus/ /deployments/quarkus/\nsrc/main/docker/Dockerfile.jvm:94:ENV JAVA_OPTS_APPEND=\"-Dquarkus.http.host=0.0.0.0 -Djava.util.logging.manager=org.jboss.logmanager.LogManager\"\nsrc/main/docker/Dockerfile.jvm:95:ENV JAVA_APP_JAR=\"/deployments/quarkus-run.jar\""}]},"parent_tool_use_id":null,"session_id":"c9dd45e7-15fd-4879-bcb7-e7ebc835a938","uuid":"1384c7d8-d33f-4381-b102-3eef89b71922"}
