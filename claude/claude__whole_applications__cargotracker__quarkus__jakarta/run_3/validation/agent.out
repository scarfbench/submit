0→\n    41→  @Inject\n    42→  @ConfigProperty(name = \"app.jms.CargoHandledQueue\", defaultValue = \"CargoHandledQueue\")\n    43→  private String cargoHandledQueue;\n    44→\n    45→  private final ExecutorService scheduler = Executors.newSingleThreadExecutor();\n    46→\n    47→  @PostConstruct\n    48→  public void onStart() {\n    49→    scheduler.submit(this);\n    50→  }\n    51→\n    52→  @PreDestroy\n    53→  public void onStop() {\n    54→    scheduler.shutdown();\n    55→  }\n    56→\n    57→  @Override\n    58→  public void run() {\n    59→    try (JMSContext context = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    60→      JMSConsumer consumer = context.createConsumer(context.createQueue(cargoHandledQueue));\n    61→      while (true) {\n    62→        Message message = consumer.receive();\n    63→        TextMessage textMessage = (TextMessage) message;\n    64→        String trackingIdString = textMessage.getText();\n    65→\n    66→        cargoInspectionService.inspectCargo(new TrackingId(trackingIdString));\n    67→      }\n    68→    } catch (JMSException e) {\n    69→      logger.log(Level.SEVERE, \"Error procesing JMS message\", e);\n    70→    }\n    71→  }\n    72→\n    73→}\n    74→"}]},"parent_tool_use_id":null,"session_id":"c9dd45e7-15fd-4879-bcb7-e7ebc835a938","uuid":"3cedea52-bf59-4c2e-ba81-bdfb500df485"}
