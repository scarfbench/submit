{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_015zgsxAzXuisUi9Zze99nES","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.routing;\n     2→\n     3→import java.util.ArrayList;\n     4→import java.util.List;\n     5→import java.util.logging.Level;\n     6→import java.util.logging.Logger;\n     7→import java.util.stream.Collectors;\n     8→import jakarta.annotation.PostConstruct;\n     9→import jakarta.enterprise.context.ApplicationScoped;\n    10→import jakarta.inject.Inject;\n    11→import jakarta.transaction.Transactional;\n    12→import jakarta.ws.rs.client.ClientBuilder;\n    13→import jakarta.ws.rs.client.WebTarget;\n    14→import jakarta.ws.rs.core.MediaType;\n    15→import org.eclipse.cargotracker.domain.model.cargo.Itinerary;\n    16→import org.eclipse.cargotracker.domain.model.cargo.Leg;\n    17→import org.eclipse.cargotracker.domain.model.cargo.RouteSpecification;\n    18→import org.eclipse.cargotracker.domain.model.location.LocationRepository;\n    19→import org.eclipse.cargotracker.domain.model.location.UnLocode;\n    20→import org.eclipse.cargotracker.domain.model.voyage.VoyageNumber;\n    21→import org.eclipse.cargotracker.domain.model.voyage.VoyageRepository;\n    22→import org.eclipse.cargotracker.domain.service.RoutingService;\n    23→import org.eclipse.microprofile.config.inject.ConfigProperty;\n    24→import org.eclipse.pathfinder.api.TransitEdge;\n    25→import org.eclipse.pathfinder.api.TransitPath;\n    26→import org.eclipse.pathfinder.api.TransitPaths;\n    27→\n    28→/**\n    29→ * Our end of the routing service. This is basically a data model translation layer between our\n    30→ * domain model and the API put forward by the routing team, which operates in a different context\n    31→ * from us.\n    32→ */\n    33→@ApplicationScoped\n    34→@Transactional\n    35→public class ExternalRoutingService implements RoutingService {\n    36→\n    37→  @Inject\n    38→  private Logger logger;\n    39→\n    40→  @ConfigProperty(name = \"app.configuration.GraphTraversalUrl\")\n    41→  private String graphTraversalUrl;\n    42→\n    43→  private WebTarget graphTraversalResource;\n    44→\n    45→  @Inject\n    46→  private LocationRepository locationRepository;\n    47→  @Inject\n    48→  private VoyageRepository voyageRepository;\n    49→\n    50→  @PostConstruct\n    51→  public void init() {\n    52→    graphTraversalResource = ClientBuilder.newClient().target(graphTraversalUrl);\n    53→  }\n    54→\n    55→  @Override\n    56→  public List<Itinerary> fetchRoutesForSpecification(RouteSpecification routeSpecification) {\n    57→    // The RouteSpecification is picked apart and adapted to the external API.\n    58→    String origin = routeSpecification.getOrigin().getUnLocode().getIdString();\n    59→    String destination = routeSpecification.getDestination().getUnLocode().getIdString();\n    60→\n    61→    List<TransitPath> transitPaths =\n    62→        graphTraversalResource\n    63→            .queryParam(\"origin\", origin)\n    64→            .queryParam(\"destination\", destination)\n    65→            .request(MediaType.APPLICATION_JSON_TYPE)\n    66→            .get(TransitPaths.class).getTransitPaths();\n    67→\n    68→    // The returned result is then translated back into our domain model.\n    69→    List<Itinerary> itineraries = new ArrayList<>();\n    70→\n    71→    // Use the specification to safe-guard against invalid itineraries\n    72→    transitPaths\n    73→        .stream()\n    74→        .map(this::toItinerary)\n    75→        .forEach(\n    76→            itinerary -> {\n    77→              if (routeSpecification.isSatisfiedBy(itinerary)) {\n    78→                itineraries.add(itinerary);\n    79→              } else {\n    80→                logger.log(\n    81→                    Level.FINE, \"Received itinerary that did not satisfy the route specification\");\n    82→              }\n    83→            });\n    84→\n    85→    return itineraries;\n    86→  }\n    87→\n    88→  private Itinerary toItinerary(TransitPath transitPath) {\n    89→    List<Leg> legs =\n    90→        transitPath.getTransitEdges().stream().map(this::toLeg).collect(Collectors.toList());\n    91→    return new Itinerary(legs);\n    92→  }\n    93→\n    94→  private Leg toLeg(TransitEdge edge) {\n    95→    return new Leg(\n    96→        voyageRepository.find(new VoyageNumber(edge.getVoyageNumber())),\n    97→        locationRepository.find(new UnLocode(edge.getFromUnLocode())),\n    98→        locationRepository.find(new UnLocode(edge.getToUnLocode())),\n    99→        edge.getFromDate(),\n   100→        edge.getToDate());\n   101→  }\n   102→}\n   103→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"be751ba2-32a8-49a7-8b94-68e2cc55da12","uuid":"3c9b6867-6950-4a6d-8232-233f05f2cf3b"}
