odule:1.9\" name=\"com.h2database.h2\">\n    33→    <resources>\n    34→        <resource-root path=\"h2.jar\"/>\n    35→    </resources>\n    36→    <dependencies>\n    37→        <module name=\"jakarta.transaction.api\"/>\n    38→    </dependencies>\n    39→</module>\n    40→MODULEXML\n    41→\n    42→# Download H2 jar for WildFly module\n    43→RUN curl -L -o ${WILDFLY_HOME}/modules/system/layers/base/com/h2database/h2/main/h2.jar \\\n    44→    \"https://repo1.maven.org/maven2/com/h2database/h2/2.2.224/h2-2.2.224.jar\"\n    45→\n    46→# Configure WildFly with standalone-full profile (includes JMS/messaging)\n    47→# Create a CLI script to configure datasource and JMS queues\n    48→COPY <<'CLISCRIPT' /tmp/configure-wildfly.cli\n    49→embed-server --server-config=standalone-full.xml\n    50→\n    51→# Add H2 JDBC driver\n    52→/subsystem=datasources/jdbc-driver=h2:add(driver-name=h2, driver-module-name=com.h2database.h2, driver-class-name=org.h2.Driver)\n    53→\n    54→# Add H2 datasource\n    55→/subsystem=datasources/data-source=CargoTrackerDS:add( \\\n    56→    jndi-name=\"java:jboss/datasources/CargoTrackerDS\", \\\n    57→    connection-url=\"jdbc:h2:file:./cargo-tracker-data/cargo-tracker-database;AUTO_SERVER=TRUE\", \\\n    58→    driver-name=h2, \\\n    59→    user-name=sa, \\\n    60→    password=\"\" \\\n    61→)\n    62→\n    63→# Add JMS Queues\n    64→jms-queue add --queue-address=CargoHandledQueue --entries=[\"java:/jms/queue/CargoHandledQueue\"]\n    65→jms-queue add --queue-address=DeliveredCargoQueue --entries=[\"java:/jms/queue/DeliveredCargoQueue\"]\n    66→jms-queue add --queue-address=HandlingEventRegistrationAttemptQueue --entries=[\"java:/jms/queue/HandlingEventRegistrationAttemptQueue\"]\n    67→jms-queue add --queue-address=MisdirectedCargoQueue --entries=[\"java:/jms/queue/MisdirectedCargoQueue\"]\n    68→jms-queue add --queue-address=RejectedRegistrationAttemptsQueue --entries=[\"java:/jms/queue/RejectedRegistrationAttemptsQueue\"]\n    69→\n    70→stop-embedded-server\n    71→CLISCRIPT\n    72→\n    73→RUN ${WILDFLY_HOME}/bin/jboss-cli.sh --file=/tmp/configure-wildfly.cli\n    74→\n    75→# Set working directory\n    76→WORKDIR /app\n    77→\n    78→# Copy all the assets\n    79→COPY . .\n    80→\n    81→RUN if [ -f mvnw ]; then chmod +x mvnw; fi && if [ -f smoke.py ]; then chmod +x smoke.py; fi\n    82→\n    83→# Build the application WAR at image build time\n    84→RUN mvn clean package -DskipTests\n    85→\n    86→# Deploy the WAR to WildFly\n    87→RUN cp /app/target/cargo-tracker.war ${WILDFLY_HOME}/standalone/deployments/\n    88→\n    89→# Expose port\n    90→EXPOSE 8080\n    91→\n    92→# Start WildFly with standalone-full profile (includes JMS subsystem)\n    93→CMD ${WILDFLY_HOME}/bin/standalone.sh -c standalone-full.xml -b 0.0.0.0 -Dapp.configuration.GraphTraversalUrl=http://localhost:8080/cargo-tracker/rest/graph-traversal/shortest-path\n    94→"}]},"parent_tool_use_id":null,"session_id":"be751ba2-32a8-49a7-8b94-68e2cc55da12","uuid":"44b8bd52-305b-49fe-9e68-5c11cd7a17ae"}
