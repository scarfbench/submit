{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WpvsmMUD1g3zcbLrDk7SaU","type":"tool_result","content":"     1→package org.eclipse.cargotracker.infrastructure.messaging.jms;\n     2→\n     3→import jakarta.enterprise.context.ApplicationScoped;\n     4→import jakarta.enterprise.event.Observes;\n     5→import jakarta.inject.Inject;\n     6→import jakarta.jms.ConnectionFactory;\n     7→import jakarta.jms.JMSConsumer;\n     8→import jakarta.jms.JMSContext;\n     9→import jakarta.jms.JMSException;\n    10→import jakarta.jms.Message;\n    11→import jakarta.jms.ObjectMessage;\n    12→import java.util.concurrent.ExecutorService;\n    13→import java.util.concurrent.Executors;\n    14→import org.eclipse.cargotracker.application.HandlingEventService;\n    15→import org.eclipse.cargotracker.domain.model.handling.CannotCreateHandlingEventException;\n    16→import org.eclipse.cargotracker.interfaces.handling.HandlingEventRegistrationAttempt;\n    17→import org.eclipse.microprofile.config.inject.ConfigProperty;\n    18→import io.quarkus.runtime.ShutdownEvent;\n    19→import io.quarkus.runtime.StartupEvent;\n    20→\n    21→/** Consumes handling event registration attempt messages and delegates to proper registration. */\n    22→@ApplicationScoped\n    23→public class HandlingEventRegistrationAttemptConsumer implements Runnable {\n    24→\n    25→  @Inject\n    26→  private HandlingEventService handlingEventService;\n    27→\n    28→  @Inject\n    29→  private ConnectionFactory connectionFactory;\n    30→\n    31→  @ConfigProperty(name = \"app.jms.HandlingEventRegistrationAttemptQueue\",\n    32→      defaultValue = \"HandlingEventRegistrationAttemptQueue\")\n    33→  private String handlingEventRegistrationAttemptQueue;\n    34→\n    35→  private final ExecutorService scheduler = Executors.newSingleThreadExecutor();\n    36→\n    37→  public void onStart(@Observes StartupEvent ev) {\n    38→    scheduler.submit(this);\n    39→  }\n    40→\n    41→  public void onStop(@Observes ShutdownEvent ev) {\n    42→    scheduler.shutdown();\n    43→  }\n    44→\n    45→  @Override\n    46→  public void run() {\n    47→    try (JMSContext context = connectionFactory.createContext(JMSContext.AUTO_ACKNOWLEDGE)) {\n    48→      JMSConsumer consumer =\n    49→          context.createConsumer(context.createQueue(handlingEventRegistrationAttemptQueue));\n    50→      while (true) {\n    51→        Message message = consumer.receive();\n    52→        ObjectMessage objectMessage = (ObjectMessage) message;\n    53→        HandlingEventRegistrationAttempt attempt =\n    54→            (HandlingEventRegistrationAttempt) objectMessage.getObject();\n    55→        handlingEventService.registerHandlingEvent(\n    56→            attempt.getCompletionTime(),\n    57→            attempt.getTrackingId(),\n    58→            attempt.getVoyageNumber(),\n    59→            attempt.getUnLocode(),\n    60→            attempt.getType());\n    61→      }\n    62→    } catch (JMSException | CannotCreateHandlingEventException e) {\n    63→      // Poison messages will be placed on dead-letter queue.\n    64→      throw new RuntimeException(\"Error occurred processing message\", e);\n    65→    }\n    66→  }\n    67→\n    68→}\n    69→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"be751ba2-32a8-49a7-8b94-68e2cc55da12","uuid":"c7d8fd04-e88a-4a3f-bd43-6edec298b0fb"}
