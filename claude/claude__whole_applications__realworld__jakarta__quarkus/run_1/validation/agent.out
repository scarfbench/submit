  </dependency>\n    86→        <dependency>\n    87→            <groupId>com.fasterxml.jackson.datatype</groupId>\n    88→            <artifactId>jackson-datatype-jsr310</artifactId>\n    89→            <version>2.19.2</version>\n    90→        </dependency>\n    91→        <dependency>\n    92→            <groupId>at.favre.lib</groupId>\n    93→            <artifactId>bcrypt</artifactId>\n    94→            <version>0.10.2</version>\n    95→        </dependency>\n    96→        <dependency>\n    97→            <groupId>org.reflections</groupId>\n    98→            <artifactId>reflections</artifactId>\n    99→            <version>0.10.2</version>\n   100→            <scope>test</scope>\n   101→        </dependency>\n   102→        <dependency>\n   103→            <groupId>io.rest-assured</groupId>\n   104→            <artifactId>rest-assured</artifactId>\n   105→            <version>5.5.5</version>\n   106→            <scope>test</scope>\n   107→        </dependency>\n   108→        <dependency>\n   109→            <groupId>com.google.code.gson</groupId>\n   110→            <artifactId>gson</artifactId>\n   111→            <version>2.13.1</version>\n   112→            <scope>test</scope>\n   113→        </dependency>\n   114→        <dependency>\n   115→            <groupId>org.junit.jupiter</groupId>\n   116→            <artifactId>junit-jupiter</artifactId>\n   117→            <version>5.13.4</version>\n   118→            <scope>test</scope>\n   119→        </dependency>\n   120→        <dependency>\n   121→            <groupId>org.jboss.weld</groupId>\n   122→            <artifactId>weld-junit5</artifactId>\n   123→            <version>5.0.1.Final</version>\n   124→            <scope>test</scope>\n   125→        </dependency>\n   126→        <dependency>\n   127→            <groupId>org.microshed</groupId>\n   128→            <artifactId>microshed-testing-core-jakarta</artifactId>\n   129→            <version>0.9.2</version>\n   130→            <scope>test</scope>\n   131→        </dependency>\n   132→        <dependency>\n   133→            <groupId>org.microshed</groupId>\n   134→            <artifactId>microshed-testing-liberty</artifactId>\n   135→            <version>0.9.2</version>\n   136→            <scope>test</scope>\n   137→        </dependency>\n   138→        <dependency>\n   139→            <groupId>org.testcontainers</groupId>\n   140→            <artifactId>testcontainers</artifactId>\n   141→            <version>1.21.3</version>\n   142→            <scope>test</scope>\n   143→        </dependency>\n   144→        <dependency>\n   145→            <groupId>org.testcontainers</groupId>\n   146→            <artifactId>postgresql</artifactId>\n   147→            <version>1.21.3</version>\n   148→            <scope>test</scope>\n   149→        </dependency>\n   150→    </dependencies>\n   151→    <build>\n   152→        <finalName>${project.artifactId}</finalName>\n   153→        <plugins>\n   154→            <plugin>\n   155→                <groupId>org.apache.maven.plugins</groupId>\n   156→                <artifactId>maven-war-plugin</artifactId>\n   157→                <version>3.4.0</version>\n   158→                <configuration>\n   159→                    <warName>${project.artifactId}</warName>\n   160→                    <failOnMissingWebXml>false</failOnMissingWebXml>\n   161→                    <packagingExcludes>pom.xml</packagingExcludes>\n   162→                </configuration>\n   163→            </plugin>\n   164→            <!-- Plugin to run unit tests -->\n   165→            <plugin>\n   166→                <groupId>org.apache.maven.plugins</groupId>\n   167→                <artifactId>maven-surefire-plugin</artifactId>\n   168→                <version>3.5.3</version>\n   169→                <executions>\n   170→                    <execution>\n   171→                        <phase>test</phase>\n   172→                        <id>default-test</id>\n   173→                        <configurati