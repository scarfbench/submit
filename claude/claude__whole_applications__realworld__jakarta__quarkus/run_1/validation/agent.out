ature.impl;\n  2245→\n  2246→import jakarta.inject.Inject;\n  2247→import jakarta.inject.Singleton;\n  2248→import org.example.realworldapi.domain.feature.FindUserById;\n  2249→import org.example.realworldapi.domain.feature.FindUserByUsername;\n  2250→import org.example.realworldapi.domain.feature.UnfollowUserByUsername;\n  2251→import org.example.realworldapi.domain.model.user.FollowRelationshipRepository;\n  2252→\n  2253→import java.util.UUID;\n  2254→\n  2255→@Singleton\n  2256→public class UnfollowUserByUsernameImpl implements UnfollowUserByUsername {\n  2257→\n  2258→    @Inject\n  2259→    private FindUserById findUserById;\n  2260→    @Inject\n  2261→    private FindUserByUsername findUserByUsername;\n  2262→    @Inject\n  2263→    private FollowRelationshipRepository followRelationshipRepository;\n  2264→\n  2265→    @Override\n  2266→    public void handle(UUID loggedUserId, String username) {\n  2267→        final var loggedUser = findUserById.handle(loggedUserId);\n  2268→        final var userToUnfollow = findUserByUsername.handle(username);\n  2269→        final var followingRelationship =\n  2270→                followRelationshipRepository.findByUsers(loggedUser, userToUnfollow).orElseThrow();\n  2271→        followRelationshipRepository.remove(followingRelationship);\n  2272→    }\n  2273→}\n  2274→\n  2275→==========================================\n  2276→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/UpdateArticleBySlugImpl.java\n  2277→==========================================\n  2278→package org.example.realworldapi.domain.feature.impl;\n  2279→\n  2280→import jakarta.inject.Inject;\n  2281→import jakarta.inject.Singleton;\n  2282→import org.example.realworldapi.domain.feature.CreateSlugByTitle;\n  2283→import org.example.realworldapi.domain.feature.FindArticleBySlug;\n  2284→import org.example.realworldapi.domain.feature.UpdateArticleBySlug;\n  2285→import org.example.realworldapi.domain.model.article.Article;\n  2286→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  2287→import org.example.realworldapi.domain.model.article.UpdateArticleInput;\n  2288→import org.example.realworldapi.domain.validator.ModelValidator;\n  2289→\n  2290→import java.time.LocalDateTime;\n  2291→\n  2292→import static org.apache.commons.lang3.StringUtils.isNotBlank;\n  2293→\n  2294→@Singleton\n  2295→public class UpdateArticleBySlugImpl implements UpdateArticleBySlug {\n  2296→\n  2297→    @Inject\n  2298→    private FindArticleBySlug findArticleBySlug;\n  2299→    @Inject\n  2300→    private CreateSlugByTitle createSlugByTitle;\n  2301→    @Inject\n  2302→    private ArticleRepository articleRepository;\n  2303→    @Inject\n  2304→    private ModelValidator modelValidator;\n  2305→\n  2306→    @Override\n  2307→    public Article handle(UpdateArticleInput updateArticleInput) {\n  2308→        final var article = findArticleBySlug.handle(updateArticleInput.getSlug());\n  2309→        if (atLeastOneFieldIsNotBlank(updateArticleInput)) {\n  2310→            if (isNotBlank(updateArticleInput.getTitle())) {\n  2311→                article.setSlug(createSlugByTitle.handle(updateArticleInput.getTitle()));\n  2312→                article.setTitle(updateArticleInput.getTitle());\n  2313→            }\n  2314→            if (isNotBlank(updateArticleInput.getDescription())) {\n  2315→                article.setDescription(updateArticleInput.getDescription());\n  2316→            }\n  2317→            if (isNotBlank(updateArticleInput.getBody())) {\n  2318→                article.setBody(updateArticleInput.getBody());\n  2319→            }\n  2320→            article.setUpdatedAt(LocalDateTime.now());\n  2321→            articleRepository.update(modelValidator.validate(article));\n  2322→        }\n  2323→        return article;\n  2324→    }\n  2325→\n  2326→    private boolean atLeastOneFieldIsNotBlank(UpdateArticleInput updateArticleInput) {\n  2327→        return isNotBlank(updateArticleInput.getTitle())\n  2328→                || isNotBlank(updateArticleInput.getDescription())\n  2329→                || isNotBlank(updateArticleInput.getBody());\n  2330→    }\n  2331→}\n  2332→\n  2333→==========================================\n  2334→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/UpdateUserImpl.java\n  2335→==========================================\n  2336→package org.example.realworldapi.domain.feature.impl;\n  2337→\n  2338→import jakarta.enterprise.context.Dependent;\n  2339→import jakarta.inject.Inject;\n  2340→import org.example.realworldapi.domain.exception.EmailAlreadyExistsException;\n  2341→import org.example.realworldapi.domain.exception.UsernameAlreadyExistsException;\n  2342→import org.example.realworldapi.domain.feature.FindUserById;\n  2343→import org.example.realworldapi.domain.feature.UpdateUser;\n  2344→import org.example.realworldapi.domain.model.user.UpdateUserInput;\n  2345→import org.example.realworldapi.domain.model.user.User;\n  2346→import org.example.realworldapi.domain.model.user.UserRepository;\n  2347→import org.example.realworldapi.domain.validator.ModelValidator;\n  2348→\n  2349→import java.util.UUID;\n  2350→\n  2351→@Dependent\n  2352→public class UpdateUserImpl implements UpdateUser {\n  2353→\n  2354→    @Inject\n  2355→    private FindUserById findUserById;\n  2356→    @Inject\n  2357→    private UserRepository userRepository;\n  2358→    @Inject\n  2359→    private ModelValidator modelValidator;\n  2360→\n  2361→    @Override\n  2362→    public User handle(UpdateUserInput updateUserInput) {\n  2363→        final var user = findUserById.handle(updateUserInput.getId());\n  2364→        checkValidations(updateUserInput, updateUserInput.getId());\n  2365→        updateFields(user, updateUserInput);\n  2366→        userRepository.update(modelValidator.validate(user));\n  2367→        return user;\n  2368→    }\n  2369→\n  2370→    private void updateFields(User user, UpdateUserInput updateUserInput) {\n  2371→        if (isPresent(updateUserInput.getUsername())) {\n  2372→            user.setUsername(updateUserInput.getUsername());\n  2373→        }\n  2374→\n  2375→        if (isPresent(updateUserInput.getEmail())) {\n  2376→            user.setEmail(updateUserInput.getEmail());\n  2377→        }\n  2378→\n  2379→        if (isPresent(updateUserInput.getBio())) {\n  2380→            user.setBio(updateUserInput.getBio());\n  2381→        }\n  2382→\n  2383→        if (isPresent(updateUserInput.getImage())) {\n  2384→            user.setImage(updateUserInput.getImage());\n  2385→        }\n  2386→    }\n  2387→\n  2388→    private void checkValidations(UpdateUserInput updateUserInput, UUID excludeId) {\n  2389→\n  2390→        if (isPresent(updateUserInput.getUsername())) {\n  2391→            checkUsername(excludeId, updateUserInput.getUsername());\n  2392→        }\n  2393→\n  2394→        if (isPresent(updateUserInput.getEmail())) {\n  2395→            checkEmail(excludeId, updateUserInput.getEmail());\n  2396→        }\n  2397→    }\n  2398→\n  2399→    private boolean isPresent(String property) {\n  2400→        return property != null && !property.isEmpty();\n  2401→    }\n  2402→\n  2403→    private void checkUsername(UUID selfId, String username) {\n  2404→        if (userRepository.existsUsername(selfId, username)) {\n  2405→            throw new UsernameAlreadyExistsException();\n  2406→        }\n  2407→    }\n  2408→\n  2409→    private void checkEmail(UUID selfId, String email) {\n  2410→        if (userRepository.existsEmail(selfId, email)) {\n  2411→            throw new EmailAlreadyExistsException();\n  2412→        }\n  2413→    }\n  2414→}\n  2415→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions abo