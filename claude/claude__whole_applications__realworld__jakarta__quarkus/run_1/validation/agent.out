indCommentsByArticleSlug {\n  1245→  List<Comment> handle(String slug);\n  1246→}\n  1247→\n  1248→==========================================\n  1249→FILE: src/main/java/org/example/realworldapi/domain/feature/FindMostRecentArticlesByFilter.java\n  1250→==========================================\n  1251→package org.example.realworldapi.domain.feature;\n  1252→\n  1253→import org.example.realworldapi.domain.model.article.Article;\n  1254→import org.example.realworldapi.domain.model.article.ArticleFilter;\n  1255→import org.example.realworldapi.domain.model.article.PageResult;\n  1256→\n  1257→public interface FindMostRecentArticlesByFilter {\n  1258→  PageResult<Article> handle(ArticleFilter articleFilter);\n  1259→}\n  1260→\n  1261→==========================================\n  1262→FILE: src/main/java/org/example/realworldapi/domain/feature/FindTags.java\n  1263→==========================================\n  1264→package org.example.realworldapi.domain.feature;\n  1265→\n  1266→import org.example.realworldapi.domain.model.tag.Tag;\n  1267→\n  1268→import java.util.List;\n  1269→\n  1270→public interface FindTags {\n  1271→  List<Tag> handle();\n  1272→}\n  1273→\n  1274→==========================================\n  1275→FILE: src/main/java/org/example/realworldapi/domain/feature/FindTagsByNameCreateIfNotExists.java\n  1276→==========================================\n  1277→package org.example.realworldapi.domain.feature;\n  1278→\n  1279→import org.example.realworldapi.domain.model.tag.Tag;\n  1280→\n  1281→import java.util.List;\n  1282→\n  1283→public interface FindTagsByNameCreateIfNotExists {\n  1284→  List<Tag> handle(List<String> names);\n  1285→}\n  1286→\n  1287→==========================================\n  1288→FILE: src/main/java/org/example/realworldapi/domain/feature/FindUserById.java\n  1289→==========================================\n  1290→package org.example.realworldapi.domain.feature;\n  1291→\n  1292→import org.example.realworldapi.domain.model.user.User;\n  1293→\n  1294→import java.util.UUID;\n  1295→\n  1296→public interface FindUserById {\n  1297→  User handle(UUID id);\n  1298→}\n  1299→\n  1300→==========================================\n  1301→FILE: src/main/java/org/example/realworldapi/domain/feature/FindUserByUsername.java\n  1302→==========================================\n  1303→package org.example.realworldapi.domain.feature;\n  1304→\n  1305→import org.example.realworldapi.domain.model.user.User;\n  1306→\n  1307→public interface FindUserByUsername {\n  1308→  User handle(String username);\n  1309→}\n  1310→\n  1311→==========================================\n  1312→FILE: src/main/java/org/example/realworldapi/domain/feature/FollowUserByUsername.java\n  1313→==========================================\n  1314→package org.example.realworldapi.domain.feature;\n  1315→\n  1316→import org.example.realworldapi.domain.model.user.FollowRelationship;\n  1317→\n  1318→import java.util.UUID;\n  1319→\n  1320→public interface FollowUserByUsername {\n  1321→  FollowRelationship handle(UUID loggedUserId, String username);\n  1322→}\n  1323→\n  1324→==========================================\n  1325→FILE: src/main/java/org/example/realworldapi/domain/feature/IsArticleFavorited.java\n  1326→==========================================\n  1327→package org.example.realworldapi.domain.feature;\n  1328→\n  1329→import org.example.realworldapi.domain.model.article.Article;\n  1330→\n  1331→import java.util.UUID;\n  1332→\n  1333→public interface IsArticleFavorited {\n  1334→  boolean handle(Article article, UUID currentUserId);\n  1335→}\n  1336→\n  1337→==========================================\n  1338→FILE: src/main/java/org/example/realworldapi/domain/feature/IsFollowingUser.java\n  1339→==========================================\n  1340→package org.example.realworldapi.domain.feature;\n  1341→\n  1342→import java.util.UUID;\n  1343→\n  1344→public interface IsFollowingUser {\n  1345→  boolean handle(UUID currentUserId, UUID followedUserId);\n  1346→}\n  1347→\n  1348→==========================================\n  1349→FILE: src/main/java/org/example/realworldapi/domain/feature/LoginUser.java\n  1350→==========================================\n  1351→package org.example.realworldapi.domain.feature;\n  1352→\n  1353→import org.example.realworldapi.domain.model.user.LoginUserInput;\n  1354→import org.example.realworldapi.domain.model.user.User;\n  1355→\n  1356→public interface LoginUser {\n  1357→  User handle(LoginUserInput loginUserInput);\n  1358→}\n  1359→\n  1360→==========================================\n  1361→FILE: src/main/java/org/example/realworldapi/domain/feature/UnfavoriteArticle.java\n  1362→==========================================\n  1363→package org.example.realworldapi.domain.feature;\n  1364→\n  1365→import java.util.UUID;\n  1366→\n  1367→public interface UnfavoriteArticle {\n  1368→  void handle(String articleSlug, UUID currentUserId);\n  1369→}\n  1370→\n  1371→==========================================\n  1372→FILE: src/main/java/org/example/realworldapi/domain/feature/UnfollowUserByUsername.java\n  1373→==========================================\n  1374→package org.example.realworldapi.domain.feature;\n  1375→\n  1376→import java.util.UUID;\n  1377→\n  1378→public interface UnfollowUserByUsername {\n  1379→  void handle(UUID loggedUserId, String username);\n  1380→}\n  1381→\n  1382→==========================================\n  1383→FILE: src/main/java/org/example/realworldapi/domain/feature/UpdateArticleBySlug.java\n  1384→==========================================\n  1385→package org.example.realworldapi.domain.feature;\n  1386→\n  1387→import org.example.realworldapi.domain.model.article.Article;\n  1388→import org.example.realworldapi.domain.model.article.UpdateArticleInput;\n  1389→\n  1390→public interface UpdateArticleBySlug {\n  1391→  Article handle(UpdateArticleInput updateArticleInput);\n  1392→}\n  1393→\n  1394→==========================================\n  1395→FILE: src/main/java/org/example/realworldapi/domain/feature/UpdateUser.java\n  1396→==========================================\n  1397→package org.example.realworldapi.domain.feature;\n  1398→\n  1399→import org.example.realworldapi.domain.model.user.UpdateUserInput;\n  1400→import org.example.realworldapi.domain.model.user.User;\n  1401→\n  1402→public interface UpdateUser {\n  1403→  User handle(UpdateUserInput updateUserInput);\n  1404→}\n  1405→\n  1406→==========================================\n  1407→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/ArticleFavoritesCountImpl.java\n  1408→==========================================\n  1409→package org.example.realworldapi.domain.feature.impl;\n  1410→\n  1411→import jakarta.inject.Inject;\n  1412→import jakarta.inject.Singleton;\n  1413→import org.example.realworldapi.domain.feature.ArticleFavoritesCount;\n  1414→import org.example.realworldapi.domain.feature.FindArticleById;\n  1415→import org.example.realworldapi.domain.model.article.FavoriteRelationshipRepository;\n  1416→\n  1417→import java.util.UUID;\n  1418→\n  1419→@Singleton\n  1420→public class ArticleFavoritesCountImpl implements ArticleFavoritesCount {\n  1421→\n  1422→    @Inject\n  1423→    private FindArticleById findArticleById;\n  1424→    @Inject\n  1425→    private FavoriteRelationshipRepository favoriteRelationshipRepository;\n  1426→\n  1427→    @Override\n  1428→    public long handle(UUID articleId) {\n  1429→        final var article = findArticleById.handle(articleId);\n  1430→        return favoriteRelationshipRepository.favoritesCount(article);\n  1431→    }\n  1432→}\n  1433→\n  1434→==========================================\n  1435→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/CreateArticleImpl.java\n  1436→==========================================\n  1437→package org.example.realworldapi.domain.feature.impl;\n  1438→\n  1439→import jakarta.inject.Inject;\n  1440→import jakarta.inject.Singleton;\n  1441→import org.example.realworldapi.domain.feature.CreateArticle;\n  1442→import org.example.realworldapi.domain.feature.CreateSlugByTitle;\n  1443→import org.example.realworldapi.domain.feature.FindTagsByNameCreateIfNotExists;\n  1444→import org.example.realworldapi.domain.feature.FindUserById;\n  1445→import org.example.realworldapi.domain.model.article.*;\n  1446→import org.example.realworldapi.domain.model.tag.Tag;\n  1447→\n  1448→import java.util.List;\n  1449→\n  1450→@Singleton\n  1451→public class CreateArticleImpl implements CreateArticle {\n  1452→\n  1453→    @Inject\n  1454→    private FindUserById findUserById;\n  1455→    @Inject\n  1456→    private ArticleRepository articleRepository;\n  1457→    @Inject\n  1458→    private ArticleModelBuilder articleBuilder;\n  1459→    @Inject\n  1460→    private CreateSlugByTitle createSlugByTitle;\n  1461→    @Inject\n  1462→    private FindTagsByNameCreateIfNotExists findTagsByNameCreateIfNotExists;\n  1463→    @Inject\n  1464→    private TagRelationshipRepository tagRelationshipRepository;\n  1465→\n  1466→    @Override\n  1467→    public Article handle(NewArticleInput newArticleInput) {\n  1468→        final var author = findUserById.handle(newArticleInput.getAuthorId());\n  1469→        final var slug = createSlugByTitle.handle(newArticleInput.getTitle());\n  1470→        final var article =\n  1471→                articleBuilder.build(\n  1472→                        slug,\n  1473→                        newArticleInput.getTitle(),\n  1474→                        newArticleInput.getDescription(),\n  1475→                        newArticleInput.getBody(),\n  1476→                        author);\n  1477→        articleRepository.save(article);\n  1478→        List<String> tagList = newArticleInput.getTagList();\n  1479→        if (tagList != null && !tagList.isEmpty()) {\n  1480→            final List<Tag> tags = findTagsByNameCreateIfNotExists.handle(newArticleInput.getTagList());\n  1481→            createTagRelationship(article, tags);\n  1482→        }\n  1483→        return article;\n  1484→    }\n  1485→\n  1486→    private void createTagRelationship(Article article, List<Tag> tags) {\n  1487→        tags.forEach(tag -> tagRelationshipRepository.save(new TagRelationship(article, tag)));\n  1488→    }\n  1489→}\n  1490→\n  1491→==========================================\n  1492→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/CreateCommentImpl.java\n  1493→==========================================\n  1494→package org.example.realworldapi.domain.feature.impl;\n  1495→\n  1496→import jakarta.inject.Inject;\n  1497→import jakarta.inject.Singleton;\n  1498→import org.example.realworldapi.domain.feature.CreateComment;\n  1499→import org.example.realworldapi.domain.feature.FindArticleBySlug;\n  1500→import org.example.realworldapi.domain.feature.FindUserById;\n  1501→import org.example.realworldapi.domain.model.comment.Comment;\n  1502→import org.example.realworldapi.domain.model.comment.CommentBuilder;\n  1503→import org.example.realworldapi.domain.model.comment.CommentRepository;\n  1504→import org.example.realworldapi.domain.model.comment.NewCommentInput;\n  1505→\n  1506→@Singleton\n  1507→public class CreateCommentImpl implements CreateComment {\n  1508→\n  1509→    @Inject\n  1510→    private CommentRepository commentRepository;\n  1511→    @Inject\n  1512→    private FindUserById findUserById;\n  1513→    @Inject\n  1514→    private FindArticleBySlug findArticleBySlug;\n  1515→    @Inject\n  1516→    private CommentBuilder commentBuilder;\n  1517→\n  1518→    @Override\n  1519→    public Comment handle(NewCommentInput newCommentInput) {\n  1520→        final var author = findUserById.handle(newCommentInput.getAuthorId());\n  1521→        final var article = findArticleBySlug.handle(newCommentInput.getArticleSlug());\n  1522→        final var comment = commentBuilder.build(author, article, newCommentInput.getBody());\n  1523→        commentRepository.save(comment);\n  1524→        return comment;\n  1525→    }\n  1526→}\n  1527→\n  1528→==========================================\n  1529→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/CreateSlugByTitleImpl.java\n  1530→==========================================\n  1531→package org.example.realworldapi.domain.feature.impl;\n  1532→\n  1533→import jakarta.inject.Inject;\n  1534→import jakarta.inject.Singleton;\n  1535→import org.example.realworldapi.domain.feature.CreateSlugByTitle;\n  1536→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1537→import org.example.realworldapi.domain.model.provider.SlugProvider;\n  1538→\n  1539→import java.util.UUID;\n  1540→\n  1541→@Singleton\n  1542→public class CreateSlugByTitleImpl implements CreateSlugByTitle {\n  1543→\n  1544→    @Inject\n  1545→    private ArticleRepository articleRepository;\n  1546→    @Inject\n  1547→    private SlugProvider slugProvider;\n  1548→\n  1549→    @Override\n  1550→    public String handle(String title) {\n  1551→        String slug = slugProvider.slugify(title);\n  1552→        if (articleRepository.existsBySlug(slug)) {\n  1553→            slug += UUID.randomUUID().toString();\n  1554→        }\n  1555→        return slug;\n  1556→    }\n  1557→}\n  1558→\n  1559→==========================================\n  1560→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/CreateTagImpl.java\n  1561→==========================================\n  1562→package org.example.realworldapi.domain.feature.impl;\n  1563→\n  1564→import jakarta.inject.Inject;\n  1565→import jakarta.inject.Singleton;\n  1566→import org.example.realworldapi.domain.feature.CreateTag;\n  1567→import org.example.realworldapi.domain.model.tag.Tag;\n  1568→import org.example.realworldapi.domain.model.tag.TagBuilder;\n  1569→import org.example.realworldapi.domain.model.tag.TagRepository;\n  1570→\n  1571→@Singleton\n  1572→public class CreateTagImpl implements CreateTag {\n  1573→\n  1574→    @Inject\n  1575→    private TagRepository tagRepository;\n  1576→    @Inject\n  1577→    private TagBuilder tagBuilder;\n  1578→\n  1579→    @Override\n  1580→    public Tag handle(String name) {\n  1581→        final var tag = tagBuilder.build(name);\n  1582→        tagRepository.save(tag);\n  1583→        return tag;\n  1584→    }\n  1585→}\n  1586→\n  1587→==========================================\n  1588→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/CreateUserImpl.java\n  1589→==========================================\n  1590→package org.example.realworldapi.domain.feature.impl;\n  1591→\n  1592→import jakarta.inject.Inject;\n  1593→import jakarta.inject.Singleton;\n  1594→import org.example.realworldapi.domain.exception.EmailAlreadyExistsException;\n  1595→import org.example.realworldapi.domain.exception.UsernameAlreadyExistsException;\n  1596→import org.example.realworldapi.domain.feature.CreateUser;\n  1597→import org.example.realworldapi.domain.model.provider.HashProvider;\n  1598→import org.example.realworldapi.domain.model.user.CreateUserInput;\n  1599→import org.example.realworldapi.domain.model.user.User;\n  1600→import org.example.realworldapi.domain.model.user.UserModelBuilder;\n  1601→import org.example.realworldapi.domain.model.user.UserRepository;\n  1602→\n  1603→@Singleton\n  1604→public class CreateUserImpl implements CreateUser {\n  1605→\n  1606→    @Inject\n  1607→    private UserRepository userRepository;\n  1608→    @Inject\n  1609→    private HashProvider hashProvider;\n  1610→    @Inject\n  1611→    private UserModelBuilder userBuilder;\n  1612→\n  1613→    @Override\n  1614→    public User handle(CreateUserInput createUserInput) {\n  1615→        final var user =\n  1616→                userBuilder.build(\n  1617→                        createUserInput.getUsername(),\n  1618→                        createUserInput.getEmail(),\n  1619→                        createUserInput.getPassword());\n  1620→        checkExistingUsername(user.getUsername());\n  1621→        checkExistingEmail(user.getEmail());\n  1622→        user.setPassword(hashProvider.hashPassword(user.getPassword()));\n  1623→        userRepository.save(user);\n  1624→        return user;\n  1625→    }\n  1626→\n  1627→    private void checkExistingUsername(String username) {\n  1628→        if (userRepository.existsByUsername(username)) {\n  1629→            throw new UsernameAlreadyExistsException();\n  1630→        }\n  1631→    }\n  1632→\n  1633→    private void checkExistingEmail(String email) {\n  1634→        if (userRepository.existsByEmail(email)) {\n  1635→            throw new EmailAlreadyExistsException();\n  1636→        }\n  1637→    }\n  1638→}\n  1639→\n  1640→==========================================\n  1641→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/DeleteArticleBySlugImpl.java\n  1642→==========================================\n  1643→package org.example.realworldapi.domain.feature.impl;\n  1644→\n  1645→import jakarta.inject.Inject;\n  1646→import jakarta.inject.Singleton;\n  1647→import org.example.realworldapi.domain.feature.DeleteArticleBySlug;\n  1648→import org.example.realworldapi.domain.feature.FindArticleByAuthorAndSlug;\n  1649→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1650→import org.example.realworldapi.domain.model.article.FavoriteRelationship;\n  1651→import org.example.realworldapi.domain.model.article.FavoriteRelationshipRepository;\n  1652→import org.example.realworldapi.domain.model.article.TagRelationshipRepository;\n  1653→import org.example.realworldapi.domain.model.comment.Comment;\n  1654→import org.example.realworldapi.domain.model.comment.CommentRepository;\n  1655→\n  1656→import java.util.List;\n  1657→import java.util.Optional;\n  1658→import java.util.UUID;\n  1659→\n  1660→@Singleton\n  1661→public class DeleteArticleBySlugImpl implements DeleteArticleBySlug {\n  1662→\n  1663→    @Inject\n  1664→    private FindArticleByAuthorAndSlug findArticleByAuthorAndSlug;\n  1665→    @Inject\n  1666→    private ArticleRepository articleRepository;\n  1667→    @Inject\n  1668→    private TagRelationshipRepository tagRelationshipRepository;\n  1669→    @Inject\n  1670→    private CommentRepository commentRepository;\n  1671→    @Inject\n  1672→    private FavoriteRelationshipRepository favoriteRelationshipRepository;\n  1673→\n  1674→    @Override\n  1675→    public void handle(UUID authorId, String slug) {\n  1676→        final var article = findArticleByAuthorAndSlug.handle(authorId, slug);\n  1677→        tagRelationshipRepository.delete(article);\n  1678→        Optional<FavoriteRelationship> favorite = favoriteRelationshipRepository.findByArticleIdAndUserId(article.getId(), authorId);\n  1679→        favorite.ifPresent(favoriteRelationship -> favoriteRelationshipRepository.delete(favoriteRelationship));\n  1680→        List<Comment> comments = commentRepository.findCommentsByArticle(article);\n  1681→        comments.forEach(c -> commentRepository.delete(c));\n  1682→        articleRepository.delete(article);\n  1683→    }\n  1684→}\n  1685→\n  1686→==========================================\n  1687→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/DeleteCommentImpl.java\n  1688→==========================================\n  1689→package org.example.realworldapi.domain.feature.impl;\n  1690→\n  1691→import jakarta.inject.Inject;\n  1692→import jakarta.inject.Singleton;\n  1693→import org.example.realworldapi.domain.feature.DeleteComment;\n  1694→import org.example.realworldapi.domain.feature.FindCommentByIdAndAuthor;\n  1695→import org.example.realworldapi.domain.model.comment.CommentRepository;\n  1696→import org.example.realworldapi.domain.model.comment.DeleteCommentInput;\n  1697→\n  1698→@Singleton\n  1699→public class DeleteCommentImpl implements DeleteComment {\n  1700→\n  1701→    @Inject\n  1702→    private FindCommentByIdAndAuthor findCommentByIdAndAuthor;\n  1703→    @Inject\n  1704→    private CommentRepository commentRepository;\n  1705→\n  1706→    @Override\n  1707→    public void handle(DeleteCommentInput deleteCommentInput) {\n  1708→        final var comment =\n  1709→                findCommentByIdAndAuthor.handle(\n  1710→                        deleteCommentInput.getCommentId(), deleteCommentInput.getAuthorId());\n  1711→        commentRepository.delete(comment);\n  1712→    }\n  1713→}\n  1714→\n  1715→==========================================\n  1716→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FavoriteArticleImpl.java\n  1717→==========================================\n  1718→package org.example.realworldapi.domain.feature.impl;\n  1719→\n  1720→import jakarta.inject.Inject;\n  1721→import jakarta.inject.Singleton;\n  1722→import org.example.realworldapi.domain.feature.FavoriteArticle;\n  1723→import org.example.realworldapi.domain.feature.FindArticleBySlug;\n  1724→import org.example.realworldapi.domain.feature.FindUserById;\n  1725→import org.example.realworldapi.domain.model.article.Article;\n  1726→import org.example.realworldapi.domain.model.article.FavoriteRelationship;\n  1727→import org.example.realworldapi.domain.model.article.FavoriteRelationshipRepository;\n  1728→\n  1729→import java.util.UUID;\n  1730→\n  1731→@Singleton\n  1732→public class FavoriteArticleImpl implements FavoriteArticle {\n  1733→\n  1734→    @Inject\n  1735→    private FindArticleBySlug findArticleBySlug;\n  1736→    @Inject\n  1737→    private FindUserById findUserById;\n  1738→    @Inject\n  1739→    private FavoriteRelationshipRepository favoriteRelationshipRepository;\n  1740→\n  1741→    @Override\n  1742→    public FavoriteRelationship handle(String articleSlug, UUID currentUserId) {\n  1743→        final var article = findArticleBySlug.handle(articleSlug);\n  1744→        final var favoriteRelationshipOptional =\n  1745→                favoriteRelationshipRepository.findByArticleIdAndUserId(article.getId(), currentUserId);\n  1746→        return favoriteRelationshipOptional.orElseGet(() -> createFavoriteRelationship(currentUserId, article));\n  1747→    }\n  1748→\n  1749→    private FavoriteRelationship createFavoriteRelationship(UUID currentUserId, Article article) {\n  1750→        final var user = findUserById.handle(currentUserId);\n  1751→        final var favoriteRelationship = new FavoriteRelationship(user, article);\n  1752→        favoriteRelationshipRepository.save(favoriteRelationship);\n  1753→        return favoriteRelationship;\n  1754→    }\n  1755→}\n  1756→\n  1757→==========================================\n  1758→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindArticleByAuthorAndSlugImpl.java\n  1759→==========================================\n  1760→package org.example.realworldapi.domain.feature.impl;\n  1761→\n  1762→import jakarta.inject.Inject;\n  1763→import jakarta.inject.Singleton;\n  1764→import org.example.realworldapi.domain.exception.ArticleNotFoundException;\n  1765→import org.example.realworldapi.domain.feature.FindArticleByAuthorAndSlug;\n  1766→import org.example.realworldapi.domain.model.article.Article;\n  1767→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1768→\n  1769→import java.util.UUID;\n  1770→\n  1771→@Singleton\n  1772→public class FindArticleByAuthorAndSlugImpl implements FindArticleByAuthorAndSlug {\n  1773→\n  1774→    @Inject\n  1775→    private ArticleRepository articleRepository;\n  1776→\n  1777→    @Override\n  1778→    public Article handle(UUID authorId, String slug) {\n  1779→        return articleRepository\n  1780→                .findByAuthorAndSlug(authorId, slug)\n  1781→                .orElseThrow(ArticleNotFoundException::new);\n  1782→    }\n  1783→}\n  1784→\n  1785→==========================================\n  1786→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindArticleByIdImpl.java\n  1787→==========================================\n  1788→package org.example.realworldapi.domain.feature.impl;\n  1789→\n  1790→import jakarta.inject.Inject;\n  1791→import jakarta.inject.Singleton;\n  1792→import org.example.realworldapi.domain.exception.ArticleNotFoundException;\n  1793→import org.example.realworldapi.domain.feature.FindArticleById;\n  1794→import org.example.realworldapi.domain.model.article.Article;\n  1795→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1796→\n  1797→import java.util.UUID;\n  1798→\n  1799→@Singleton\n  1800→public class FindArticleByIdImpl implements FindArticleById {\n  1801→\n  1802→    @Inject\n  1803→    private ArticleRepository articleRepository;\n  1804→\n  1805→    @Override\n  1806→    public Article handle(UUID id) {\n  1807→        return articleRepository.findArticleById(id).orElseThrow(ArticleNotFoundException::new);\n  1808→    }\n  1809→}\n  1810→\n  1811→==========================================\n  1812→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindArticleBySlugImpl.java\n  1813→==========================================\n  1814→package org.example.realworldapi.domain.feature.impl;\n  1815→\n  1816→import jakarta.inject.Inject;\n  1817→import jakarta.inject.Singleton;\n  1818→import org.example.realworldapi.domain.exception.ArticleNotFoundException;\n  1819→import org.example.realworldapi.domain.feature.FindArticleBySlug;\n  1820→import org.example.realworldapi.domain.model.article.Article;\n  1821→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1822→\n  1823→@Singleton\n  1824→public class FindArticleBySlugImpl implements FindArticleBySlug {\n  1825→\n  1826→    @Inject\n  1827→    private ArticleRepository articleRepository;\n  1828→\n  1829→    @Override\n  1830→    public Article handle(String slug) {\n  1831→        return articleRepository.findBySlug(slug).orElseThrow(ArticleNotFoundException::new);\n  1832→    }\n  1833→}\n  1834→\n  1835→==========================================\n  1836→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindArticleTagsImpl.java\n  1837→==========================================\n  1838→package org.example.realworldapi.domain.feature.impl;\n  1839→\n  1840→import jakarta.inject.Inject;\n  1841→import jakarta.inject.Singleton;\n  1842→import org.example.realworldapi.domain.feature.FindArticleTags;\n  1843→import org.example.realworldapi.domain.model.article.Article;\n  1844→import org.example.realworldapi.domain.model.article.TagRelationshipRepository;\n  1845→import org.example.realworldapi.domain.model.tag.Tag;\n  1846→\n  1847→import java.util.List;\n  1848→\n  1849→@Singleton\n  1850→public class FindArticleTagsImpl implements FindArticleTags {\n  1851→\n  1852→    @Inject\n  1853→    private TagRelationshipRepository tagRelationshipRepository;\n  1854→\n  1855→    @Override\n  1856→    public List<Tag> handle(Article article) {\n  1857→        return tagRelationshipRepository.findArticleTags(article);\n  1858→    }\n  1859→}\n  1860→\n  1861→==========================================\n  1862→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindArticlesByFilterImpl.java\n  1863→==========================================\n  1864→package org.example.realworldapi.domain.feature.impl;\n  1865→\n  1866→import jakarta.inject.Inject;\n  1867→import jakarta.inject.Singleton;\n  1868→import org.example.realworldapi.domain.feature.FindArticlesByFilter;\n  1869→import org.example.realworldapi.domain.model.article.Article;\n  1870→import org.example.realworldapi.domain.model.article.ArticleFilter;\n  1871→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1872→import org.example.realworldapi.domain.model.article.PageResult;\n  1873→\n  1874→@Singleton\n  1875→public class FindArticlesByFilterImpl implements FindArticlesByFilter {\n  1876→\n  1877→    @Inject\n  1878→    private ArticleRepository articleRepository;\n  1879→\n  1880→    @Override\n  1881→    public PageResult<Article> handle(ArticleFilter articleFilter) {\n  1882→        return articleRepository.findArticlesByFilter(articleFilter);\n  1883→    }\n  1884→}\n  1885→\n  1886→==========================================\n  1887→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindCommentByIdAndAuthorImpl.java\n  1888→==========================================\n  1889→package org.example.realworldapi.domain.feature.impl;\n  1890→\n  1891→import jakarta.inject.Inject;\n  1892→import jakarta.inject.Singleton;\n  1893→import org.example.realworldapi.domain.exception.CommentNotFoundException;\n  1894→import org.example.realworldapi.domain.feature.FindCommentByIdAndAuthor;\n  1895→import org.example.realworldapi.domain.model.comment.Comment;\n  1896→import org.example.realworldapi.domain.model.comment.CommentRepository;\n  1897→\n  1898→import java.util.UUID;\n  1899→\n  1900→@Singleton\n  1901→public class FindCommentByIdAndAuthorImpl implements FindCommentByIdAndAuthor {\n  1902→\n  1903→    @Inject\n  1904→    private CommentRepository commentRepository;\n  1905→\n  1906→    @Override\n  1907→    public Comment handle(UUID commentId, UUID authorId) {\n  1908→        return commentRepository\n  1909→                .findByIdAndAuthor(commentId, authorId)\n  1910→                .orElseThrow(CommentNotFoundException::new);\n  1911→    }\n  1912→}\n  1913→\n  1914→==========================================\n  1915→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindCommentsByArticleSlugImpl.java\n  1916→==========================================\n  1917→package org.example.realworldapi.domain.feature.impl;\n  1918→\n  1919→import jakarta.inject.Inject;\n  1920→import jakarta.inject.Singleton;\n  1921→import org.example.realworldapi.domain.feature.FindArticleBySlug;\n  1922→import org.example.realworldapi.domain.feature.FindCommentsByArticleSlug;\n  1923→import org.example.realworldapi.domain.model.comment.Comment;\n  1924→import org.example.realworldapi.domain.model.comment.CommentRepository;\n  1925→\n  1926→import java.util.List;\n  1927→\n  1928→@Singleton\n  1929→public class FindCommentsByArticleSlugImpl implements FindCommentsByArticleSlug {\n  1930→\n  1931→    @Inject\n  1932→    private FindArticleBySlug findArticleBySlug;\n  1933→    @Inject\n  1934→    private CommentRepository commentRepository;\n  1935→\n  1936→    @Override\n  1937→    public List<Comment> handle(String slug) {\n  1938→        final var article = findArticleBySlug.handle(slug);\n  1939→        return commentRepository.findCommentsByArticle(article);\n  1940→    }\n  1941→}\n  1942→\n  1943→==========================================\n  1944→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindMostRecentArticlesByFilterImpl.java\n  1945→==========================================\n  1946→package org.example.realworldapi.domain.feature.impl;\n  1947→\n  1948→import jakarta.inject.Inject;\n  1949→import jakarta.inject.Singleton;\n  1950→import org.example.realworldapi.domain.feature.FindMostRecentArticlesByFilter;\n  1951→import org.example.realworldapi.domain.model.article.Article;\n  1952→import org.example.realworldapi.domain.model.article.ArticleFilter;\n  1953→import org.example.realworldapi.domain.model.article.ArticleRepository;\n  1954→import org.example.realworldapi.domain.model.article.PageResult;\n  1955→\n  1956→@Singleton\n  1957→public class FindMostRecentArticlesByFilterImpl implements FindMostRecentArticlesByFilter {\n  1958→\n  1959→    @Inject\n  1960→    private ArticleRepository articleRepository;\n  1961→\n  1962→    @Override\n  1963→    public PageResult<Article> handle(ArticleFilter articleFilter) {\n  1964→        return articleRepository.findMostRecentArticlesByFilter(articleFilter);\n  1965→    }\n  1966→}\n  1967→\n  1968→==========================================\n  1969→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindTagsByNameCreateIfNotExistsImpl.java\n  1970→==========================================\n  1971→package org.example.realworldapi.domain.feature.impl;\n  1972→\n  1973→import jakarta.inject.Inject;\n  1974→import jakarta.inject.Singleton;\n  1975→import org.example.realworldapi.domain.feature.CreateTag;\n  1976→import org.example.realworldapi.domain.feature.FindTagsByNameCreateIfNotExists;\n  1977→import org.example.realworldapi.domain.model.tag.Tag;\n  1978→import org.example.realworldapi.domain.model.tag.TagRepository;\n  1979→\n  1980→import java.util.LinkedList;\n  1981→import java.util.List;\n  1982→import java.util.stream.Collectors;\n  1983→\n  1984→@Singleton\n  1985→public class FindTagsByNameCreateIfNotExistsImpl implements FindTagsByNameCreateIfNotExists {\n  1986→\n  1987→    @Inject\n  1988→    private TagRepository tagRepository;\n  1989→    @Inject\n  1990→    private CreateTag createTag;\n  1991→\n  1992→    @Override\n  1993→    public List<Tag> handle(List<String> names) {\n  1994→        final var tags = tagRepository.findByNames(names);\n  1995→        tags.addAll(createTags(nonexistent(tags, names)));\n  1996→        return tags;\n  1997→    }\n  1998→\n  1999→    private List<Tag> createTags(List<String> names) {\n  2000→        final var tags = new LinkedList<Tag>();\n  2001→        names.forEach(name -> tags.add(createTag.handle(name)));\n  2002→        return tags;\n  2003→    }\n  2004→\n  2005→    private List<String> nonexistent(List<Tag> existing, List<String> allNames) {\n  2006→        return allNames.stream()\n  2007→                .filter(name -> existing.stream().noneMatch(tag -> tag.getName().equalsIgnoreCase(name)))\n  2008→                .collect(Collectors.toList());\n  2009→    }\n  2010→}\n  2011→\n  2012→==========================================\n  2013→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FindTagsImpl.java\n  2014→==========================================\n  2015→package or