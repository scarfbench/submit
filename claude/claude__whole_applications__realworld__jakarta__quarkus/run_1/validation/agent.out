→import java.util.LinkedList;\n   463→import java.util.List;\n   464→\n   465→@Getter\n   466→@Setter\n   467→@JsonRootName(\"errors\")\n   468→public class ErrorResponse {\n   469→\n   470→    private List<String> body;\n   471→\n   472→    public ErrorResponse() {\n   473→        this.body = new LinkedList<>();\n   474→    }\n   475→\n   476→    public ErrorResponse(String error) {\n   477→        this();\n   478→        this.body.add(error);\n   479→    }\n   480→\n   481→    public ErrorResponse(List<String> errors) {\n   482→        this.body = errors;\n   483→    }\n   484→}\n   485→\n   486→==========================================\n   487→FILE: src/main/java/org/example/realworldapi/application/web/model/response/ProfileResponse.java\n   488→==========================================\n   489→package org.example.realworldapi.application.web.model.response;\n   490→\n   491→import com.fasterxml.jackson.annotation.JsonRootName;\n   492→import lombok.Getter;\n   493→import lombok.Setter;\n   494→import org.example.realworldapi.domain.model.user.User;\n   495→\n   496→@Getter\n   497→@Setter\n   498→@JsonRootName(\"profile\")\n   499→public class ProfileResponse {\n   500→\n   501→    private String username;\n   502→    private String bio;\n   503→    private String image;\n   504→    private boolean following;\n   505→\n   506→    public ProfileResponse(User user) {\n   507→        this.username = user.getUsername();\n   508→        this.bio = user.getBio();\n   509→        this.image = user.getImage();\n   510→    }\n   511→}\n   512→\n   513→==========================================\n   514→FILE: src/main/java/org/example/realworldapi/application/web/model/response/TagsResponse.java\n   515→==========================================\n   516→package org.example.realworldapi.application.web.model.response;\n   517→\n   518→import lombok.Getter;\n   519→import lombok.Setter;\n   520→import org.example.realworldapi.domain.model.tag.Tag;\n   521→\n   522→import java.util.List;\n   523→import java.util.stream.Collectors;\n   524→\n   525→@Getter\n   526→@Setter\n   527→public class TagsResponse {\n   528→\n   529→    private List<String> tags;\n   530→\n   531→    public TagsResponse(List<Tag> tags) {\n   532→        this.tags = tags.stream().map(Tag::getName).collect(Collectors.toList());\n   533→    }\n   534→}\n   535→\n   536→==========================================\n   537→FILE: src/main/java/org/example/realworldapi/application/web/model/response/UserResponse.java\n   538→==========================================\n   539→package org.example.realworldapi.application.web.model.response;\n   540→\n   541→import com.fasterxml.jackson.annotation.JsonRootName;\n   542→import lombok.Getter;\n   543→import lombok.NoArgsConstructor;\n   544→import lombok.Setter;\n   545→import org.example.realworldapi.domain.model.user.User;\n   546→\n   547→@Getter\n   548→@Setter\n   549→@NoArgsConstructor\n   550→@JsonRootName(\"user\")\n   551→public class UserResponse {\n   552→\n   553→    private String username;\n   554→    private String bio;\n   555→    private String image;\n   556→    private String email;\n   557→    private String token;\n   558→\n   559→    public UserResponse(User user, String token) {\n   560→        this.username = user.getUsername();\n   561→        this.bio = user.getBio();\n   562→        this.image = user.getImage();\n   563→        this.email = user.getEmail();\n   564→        this.token = token;\n   565→    }\n   566→}\n   567→\n   568→==========================================\n   569→FILE: src/main/java/org/example/realworldapi/application/web/resource/ArticlesResource.java\n   570→==========================================\n   571→package org.example.realworldapi.application.web.resource;\n   572→\n   573→import com.fasterxml.jackson.core.JsonProcessingException;\n   574→import com.fasterxml.jackson.databind.ObjectMapper;\n   575→import jakarta.inject.Inject;\n   576→import jakarta.transaction.Transactional;\n   577→import jakarta.validation.Valid;\n   578→import jakarta.validation.constraints.NotBlank;\n   579→import jakarta.validation.constraints.NotNull;\n   580→import jakarta.ws.rs.*;\n   581→import jakarta.ws.rs.core.Context;\n   582→import jakarta.ws.rs.core.MediaType;\n   583→import jakarta.ws.rs.core.Response;\n   584→import jakarta.ws.rs.core.SecurityContext;\n   585→import org.example.realworldapi.application.web.model.request.NewArticleRequestWrapper;\n   586→import org.example.realworldapi.application.web.model.request.NewCommentRequestWrapper;\n   587→import org.example.realworldapi.application.web.model.request.UpdateArticleRequestWrapper;\n   588→import org.example.realworldapi.application.web.resource.utils.ResourceUtils;\n   589→import org.example.realworldapi.domain.feature.*;\n   590→import org.example.realworldapi.domain.model.article.ArticleFilter;\n   591→import org.example.realworldapi.domain.model.comment.DeleteCommentInput;\n   592→import org.example.realworldapi.domain.model.constants.ValidationMessages;\n   593→import org.example.realworldapi.infrastructure.web.qualifiers.NoWrapRootValueObjectMapper;\n   594→import org.example.realworldapi.infrastructure.web.security.annotation.Secured;\n   595→import org.example.realworldapi.infrastructure.web.security.profile.Role;\n   596→\n   597→import java.util.List;\n   598→import java.util.UUID;\n   599→\n   600→@Path(\"/articles\")\n   601→public class ArticlesResource {\n   602→\n   603→    @Inject\n   604→    private FindArticlesByFilter findArticlesByFilter;\n   605→    @Inject\n   606→    private CreateArticle createArticle;\n   607→    @Inject\n   608→    private FindMostRecentArticlesByFilter findMostRecentArticlesByFilter;\n   609→    @Inject\n   610→    private FindArticleBySlug findArticleBySlug;\n   611→    @Inject\n   612→    private UpdateArticleBySlug updateArticleBySlug;\n   613→    @Inject\n   614→    private DeleteArticleBySlug deleteArticleBySlug;\n   615→    @Inject\n   616→    private CreateComment createComment;\n   617→    @Inject\n   618→    private DeleteComment deleteComment;\n   619→    @Inject\n   620→    private FindCommentsByArticleSlug findCommentsByArticleSlug;\n   621→    @Inject\n   622→    private FavoriteArticle favoriteArticle;\n   623→    @Inject\n   624→    private UnfavoriteArticle unfavoriteArticle;\n   625→    @Inject\n   626→    private ResourceUtils resourceUtils;\n   627→    @Inject\n   628→    ObjectMapper objectMapper;\n   629→    @Inject\n   630→    @NoWrapRootValueObjectMapper\n   631→    ObjectMapper noWrapObjectMapper;\n   632→\n   633→\n   634→    @GET\n   635→    @Path(\"/feed\")\n   636→    @Secured({Role.USER, Role.ADMIN})\n   637→    @Produces(MediaType.APPLICATION_JSON)\n   638→    public Response feed(\n   639→            @QueryParam(\"offset\") int offset,\n   640→            @QueryParam(\"limit\") int limit,\n   641→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   642→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   643→        final var articlesFilter =\n   644→                new ArticleFilter(offset, resourceUtils.getLimit(limit), loggedUserId, null, null, null);\n   645→        final var articlesPageResult = findMostRecentArticlesByFilter.handle(articlesFilter);\n   646→        return Response.ok(noWrapObjectMapper.writeValueAsString(resourceUtils.articlesResponse(articlesPageResult, loggedUserId)))\n   647→                .status(Response.Status.OK)\n   648→                .build();\n   649→    }\n   650→\n   651→    @GET\n   652→    @Produces(MediaType.APPLICATION_JSON)\n   653→    @Secured(optional = true)\n   654→    public Response getArticles(\n   655→            @QueryParam(\"offset\") int offset,\n   656→            @QueryParam(\"limit\") int limit,\n   657→            @QueryParam(\"tag\") List<String> tags,\n   658→            @QueryParam(\"author\") List<String> authors,\n   659→            @QueryParam(\"favorited\") List<String> favorited,\n   660→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   661→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   662→        final var filter =\n   663→                new ArticleFilter(\n   664→                        offset, resourceUtils.getLimit(limit), loggedUserId, tags, authors, favorited);\n   665→        final var articlesPageResult = findArticlesByFilter.handle(filter);\n   666→        return Response.ok(noWrapObjectMapper.writeValueAsString(resourceUtils.articlesResponse(articlesPageResult, loggedUserId)))\n   667→                .status(Response.Status.OK)\n   668→                .build();\n   669→    }\n   670→\n   671→    @POST\n   672→    @Transactional\n   673→    @Secured({Role.ADMIN, Role.USER})\n   674→    @Consumes(MediaType.APPLICATION_JSON)\n   675→    @Produces(MediaType.APPLICATION_JSON)\n   676→    public Response create(\n   677→            @Valid\n   678→            NewArticleRequestWrapper newArticleRequest,\n   679→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   680→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   681→        final var article = createArticle.handle(newArticleRequest.getArticle().toNewArticleInput(loggedUserId));\n   682→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.articleResponse(article, loggedUserId)))\n   683→                .status(Response.Status.CREATED)\n   684→                .build();\n   685→    }\n   686→\n   687→    @GET\n   688→    @Path(\"/{slug}\")\n   689→    @Produces(MediaType.APPLICATION_JSON)\n   690→    public Response findBySlug(\n   691→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK)\n   692→            String slug) throws JsonProcessingException {\n   693→        final var article = findArticleBySlug.handle(slug);\n   694→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.articleResponse(article, null)))\n   695→                .status(Response.Status.OK)\n   696→                .build();\n   697→    }\n   698→\n   699→    @PUT\n   700→    @Transactional\n   701→    @Path(\"/{slug}\")\n   702→    @Secured({Role.ADMIN, Role.USER})\n   703→    @Consumes(MediaType.APPLICATION_JSON)\n   704→    @Produces(MediaType.APPLICATION_JSON)\n   705→    public Response update(\n   706→            @PathParam(\"slug\") @NotBlank String slug,\n   707→            @Valid UpdateArticleRequestWrapper updateArticleRequest,\n   708→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   709→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   710→        final var updatedArticle =\n   711→                updateArticleBySlug.handle(updateArticleRequest.getArticle().toUpdateArticleInput(loggedUserId, slug));\n   712→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.articleResponse(updatedArticle, null)))\n   713→                .status(Response.Status.OK)\n   714→                .build();\n   715→    }\n   716→\n   717→    @DELETE\n   718→    @Transactional\n   719→    @Path(\"/{slug}\")\n   720→    @Secured({Role.ADMIN, Role.USER})\n   721→    @Produces(MediaType.APPLICATION_JSON)\n   722→    public Response delete(\n   723→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   724→            @Context SecurityContext securityContext) {\n   725→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   726→        deleteArticleBySlug.handle(loggedUserId, slug);\n   727→        return Response.ok().build();\n   728→    }\n   729→\n   730→    @GET\n   731→    @Path(\"/{slug}/comments\")\n   732→    @Secured(optional = true)\n   733→    @Produces(MediaType.APPLICATION_JSON)\n   734→    public Response getCommentsBySlug(\n   735→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   736→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   737→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   738→        final var comments = findCommentsByArticleSlug.handle(slug);\n   739→        return Response.ok(noWrapObjectMapper.writeValueAsString(resourceUtils.commentsResponse(comments, loggedUserId)))\n   740→                .status(Response.Status.OK)\n   741→                .build();\n   742→    }\n   743→\n   744→    @POST\n   745→    @Transactional\n   746→    @Path(\"/{slug}/comments\")\n   747→    @Secured({Role.ADMIN, Role.USER})\n   748→    @Consumes(MediaType.APPLICATION_JSON)\n   749→    @Produces(MediaType.APPLICATION_JSON)\n   750→    public Response createComment(\n   751→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   752→            @Valid NewCommentRequestWrapper newCommentRequest,\n   753→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   754→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   755→        final var comment =\n   756→                createComment.handle(newCommentRequest.getComment().toNewCommentInput(loggedUserId, slug));\n   757→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.commentResponse(comment, loggedUserId)))\n   758→                .status(Response.Status.OK)\n   759→                .build();\n   760→    }\n   761→\n   762→    @DELETE\n   763→    @Transactional\n   764→    @Path(\"/{slug}/comments/{id}\")\n   765→    @Secured({Role.ADMIN, Role.USER})\n   766→    @Produces(MediaType.APPLICATION_JSON)\n   767→    public Response deleteComment(\n   768→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   769→            @PathParam(\"id\") @NotNull(message = ValidationMessages.COMMENT_ID_MUST_BE_NOT_NULL) UUID id,\n   770→            @Context SecurityContext securityContext) {\n   771→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   772→        deleteComment.handle(new DeleteCommentInput(id, loggedUserId, slug));\n   773→        return Response.ok().build();\n   774→    }\n   775→\n   776→    @POST\n   777→    @Transactional\n   778→    @Path(\"/{slug}/favorite\")\n   779→    @Secured({Role.ADMIN, Role.USER})\n   780→    @Produces(MediaType.APPLICATION_JSON)\n   781→    public Response favoriteArticle(\n   782→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   783→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   784→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   785→        favoriteArticle.handle(slug, loggedUserId);\n   786→        final var article = findArticleBySlug.handle(slug);\n   787→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.articleResponse(article, loggedUserId)))\n   788→                .status(Response.Status.OK)\n   789→                .build();\n   790→    }\n   791→\n   792→    @DELETE\n   793→    @Transactional\n   794→    @Path(\"/{slug}/favorite\")\n   795→    @Secured({Role.ADMIN, Role.USER})\n   796→    @Produces(MediaType.APPLICATION_JSON)\n   797→    public Response unfavoriteArticle(\n   798→            @PathParam(\"slug\") @NotBlank(message = ValidationMessages.SLUG_MUST_BE_NOT_BLANK) String slug,\n   799→            @Context SecurityContext securityContext) throws JsonProcessingException {\n   800→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n   801→        unfavoriteArticle.handle(slug, loggedUserId);\n   802→        final var article = findArticleBySlug.handle(slug);\n   803→        return Response.ok(objectMa