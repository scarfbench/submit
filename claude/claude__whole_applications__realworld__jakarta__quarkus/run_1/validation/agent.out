;\n  2067→\n  2068→import jakarta.enterprise.context.Dependent;\n  2069→import jakarta.inject.Inject;\n  2070→import org.example.realworldapi.domain.exception.UserNotFoundException;\n  2071→import org.example.realworldapi.domain.feature.FindUserByUsername;\n  2072→import org.example.realworldapi.domain.model.user.User;\n  2073→import org.example.realworldapi.domain.model.user.UserRepository;\n  2074→\n  2075→@Dependent\n  2076→public class FindUserByUsernameImpl implements FindUserByUsername {\n  2077→\n  2078→    @Inject\n  2079→    private UserRepository userRepository;\n  2080→\n  2081→    @Override\n  2082→    public User handle(String username) {\n  2083→        return userRepository.findByUsername(username).orElseThrow(UserNotFoundException::new);\n  2084→    }\n  2085→}\n  2086→\n  2087→==========================================\n  2088→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/FollowUserByUsernameImpl.java\n  2089→==========================================\n  2090→package org.example.realworldapi.domain.feature.impl;\n  2091→\n  2092→import jakarta.inject.Inject;\n  2093→import jakarta.inject.Singleton;\n  2094→import org.example.realworldapi.domain.feature.FindUserById;\n  2095→import org.example.realworldapi.domain.feature.FindUserByUsername;\n  2096→import org.example.realworldapi.domain.feature.FollowUserByUsername;\n  2097→import org.example.realworldapi.domain.model.user.FollowRelationship;\n  2098→import org.example.realworldapi.domain.model.user.FollowRelationshipRepository;\n  2099→\n  2100→import java.util.UUID;\n  2101→\n  2102→@Singleton\n  2103→public class FollowUserByUsernameImpl implements FollowUserByUsername {\n  2104→\n  2105→    @Inject\n  2106→    private FindUserById findUserById;\n  2107→    @Inject\n  2108→    private FindUserByUsername findUserByUsername;\n  2109→    @Inject\n  2110→    private FollowRelationshipRepository usersFollowedRepository;\n  2111→\n  2112→    @Override\n  2113→    public FollowRelationship handle(UUID loggedUserId, String username) {\n  2114→        final var loggedUser = findUserById.handle(loggedUserId);\n  2115→        final var userToFollow = findUserByUsername.handle(username);\n  2116→        final var followingRelationship = new FollowRelationship(loggedUser, userToFollow);\n  2117→        usersFollowedRepository.save(followingRelationship);\n  2118→        return followingRelationship;\n  2119→    }\n  2120→}\n  2121→\n  2122→==========================================\n  2123→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/IsArticleFavoritedImpl.java\n  2124→==========================================\n  2125→package org.example.realworldapi.domain.feature.impl;\n  2126→\n  2127→import jakarta.inject.Inject;\n  2128→import jakarta.inject.Singleton;\n  2129→import org.example.realworldapi.domain.feature.IsArticleFavorited;\n  2130→import org.example.realworldapi.domain.model.article.Article;\n  2131→import org.example.realworldapi.domain.model.article.FavoriteRelationshipRepository;\n  2132→\n  2133→import java.util.UUID;\n  2134→\n  2135→@Singleton\n  2136→public class IsArticleFavoritedImpl implements IsArticleFavorited {\n  2137→\n  2138→    @Inject\n  2139→    private FavoriteRelationshipRepository favoriteRelationshipRepository;\n  2140→\n  2141→    @Override\n  2142→    public boolean handle(Article article, UUID currentUserId) {\n  2143→        return favoriteRelationshipRepository.isFavorited(article, currentUserId);\n  2144→    }\n  2145→}\n  2146→\n  2147→==========================================\n  2148→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/IsFollowingUserImpl.java\n  2149→==========================================\n  2150→package org.example.realworldapi.domain.feature.impl;\n  2151→\n  2152→import jakarta.enterprise.context.Dependent;\n  2153→import jakarta.inject.Inject;\n  2154→import org.example.realworldapi.domain.feature.IsFollowingUser;\n  2155→import org.example.realworldapi.domain.model.user.FollowRelationshipRepository;\n  2156→\n  2157→import java.util.UUID;\n  2158→\n  2159→@Dependent\n  2160→public class IsFollowingUserImpl implements IsFollowingUser {\n  2161→\n  2162→    @Inject\n  2163→    private FollowRelationshipRepository usersFollowedRepository;\n  2164→\n  2165→    @Override\n  2166→    public boolean handle(UUID currentUserId, UUID followedUserId) {\n  2167→        return usersFollowedRepository.isFollowing(currentUserId, followedUserId);\n  2168→    }\n  2169→}\n  2170→\n  2171→==========================================\n  2172→FILE: src/main/java/org/example/realworldapi/domain/feature/impl/LoginUserImpl.java\n  2173→==========================================\n  2174→package org.example.realworldapi.domain.feature.impl;\n  2175→\n  2176→import jakarta.inject.Inject;\n  2177→import jakarta.inject.Singleton;\n  2178→import org.example.realworldapi.domain.exception.InvalidPasswordException;\n  2179→import org.example.realworldapi.domain.exception.UserNotFoundException;\n  2180→import org.example.realworldapi.domain.feature.LoginUser;\n  2181→import org.example.realworldapi.domain.model.provider.HashProvider;\n  2182→import org.example.realworldapi.domain.model.user.LoginUserInput;\n  2183→import org.example.realworldapi.domain.model.user.User;\n  2184→import org.example.realworldapi.domain.model.user.UserRepository;\n  2185→\n  2186→@Singleton\n  2187→public class LoginUserImpl implements LoginUser {\n  2188→\n  2189→    @Inject\n  2190→    private UserRepository userRepository;\n  2191→    @Inject\n  2192→    private HashProvider hashProvider;\n  2193→\n  2194→    @Override\n  2195→    public User handle(LoginUserInput loginUserInput) {\n  2196→        final var user =\n  2197→                userRepository\n  2198→                        .findByEmail(loginUserInput.getEmail())\n  2199→                        .orElseThrow(UserNotFoundException::new);\n  2200→        if (!isPasswordValid(loginUserInput.getPassword(), user.g