serId(securityContext);\n   882→        unfollowUserByUsername.handle(loggedUserId, username);\n   883→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.profileResponse(username, loggedUserId)))\n   884→                .status(Response.Status.OK)\n   885→                .build();\n   886→    }\n   887→}\n   888→\n   889→==========================================\n   890→FILE: src/main/java/org/example/realworldapi/application/web/resource/TagsResource.java\n   891→==========================================\n   892→package org.example.realworldapi.application.web.resource;\n   893→\n   894→import jakarta.inject.Inject;\n   895→import jakarta.ws.rs.GET;\n   896→import jakarta.ws.rs.Path;\n   897→import jakarta.ws.rs.Produces;\n   898→import jakarta.ws.rs.core.MediaType;\n   899→import jakarta.ws.rs.core.Response;\n   900→import org.example.realworldapi.application.web.model.response.TagsResponse;\n   901→import org.example.realworldapi.domain.feature.FindTags;\n   902→import org.example.realworldapi.domain.model.tag.Tag;\n   903→\n   904→import java.util.List;\n   905→\n   906→@Path(\"/tags\")\n   907→public class TagsResource {\n   908→\n   909→    @Inject\n   910→    private FindTags findTags;\n   911→\n   912→    @GET\n   913→    @Produces(MediaType.APPLICATION_JSON)\n   914→    public Response getTags() {\n   915→        List<Tag> tags = findTags.handle();\n   916→        return Response.ok(new TagsResponse(tags))\n   917→                .status(Response.Status.OK)\n   918→                .build();\n   919→    }\n   920→}\n   921→\n   922→==========================================\n   923→FILE: src/main/java/org/example/realworldapi/application/web/resource/UserResource.java\n   924→==========================================\n   925→package org.example.realworldapi.application.web.resource;\n   926→\n   927→import com.fasterxml.jackson.core.JsonProcessingException;\n   928→import com.fasterxml.jackson.databind.ObjectMapper;\n   929→import jakarta.inject.Inject;\n   930→import jakarta.transaction.Transactional;\n   931→import jakarta.validation.Valid;\n   932→import jakarta.ws.rs.*;\n   933→import jakarta.ws.rs.core.Context;\n   934→import jakarta.ws.rs.core.MediaType;\n   935→import jakarta.ws.rs.core.Response;\n   936→import jakarta.ws.rs.core.SecurityContext;\n   937→import org.example.realworldapi.application.web.model.request.UpdateUserRequestWrapper;\n   938→import org.example.realworldapi.application.web.model.response.UserResponse;\n   939→import org.example.realworldapi.domain.feature.FindUserById;\n   940→import org.example.realworldapi.domain.feature.UpdateUser;\n   941→import org.example.realworldapi.infrastructure.web.provider.TokenProvider;\n   942→import org.example.realworldapi.infrastructure.web.security.annotation.Secured;\n   943→import org.example.realworldapi.infrastructure.web.security.profile.Role;\n   944→\n   945→import java.util.UUID;\n   946→\n   947→@Path(\"/user\")\n   948→public class UserResource {\n   949→\n   950→    @Inject\n   951→    private FindUserById findUserById;\n   952→    @Inject\n   953→    private UpdateUser updateUser;\n   954→    @Inject\n   955→    private TokenProvider tokenProvider;\n   956→    @Inject\n   957→    private ObjectMapper objectMapper;\n   958→\n   959→    @GET\n   960→    @Secured({Role.ADMIN, Role.USER})\n   961→    @Produces(MediaType.APPLICATION_JSON)\n   962→    public Response getUser(@Context SecurityContext securityContext) throws JsonProcessingException {\n   963→        final var userId = UUID.fromString(securityContext.getUserPrincipal().getName());\n   964→        final var user = findUserById.handle(userId);\n   965→        final var token = tokenProvider.createUserToken(user.getId().toString());\n   966→        return Response.ok(objectMapper.writeValueAsString(new UserResponse(user, token))).status(Response.Status.OK).build();\n   967→    }\n   968→\n   969→    @PUT\n   970→    @Transactional\n   971→    @Secured({Role.ADMIN, Role.USER})\n   972→    @Consumes(MediaType.APPLICATION_JSON)\n   973→    @Produces(MediaType.APPLICATION_JSON)\n   974→    public Response update(\n   975→            @Context SecurityContext securityContext,\n   976→            @Valid UpdateUserRequestWrapper updateUserRequest) throws JsonProcessingException {\n   977→        final var userId = UUID.fromString(securityContext.getUserPrincipal().getName());\n   978→        final var user = updateUser.handle(updateUserRequest.getUser().toUpdateUserInput(userId));\n   979→        final var token = tokenProvider.createUserToken(user.getId().toString());\n   980→        return Response.ok(objectMapper.writeValueAsString(new UserResponse(user, token))).status(Response.Status.OK).build();\n   981→    }\n   982→}\n   983→\n   984→==========================================\n   985→FILE: src/main/java/org/example/realworldapi/application/web/resource/UsersResource.java\n   986→==========================================\n   987→package org.example.realworldapi.application.web.resource;\n   988→\n   989→import com.fasterxml.jackson.core.JsonProcessingException;\n   990→import com.fasterxml.jackson.databind.ObjectMapper;\n   991→import jakarta.inject.Inject;\n   992→import jakarta.transaction.Transactional;\n   993→import jakarta.validation.Valid;\n   994→import jakarta.ws.rs.Consumes;\n   995→import jakarta.ws.rs.POST;\n   996→import jakarta.ws.rs.Path;\n   997→import jakarta.ws.rs.Produces;\n   998→import jakarta.ws.rs.core.Context;\n   999→import jakarta.ws.rs.core.MediaType;\n  1000→import jakarta.ws.rs.core.Response;\n  1001→import org.example.realworldapi.application.web.model.request.LoginRequestWrapper;\n  1002→import org.example.realworldapi.application.web.model.request.NewUserRequestWrapper;\n  1003→import org.example.realworldapi.application.web.model.response.UserResponse;\n  1004→import org.example.realworldapi.domain.exception.InvalidPasswordException;\n  1005→import org.example.realworldapi.domain.exception.UserNotFoundException;\n  1006→import org.example.realworldapi.domain.feature.CreateUser;\n  1007→import org.example.realworldapi.domain.feature.LoginUser;\n  1008→import org.example.realworldapi.domain.model.user.User;\n  1009→import org.example.realworldapi.infrastructure.web.exception.UnauthorizedException;\n  1010→import org.example.realworldapi.infrastructure.web.provider.TokenProvider;\n  1011→\n  1012→@Path(\"/users\")\n  1013→public class UsersResource {\n  1014→\n  1015→    @Inject\n  1016→    private CreateUser createUser;\n  1017→    @Inject\n  1018→    private LoginUser loginUser;\n  1019→    @Inject\n  1020→    private TokenProvider tokenProvider;\n  1021→    @Inject\n  1022→    private ObjectMapper objectMapper;\n  1023→\n  1024→    @POST\n  1025→    @Transactional\n  1026→    @Consumes(MediaType.APPLICATION_JSON)\n  1027→    @Produces(MediaType.APPLICATION_JSON)\n  1028→    public Response create(\n  1029→            @Valid\n  1030→            NewUserRequestWrapper newUserRequest,\n  1031→            @Context SecurityException context) throws JsonProcessingException {\n  1032→        final var user = createUser.handle(newUserRequest.getUser().toCreateUserInput());\n  1033→        final var token = tokenProvider.createUserToken(user.getId().toString());\n  1034→        return Response.ok(objectMapper.writeValueAsString(new UserResponse(user, token))).status(Response.Status.CREATED).build();\n  1035→    }\n  1036→\n  1037→    @POST\n  1038→    @Path(\"/login\")\n  1039→    @Consumes(MediaType.APPLICATION_JSON)\n  1040→    @Produces(MediaType.APPLICATION_JSON)\n  1041→    public Response login(\n  1042→            @Valid\n  1043→            LoginRequestWrapper loginRequest) throws JsonProcessingException {\n  1044→        User user;\n  1045→\n  1046→        try {\n  1047→            user = loginUser.handle(loginRequest.getUser().toLoginUserInput());\n  1048→        } catch (UserNotFoundException | InvalidPasswordException ex) {\n  1049→            throw new UnauthorizedException();\n  1050→        }\n  1051→        final var token = tokenProvider.createUserToken(user.getId().toString());\n  1052→        return Response.ok(objectMapper.writeValueAsString(new UserResponse(user, token))).status(Response.Status.OK).build();\n  1053→    }\n  1054→}\n  1055→\n  1056→==========================================\n  1057→FILE: src/main/java/org/example/realworldapi/domain/feature/ArticleFavoritesCount.java\n  1058→==========================================\n  1059→package org.example.realworldapi.domain.feature;\n  1060→\n  1061→import java.util.UUID;\n  1062→\n  1063→public interface ArticleFavoritesCount {\n  1064→  long handle(UUID articleId);\n  1065→}\n  1066→\n  1067→==========================================\n  1068→FILE: src/main/java/org/example/realworldapi/domain/feature/CreateArticle.java\n  1069→==========================================\n  1070→package org.example.realworldapi.domain.feature;\n  1071→\n  1072→import org.example.realworldapi.domain.model.article.Article;\n  1073→import org.example.realworldapi.domain.model.article.NewArticleInput;\n  1074→\n  1075→public interface CreateArticle {\n  1076→  Article handle(NewArticleInput newArticleInput);\n  1077→}\n  1078→\n  1079→==========================================\n  1080→FILE: src/main/java/org/example/realworldapi/domain/feature/CreateComment.java\n  1081→==========================================\n  1082→package org.example.realworldapi.domain.feature;\n  1083→\n  1084→import org.example.realworldapi.domain.model.comment.Comment;\n  1085→import org.example.realworldapi.domain.model.comment.NewCommentInput;\n  1086→\n  1087→public interface CreateComment {\n  1088→  Comment handle(NewCommentInput newCommentInput);\n  1089→}\n  1090→\n  1091→==========================================\n  1092→FILE: src/main/java/org/example/realworldapi/domain/feature/CreateSlugByTitle.java\n  1093→==========================================\n  1094→package org.example.real