his.description = article.getDescription();\n   357→        this.body = article.getBody();\n   358→        this.createdAt = article.getCreatedAt();\n   359→        this.updatedAt = article.getUpdatedAt();\n   360→        this.author = author;\n   361→        this.favoritesCount = favoritesCount;\n   362→        this.tagList = tags.stream().map(Tag::getName).collect(Collectors.toList());\n   363→    }\n   364→}\n   365→\n   366→==========================================\n   367→FILE: src/main/java/org/example/realworldapi/application/web/model/response/ArticlesResponse.java\n   368→==========================================\n   369→package org.example.realworldapi.application.web.model.response;\n   370→\n   371→import lombok.Getter;\n   372→import lombok.NoArgsConstructor;\n   373→import lombok.Setter;\n   374→\n   375→import java.util.List;\n   376→\n   377→@Getter\n   378→@Setter\n   379→@NoArgsConstructor\n   380→public class ArticlesResponse {\n   381→\n   382→    private List<ArticleResponse> articles;\n   383→    private long articlesCount;\n   384→\n   385→    public ArticlesResponse(List<ArticleResponse> articles, long articlesCount) {\n   386→        this.articles = articles;\n   387→        this.articlesCount = articlesCount;\n   388→    }\n   389→}\n   390→\n   391→==========================================\n   392→FILE: src/main/java/org/example/realworldapi/application/web/model/response/CommentResponse.java\n   393→==========================================\n   394→package org.example.realworldapi.application.web.model.response;\n   395→\n   396→import com.fasterxml.jackson.annotation.JsonFormat;\n   397→import com.fasterxml.jackson.annotation.JsonRootName;\n   398→import lombok.Getter;\n   399→import lombok.NoArgsConstructor;\n   400→import lombok.Setter;\n   401→import org.example.realworldapi.domain.model.comment.Comment;\n   402→\n   403→import java.time.LocalDateTime;\n   404→import java.util.UUID;\n   405→\n   406→@Getter\n   407→@Setter\n   408→