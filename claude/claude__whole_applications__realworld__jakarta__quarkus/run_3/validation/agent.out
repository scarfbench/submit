essingException {\n    40→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n    41→        final var profileResponse = resourceUtils.profileResponse(username, loggedUserId);\n    42→        return Response.ok(objectMapper.writeValueAsString(profileResponse)).status(Response.Status.OK).build();\n    43→    }\n    44→\n    45→    @POST\n    46→    @Transactional\n    47→    @Secured({Role.USER, Role.ADMIN})\n    48→    @Path(\"/{username}/follow\")\n    49→    @Produces(MediaType.APPLICATION_JSON)\n    50→    public Response follow(\n    51→            @PathParam(\"username\") @NotBlank(message = ValidationMessages.USERNAME_MUST_BE_NOT_BLANK)\n    52→            String username,\n    53→            @Context SecurityContext securityContext) throws JsonProcessingException {\n    54→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n    55→        followUserByUsername.handle(loggedUserId, username);\n    56→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.profileResponse(username, loggedUserId)))\n    57→                .status(Response.Status.OK)\n    58→                .build();\n    59→    }\n    60→\n    61→    @DELETE\n    62→    @Transactional\n    63→    @Secured({Role.USER, Role.ADMIN})\n    64→    @Path(\"/{username}/follow\")\n    65→    @Produces(MediaType.APPLICATION_JSON)\n    66→    public Response unfollow(\n    67→            @PathParam(\"username\") @NotBlank(message = ValidationMessages.USERNAME_MUST_BE_NOT_BLANK)\n    68→            String username,\n    69→            @Context SecurityContext securityContext) throws JsonProcessingException {\n    70→        final var loggedUserId = resourceUtils.getLoggedUserId(securityContext);\n    71→        unfollowUserByUsername.handle(loggedUserId, username);\n    72→        return Response.ok(objectMapper.writeValueAsString(resourceUtils.profileResponse(username, loggedUserId)))\n    73→                .status(Response.Status