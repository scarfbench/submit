oke tests failed with exit code $TEST_EXIT ===\"\nfi\n\n# Wait for the app process\nwait $APP_PID\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":404,"cache_read_input_tokens":126091,"cache_creation":{"ephemeral_5m_input_tokens":404,"ephemeral_1h_input_tokens":0},"output_tokens":668},"context_management":null},"parent_tool_use_id":null,"session_id":"e4f0ba96-c3d7-44ae-b77e-aba0b53da63a","uuid":"e06ba175-6b06-40e4-881a-eb0ff6a52978"}
