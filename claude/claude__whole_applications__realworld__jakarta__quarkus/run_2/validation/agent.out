on>\n   174→                            <excludes>\n   175→                                <exclude>**/it/**</exclude>\n   176→                            </excludes>\n   177→                            <reportsDirectory>${project.build.directory}/test-reports/unit</reportsDirectory>\n   178→                        </configuration>\n   179→                    </execution>\n   180→                </executions>\n   181→            </plugin>\n   182→            <plugin>\n   183→                <groupId>io.openliberty.tools</groupId>\n   184→                <artifactId>liberty-maven-plugin</artifactId>\n   185→                <version>3.11.4</version>\n   186→                <configuration>\n   187→                    <copyDependencies>\n   188→                        <dependencyGroup>\n   189→                            <location>jdbc</location>\n   190→                            <dependency>\n   191→                                <groupId>org.postgresql</groupId>\n   192→                                <artifactId>postgresql</artifactId>\n   193→                                <version>42.7.7</version>\n   194→                            </dependency>\n   195→                        </dependencyGroup>\n   196→                    </copyDependencies>\n   197→                </configuration>\n   198→            </plugin>\n   199→            <plugin>\n   200→                <groupId>org.apache.maven.plugins</groupId>\n   201→                <artifactId>maven-failsafe-plugin</artifactId>\n   202→                <version>3.5.3</version>\n   203→                <executions>\n   204→                    <execution>\n   205→                        <phase>integration-test</phase>\n   206→                        <id>integration-test</id>\n   207→                        <goals>\n   208→                            <goal>integration-test</goal>\n   209→                        </goals>\n   210→                    </execution>\n   211→                    <execution>\n   212→        