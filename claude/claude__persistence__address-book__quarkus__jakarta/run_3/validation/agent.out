            <activation>\n                <property>\n                    <name>native</name>\n                </property>\n            </activation>\n            <properties>\n                <skipITs>false</skipITs>\n                <quarkus.native.enabled>true</quarkus.native.enabled>\n            </properties>\n        </profile>\n    </profiles>\n</project>","new_string":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\"\n         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd\">\n    <modelVersion>4.0.0</modelVersion>\n    <groupId>jakarta.tutorial</groupId>\n    <artifactId>address-book-jakarta</artifactId>\n    <version>1.0.0-SNAPSHOT</version>\n    <packaging>war</packaging>\n\n    <properties>\n        <maven.compiler.release>17</maven.compiler.release>\n        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>\n        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>\n        <failOnMissingWebXml>false</failOnMissingWebXml>\n    </properties>\n\n    <dependencies>\n        <!-- Jakarta EE 10 API (provided by WildFly) -->\n        <dependency>\n            <groupId>jakarta.platform</groupId>\n            <artifactId>jakarta.jakartaee-api</artifactId>\n            <version>10.0.0</version>\n            <scope>provided</scope>\n        </dependency>\n\n        <!-- H2 Database (bundled in WAR for standalone usage) -->\n        <dependency>\n            <groupId>com.h2database</groupId>\n            <artifactId>h2</artifactId>\n            <version>2.2.224</version>\n            <scope>compile</scope>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <finalName>address-book</finalName>\n        <plugins>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-compiler-plugin<