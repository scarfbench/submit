embed-server --server-config=standalone.xml --std-out=echo

# Add the AddressBook datasource using the built-in H2 driver
/subsystem=datasources/data-source=AddressBookDS:add(jndi-name=java:jboss/datasources/AddressBookDS,driver-name=h2,connection-url="jdbc:h2:mem:addressbook;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE",user-name=sa,password=sa)

stop-embedded-server
