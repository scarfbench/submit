ments/\n    40â†’\n    41â†’EXPOSE 8080\n    42â†’\n    43â†’CMD [\"/opt/wildfly/bin/standalone.sh\", \"-b\", \"0.0.0.0\"]\n    44â†’"}]},"parent_tool_use_id":null,"session_id":"7644972d-de55-42ce-94f0-5092bba75a4d","uuid":"30a583c1-ac83-407a-b1dd-d278a7bc0cc2"}
