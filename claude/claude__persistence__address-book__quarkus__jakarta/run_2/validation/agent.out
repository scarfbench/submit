               <artifactId>quarkus-maven-plugin</artifactId>\n    80â†’                <version>${quarkus.platform.version}</version>\n    81â†’                <extensions>true</extensions>\n    82â†’                <executions>\n    83â†’                    <execution>\n    84â†’                        <goals>\n    85â†’                            <goal>build</goal>\n    86â†’                            <goal>generate-code</goal>\n    87â†’                            <goal>generate-code-tests</goal>\n    88â†’                            <goal>native-image-agent</goal>\n    89â†’                        </goals>\n    90â†’                    </execution>\n    91â†’                </executions>\n    92â†’            </plugin>\n    93â†’            <plugin>\n    94â†’                <artifactId>maven-compiler-plugin</artifactId>\n    95â†’                <version>${compiler-plugin.version}</version>\n    96â†’                <configuration>\n    97â†’                    <parameters>true</parameters>\n    98â†’                </configuration>\n    99â†’            </plugin>\n   100â†’            <plugin>\n   101â†’                <artifactId>maven-surefire-plugin</artifactId>\n   102â†’                <version>${surefire-plugin.version}</version>\n   103â†’                <configuration>\n   104â†’                    <systemPropertyVariables>\n   105â†’                        <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>\n   106â†’                        <maven.home>${maven.home}</maven.home>\n   107â†’                    </systemPropertyVariables>\n   108â†’                </configuration>\n   109â†’            </plugin>\n   110â†’            <plugin>\n   111â†’                <artifactId>maven-failsafe-plugin</artifactId>\n   112â†’                <version>${surefire-plugin.version}</version>\n   113â†’                <executions>\n   114â†’                    <execution>\n   115â†’                        <goals>\n   116â†’    