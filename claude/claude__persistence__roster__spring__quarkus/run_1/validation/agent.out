ntCaptor.forClass(League.class);\n    35→    verify(leagueRepository).save(cap1.capture());\n    36→    assertTrue(cap1.getValue() instanceof SummerLeague);\n    37→\n    38→    reset(leagueRepository);\n    39→    bean.createLeague(new LeagueDetails(\"L2\",\"Name\",\"hockey\"));\n    40→    ArgumentCaptor<League> cap2 = ArgumentCaptor.forClass(League.class);\n    41→    verify(leagueRepository).save(cap2.capture());\n    42→    assertTrue(cap2.getValue() instanceof WinterLeague);\n    43→  }\n    44→\n    45→  @Test\n    46→  void addPlayerLinksAndSavesTeam() {\n    47→    RequestBean bean = new RequestBean(playerRepository, teamRepository, leagueRepository);\n    48→    Player p = new Player(\"P1\",\"Alice\",\"Forward\",100);\n    49→    Team t = new Team(\"T1\",\"Tigers\",\"Austin\");\n    50→    when(playerRepository.findById(\"P1\")).thenReturn(Optional.of(p));\n    51→    when(teamRepository.findById(\"T1\")).thenReturn(Optional.of(t));\n    52→\n    53→    bean.addPlayer(\"P1\",\"T1\");\n    54→\n    55→    verify(teamRepository).save(t);\n    56→    assertTrue(t.getPlayers().contains(p));\n    57→    assertTrue(p.getTeams().contains(t));\n    58→  }\n    59→}\n    60→"}]},"parent_tool_use_id":null,"session_id":"d54aa1ac-75bb-4334-9153-448f533619ac","uuid":"839f3ea8-88e2-4a48-b720-2181090c07f9"}
