 @Inject\n    36→  public RequestBean(PlayerRepository playerRepository, TeamRepository teamRepository, LeagueRepository leagueRepository) {\n    37→    this.playerRepository = playerRepository;\n    38→    this.teamRepository = teamRepository;\n    39→    this.leagueRepository = leagueRepository;\n    40→  }\n    41→\n    42→  @PostConstruct\n    43→  void init() {\n    44→  }\n    45→\n    46→  @Override\n    47→  public void createPlayer(String id, String name, String position, double salary) {\n    48→    Player p = new Player(id, name, position, salary);\n    49→    playerRepository.save(p);\n    50→  }\n    51→\n    52→  @Override\n    53→  public void addPlayer(String playerId, String teamId) {\n    54→    Player p = playerRepository.findById(playerId).orElse(null);\n    55→    Team t = teamRepository.findById(teamId).orElse(null);\n    56→    if (p == null || t == null) return;\n    57→    t.addPlayer(p);\n    58→    teamRepository.save(t);\n    59→  }\n    60→\n    61→  @Override\n    62→  public void removePlayer(String playerId) {\n    63→    playerRepository.findById(playerId).ifPresent(p -> {\n    64→      List<Team> teams = new ArrayList<>(Optional.ofNullable(p.getTeams()).orElse(List.of()));\n    65→      for (Team t : teams) {\n    66→        t.dropPlayer(p);\n    67→      }\n    68→      teamRepository.saveAll(teams);\n    69→      playerRepository.deleteById(playerId);\n    70→    });\n    71→  }\n    72→\n    73→  @Override\n    74→  public void dropPlayer(String playerId, String teamId) {\n    75→    Player p = playerRepository.findById(playerId).orElse(null);\n    76→    Team t = teamRepository.findById(teamId).orElse(null);\n    77→    if (p == null || t == null) return;\n    78→    t.dropPlayer(p);\n    79→    teamRepository.save(t);\n    80→  }\n    81→\n    82→  @Override\n    83→  public PlayerDetails getPlayer(String playerId) {\n    84→    return playerRepository.findById(playerId).map(this::toPlayerDetails).orElse(null);\n    85→  }\n    86→\n    87→  @Override\n    88→  public List<PlayerDetails> getPlayersOfTeam(String teamId) {\n    89→    return playerRepository.findByTeams_Id(teamId).stream().map(this::toPlayerDetails).toList();\n    90→  }\n    91→\n    92→  @Override\n    93→  public List<TeamDetails> getTeamsOfLeague(String leagueId) {\n    94→    return teamRepository.findByLeague_Id(leagueId).stream().map(this::toTeamDetails).toList();\n    95→  }\n    96→\n    97→  @Override\n    98→  public List<PlayerDetails> getPlayersByPosition(String position) {\n    99→    return playerRepository.findByPosition(position).stream().map(this::toPlayerDetails).toList();\n   100→  }\n   101→\n   102→  @Override\n   103→  public List<PlayerDetails> getPlayersByHigherSalary(String name) {\n   104→    Optional<Player> base = playerRepository.findFirstByName(name);\n   105→    if (base.isEmpty()) return List.of();\n   106→    return playerRepository.findBySalaryGreaterThan(base.get().getSalary()).stream().map(this::toPlayerDetails).toList();\n   107→  }\n   108→\n   109→  @Override\n   110→  public List<PlayerDetails> getPlayersBySalaryRange(double low, double high) {\n   111→    return playerRepository.findBySalaryBetween(low, high).stream().map(this::toPlayerDetails).toList();\n   112→  }\n   113→\n   114→  @Override\n   115→  public List<PlayerDetails> getPlayersByLeagueId(String leagueId) {\n   116→    return playerRepository.findDistinctByTeams_League_Id(leagueId).stream().map(this::toPlayerDetails).toList();\n   117→  }\n   118→\n   119→  @Override\n   120→  public List<PlayerDetails> getPlayersBySport(String sport) {\n   121→    return playerRepository.findDistinctByTeams_League_Sport(sport).stream().map(this::toPlayerDetails).toList();\n   122→  }\n   123→\n   124→  @Override\n   125→  public List<PlayerDetails> getPlayersByCity(String city) {\n   126→    return playerRepository.findDistinctByTeams_City(city).stream().map(this::toPlayerDetails).toList();\n   127→  }\n   128→\n   129→  @Override\n   130→  public List<PlayerDetails> getAllPlayers() {\n   131→    return playerRepository.findAll().stream().sorted(Comparator.comparing(Player::getId)).map(this::toPlayerDetails).toList();\n   132→  }\n   133→\n   134→  @Override\n   135→  public List<PlayerDetails> getPlayersNotOnTeam() {\n   136→    return playerRepository.findByTeamsIsEmpty().stream().map(this::toPlayerDetails).toList();\n   137→  }\n   138→\n   139→  @Override\n   140→  public List<PlayerDetails> getPlayersByPositionAndName(String position, String name) {\n   141→    return playerRepository.findByPositionAndName(position, name).stream().map(this::toPlayerDetails).toList();\n   142→  }\n   143→\n   144→  @Override\n   145→  public List<LeagueDetails> getLeaguesOfPlayer(String playerId) {\n   146→    return playerRepository.findById(playerId).map(p -> Optional.ofNullable(p.getTeams()).orElse(List.of()).stream()\n   147→        .map(Team::getLeague).filter(Objects::nonNull).collect(Collectors.toMap(League::getId, l -> l, (a, b) -> a)).values().stream()\n   148→        .map(this::toLeagueDetails).toList()).orElse(List.of());\n   149→  }\n   150→\n   151→  @Override\n   152→  public List<String> getSportsOfPlayer(String playerId) {\n   153→    return playerRepository.findById(playerId).map(p -> Optional.ofNullable(p.getTeams()).orElse(List.of()).stream()\n   154→        .map(Team::getLeague).filter(Objects::nonNull).map(League::getSport).filter(Objects::nonNull)\n   155→        .collect(Collectors.toCollection(java.util.LinkedHashSet::new))).orElseGet(java.util.LinkedHashSet::new).stream().toList();\n   156→  }\n   157→\n   158→  @Override\n   159→  public void createTeamInLeague(TeamDetails teamDetails, String leagueId) {\n   160→    League league = leagueRepository.findById(leagueId).orElse(null);\n   161→    if (league == null) return;\n   162→    Team t = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   163→    t.setLeague(league);\n   164→    teamRepository.save(t);\n   165→  }\n   166→\n   167→  @Override\n   168→  public void removeTeam(String teamId) {\n   169→    teamRepository.findById(teamId).ifPresent(t -> {\n   170→      List<Player> players = new ArrayList<>(Optional.ofNullable(t.getPlayers()).orElse(List.of()));\n   171→      for (Player p : players) {\n   172→        t.dropPlayer(p);\n   173→      }\n   174→      teamRepository.save(t);\n   175→      teamRepository.deleteById(teamId);\n   176→    });\n   177→  }\n   178→\n   179→  @Override\n   180→  public TeamDetails getTeam(String teamId) {\n   181→    return teamRepository.findById(teamId).map(this::toTeamDetails).orElse(null);\n   182→  }\n   183→\n   184→  @Override\n   185→  public void createLeague(LeagueDetails leagueDetails) {\n   186→    League l = instantiateLeague(leagueDetails);\n   187→    leagueRepository.save(l);\n   188→  }\n   189→\n   190→  @Override\n   191→  public void removeLeague(String leagueId) {\n   192→    leagueRepository.deleteById(leagueId);\n   193→  }\n   194→\n   195→  @Override\n   196→  public LeagueDetails getLeague(String leagueId) {\n   197→    return leagueRepository.findById(leagueId).map(this::toLeagueDetails).orElse(null);\n   198→  }\n   199→\n   200→  private PlayerDetails toPlayerDetails(Player p) {\n   201→    return new PlayerDetails(p.getId(), p.getName(), p.getPosition(), p.getSalary());\n   202→  }\n   203→\n   204→  private TeamDetails toTeamDetails(Team t) {\n   205→    return new TeamDetails(t.getId(), t.getName(), t.getCity());\n   206→  }\n   207→\n   208→  private LeagueDetails toLeagueDetails(League l) {\n   209→    return new LeagueDetails(l.getId(), l.getName(), l.getSport());\n   210→  }\n   211→\n   212→  private League instantiateLeague(LeagueDetails d) {\n   213→    try {\n   214→      String sport = d.getSport() == null ? \"\" : d.getSport().toLowerCase();\n   215→      if (sport.contains(\"ski\") || sport.contains(\"hockey\") || sport.contains(\"ice\") || sport.contains(\"snow\")) {\n   216→        return new WinterLeague(d.getId(), d.getName(), d.getSport());\n   217→      }\n   218→      return new SummerLeague(d.getId(), d.getName(), d.getSport());\n   219→    } catch (IncorrectSportException e) {\n   220→      throw new IllegalArgumentException(e);\n   221→    }\n   222→  }\n   223→}\n   224→"}]},"parent_tool_use_id":null,"session_id":"d54aa1ac-75bb-4334-9153-448f533619ac","uuid":"c2bc9338-43a4-4e1d-83ae-3333e4ce129b"}
