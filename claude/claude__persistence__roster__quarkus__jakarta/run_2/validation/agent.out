eation":{"ephemeral_5m_input_tokens":14423,"ephemeral_1h_input_tokens":0},"output_tokens":799},"context_management":null},"parent_tool_use_id":null,"session_id":"d9729fc2-69e7-40e2-ad86-5630b00c4ba7","uuid":"69de420b-619b-42f3-8f13-be1ed3247c03"}
