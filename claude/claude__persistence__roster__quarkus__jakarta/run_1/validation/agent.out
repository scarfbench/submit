eam == null) {\n    83→                throw new WebApplicationException(\"Player or Team not found\", Response.Status.NOT_FOUND);\n    84→            }\n    85→            team.addPlayer(player);\n    86→            player.addTeam(team);\n    87→            em.merge(player);\n    88→            em.merge(team);\n    89→            em.flush();\n    90→        } catch (Exception ex) {\n    91→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n    92→        }\n    93→    }\n    94→\n    95→    @Override\n    96→    @DELETE\n    97→    @Path(\"/player/{playerId}\")\n    98→    @Produces(MediaType.APPLICATION_JSON)\n    99→    public void removePlayer(@PathParam(\"playerId\") String playerId) {\n   100→        logger.info(\"removePlayer\");\n   101→        try {\n   102→            Player player = em.find(Player.class, playerId);\n   103→            if (player == null) {\n   104→                throw new WebApplicationException(\"Player not found\", Response.Status.NOT_FOUND);\n   105→            }\n   106→            Collection<Team> teams = player.getTeams();\n   107→            for (Team team : teams) {\n   108→                team.dropPlayer(player);\n   109→            }\n   110→            em.remove(player);\n   111→            em.flush();\n   112→        } catch (Exception ex) {\n   113→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   114→        }\n   115→    }\n   116→\n   117→    @Override\n   118→    @DELETE\n   119→    @Path(\"/player/{playerId}/team/{teamId}\")\n   120→    @Produces(MediaType.APPLICATION_JSON)\n   121→    public void dropPlayer(@PathParam(\"playerId\") String playerId, @PathParam(\"teamId\") String teamId) {\n   122→        logger.info(\"dropPlayer\");\n   123→        try {\n   124→            Player player = em.find(Player.class, playerId);\n   125→            Team team = em.find(Team.class, teamId);\n   126→            if (player == null || team == null) 