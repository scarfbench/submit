cache_creation_input_tokens":11390,"cache_read_input_tokens":24542,"cache_creation":{"ephemeral_5m_input_tokens":11390,"ephemeral_1h_input_tokens":0},"output_tokens":733},"context_management":null},"parent_tool_use_id":null,"session_id":"831f66ff-c9ae-4571-b43b-fbfb1716cdb8","uuid":"0b38d469-d6cc-4ee7-a55a-17553a564698"}
