h (Exception ex) {\n   210→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   211→        }\n   212→    }\n   213→\n   214→    @Override\n   215→    @GET\n   216→    @Path(\"/players/salary/higher/{name}\")\n   217→    @Produces(MediaType.APPLICATION_JSON)\n   218→    public List<PlayerDetails> getPlayersByHigherSalary(@PathParam(\"name\") String name) {\n   219→        logger.info(\"getPlayersByHigherSalary\");\n   220→        try {\n   221→            CriteriaBuilder cb = getCB();\n   222→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   223→            Root<Player> player1 = cq.from(Player.class);\n   224→            Root<Player> player2 = cq.from(Player.class);\n   225→            Predicate gtPredicate = cb.greaterThan(player1.get(\"salary\"), player2.get(\"salary\"));\n   226→            Predicate equalPredicate = cb.equal(player2.get(\"name\"), name);\n   227→            cq.where(gtPredicate, equalPredicate);\n   228→            cq.select(player1).distinct(true);\n   229→            TypedQuery<Player> q = em.createQuery(cq);\n   230→            List<Player> players = q.getResultList();\n   231→            return copyPlayersToDetails(players);\n   232→        } catch (Exception ex) {\n   233→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   234→        }\n   235→    }\n   236→\n   237→    @Override\n   238→    @GET\n   239→    @Path(\"/players/salary/range\")\n   240→    @Produces(MediaType.APPLICATION_JSON)\n   241→    public List<PlayerDetails> getPlayersBySalaryRange(@QueryParam(\"low\") double low, @QueryParam(\"high\") double high) {\n   242→        logger.info(\"getPlayersBySalaryRange\");\n   243→        try {\n   244→            CriteriaBuilder cb = getCB();\n   245→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   246→            Root<Player> player = cq.from(Player.class);\n   247→            cq.where(cb.between(player.get(\"salary\"), low, high));\n   248→            cq.select(player).distinct(true);\n   249→            TypedQuery<Player> q = em.createQuery(cq);\n   250→            List<Player> players = q.getResultList();\n   251→            return copyPlayersToDetails(players);\n   252→        } catch (Exception ex) {\n   253→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   254→        }\n   255→    }\n   256→\n   257→    @Override\n   258→    @GET\n   259→    @Path(\"/players/league/{leagueId}\")\n   260→    @Produces(MediaType.APPLICATION_JSON)\n   261→    public List<PlayerDetails> getPlayersByLeagueId(@PathParam(\"leagueId\") String leagueId) {\n   262→        logger.info(\"getPlayersByLeagueId\");\n   263→        try {\n   264→            CriteriaBuilder cb = getCB();\n   265→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   266→            Root<Player> player = cq.from(Player.class);\n   267→            Join<Player, Team> team = player.join(\"teams\");\n   268→            Join<Team, League> league = team.join(\"league\");\n   269→            cq.where(cb.equal(league.get(\"id\"), leagueId));\n   270→            cq.select(player).distinct(true);\n   271→            TypedQuery<Player> q = em.createQuery(cq);\n   272→            List<Player> players = q.getResultList();\n   273→            return copyPlayersToDetails(players);\n   274→        } catch (Exception ex) {\n   275→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   276→        }\n   277→    }\n   278→\n   279→    @Override\n   280→    @GET\n   281→    @Path(\"/players/sport/{sport}\")\n   282→    @Produces(MediaType.APPLICATION_JSON)\n   283→    public List<PlayerDetails> getPlayersBySport(@PathParam(\"sport\") String sport) {\n   284→        logger.info(\"getPlayersBySport\");\n   285→        try {\n   286→            CriteriaBuilder cb = getCB();\n   287→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   288→            Root<Player> player = cq.from(Player.class);\n   289→            Join<Player, Team> team = player.join(\"teams\");\n   290→            Join<Team, League> league = team.join(\"league\");\n   291→            cq.where(cb.equal(league.get(\"sport\"), sport));\n   292→            cq.select(player).distinct(true);\n   293→            TypedQuery<Player> q = em.createQuery(cq);\n   294→            List<Player> players = q.getResultList();\n   295→            return copyPlayersToDetails(players);\n   296→        } catch (Exception ex) {\n   297→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   298→        }\n   299→    }\n   300→\n   301→    @Override\n   302→    @GET\n   303→    @Path(\"/players/city/{city}\")\n   304→    @Produces(MediaType.APPLICATION_JSON)\n   305→    public List<PlayerDetails> getPlayersByCity(@PathParam(\"city\") String city) {\n   306→        logger.info(\"getPlayersByCity\");\n   307→        try {\n   308→            CriteriaBuilder cb = getCB();\n   309→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   310→            Root<Player> player = cq.from(Player.class);\n   311→            Join<Player, Team> team = player.join(\"teams\");\n   312→            cq.where(cb.equal(team.get(\"city\"), city));\n   313→            cq.select(player).distinct(true);\n   314→            TypedQuery<Player> q = em.createQuery(cq);\n   315→            List<Player> players = q.getResultList();\n   316→            return copyPlayersToDetails(players);\n   317→        } catch (Exception ex) {\n   318→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   319→        }\n   320→    }\n   321→\n   322→    @Override\n   323→    @GET\n   324→    @Path(\"/players\")\n   325→    @Produces(MediaType.APPLICATION_JSON)\n   326→    public List<PlayerDetails> getAllPlayers() {\n   327→        logger.info(\"getAllPlayers\");\n   328→        try {\n   329→            CriteriaBuilder cb = getCB();\n   330→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   331→            Root<Player> player = cq.from(Player.class);\n   332→            cq.select(player);\n   333→            TypedQuery<Player> q = em.createQuery(cq);\n   334→            List<Player> players = q.getResultList();\n   335→            return copyPlayersToDetails(players);\n   336→        } catch (Exception ex) {\n   337→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   338→        }\n   339→    }\n   340→\n   341→    @Override\n   342→    @GET\n   343→    @Path(\"/players/not-on-team\")\n   344→    @Produces(MediaType.APPLICATION_JSON)\n   345→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   346→        logger.info(\"getPlayersNotOnTeam\");\n   347→        try {\n   348→            CriteriaBuilder cb = getCB();\n   349→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   350→            Root<Player> player = cq.from(Player.class);\n   351→            cq.where(cb.isEmpty(player.get(\"teams\")));\n   352→            cq.select(player).distinct(true);\n   353→            TypedQuery<Player> q = em.createQuery(cq);\n   354→            List<Player> players = q.getResultList();\n   355→            return copyPlayersToDetails(players);\n   356→        } catch (Exception ex) {\n   357→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   358→        }\n   359→    }\n   360→\n   361→    @Override\n   362→    @GET\n   363→    @Path(\"/players/position/{position}/name/{name}\")\n   364→    @Produces(MediaType.APPLICATION_JSON)\n   365→    public List<PlayerDetails> getPlayersByPositionAndName(\n   366→            @PathParam(\"position\") String position,\n   367→            @PathParam(\"name\") String name) {\n   368→        logger.info(\"getPlayersByPositionAndName\");\n   369→        try {\n   370→            CriteriaBuilder cb = getCB();\n   371→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   372→            Root<Player> player = cq.from(Player.class);\n   373→            cq.where(cb.equal(player.get(\"position\"), position),\n   374→                    cb.equal(player.get(\"name\"), name));\n   375→            cq.select(player).distinct(true);\n   376→            TypedQuery<Player> q = em.createQuery(cq);\n   377→            List<Player> players = q.getResultList();\n   378→            return copyPlayersToDetails(players);\n   379→        } catch (Exception ex) {\n   380→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   381→        }\n   382→    }\n   383→\n   384→    @Override\n   385→    @GET\n   386→    @Path(\"/player/{playerId}/leagues\")\n   387→    @Produces(MediaType.APPLICATION_JSON)\n   388→    public List<LeagueDetails> getLeaguesOfPlayer(@PathParam(\"playerId\") String playerId) {\n   389→        logger.info(\"getLeaguesOfPlayer\");\n   390→        List<LeagueDetails> detailsList = new ArrayList<>();\n   391→        try {\n   392→            CriteriaBuilder cb = getCB();\n   393→            CriteriaQuery<League> cq = cb.createQuery(League.class);\n   394→            Root<League> leagueRoot = cq.from(League.class);\n   395→            Join<League, Team> team = leagueRoot.join(\"teams\");\n   396→            Join<Team, Player> player = team.join(\"players\");\n   397→            cq.where(cb.equal(player.get(\"id\"), playerId));\n   398→            cq.select(leagueRoot).distinct(true);\n   399→            TypedQuery<League> q = em.createQuery(cq);\n   400→            List<League> leagues = q.getResultList();\n   401→            if (leagues == null || leagues.isEmpty()) {\n   402→                logger.warning(\"No leagues found for player with ID \" + playerId);\n   403→                return null;\n   404→            }\n   405→            for (League currentLeague : leagues) {\n   406→                detailsList.add(new LeagueDetails(currentLeague.getId(), currentLeague.getName(), currentLeague.getSport()));\n   407→            }\n   408→            return detailsList;\n   409→        } catch (Exception ex) {\n   410→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   411→        }\n   412→    }\n   413→\n   414→    @Override\n   415→    @GET\n   416→    @Path(\"/player/{playerId}/sports\")\n   417→    @Produces(MediaType.APPLICATION_JSON)\n   418→    public List<String> getSportsOfPlayer(@PathParam(\"playerId\") String playerId) {\n   419→        logger.info(\"getSportsOfPlayer\");\n   420→        try {\n   421→            CriteriaBuilder cb = getCB();\n   422→            CriteriaQuery<String> cq = cb.createQuery(String.class);\n   423→            Root<Player> player = cq.from(Player.class);\n   424→            Join<Player, Team> team = player.join(\"teams\");\n   425→            Join<Team, League> league = team.join(\"league\");\n   426→            cq.where(cb.equal(player.get(\"id\"), playerId));\n   427→            cq.select(league.get(\"sport\")).distinct(true);\n   428→            TypedQuery<String> q = em.createQuery(cq);\n   429→            return q.getResultList();\n   430→        } catch (Exception ex) {\n   431→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   432→        }\n   433→    }\n   434→\n   435→    @Override\n   436→    @POST\n   437→    @Path(\"/team/league/{leagueId}\")\n   438→    @Consumes(MediaType.APPLICATION_JSON)\n   439→    @Produces(MediaType.APPLICATION_JSON)\n   440→    public void createTeamInLeague(TeamDetails teamDetails, @PathParam(\"leagueId\") String leagueId) {\n   441→        logger.info(\"createTeamInLeague\");\n   442→        try {\n   443→            League league = em.find(League.class, leagueId);\n   444→            if (league == null) {\n   445→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   446→            }\n   447→            Team team = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   448→            em.persist(team);\n   449→            team.setLeague(league);\n   450→            league.addTeam(team);\n   451→            em.merge(league);\n   452→            em.flush();\n   453→        } catch (Exception ex) {\n   454→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   455→        }\n   456→    }\n   457→\n   458→    @Override\n   459→    @DELETE\n   460→    @Path(\"/team/{teamId}\")\n   461→    @Produces(MediaType.APPLICATION_JSON)\n   462→    public void removeTeam(@PathParam(\"teamId\") String teamId) {\n   463→        logger.info(\"removeTeam\");\n   464→        try {\n   465→            Team team = em.find(Team.class, teamId);\n   466→            if (team == null) {\n   467→                throw new WebApplicationException(\"Team not found\", Response.Status.NOT_FOUND);\n   468→            }\n   469→            for (Player player : team.getPlayers()) {\n   470→                player.dropTeam(team);\n   471→                em.merge(player);\n   472→            }\n   473→            em.remove(team);\n   474→            em.flush();\n   475→        } catch (Exception ex) {\n   476→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   477→        }\n   478→    }\n   479→\n   480→    @Override\n   481→    @GET\n   482→    @Path(\"/team/{teamId}\")\n   483→    @Produces(MediaType.APPLICATION_JSON)\n   484→    public TeamDetails getTeam(@PathParam(\"teamId\") String teamId) {\n   485→        logger.info(\"getTeam\");\n   486→        try {\n   487→            Team team = em.find(Team.class, teamId);\n   488→            if (team == null) {\n   489→                throw new WebApplicationException(\"Team not found\", Response.Status.NOT_FOUND);\n   490→            }\n   491→            return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   492→        } catch (Exception ex) {\n   493→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   494→        }\n   495→    }\n   496→\n   497→    @Override\n   498→    @POST\n   499→    @Path(\"/league\")\n   500→    @Consumes(MediaType.APPLICATION_JSON)\n   501→    @Produces(MediaType.APPLICATION_JSON)\n   502→    public void createLeague(LeagueDetails leagueDetails) {\n   503→        logger.info(\"createLeague\");\n   504→        try {\n   505→            String sport = leagueDetails.getSport().toLowerCase();\n   506→            if (sport.equals(\"soccer\") || sport.equals(\"swimming\") || sport.equals(\"basketball\") || sport.equals(\"baseball\")) {\n   507→                SummerLeague league = new SummerLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   508→                em.persist(league);\n   509→                em.flush();\n   510→            } else if (sport.equals(\"hockey\") || sport.equals(\"skiing\") || sport.equals(\"snowboarding\")) {\n   511→                WinterLeague league = new WinterLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   512→                em.persist(league);\n   513→                em.flush();\n   514→            } else {\n   515→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   516→            }\n   517→        } catch (Exception ex) {\n   518→            throw new WebApplicationException(ex, Response.Status.BAD_REQUEST);\n   519→        }\n   520→    }\n   521→\n   522→    @Override\n   523→    @DELETE\n   524→    @Path(\"/league/{leagueId}\")\n   525→    @Produces(MediaType.APPLICATION_JSON)\n   526→    public void removeLeague(@PathParam(\"leagueId\") String leagueId) {\n   527→        logger.info(\"removeLeague\");\n   528→        try {\n   529→            League league = em.find(League.class, leagueId);\n   530→            if (league == null) {\n   531→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   532→            }\n   533→            em.remove(league);\n   534→            em.flush();\n   535→        } catch (Exception ex) {\n   536→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   537→        }\n   538→    }\n   539→\n   540→    @Override\n   541→    @GET\n   542→    @Path(\"/league/{leagueId}\")\n   543→    @Produces(MediaType.APPLICATION_JSON)\n   544→    public LeagueDetails getLeague(@PathParam(\"leagueId\") String leagueId) {\n   545→        logger.info(\"getLeague\");\n   546→        try {\n   547→            League league = em.find(League.class, leagueId);\n   548→            if (league == null) {\n   549→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   550→            }\n   551→            return new LeagueDetails(league.getId(), league.getName(), league.getSport());\n   552→        } catch (Exception ex) {\n   553→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   554→        }\n   555→    }\n   556→\n   557→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   558→        List<PlayerDetails> detailsList = new ArrayList<>();\n   559→        for (Player player : players) {\n   560→            detailsList.add(new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary()));\n   561→        }\n   562→        return detailsList;\n   563→    }\n   564→}\n   565→"}]},"parent_tool_use_id":null,"session_id":"831f66ff-c9ae-4571-b43b-fbfb1716cdb8","uuid":"4bf7c4f3-ea5b-41aa-9cc4-13bedd06d17f"}
