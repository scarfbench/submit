            Player player = em.find(Player.class, playerId);\n    85→            Team team = em.find(Team.class, teamId);\n    86→            if (player == null || team == null) {\n    87→                throw new WebApplicationException(\"Player or Team not found\", Response.Status.NOT_FOUND);\n    88→            }\n    89→            team.addPlayer(player);\n    90→            player.addTeam(team);\n    91→            em.merge(player);\n    92→            em.merge(team);\n    93→            em.flush();\n    94→        } catch (Exception ex) {\n    95→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n    96→        }\n    97→    }\n    98→\n    99→    @Override\n   100→    @DELETE\n   101→    @Path(\"/player/{playerId}\")\n   102→    @Produces(MediaType.APPLICATION_JSON)\n   103→    public void removePlayer(@PathParam(\"playerId\") String playerId) {\n   104→        logger.info(\"removePlayer\");\n   105→        try {\n   106→            Player player = em.find(Player.class, playerId);\n   107→            if (player == null) {\n   108→                throw new WebApplicationException(\"Player not found\", Response.Status.NOT_FOUND);\n   109→            }\n   110→            Collection<Team> teams = player.getTeams();\n   111→            for (Team team : teams) {\n   112→                team.dropPlayer(player);\n   113→            }\n   114→            em.remove(player);\n   115→            em.flush();\n   116→        } catch (Exception ex) {\n   117→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   118→        }\n   119→    }\n   120→\n   121→    @Override\n   122→    @DELETE\n   123→    @Path(\"/player/{playerId}/team/{teamId}\")\n   124→    @Produces(MediaType.APPLICATION_JSON)\n   125→    public void dropPlayer(@PathParam(\"playerId\") String playerId, @PathParam(\"teamId\") String teamId) {\n   126→        logger.info(\"dropPlayer\");\n   127→        try {\n   128→            Player player = em.find(Player.class, playerId);\n   129→            Team team = em.find(Team.class, teamId);\n   130→            if (player == null || team == null) {\n   131→                throw new WebApplicationException(\"Player or Team not found\", Response.Status.NOT_FOUND);\n   132→            }\n   133→            team.dropPlayer(player);\n   134→            player.dropTeam(team);\n   135→            em.merge(player);\n   136→            em.merge(team);\n   137→            em.flush();\n   138→        } catch (Exception ex) {\n   139→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   140→        }\n   141→    }\n   142→\n   143→    @Override\n   144→    @GET\n   145→    @Path(\"/player/{playerId}\")\n   146→    @Produces(MediaType.APPLICATION_JSON)\n   147→    public PlayerDetails getPlayer(@PathParam(\"playerId\") String playerId) {\n   148→        logger.info(\"getPlayerDetails\");\n   149→        try {\n   150→            Player player = em.find(Player.class, playerId);\n   151→            if (player == null) {\n   152→                throw new WebApplicationException(\"Player not found\", Response.Status.NOT_FOUND);\n   153→            }\n   154→            return new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary());\n   155→        } catch (Exception ex) {\n   156→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   157→        }\n   158→    }\n   159→\n   160→    @Override\n   161→    @GET\n   162→    @Path(\"/team/{teamId}/players\")\n   163→    @Produces(MediaType.APPLICATION_JSON)\n   164→    public List<PlayerDetails> getPlayersOfTeam(@PathParam(\"teamId\") String teamId) {\n   165→        logger.info(\"getPlayersOfTeam\");\n   166→        try {\n   167→            Team team = em.find(Team.class, teamId);\n   168→            if (team == null) {\n   169→                throw new WebApplicationException(\"Team not found\", Response.Status.NOT_FOUND);\n   170→            }\n   171→            return copyPlayersToDetails(new ArrayList<>(team.getPlayers()));\n   172→        } catch (Exception ex) {\n   173→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   174→        }\n   175→    }\n   176→\n   177→    @Override\n   178→    @GET\n   179→    @Path(\"/league/{leagueId}/teams\")\n   180→    @Produces(MediaType.APPLICATION_JSON)\n   181→    public List<TeamDetails> getTeamsOfLeague(@PathParam(\"leagueId\") String leagueId) {\n   182→        logger.info(\"getTeamsOfLeague\");\n   183→        List<TeamDetails> detailsList = new ArrayList<>();\n   184→        try {\n   185→            League league = em.find(League.class, leagueId);\n   186→            if (league == null) {\n   187→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   188→            }\n   189→            for (Team team : league.getTeams()) {\n   190→                detailsList.add(new TeamDetails(team.getId(), team.getName(), team.getCity()));\n   191→            }\n   192→            return detailsList;\n   193→        } catch (Exception ex) {\n   194→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   195→        }\n   196→    }\n   197→\n   198→    @Override\n   199→    @GET\n   200→    @Path(\"/players/position/{position}\")\n   201→    @Produces(MediaType.APPLICATION_JSON)\n   202→    public List<PlayerDetails> getPlayersByPosition(@PathParam(\"position\") String position) {\n   203→        logger.info(\"getPlayersByPosition\");\n   204→        try {\n   205→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   206→            Root<Player> player = cq.from(Player.class);\n   207→            cq.where(cb.equal(player.get(Player_.position), position));\n   208→            cq.select(player);\n   209→            TypedQuery<Player> q = em.createQuery(cq);\n   210→            List<Player> players = q.getResultList();\n   211→            return copyPlayersToDetails(players);\n   212→        } catch (Exception ex) {\n   213→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   214→        }\n   215→    }\n   216→\n   217→    @Override\n   218→    @GET\n   219→    @Path(\"/players/salary/higher/{name}\")\n   220→    @Produces(MediaType.APPLICATION_JSON)\n   221→    public List<PlayerDetails> getPlayersByHigherSalary(@PathParam(\"name\") String name) {\n   222→        logger.info(\"getPlayersByHigherSalary\");\n   223→        try {\n   224→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   225→            Root<Player> player1 = cq.from(Player.class);\n   226→            Root<Player> player2 = cq.from(Player.class);\n   227→            Predicate gtPredicate = cb.greaterThan(player1.get(Player_.salary), player2.get(Player_.salary));\n   228→            Predicate equalPredicate = cb.equal(player2.get(Player_.name), name);\n   229→            cq.where(gtPredicate, equalPredicate);\n   230→            cq.select(player1).distinct(true);\n   231→            TypedQuery<Player> q = em.createQuery(cq);\n   232→            List<Player> players = q.getResultList();\n   233→            return copyPlayersToDetails(players);\n   234→        } catch (Exception ex) {\n   235→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   236→        }\n   237→    }\n   238→\n   239→    @Override\n   240→    @GET\n   241→    @Path(\"/players/salary/range\")\n   242→    @Produces(MediaType.APPLICATION_JSON)\n   243→    public List<PlayerDetails> getPlayersBySalaryRange(@QueryParam(\"low\") double low, @QueryParam(\"high\") double high) {\n   244→        logger.info(\"getPlayersBySalaryRange\");\n   245→        try {\n   246→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   247→            Root<Player> player = cq.from(Player.class);\n   248→         