r = cq.from(Player.class);\n   288→            Join<Player, Team> team = player.join(Player_.teams);\n   289→            Join<Team, League> league = team.join(Team_.league);\n   290→            cq.where(cb.equal(league.get(League_.sport), sport));\n   291→            cq.select(player).distinct(true);\n   292→            TypedQuery<Player> q = em.createQuery(cq);\n   293→            List<Player> players = q.getResultList();\n   294→            return copyPlayersToDetails(players);\n   295→        } catch (Exception ex) {\n   296→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   297→        }\n   298→    }\n   299→\n   300→    @Override\n   301→    @GET\n   302→    @Path(\"/players/city/{city}\")\n   303→    @Produces(MediaType.APPLICATION_JSON)\n   304→    public List<PlayerDetails> getPlayersByCity(@PathParam(\"city\") String city) {\n   305→        logger.info(\"getPlayersByCity\");\n   306→        try {\n   307→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   308→            Root<Player> player = cq.from(Player.class);\n   309→            Join<Player, Team> team = player.join(Player_.teams);\n   310→            cq.where(cb.equal(team.get(Team_.city), city));\n   311→            cq.select(player).distinct(true);\n   312→            TypedQuery<Player> q = em.createQuery(cq);\n   313→            List<Player> players = q.getResultList();\n   314→            return copyPlayersToDetails(players);\n   315→        } catch (Exception ex) {\n   316→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   317→        }\n   318→    }\n   319→\n   320→    @Override\n   321→    @GET\n   322→    @Path(\"/players\")\n   323→    @Produces(MediaType.APPLICATION_JSON)\n   324→    public List<PlayerDetails> getAllPlayers() {\n   325→        logger.info(\"getAllPlayers\");\n   326→        try {\n   327→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   328→            Root<Player> player = cq.from(Player.class);\n   329→            cq.select(player);\n   330→            TypedQuery<Player> q = em.createQuery(cq);\n   331→            List<Player> players = q.getResultList();\n   332→            return copyPlayersToDetails(players);\n   333→        } catch (Exception ex) {\n   334→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   335→        }\n   336→    }\n   337→\n   338→    @Override\n   339→    @GET\n   340→    @Path(\"/players/not-on-team\")\n   341→    @Produces(MediaType.APPLICATION_JSON)\n   342→    public List<PlayerDetails> getPlayersNotOnTeam() {\n   343→        logger.info(\"getPlayersNotOnTeam\");\n   344→        try {\n   345→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   346→            Root<Player> player = cq.from(Player.class);\n   347→            cq.where(cb.isEmpty(player.get(Player_.teams)));\n   348→            cq.select(player).distinct(true);\n   349→            TypedQuery<Player> q = em.createQuery(cq);\n   350→            List<Player> players = q.getResultList();\n   351→            return copyPlayersToDetails(players);\n   352→        } catch (Exception ex) {\n   353→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   354→        }\n   355→    }\n   356→\n   357→    @Override\n   358→    @GET\n   359→    @Path(\"/players/position/{position}/name/{name}\")\n   360→    @Produces(MediaType.APPLICATION_JSON)\n   361→    public List<PlayerDetails> getPlayersByPositionAndName(\n   362→            @PathParam(\"position\") String position,\n   363→            @PathParam(\"name\") String name) {\n   364→        logger.info(\"getPlayersByPositionAndName\");\n   365→        try {\n   366→            CriteriaQuery<Player> cq = cb.createQuery(Player.class);\n   367→            Root<Player> player = cq.from(Player.class);\n   368→            cq.where(cb.equal(player.get(Player_.position), position),\n   369→                    cb.equal(player.get(Player_.name), name));\n   370→            cq.select(player).distinct(true);\n   371→            TypedQuery<Player> q = em.createQuery(cq);\n   372→            List<Player> players = q.getResultList();\n   373→            return copyPlayersToDetails(players);\n   374→        } catch (Exception ex) {\n   375→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   376→        }\n   377→    }\n   378→\n   379→    @Override\n   380→    @GET\n   381→    @Path(\"/player/{playerId}/leagues\")\n   382→    @Produces(MediaType.APPLICATION_JSON)\n   383→    public List<LeagueDetails> getLeaguesOfPlayer(@PathParam(\"playerId\") String playerId) {\n   384→        logger.info(\"getLeaguesOfPlayer\");\n   385→        List<LeagueDetails> detailsList = new ArrayList<>();\n   386→        try {\n   387→            CriteriaQuery<League> cq = cb.createQuery(League.class);\n   388→            Root<League> leagueRoot = cq.from(League.class);\n   389→            Join<League, Team> team = leagueRoot.join(League_.teams);\n   390→            Join<Team, Player> player = team.join(Team_.players);\n   391→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   392→            cq.select(leagueRoot).distinct(true);\n   393→            TypedQuery<League> q = em.createQuery(cq);\n   394→            List<League> leagues = q.getResultList();\n   395→            if (leagues == null || leagues.isEmpty()) {\n   396→                logger.warning(\"No leagues found for player with ID \" + playerId);\n   397→                return null;\n   398→            }\n   399→            for (League currentLeague : leagues) {\n   400→                detailsList.add(new LeagueDetails(currentLeague.getId(), currentLeague.getName(), currentLeague.getSport()));\n   401→            }\n   402→            return detailsList;\n   403→        } catch (Exception ex) {\n   404→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   405→        }\n   406→    }\n   407→\n   408→    @Override\n   409→    @GET\n   410→    @Path(\"/player/{playerId}/sports\")\n   411→    @Produces(MediaType.APPLICATION_JSON)\n   412→    public List<String> getSportsOfPlayer(@PathParam(\"playerId\") String playerId) {\n   413→        logger.info(\"getSportsOfPlayer\");\n   414→        try {\n   415→            CriteriaQuery<String> cq = cb.createQuery(String.class);\n   416→            Root<Player> player = cq.from(Player.class);\n   417→            Join<Player, Team> team = player.join(Player_.teams);\n   418→            Join<Team, League> league = team.join(Team_.league);\n   419→            cq.where(cb.equal(player.get(Player_.id), playerId));\n   420→            cq.select(league.get(League_.sport)).distinct(true);\n   421→            TypedQuery<String> q = em.createQuery(cq);\n   422→            return q.getResultList();\n   423→        } catch (Exception ex) {\n   424→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   425→        }\n   426→    }\n   427→\n   428→    @Override\n   429→    @POST\n   430→    @Path(\"/team/league/{leagueId}\")\n   431→    @Consumes(MediaType.APPLICATION_JSON)\n   432→    @Produces(MediaType.APPLICATION_JSON)\n   433→    public void createTeamInLeague(TeamDetails teamDetails, @PathParam(\"leagueId\") String leagueId) {\n   434→        logger.info(\"createTeamInLeague\");\n   435→        try {\n   436→            League league = em.find(League.class, leagueId);\n   437→            if (league == null) {\n   438→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   439→            }\n   440→            Team team = new Team(teamDetails.getId(), teamDetails.getName(), teamDetails.getCity());\n   441→            em.persist(team);\n   442→            team.setLeague(league);\n   443→            league.addTeam(team);\n   444→            em.merge(league);\n   445→            em.flush();\n   446→        } catch (Exception ex) {\n   447→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   448→        }\n   449→    }\n   450→\n   451→    @Override\n   452→    @DELETE\n   453→    @Path(\"/team/{teamId}\")\n   454→    @Produces(MediaType.APPLICATION_JSON)\n   455→    public void removeTeam(@PathParam(\"teamId\") String teamId) {\n   456→        logger.info(\"removeTeam\");\n   457→        try {\n   458→            Team team = em.find(Team.class, teamId);\n   459→            if (team == null) {\n   460→                throw new WebApplicationException(\"Team not found\", Response.Status.NOT_FOUND);\n   461→            }\n   462→            for (Player player : team.getPlayers()) {\n   463→                player.dropTeam(team);\n   464→                em.merge(player);\n   465→            }\n   466→            em.remove(team);\n   467→            em.flush();\n   468→        } catch (Exception ex) {\n   469→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   470→        }\n   471→    }\n   472→\n   473→    @Override\n   474→    @GET\n   475→    @Path(\"/team/{teamId}\")\n   476→    @Produces(MediaType.APPLICATION_JSON)\n   477→    public TeamDetails getTeam(@PathParam(\"teamId\") String teamId) {\n   478→        logger.info(\"getTeam\");\n   479→        try {\n   480→            Team team = em.find(Team.class, teamId);\n   481→            if (team == null) {\n   482→                throw new WebApplicationException(\"Team not found\", Response.Status.NOT_FOUND);\n   483→            }\n   484→            return new TeamDetails(team.getId(), team.getName(), team.getCity());\n   485→        } catch (Exception ex) {\n   486→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   487→        }\n   488→    }\n   489→\n   490→    @Override\n   491→    @POST\n   492→    @Path(\"/league\")\n   493→    @Consumes(MediaType.APPLICATION_JSON)\n   494→    @Produces(MediaType.APPLICATION_JSON)\n   495→    public void createLeague(LeagueDetails leagueDetails) {\n   496→        logger.info(\"createLeague\");\n   497→        try {\n   498→            String sport = leagueDetails.getSport().toLowerCase();\n   499→            if (sport.equals(\"soccer\") || sport.equals(\"swimming\") || sport.equals(\"basketball\") || sport.equals(\"baseball\")) {\n   500→                SummerLeague league = new SummerLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   501→                em.persist(league);\n   502→                em.flush();\n   503→            } else if (sport.equals(\"hockey\") || sport.equals(\"skiing\") || sport.equals(\"snowboarding\")) {\n   504→                WinterLeague league = new WinterLeague(leagueDetails.getId(), leagueDetails.getName(), leagueDetails.getSport());\n   505→                em.persist(league);\n   506→                em.flush();\n   507→            } else {\n   508→                throw new IncorrectSportException(\"The specified sport is not valid.\");\n   509→            }\n   510→        } catch (Exception ex) {\n   511→            throw new WebApplicationException(ex, Response.Status.BAD_REQUEST);\n   512→        }\n   513→    }\n   514→\n   515→    @Override\n   516→    @DELETE\n   517→    @Path(\"/league/{leagueId}\")\n   518→    @Produces(MediaType.APPLICATION_JSON)\n   519→    public void removeLeague(@PathParam(\"leagueId\") String leagueId) {\n   520→        logger.info(\"removeLeague\");\n   521→        try {\n   522→            League league = em.find(League.class, leagueId);\n   523→            if (league == null) {\n   524→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   525→            }\n   526→            em.remove(league);\n   527→            em.flush();\n   528→        } catch (Exception ex) {\n   529→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   530→        }\n   531→    }\n   532→\n   533→    @Override\n   534→    @GET\n   535→    @Path(\"/league/{leagueId}\")\n   536→    @Produces(MediaType.APPLICATION_JSON)\n   537→    public LeagueDetails getLeague(@PathParam(\"leagueId\") String leagueId) {\n   538→        logger.info(\"getLeague\");\n   539→        try {\n   540→            League league = em.find(League.class, leagueId);\n   541→            if (league == null) {\n   542→                throw new WebApplicationException(\"League not found\", Response.Status.NOT_FOUND);\n   543→            }\n   544→            return new LeagueDetails(league.getId(), league.getName(), league.getSport());\n   545→        } catch (Exception ex) {\n   546→            throw new WebApplicationException(ex, Response.Status.INTERNAL_SERVER_ERROR);\n   547→        }\n   548→    }\n   549→\n   550→    private List<PlayerDetails> copyPlayersToDetails(List<Player> players) {\n   551→        List<PlayerDetails> detailsList = new ArrayList<>();\n   552→        for (Player player : players) {\n   553→            detailsList.add(new PlayerDetails(player.getId(), player.getName(), player.getPosition(), player.getSalary()));\n   554→        }\n   555→        return detailsList;\n   556→    }\n   557→}\n   558→"}]},"parent_tool_use_id":null,"session_id":"98f0c157-25c8-4522-ad5d-c073f4a9b639","uuid":"c0a22379-d1fd-435a-bbcf-8bc06759fe6b"}
