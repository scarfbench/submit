→    <!-- RESTEasy for JAX-RS endpoints -->\n    39→    <dependency>\n    40→      <groupId>io.quarkus</groupId>\n    41→      <artifactId>quarkus-resteasy-reactive</artifactId>\n    42→    </dependency>\n    43→    <dependency>\n    44→      <groupId>io.quarkus</groupId>\n    45→      <artifactId>quarkus-resteasy-reactive-jackson</artifactId>\n    46→    </dependency>\n    47→\n    48→    <!-- Qute templating engine -->\n    49→    <dependency>\n    50→      <groupId>io.quarkus</groupId>\n    51→      <artifactId>quarkus-resteasy-reactive-qute</artifactId>\n    52→    </dependency>\n    53→\n    54→    <!-- Hibernate ORM -->\n    55→    <dependency>\n    56→      <groupId>io.quarkus</groupId>\n    57→      <artifactId>quarkus-hibernate-orm</artifactId>\n    58→    </dependency>\n    59→\n    60→    <!-- H2 Database -->\n    61→    <dependency>\n    62→      <groupId>io.quarkus</groupId>\n    63→      <artifactId>quarkus-jdbc-h2</artifactId>\n    64→    </dependency>\n    65→\n    66→    <!-- Bean validation -->\n    67→    <dependency>\n    68→      <groupId>io.quarkus</groupId>\n    69→      <artifactId>quarkus-hibernate-validator</artifactId>\n    70→    </dependency>\n    71→\n    72→    <!-- Health check / actuator equivalent -->\n    73→    <dependency>\n    74→      <groupId>io.quarkus</groupId>\n    75→      <artifactId>quarkus-smallrye-health</artifactId>\n    76→    </dependency>\n    77→\n    78→    <!-- JAXB for XML annotations -->\n    79→    <dependency>\n    80→      <groupId>jakarta.xml.bind</groupId>\n    81→      <artifactId>jakarta.xml.bind-api</artifactId>\n    82→    </dependency>\n    83→    <dependency>\n    84→      <groupId>org.glassfish.jaxb</groupId>\n    85→      <artifactId>jaxb-runtime</artifactId>\n    86→    </dependency>\n    87→\n    88→    <!-- Test dependencies -->\n    89→    <dependency>\n    90→      <groupId>io.quarkus</groupId>\n    91→      <artifactId>quarkus-junit5</artifactId>\n    92→      <scope>test</scope>\n    93→   