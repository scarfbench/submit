"cache_creation_input_tokens":5185,"cache_read_input_tokens":56743,"cache_creation":{"ephemeral_5m_input_tokens":5185,"ephemeral_1h_input_tokens":0},"output_tokens":1016},"context_management":null},"parent_tool_use_id":null,"session_id":"86a09403-f8e6-4dd1-bd75-9998012ce328","uuid":"91312f6f-42b6-40be-a685-8309b493b293"}
