-->\n    39→    <dependency>\n    40→      <groupId>io.quarkus</groupId>\n    41→      <artifactId>quarkus-rest-jackson</artifactId>\n    42→    </dependency>\n    43→\n    44→    <!-- Qute templating -->\n    45→    <dependency>\n    46→      <groupId>io.quarkus</groupId>\n    47→      <artifactId>quarkus-rest-qute</artifactId>\n    48→    </dependency>\n    49→\n    50→    <!-- Hibernate ORM -->\n    51→    <dependency>\n    52→      <groupId>io.quarkus</groupId>\n    53→      <artifactId>quarkus-hibernate-orm</artifactId>\n    54→    </dependency>\n    55→\n    56→    <!-- H2 Database -->\n    57→    <dependency>\n    58→      <groupId>io.quarkus</groupId>\n    59→      <artifactId>quarkus-jdbc-h2</artifactId>\n    60→    </dependency>\n    61→\n    62→    <!-- Hibernate Validator -->\n    63→    <dependency>\n    64→      <groupId>io.quarkus</groupId>\n    65→      <artifactId>quarkus-hibernate-validator</artifactId>\n    66→    </dependency>\n    67→\n    68→    <!-- Quarkus Arc (CDI) -->\n    69→    <dependency>\n    70→      <groupId>io.quarkus</groupId>\n    71→      <artifactId>quarkus-arc</artifactId>\n    72→    </dependency>\n    73→\n    74→    <!-- Health checks -->\n    75→    <dependency>\n    76→      <groupId>io.quarkus</groupId>\n    77→      <artifactId>quarkus-smallrye-health</artifactId>\n    78→    </dependency>\n    79→\n    80→    <!-- Quarkus Cache -->\n    81→    <dependency>\n    82→      <groupId>io.quarkus</groupId>\n    83→      <artifactId>quarkus-cache</artifactId>\n    84→    </dependency>\n    85→\n    86→    <!-- JAXB for XML binding annotations used in Vet/Vets -->\n    87→    <dependency>\n    88→      <groupId>jakarta.xml.bind</groupId>\n    89→      <artifactId>jakarta.xml.bind-api</artifactId>\n    90→    </dependency>\n    91→\n    92→    <!-- Test dependencies -->\n    93→    <dependency>\n    94→      <groupId>io.quarkus</groupId>\n    95→      <artifactId>quarkus-junit5</artifactId>\n    96→      <scope>test</scope>\n    