he_creation":{"ephemeral_5m_input_tokens":4696,"ephemeral_1h_input_tokens":0},"output_tokens":651},"context_management":null},"parent_tool_use_id":null,"session_id":"989b6ec8-5330-484b-9e5f-c61fa819ffe2","uuid":"5f8a5680-bd00-430b-a0dc-245a4969737f"}
